           first_mismatch_displayed = 1;
           $display("Mismatch detected at time %t", $time);
           $display("\nLast %0d cycles of simulation:", in_queue.size());
           for (int i = 0; i < in_queue.size(); i++) begin
               if (got_output_queue[i] === golden_queue[i]) begin
                   $display("Got Match at");
               end else begin
