// Reference Module Implementation to make TB runnable
module RefModule (
    input  logic [7:0] in,
    output logic [2:0] pos
);
    always_comb begin
        pos = 3'd0;
        for (int i = 0; i < 8; i++) begin
            if (in[i]) begin
                pos = i[2:0];
                break;
            end
        end
    end
endmodule

module stimulus_gen (
    input clk,
    output logic [7:0] in, 
    output logic [511:0] wavedrom_title,
    output logic wavedrom_enable    
);

    task wavedrom_start(input[511:0] title = "");
    endtask
    
    task wavedrom_stop;
        #1;
    endtask    

    initial begin
        @(negedge clk) wavedrom_start("Priority encoder");
            @(posedge clk) in <= 8'h1;
            repeat(8) @(posedge clk) in <= in << 1;
            in <= 8'h10;
            repeat(8) @(posedge clk) in <= in + 1;
        @(negedge clk) wavedrom_stop();

        repeat(50) @(posedge clk, negedge clk) begin
            in <= $urandom;
        end
        repeat(260) @(posedge clk, negedge clk) begin
            in <= in + 1;
        end
        $finish;
    end
    
endmodule

module tb();

