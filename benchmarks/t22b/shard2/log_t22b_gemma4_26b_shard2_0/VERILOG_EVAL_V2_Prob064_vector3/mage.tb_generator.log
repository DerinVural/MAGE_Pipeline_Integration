   logic [4:0] a, b, c, d, e, f;\n    logic [7:0] w_ref, w_dut;\n    logic [7:0] x_ref, x_dut;\n    logic [7:0] y_ref, y_dut;\n    logic [7:0] z_ref, z_dut;\n\n    initial begin \n        $dumpfile(\"wave.vcd\");\n        $dumpvars(1, stim1.clk, tb_mismatch, a, b, c, d, e, f, w_ref, w_dut, x_ref, x_dut, y_ref, y_dut, z_ref, z_dut);\n    end\n\n    wire tb_match;\n    wire tb_mismatch = ~tb_match;\n    \n    stimulus_gen stim1 (\n        .clk,\n        .a, .b, .c, .d, .e, .f,\n        .wavedrom_title,\n        .wavedrom_enable\n    );\n\n    RefModule good1 (\n        .a, .b, .c, .d, .e, .f,\n        .w(w_ref), .x(x_ref), .y(y_ref), .z(z_ref)\n    );\n        \n    TopModule top_module1 (\n        .a, .b, .c, .d, .e, .f,\n        .w(w_dut), .x(x_dut), .y(y_dut), .z(z_dut)\n    );\n\n    assign tb_match = ( { w_ref, x_ref, y_ref, z_ref } === ( { w_ref, x_ref, y_ref, z_ref } ^ { w_dut, x_dut, y_dut, z_dut } ^ { w_ref, x_ref, y_ref, z_ref } ) );\n\n    // Combinational logic mismatch detection\n    // We sample at the edges to capture the state of the combinational logic\n    always @(posedge clk, negedge clk) begin\n        stats1.clocks++;\n        if (!tb_match) begin\n            if (stats1.errors == 0) begin\n                stats1.errortime = $time;\n                $display(\"\\n[FIRST MISMATCH DETECTED at %0t]\\n\", $time);\n                $display(\"Inputs: a=%h(%b), b=%h(%b), c=%h(%b), d=%h(%b), e=%h(%b), f=%h(%b)\", \n                    a,a,b,b,c,c,d,d,e,e,f,f);\n                $display(\"Outputs Got: w=%h(%b), x=%h(%b), y=%h(%b), z=%h(%b)\", \n                    w_dut,w_dut,x_dut,x_dut,y_dut,y_dut,z_dut,z_dut);\n                $display(\"Outputs Exp: w=%h(%b), x=%h(%b), y=%h(%b), z=%h(%b)\", \n                    w_ref,w_ref,x_ref,x_ref,y_ref,y_ref,z_ref,z_ref);\n            end\n            stats1.errors++;\n        end\n\n        if (w_ref !== ( w_ref ^ w_dut ^ w_ref )) begin \n            if (stats1.errors_w == 0) stats1.errortime_w = $time;\n       