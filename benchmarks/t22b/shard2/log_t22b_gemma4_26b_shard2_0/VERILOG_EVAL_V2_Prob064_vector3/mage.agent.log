module RefModule (
    input logic [4:0] a, b, c, d, e, f,
    output logic [7:0] w, x, y, z
);
    // Concatenate 30 bits + 2 bits = 32 bits. Split into four 8-bit vectors.
    // Note: The spec says 30 bits input + two 1 bits in LSB = 32 bits.
    // Input bits: a[4:0], b[4:0], c[4:0], d[4:0], e[4:0], f[4:0]
    // Total bits = 30. Adding two 1s at LSB = 32.
    // Pattern: {a,b,c,d,e,f, 2'b11}
    logic [31:0] combined;
    assign combined = {a, b, c, d, e, f, 2'b11};
    assign {w, x, y, z} = combined;
endmodule

