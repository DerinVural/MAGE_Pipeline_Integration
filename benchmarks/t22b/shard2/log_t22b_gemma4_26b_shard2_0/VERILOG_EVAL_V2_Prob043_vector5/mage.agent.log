[2026-05-13 11:54:47,636 - mage.agent - INFO] module TopModule (
    input  logic a,
    input  logic b,
    input  logic c,
    input  logic d,
    input  logic e,
    output logic [24:0] out
);

    // The output is 25 bits representing all pairwise comparisons.
    // The mapping is derived from the spec: 
    // out[24...20] are comparisons with 'a'
    // out[19...15] are comparisons with 'b'
    // out[14...10] are comparisons with 'c'
    // out[9...5]   are comparisons with 'd'
    // out[4...0]   are comparisons with 'e'

    always @(*) begin
        out[24] = ~(a ^ a);
        out[23] = ~(a ^ b);
        out[22] = ~(a ^ c);
        out[21] = ~(a ^ d);
        out[20] = ~(a ^ e);

        out[19] = ~(b ^ a);
        out[18] = ~(b ^ b);
        out[17] = ~(b ^ c);
        out[16] = ~(b ^ d);
        out[15] = ~(b ^ e);

        out[14] = ~(c ^ a);
        out[13] = ~(c ^ b);
        out[12] = ~(c ^ c);
        out[11] = ~(c ^ d);
        out[10] = ~(c ^ e);

        out[9]  = ~(d ^ a);
        out[8]  = ~(d ^ b);
        out[7]  = ~(d ^ c);
        out[6]  = ~(d ^ d);
        out[5]  = ~(d ^ e);

        out[4]  = ~(e ^ a);
        out[3]  = ~(e ^ b);
        out[2]  = ~(e ^ c);
        out[1]  = ~(e ^ d);
        out[0]  = ~(e ^ e);
    end

endmodule
