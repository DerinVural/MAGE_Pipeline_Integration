module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_q;
		int errortime_q;

		int clocks;
	} stats;
	
	stats stats1;
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic [7:0] d;
	logic areset;
	logic [7:0] q_ref;
	logic [7:0] q_dut;

	// Queue for error reporting
	localparam MAX_QUEUE_SIZE = 10;
	logic clk_q [$];
	logic areset_q [$];
	logic [7:0] d_q [$];
	logic [7:0] q_ref_q [$];
	logic [7:0] q_dut_q [$];

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,clk,d,areset,q_ref,q_dut );
	end

	wire tb_match;      // Verification
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk,
		.* ,
		.d,
		.areset );
	RefModule good1 (
		.clk,
		.d,
		.areset,
		.q(q_ref) );
		
	TopModule top_module1 (
		.clk,
		.d,
		.areset,
		.q(q_dut) );

	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
			strobe <= !strobe;  // Try to delay until the very end of the time step.
			@(strobe);
		end;
	endtask	

	final begin
		if (stats1.errors_q) begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_q, stats1.errortime_q);
			$display("Hint: Output 'q' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_q, stats1.errortime_q);
		end else begin
			$display("SIMULATION PASSED");
			$display("Hint: Output 'q' has no mismatches.");
		end

		$display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
		$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
	end
	
	assign tb_match = ( { q_ref } === ( { q_ref } ^ { q_dut } ^ { q_ref } ) );

	always @(posedge clk, negedge clk) begin
		// Manage Queue
		if (clk_q.size() >= MAX_QUEUE_SIZE) begin
			clk_q.delete(0);
			areset_q.delete(0);
			d_q.delete(0);
			q_ref_q.delete(0);
			q_dut_q.delete(0);
		end
		if (tb_match || areset) begin // Only push relevant data when not in reset or if we want to track reset states
			clk_q.push_back(clk);
			areset_q.push_back(areset);
			d_q.push_back(d);
			q_ref_q.push_back(q_ref);
			q_dut_q.push_back(q_dut);
		end

		// Stats and error counting
		stats1.clocks++;
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
		end

		if (q_ref !== ( q_ref ^ q_dut ^ q_ref )) begin 
			if (stats1.errors_q == 0) begin
				stats1.errortime_q = $time;
				// Display Queue on first mismatch
				$display("\n--- FIRST MISMATCH DETECTED ---");
				$display("Time: %t", $time);
				$display("Mismatching Values: Got q=%h (%b), Exp q=%h (%b)", q_dut, q_dut, q_ref, q_ref);
				$display("\nLast %0d cycles of simulation:", clk_q.size());
				for (int i = 0; i < clk_q.size(); i++) begin
					$display("Cycle %0d, reset=%b, d=%h(%b), got_q=%h(%b), exp_q=%h(%b)", 
							i, areset_q[i], d_q[i], d_q[i], q_dut_q[i], q_dut_q[i], q_ref_q[i], q_ref_q[i]);
					end;
				$display("------------------------------\n");
			end
			stats1.errors_q = stats1.errors_q + 1'b1; 
		end
	end

   // add timeout after 100K cycles
   initial begin
     #1000000
     $display("TIMEOUT");
     $finish();
   end

end
endmodule
