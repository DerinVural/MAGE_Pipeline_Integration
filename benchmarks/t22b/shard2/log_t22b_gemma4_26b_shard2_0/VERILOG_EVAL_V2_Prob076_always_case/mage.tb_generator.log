drom_title;\n    wire wavedrom_enable;\n    int wavedrom_hide_after_time;\n    \n    reg clk=0;\n    initial forever\n        #5 clk = ~clk;\n\n    logic [2:0] sel;\n    logic [3:0] data0;\n    logic [3:0] data1;\n    logic [3:0] data2;\n    logic [3:0] data3;\n    logic [3:0] data4;\n    logic [3:0] data5;\n    logic [3:0] out_ref;\n    logic [3:0] out_dut;\n\n    initial begin \n        $dumpfile(\"wave.vcd\");\n        $dumpvars(1, stim1.clk, tb_mismatch ,sel,data0,data1,data2,data3,data4,data5,out_ref,out_dut );\n    end\n\n    wire tb_match;\n    wire tb_mismatch = ~tb_match;\n    \n    stimulus_gen stim1 (\n        .clk,\n        .* ,\n        .sel,\n        .data0,\n        .data1,\n        .data2,\n        .data3,\n        .data4,\n        .data5 );\n\n    RefModule good1 (\n        .sel,\n        .data0,\n        .data1,\n        .data2,\n        .data3,\n        .data4,\n        .data5,\n        .out(out_ref) );\n        \n    TopModule top_module1 (\n        .sel,\n        .data0,\n        .data1,\n        .data2,\n        .data3,\n        .data4,\n        .data5,\n        .out(out_dut) );\n\n    bit strobe = 0;\n    task wait_for_end_of_timestep;\n        repeat(5) begin\n            strobe <= !strobe;\n            @(strobe);\n        end\n    endtask    \n\n    assign tb_match = ( { out_ref } === ( { out_ref } ^ { out_dut } ^ { out_ref } ) );\n\n    always @(posedge clk, negedge clk) begin\n        stats1.clocks++;\n        if (!tb_match) begin\n            if (stats1.errors == 0) stats1.errortime = $time;\n            stats1.errors++;\n        end\n\n        if (out_ref !== ( out_ref ^ out_dut ^ out_ref )) begin \n            if (stats1.errors_out == 0) begin\n                stats1.errortime_out = $time;\n                $display(\"FIRST MISMATCH DETECTED AT TIME %0t:\", $time);\n                $display(\"sel: %h (%b), data0: %h (%b), data1: %h (%b), data2: %h (%b), data3: %h (%b), data4: %h (%b), data5: %h (%b)\", \n                         sel, sel