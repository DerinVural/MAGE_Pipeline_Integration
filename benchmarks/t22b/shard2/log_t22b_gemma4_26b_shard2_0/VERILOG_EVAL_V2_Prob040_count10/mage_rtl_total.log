[2026-05-13 11:36:25,921 - mage.agent - INFO] `timescale 1 ps/1 ps
`define OK 12
`define INCORRECT 13

module RefModule (
    input logic clk,
    input logic reset,
    output logic [3:0] q
);
    always @(posedge clk) begin
        if (reset) q <= 4'd0;
        else q <= (q >= 4'd9) ? 4'd0 : q + 4'd1;
    end
endmodule

module stimulus_gen (
    input logic clk,
    output logic reset,
    output logic [511:0] wavedrom_title,
    output logic wavedrom_enable,
    input logic tb_match
);

    task reset_test(input bit async=0);
        bit arfail, srfail, datafail;
    
        @(posedge clk);
        @(posedge clk) reset <= 0;
        repeat(3) @(posedge clk);
    
        @(negedge clk) begin datafail = !tb_match; reset <= 1; end
        @(posedge clk) arfail = !tb_match;
        @(posedge clk) begin
            srfail = !tb_match;
            reset <= 0;
        end
        if (srfail)
            $display("Hint: Your reset doesn't seem to be working.");
        else if (arfail && (async || !datafail))
            $display("Hint: Your reset should be %s, but doesn't appear to be.", async ? "asynchronous" : "synchronous");
    endtask

    task wavedrom_start(input [511:0] title = "");
        wavedrom_enable <= 1;
        wavedrom_title <= title;
    endtask
    
    task wavedrom_stop;
        wavedrom_enable <= 0;
        #1;
    endtask

    initial begin
        reset <= 1;
        wavedrom_enable <= 0;
        wavedrom_title <= 0;
        wavedrom_start("Synchronous reset and counting");
        reset_test();
        repeat(12) @(posedge clk);
        wavedrom_stop();
        @(posedge clk);
        
        repeat(400) @(posedge clk, negedge clk) begin
            reset <= !($random & 31);
        end
        #1 $finish;
    end
endmodule

module tb;

    typedef struct packed {
        int errors;
        int errortime;
        int errors_q;
        int errortime_q;
        int clocks;
    } stats;
    
    stats stats1;
    
    wire [511:0] wavedrom_title;
    wire wavedrom_enable;
    reg clk = 0;
    initial forever #5 clk = ~clk;

    logic reset;
    logic [3:0] q_ref;
    logic [3:0] q_dut;

    // Queues for mismatch display
    logic clk_q [$];
    logic reset_q [$];
    logic [3:0] q_ref_q [$];
    logic [3:0] q_dut_q [$];
    localparam MAX_QUEUE_SIZE = 10;

    initial begin 
        $dumpfile("wave.vcd");
        $dumpvars(0, tb);
    end

    wire tb_match;
    wire tb_mismatch = ~tb_match;
    
    stimulus_gen stim1 (
        .clk,
        .reset,
        .wavedrom_title,
        .wavedrom_enable,
        .tb_match
    );

    RefModule good1 (
        .clk,
        .reset,
        .q(q_ref)
    );
        
    TopModule top_module1 (
        .clk,
        .reset,
        .q(q_dut)
    );

    assign tb_match = (q_ref === q_dut);

    always @(posedge clk, negedge clk) begin
        // Maintain Queue
        if (clk_q.size() >= MAX_QUEUE_SIZE) begin
            clk_q.delete(0);
            reset_q.delete(0);
            q_ref_q.delete(0);
            q_dut_q.delete(0);
        end
        clk_q.push_back(clk);
        reset_q.push_back(reset);
        q_ref_q.push_back(q_ref);
        q_dut_q.push_back(q_dut);

        // Error counting logic
        stats1.clocks++;
        if (!tb_match) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
            
            // Display first mismatch details
            if (stats1.errors == 1) begin
                $display("Mismatch detected at time %t", $time);
                $display("Last %0d cycles of simulation:", clk_q.size());
                for (int i = 0; i < clk_q.size(); i++) begin
                    $display("Cycle %0d, reset %b, q_ref %h (%b), q_dut %h (%b)", 
                        i, reset_q[i], q_ref_q[i], q_ref_q[i], q_dut_q[i], q_dut_q[i]);
                end
            end
        end

        if (q_ref !== q_dut) begin
            if (stats1.errors_q == 0) stats1.errortime_q = $time;
            stats1.errors_q = stats1.errors_q + 1;
        end
    end

    initial begin
        #1000000;
        $display("TIMEOUT");
        $finish();
    end

    final begin
        if (stats1.errors_q == 0) begin
            $display("SIMULATION PASSED");
        end else begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_q, stats1.errortime_q);
        end
        $display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
        $display("Simulation finished at %0d ps", $time);
    end

endmodule
