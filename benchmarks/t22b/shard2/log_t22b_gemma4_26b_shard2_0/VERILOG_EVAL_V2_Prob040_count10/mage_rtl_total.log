	endtask

	task wavedrom_start(input[511:0] title = "");
		wavedrom_enable <= 1;
		wavedrom_title <= title;
	endtask
	
	task wavedrom_stop;
		wavedrom_enable <= 0;
		#1;
	endtask	

	initial begin
		reset <= 1;
		wavedrom_enable <= 0;
