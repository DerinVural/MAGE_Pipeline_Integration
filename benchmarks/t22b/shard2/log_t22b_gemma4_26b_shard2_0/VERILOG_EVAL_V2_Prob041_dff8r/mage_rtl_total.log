	logic [7:0] d_q [$];
	logic [7:0] q_dut_q [$];
	logic [7:0] q_ref_q [$];
	logic reset_q [$];
	localparam MAX_QUEUE_SIZE = 10;

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,clk,d,reset,q_ref,q_dut );
	end

	wire tb_match;    // Verification
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk,
		.* ,
		.d,
		.reset );
	RefModule good1 (
		.clk,
		.d,
		.reset,
		.q(q_ref) );
		
	TopModule top_module1 (
		.clk,
		.d,
		.reset,
		.q(q_dut) );

