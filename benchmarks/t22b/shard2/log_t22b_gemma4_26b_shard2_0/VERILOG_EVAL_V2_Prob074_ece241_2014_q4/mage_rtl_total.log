        dff2_out <= d2_in;
        dff3_out <= d3_in;
    end

    // Output logic: Three-input NOR gate
    // z = ~(dff1_out | dff2_out | dff3_out)
    assign z = ~(dff1_out | dff2_out | dff3_out);

endmodule
