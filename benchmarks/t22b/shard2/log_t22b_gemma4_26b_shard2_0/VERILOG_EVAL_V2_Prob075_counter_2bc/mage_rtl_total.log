// RefModule required by the testbench to act as golden model
module RefModule (
    input  logic clk,
    input  logic areset,
    input  logic train_valid,
    input  logic train_taken,
    output logic [1:0] state
);
    logic [1:0] cnt;
    always_ff @(posedge clk or posedge areset) begin
        if (areset) cnt <= 2'b01;
        else if (train_valid) begin
            if (train_taken && cnt < 2'b11) cnt <= cnt + 1'b1;
            else if (!train_taken && cnt > 2'b00) cnt <= cnt - 1'b1;
        end
    end
    assign state = cnt;
endmodule

