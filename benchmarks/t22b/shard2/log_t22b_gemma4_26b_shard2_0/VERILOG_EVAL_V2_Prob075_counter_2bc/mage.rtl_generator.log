];\n    reg train_valid_q [$];\n    reg train_taken_q [$];\n    reg [1:0] state_dut_q [$];\n    reg [1:0] state_ref_q [$];\n\n    stimulus_gen stim1 (\n        .clk,\n        .*,\n        .areset,\n        .train_valid,\n        .train_taken\n    );\n\n    RefModule good1 (\n        .clk,\n        .areset,\n        .train_valid,\n        .train_taken,\n        .state(state_ref) \n    );\n        \n    TopModule top_module1 (\n        .clk,\n        .areset,\n        .train_valid,\n        .train_taken,\n        .state(state_dut) \n    );\n\n    bit strobe = 0;\n    task wait_for_end_of_timestep;\n        repeat(5) begin\n            strobe <= !strobe;\n            @(strobe);\n        end\n    endtask\n\n    assign tb_match = ( { state_ref } === ( { state_ref } ^ { state_dut } ^ { state_ref } ) );\n\n    always @(posedge clk, negedge clk) begin\n        // Push to queue\n        if (areset_q.size() >= MAX_QUEUE_SIZE) begin\n            areset_q.delete(0);\n            train_valid_q.delete(0);\n            train_taken_q.delete(0);\n            state_dut_q.delete(0);\n            state_ref_q.delete(0);\n        end\n        areset_q.push_back(areset);\n        train_valid_q.push_back(train_valid);\n        train_taken_q.push_back(train_taken);\n        state_dut_q.push_back(state_dut);\n        state_ref_q.push_back(state_ref);\n\n        stats1.clocks++;\n        if (!tb_match) begin\n            if (stats1.errors == 0) stats1.errortime = $time;\n            stats1.errors++;\n\n            // Display first mismatch details\n            if (stats1.errors == 1) begin\n                $display("First mismatch detected at time %t", $time);\n                $display("Queue history:");\n                for (int i = 0; i < areset_q.size(); i++) begin\n                    $display("Cycle %0d: areset=%b, train_valid=%b, train_taken=%b, got_state=%b (%h), exp_state=%b (%h)", \n                        i, areset_q[i], train_valid_q[i], train_taken_q[i], state_dut_q[i], state_dut_