module stimulus_gen (
	input clk,
	output reg a, b,
	output reg[511:0] wavedrom_title,
	output reg wavedrom_enable
);

	task wavedrom_start(input[511:0] title = "");
	endtask
	
	task wavedrom_stop;
		#1;
	endtask	

	initial begin
		int count; count = 0;
		{a,b} <= 1'b0;
		wavedrom_start("XOR gate");
		repeat(10) @(posedge clk)
			{a,b} <= count++;
		wavedrom_stop();
		
		repeat(200) @(posedge clk, negedge clk)
			{b,a} <= $urandom;
		
		#1 $finish;
	end
	
endmodule

module RefModule (
	input clk,
	input a,
	input b,
	output logic out_assign,
	output logic out_always_comb,
	output logic out_always_ff
);
	logic ff_reg;
	assign out_assign = a ^ b;
	assign out_always_comb = a ^ b;
	always @(posedge clk) begin
		ff_reg <= a ^ b;
	end
	assign out_always_ff = ff_reg;
endmodule

module tb();

