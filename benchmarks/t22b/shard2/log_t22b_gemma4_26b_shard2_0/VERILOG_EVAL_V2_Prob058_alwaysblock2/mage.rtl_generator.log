ign(out_assign_dut),\n\t\t.out_always_comb(out_always_comb_dut),\n\t\t.out_always_ff(out_always_ff_dut) );\n\n\tbit strobe = 0;\n\ttask wait_for_end_of_timestep;\n\t\trepeat(5) begin\n\t\t\tstrobe <= !strobe;\n\t\t\t@(strobe);\n\t\tend\n\tendtask\t\n\n\tassign tb_match = ( { out_assign_ref, out_always_comb_ref, out_always_ff_ref } === ( { out_assign_ref, out_always_comb_ref, out_always_ff_ref } ^ { out_assign_dut, out_always_comb_dut, out_always_ff_dut } ^ { out_assign_ref, out_always_comb_ref, out_always_ff_ref } ) );\n\n\talways @(posedge clk, negedge clk) begin\n\t\t// Maintain Queue\n\t\tif (a_q.size() >= MAX_QUEUE_SIZE) begin\n\t\t\ta_q.delete(0); b_q.delete(0); out_a_dut_q.delete(0); out_comb_dut_q.delete(0); out_ff_dut_q.delete(0);\n\t\t\tout_a_ref_q.delete(0); out_comb_ref_q.delete(0); out_ff_ref_q.delete(0);\n\t\tend\n\t\ta_q.push_back(a);\n\t\tb_q.push_back(b);\n\t\tout_a_dut_q.push_back(out_assign_dut);\n\t\tout_comb_dut_q.push_back(out_always_comb_dut);\n\t\tout_ff_dut_q.push_back(out_always_ff_dut);\n\t\tout_a_ref_q.push_back(out_assign_ref);\n\t\tout_comb_ref_q.push_back(out_always_comb_ref);\n\t\tout_ff_ref_q.push_back(out_always_ff_ref);\n\n\t\tstats1.clocks++;\n\n\t\tif (!tb_match) begin\n\t\t\tif (stats1.errors == 0) stats1.errortime = $time;\n\t\t\tstats1.errors++;\n\n\t\t\t// Display first mismatch queue content\n\t\t\tif (stats1.errors == 1) begin\n\t\t\t\t$display("Mismatch detected at time %t", $time);\n\t\t\t\t$display("Queue content:");\n\t\t\t\tfor (int i = 0; i < a_q.size(); i++) begin\n\t\t\t\t\t$display("Cycle %0d: a=%b, b=%b, out_assign_dut=%b, out_always_comb_dut=%b, out_always_ff_dut=%b | ref: assign=%b, comb=%b, ff=%b", \n\t\t\t\t\t\t\ti, a_q[i], b_q[i], out_a_dut_q[i], out_comb_dut_q[i], out_ff_dut_q[i], out_a_ref_q[i], out_comb_ref_q[i], out_ff_ref_q[i]);\n\t\t\t\t\tend\n\t\t\t\tend\n\t\t\tend\n\t\tend\n\n\t\tif (out_assign_ref !== ( out_assign_ref ^ out_assign_dut ^ out_assign_ref )) begin \n\t\t\tif (stats1.errors_out_assign == 0