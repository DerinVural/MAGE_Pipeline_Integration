m_title;\n    wire wavedrom_enable;\n    int wavedrom_hide_after_time;\n    \n    reg clk=0;\n    initial forever #5 clk = ~clk;\n\n    logic reset;\n    logic [3:1] ena_ref;\n    logic [3:1] ena_dut;\n    logic [15:0] q_ref;\n    logic [15:0] q_dut;\n\n    // Queues for mismatch display\n    localparam MAX_QUEUE_SIZE = 10;\n    logic [15:0] q_q_dut [$];\n    logic [15:0] q_q_ref [$];\n    logic [3:1]  q_ena_dut [$];\n    logic [3:1]  q_ena_ref [$];\n    logic        q_reset [$];\n\n    initial begin \n        $dumpfile(\"wave.vcd\");\n        $dumpvars(1, stim1.clk, tb_mismatch, clk, reset, ena_ref, ena_dut, q_ref, q_dut);\n    end\n\n    wire tb_match;\n    wire tb_mismatch = ~tb_match;\n    \n    stimulus_gen stim1 (\n        .clk,\n        .*,\n        .reset\n    );\n\n    // Note: RefModule is assumed to be provided/instantiated in the environment\n    RefModule good1 (\n        .clk,\n        .reset,\n        .ena(ena_ref),\n        .q(q_ref) \n    );\n        \n    TopModule top_module1 (\n        .clk,\n        .reset,\n        .ena(ena_dut),\n        .q(q_dut) \n    );\n\n    bit strobe = 0;\n    task wait_for_end_of_timestep;\n        repeat(5) begin\n            strobe <= !strobe;\n            @(strobe);\n        end\n    endtask\t\n\n    assign tb_match = ( { ena_ref, q_ref } === ( { ena_ref, q_ref } ^ { ena_dut, q_dut } ^ { ena_ref, q_ref } ) );\n\n    always @(posedge clk, negedge clk) begin\n        // Push to queues\n        if (q_reset.size() >= MAX_QUEUE_SIZE) begin\n            q_reset.delete(0);\n            q_ena_dut.delete(0);\n            q_ena_ref.delete(0);\n            q_q_dut.delete(0);\n            q_q_ref.delete(0);\n        end\n        q_reset.push_back(reset);\n        q_ena_dut.push_back(ena_dut);\n        q_ena_ref.push_back(ena_ref);\n        q_q_dut.push_back(q_dut);\n        q_q_ref.push_back(q_ref);\n\n        stats1.clocks++;\n\n        if (!tb_match) begin\n            if (stats1.errors == 0) stats1.errortime = $time;\n      