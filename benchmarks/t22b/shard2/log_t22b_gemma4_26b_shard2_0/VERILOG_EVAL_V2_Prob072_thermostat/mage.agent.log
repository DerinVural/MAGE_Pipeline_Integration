    input  logic fan_on,
    output logic heater,
    output logic aircon,
    output logic fan
);

    // Combinational logic for heater
    // In heating mode (mode=1), turn heater on when too_cold=1
    // In cooling mode (mode=0), heater is always off
    assign heater = mode && too_cold;

    // Combinational logic for aircon
