module RefModule (
	input mode,
	input too_cold,
	input too_hot,
	input fan_on,
	output heater,
	output aircon,
	output fan
);
	assign heater = mode ? too_cold : 1'b0;
	assign aircon = mode ? 1'b0 : too_hot;
	assign fan    = (mode ? too_cold : too_hot) || fan_on;
endmodule

