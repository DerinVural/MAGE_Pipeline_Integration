        wavedrom_enable = 1'b0;
        #1;
    endtask

    initial begin
        {a, b, sel} <= '0;
        @(negedge clk) wavedrom_start("");
            @(posedge clk, negedge clk) {a,b,sel} <= {8'haa, 8'hbb, 1'b0};
