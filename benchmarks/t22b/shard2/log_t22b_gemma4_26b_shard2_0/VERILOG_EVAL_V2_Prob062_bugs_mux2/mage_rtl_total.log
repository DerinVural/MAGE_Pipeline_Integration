            @(posedge clk, negedge clk) sel <= 1'b0;
            @(posedge clk, negedge clk) sel <= 1'b1;
            @(posedge clk, negedge clk) sel <= 1'b1;
        wavedrom_stop();
        
        repeat(100) @(posedge clk, negedge clk)
            {a,b,sel} <= $urandom;
        $finish;
    end
endmodule

module tb();

    typedef struct packed {
        int errors;
        int errortime;
        int errors_out;
        int errortime_out;
        int clocks;
    } stats;
    
    stats stats1;
    
    wire [511:0] wavedrom_title;
    wire wavedrom_enable;
    
    reg clk=0;
    initial forever #5 clk = ~clk;

    logic sel;
    logic [7:0] a;
    logic [7:0] b;
    logic [7:0] out_ref;
    logic [7:0] out_dut;

    initial begin 
        $dumpfile("wave.vcd");
        $dumpvars(1, stim1.clk, tb_mismatch, sel, a, b, out_ref, out_dut);
    end

    wire tb_match;
    wire tb_mismatch = ~tb_match;
    
    stimulus_gen stim1 (
        .clk,
        .sel,
        .a,
        .b,
        .wavedrom_title,
        .wavedrom_enable
    );

    RefModule good1 (
        .sel,
        .a,
        .b,
        .out(out_ref)
    );
        
    TopModule top_module1 (
        .sel,
        .a,
        .b,
        .out(out_dut)
    );

    assign tb_match = (out_ref === out_dut);

    // Combinational mismatch display logic
    always @(*) begin
        if (out_ref !== out_dut) begin
            // We only want to display the FIRST mismatch as per requirements
            // However, the logic must maintain error counting.
            // To avoid spamming the log for a single combinational glitch, 
            // we check if it's the first time we see this mismatch in this timestep.
            static logic [7:0] last_a, last_b, last_out_dut, last_out_ref;
            static logic last_sel;
            
            if (stats1.errors_out == 0) begin
                $display("Mismatch detected at time %t", $time);
                $display("Inputs: sel=%b, a=%h(%b), b=%h(%b)", sel, a, a, b, b);
                $display("Got: out=%h(%b), Exp: out=%h(%b)", out_dut, out_dut, out_ref, out_ref);
            end
        end
    end

    always @(posedge clk, negedge clk) begin
        stats1.clocks++;
        if (!tb_match) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
        end
        if (out_ref !== out_dut) begin
            if (stats1.errors_out == 0) stats1.errortime_out = $time;
            stats1.errors_out = stats1.errors_out + 1;
        end
    end

    final begin
        if (stats1.errors_out > 0) begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_out, stats1.errortime_out);
            $display("Hint: Output 'out' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_out, stats1.errortime_out);
