        #1;
        wavedrom_enable = 0;
    endtask

    initial begin
        reg [3:0] count; count = 0;
        in <= 100'h0;
        @(negedge clk) wavedrom_start("Test AND gate");
            @(posedge clk, negedge clk) in <= 100'h0;        
            @(posedge clk, negedge clk); in <= ~100'h0;        
