);

    // Internal registers for the 4-stage shift register
    logic q1;
    logic q2;
    logic q3;
    logic q4;

    // Initialize registers to a known value to avoid X in simulation
    initial begin
        q1 = 1'b0;
        q2 = 1'b0;
        q3 = 1'b0;
        q4 = 1'b0;
