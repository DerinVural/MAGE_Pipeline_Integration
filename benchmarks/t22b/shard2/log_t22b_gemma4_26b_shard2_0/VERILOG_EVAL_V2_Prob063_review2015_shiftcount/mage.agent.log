    output logic [3:0] q
);

    // Initialize the register to a known value to avoid 'X' in simulation
    initial begin
        q = 4'b0000;
    end

    // Sequential logic for shift register and down counter
    always @(posedge clk) begin
        if (shift_ena) begin
