module RefModule (
    input logic a, b, c, d,
    output logic out
);
    always_comb begin
        case ({a, b, c, d})
            4'b00_00: out = 1;
            4'b00_01: out = 1;
            4'b00_11: out = 0;
            4'b00_10: out = 1;
            
            4'b01_00: out = 1;
