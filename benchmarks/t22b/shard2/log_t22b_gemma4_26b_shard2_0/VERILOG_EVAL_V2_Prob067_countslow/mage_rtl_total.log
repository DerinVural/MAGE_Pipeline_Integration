// Reference Model to make the testbench functional
module RefModule (
    input logic clk,
    input logic slowena,
    input logic reset,
    output logic [3:0] q
);
    always_ff @(posedge clk) begin
        if (reset) begin
            q <= 4'd0;
        end else if (slowena) begin
            if (q == 4'd9) q <= 4'd0;
            else q <= q + 1'b1;
        end
    end
endmodule

