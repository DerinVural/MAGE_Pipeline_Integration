module RefModule (
    input clk,
    input slowena,
    input reset,
    output reg [3:0] q
);
    reg [3:0] count;
    always @(posedge clk) begin
        if (reset) count <= 0;
        else if (slowena) count <= (count == 9) ? 0 : count + 1;
    end
    always @(*) q = count;
