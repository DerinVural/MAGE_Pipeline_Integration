    logic [7:0] in_d1;

    // Initialize register to avoid unknown state in simulation
    initial begin
        in_d1 = 8'b0;
    end

    // Sequential logic: Delay the input by one clock cycle
    always @(posedge clk) begin
        in_d1 <= in;
