// Dummy RefModule to make the testbench runnable
module RefModule (
    input  logic       clk,
    input  logic [7:0] in,
    output logic [7:0] pedge
);
    logic [7:0] in_delay;
    always @(posedge clk) begin
        in_delay <= in;
    end
    assign pedge = in & ~in_delay;
endmodule

module stimulus_gen (
    input clk,
    input tb_match,
    output reg [7:0] in,
    output reg [511:0] wavedrom_title,
    output reg wavedrom_enable
);

    task wavedrom_start(input[511:0] title = "");
    endtask
    
    task wavedrom_stop;
        #1;
    endtask    

    initial begin
        in <= 0;
        @(posedge clk);
        wavedrom_start("");
        repeat(2) @(posedge clk);
        in <= 1;
        repeat(4) @(posedge clk);
        in <= 0;
        repeat(4) @(negedge clk);
        in <= 6;
        repeat(2) @(negedge clk);
        in <= 0;        
        repeat(2) @(posedge clk);
        wavedrom_stop();

        repeat(200)
            @(posedge clk, negedge clk) in <= $random;
        $finish;
    end
endmodule

module tb();

    typedef struct packed {
        int errors;
        int errortime;
        int errors_pedge;
        int errortime_pedge;
        int clocks;
    } stats;
    
    stats stats1;
    
    wire[511:0] wavedrom_title;
    wire wavedrom_enable;
    int wavedrom_hide_after_time;
    
    reg clk=0;
    initial forever
        #5 clk = ~clk;

    logic [7:0] in;
    logic [7:0] pedge_ref;
    logic [7:0] pedge_dut;

    initial begin 
        $dumpfile("wave.vcd");
        $dumpvars(1, stim1.clk, tb_mismatch, clk, in, pedge_ref, pedge_dut);
    end

    wire tb_match;        // Verification
    wire tb_mismatch = ~tb_match;
    
    stimulus_gen stim1 (
        .clk,
        .*,
        .in
    );

    RefModule good1 (
        .clk,
        .in,
        .pedge(pedge_ref) 
    );
        
    TopModule top_module1 (
        .clk,
        .in,
        .pedge(pedge_dut) 
    );

    // Queue for mismatch display
    localparam MAX_QUEUE_SIZE = 10;
    logic [7:0] in_q [$];
    logic [7:0] dut_q [$];
    logic [7:0] ref_q [$];
    bit first_mismatch_displayed = 0;

    bit strobe = 0;
    task wait_for_end_of_timestep;
        repeat(5) begin
            strobe <= !strobe;
            @(strobe);
        end
    endtask    

    // Verification Logic
    assign tb_match = ( { pedge_ref } === ( { pedge_ref } ^ { pedge_dut } ^ { pedge_ref } ) );

    always @(posedge clk, negedge clk) begin
        // Maintain Queue
        if (in_q.size() >= MAX_QUEUE_SIZE) begin
            in_q.delete(0);
            dut_q.delete(0);
            ref_q.delete(0);
        end
        in_q.push_back(in);
        dut_q.push_back(pedge_dut);
        ref_q.push_back(pedge_ref);

        // Error counting (Original Logic)
        stats1.clocks++;
        if (!tb_match) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
        end
        if (pedge_ref !== ( pedge_ref ^ pedge_dut ^ pedge_ref )) begin 
            if (stats1.errors_pedge == 0) stats1.errortime_pedge = $time;
            stats1.errors_pedge = stats1.errors_pedge + 1;
        end

        // Mismatch Display Logic (New Requirement)
        if (!tb_match && !first_mismatch_displayed) begin
            $display("Mismatch detected at time %t", $time);
            $display("\nLast %d cycles of simulation:", in_q.size());
            for (int i = 0; i < in_q.size(); i++) begin
                $display("Cycle %d, in: %h (%b), got output: %h (%b), exp output: %h (%b)",
                    i, 
                    in_q[i], in_q[i], 
                    dut_q[i], dut_q[i], 
                    ref_q[i], ref_q[i]);
            end
            first_mismatch_displayed = 1;
        end
    end

    final begin
        if (stats1.errors_pedge) 
            $display("Hint: Output '%s' has %0d mismatches. First mismatch occurred at time %0d.", "pedge", stats1.errors_pedge, stats1.errortime_pedge);
        else 
            $display("Hint: Output '%s' has no mismatches.", "pedge");

        $display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
        $display("Simulation finished at %0d ps", $time);
        $display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
        
        if (stats1.errors == 0) begin
            $display("SIMULATION PASSED");
        end else begin
            $display("SIMULATION FAILED - %d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
        end
    end

    initial begin
        #1000000
        $display("TIMEOUT");
        $finish();
    end

endmodule

