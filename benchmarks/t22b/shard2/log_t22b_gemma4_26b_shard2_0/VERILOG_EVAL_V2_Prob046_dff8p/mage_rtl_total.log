    input clk,
    input [7:0] d,
    input reset,
    output logic [7:0] q
);
    always @(negedge clk) begin
        if (reset) q <= 8'h34;
        else       q <= d;
    end
endmodule

module tb();

    typedef struct packed {
        int errors;
        int errortime;
        int errors_q;
        int errortime_q;
        int clocks;
    } stats;
    
    stats stats1;
    
    wire[511:0] wavedrom_title;
    wire wavedrom_enable;
    int wavedrom_hide_after_time;
    
    reg clk=0;
    initial forever #5 clk = ~clk;

