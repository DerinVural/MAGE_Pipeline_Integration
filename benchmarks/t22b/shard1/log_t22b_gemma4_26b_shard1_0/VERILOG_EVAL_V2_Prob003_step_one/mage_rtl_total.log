[2026-05-13 11:45:09,341 - mage.agent - INFO] `timescale 1 ps/1 ps
`define OK 12
`define INCORRECT 13

module stimulus_gen (
	input logic clk,
	output logic [511:0] wavedrom_title,
	output logic wavedrom_enable
);

	task wavedrom_start(input [511:0] title = "");
		$display("WaveDrom Start: %s", title);
	endtask
	
	task wavedrom_stop;
		#1;
	endtask	

	initial begin
		wavedrom_start("Output should be 1");
		repeat(20) @(posedge clk, negedge clk);
		wavedrom_stop();
		
		#1 $finish;
	end
	
endmodule

module RefModule (
	output logic one
);
	assign one = 1'b1;
endmodule

module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_one;
		int errortime_one;

		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic one_ref;
	logic one_dut;

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch, one_ref, one_dut);
	end

	wire tb_match;        // Verification
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk,
		.*  );
	RefModule good1 (
		.one(one_ref) );
		
	TopModule top_module1 (
		.one(one_dut) );

	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
			strobe <= !strobe;  // Try to delay until the very end of the time step.
			@(strobe);
		end;
	endtask	
	
	final begin
		if (stats1.errors_one == 0) begin
			$display("SIMULATION PASSED");
			$display("Hint: Output 'one' has no mismatches.");
		end else begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_one, stats1.errortime_one);
			$display("Hint: Output 'one' has %0d mismatches. First mismatch occurred at time %0d.", "one", stats1.errors_one, stats1.errortime_one);
		end

		$display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
		$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
	end;
	
	// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.
	assign tb_match = ( { one_ref } === ( { one_ref } ^ { one_dut } ^ { one_ref } ) );
	
	// Use explicit sensitivity list here.
	always @(posedge clk, negedge clk) begin

		stats1.clocks++;
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
		end;

		if (one_ref !== ( one_ref ^ one_dut ^ one_ref ))
		begin 
			if (stats1.errors_one == 0) begin
				stats1.errortime_one = $time;
				// Display mismatch info for the first error
				$display("FIRST MISMATCH DETECTED at time %0t ps:", $time);
				$display("  Input signals: (none)");
				$display("  Output (dut) one: %b", one_dut);
				$display("  Expected (ref) one: %b", one_ref);
			end
			stats1.errors_one = stats1.errors_one + 1'b1; 
		end;

	end;

   // add timeout after 100K cycles
   initial begin
     #1000000
     $display("TIMEOUT");
     $finish();
   end

endmodule
