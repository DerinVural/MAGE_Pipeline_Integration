`define OK 12
`define INCORRECT 13

module stimulus_gen (
    input logic clk,
    output logic [511:0] wavedrom_title,
    output logic wavedrom_enable
);

    task wavedrom_start(input [511:0] title = "");
    endtask
    
    task wavedrom_stop;
        #1;
    endtask    

    initial begin
        wavedrom_start("Output should be 1");
        repeat(20) @(posedge clk, negedge clk);
        wavedrom_stop();
        #1 $finish;
    end
    
endmodule

module RefModule (
    output logic one
);
    initial one = 1;
    always @(posedge clk or negedge clk) one <= 1;
endmodule

module tb();

    typedef struct packed {
        int errors;
        int errortime;
        int errors_one;
        int errortime_one;
        int clocks;
    } stats;
    
    stats stats1;
    
    wire [511:0] wavedrom_title;
    wire wavedrom_enable;
    int wavedrom_hide_after_time;
    
    reg clk = 0;
    initial forever #5 clk = ~clk;

    logic one_ref;
    logic one_dut;

    // Queue for mismatch display
    logic [0:0] ref_queue [$];
    logic [0:0] dut_queue [$];
    localparam int MAX_QUEUE_SIZE = 10;

    initial begin 
        $dumpfile("wave.vcd");
        $dumpvars(1, stim1.clk, tb_mismatch, one_ref, one_dut);
    end

    wire tb_match;        // Verification
    wire tb_mismatch = ~tb_match;
    
    stimulus_gen stim1 (
        .clk,
        .*  
    );

    RefModule good1 (
        .one(one_ref)
    );
        
    TopModule top_module1 (
        .one(one_dut)
    );

    bit strobe = 0;
    task wait_for_end_of_timestep;
        repeat(5) begin
            strobe <= !strobe;
            @(strobe);
        end
    endtask    

    // Verification Logic
    assign tb_match = ( { one_ref } === ( { one_ref } ^ { one_dut } ^ { one_ref } ) );

    always @(posedge clk, negedge clk) begin
        // Maintain Queue
        if (ref_queue.size() >= MAX_QUEUE_SIZE) begin
            ref_queue.delete(0);
            dut_queue.delete(0);
        end
        ref_queue.push_back(one_ref);
        dut_queue.push_back(one_dut);

        stats1.clocks++;
        
        if (!tb_match) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
            
            // Display mismatch details if it's the first mismatch for the specific signal 'one'
            if (stats1.errors_one == 0) begin
                $display("Mismatch detected at time %t", $time);
                $display("Input/Ref: %b, Got: %b, Exp: %b", one_dut, one_dut, one_ref);
                $display("\nLast %d cycles of simulation:", ref_queue.size());
                for (int i = 0; i < ref_queue.size(); i++) begin
                    $display("Cycle %d, ref %b, dut %b", i, ref_queue[i], dut_queue[i]);
                end
            end
        end

        // Original error counting for 'one'
        if (one_ref !== ( one_ref ^ one_dut ^ one_ref )) begin 
            if (stats1.errors_one == 0) stats1.errortime_one = $time;
            stats1.errors_one = stats1.errors_one + 1'b1;
        end
    end

    final begin
        if (stats1.errors_one == 0) begin
            $display("SIMULATION PASSED");
            $display("Hint: Output 'one' has no mismatches.");
        end else begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_one, stats1.errortime_one);
            $display("Hint: Output 'one' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_one, stats1.errortime_one);
        end

        $display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
        $display("Simulation finished at %0d ps", $time);
        $display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
    end
    
    initial begin
        #1000000;
        $display("TIMEOUT");
        $finish();
    end

endmodule
