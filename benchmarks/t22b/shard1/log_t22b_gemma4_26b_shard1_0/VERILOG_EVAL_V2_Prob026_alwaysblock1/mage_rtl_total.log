		{a,b} <= 1'b0;
		wavedrom_start("AND gate");
		repeat(10) @(posedge clk)
			{a,b} <= count++;
		wavedrom_stop();
		
		repeat(200) @(posedge clk, negedge clk)
			{b,a} <= $random;
			
		#1 $finish;
	end
	
endmodule

module RefModule (
	input  logic a,
	input  logic b,
	output logic out_assign,
	output logic out_alwaysblock
);
	assign out_assign = a & b;
	always_comb begin
		out_alwaysblock = a & b;
	end
endmodule

