module tb();

    typedef struct packed {
        int errors;
        int errortime;
        int errors_out;
        int errortime_out;
        int clocks;
    } stats;
    
    stats stats1;
    
    wire[511:0] wavedrom_title;
    wire wavedrom_enable;
    int wavedrom_hide_after_time;
    
    reg clk=0;
    initial forever
        #5 clk = ~clk;

    logic out_ref;
    logic out_dut;

    initial begin 
        $dumpfile("wave.vcd");
        $dumpvars(1, stim1.clk, tb_mismatch ,out_ref,out_dut );
    end

    wire tb_match;        // Verification
    wire tb_mismatch = ~tb_match;
    
    stimulus_gen stim1 (
        .clk,
        .*  );

    RefModule good1 (
        .out(out_ref) );
        
    TopModule top_module1 (
        .out(out_dut) );

    // Queue for mismatch reporting
    localparam MAX_QUEUE_SIZE = 10;
    logic out_ref_q [$];
    logic out_dut_q [$];
    int mismatch_count = 0;
    int first_mismatch_time = 0;

    bit strobe = 0;
    task wait_for_end_of_timestep;
        repeat(5) begin
            strobe <= !strobe;
            @(strobe);
        end
    endtask    

    assign tb_match = ( { out_ref } === ( { out_ref } ^ { out_dut } ^ { out_ref } ) );

    always @(posedge clk, negedge clk) begin
        // Maintain Queue
        if (out_ref_q.size() >= MAX_QUEUE_SIZE) begin
            out_ref_q.delete(0);
            out_dut_q.delete(0);
        end
        out_ref_q.push_back(out_ref);
        out_dut_q.push_back(out_dut);

        stats1.clocks++;
        
        if (!tb_match) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
            
            if (stats1.errors_out == 0) first_mismatch_time = $time;
            stats1.errors_out = stats1.errors_out + 1;

            // Display first mismatch details
            if (stats1.errors == 1) begin
                $display("Mismatch detected at time %t", $time);
                $display("Input (out_ref): %b, Got: %b, Expected: %b", out_ref, out_dut, out_ref);
            end
        end
    end

    final begin
        if (stats1.errors_out == 0) begin
            $display("SIMULATION PASSED");
            $display("Hint: Output 'out' has no mismatches.");
        end else begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_out, first_mismatch_time);
            $display("Hint: Output 'out' has %0d mismatches. First mismatch occurred at time %0d.", "out", stats1.errors_out, stats1.errortime_out);
        end

        $display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
        $display("Simulation finished at %0d ps", $time);
        $display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
    end

    initial begin
      #1000000
      $display("TIMEOUT");
      $finish();
    end

endmodule
