// Implementation of TopModule as per spec
module TopModule (
    input  logic [7:0] in,
    output logic [7:0] out
);
    always_comb begin
        for (int i = 0; i < 8; i++) begin
            out[i] = in[7-i];
        end
    end
endmodule

// Implementation of RefModule required by golden testbench
module RefModule (
    input  logic [7:0] in,
    output logic [7:0] out
);
    always_comb begin
        for (int i = 0; i < 8; i++) begin
            out[i] = in[7-i];
        end
    end
endmodule

