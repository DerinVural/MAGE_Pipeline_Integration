module stimulus_gen (
	input clk,
	output reg [2:0] vec,
	output reg[511:0] wavedrom_title,
	output reg wavedrom_enable
);

	task wavedrom_start(input[511:0] title = "");
	endtask
	
	task wavedrom_stop;
		#1;
	endtask	

	initial begin
		int count; count = 0;
		vec <= 3'b0;
		@(negedge clk);
		wavedrom_start();
		repeat(10) @(posedge clk)
			vec <= count++;
		wavedrom_stop();
		
		#1 $finish;
	end
	
endmodule

module RefModule (
	input  logic [2:0] vec,
	output logic [2:0] outv,
	output logic       o2,
	output logic       o1,
	output logic       o0
);
	assign outv = vec;
	assign o2 = vec[2];
	assign o1 = vec[1];
	assign o0 = vec[0];
endmodule

