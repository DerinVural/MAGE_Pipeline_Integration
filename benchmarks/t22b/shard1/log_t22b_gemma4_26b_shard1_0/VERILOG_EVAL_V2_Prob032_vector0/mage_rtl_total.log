	always @(posedge clk, negedge clk) begin

		stats1.clocks++;
		if (!tb_match) begin
			if (stats1.errors == 0) begin
				stats1.errortime = $time;
				$display("First mismatch detected at time %t", $time);
				$display("Input vec: %h (%b)", vec, vec);
				$display("DUT outv: %h (%b), Exp outv: %h (%b)", outv_dut, outv_dut, outv_ref, outv_ref);
				$display("DUT o2: %b, Exp o2: %b", o2_dut, o2_ref);
				$display("DUT o1: %b, Exp o1: %b", o1_dut, o1_ref);
				$display("DUT o0: %b, Exp o0: %b", o0_dut, o0_ref);
			end
