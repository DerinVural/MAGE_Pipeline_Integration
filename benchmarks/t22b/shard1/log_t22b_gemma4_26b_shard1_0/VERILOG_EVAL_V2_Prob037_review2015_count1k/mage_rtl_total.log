	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic reset;
	logic [9:0] q_ref;
	logic [9:0] q_dut;

	// Queue for mismatch display
	logic clk_q [$];
	logic reset_q [$];
	logic [9:0] q_dut_q [$];
	logic [9:0] q_ref_q [$];
	logic tb_match_q [$];
	localparam MAX_QUEUE_SIZE = 10;

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,clk,reset,q_ref,q_dut );
	end

	wire tb_match; // Verification
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk,
		.* ,
		.reset );
	RefModule good1 (
		.clk,
		.reset,
		.q(q_ref) );
		
	TopModule top_module1 (
		.clk,
		.reset,
		.q(q_dut) );

	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
			strobe <= !strobe;  // Try to delay until the very end of the time step.
			@(strobe);
		end;
	endtask	

	assign tb_match = ( { q_ref } === ( { q_ref } ^ { q_dut } ^ { q_ref } ) );

	// Improved Mismatch Tracking
	always @(posedge clk, negedge clk) begin
		// Maintain Queue
		if (clk_q.size() >= MAX_QUEUE_SIZE) begin
			clk_q.delete(0);
			reset_q.delete(0);
			q_dut_q.delete(0);
			q_ref_q.delete(0);
			tb_match_q.delete(0);
		end;

		clk_q.push_back(clk);
		reset_q.push_back(reset);
		q_dut_q.push_back(q_dut);
		q_ref_q.push_back(q_ref);
		tb_match_q.push_back(tb_match);

		// Original logic
		stats1.clocks++;
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
