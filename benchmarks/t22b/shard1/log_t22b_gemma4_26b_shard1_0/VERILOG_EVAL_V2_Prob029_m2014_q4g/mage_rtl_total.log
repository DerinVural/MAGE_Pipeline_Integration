// Implementation of the module under test
module TopModule (
    input  logic in1,
    input  logic in2,
    input  logic in3,
    output logic out
);
    // (in1 XNOR in2) XOR in3
    // XNOR is ~(A ^ B)
    assign out = (~(in1 ^ in2)) ^ in3;
endmodule

// Reference module for the testbench
module RefModule (
    input  logic in1,
    input  logic in2,
    input  logic in3,
    output logic out
);
    assign out = (~(in1 ^ in2)) ^ in3;
endmodule

module stimulus_gen (
    input clk,
    output logic in1, in2, in3
);
    initial begin
        {in1, in2, in3} = 3'b0;
        repeat(100) @(posedge clk, negedge clk) begin
            {in1, in2, in3} <= $random;
        end
        #1 $finish;
    end
endmodule

module tb();

    typedef struct packed {
        int errors;
        int errortime;
        int errors_out;
        int errortime_out;
        int clocks;
    } stats;
    
    stats stats1;
    
    wire[511:0] wavedrom_title;
    wire wavedrom_enable;
    int wavedrom_hide_after_time;
    
    reg clk=0;
    initial forever
        #5 clk = ~clk;

    logic in1;
    logic in2;
    logic in3;
    logic out_ref;
    logic out_dut;

    initial begin 
        $dumpfile("wave.vcd");
        $dumpvars(1, stim1.clk, tb_mismatch, in1, in2, in3, out_ref, out_dut);
    end

    wire tb_match;
    wire tb_mismatch = ~tb_match;
    
    // Flag to ensure we only display the first mismatch details once
    bit first_mismatch_displayed = 0;

    stimulus_gen stim1 (
        .clk,
        .in1,
        .in2,
        .in3
    );

    RefModule good1 (
        .in1,
        .in2,
        .in3,
        .out(out_ref)
    );
        
    TopModule top_module1 (
        .in1,
        .in2,
        .in3,
        .out(out_dut)
    );

    task wait_for_end_of_timestep;
        repeat(5) begin
            #1; // Added slight delay to ensure signals have propagated
        end
    endtask

    // Verification logic matching golden TB
    assign tb_match = ( { out_ref } === ( { out_ref } ^ { out_dut } ^ { out_ref } ) );

    always @(posedge clk, negedge clk) begin
        stats1.clocks++;
        
        if (!tb_match) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
            
            // Combinational mismatch display requirement
            if (!first_mismatch_displayed) begin
                $display("First Mismatch Detected at time %t:", $time);
                $display("Inputs: in1=%b, in2=%b, in3=%b", in1, in2, in3);
                $display("Got: out_dut=%b, Exp: out_ref=%b", out_dut, out_ref);
                first_mismatch_displayed = 1;
            end
        end

        if (out_ref !== ( out_ref ^ out_dut ^ out_ref )) begin 
            if (stats1.errors_out == 0) stats1.errortime_out = $time;
            stats1.errors_out = stats1.errors_out + 1'b1;
        end
    end

    final begin
        if (stats1.errors_out > 0) begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_out, stats1.errortime_out);
            $display("Hint: Output 'out' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_out, stats1.errortime_out);
        end else begin
            $display("SIMULATION PASSED");
            $display("Hint: Output 'out' has no mismatches.");
        end

        $display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
        $display("Simulation finished at %0d ps", $time);
        $display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
    end

    initial begin
        #1000000;
        $display("TIMEOUT");
        $finish();
    end

endmodule
