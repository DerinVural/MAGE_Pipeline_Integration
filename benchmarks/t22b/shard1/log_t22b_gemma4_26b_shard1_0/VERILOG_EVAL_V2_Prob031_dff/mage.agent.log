        wavedrom_title <= 0;
        @(posedge clk);
        wavedrom_start("Positive-edge triggered DFF");
        repeat(10) @(posedge clk);
        wavedrom_stop();
        
        repeat(100) @(posedge clk, negedge clk);
        $finish;
    end
