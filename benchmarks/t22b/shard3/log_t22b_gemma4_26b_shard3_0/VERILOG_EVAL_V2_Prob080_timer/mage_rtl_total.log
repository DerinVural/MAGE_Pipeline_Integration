// Reference Module to provide golden values
module RefModule (
    input  logic clk,
    input  logic load,
    input  logic [9:0] data,
    output logic tc
);
    logic [9:0] count;
    always @(posedge clk) begin
        if (load) begin
            count <= data;
        end else if (count > 0) begin
            count <= count - 1'b1;
        end
    end
    assign tc = (count == 0);
endmodule

module stimulus_gen(
	input clk, 
	output logic load, 
	output logic [9:0] data, 
	input tb_match,
	output logic [511:0] wavedrom_title,
	output logic wavedrom_enable,
