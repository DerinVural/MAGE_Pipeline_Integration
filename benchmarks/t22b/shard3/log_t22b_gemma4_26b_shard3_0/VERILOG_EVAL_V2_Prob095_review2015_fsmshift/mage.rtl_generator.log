    "module": "module TopModule (\n    input  logic clk,\n    input  logic reset,\n    output logic shift_ena\n);\n\n    // State definitions\n    localparam STATE_COUNTING = 2'b01;\n    localparam STATE_DISABLED = 2'b10;\n\n    // State and counter registers\n    logic [1:0] state;\n    logic [2:0] count;\n\n    // Initialize signals to avoid X\n    initial begin\n        state = 2'b00;\n        count = 3'b000;\n    end\n\n    // Sequential logic\n    always @(posedge clk) begin\n        if (reset) begin\n            // On reset, start the 4-cycle sequence\n            state <= STATE_COUNTING;\n            count <= 3'd1;\n        end else begin\n            case (state)\n                STATE_COUNTING:\n                    if (count == 3'd4) begin\n                        state <= STATE_DISABLED;\n                        count <= 3'd0;\n                    end else begin\n                        count <= count + 3'd1;\n                    end\n                \n                STATE_DISABLED:\n                    state <= STATE_DISABLED;\n\n                default:\n                    state <= STATE_DISABLED;\n            endcase\n        end\n    end\n\n    // Combinational output logic\n    always @(*)\n        if (state == STATE_COUNTING) begin\n            shift_ena = 1'b1;\n        end else begin\n            shift_ena = 1'b0;\n        end\n\nendmodule"
