                STATE_COUNTING:
                    if (count == 3'd4) begin
                        state <= STATE_DISABLED;
                        count <= 3'd0;
                    end else begin
                        count <= count + 3'd1;
                    end
                
                STATE_DISABLED:
                    state <= STATE_DISABLED;

                default:
                    state <= STATE_DISABLED;
            endcase
        end
    end

    // Combinational output logic
    always @(*)
        if (state == STATE_COUNTING) begin
            shift_ena = 1'b1;
        end else begin
            shift_ena = 1'b0;
        end

endmodule
