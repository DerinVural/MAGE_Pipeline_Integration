module RefModule (
    input  logic [7:0] code,
    output logic [3:0] out,
    output logic       valid
);
    always_comb begin
        valid = 1'b0;
        out   = 4'b0000;
        case (code)
            8'h45: begin out = 4'd0; valid = 1'b1; end
            8'h16: begin out = 4'd1; valid = 1'b1; end
            8'h1e: begin out = 4'd2; valid = 1'b1; end
