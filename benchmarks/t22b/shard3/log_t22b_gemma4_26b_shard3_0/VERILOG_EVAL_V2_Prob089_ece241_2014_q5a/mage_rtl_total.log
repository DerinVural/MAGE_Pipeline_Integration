                    state_next = S_INV_ZERO;
                else 
                    state_next = S_INV_ONE;

            S_INV_ZERO:
                if (x == 1'b1) 
                    state_next = S_INV_ZERO;
                else 
                    state_next = S_INV_ONE;

            S_INV_ONE:
                if (x == 1'b1) 
                    state_next = S_INV_ZERO;
                else 
                    state_next = S_INV_ONE;
            
            default:
                state_next = S_ZERO;
        endcase
    end

    // Output combinational logic (Moore Machine: output depends only on state)
    always @(*) begin
        case (state)
            S_ZERO:
                z = 1'b0;
            S_ONE:
                z = 1'b1;
            S_INV_ZERO:
                z = 1'b0;
            S_INV_ONE:
                z = 1'b1;
            default:
                z = 1'b0;
        endcase
    end

endmodule
