		w_q.push_back(w);
		Y1_dut_q.push_back(Y1_dut);
		Y3_dut_q.push_back(Y3_dut);
		Y1_ref_q.push_back(Y1_ref);
		Y3_ref_q.push_back(Y3_ref);

