				$display("FIRST MISMATCH AT TIME %0t: a=%b, b=%b | REF: and=%b, or=%b, xor=%b, nand=%b, nor=%b, xnor=%b, anotb=%b | DUT: and=%b, or=%b, xor=%b, nand=%b, nor=%b, xnor=%b, anotb=%b", 
