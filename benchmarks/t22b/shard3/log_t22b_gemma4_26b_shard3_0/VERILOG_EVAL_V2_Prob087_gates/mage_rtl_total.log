module stimulus_gen (
	input clk,
	output logic a,b,
	output logic [511:0] wavedrom_title,
	output logic wavedrom_enable
);

	task wavedrom_start(input[511:0] title = "");
	endtask
	
	task wavedrom_stop;
		#1;
	endtask	

	initial begin
		@(negedge clk) {a,b} <= 0;
		wavedrom_start();
			@(posedge clk) {a,b} <= 0;
			@(posedge clk) {a,b} <= 1;
			@(posedge clk) {a,b} <= 2;
			@(posedge clk) {a,b} <= 3;
			@(negedge clk);
		wavedrom_stop();
		repeat(200) @(posedge clk, negedge clk)
		{a,b} <= $random;
		$finish;
	end
	
endmodule

module RefModule (
	input  logic a,
	input  logic b,
	output logic out_and,
	output logic out_or,
	output logic out_xor,
	output logic out_nand,
	output logic out_nor,
	output logic out_xnor,
	output logic out_anotb
);
	assign out_and   = a & b;
	assign out_or    = a | b;
	assign out_xor   = a ^ b;
	assign out_nand  = ~(a & b);
	assign out_nor   = ~(a | b);
	assign out_xnor  = ~(a ^ b);
	assign out_anotb = a & (~b);
endmodule

