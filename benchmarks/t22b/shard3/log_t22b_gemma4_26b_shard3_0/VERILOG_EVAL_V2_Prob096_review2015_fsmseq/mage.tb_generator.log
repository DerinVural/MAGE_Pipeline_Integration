    "testbench": "`timescale 1 ps/1 ps\n`define OK 12\n`define INCORRECT 13\n\n// RefModule is required by the golden testbench to function.\n// Since the implementation isn't provided, we provide a stub that mimics the spec behavior.\nmodule RefModule (\n    input logic clk,\n    input logic reset,\n    input logic data,\n    output logic start_shifting\n);\n    logic [3:0] shift_reg;\n    always @(posedge clk) begin\n        if (reset) begin\n            shift_reg <= 4'b0000;\n            start_shifting <= 1'b0;\n        end else begin\n            shift_reg <= {shift_reg[2:0], data};\n            if (shift_reg == 4'b1101 || (start_shifting == 1'b1)) begin\n                start_shifting <= 1'b1;\n            end else if (shift_reg == 4'b1101) begin\n                // This part is a bit redundant due to the logic above, but follows pattern detection\n                start_shifting <= 1'b1;\n            end\n        end\n    end\n    // Correcting logic to match spec: detect 1101 then set high forever\n    // The pattern detection is actually on the shift register content\n    always @(posedge clk) begin\n        if (reset) begin\n            start_shifting <= 1'b0;\n        end else begin\n            if ({shift_reg[2:0], data} == 4'b1101) start_shifting <= 1'b1;\n            else if (start_shifting) start_shifting <= 1'b1;\n        end\n    end\nendmodule\n\nmodule stimulus_gen (\n    input clk,\n    output reg reset, data,\n    output reg[511:0] wavedrom_title,\n    output reg wavedrom_enable,\n    input tb_match\n);\n\n    task reset_test(input async=0);\n        bit arfail, srfail, datafail;\n    \n        @(posedge clk);\n        @(posedge clk) reset <= 0;\n        repeat(3) @(posedge clk);\n    \n        @(negedge clk) begin datafail = !tb_match ; reset <= 1; end\n        @(posedge clk) arfail = !tb_match;\n        @(posedge clk) begin\n            srfail = !tb_match;\n            reset <= 0;\n        end\n        if (srfail)\n            $display(\"Hint: Your reset doesn't seem to be working.\");\n        else if (arfail && (async || !datafail))\n            $display(\"Hint: Your reset should be %0s, but doesn't appear to be.\", async ? \"asynchronous\" : \"synchronous\");\n    endtask\n\n    task wavedrom_start(input[511:0] title = \"\");\n    endtask\n    \n    task wavedrom_stop;\n        #1;\n    endtask    \n\n    wire [0:9] d = 10'b1110110011;\n    \n    initial begin\n        reset <= 1;\n        @(posedge clk) reset <= 0;\n        data <= 1;\n        repeat(2) @(posedge clk) ;\n        data <= 0;\n        @(posedge clk);\n        data <= 1;\n        @(posedge clk);\n        data <= 0;\n    \n        wavedrom_start(\"Reset and sequence detect\");\n        reset_test();\n        for (int i=0;i<10;i++) begin\n            @(posedge clk) data <= d[i];\n        end\n        wavedrom_stop();\n        repeat(600) @(posedge clk, negedge clk) begin\n            reset <= !($random & 31);\n            data <= $random;\n        end\n\n        #1 $finish;\n    end\nendmodule\n\nmodule tb();\n\n    typedef struct packed {\n        int errors;\n        int errortime;\n        int errors_start_shifting;\n        int errortime_start_shifting;\n        int clocks;\n    } stats;\n    \n    stats stats1;\n    \n    wire[511:0] wavedrom_title;\n    wire wavedrom_enable;\n    int wavedrom_hide_after_time;\n    \n    reg clk=0;\n    initial forever #5 clk = ~clk;\n\n    logic reset;\n    logic data;\n    logic start_shifting_ref;\n    logic start_shifting_dut;\n\n    initial begin \n        $dumpfile(\"wave.vcd\");\n        $dumpvars(1, stim1.clk, tb_mismatch ,clk,reset,data,start_shifting_ref,start_shifting_dut );\n    end\n\n    wire tb_match;\n    wire tb_mismatch = ~tb_match;\n    \n    stimulus_gen stim1 (\n        .clk,\n        .*,\n        .reset,\n        .data \n    );\n\n    RefModule good1 (\n        .clk,\n        .reset,\n        .data,\n        .start_shifting(start_shifting_ref) \n    );\n        \n    TopModule top_module1 (\n        .clk,\n        .reset,\n        .data,\n        .start_shifting(start_shifting_dut) \n    );\n\n    // Queue for mismatch display\n    reg [0:0] q_clk [$];\n    reg [0:0] q_reset [$];\n    reg [0:0] q_data [$];\n    reg [0:0] q_ref [$];\n    reg [0:0] q_dut [$];\n    localparam MAX_QUEUE_SIZE = 10;\n\n    bit strobe = 0;\n    task wait_for_end_of_timestep;\n        repeat(5) begin\n            strobe <= !strobe;\n            @(strobe);\n        end\n    endtask    \n\n    assign tb_match = ( { start_shifting_ref } === ( { start_shifting_ref } ^ { start_shifting_dut } ^ { start_shifting_ref } ) );\n\n    always @(posedge clk, negedge clk) begin\n        // Manage Queues\n        if (q_clk.size() >= MAX_QUEUE_SIZE) begin\n            q_clk.delete(0);\n            q_reset.delete(0);\n            q_data.delete(0);\n            q_ref.delete(0);\n            q_dut.delete(0);\n        end\n        q_clk.push_back(clk);\n        q_reset.push_back(reset);\n        q_data.push_back(data);\n        q_ref.push_back(start_shifting_ref);\n        q_dut.push_back(start_shifting_dut);\n\n        // Error Counting\n        stats1.clocks++;\n        if (!tb_match) begin\n            if (stats1.errors == 0) stats1.errortime = $time;\n            stats1.errors++;\n\n            // Display First Mismatch Details\n            if (stats1.errors == 1) begin\n                $display(\"Mismatch detected at time %t\", $time);\n                $display(\"\\nLast %d cycles of simulation:\", q_clk.size());\n                for (int i = 0; i < q_clk.size(); i++) begin\n                    $display(\"Cycle %d, reset %b, data %b, got output %b, exp output %b\",\n                        i, q_reset[i], q_data[i], q_dut[i], q_ref[i]);\n                end\n            end\n        end\n\n        if (start_shifting_ref !== ( start_shifting_ref ^ start_shifting_dut ^ start_shifting_ref )) begin\n            if (stats1.errors_start_shifting == 0) stats1.errortime_start_shifting = $time;\n            stats1.errors_start_shifting = stats1.errors_start_shifting + 1'b1;\n        end\n    end\n\n    final begin\n        if (stats1.errors == 0) begin\n            $display(\"SIMULATION PASSED\");\n        end else begin\n            $display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\", stats1.errors, stats1.errortime);\n        end\n\n        if (stats1.errors_start_shifting) \n            $display(\"Hint: Output '%s' has %0d mismatches. First mismatch occurred at time %0d.\", \"start_shifting\", stats1.errors_start_shifting, stats1.errortime_start_shifting);\n        else \n            $display(\"Hint: Output '%s' has no mismatches.\", \"start_shifting\");\n\n        $display(\"Hint: Total mismatched samples is %1d out of %1d samples\\n\", stats1.errors, stats1.clocks);\n        $display(\"Simulation finished at %0d ps\", $time);\n        $display(\"Mismatches: %1d in %1d samples\", stats1.errors, stats1.clocks);\n    end\n\n    initial begin\n      #1000000\n      $display(\"TIMEOUT\");\n      $finish();\n    end\n\nendmodule"
