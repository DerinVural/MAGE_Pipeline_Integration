[2026-05-13 16:04:14,738 - mage.agent - INFO] module TopModule (
    input  logic clk,
    input  logic a,
    output logic [2:0] q
);

    // Initialize q to a known value to avoid X
    initial begin
        q = 3'b000;
    end

    // Sequential logic implementation
    always @(posedge clk) begin
        if (a) begin
            // When a is 1, q is set to 4
            q <= 3'd4;
        end else begin
            // When a is 0, q increments (with 3-bit wrap around)
            q <= q + 3'd1;
        end
    end

endmodule
