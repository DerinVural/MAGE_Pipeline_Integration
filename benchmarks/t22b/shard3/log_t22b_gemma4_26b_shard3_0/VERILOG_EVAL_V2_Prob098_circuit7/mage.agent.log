module stimulus_gen (
	input clk,
	output logic a,
	output logic [511:0] wavedrom_title,
	output logic wavedrom_enable
);

	task wavedrom_start(input[511:0] title = "");
	endtask
	
	task wavedrom_stop;
		#1;
	endtask	

	initial begin
		@(posedge clk) a <= 0;
		@(negedge clk) wavedrom_start("Unknown circuit");
			@(posedge clk) a <= 0;
			repeat(10) @(posedge clk) a <= $urandom % 2;
		wavedrom_stop();

		repeat(100) @(posedge clk, negedge clk)
			a <= $urandom % 2;
		$finish;
	end
	
	assign wavedrom_title = 512'b0;
	assign wavedrom_enable = 1'b0;
endmodule

module RefModule (
	input clk,
	input a,
	output logic q
);
	// Based on waveform: q(t) = ~a(t-10ns) on posedge
	// This is equivalent to q <= ~a on posedge clk
	always @(posedge clk) begin
		q <= ~a;
	end
endmodule

module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_q;
		int errortime_q;
		int clocks;
	} stats;
	
	stats stats1;
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic a;
	logic q_ref;
	logic q_dut;

	// Queue for mismatch display
	logic [0:0] q_a_hist [$];
	logic [0:0] q_q_ref_hist [$];
	logic [0:0] q_q_dut_hist [$];
	localparam MAX_QUEUE_SIZE = 10;

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,clk,a,q_ref,q_dut );
	end

	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk,
		.a,
		.wavedrom_title(wavedrom_title),
		.wavedrom_enable(wavedrom_enable)
	);

	RefModule good1 (
		.clk,
		.a,
		.q(q_ref) 
	);
		
	TopModule top_module1 (
		.clk,
		.a,
		.q(q_dut) 
	);

	// Verification logic
	assign tb_match = ( { q_ref } === ( { q_ref } ^ { q_dut } ^ { q_ref } ) );

	always @(posedge clk, negedge clk) begin
		// Maintain queue size
		if (q_a_hist.size() >= MAX_QUEUE_SIZE) begin
			q_a_hist.delete(0);
			q_q_ref_hist.delete(0);
			q_q_dut_hist.delete(0);
		end

		// Push current values
		q_a_hist.push_back(a);
		q_q_ref_hist.push_back(q_ref);
		q_q_dut_hist.push_back(q_dut);

		stats1.clocks++;

		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
		end

		if (q_ref !== ( q_ref ^ q_dut ^ q_ref )) begin 
			if (stats1.errors_q == 0) stats1.errortime_q = $time;
			stats1.errors_q = stats1.errors_q + 1;
			end

		// Display first mismatch details
		if (q_ref !== ( q_ref ^ q_dut ^ q_ref )) begin
			// We only want to print the queue once at the first error
			// But the requirement says: "When the first mismatch occurs, display the queue content"
			// Since this block runs every edge, we check if it's the first error
			if (stats1.errors_q == 1) begin
				$display("Mismatch detected at time %t", $time);
				$display("\nLast %d cycles of simulation:", q_a_hist.size());
				for (int i = 0; i < q_a_hist.size(); i++) begin
					$display("Cycle %d, a=%b, q_ref=%b, q_dut=%b", 
							i, q_a_hist[i], q_q_ref_hist[i], q_q_dut_hist[i]);
					end
				end
			end
		end
	end

	initial begin
		#1000000;
		$display("TIMEOUT");
		$finish();
	end

	final begin
		if (stats1.errors_q == 0) begin
			$display("SIMULATION PASSED");
			$display("Hint: Output 'q' has no mismatches.");
		end else begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_q, stats1.errortime_q);
			$display("Hint: Output 'q' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_q, stats1.errortime_q);
		end
		$display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
		$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
	end

endmodule
