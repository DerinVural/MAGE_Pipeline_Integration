module RefModule (
    input  logic [3:0] x,
    output logic f
);
    always_comb begin
        case (x)
            4'b0000: f = 1'b1;
            4'b0001: f = 1'b0;
            4'b0011: f = 1'b0;
            4'b0010: f = 1'b1;
