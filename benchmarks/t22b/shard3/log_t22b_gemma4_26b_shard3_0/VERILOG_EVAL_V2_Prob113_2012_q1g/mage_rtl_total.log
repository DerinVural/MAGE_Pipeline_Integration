module stimulus_gen (
	input clk,
	output logic [3:0] x
);

	initial begin
		repeat(100) @(posedge clk, negedge clk) begin
			x <= $random;
		end
		
		#1 $finish;
	end
	
endmodule

module RefModule (
    input  logic [3:0] x,
    output logic f
);
    always_comb begin
        case (x)
            4'b0000: f = 1;
            4'b0001: f = 0;
            4'b0011: f = 0;
            4'b0010: f = 1;
            4'b0100: f = 0;
            4'b0101: f = 0;
            4'b0111: f = 0;
            4'b0110: f = 0;
            4'b1100: f = 1;
            4'b1101: f = 1;
            4'b1111: f = 1;
            4'b1110: f = 0;
            4'b1000: f = 1;
            4'b1001: f = 1;
            4'b1011: f = 0;
            4'b1010: f = 1;
            default: f = 0;
        endcase
    end
endmodule

