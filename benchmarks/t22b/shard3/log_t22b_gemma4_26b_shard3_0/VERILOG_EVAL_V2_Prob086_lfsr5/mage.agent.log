module tb;

    typedef struct packed {
        int errors;
        int errortime;
        int errors_q;
        int errortime_q;
        int clocks;
    } stats;
    
    stats stats1;
    
    wire [511:0] wavedrom_title;
    wire wavedrom_enable;
    
    reg clk = 0;
    initial forever #5 clk = ~clk;

    logic reset;
    logic [4:0] q_ref;
    logic [4:0] q_dut;

    // Error tracking queues
    logic [4:0] q_ref_q [$];
    logic [4:0] q_dut_q [$];
    logic [4:0] q_expected_q [$];
    logic reset_q [$];
    localparam MAX_QUEUE_SIZE = 10;
    bit first_mismatch_displayed = 0;

    initial begin 
        $dumpfile("wave.vcd");
        $dumpvars(0, tb);
    end

    wire tb_match;
    wire tb_mismatch = ~tb_match;
    
    stimulus_gen stim1 (
        .clk,
        .reset,
        .wavedrom_title(wavedrom_title),
        .wavedrom_enable(wavedrom_enable),
        .tb_match(tb_match)
    );

    RefModule good1 (
        .clk,
        .reset,
        .q(q_ref)
    );
        
    TopModule top_module1 (
        .clk,
        .reset,
        .q(q_dut)
    );

    assign tb_match = (q_ref === q_dut);

    always @(posedge clk, negedge clk) begin
        // Maintain queue
        if (reset_q.size() >= MAX_QUEUE_SIZE - 1) begin
            reset_q.delete(0);
            q_ref_q.delete(0);
            q_dut_q.delete(0);
            q_expected_q.delete(0);
        end

        // Push current values
        // Note: Since we check mismatch at the same edge, we push the values that were just sampled
        reset_q.push_back(reset);
        q_ref_q.push_back(q_ref);
        q_dut_q.push_back(q_dut);
        q_expected_q.push_back(q_ref); // In this TB, q_ref is the golden expected

        stats1.clocks++;

        if (!tb_match) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;

            if (q_ref !== q_dut) begin
                if (stats1.errors_q == 0) stats1.errortime_q = $time;
                stats1.errors_q++;

                if (!first_mismatch_displayed) begin
                    $display("Mismatch detected at time %t", $time);
                    $display("\nLast %d cycles of simulation:", reset_q.size());
                    for (int i = 0; i < reset_q.size(); i++) begin
                        $display("Cycle %d, reset %b, got output %h (%b), exp output %h (%b)",
                            i, reset_q[i], q_dut_q[i], q_dut_q[i], q_expected_q[i], q_expected_q[i]);
                    end
                    first_mismatch_displayed = 1;
                end
            end
        end
    end

    initial begin
        #1000000;
        $display("TIMEOUT");
        $finish();
    end

    final begin
        if (stats1.errors_q > 0) begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_q, stats1.errortime_q);
        end else begin
            $display("SIMULATION PASSED");
        end
        $display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
        $display("Simulation finished at %0d ps", $time);
    end
endmodule
