module RefModule (
    input logic clk,
    input logic reset,
    output logic [4:0] q
);
    logic [4:0] q_reg;
    always @(posedge clk) begin
        if (reset) begin
            q_reg <= 5'b00001;
        end else begin
            // Galois LFSR: shift right. Taps at pos 5 (q[4]) and pos 3 (q[2])
            // If q[0] is 1, XOR with taps.
            if (q_reg[0]) begin
                q_reg <= {1'b0, q_reg[4:1]} ^ 5'b01010; // This logic is specific to the tap description
                // Re-interpreting: Galois LFSR shifts right. 
                // Next q[4] = q[4] ^ q[0] if tap at 5
                // Next q[2] = q[2] ^ q[0] if tap at 3
                // Correct Galois implementation:
                // q_next[4] = q[0] ? (q[4] ^ 1) : q[4]; ... wait, that's not standard.
                // Standard: q_next = (q >> 1); if (q[0]) q_next ^= taps;
                // Let's follow the spec: "bit position with a tap is XORed with the LSB output bit (q[0]) to produce its next value"
            end else begin
                q_reg <= {1'b0, q_reg[4:1]};
            end
        end
    end
    // Let's use a more robust implementation of the spec description:
    // "shifts right, where a bit position with a 'tap' is XORed with the LSB output bit (q[0]) to produce its next value"
    // This means q_next[i] = q[i+1] ^ (q[0] if i+1 is a tap)
    always @(posedge clk) begin
        if (reset) begin
            q_reg <= 5'b00001;
        end else begin
            automatic logic [4:0] next_q;
            next_q = {1'b0, q_reg[4:1]};
            if (q_reg[0]) begin
                // Tap at pos 5 (index 4) and pos 3 (index 2)
                next_q[4] = q_reg[4] ^ 1'b1;
                next_q[2] = q_reg[2] ^ 1'b1;
            end else begin
                next_q[4] = q_reg[4];
                next_q[2] = q_reg[2];
            end
            q_reg <= next_q;
        end
    end
    assign q = q_reg;
endmodule

