    output logic [31:0] q
);

    logic [31:0] q_next;

    // Combinational logic for next state
    always @(*) begin
        // Default: shift right
        q_next = {1'b0, q[31:1]};
        
        // Apply Galois taps
        // The spec says: 'a bit position with a tap is XORed with the LSB output bit (q[0]) to produce its next value'
        // Taps: 32, 22, 2, 1
        
        // For tap 32: This affects the bit shifted into position 31.
        // Since it's a 32-bit register, the bit shifting into 31 is the '32nd' bit.
        q_next[31] = 1'b0 ^ q[0];

        // For tap 22: q_next[22] = q[23] ^ q[0]
        q_next[22] = q[23] ^ q[0];

        // For tap 2: q_next[2] = q[3] ^ q[0]
        q_next[2] = q[3] ^ q[0];

        // For tap 1: q_next[1] = q[2] ^ q[0]
        q_next[1] = q[2] ^ q[0];

        // However, we must ensure that the 'shift right' logic is applied to all other bits.
        // The current logic above overwrites q_next[31], [22], [2], [1].
        // Let's refine the assignment to be cleaner.
        
        q_next = {1'b0, q[31:1]}; // Standard right shift
        
        // Re-apply taps: if position i is a tap, q_next[i] = q[i+1] ^ q[0]
        // Tap 32: affects q_next[31]
        q_next[31] = 1'b0 ^ q[0]; 
        // Tap 22
        q_next[22] = q[23] ^ q[0];
        // Tap 2
        q_next[2] = q[3] ^ q[0];
        // Tap 1
        q_next[1] = q[2] ^ q[0];
    end

    // Sequential logic
    always @(posedge clk) begin
        if (reset) begin
            q <= 32'h1;
        end else begin
            q <= q_next;
        end
    end

endmodule
