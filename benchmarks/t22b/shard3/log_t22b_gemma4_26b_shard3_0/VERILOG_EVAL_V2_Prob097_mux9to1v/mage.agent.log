module RefModule (
    input  logic [15:0] a,b,c,d,e,f,g,h,i,
    input  logic [3:0]  sel,
    output logic [15:0] out
);
    always_comb begin
        case(sel)
            4'd0: out = a;
            4'd1: out = b;
            4'd2: out = c;
            4'd3: out = d;
            4'd4: out = e;
