k [$];\n\tlogic [0:0] q_reset [$];\n\tlogic [0:0] q_out_dut [$];\n\tlogic [0:0] q_out_ref [$];\n\tbit first_mismatch_done = 0;\n\n\tinitial begin \n\t\t$dumpfile("wave.vcd");\n\t\t$dumpvars(1, stim1.clk, tb_match, clk, j, k, reset, out_ref, out_dut);\n\tend\n\n\twire tb_match;\n\twire tb_mismatch = ~tb_match;\n\t\n\tstimulus_gen stim1 (\n\t\t.clk,\n\t\t.j,\n\t\t.k,\n\t\t.reset,\n\t\t.wavedrom_title,\n\t\t.wavedrom_enable,\n\t\t.tb_match\n\t);\n\n\tRefModule good1 (\n\t\t.clk,\n\t\t.j,\n\t\t.k,\n\t\t.reset,\n\t\t.out(out_ref) \n\t);\n\t\t\n\tTopModule top_module1 (\n\t\t.clk,\n\t\t.j,\n\t\t.k,\n\t\t.reset,\n\t\t.out(out_dut) \n\t);\n\n\tassign tb_match = ( { out_ref } === ( { out_ref } ^ { out_dut } ^ { out_ref } ) );\n\n\talways @(posedge clk, negedge clk) begin\n\t\t// Manage Queues\n\t\tif (q_j.size() >= MAX_QUEUE_SIZE) begin\n\t\t\tq_j.delete(0);\n\t\t\tq_k.delete(0);\n\t\t\tq_reset.delete(0);\n\t\t\tq_out_dut.delete(0);\n\t\t\tq_out_ref.delete(0);\n\t\tend\n\t\t\n\t\tq_j.push_back(j);\n\t\tq_k.push_back(k);\n\t\tq_reset.push_back(reset);\n\t\tq_out_dut.push_back(out_dut);\n\t\tq_out_ref.push_back(out_ref);\n\n\t\t// Statistics and Mismatch Detection\n\t\tstats1.clocks++;\n\t\tif (!tb_match) begin\n\t\t\tif (stats1.errors == 0) stats1.errortime = $time;\n\t\t\tstats1.errors++;\n\t\t\t\n\t\t\tif (!first_mismatch_done) begin\n\t\t\t\t$display("Mismatch detected at time %t", $time);\n\t\t\t\t$display("\\nLast %d cycles of simulation:", q_j.size());\n\t\t\t\tfor (int i = 0; i < q_j.size(); i++) begin\n\t\t\t\t\t$display("Cycle %d, reset=%b, j=%b, k=%b, got_out=%b, exp_out=%b", \n\t\t\t\t\t\t\t i, q_reset[i], q_j[i], q_k[i], q_out_dut[i], q_out_ref[i]);\n\t\t\t\t\tend\n\t\t\t\tfirst_mismatch_done = 1;\n\t\t\tend\n\t\tend\n\n\t\tif (out_ref !== ( out_ref ^ out_dut ^ out_ref )) begin \n\t\t\tif (stats1.errors_out == 0) stats1.errortime_out = $time;\n\t\t\tstats1.errors_out = stats1.errors_out + 1;\n\t\tend\n\tend\n\n\tinitial begin\n\t\t#1000000;\n\t\t$display("TIMEOUT"