           q_j.delete(0);\n            q_k.delete(0);\n            q_areset.delete(0);\n            q_out_dut.delete(0);\n            q_out_ref.delete(0);\n        end\n        q_j.push_back(j);\n        q_k.push_back(k);\n        q_areset.push_back(areset);\n        q_out_dut.push_back(out_dut);\n        q_out_ref.push_back(out_ref);\n\n        stats1.clocks++;\n        if (!tb_match) begin\n            if (stats1.errors == 0) stats1.errortime = $time;\n            stats1.errors++;\n        end\n\n        if (out_ref !== ( out_ref ^ out_dut ^ out_ref )) begin \n            if (stats1.errors_out == 0) begin\n                stats1.errortime_out = $time;\n                // Display queue on first mismatch\n                $display(\"Mismatch detected at time %t\", $time);\n                $display(\"\\nLast %d cycles of simulation:\", q_j.size());\n                for (int i = 0; i < q_j.size(); i++) begin\n                    $display(\"Cycle %d, reset %b, j=%b, k=%b, got output %b, exp output %b\",\n                        i, q_areset[i], q_j[i], q_k[i], q_out_dut[i], q_out_ref[i]);\n                end\n            end\n            stats1.errors_out = stats1.errors_out + 1'b1;\n        end\n    end\n\n    final begin\n        if (stats1.errors_out == 0) begin\n            $display(\"SIMULATION PASSED\");\n        end else begin\n            $display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\", stats1.errors_out, stats1.errortime_out);\n        end\n\n        if (stats1.errors_out) $display(\"Hint: Output '%s' has %0d mismatches. First mismatch occurred at time %0d.\", \"out\", stats1.errors_out, stats1.errortime_out);\n        else $display(\"Hint: Output '%s' has no mismatches.\", \"out\");\n\n        $display(\"Hint: Total mismatched samples is %1d out of %1d samples\\n\", stats1.errors, stats1.clocks);\n        $display(\"Simulation finished at %0d ps\", $time);\n        $display(\"Mismatches: %1d in %1d samples\", stats1.errors, stats1.c