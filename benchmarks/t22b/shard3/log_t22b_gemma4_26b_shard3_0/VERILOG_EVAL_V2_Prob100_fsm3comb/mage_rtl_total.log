`define OK 12
`define INCORRECT 13

module stimulus_gen (
    input clk,
    output logic in,
    output logic [1:0] state
);

    initial begin
        in <= 0;
        state <= 0;
        repeat(100) @(posedge clk, negedge clk) begin
            in <= $random;
            state <= $random;
        end

        #1 $finish;
    end
    
endmodule

module tb();

    typedef struct packed {
        int errors;
        int errortime;
        int errors_next_state;
        int errortime_next_state;
        int errors_out;
        int errortime_out;

        int clocks;
    } stats;
    
    stats stats1;
    
    wire[511:0] wavedrom_title;
    wire wavedrom_enable;
    int wavedrom_hide_after_time;
    
    reg clk=0;
    initial forever
        #5 clk = ~clk;

    logic in;
    logic [1:0] state;
    logic [1:0] next_state_ref;
    logic [1:0] next_state_dut;
    logic out_ref;
    logic out_dut;

    // Queue for mismatch display
    localparam MAX_QUEUE_SIZE = 10;
    logic in_q [$];
    logic [1:0] state_q [$];
    logic [1:0] next_state_dut_q [$];
    logic out_dut_q [$];
    logic [1:0] next_state_ref_q [$];
    logic out_ref_q [$];

    bit first_mismatch_done = 0;

    initial begin 
        $dumpfile("wave.vcd");
        $dumpvars(1, stim1.clk, tb_mismatch ,in,state,next_state_ref,next_state_dut,out_ref,out_dut );
    end

    wire tb_match;
    wire tb_mismatch = ~tb_match;
    
    stimulus_gen stim1 (
        .clk,
        .* ,
        .in,
        .state );

    // RefModule is expected to exist based on golden testbench
    RefModule good1 (
        .in,
        .state,
        .next_state(next_state_ref),
        .out(out_ref) );
        
    TopModule top_module1 (
        .in,
        .state,
        .next_state(next_state_dut),
        .out(out_dut) );

    bit strobe = 0;
    task wait_for_end_of_timestep;
        repeat(5) begin
            strobe <= !strobe;
            @(strobe);
        end
    endtask    

    assign tb_match = ( { next_state_ref, out_ref } === ( { next_state_ref, out_ref } ^ { next_state_dut, out_dut } ^ { next_state_ref, out_ref } ) );

    always @(posedge clk, negedge clk) begin
        // Maintain Queue
        if (in_q.size() >= MAX_QUEUE_SIZE) begin
            in_q.delete(0);
            state_q.delete(0);
            next_state_dut_q.delete(0);
            out_dut_q.delete(0);
            next_state_ref_q.delete(0);
            out_ref_q.delete(0);
        end

        in_q.push_back(in);
        state_q.push_back(state);
        next_state_dut_q.push_back(next_state_dut);
        out_dut_q.push_back(out_dut);
        next_state_ref_q.push_back(next_state_ref);
        out_ref_q.push_back(out_ref);

        stats1.clocks++;

        if (!tb_match) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;

            // Display first mismatch details
            if (!first_mismatch_done) begin
                $display("Mismatch detected at time %t", $time);
                $display("Input: in=%b, state=%b | Got: next_state=%b, out=%b | Exp: next_state=%b, out=%b", 
                         in, state, next_state_dut, out_dut, next_state_ref, out_ref);
                first_mismatch_done = 1;
            end
        end else begin
            first_mismatch_done = 0; // Reset if match found again (though usually we only care about first)
        end

        // Original error counting logic
