xt_state_ref, out_ref } ^ { next_state_dut, out_dut } ^ { next_state_ref, out_ref } ) );\n\n    always @(posedge clk, negedge clk) begin\n        // Maintain Queue\n        if (in_q.size() >= MAX_QUEUE_SIZE) begin\n            in_q.delete(0);\n            state_q.delete(0);\n            next_state_dut_q.delete(0);\n            out_dut_q.delete(0);\n            next_state_ref_q.delete(0);\n            out_ref_q.delete(0);\n        end\n\n        in_q.push_back(in);\n        state_q.push_back(state);\n        next_state_dut_q.push_back(next_state_dut);\n        out_dut_q.push_back(out_dut);\n        next_state_ref_q.push_back(next_state_ref);\n        out_ref_q.push_back(out_ref);\n\n        stats1.clocks++;\n\n        if (!tb_match) begin\n            if (stats1.errors == 0) stats1.errortime = $time;\n            stats1.errors++;\n\n            // Display first mismatch details\n            if (!first_mismatch_done) begin\n                $display("Mismatch detected at time %t", $time);\n                $display("Input: in=%b, state=%b | Got: next_state=%b, out=%b | Exp: next_state=%b, out=%b", \n                         in, state, next_state_dut, out_dut, next_state_ref, out_ref);\n                first_mismatch_done = 1;\n            end\n        end else begin\n            first_mismatch_done = 0; // Reset if match found again (though usually we only care about first)\n        end\n\n        // Original error counting logic\n        if (next_state_ref !== ( next_state_ref ^ next_state_dut ^ next_state_ref )) begin \n            if (stats1.errors_next_state == 0) stats1.errortime_next_state = $time;\n            stats1.errors_next_state = stats1.errors_next_state + 1\'b1; \n        end\n\n        if (out_ref !== ( out_ref ^ out_dut ^ out_ref )) begin \n            if (stats1.errors_out == 0) stats1.errortime_out = $time;\n            stats1.errors_out = stats1.errors_out + 1\'b1; \n        end\n    end\n\n    initial begin\n      #1000000\n      $display("TIMEOUT");\n      $finish();\n    end\n\n    final begin\n        if (stats1.errors == 0) begin\n            $display("SIMULATION PASSED");\n        end else begin\n            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);\n        end\n\n        if (stats1.errors_next_state) $display("Hint: Output \'%s\' has %0d mismatches. First mismatch occurred at time %0d.", "next_state", stats1.errors_next_state, stats1.errortime_next_state);\n        else $display("Hint: Output \'%s\' has no mismatches.", "next_state");\n        \n        if (stats1.errors_out) $display("Hint: Output \'%s\' has %0d mismatches. First mismatch occurred at time %0d.", "out", stats1.errors_out, stats1.errortime_out);\n        else $display("Hint: Output \'%s\' has no mismatches.", "out");\n\n        $display("Hint: Total mismatched samples is %1d out of %1d samples\\n", stats1.errors, stats1.clocks);\n        $display("Simulation finished at %0d ps", $time);\n        $display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);\n    end\n\nendmodule\n\n</testbench>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nThe module interface is given below:\n<module_interface>\nmodule TopModule (\n    input  logic       in,\n    input  logic [1:0] state,\n    output logic [1:0] next_state,\n    output logic       out\n);\n\n</module_interface>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nYour response will be processed by a program, not human.\nSo, please STRICTLY FOLLOW the output format given as XML tag content below to generate a VALID JSON OBJECT:\n<output_format>\n{\n    "reasoning": "All reasoning steps and advices to avoid syntax error",\n    "module": "Pure SystemVerilog code, a complete module"\n}\n</output_format>\nDO NOT include any other information in your response, like \'json\', \'re