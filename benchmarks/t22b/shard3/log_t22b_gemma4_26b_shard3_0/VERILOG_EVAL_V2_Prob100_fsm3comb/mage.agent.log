    stimulus_gen stim1 (
        .clk,
        .* ,
        .in,
        .state );

    // RefModule is expected to exist based on golden testbench
    RefModule good1 (
        .in,
        .state,
        .next_state(next_state_ref),
        .out(out_ref) );
        
    TopModule top_module1 (
        .in,
        .state,
        .next_state(next_state_dut),
        .out(out_dut) );

    bit strobe = 0;
    task wait_for_end_of_timestep;
        repeat(5) begin
            strobe <= !strobe;
            @(strobe);
        end
    endtask    

    assign tb_match = ( { next_state_ref, out_ref } === ( { next_state_ref, out_ref } ^ { next_state_dut, out_dut } ^ { next_state_ref, out_ref } ) );

    always @(posedge clk, negedge clk) begin
        // Maintain Queue
        if (in_q.size() >= MAX_QUEUE_SIZE) begin
            in_q.delete(0);
            state_q.delete(0);
            next_state_dut_q.delete(0);
            out_dut_q.delete(0);
            next_state_ref_q.delete(0);
            out_ref_q.delete(0);
        end

        in_q.push_back(in);
        state_q.push_back(state);
        next_state_dut_q.push_back(next_state_dut);
        out_dut_q.push_back(out_dut);
        next_state_ref_q.push_back(next_state_ref);
        out_ref_q.push_back(out_ref);

        stats1.clocks++;

        if (!tb_match) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;

            // Display first mismatch details
            if (!first_mismatch_done) begin
                $display("Mismatch detected at time %t", $time);
                $display("Input: in=%b, state=%b | Got: next_state=%b, out=%b | Exp: next_state=%b, out=%b", 
                         in, state, next_state_dut, out_dut, next_state_ref, out_ref);
                first_mismatch_done = 1;
            end
        end else begin
            first_mismatch_done = 0; // Reset if match found again (though usually we only care about first)
        end

        // Original error counting logic
        if (next_state_ref !== ( next_state_ref ^ next_state_dut ^ next_state_ref )) begin 
            if (stats1.errors_next_state == 0) stats1.errortime_next_state = $time;
            stats1.errors_next_state = stats1.errors_next_state + 1'b1; 
        end

        if (out_ref !== ( out_ref ^ out_dut ^ out_ref )) begin 
            if (stats1.errors_out == 0) stats1.errortime_out = $time;
            stats1.errors_out = stats1.errors_out + 1'b1; 
        end
    end

    initial begin
      #1000000
      $display("TIMEOUT");
      $finish();
    end

    final begin
        if (stats1.errors == 0) begin
            $display("SIMULATION PASSED");
        end else begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
        end

        if (stats1.errors_next_state) $display("Hint: Output '%s' has %0d mismatches. First mismatch occurred at time %0d.", "next_state", stats1.errors_next_state, stats1.errortime_next_state);
        else $display("Hint: Output '%s' has no mismatches.", "next_state");
        
        if (stats1.errors_out) $display("Hint: Output '%s' has %0d mismatches. First mismatch occurred at time %0d.", "out", stats1.errors_out, stats1.errortime_out);
        else $display("Hint: Output '%s' has no mismatches.", "out");

        $display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
        $display("Simulation finished at %0d ps", $time);
        $display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
    end

endmodule

