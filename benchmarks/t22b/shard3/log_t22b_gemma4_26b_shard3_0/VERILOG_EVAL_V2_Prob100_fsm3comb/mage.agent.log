    localparam MAX_QUEUE_SIZE = 10;
    logic in_q [$];
    logic [1:0] state_q [$];
    logic [1:0] next_state_dut_q [$];
    logic out_dut_q [$];
    logic [1:0] next_state_ref_q [$];
    logic out_ref_q [$];

    bit first_mismatch_done = 0;

    initial begin 
        $dumpfile("wave.vcd");
        $dumpvars(1, stim1.clk, tb_mismatch ,in,state,next_state_ref,next_state_dut,out_ref,out_dut );
    end

    wire tb_match;
