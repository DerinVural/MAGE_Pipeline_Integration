    // 0000             | 00             | 00             | d
    // 0001             | 01             | 00             | 0
    // 0010             | 00             | 10             | d
    // 0011             | 01             | 10             | 0
    // 0100             | 00             | 01             | 0
    // 0101             | 01             | 01             | d
