            4'b0111: f = 1'b1; // 1
            4'b1000: f = 1'b1; // 1
            4'b1001: f = 1'b1; // 1
            4'b1010: f = 1'b1; // d
            4'b1011: f = 1'b1; // d
            4'b1100: f = 1'b1; // 1
