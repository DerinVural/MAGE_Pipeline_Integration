            4'b0000: f = 1'b0; // d
            4'b0001: f = 1'b0; // 0
            4'b0010: f = 1'b0; // d
            4'b0011: f = 1'b0; // 0
            4'b0100: f = 1'b0; // 0
            4'b0101: f = 1'b0; // d
