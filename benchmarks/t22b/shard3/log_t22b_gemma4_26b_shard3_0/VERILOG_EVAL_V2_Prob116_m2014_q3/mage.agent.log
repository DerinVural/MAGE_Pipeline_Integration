    // 1010             | 10             | 10             | d
    // 1011             | 11             | 10             | d
    // 1100             | 10             | 01             | 1
    // 1101             | 11             | 01             | 1
    // 1110             | 10             | 11             | 0
    // 1111             | 11             | 11             | d

    always @(*) begin
