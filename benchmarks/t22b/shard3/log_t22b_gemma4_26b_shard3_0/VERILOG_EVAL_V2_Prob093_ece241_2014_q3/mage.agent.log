module stimulus_gen (
    input clk,
    output logic c, d,
    output logic [511:0] wavedrom_title,
    output logic wavedrom_enable
);

    task wavedrom_start(input [511:0] title = "");
    endtask
    
    task wavedrom_stop;
        #1;
    endtask

    initial begin
        {c, d} <= 0;
        @(negedge clk) wavedrom_start();
            @(posedge clk) {c, d} <= 2'h0;
            @(posedge clk) {c, d} <= 2'h1;
            @(posedge clk) {c, d} <= 2'h2;
            @(posedge clk) {c, d} <= 2'h3;
        @(negedge clk) wavedrom_stop();
        repeat(50) @(posedge clk, negedge clk)
            {c,d} <= $random;

        $finish;
    end
endmodule

module RefModule (
    input logic c,
    input logic d,
    output logic [3:0] mux_in
);
    // K-map derived logic for inputs to the 4-to-1 mux
    assign mux_in[0] = c | d;   // ab=00
    assign mux_in[1] = 1'b0;    // ab=01
    assign mux_in[2] = c & d;   // ab=11
    assign mux_in[3] = ~d;      // ab=10
endmodule

module tb();

    typedef struct packed {
        int errors;
        int errortime;
        int errors_mux_in;
        int errortime_mux_in;
        int clocks;
    } stats_t;
    
    stats_t stats1;
    
    wire [511:0] wavedrom_title;
    wire wavedrom_enable;
    
    reg clk = 0;
    initial forever #5 clk = ~clk;

    logic c;
    logic d;
    logic [3:0] mux_in_ref;
    logic [3:0] mux_in_dut;

    initial begin 
        $dumpfile("wave.vcd");
        $dumpvars(0, tb);
    end

    wire tb_match;
    wire tb_mismatch = ~tb_match;

    stimulus_gen stim1 (
        .clk,
        .c,
        .d,
        .wavedrom_title(wavedrom_title),
        .wavedrom_enable(wavedrom_enable)
    );

    RefModule good1 (
        .c,
        .d,
        .mux_in(mux_in_ref) 
    );
        
    TopModule top_module1 (
        .c,
        .d,
        .mux_in(mux_in_dut) 
    );

    assign tb_match = (mux_in_ref === mux_in_dut);

    always @(posedge clk, negedge clk) begin
        stats1.clocks++;
        if (!tb_match) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
            
            // Display requirement for combinational logic mismatch
            if (stats1.errors == 1) begin
                $display("First mismatch detected at time %t", $time);
                $display("Input: c=%b, d=%b", c, d);
                $display("Got: mux_in=%h (binary: %b)", mux_in_dut, mux_in_dut);
                $display("Exp: mux_in=%h (binary: %b)", mux_in_ref, mux_in_ref);
            end
        end
        
        if (mux_in_ref !== (mux_in_ref ^ mux_in_dut ^ mux_in_ref)) begin 
            if (stats1.errors_mux_in == 0) stats1.errortime_mux_in = $time;
            stats1.errors_mux_in = stats1.errors_mux_in + 1;
        end
    end

    initial begin
      #1000000;
      $display("TIMEOUT");
      $finish();
    end

    final begin
        if (stats1.errors == 0) begin
            $display("SIMULATION PASSED");
        end else begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
        end

        if (stats1.errors_mux_in) 
            $display("Hint: Output 'mux_in' has %0d mismatches. First mismatch occurred at time %0d.", "mux_in", stats1.errors_mux_in, stats1.errortime_mux_in);
        else 
            $display("Hint: Output 'mux_in' has no mismatches.");

        $display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
        $display("Simulation finished at %0d ps", $time);
        $display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
    end

endmodule
