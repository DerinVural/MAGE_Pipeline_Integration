module RefModule (
    input logic c,
    input logic d,
    output logic [3:0] mux_in
);
    // Reference implementation based on the K-map logic derived
    // ab=00: c|d, ab=01: 0, ab=11: c&d, ab=10: c|~d
    // The 4-to-1 mux selects based on ab. 
    // However, the testbench only drives c and d. 
    // The K-map output depends on c, d AND a, b. 
    // But the DUT only takes c and d. 
    // This implies the 'TopModule' is the part that provides the inputs to the 4-to-1 mux.
    // The 4-to-1 mux itself is NOT part of the DUT, it's part of the 'entire circuit'.
    // The testbench compares the DUT's 4-bit output (which are the mux inputs) to a reference.
    // The K-map is a function of (a,b,c,d). The 4-to-1 mux output is F. 
    // The 4-to-1 mux output is: mux_in[0] if ab=00, mux_in[1] if ab=01, mux_in[2] if ab=11, mux_in[3] if ab=10.
    // Since the testbench only provides c and d, the reference must account for the fact that 
    // the 4-to-1 mux is external. But the testbench compares mux_in_ref to mux_in_dut.
    // This means the reference must also be the 4-bit vector that, when fed into a 4-to-1 mux with a,b, 
    // produces the K-map result. But the K-map result is a single bit. 
    // The only way the testbench works is if mux_in_ref is the 4-bit vector [mux_in[3], mux_in[2], mux_in[1], mux_in[0]].
    // Let's look at the K-map again. 
    // col 00 (ab=00): 0, 1, 1, 1 -> c|d
    // col 01 (ab=01): 0, 0, 0, 0 -> 0
    // col 11 (ab=11): 0, 0, 1, 0 -> c&d
    // col 10 (ab=10): 1, 0, 1, 1 -> c|~d
    // So mux_in[0]=c|d, mux_in[1]=0, mux_in[2]=c&d, mux_in[3]=c|~d.
    assign mux_in[0] = c | d;
    assign mux_in[1] = 1'b0;
    assign mux_in[2] = c & d;
    assign mux_in[3] = c | (~d);
