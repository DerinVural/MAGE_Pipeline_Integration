    "testbench": "`timescale 1 ps/1 ps\n`define OK 12\n`define INCORRECT 13\n\nmodule stimulus_gen (\n    input clk,\n    output logic c, d,\n    output logic [511:0] wavedrom_title,\n    output logic wavedrom_enable\n);\n\n    task wavedrom_start(input[511:0] title = \"\");\n    endtask\n    \n    task wavedrom_stop;\n        #1;\n    endtask    \n\n    initial begin\n        {c, d} <= 0;\n        @(negedge clk) wavedrom_start();\n            @(posedge clk) {c, d} <= 2'h0;\n            @(posedge clk) {c, d} <= 2'h1;\n            @(posedge clk) {c, d} <= 2'h2;\n            @(posedge clk) {c, d} <= 2'h3;\n        @(negedge clk) wavedrom_stop();\n        repeat(50) @(posedge clk, negedge clk)\n            {c,d} <= $random;\n\n        $finish;\n    end\nendmodule\n\nmodule RefModule (\n    input logic c,\n    input logic d,\n    output logic [3:0] mux_in\n);\n    // Reference implementation based on the K-map logic derived\n    // ab=00: c|d, ab=01: 0, ab=11: c&d, ab=10: c|~d\n    // The 4-to-1 mux selects based on ab. \n    // However, the testbench only drives c and d. \n    // The K-map output depends on c, d AND a, b. \n    // But the DUT only takes c and d. \n    // This implies the 'TopModule' is the part that provides the inputs to the 4-to-1 mux.\n    // The 4-to-1 mux itself is NOT part of the DUT, it's part of the 'entire circuit'.\n    // The testbench compares the DUT's 4-bit output (which are the mux inputs) to a reference.\n    // The K-map is a function of (a,b,c,d). The 4-to-1 mux output is F. \n    // The 4-to-1 mux output is: mux_in[0] if ab=00, mux_in[1] if ab=01, mux_in[2] if ab=11, mux_in[3] if ab=10.\n    // Since the testbench only provides c and d, the reference must account for the fact that \n    // the 4-to-1 mux is external. But the testbench compares mux_in_ref to mux_in_dut.\n    // This means the reference must also be the 4-bit vector that, when fed into a 4-to-1 mux with a,b, \n    // produces the K-map result. But the K-map result is a single bit. \n    // The only way the testbench works is if mux_in_ref is the 4-bit vector [mux_in[3], mux_in[2], mux_in[1], mux_in[0]].\n    // Let's look at the K-map again. \n    // col 00 (ab=00): 0, 1, 1, 1 -> c|d\n    // col 01 (ab=01): 0, 0, 0, 0 -> 0\n    // col 11 (ab=11): 0, 0, 1, 0 -> c&d\n    // col 10 (ab=10): 1, 0, 1, 1 -> c|~d\n    // So mux_in[0]=c|d, mux_in[1]=0, mux_in[2]=c&d, mux_in[3]=c|~d.\n    assign mux_in[0] = c | d;\n    assign mux_in[1] = 1'b0;\n    assign mux_in[2] = c & d;\n    assign mux_in[3] = c | (~d);\nendmodule\n\nmodule tb();\n\n    typedef struct packed {\n        int errors;\n        int errortime;\n        int errors_mux_in;\n        int errortime_mux_in;\n        int clocks;\n    } stats;\n    \n    stats stats1;\n    \n    wire[511:0] wavedrom_title;\n    wire wavedrom_enable;\n    int wavedrom_hide_after_time;\n    \n    reg clk=0;\n    initial forever\n        #5 clk = ~clk;\n\n    logic c;\n    logic d;\n    logic [3:0] mux_in_ref;\n    logic [3:0] mux_in_dut;\n\n    initial begin \n        $dumpfile(\"wave.vcd\");\n        $dumpvars(1, stim1.clk, tb_mismatch, c, d, mux_in_ref, mux_in_dut);\n    end\n\n    wire tb_match;\n    wire tb_mismatch = ~tb_match;\n    \n    stimulus_gen stim1 (\n        .clk,\n        .*,\n        .c,\n        .d \n    );\n\n    RefModule good1 (\n        .c,\n        .d,\n        .mux_in(mux_in_ref) \n    );\n        \n    TopModule top_module1 (\n        .c,\n        .d,\n        .mux_in(mux_in_dut) \n    );\n\n    bit strobe = 0;\n    task wait_for_end_of_timestep;\n        repeat(5) begin\n            strobe <= !strobe;\n            @(strobe);\n        end\n    endtask    \n\n    assign tb_match = ( { mux_in_ref } === ( { mux_in_ref } ^ { mux_in_dut } ^ { mux_in_ref } ) );\n\n    always @(posedge clk, negedge clk) begin\n        stats1.clocks++;\n        if (!tb_match) begin\n            if (stats1.errors == 0) stats1.errortime = $time;\n            stats1.errors++;\n\n            // Requirement: Display first mismatch\n            if (stats1.errors == 1) begin\n                $display(\"FIRST MISMATCH AT TIME %0t:\", $time);\n                $display(\"Inputs: c=%b, d=%b\", c, d);\n                $display(\"Expected mux_in: %h (%b)\", mux_in_ref, mux_in_ref);\n                $display(\"Actual mux_in:   %h (%b)\", mux_in_dut, mux_in_dut);\n            end\n        end\n\n        if (mux_in_ref !== ( mux_in_ref ^ mux_in_dut ^ mux_in_ref )) begin \n            if (stats1.errors_mux_in == 0) stats1.errortime_mux_in = $time;\n            stats1.errors_mux_in = stats1.errors_mux_in + 1'b1;\n        end\n    end\n\n    final begin\n        if (stats1.errors == 0) begin\n            $display(\"SIMULATION PASSED\");\n        end else begin\n            $display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\", stats1.errors, stats1.errortime);\n        end\n\n        if (stats1.errors_mux_in) $display(\"Hint: Output '%s' has %0d mismatches. First mismatch occurred at time %0d.\", \"mux_in\", stats1.errors_mux_in, stats1.errortime_mux_in);\n        else $display(\"Hint: Output '%s' has no mismatches.\", \"mux_in\");\n\n        $display(\"Hint: Total mismatched samples is %1d out of %1d samples\\n\", stats1.errors, stats1.clocks);\n        $display(\"Simulation finished at %0d ps\", $time);\n        $display(\"Mismatches: %1d in %1d samples\", stats1.errors, stats1.clocks);\n    end\n\n    initial begin\n        #1000000;\n        $display(\"TIMEOUT\");\n        $finish();\n    end\n\nendmodule"
