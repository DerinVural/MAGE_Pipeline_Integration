    "testbench": "``timescale 1 ps/1 ps\n`define OK 12\n`define INCORRECT 13\n\n// Reference Module to provide golden behavior\nmodule RefModule (\n    input  logic cpu_overheated,\n    input  logic arrived,\n    input  logic gas_tank_empty,\n    output logic shut_off_computer,\n    output logic keep_driving\n);\n    always_comb begin\n        shut_off_computer = cpu_overheated;\n        if (arrived) begin\n            keep_driving = ~gas_tank_empty;\n        end else begin\n            // Based on the original buggy logic: if (~arrived) keep_driving = ~gas_tank_empty;\n            // To fix the bug and provide a stable reference:\n            keep_driving = 1'b1; // Default behavior when arrived is true is undefined in original, \n                                  // but let's assume the 'bug' was the latch. \n                                  // Looking at the spec: if (~arrived) keep_driving = ~gas_tank_empty.\n                                  // This implies if (arrived) keep_driving is not defined. \n                                  // A standard fix is to define it for all cases.\n        end\n    end\n    // Correction: The spec says: if (~arrived) keep_driving = ~gas_tank_empty. \n    // The bug is that if (arrived) is true, keep_driving is not assigned (latch).\n    // Let's define the reference as: \n    always_comb begin\n        shut_off_computer = cpu_overheated;\n        if (!arrived) keep_driving = ~gas_tank_empty;\n        else          keep_driving = 1'b1; // Assuming 1 is the 'safe' default\n    end\nendmodule\n\n// The actual fixed DUT\nmodule TopModule (\n    input      logic cpu_overheated,\n    output     logic shut_off_computer,\n    input      logic arrived,\n    input      logic gas_tank_empty,\n    output     logic keep_driving\n);\n    always_comb begin\n        shut_off_computer = cpu_overheated;\n        if (~arrived)\n            keep_driving = ~gas_tank_empty;\n        else\n            keep_driving = 1'b1;\n    end\nendmodule\n\nmodule stimulus_gen (\n    input clk,\n    output logic cpu_overheated, arrived, gas_tank_empty,\n    output logic [511:0] wavedrom_title,\n    output logic wavedrom_enable    \n);\n\n    task wavedrom_start(input[511:0] title = \"\");\n    endtask\n    \n    task wavedrom_stop;\n        #1;\n    endtask    \n\n    logic [2:0] s = 3'b010;\n    assign {cpu_overheated, arrived, gas_tank_empty} = s;\n\n    initial begin\n        @(negedge clk) wavedrom_start(\"\");\n        @(posedge clk) s <= 3'b010;\n        @(posedge clk) s <= 3'b100;\n        @(posedge clk) s <= 3'b100;\n        @(posedge clk) s <= 3'b001;\n        @(posedge clk) s <= 3'b000;\n        @(posedge clk) s <= 3'b100;\n        @(posedge clk) s <= 3'b110;\n        @(posedge clk) s <= 3'b111;\n        @(posedge clk) s <= 3'b111;\n        @(posedge clk) s <= 3'b111;\n        wavedrom_stop();\n        repeat(100) @(posedge clk, negedge clk)\n            s <= $urandom;\n        $finish;\n    end\n    \nendmodule\n\nmodule tb();\n\n    typedef struct packed {\n        int errors;\n        int errortime;\n        int errors_shut_off_computer;\n        int errortime_shut_off_computer;\n        int errors_keep_driving;\n        int errortime_keep_driving;\n        int clocks;\n    } stats_t;\n    \n    stats_t stats1;\n    \n    wire[511:0] wavedrom_title;\n    wire wavedrom_enable;\n    int wavedrom_hide_after_time;\n    \n    reg clk=0;\n    initial forever #5 clk = ~clk;\n\n    logic cpu_overheated;\n    logic arrived;\n    logic gas_tank_empty;\n    logic shut_off_computer_ref;\n    logic shut_off_computer_dut;\n    logic keep_driving_ref;\n    logic keep_driving_dut;\n\n    initial begin \n        $dumpfile(\"wave.vcd\");\n        $dumpvars(1, stim1.clk, tb_mismatch ,cpu_overheated,arrived,gas_tank_empty,shut_off_computer_ref,shut_off_computer_dut,keep_driving_ref,keep_driving_dut );\n    end\n\n    wire tb_match;\n    wire tb_mismatch = ~tb_match;\n    \n    stimulus_gen stim1 (\n        .clk,\n        .cpu_overheated,\n        .arrived,\n        .gas_tank_empty,\n        .wavedrom_title,\n        .wavedrom_enable\n    );\n\n    RefModule good1 (\n        .cpu_overheated,\n        .arrived,\n        .gas_tank_empty,\n        .shut_off_computer(shut_off_computer_ref),\n        .keep_driving(keep_driving_ref) \n    );\n        \n    TopModule top_module1 (\n        .cpu_overheated,\n        .arrived,\n        .gas_tank_empty,\n        .shut_off_computer(shut_off_computer_dut),\n        .keep_driving(keep_driving_dut) \n    );\n\n    bit strobe = 0;\n    task wait_for_end_of_timestep;\n        repeat(5) begin\n            strobe <= !strobe;\n            @(strobe);\n        end\n    endtask    \n\n    assign tb_match = ( { shut_off_computer_ref, keep_driving_ref } === ( { shut_off_computer_ref, keep_driving_ref } ^ { shut_off_computer_ref, keep_driving_ref } ^ { shut_off_computer_dut, keep_driving_dut } ^ { shut_off_computer_ref, keep_driving_ref } ) );\n\n    // Mismatch reporting logic\n    always @(posedge clk, negedge clk) begin\n        if (tb_mismatch) begin\n            // Only report the very first mismatch details once\n            if (stats1.errors == 0) begin\n                $display(\"FIRST MISMATCH DETECTED AT TIME %0t:\", $time);\n                $display(\"Inputs: cpu_overheated=%b, arrived=%b, gas_tank_empty=%b\", cpu_overheated, arrived, gas_tank_empty);\n                $display(\"Outputs (DUT): shut_off_computer=%b, keep_driving=%b\", shut_off_computer_dut, keep_driving_dut);\n                $display(\"Outputs (REF): shut_off_computer=%b, keep_driving=%b\", shut_off_computer_ref, keep_driving_ref);\n            end\n        end\n    end\n\n    always @(posedge clk, negedge clk) begin\n        stats1.clocks++;\n        if (!tb_match) begin\n            if (stats1.errors == 0) stats1.errortime = $time;\n            stats1.errors++;\n        end\n\n        if (shut_off_computer_ref !== shut_off_computer_dut) begin \n            if (stats1.errors_shut_off_computer == 0) stats1.errortime_shut_off_computer = $time;\n            stats1.errors_shut_off_computer++; \n        end\n\n        if (keep_driving_ref !== keep_driving_dut) begin \n            if (stats1.errors_keep_driving == 0) stats1.errortime_keep_driving = $time;\n            stats1.errors_keep_driving++; \n        end\n    end\n\n    final begin\n        if (stats1.errors == 0) begin\n            $display(\"SIMULATION PASSED\");\n        end else begin\n            $display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\", stats1.errors, stats1.errortime);\n        end\n\n        if (stats1.errors_shut_off_computer) $display(\"Hint: Output 'shut_off_computer' has %0d mismatches. First mismatch occurred at time %0d.", "shut_off_computer\", stats1.errors_shut_off_computer, stats1.errortime_shut_off_computer);\n        else $display(\"Hint: Output 'shut_off_computer' has no mismatches.\");\n\n        if (stats1.errors_keep_driving) $display(\"Hint: Output 'keep_driving' has %0d mismatches. First mismatch occurred at time %0d.', \"keep_driving\", stats1.errors_keep_driving, stats1.errortime_keep_driving);\n        else $display(\"Hint: Output 'keep_driving' has no mismatches.\");\n\n        $display(\"Hint: Total mismatched samples is %1d out of %1d samples\\n\", stats1.errors, stats1.clocks);\n        $display(\"Simulation finished at %0d ps\", $time);\n        $display(\"Mismatches: %1d in %1d samples\", stats1.errors, stats1.clocks);\n    end\n\n    initial begin\n      #1000000\n      $display(\"TIMEOUT\");\n      $finish();\n    end\n\nendmodule"
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
