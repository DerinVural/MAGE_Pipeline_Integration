// Dummy RefModule to satisfy the golden testbench requirement
module RefModule (
    input  logic [3:0] a,
    input  logic [3:0] b,
    input  logic [3:0] c,
    input  logic [3:0] d,
    input  logic [3:0] e,
    output logic [3:0] q
);
    always_comb begin
        if      (c == 4'd0) q = b;
        else if (c == 4'd1) q = e;
        else if (c == 4'd2) q = a;
        else if (c == 4'd3) q = d;
        else                q = 4'hf;
    end
endmodule

