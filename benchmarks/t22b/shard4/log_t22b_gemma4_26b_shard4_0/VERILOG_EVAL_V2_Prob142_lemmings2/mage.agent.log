		.clk,
		.areset,
		.bump_left,
		.bump_right,
		.ground,
		.walk_left(walk_left_ref),
		.walk_right(walk_right_ref),
		.aaah(aaah_ref) );
		
	TopModule top_module1 (
		.clk,
		.areset,
		.bump_left,
		.bump_right,
		.ground,
		.walk_left(walk_left_dut),
		.walk_right(walk_right_dut),
		.aaah(aaah_dut) );

	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
			strobe <= !strobe;  // Try to delay until the very end of the time step.
			@(strobe);
		end;
	endtask	

	assign tb_match = ( { walk_left_ref, walk_right_ref, aaah_ref } === ( { walk_left_ref, walk_right_ref, aaah_ref } ^ { walk_left_dut, walk_right_dut, aaah_dut } ^ { walk_left_ref, walk_right_ref, aaah_ref } ) );

	always @(posedge clk, negedge clk) begin
		// Queue Management
		if (clk_q.size() >= MAX_QUEUE_SIZE - 1) begin
			clk_q.delete(0); areset_q.delete(0); bump_left_q.delete(0); bump_right_q.delete(0);
			ground_q.delete(0); walk_left_dut_q.delete(0); walk_right_dut_q.delete(0); aaah_dut_q.delete(0);
			walk_left_ref_q.delete(0); walk_right_ref_q.delete(0); aaah_ref_q.delete(0);
		end
		clk_q.push_back(clk);
		areset_q.push_back(areset);
		bump_left_q.push_back(bump_left);
		bump_right_q.push_back(bump_right);
		ground_q.push_back(ground);
		walk_left_dut_q.push_back(walk_left_dut);
		walk_right_dut_q.push_back(walk_right_dut);
		aaah_dut_q.push_back(aaah_dut);
		walk_left_ref_q.push_back(walk_left_ref);
		walk_right_ref_q.push_back(walk_right_ref);
		aaah_ref_q.push_back(aaah_ref);

		// Error Counting and Display
		stats1.clocks++;
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
			if (!mismatch_displayed) begin
				$display("Mismatch detected at time %t", $time);
				$display("\nLast %d cycles of simulation:", clk_q.size());
				for (int i = 0; i < clk_q.size(); i++) begin
					$display("Cycle %d, clk=%b, areset=%b, bump_l=%b, bump_r=%b, ground=%b, walk_l_dut=%b, walk_r_dut=%b, aaah_dut=%b, walk_l_ref=%b, walk_r_ref=%b, aaah_ref=%b",
							i, clk_q[i], areset_q[i], bump_left_q[i], bump_right_q[i], ground_q[i], walk_left_dut_q[i], walk_right_dut_q[i], aaah_dut_q[i], walk_left_ref_q[i], walk_right_ref_q[i], aaah_ref_q[i]);
				end
				mismatch_displayed = 1;
			end
		end

		if (walk_left_ref !== ( walk_left_ref ^ walk_left_dut ^ walk_left_ref )) begin 
			if (stats1.errors_walk_left == 0) stats1.errortime_walk_left = $time;
			stats1.errors_walk_left = stats1.errors_walk_left+1'b1; 
		end
		if (walk_right_ref !== ( walk_right_ref ^ walk_right_dut ^ walk_right_ref )) begin 
			if (stats1.errors_walk_right == 0) stats1.errortime_walk_right = $time;
			stats1.errors_walk_right = stats1.errors_walk_right+1'b1; 
		end
		if (aaah_ref !== ( aaah_ref ^ aaah_dut ^ aaah_ref )) begin 
			if (stats1.errors_aaah == 0) stats1.errortime_aaah = $time;
			stats1.errors_aaah = stats1.errors_aaah+1'b1; 
		end
	end

	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

	final begin
		if (stats1.errors == 0) $display("SIMULATION PASSED");
		if (stats1.errors > 0) $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);

		if (stats1.errors_walk_left) $display("Hint: Output '%s' has %0d mismatches. First mismatch occurred at time %0d.", "walk_left", stats1.errors_walk_left, stats1.errortime_walk_left);
		else $display("Hint: Output '%s' has no mismatches.", "walk_left");
