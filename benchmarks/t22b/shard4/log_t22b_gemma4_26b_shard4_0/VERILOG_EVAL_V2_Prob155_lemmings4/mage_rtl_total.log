		reset <= 0; // Resurrect.
		
		repeat(400) @(posedge clk, negedge clk) begin
			{dig, bump_right, bump_left} <= $random & $random;
			ground <= |($random & 7);
			reset <= !($random & 31);
		end

		#1 $finish;
	end
	
endmodule

module RefModule (
	input clk,
	input areset,
	input bump_left,
	input bump_right,
	input ground,
	input dig,
	output logic walk_left,
	output logic walk_right,
	output logic aaah,
	output logic digging
);
	// Implementation of the spec for RefModule
	typedef enum logic [2:0] {WALK_L, WALK_R, FALLING, DIGGING, SPLATTED} state_t;
	state_t state;
	logic dir; // 0: left, 1: right
	int fall_timer;

	always_ff @(posedge clk or posedge areset) begin
		if (areset) begin
			state <= WALK_L;
			dir <= 0;
			fall_timer <= 0;
		end else begin
			case (state)
				WALK_L:
					if (!ground) begin state <= FALLING; fall_timer <= 1; end
					else if (dig) state <= DIGGING;
					else if (bump_left || bump_right) begin dir <= 1; state <= WALK_R; end
					else state <= WALK_L;
				WALK_R:
					if (!ground) begin state <= FALLING; fall_timer <= 1; end
					else if (dig) state <= DIGGING;
					else if (bump_left || bump_right) begin dir <= 0; state <= WALK_L; end
					else state <= WALK_R;
				FALLING:
					if (ground) begin
						if (fall_timer > 20) state <= SPLATTED;
						else if (dig) state <= DIGGING;
						else state <= (dir == 0) ? WALK_L : WALK_R;
						end else fall_timer <= fall_timer + 1;
				DIGGING:
					if (!ground) begin state <= FALLING; fall_timer <= 1; end
					else state <= DIGGING;
				SPLATTED: state <= SPLATTED;
				endcase
			end
		end
	end

	assign walk_left = (state == WALK_L);
	assign walk_right = (state == WALK_R);
	assign aaah = (state == FALLING);
	assign digging = (state == DIGGING);
endmodule

