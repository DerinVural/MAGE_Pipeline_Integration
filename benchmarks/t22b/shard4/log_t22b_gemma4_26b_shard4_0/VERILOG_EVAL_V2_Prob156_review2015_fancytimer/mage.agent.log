[2026-05-13 19:08:05,608 - mage.agent - INFO] module TopModule (
    input  logic clk,
    input  logic reset,
    input  logic data,
    output logic [3:0] count,
    output logic counting,
    output logic done,
    input  logic ack
);

    // State definitions
    localparam STATE_IDLE  = 3'd0;
    localparam STATE_LOAD  = 3'd1;
    localparam STATE_COUNT = 3'd2;
    localparam STATE_DONE  = 3'd3;

    // Internal signals
    logic [2:0] state;
    logic [3:0] pattern_bits;
    logic [3:0] delay_reg;
    logic [2:0] load_idx;
    logic [13:0] timer_cnt;
    logic [9:0]  interval_cnt;
    logic [3:0]  current_count;

    // Sequential logic
    always @(posedge clk) begin
        if (reset) begin
            state <= STATE_IDLE;
            pattern_bits <= 4'b0000;
            delay_reg <= 4'b0000;
            load_idx <= 3'd0;
            timer_cnt <= 14'd0;
            interval_cnt <= 10'd0;
            current_count <= 4'd0;
        end else begin
            case (state)
                STATE_IDLE:
                    begin
                        pattern_bits <= {pattern_bits[2:0], data};
                        if ({pattern_bits[2:0], data} == 4'b1101) begin
                            state <= STATE_LOAD;
                            load_idx <= 3'd0;
                            delay_reg <= 4'b0000;
                        end else begin
                            state <= STATE_IDLE;
                        end
                    end

                STATE_LOAD:
                    begin
                        delay_reg <= {delay_reg[2:0], data};
                        if (load_idx == 3'd3) begin
                            state <= STATE_COUNT;
                            // On the transition to COUNT, we initialize the timer.
                            // Since delay_reg updates on the edge, we'll use the
                            // value that is about to be latched/is latched.
                            // To be safe, we handle initialization in the next state
                            // or use a combinational trick. 
                            // Let's use a flag or check timer_cnt in STATE_COUNT.
                            timer_cnt <= 14'd0; 
                            interval_cnt <= 10'd0;
                        end else begin
                            load_idx <= load_idx + 3'd1;
                        end
                    end

                STATE_COUNT:
                    begin
                        if (timer_cnt == 14'd0) begin
                            // First cycle of counting: initialize with the delay_reg
                            // Note: delay_reg was updated during the last edge of STATE_LOAD
                            timer_cnt <= (delay_reg + 4'd1) * 1000;
                            current_count <= delay_reg;
                            interval_cnt <= 10'd0;
                        end else if (timer_cnt == 14'd1) begin
                            state <= STATE_DONE;
                            timer_cnt <= 14'd0;
                        end else begin
                            timer_cnt <= timer_cnt - 14'd1;
                            if (interval_cnt == 10'd999) begin
                                interval_cnt <= 10'd0;
                                if (current_count > 4'd0) begin
                                    current_count <= current_count - 4'd1;
                                end
                            end else begin
                                interval_cnt <= interval_cnt + 10'd1;
                            end
                        end
                    end

                STATE_DONE:
                    begin
                        if (ack) begin
                            state <= STATE_IDLE;
                        end else begin
                            state <= STATE_DONE;
                        end
                    end

                default:
                    begin
                        state <= STATE_IDLE;
                    end
            endcase
        end
    end

    // Combinational Output Logic
    always @(*) begin
        counting = (state == STATE_COUNT);
        done     = (state == STATE_DONE);
        count    = current_count;
    end

endmodule
