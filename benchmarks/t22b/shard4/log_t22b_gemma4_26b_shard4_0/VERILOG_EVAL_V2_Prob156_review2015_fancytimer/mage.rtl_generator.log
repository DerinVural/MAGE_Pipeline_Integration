lculate target in sequential block to avoid combinational loops\n                        // target = (delay + 1) * 1000\n                        // We calculate the target once when entering the state\n                        // But for simplicity, we can use the current delay_val\n                        if (cycle_cnt < (delay_val + 4'd1) * 14'd1000) begin\n                            cycle_cnt <= cycle_cnt + 1'b1;\n                        end else begin\n                            state <= STATE_DONE;\n                        end\n                    end\n\n                STATE_DONE:\n                    begin\n                        if (ack) begin\n                            state <= STATE_SEARCH;\n                        end\n                    end\n\n                default:\n                    state <= STATE_SEARCH;\n            endcase\n        end\n    end\n\n    // Combinational logic for outputs\n    always @(*) begin\n        counting = (state == STATE_COUNT);\n        done = (state == STATE_DONE);\n        \n        // count[3:0] is don't-care when not counting\n        if (state == STATE_COUNT) begin\n            // count = delay - (cycle_cnt / 1000)\n            // cycle_cnt goes from 0 to (delay+1)*1000 - 1\n            // For delay=0, cycle_cnt 0-999 -> count=0\n            // For delay=5, cycle_cnt 0-999 -> count=5, 1000-1999 -> count=4, etc.\n            count = delay_val - (cycle_cnt / 1000);\n        end else begin\n            count = 4'b0000;\n        end\n    end\n\nendmodule"
