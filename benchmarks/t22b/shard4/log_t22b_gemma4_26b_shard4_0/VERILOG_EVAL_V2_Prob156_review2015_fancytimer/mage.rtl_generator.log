            state <= STATE_SEARCH;
            pattern_reg <= 4'b0000;
            delay_reg <= 4'b0000;
            delay_shift_reg <= 4'b0000;
            timer_cycle_cnt <= 14'd0;
            bit_cnt <= 3'd0;
        end else begin
            case (state) 
                STATE_SEARCH: begin
                    pattern_reg <= {pattern_reg[2:0], data};
                    if ({pattern_reg[2:0], data} == 4'b1101) begin
                        state <= STATE_GET_DELAY;
                        bit_cnt <= 3'd0;
                        delay_shift_reg <= 4'b0000;
                    end else begin
                        state <= STATE_SEARCH;
                    end
                end

                STATE_GET_DELAY: begin
                    delay_shift_reg <= {delay_shift_reg[2:0], data};
                    if (bit_cnt == 3'd3) begin
                        delay_reg <= {delay_shift_reg[2:0], data};
                        state <= STATE_COUNTING;
                        timer_cycle_cnt <= 14'd0;
                        bit_cnt <= 3'd0;
                    end else begin
                        bit_cnt <= bit_cnt + 3'd1;
                    end
                end

                STATE_COUNTING: begin
                    timer_cycle_cnt <= timer_cycle_cnt + 14'd1;
                    // Duration is (delay + 1) * 1000
                    // Max cycles: (15+1)*1000 = 16000. 14-bit is up to 16383. Good.
                    if (timer_cycle_cnt + 14'd1 >= (delay_reg + 4'd1) * 14'd1000) begin
                        state <= STATE_DONE_WAIT;
                    end else begin
                        state <= STATE_COUNTING;
                    end
                end

                STATE_DONE_WAIT: begin
                    if (ack) begin
                        state <= STATE_SEARCH;
                    end else begin
                        state <= STATE_DONE_WAIT;
                    end
                end

                default: state <= STATE_SEARCH;
            endcase
        end
    end

    // Combinational outputs
    always @(*) begin
        counting = (state == STATE_COUNTING);
        done = (state == STATE_DONE_WAIT);
        
        if (state == STATE_COUNTING) begin
            // count = delay - (timer_cycle_cnt / 1000)
            // timer_cycle_cnt is 0-indexed. 
            // 0 to 999: count = delay
            // 1000 to 1999: count = delay - 1
            count = delay_reg - (timer_cycle_cnt / 14'd1000);
        end else begin
            count = 4'b0000;
        end
    end

endmodule
