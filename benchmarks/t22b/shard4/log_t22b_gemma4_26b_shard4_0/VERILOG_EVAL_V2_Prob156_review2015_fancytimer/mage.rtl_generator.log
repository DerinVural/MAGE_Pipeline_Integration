    input  logic clk,
    input  logic reset,
    input  logic data,
    output logic [3:0] count,
    output logic counting,
    output logic done,
    input  logic ack
);

    // State definitions
    localparam STATE_SEARCH   = 3'd0;
    localparam STATE_GET_DLAY = 3'd1;
    localparam STATE_COUNTING = 3'd2;
    localparam STATE_DONE     = 3'd3;

    logic [2:0] state;
    logic [3:0] shift_reg; // For pattern 1101 and delay bits
    logic [3:0] delay_val;
    logic [13:0] cycle_counter; // Max cycles = 16 * 1000 = 16000

    // Sequential logic
    always @(posedge clk) begin
        if (reset) begin
            state <= STATE_SEARCH;
            shift_reg <= 4'b0000;
            delay_val <= 4'b0000;
            cycle_counter <= 14'd0;
        end else begin
            case (state)n
                STATE_SEARCH:
                    begin
                        // Shift in data to find 1101
                        // We use a 4-bit shift register to track the last 4 bits
                        shift_reg <= {shift_reg[2:0], data};
                        if ({shift_reg[2:0], data} == 4'b1101) begin
                            state <= STATE_GET_DLAY;
                            shift_reg <= 4'b0000; // Reset for next bits
                        end else begin
                            state <= STATE_SEARCH;
                        end
                    end

                STATE_GET_DLAY:
                    begin
                        // Capture next 4 bits (MSB first)
                        // The specification says: 'the circuit must then shift in the next 4 bits, most-significant-bit first'
                        // We can use the shift_reg to collect them.
                        shift_reg <= {shift_reg[2:0], data};
                        // We need to know when 4 bits are collected. 
                        // Since we transition on the cycle after 1101 is detected, 
                        // we use a small counter or rely on the state transitions.
                        // Let's use a temporary counter for the 4 bits.
                        // Actually, we can use the state logic to count cycles in this state.
                        // But let's just add a bit counter if needed. 
                        // Simpler: use a state transition logic.
                    end

                STATE_COUNTING:
                    begin
                        if (cycle_counter >= ((delay_val + 4'd1) * 1000) - 1) begin
                            state <= STATE_DONE;
                            cycle_counter <= 14'd0;
                        end else begin
                            cycle_counter <= cycle_counter + 1'b1;
                        end
                    end

                STATE_DONE:
                    begin
                        if (ack) begin
                            state <= STATE_SEARCH;
                            cycle_counter <= 14'd0;
                        end else begin
                            state <= STATE_DONE;
                        end
                    end

                default:
                    state <= STATE_SEARCH;
            endcase
        end
    end

    // Refined FSM to handle bit collection strictly
    logic [2:0] bit_count;
    always @(posedge clk) begin
        if (reset) begin
            state <= STATE_SEARCH;
            shift_reg <= 4'b0000;
            delay_val <= 4'b0000;
            cycle_counter <= 14'd0;
            bit_count <= 3'd0;
        end else begin
            case (state) 
                STATE_SEARCH: begin
                    bit_count <= 3'd0;
                    shift_reg <= {shift_reg[2:0], data};
                    if ({shift_reg[2:0], data} == 4'b1101) begin
                        state <= STATE_GET_DLAY;
                        bit_count <= 3'd0;
                    end else begin
                        state <= STATE_SEARCH;
                    end
                end

                STATE_GET_DLAY: begin
                    shift_reg <= {shift_reg[2:0], data};
                    if (bit_count == 3'd3) begin
                        delay_val <= {shift_reg[2:0], data};
                        state <= STATE_COUNTING;
                        cycle_counter <= 14'd0;
                        bit_count <= 3'd0;
                    end else begin
                        bit_count <= bit_count + 1'b1;
                    end
                end

                STATE_COUNTING: begin
                    if (cycle_counter >= ((delay_val + 4'd1) * 1000) - 1) begin
                        state <= STATE_DONE;
                        cycle_counter <= 14'd0;
                    end else begin
                        cycle_counter <= cycle_counter + 1'b1;
                    end
                end

                STATE_DONE: begin
                    if (ack) begin
                        state <= STATE_SEARCH;
                    end else begin
                        state <= STATE_DONE;
                    end
                end

                default: state <= STATE_SEARCH;
            endcase
        end
    end

    // Outputs
    assign counting = (state == STATE_COUNTING);
    assign done     = (state == STATE_DONE);

    // count[3:0] calculation
    // For 1000 cycles, count = delay
    // For next 1000 cycles, count = delay - 1
    // ... until count = 0 for 1000 cycles
    always @(*) begin
        if (state == STATE_COUNTING) begin
            // cycle_counter goes from 0 to (delay+1)*1000 - 1
            // The index k = cycle_counter / 1000
            // value = delay - k
            // But we must ensure we don't go below 0
            // Actually, the requirement says: "delay for 1000, then delay-1 for 1000 ... until 0 for 1000"
            // Total = (delay + 1) * 1000 cycles.
            count = delay_val - (cycle_counter / 1000);
        end else begin
            count = 4'b0000;
        end
    end

endmodule
