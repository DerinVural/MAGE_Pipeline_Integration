_IDLE:\n                    begin\n                        pattern_bits <= {pattern_bits[2:0], data};\n                        if ({pattern_bits[2:0], data} == 4'b1101) begin\n                            state <= STATE_LOAD;\n                            load_idx <= 3'd0;\n                            delay_shift <= 4'b0000;\n                        end else begin\n                            state <= STATE_IDLE;\n                        end\n                    end\n\n                STATE_LOAD:\n                    begin\n                        delay_shift <= {delay_shift[2:0], data};\n                        if (load_idx == 3'd3) begin\n                            state <= STATE_COUNT;\n                            // delay_shift will be {old_bits, data}\n                            // Since we want MSB first, and we shift in: \n                            // idx 0: delay_shift becomes {0,0,0,d0} -> d0 is LSB? No.\n                            // If MSB is first: \n                            // idx 0: delay_shift <= {4'b0, data} -> {0,0,0,d0}\n                            // idx 1: delay_shift <= {0,0,d0,d1}\n                            // idx 2: delay_shift <= {0,d0,d1,d2}\n                            // idx 3: delay_shift <= {d0,d1,d2,d3}\n                            // This correctly puts d0 in MSB.\n                            // We need the value after the edge.\n                            // We'll use a combinational block or handle it in COUNT.\n                            // Let's just calculate the target delay manually.\n                            // Since we know delay_shift after this edge is the value.\n                            // We'll use a logic that works with the transition.\n                        end else begin\n                            load_idx <= load_idx + 3'd1;\n                        end\n                    end\n\n                STATE_COUNT:\n                    begin\n                        // We need to transition from LOAD to