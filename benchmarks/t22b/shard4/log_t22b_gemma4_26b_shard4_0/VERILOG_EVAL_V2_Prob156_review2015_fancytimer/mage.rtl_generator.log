le of COUNT\\n                        if (t_reg == 14\'d0) begin\\n                            // We need to capture the d_reg that was just loaded.\\n                            // But we can\'t reset t_reg to 0 if we use it as a counter.\\n                            // Let\'s use a separate \'init\' flag or state.\\n                        end\\n                    end\\n            endcase\\n        end\\n    end\\n\\n    // Final, final attempt - Clean and Robust\\n    // States: IDLE (0), LOAD (1), COUNT (2), DONE (3)\\n    // We\'ll use a helper to handle the delay value\\n\\n    logic [3:0] delay_val_reg;\\n    logic [13:0] timer_val;\\n    logic [9:0] interval_val;\\n    logic [3:0] count_val;\\n\\n    always @(posedge clk) begin\\n        if (reset) begin\\n            state <= STATE_IDLE;\\n            pattern_bits <= 4\'b0;\\n            delay_val_reg <= 4\'b0;\\n            load_idx <= 3\'d0;\\n            timer_val <= 14\'d0;\\n            interval_val <= 10\'d0;\\n            count_val <= 4\'b0;\\n        end else begin\\n            case (state)\\n                STATE_IDLE:\\n                    begin\\n                        pattern_bits <= {pattern_bits[2:0], data};\\n                        if ({pattern_bits[2:0], data} == 4\'b1101) begin\\n                            state <= STATE_LOAD;\\n                            load_idx <= 3\'d0;\\n                            delay_val_reg <= 4\'b0;\\n                        end else begin\\n                            state <= STATE_IDLE;\\n                        end\\n                    end\\n\\n                STATE_LOAD:\\n                    begin\\n                        delay_val_reg <= {delay_val_reg[2:0], data};\\n                        if (load_idx == 3\'d3) begin\\n                            state <= STATE_COUNT;\\n                            // We use the updated delay_val_reg in the next state\\n                            // But we need to initialize timer_val and interval_val\\n       