[2026-05-13 19:13:09,902 - mage.rtl_generator - INFO] RTL code: module TopModule (
    input  logic clk,
    input  logic reset,
    input  logic data,
    output logic [3:0] count,
    output logic counting,
    output logic done,
    input  logic ack
);

    // State definitions
    localparam STATE_SEARCH   = 3'd0;
    localparam STATE_GET_DLAY = 3'd1;
    localparam STATE_COUNTING = 3'd2;
    localparam STATE_DONE     = 3'd3;

    logic [2:0] state;
    logic [3:0] shift_reg; // For pattern detection and delay capture
    logic [3:0] delay_val;
    logic [15:0] cycle_counter; // Enough to hold (15+1)*1000 = 16000
    logic [3:0] bit_cnt;

    // Sequential logic
    always @(posedge clk) begin
        if (reset) begin
            state <= STATE_SEARCH;
            shift_reg <= 4'b0;
            delay_val <= 4'b0;
            cycle_counter <= 16'd0;
            bit_cnt <= 4'd0;
        end else begin
            case (state)
                STATE_SEARCH: begin
                    bit_cnt <= 4'd0;
                    // Shift in data to find 1101
                    shift_reg <= {shift_reg[2:0], data};
                    if ({shift_reg[2:0], data} == 4'b1101) begin
                        state <= STATE_GET_DLAY;
                        bit_cnt <= 4'd0;
                        shift_reg <= 4'b0; // reset shift reg for delay bits
                    end
                end

                STATE_GET_DLAY: begin
                    // Shift in 4 bits, MSB first
                    shift_reg <= {shift_reg[2:0], data};
                    bit_cnt <= bit_cnt + 1'b1;
                    if (bit_cnt == 4'd3) begin
                        // After 4 bits are shifted in (total 4 cycles)
                        // bit_cnt 0: 1st bit (MSB), 1: 2nd, 2: 3rd, 3: 4th (LSB)
                        // shift_reg will contain {bit3, bit2, bit1, bit0}
                        delay_val <= {shift_reg[2:0], data};
                        state <= STATE_COUNTING;
                        cycle_counter <= ({shift_reg[2:0], data} + 4'd1) * 16'd1000;
                    end
                end

                STATE_COUNTING: begin
                    if (cycle_counter == 16'd0) begin
                        state <= STATE_DONE;
                    end else begin
                        cycle_counter <= cycle_counter - 1'b1;
                    end
                end

                STATE_DONE: begin
                    if (ack) begin
                        state <= STATE_SEARCH;
                    end
                end

                default: state <= STATE_SEARCH;
            endcase
        end
    end

    // Combinational logic for outputs
    always @(*) begin
        counting = 1'b0;
        done     = 1'b0;
        count    = 4'b0;

        if (state == STATE_COUNTING) begin
            counting = 1'b1;
            // cycle_counter goes from (delay+1)*1000 down to 1.
            // delay=0 -> counter=1000. count=0.
            // delay=1 -> counter=2000. count=1 for 1000 cycles, then 0 for 1000.
            // Formula: current_count = cycle_counter / 1000. 
            // Since cycle_counter is 1-indexed (counts down to 1), 
            // we use (cycle_counter - 1) / 1000.
            // Wait, the spec says: delay for 1000, then delay-1 for 1000...
            // If delay=1: cycle_counter is 2000 down to 1.
            // cycles 2000 to 1001 (1000 cycles): count = 1
            // cycles 1000 to 1 (1000 cycles): count = 0
            // So: count = (cycle_counter - 1) / 1000;
            // Let's verify for delay=0: cycle_counter is 1000 down to 1.
            // (1000-1)/1000 = 0. Correct.
            // Let's verify for delay=1: cycle_counter is 2000 down to 1.
            // 2000..1001 -> 1999/1000 = 1. 1000..1 -> 999/1000 = 0. Correct.
            count = (cycle_counter - 16'd1) / 16'd1000;
        end else if (state == STATE_DONE) begin
            done = 1'b1;
            // count is don't care
        end
    end

endmodule
