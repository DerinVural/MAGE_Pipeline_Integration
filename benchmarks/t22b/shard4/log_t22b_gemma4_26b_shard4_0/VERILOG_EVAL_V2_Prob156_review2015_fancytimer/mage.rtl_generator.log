                        end
                    end

                default:
                    state <= STATE_SEARCH;
            endcase
        end
    end

    // Combinational logic for outputs
    always @(*)
    begin
        counting = 1'b0;
        done = 1'b0;
        count = 4'b0000;

        case (state)
