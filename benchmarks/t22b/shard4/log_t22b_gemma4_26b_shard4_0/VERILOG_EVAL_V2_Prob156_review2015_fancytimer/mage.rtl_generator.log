], data};\n                        if (load_idx == 3'd3) begin\n                            state <= STATE_COUNT;\n                            // We use the updated delay_val_reg in the next state\n                            // But we need to initialize timer_val and interval_val\n                            // We will do it in a special way: \n                            // the first cycle of STATE_COUNT, we check if timer_val is 0.\n                        end else begin\n                            load_idx <= load_idx + 3'd1;\n                        end\n                    end\n\n                STATE_COUNT:\n                    begin\n                        if (timer_val == 14'd0) begin\n                            // This happens on the first cycle of COUNT\n                            timer_val <= (delay_val_reg + 4'd1) * 1000;\n                            interval_val <= 10'd0;\n                            count_val <= delay_val_reg;\n                        end else if (timer_val == 14'd1) begin\n                            state <= STATE_DONE;\n                            timer_val <= 14'd0;\n                            count_val <= 0;\n                        end else begin\n                            timer_val <= timer_val - 14'd1;\n                            if (interval_val == 10'd999) begin\n                                interval_val <= 10'd0;\n                                if (count_val == 4'd0) count_val <= 4'd0;\n                                else count_val <= count_val - 4'd1;\n                            end else begin\n                                interval_val <= interval_val + 10'd1;\n                            end\n                        end\n                    end\n\n                STATE_DONE:\n                    begin\n                        if (ack) begin\n                            state <= STATE_IDLE;\n                        end else begin\n                            state <= STATE_DONE;\n                        end\n                    end\n                default: state <= STATE_IDLE;\n            endcase\n        end\n    end\n\n    assign counting = (state == STATE_COUNT);\n    assign done = (state == STATE_DONE);\n    assign count = count_val;\n\nendmodule"
