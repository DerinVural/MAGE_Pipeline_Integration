1;\\n        data <= 0;\\n        ack <= 1\'bx;\\n        @(posedge clk) \\n            data <= 1;\\n            reset <= 0;\\n        @(posedge clk) data <= 0;\\n        @(posedge clk) data <= 0;\\n        @(posedge clk) data <= 1;\\n        @(posedge clk) data <= 1;\\n        @(posedge clk) data <= 0;\\n        @(posedge clk) data <= 1;\\n        @(posedge clk) data <= 0;\\n        @(posedge clk) data <= 0;\\n        @(posedge clk) data <= 0;\\n        @(posedge clk) data <= 1;\\n        @(posedge clk);\\n            data <= 1\'bx;\\n        repeat(2000) @(posedge clk);\\n            ack <= 1\'b0;\\n        repeat(3) @(posedge clk);\\n            ack <= 1\'b1;\\n        @(posedge clk);\\n            ack <= 1\'b0;\\n            data <= 1\'b1;\\n        if (counting_cycles != 2000)\\n            $display(\\"Hint: The first test case should count for 2000 cycles. Your circuit counted %0d\\", counting_cycles);\\n        counting_cycles <= 0;\\n        @(posedge clk);\\n            ack <= 1\'bx;\\n            data <= 1\'b1;\\n        @(posedge clk);\\n            data <= 1\'b0;\\n        @(posedge clk);\\n            data <= 1\'b1;\\n        @(posedge clk);    data <= 1\'b1;\\n        @(posedge clk);    data <= 1\'b1;\\n        @(posedge clk);    data <= 1\'b1;\\n        @(posedge clk);    data <= 1\'b0;\\n        repeat(14800) @(posedge clk);\\n        ack <= 1\'b0;\\n        repeat(400) @(posedge clk);\\n\\n        if (counting_cycles != 15000)\\n            $display(\\"Hint: The second test case should count for 15000 cycles. Your circuit counted %0d\\", counting_cycles);\\n        counting_cycles <= 0;\\n\\n        if (failed)\\n            $display(\\"Hint: Your FSM didn\'t pass the sample timing diagram posted with the problem statement. Perhaps try debugging that?\\");\\n        \\n    \\n        repeat(1000) @(posedge clk, negedge clk) begin\\n            reset <= !($random & 8191);\\n            data <= $random;\\n            ack <= !($random & 31);\\n        end\\n        repeat(100000) @(posedge clk) begin\\n            reset <= !($random & 8191);\\n            data <= $random;\\n            ack <= !($random & 31);\\n        end\\n\\n        #1 $finish;\\n    end\\nendmodule\\n\\nmodule tb();\\n\\n    typedef struct packed {\\n        int errors;\\n        int errortime;\\n        int errors_count;\\n        int errortime_count;\\n        int errors_counting;\\n        int errortime_counting;\\n        int errors_done;\\n        int errortime_done;\\n        int clocks;\\n    } stats;\\n    \\n    stats stats1;\\n    \\n    reg clk=0;\\n    initial forever #5 clk = ~clk;\\n\\n    logic reset;\\n    logic data;\\n    logic ack;\\n    logic [3:0] count_ref;\\n    logic [3:0] count_dut;\\n    logic counting_ref;\\n    logic counting_dut;\\n    logic done_ref;\\n    logic done_dut;\\n\\n    // Queues for mismatch reporting\\n    localparam MAX_QUEUE_SIZE = 10;\\n    logic [2:0] q_reset [$];\\n    logic [0:0] q_data [$];\\n    logic [0:0] q_ack [$];\\n    logic [3:0] q_count_got [$];\\n    logic [0:0] q_counting_got [$];\\n    logic [0:0] q_done_got [$];\\n    logic [3:0] q_count_ref [$];\\n    logic [0:0] q_counting_ref [$];\\n    logic [0:0] q_done_ref [$];\\n\\n    initial begin \\n        $dumpfile(\\"wave.vcd\\");\\n        $dumpvars(1, stim1.clk, tb_mismatch ,clk,reset,data,ack,count_ref,count_dut,counting_ref,counting_dut,done_ref,done_dut );\\n    end\\n\\n    wire tb_match;\\n    wire tb_mismatch = ~tb_match;\\n    \\n    stimulus_gen stim1 (\\n        .clk,\\n        .* ,\\n        .reset,\\n        .data,\\n        .ack );\\n\\n    RefModule good1 (\\n        .clk,\\n        .reset,\\n        .data,\\n        .ack,\\n        .count(count_ref),\\n        .counting(counting_ref),\\n        .done(done_ref) );\\n        \\n    TopModule top_module1 (\\n        .clk,\\n        .reset,\\n        .data,\\n        .ack,\\n        .count(count_dut),\\n        .counting(counting_dut),\\n        .done(done_dut) );\\n\\n    assign tb_match = ( { count_ref, counting_ref, done_ref } === ( { count_ref, counting_ref, done_ref } ^ { count_dut, counting_dut, done_dut } ^ { count_ref, counting_ref, done_ref } ) );\\n\\n    always @(posedge clk, negedge clk) begin\\n        // Maintain Queues\\n        if (q_reset.size() >= MAX_QUEUE_SIZE) begin\\n            q_reset.delete(0); q_data.delete(0); q_ack.delete(0);\\n            q_count_got.delete(0); q_counting_got.delete(0); q_done_got.delete(0);\\n            q_count_ref.delete(0); q_counting_ref.delete(0); q_done_ref.delete(0);\\n        end\\n\\n        q_reset.push_back(reset);\\n        q_data.push_back(data);\\n        q_ack.push_back(ack);\\n        q_count_got.push_back(count_dut);\\n        q_counting_got.push_back(counting_dut);\\n        q_done_got.push_back(done_dut);\\n        q_count_ref.push_back(count_ref);\\n        q_counting_ref.push_back(counting_ref);\\n        q_done_ref.push_back(done_ref);\\n\\n        // Error counting logic\\n        stats1.clocks++;\\n        if (!tb_match) begin\\n            if (stats1.errors == 0) stats1.errortime = $time;\\n            stats1.errors++;\\n\\n            // Display first mismatch\\n            if (stats1.errors == 1) begin\\n                $display(\\"Mismatch detected at time %t\\", $time);\\n                $display(\\"\\\\nLast %0d cycles of simulation:\\", q_reset.size());\\n                for (int i = 0; i < q_reset.size(); i++) begin\\n                    $display(\\"Cycle %0d, reset=%b, data=%b, ack=%b | Got: count=%h(%b) counti=%b done=%b | Exp: count=%h(%b) counti=%b done=%b\\", \\n                        i, q_reset[i], q_data[i], q_ack[i],\\n                        q_count_got[i], (q_count_got[i] < 64 ? $b2h(q_count_got[i]) : \\"\\", q_counting_got[i], q_done_got[i],\\n                        q_count_ref[i], (q_count_ref[i] < 64 ? $b2h(q_count_ref[i]) : \\"\\", q_counting_ref[i], q_done_ref[i]);\\n                end\\n            end\\n        end\\n\\n        if (count_ref !== ( count_ref ^ count_dut ^ count_ref )) begin \\n            if (stats1.errors_count == 0) stats1.errortime_count = $time;\\n            stats1.errors_count = stats1.errors_count+1\'b1; \\n        end\\n        if (counting_ref !== ( counting_ref ^ counting_dut ^ counting_ref )) begin \\n            if (stats1.errors_counting == 0) stats1.errortime_counting = $time;\\n            stats1.errors_counting = stats1.errors_counting+1\'b1; \\n        end\\n        if (done_ref !== ( done_ref ^ done_dut ^ done_ref )) begin \\n            if (stats1.errors_done == 0) stats1.errortime_done = $time;\\n            stats1.errors_done = stats1.errors_done+1\'b1; \\n        end\\n    end\\n\\n    final begin\\n        if (stats1.errors == 0) begin\\n            $display(\\"SIMULATION PASSED\\");\\n        end else begin\\n            $display(\\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\\", stats1.errors, stats1.errortime);\\n        end\\n\\n        if (stats1.errors_count) $display(\\"Hint: Output \'%s\' has %0d mismatches. First mismatch occurred at time %0d.", "count\\", stats1.errors_count, stats1.errortime_count);\\n        else $display(\\"Hint: Output \'%s\' has no mismatches.\\", \\"count\\");\\n        if (stats1.errors_counting) $display(\\"Hint: Output \'%s\' has %0d mismatches. First mismatch occurred at time %0d.\\", \\"counting\\", stats1.errors_counting, stats1.errortime_counting);\\n        else $display(\\"Hint: Output \'%s\' has no mismatches.\\", \\"counting\\");\\n        if (stats1.errors_done) $display(\\"Hint: Output \'%s\' has %0d mismatches. First mismatch occurred at time %0d.\\", \\"done\\", stats1.errors_done, stats1.errortime_done);\\n        else $display(\\"Hint: Output \'%s\' has no mismatches.\\", \\"done\\");\\n\\n        $display(\\"Hint: Total mismatched samples is %1d out of %1d samples\\\\n\\", stats1.errors, stats1.clocks);\\n        $display(\\"Simulation finished at %0d ps\\", $time);\\n        $display(\\"Mismatches: %1d in %1d samples\\", stats1.errors, stats1.clocks);\\n    end\\n\\n    initial begin\\n      #1000000\\n      $display(\\"TIMEOUT\\");\\n      $finish();\\n    end\\nendmodule"\n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \