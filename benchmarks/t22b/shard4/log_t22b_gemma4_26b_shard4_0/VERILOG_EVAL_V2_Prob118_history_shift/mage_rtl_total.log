				clk, areset, predict_valid, predict_taken, train_mispredicted, train_taken, train_history, train_history);
			$display("Outputs: predict_history_dut=0x%h (%b), predict_history_ref=0x%h (%b)", 
				predict_history_dut, predict_history_dut, predict_history_ref, predict_history_ref);
		end
	end

	initial begin 
		#1000000;
		$display("TIMEOUT");
		$finish();
	end

	final begin
		if (stats1.errors_predict_history) 
			$display("Hint: Output 'predict_history' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_predict_history, stats1.errortime_predict_history);
		else 
			$display("Hint: Output 'predict_history' has no mismatches.");

		if (stats1.errors == 0) begin
			$display("SIMULATION PASSED");
		else begin
