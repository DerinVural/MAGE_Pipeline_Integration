module stimulus_gen (
    input clk,
    output logic in,
    output logic reset
);

    initial begin
        reset <= 1;
        in <= 1;
        @(posedge clk);
        reset <= 0;
        in <= 0;
        repeat(9) @(posedge clk);
        in <= 1;
        @(posedge clk);
        in <= 0;
        repeat(9) @(posedge clk);
        in <= 1;
        @(posedge clk);
        in <= 0;
        repeat(10) @(posedge clk);
        in <= 1;
        @(posedge clk);
