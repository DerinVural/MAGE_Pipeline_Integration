[2026-05-13 15:47:37,523 - mage.agent - INFO] module TopModule (
    input  logic       clk,
    input  logic       in,
    input  logic       reset,
    output logic [7:0] out_byte,
    output logic       done
);

    // State definitions
    localparam logic [1:0] STATE_IDLE      = 2'b00;
    localparam logic [1:0] STATE_DATA      = 2'b01;
    localparam logic [1:0] STATE_STOP      = 2'b10;
    localparam logic [1:0] STATE_WAIT_STOP = 2'b11;

    logic [1:0] state;
    logic [2:0] bit_cnt;
    logic [7:0] data_reg;
    logic [7:0] out_reg;
    logic       done_reg;

    // Initialize signals to avoid X
    initial begin
        state    = STATE_IDLE;
        bit_cnt  = 3'd0;
        data_reg = 8'd0;
        out_reg  = 8'd0;
        done_reg = 1'b0;
    end

    // FSM Sequential Logic
    always @(posedge clk) begin
        if (reset) begin
            state    <= STATE_IDLE;
            bit_cnt  <= 3'd0;
            data_reg <= 8'd0;
            out_reg  <= 8'd0;
            done_reg <= 1'b0;
        end else begin
            // Default values
            done_reg <= 1'b0;

            case (state) 
                STATE_IDLE: begin
                    if (in == 1'b0) begin
                        state    <= STATE_DATA;
                        bit_cnt  <= 3'd0;
                        data_reg <= 8'd0;
                    end else begin
                        state    <= STATE_IDLE;
                    end
                end

                STATE_DATA: begin
                    // LSB first: shift in from the left so the first bit ends up at bit 0
                    // Actually, to have first bit at bit 0: 
                    // bit 0 = in, bit 1 = in_prev, etc.
                    // We can use: data_reg <= {in, data_reg[7:1]};
                    // Or: data_reg <= {data_reg[6:0], in};
                    // Let's use bit_cnt to track and build the byte.
                    // If bit_cnt=0, data_reg[0]=in. If bit_cnt=1, data_reg[1]=in.
                    
                    // Implementation using a shift register where 'in' is shifted into bit 0
                    // but we need to preserve existing bits. 
                    // Let's use a simple loop-like logic: 
                    // data_reg[bit_cnt] <= in;
                    // Since we can't do that in a single non-blocking assignment easily without a temp variable,
                    // we'll use the shift method: 
                    // To get LSB first: first bit goes to bit 0, second to bit 1...
                    // data_reg <= {in, data_reg[7:1]} puts in at bit 7. 
                    // data_reg <= {data_reg[6:0], in} puts in at bit 0.
                    
                    data_reg <= {data_reg[6:0], in};
                    
                    if (bit_cnt == 3'd7) begin
                        state <= STATE_STOP;
                    end else begin
                        bit_cnt <= bit_cnt + 3'd1;
                    end
                end

                STATE_STOP: begin
                    if (in == 1'b1) begin
                        // Valid stop bit
                        out_reg  <= data_reg;
                        done_reg <= 1'b1;
                        state    <= STATE_IDLE;
                    end else begin
                        // Invalid stop bit
                        state    <= STATE_WAIT_STOP;
                    end
                end

                STATE_WAIT_STOP: begin
                    if (in == 1'b1) begin
                        state <= STATE_IDLE;
                    end else begin
                        state <= STATE_WAIT_STOP;
                    end
                end

                default: state <= STATE_IDLE;
            endcase
        end
    end

    // Output Assignments
    assign out_byte = out_reg;
    assign done     = done_reg;

endmodule
