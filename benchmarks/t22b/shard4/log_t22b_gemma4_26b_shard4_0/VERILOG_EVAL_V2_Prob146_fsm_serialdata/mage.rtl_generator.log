    input  logic       clk,
    input  logic       in,
    input  logic       reset,
    output logic [7:0] out_byte,
    output logic       done
);

    // State definitions
    localparam logic [1:0] STATE_IDLE         = 2'b00;
    localparam logic [1:0] STATE_RECEIVE_DATA = 2'b01;
    localparam logic [1:0] STATE_CHECK_STOP   = 2'b10;
    localparam logic [1:0] STATE_WAIT_STOP    = 2'b11;

    logic [1:0] state;
    logic [2:0] bit_cnt;
    logic [7:0] data_reg;

    // Initialize signals to avoid X
    initial begin
        state = STATE_IDLE;
        bit_cnt = 3'b0;
        data_reg = 8'b0;
    end

    // FSM Sequential Logic
    always @(posedge clk) begin
        if (reset) begin
            state <= STATE_IDLE;
            bit_cnt <= 3'b0;
            data_reg <= 8'b0;
        end else begin
            case (state)
                STATE_IDLE:
                    if (in == 1'b0) begin
                        state <= STATE_RECEIVE_DATA;
                        bit_cnt <= 3'b0;
                        data_reg <= 8'b0;
                    end

                STATE_RECEIVE_DATA:
                    begin
                        // Shift in: first bit received is LSB
                        // To get LSB at bit 0 after 8 bits, we shift left
                        // bit0 arrives: data_reg = {bit0, 7'b0}
                        // bit1 arrives: data_reg = {bit1, bit0, 6'b0} ...
                        // This puts bit0 at index 0 after 8 cycles
                        data_reg <= {data_reg[6:0], in};
                        if (bit_cnt == 3'd7) begin
                            state <= STATE_CHECK_STOP;
                        end else begin
                            bit_cnt <= bit_cnt + 3'd1;
                        end
                    end

                STATE_CHECK_STOP:
                    if (in == 1'b1) begin
                        state <= STATE_IDLE;
                    end else begin
                        state <= STATE_WAIT_STOP;
                    end

                STATE_WAIT_STOP:
                    if (in == 1'b1) begin
                        state <= STATE_IDLE;
                    end else begin
                        state <= STATE_WAIT_STOP;
                    end

                default:
                    state <= STATE_IDLE;
            endcase
        end
    end

    // Output Logic
    // done is high when we successfully find a stop bit.
    // Based on the requirement "It should assert done each time it finds a stop bit."
    // and "If the stop bit does not appear when expected, the FSM must wait..."
    // Also "out_byte needs to be valid when done is 1".
    
    // We need to detect the transition to the successful stop bit.
    // In STATE_CHECK_STOP, if in == 1, it means the stop bit was correct.
    
    logic done_next;
    always @(*):
    begin
        done_next = 1'b0;
        if (state == STATE_CHECK_STOP && in == 1'b1) begin
            done_next = 1'b1;
        end
        // Note: if we are in STATE_WAIT_STOP and in becomes 1, 
        // the spec says "wait until it finds a stop bit before attempting to receive the next byte".
        // It doesn't explicitly say to pulse 'done' if the stop bit was late/wrong.
        // "It should assert done each time it finds a stop bit" usually refers to valid bytes.
        // Let's assume 'done' is only for validly received bytes.
    end

    // To make 'done' a single cycle pulse, we can use a register or just the combinational logic.
    // Given the FSM transitions, if state is CHECK_STOP and in is 1, next state is IDLE.
    // So done will be high for exactly one cycle.
    
    assign done = done_next;

    // out_byte is valid when done is 1.
    // Since the data was collected in data_reg, we need to output it.
    // However, data_reg is updated in RECEIVE_DATA. 
    // In CHECK_STOP, data_reg contains the 8 bits.
    // But we need to handle the shift direction. 
    // If we use `data_reg <= {data_reg[6:0], in}`, the first bit (LSB) ends up in `data_reg[7]`.
    // Wait, let's re-trace: 
    // bit 0: {0, 0, 0, 0, 0, 0, 0, bit0} -> data_reg[0]=bit0
    // bit 1: {bit0, 0, 0, 0, 0, 0, 0, bit1} -> data_reg[0]=bit0, data_reg[1]=bit1
    // This is `data_reg <= {data_reg[6:0], in}`. 
    // After 8 bits, bit 0 is at index 0, bit 7 is at index 7. This is correct.

    // The data_reg holds the byte. We need to output it when done is high.
    // Since 'done' is a pulse in the cycle where we check the stop bit,
    // and data_reg is not changing in CHECK_STOP, we can just assign it.
    
    // However, the data_reg in my logic is updated during RECEIVE_DATA. 
    // When we are in CHECK_STOP, data_reg holds the final byte.
    // But there is one tiny issue: the 'in' bit that was the 8th data bit was shifted into data_reg[7].
    // Let's re-verify: 
    // Cycle 1 (bit 0): data_reg[0] = in0
    // Cycle 2 (bit 1): data_reg[1] = in1, data_reg[0] = in0
    // ... 
    // Cycle 8 (bit 7): data_reg[7] = in7, ..., data_reg[0] = in0. Correct.
    
    // We need to make sure out_byte is updated correctly. 
    // Since the spec says "out_byte needs to be valid when done is 1, and is don't-care otherwise",
    // we can use a register to hold the last valid byte to ensure it's stable.
    
    logic [7:0] out_byte_reg;
    initial out_byte_reg = 8'b0;

    always @(posedge clk) begin
        if (reset) begin
            out_byte_reg <= 8'b0;
        end else if (state == STATE_CHECK_STOP && in == 1'b1) begin
            out_byte_reg <= data_reg;
        end
    end

    assign out_byte = out_byte_reg;

endmodule
