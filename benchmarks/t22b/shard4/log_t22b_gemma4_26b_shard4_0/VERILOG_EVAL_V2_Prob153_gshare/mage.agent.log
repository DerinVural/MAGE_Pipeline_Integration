        predict_pc_r <= 7'ha;
        predict_valid <= 1;
        train_history_r <= 7'h0;
        train_pc_r <= 7'ha;
        train_taken_r <= 1;
        train_valid <= 0;
        train_mispredicted_r <= 1;
        
        @(negedge clk) reset <= 0;
        @(posedge clk);
