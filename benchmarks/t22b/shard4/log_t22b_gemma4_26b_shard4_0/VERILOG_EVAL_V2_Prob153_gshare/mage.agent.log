        @(posedge clk) reset <= 0;
        predict_valid <= 1;
        train_mispredicted_r <= 1;
        train_history_r <= 7'h7f;
        train_pc_r <= 7'h4;
        train_taken_r <= 1;
        train_valid <= 1;
        predict_valid <= 1;
        predict_pc_r <= 4;
    
        wavedrom_start("Asynchronous reset");
