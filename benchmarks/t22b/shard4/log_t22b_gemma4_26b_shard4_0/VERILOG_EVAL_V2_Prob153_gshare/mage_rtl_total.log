n29:     always @(posedge clk or posedge areset) begin\n30:         if (areset) begin\n31:             ghr <= 7\'b0;\n32:             for (int i = 0; i < 128; i++) begin\n33:                 pht[i] <= 2\'b01;\n34:             end\n35:         end else begin\n36:             // 1. PHT Update\n37:             if (train_valid) begin\n38:                 logic [6:0] train_idx;\n39:                 train_idx = train_pc ^ train_history;\n40:                 if (train_taken) begin\n41:                     if (pht[train_idx] != 2\'b11) \n42:                         pht[train_idx] <= pht[train_idx] + 1\'b1;\n43:                 end else begin\n44:                     if (pht[train_idx] != 2\'b00) \n45:                         pht[train_idx] <= pht[train_idx] - 1\'b1;\n46:                 end\n47:             end\n48: \n49:             // 2. GHR Update\n50:             // Priority: Training Misprediction Recovery > Prediction Update\n51:             if (train_valid && train_mispredicted) begin\n52:                 ghr <= train_history;\n53:             end else if (predict_valid) begin\n54:                 // The spec says: \'The branch history register is then updated... for the predicted branch.\'\n55:                 // This implies shifting in the prediction bit.\n56:                 // Note: We need the prediction bit from the CURRENT state of the PHT\n57:                 logic [6:0] pred_idx;\n58:                 logic pred_bit;\n59:                 pred_idx = predict_pc ^ ghr;\n60:                 pred_bit = pht[pred_idx][1];\n61:                 ghr <= {ghr[5:0], pred_bit};\n62:             end\n63:         end\n64:     end\n65: \n66:     // Combinational Logic: Prediction Output\n67:     always @(*):\n68:     begin\n69:         predict_taken = 1\'b0;\n70:         predict_history = 7\'b0;\n71:         if (predict_valid) begin\n72:             logic [6:0] pred_idx;\n73:             pred_idx = predict_pc ^ ghr;\n74:             predict_taken = pht[pred_idx][1];\n75:    