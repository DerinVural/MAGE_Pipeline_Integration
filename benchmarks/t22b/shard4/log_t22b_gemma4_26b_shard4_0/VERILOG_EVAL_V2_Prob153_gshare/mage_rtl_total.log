iction bit.\n                // Note: We need the prediction bit from the CURRENT state of the PHT\n                logic [6:0] pred_idx;\n                logic pred_bit;\n                pred_idx = predict_pc ^ ghr;\n                pred_bit = pht[pred_idx][1];\n                ghr <= {ghr[5:0], pred_bit};\n            end\n        end\n    end\n\n    // Combinational Logic: Prediction Output\n    always @(*):\n    begin\n        predict_taken = 1'b0;\n        predict_history = 7'b0;\n        if (predict_valid) begin\n            logic [6:0] pred_idx;\n            pred_idx = predict_pc ^ ghr;\n            predict_taken = pht[pred_idx][1];\n            predict_history = ghr;\n        end\n    end\n\nendmodule"
