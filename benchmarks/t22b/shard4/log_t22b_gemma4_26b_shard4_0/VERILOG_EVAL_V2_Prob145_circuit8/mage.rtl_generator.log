    // State encoding
    localparam S0 = 2'b00;
    localparam S1 = 2'b01;
    localparam S2 = 2'b10;
    localparam S3 = 2'b11;

    logic [1:0] state;
    logic [1:0] next_state;

    // Initialize state to avoid X
    initial begin
        state = S0;
    end

    // Sequential logic
    always @(posedge clock) begin
        state <= next_state;
    end

    // Next state logic
    always @(*) begin
        next_state = state;
        case (state) 
            S0: begin
                if (a) next_state = S1;
                else   next_state = S0;
            end
            S1: begin
                if (a) next_state = S1;
                else   next_state = S2;
            end
            S2: begin
                if (a) next_state = S2;
                else   next_state = S3;
            end
            S3: begin
                if (a) next_state = S2;
                else   next_state = S0;
            end
            default: next_state = S0;
        endcase
    end

    // Output logic (Moore Machine)
    always @(*) begin
        case (state) 
            S0: begin p = 1'b0; q = 1'b0; end
            S1: begin p = 1'b1; q = 1'b0; end
            S2: begin p = 1'b1; q = 1'b1; end
            S3: begin p = 1'b0; q = 1'b1; end
            default: begin p = 1'b0; q = 1'b0; end
        endcase
    end

endmodule
