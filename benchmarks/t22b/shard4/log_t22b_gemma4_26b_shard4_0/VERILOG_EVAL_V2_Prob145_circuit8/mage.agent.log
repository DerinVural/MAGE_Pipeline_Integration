[2026-05-13 15:11:03,237 - mage.agent - INFO] module TopModule (
    input  logic clock,
    input  logic a,
    output logic p,
    output logic q
);

    // State encoding
    localparam STATE_0 = 3'd0;
    localparam STATE_1 = 3'd1;
    localparam STATE_2 = 3'd2;
    localparam STATE_3 = 3'd3;
    localparam STATE_4 = 3'd4;
    localparam STATE_5 = 3'd5;

    logic [2:0] state;

    // Initialize state to avoid X in simulation
    initial begin
        state = STATE_0;
    end

    // Sequential logic for state transitions
    always @(posedge clock) begin
        case (state)
            STATE_0: if (a) state <= STATE_1;
                      else state <= STATE_0;
            STATE_1: if (a) state <= STATE_2;
                      else state <= STATE_0;
            STATE_2: if (a) state <= STATE_3;
                      else state <= STATE_0;
            STATE_3: if (a) state <= STATE_3;
                      else state <= STATE_4;
            STATE_4: if (a) state <= STATE_4;
                      else state <= STATE_5;
            STATE_5: if (a) state <= STATE_4;
                      else state <= STATE_0;
            default: state <= STATE_0;
        endcase
    end

    // Combinational logic for outputs
    always @(*) begin
        p = 1'b0;
        q = 1'b0;
        case (state)
            STATE_2: p = 1'b1;
            STATE_3: p = 1'b1;
            STATE_4: begin
                p = 1'b1;
                q = 1'b1;
            end
            STATE_5: begin
                p = 1'b1;
                q = 1'b1;
            end
            default: begin
                p = 1'b0;
                q = 1'b0;
            end
        endcase
    end

endmodule
