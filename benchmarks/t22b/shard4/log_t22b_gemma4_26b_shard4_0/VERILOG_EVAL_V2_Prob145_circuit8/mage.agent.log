module stimulus_gen (
    input clk,
    output logic clock=0,
    output logic a,
    output logic [511:0] wavedrom_title,
    output logic wavedrom_enable
);

    always begin
        repeat(3) @(posedge clk);
        clock = ~clock;
    end

    task wavedrom_start(input [511:0] title = "");
    endtask
    
    task wavedrom_stop;
        #1;
    endtask

    initial begin
        a <= 0;
        @(negedge clock) {a} <= 0;
        @(negedge clk) wavedrom_start("Unknown circuit");
            @(posedge clk) {a} <= 0;
            repeat(14) @(posedge clk, negedge clk) a <= ~a;
            repeat(5) @(posedge clk, negedge clk);
            repeat(8) @(posedge clk, negedge clk) a <= ~a;
        wavedrom_stop();

        repeat(200) @(posedge clk, negedge clk)
            a <= $urandom;
        $finish;
    end
endmodule

// Dummy RefModule to make the testbench runnable based on waveform patterns
module RefModule (
    input logic clock,
    input logic a,
    output logic p,
    output logic q
);
    logic [2:0] state;
    always @(posedge clock) begin
        case (state)
            3'd0: if (a) state <= 3'd1; else state <= 3'd0;
            3'd1: if (a) state <= 3'd2; else state <= 3'd0;
            3'd2: if (a) state <= 3'd3; else state <= 3'd0;
            3'd3: if (a) state <= 3'd3; else state <= 3'd4;
            3'd4: if (!a) state <= 3'd5; else state <= 3'd4;
            3'd5: if (!a) state <= 3'd0; else state <= 3'd4;
            default: state <= 3'd0;
        endcase
    end
    assign p = (state == 3'd2 || state == 3'd3 || state == 3'd4 || state == 3'd5);
    assign q = (state == 3'd4 || state == 3'd5);
endmodule

module tb();

    typedef struct packed {
        int errors;
        int errortime;
        int errors_p;
        int errortime_p;
        int errors_q;
        int errortime_q;
        int clocks;
    } stats;
    
    stats stats1;
    
    wire [511:0] wavedrom_title;
    wire wavedrom_enable;
    reg clk=0;
    initial forever #5 clk = ~clk;

    logic clock;
    logic a;
    logic p_ref;
    logic p_dut;
    logic q_ref;
    logic q_dut;

    // Queues for mismatch display
    logic [511:0] a_q [$];
    logic [511:0] p_ref_q [$];
    logic [511:0] p_dut_q [$];
    logic [511:0] q_ref_q [$];
    logic [511:0] q_dut_q [$];
    localparam MAX_QUEUE_SIZE = 10;

    initial begin 
        $dumpfile("wave.vcd");
        $dumpvars(1, stim1.clk, tb_mismatch, clock, a, p_ref, p_dut, q_ref, q_dut);
    end

    wire tb_match;
    wire tb_mismatch = ~tb_match;
    
    stimulus_gen stim1 (
        .clk,
        .*,
        .clock,
        .a
    );

    RefModule good1 (
        .clock,
        .a,
        .p(p_ref),
        .q(q_ref)
    );
        
    TopModule top_module1 (
        .clock,
        .a,
        .p(p_dut),
        .q(q_dut)
    );

    assign tb_match = ( { p_ref, q_ref } === ( { p_ref, q_ref } ^ { p_dut, q_dut } ^ { p_ref, q_ref } ) );

    always @(posedge clk, negedge clk) begin
        // Maintain Queues
        if (a_q.size() >= MAX_QUEUE_SIZE) begin
            a_q.delete(0);
            p_ref_q.delete(0);
            p_dut_q.delete(0);
            q_ref_q.delete(0);
            q_dut_q.delete(0);
        end
        a_q.push_back(a);
        p_ref_q.push_back(p_ref);
        p_dut_q.push_back(p_dut);
        q_ref_q.push_back(q_ref);
        q_dut_q.push_back(q_dut);

        stats1.clocks++;
        
        if (!tb_match) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;

            // Display queue on first mismatch
            if (stats1.errors == 1) begin
                $display("\n--- FIRST MISMATCH DETECTED AT TIME %0t ---", $time);
                $display("History (Last %0d samples):", a_q.size());
                for (int i = 0; i < a_q.size(); i++) begin
                    $display("Time: %0t | a=%b | p_ref=%b, p_dut=%b | q_ref=%b, q_dut=%b", 
                        $time - (a_q.size()-1-i)*10, a_q[i], p_ref_q[i], p_dut_q[i], q_ref_q[i], q_dut_q[i]);
                end
            end
        end

        if (p_ref !== ( p_ref ^ p_dut ^ p_ref )) begin 
            if (stats1.errors_p == 0) stats1.errortime_p = $time;
            stats1.errors_p = stats1.errors_p + 1;
        end

        if (q_ref !== ( q_ref ^ q_dut ^ q_ref )) begin 
            if (stats1.errors_q == 0) stats1.errortime_q = $time;
            stats1.errors_q = stats1.errors_q + 1;
        end
    end

    final begin
        if (stats1.errors == 0) begin
            $display("SIMULATION PASSED");
        end else begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
        end

        if (stats1.errors_p) $display("Hint: Output 'p' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_p, stats1.errortime_p);
        else $display("Hint: Output 'p' has no mismatches.");
        
        if (stats1.errors_q) $display("Hint: Output 'q' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_q, stats1.errortime_q);
        else $display("Hint: Output 'q' has no mismatches.");

        $display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
        $display("Simulation finished at %0d ps", $time);
        $display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
    end

    initial begin
        #1000000;
        $display("TIMEOUT");
        $finish();
    end

endmodule
