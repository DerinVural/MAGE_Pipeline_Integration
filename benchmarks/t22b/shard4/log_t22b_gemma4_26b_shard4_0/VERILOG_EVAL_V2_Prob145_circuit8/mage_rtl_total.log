`define OK 12
`define INCORRECT 13

module stimulus_gen (
    input clk,
    output logic clock=0,
    output logic a,
    output logic [511:0] wavedrom_title,
    output logic wavedrom_enable
);

    always begin
        repeat(3) @(posedge clk);
        clock = ~clock;
    end

    task wavedrom_start(input[511:0] title = "");
        wavedrom_enable <= 1;
        wavedrom_title <= title;
    endtask
    
    task wavedrom_stop;
        #1;
        wavedrom_enable <= 0;
    endtask

    initial begin
        a <= 0;
        wavedrom_enable <= 0;
        wavedrom_title <= 0;
        @(negedge clock) {a} <= 0;
        @(negedge clk) wavedrom_start("Unknown circuit");
            @(posedge clk) {a} <= 0;
            repeat(14) @(posedge clk,negedge clk) a <= ~a;
            repeat(5) @(posedge clk, negedge clk);
            repeat(8) @(posedge clk,negedge clk) a <= ~a;
        wavedrom_stop();

        repeat(200) @(posedge clk, negedge clk)
            a <= $urandom;
        $finish;
    end
endmodule

// Dummy RefModule to allow compilation
module RefModule (
    input  logic clock,
    input  logic a,
    output logic p,
    output logic q
);
