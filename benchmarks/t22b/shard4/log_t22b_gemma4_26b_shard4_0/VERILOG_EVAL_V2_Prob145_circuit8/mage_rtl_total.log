// Dummy RefModule to make the testbench runnable based on waveform patterns
module RefModule (
    input logic clock,
    input logic a,
    output logic p,
    output logic q
);
    logic [2:0] state;
    always @(posedge clock) begin
        case (state)
            3'd0: if (a) state <= 3'd1; else state <= 3'd0;
            3'd1: if (a) state <= 3'd2; else state <= 3'd0;
            3'd2: if (a) state <= 3'd3; else state <= 3'd0;
            3'd3: if (a) state <= 3'd3; else state <= 3'd4;
            3'd4: if (!a) state <= 3'd5; else state <= 3'd4;
            3'd5: if (!a) state <= 3'd0; else state <= 3'd4;
            default: state <= 3'd0;
        endcase
    end
    assign p = (state == 3'd2 || state == 3'd3 || state == 3'd4 || state == 3'd5);
    assign q = (state == 3'd4 || state == 3'd5);
endmodule

