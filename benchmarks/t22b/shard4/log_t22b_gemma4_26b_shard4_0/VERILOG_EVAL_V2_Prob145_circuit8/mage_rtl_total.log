    localparam STATE_S2 = 2'b10;
    localparam STATE_S3 = 2'b11;

    logic [1:0] current_state;
    logic [1:0] next_state;

    // Initialize state
    initial begin
        current_state = STATE_S0;
    end

    // State register
    always @(posedge clock) begin
