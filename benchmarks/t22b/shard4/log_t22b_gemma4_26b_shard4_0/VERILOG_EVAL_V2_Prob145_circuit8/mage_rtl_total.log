            STATE_S1:
                if (a) next_state = STATE_S1;
                else   next_state = STATE_S2;
            STATE_S2:
                if (a) next_state = STATE_S2;
                else   next_state = STATE_S3;
            STATE_S3:
                if (a) next_state = STATE_S2;
                else   next_state = STATE_S0;
            default:
                next_state = STATE_S0;
        endcase
    end

    // Output logic
    always @(*) begin
        case (current_state)
            STATE_S0:
                begin p = 1'b0; q = 1'b0; end
            STATE_S1:
                begin p = 1'b1; q = 1'b0; end
            STATE_S2:
                begin p = 1'b1; q = 1'b1; end
            STATE_S3:
                begin p = 1'b0; q = 1'b1; end
            default:
                begin p = 1'b0; q = 1'b0; end
        endcase
    end

endmodule
