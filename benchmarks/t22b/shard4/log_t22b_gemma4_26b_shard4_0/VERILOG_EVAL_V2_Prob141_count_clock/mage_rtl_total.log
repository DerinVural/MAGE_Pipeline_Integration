      q_hh_dut.push_back(hh_dut); q_mm_dut.push_back(mm_dut); q_ss_dut.push_back(ss_dut);\n        q_pm_dut.push_back(pm_dut); reset_q.push_back(reset); ena_q.push_back(ena);\n        q_hh_ref.push_back(hh_ref); q_mm_ref.push_back(mm_ref); q_ss_ref.push_back(ss_ref); q_pm_ref.push_back(pm_ref);\n\n        stats1.clocks++;\n\n        if (!tb_match) begin\n            if (stats1.errors == 0) begin\n                stats1.errortime = $time;\n                $display("Mismatch detected at time %t", $time);\n                $display("\\nFirst Mismatch Details:");\n                for (int i = 0; i < q_hh_in.size(); i++) begin\n                    $display("Cycle %d: reset=%b, ena=%b, in(hh,mm,ss)=%h:%h:%h, dut(hh,mm,ss)=%h:%h:%h, ref(hh,mm,ss)=%h:%h:%h, pm_dut=%b, pm_ref=%b",\n                        i, reset_q[i], ena_q[i], q_hh_in[i], q_mm_in[i], q_ss_in[i], \n                        q_hh_dut[i], q_mm_dut[i], q_ss_dut[i], \n                        q_hh_ref[i], q_mm_ref[i], q_ss_ref[i], q_pm_dut[i], q_pm_ref[i]);\n                    if (q_hh_dut[i] !== q_hh_ref[i] || q_mm_dut[i] !== q_mm_ref[i] || q_ss_dut[i] !== q_ss_ref[i] || q_pm_dut[i] !== q_pm_ref[i]) begin\n                         $display("  [!] Mismatch in this cycle!");\n                    end else begin\n                         $display("  [OK] Match");\n                    end\n                end\n            end else begin\n                // Just continue counting for the stats\n            end\n            \n            if (stats1.errors == 0) stats1.errors++;\n            if (pm_ref !== ( pm_ref ^ pm_dut ^ pm_ref )) begin\n                if (stats1.errors_pm == 0) stats1.errortime_pm = $time;\n                stats1.errors_pm++;\n            end\n            if (hh_ref !== ( hh_ref ^ hh_dut ^ hh_ref )) begin\n                if (stats1.errors_hh == 0) stats1.errortime_hh = $time;\n                stats1.errors_hh++;\n            end\n            if (mm_ref !== ( mm_ref ^ mm_dut ^ mm_ref )) begin\n  