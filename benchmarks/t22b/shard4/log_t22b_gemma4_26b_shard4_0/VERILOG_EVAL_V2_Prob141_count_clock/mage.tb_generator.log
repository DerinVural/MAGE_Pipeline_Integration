clk=0;\n    initial forever #5 clk = ~clk;\n\n    logic reset;\n    logic ena;\n    logic pm_ref;\n    logic pm_dut;\n    logic [7:0] hh_ref;\n    logic [7:0] hh_dut;\n    logic [7:0] mm_ref;\n    logic [7:0] mm_dut;\n    logic [7:0] ss_ref;\n    logic [7:0] ss_dut;\n\n    initial begin \n        $dumpfile(\"wave.vcd\");\n        $dumpvars(1, stim1.clk, tb_mismatch, clk, reset, ena, pm_ref, pm_dut, hh_ref, hh_dut, mm_ref, mm_dut, ss_ref, ss_dut);\n    end\n\n    wire tb_match;\n    wire tb_mismatch = ~tb_match;\n    \n    // To track the first mismatch for display\n    bit first_mismatch_displayed = 0;\n\n    stimulus_gen stim1 (\n        .clk,\n        .*,\n        .reset,\n        .ena\n    );\n\n    RefModule good1 (\n        .clk,\n        .reset,\n        .ena,\n        .pm(pm_ref),\n        .hh(hh_ref),\n        .mm(mm_ref),\n        .ss(ss_ref)\n    );\n        \n    TopModule top_module1 (\n        .clk,\n        .reset,\n        .ena,\n        .pm(pm_dut),\n        .hh(hh_dut),\n        .mm(mm_dut),\n        .ss(ss_dut)\n    );\n\n    bit strobe = 0;\n    task wait_for_end_of_timestep;\n        repeat(5) begin\n            strobe <= !strobe;\n            @(strobe);\n        end\n    endtask    \n\n    assign tb_match = ( { pm_ref, hh_ref, mm_ref, ss_ref } === ( { pm_ref, hh_ref, mm_ref, ss_ref } ^ { pm_dut, hh_dut, mm_dut, ss_dut } ^ { pm_ref, hh_ref, mm_ref, ss_ref } ) );\n\n    always @(posedge clk, negedge clk) begin\n        stats1.clocks++;\n        if (!tb_match) begin\n            if (stats1.errors == 0) stats1.errortime = $time;\n            stats1.errors++;\n\n            // Display the first mismatch details\n            if (!first_mismatch_displayed) begin\n                $display(\"--- FIRST MISMATCH DETECTED ---\");\n                $display(\"Time: %0t\", $time);\n                $display(\"Inputs: clk=%b, reset=%b, ena=%b\", clk, reset, ena);\n                $display(\"Outputs (DUT): pm=%b, hh=%h (%b), mm=%h (%b), ss=%h (%b)\", \n          