s_cnt_int / 10), (s_cnt_int % 10) }; // This is not quite right for BCD bit-width\n    end\n\n    // Correct BCD conversion:\n    always @(*) begin\n        ss = { 4'd0, 4'd0 };\n        ss[3:0] = s_cnt_int % 10;\n        ss[7:4] = s_cnt_int / 10;\n\n        mm[3:0] = m_cnt_int % 10;\n        mm[7:4] = m_cnt_int / 10;\n\n        hh[3:0] = h_cnt_int % 10;\n        hh[7:4] = h_cnt_int / 10;\n        \n        pm = p_cnt_int;\n    end\n\nendmodule"
