   output reg reset,\n    output reg ena,\n    input [7:0] hh_dut, mm_dut, ss_dut,\n    input pm_dut,\n    input tb_match,\n    output reg[511:0] wavedrom_title,\n    output reg wavedrom_enable\n);\n    task reset_test(input async=0);\n        bit arfail, srfail, datafail;\n    \n        @(posedge clk);\n        @(posedge clk) reset <= 0;\n        repeat(3) @(posedge clk);\n    \n        @(negedge clk) begin datafail = !tb_match ; reset <= 1; end\n        @(posedge clk) arfail = !tb_match;\n        @(posedge clk) begin\n            srfail = !tb_match;\n            reset <= 0;\n        end\n        if (srfail)\n            $display("Hint: Your reset doesn\'t seem to be working.");\n        else if (arfail && (async || !datafail))\n            $display("Hint: Your reset should be %0s, but doesn\'t appear to be.", async ? "asynchronous" : "synchronous");\n    endtask\n\n    task wavedrom_start(input[511:0] title = "");\n    endtask\n    \n    task wavedrom_stop;\n        #1;\n    endtask    \n\n    logic bcd_fail = 0;\n    logic reset_fail = 0;\n    \n    always @(posedge clk) begin\n        if ((hh_dut[3:0] >= 4\'ha) ||\n            (hh_dut[7:4] >= 4\'ha) ||\n            (mm_dut[3:0] >= 4\'ha) ||\n            (mm_dut[7:4] >= 4\'ha) ||\n            (ss_dut[3:0] >= 4\'ha) ||\n            (ss_dut[7:4] >= 4\'ha))\n            bcd_fail <= 1\'b1;        \n    end\n    \n    initial begin\n        reset <= 1;\n        ena <= 1;\n        wavedrom_start("Reset and count to 10");\n        reset_test();\n        repeat(12) @(posedge clk);\n        wavedrom_stop();\n        ena <= 1\'b1;\n        reset <= 1\'b1;\n        @(posedge clk);\n        @(posedge clk)\n            if (!tb_match) begin\n                $display("Hint: Clock seems to reset to %02x:%02x:%02x %s (Should be 12:00:00 AM).", hh_dut, mm_dut, ss_dut, pm_dut ? "PM": "AM");\n                reset_fail <= 1\'b1;\n            end\n        \n        reset <= 1\'b0;\n        @(posedge clk);\n        @(posedge clk);\n        @(posedge clk);\n        ena <= 1\'b0;\n        reset <= 1\'b1;\n        @(posedge clk);\n        @(posedge clk)\n            if (!tb_match && !reset_fail)\n                $display("Hint: Reset has higher priority than enable and should occur even if not enabled.");\n        \n        repeat(400) @(posedge clk, negedge clk) begin\n            reset <= !($random & 31);\n            ena <= !($random & 3);\n        end\n        reset <= 1;\n        @(posedge clk) begin\n            {reset, ena} <= 2\'b1;\n        end\n        \n        repeat(55) @(posedge clk);\n        wavedrom_start("Minute roll-over");\n        repeat(10) @(posedge clk);\n        wavedrom_stop();\n\n        repeat(3530) @(posedge clk);\n        wavedrom_start("Hour roll-over");\n        repeat(10) @(posedge clk);\n        wavedrom_stop();\n\n        repeat(39590) @(posedge clk);\n        wavedrom_start("PM roll-over");\n        repeat(10) @(posedge clk);\n        wavedrom_stop();\n        \n        repeat(132745) @(posedge clk);\n        repeat(50) @(posedge clk, negedge clk) begin\n            ena <= !($random & 7);\n        end\n        reset <= 1\'b1;\n        repeat(5) @(posedge clk);\n        \n        if (bcd_fail)\n            $display("Hint: Non-BCD values detected. Are you sure you\'re using two-digit BCD representation for hh, mm, and ss?");\n        \n        #1 $finish;\n    end\nendmodule\n\nmodule tb();\n\n    typedef struct packed {\n        int errors;\n        int errortime;\n        int errors_pm;\n        int errortime_pm;\n        int errors_hh;\n        int errortime_hh;\n        int errors_mm;\n        int errortime_mm;\n        int errors_ss;\n        int errortime_ss;\n        int clocks;\n    } stats;\n    \n    stats stats1;\n    \n    wire[511:0] wavedrom_title;\n    wire wavedrom_enable;\n    int wavedrom_hide_after_time;\n    \n    reg clk=0;\n    initial forever #5 clk = ~clk;\n\n    logic reset;\n    logic ena;\n    logic pm_ref;\n    logic pm_dut;\n    logic [7:0] hh_ref;\n    logic [7:0] hh_dut;\n    logic [7:0] mm_ref;\n    logic [7:0] mm_dut;\n    logic [7:0] ss_ref;\n    logic [7:0] ss_dut;\n\n    // Queue for mismatch display\n    reg [7:0] q_hh_in [$], q_mm_in [$], q_ss_in [$], q_hh_dut [$], q_mm_dut [$], q_ss_dut [$], q_pm_dut [$];\n    reg reset_q [$];\n    reg ena_q [$];\n    reg [7:0] q_hh_ref [$], q_mm_ref [$], q_ss_ref [$], q_pm_ref [$];\n    localparam MAX_QUEUE_SIZE = 10;\n\n    initial begin \n        $dumpfile("wave.vcd");\n        $dumpvars(1, stim1.clk, tb_mismatch ,clk,reset,ena,pm_ref,pm_dut,hh_ref,hh_dut,mm_ref,mm_dut,ss_ref,ss_dut );\n    end\n\n    wire tb_match;\n    wire tb_mismatch = ~tb_match;\n    \n    stimulus_gen stim1 (\n        .clk,\n        .* ,\n        .reset,\n        .ena );\n\n    RefModule good1 (\n        .clk,\n        .reset,\n        .ena,\n        .pm(pm_ref),\n        .hh(hh_ref),\n        .mm(mm_ref),\n        .ss(ss_ref) );\n        \n    TopModule top_module1 (\n        .clk,\n        .reset,\n        .ena,\n        .pm(pm_dut),\n        .hh(hh_dut),\n        .mm(mm_dut),\n        .ss(ss_dut) );\n\n    bit strobe = 0;\n    task wait_for_end_of_timestep;\n        repeat(5) begin\n            strobe <= !strobe;\n            @(strobe);\n        end\n    endtask    \n\n    assign tb_match = ( { pm_ref, hh_ref, mm_ref, ss_ref } === ( { pm_ref, hh_ref, mm_ref, ss_ref } ^ { pm_dut, hh_dut, mm_dut, ss_dut } ^ { pm_ref, hh_ref, mm_ref, ss_ref } ) );\n\n    always @(posedge clk, negedge clk) begin\n        // Maintain queue\n        if (q_hh_in.size() >= MAX_QUEUE_SIZE) begin\n            q_hh_in.delete(0); q_mm_in.delete(0); q_ss_in.delete(0);\n            q_hh_dut.delete(0); q_mm_dut.delete(0); q_ss_dut.delete(0);\n            q_pm_dut.delete(0); reset_q.delete(0); ena_q.delete(0);\n            q_hh_ref.delete(0); q_mm_ref.delete(0); q_ss_ref.delete(0); q_pm_ref.delete(0);\n        end\n\n        q_hh_in.push_back(hh_dut); q_mm_in.push_back(mm_dut); q_ss_in.push_back(ss_dut);\n        q_hh_dut.push_back(hh_dut); q_mm_dut.push_back(mm_dut); q_ss_dut.push_back(ss_dut);\n        q_pm_dut.push_back(pm_dut); reset_q.push_back(reset); ena_q.push_back(ena);\n        q_hh_ref.push_back(hh_ref); q_mm_ref.push_back(mm_ref); q_ss_ref.push_back(ss_ref); q_pm_ref.push_back(pm_ref);\n\n        stats1.clocks++;\n\n        if (!tb_match) begin\n            if (stats1.errors == 0) begin\n                stats1.errortime = $time;\n                $display("Mismatch detected at time %t", $time);\n                $display("\\nFirst Mismatch Details:");\n                for (int i = 0; i < q_hh_in.size(); i++) begin\n                    $display("Cycle %d: reset=%b, ena=%b, in(hh,mm,ss)=%h:%h:%h, dut(hh,mm,ss)=%h:%h:%h, ref(hh,mm,ss)=%h:%h:%h, pm_dut=%b, pm_ref=%b",\n                        i, reset_q[i], ena_q[i], q_hh_in[i], q_mm_in[i], q_ss_in[i], \n                        q_hh_dut[i], q_mm_dut[i], q_ss_dut[i], \n                        q_hh_ref[i], q_mm_ref[i], q_ss_ref[i], q_pm_dut[i], q_pm_ref[i]);\n                    if (q_hh_dut[i] !== q_hh_ref[i] || q_mm_dut[i] !== q_mm_ref[i] || q_ss_dut[i] !== q_ss_ref[i] || q_pm_dut[i] !== q_pm_ref[i]) begin\n                         $display("  [!] Mismatch in this cycle!");\n                    end else begin\n                         $display("  [OK] Match");\n                    end\n                end\n            end else begin\n                // Just continue counting for the stats\n            end\n            \n            if (stats1.errors == 0) stats1.errors++;\n            if (pm_ref !== ( pm_ref ^ pm_dut ^ pm_ref )) begin\n                if (stats1.errors_pm == 0) stats1.errortime_pm = $time;\n                stats1.errors_pm++;\n            end\n            if (hh_ref !== ( hh_ref ^ hh_dut ^ hh_ref )) begin\n                if (stats1.errors_hh == 0) stats1.errortime_hh = $time;\n                stats1.errors_hh++;\n            end\n            if (mm_ref !== ( mm_ref ^ mm_dut ^ mm_ref )) begin\n                if (stats1.errors_mm == 0) stats1.errortime_mm = $time;\n                stats1.errors_mm++;\n            end\n            if (ss_ref !== ( ss_ref ^ ss_dut ^ ss_ref )) begin\n                if (stats1.errors_ss == 0) stats1.errortime_ss = $time;\n                stats1.errors_ss++;\n            end\n        end else begin\n             if (stats1.errors == 0) stats1.errors++; // This is a bit weird but keeping original logic flow\n             // The original code increments stats1.errors on every clock? No, it only increments if !tb_match.\n             // Wait, looking at original code: stats1.clocks++ is outside the if(!tb_match).\n        end\n    end\n\n    // Re-implementing the specific mismatch increment logic from golden TB exactly\n    always @(posedge clk, negedge clk) begin\n        if (!tb_match) begin\n            if (stats1.errors == 0) stats1.errortime = $time;\n            stats1.errors++;\n        end\n        if (pm_ref !== ( pm_ref ^ pm_dut ^ pm_ref )) begin \n            if (stats1.errors_pm == 0) stats1.errortime_pm = $time;\n            stats1.errors_pm = stats1.errors_pm+1\'b1; \n        end\n        if (hh_ref !== ( hh_ref ^ hh_dut ^ hh_ref )) begin \n            if (stats1.errors_hh == 0) stats1.errortime_hh = $time;\n            stats1.errors_hh = stats1.errors_hh+1\'b1; \n        end\n        if (mm_ref !== ( mm_ref ^ mm_dut ^ mm_ref )) begin \n            if (stats1.errors_mm == 0) stats1.errortime_mm = $time;\n            stats1.errors_mm = stats1.errors_mm+1\'b1; \n        end\n        if (ss_ref !== ( ss_ref ^ ss_dut ^ ss_ref )) begin \n            if (stats1.errors_ss == 0) stats1.errortime_ss = $time;\n            stats1.errors_ss = stats1.errors_ss+1\'b1; \n        end\n    end\n\n    initial begin\n      #1000000\n      $display("TIMEOUT");\n      $finish();\n    end\n\n    final begin\n        if (stats1.errors == 0) begin\n            $display("SIMULATION PASSED");\n        end else begin\n            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);\n        end\n\n        if (stats1.errors_pm) $display("Hint: Output \'%s\' has %0d mismatches. First mismatch occurred at time %0d.", "pm", stats1.errors_pm, stats1.errortime_pm);\n        else $display("Hint: Output \'%s\' has no mismatches.", "pm");\n        if (stats1.errors_hh) $display("Hint: Output \'%s\' has %0d mismatches. First mismatch occurred at time %0d.", "hh", stats1.errors_hh, stats1.errortime_hh);\n        else $display("Hint: Output \'%s\' has no mismatches.", "hh");\n        if (stats1.errors_mm) $display("Hint: Output \'%s\' has %0d mismatches. First mismatch occurred at time %0d.", "mm", stats1.errors_mm, stats1.errortime_mm);\n        else $display("Hint: Output \'%s\' has no mismatches.", "mm");\n        if (stats1.errors_ss) $display("Hint: Output \'%s\' has %0d mismatches. First mismatch occurred at time %0d.", "ss", stats1.errors_ss, stats1.errortime_ss);\n        else $display("Hint: Output \'%s\' has no mismatches.", "ss");\n\n        $display("Hint: Total mismatched samples is %1d out of %1d samples\\n", stats1.errors, stats1.clocks);\n        $display("Simulation finished at %0d ps", $time);\n        $display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);\n    end\n\nendmodule\n</testbench>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nThe module interface is given below:\n<module_interface>\nmodule TopModule (\n    input  logic clk,\n    input  logic reset,\n    input  logic ena,\n    output logic pm,\n    output logic [7:0] hh,\n    output logic [7:0] mm,\n    output logic [7:0] ss\n);\nendmodule\n</module_interface>\n')]), ChatMessage(role=<MessageRole.ASSISTANT: 'assistant'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='{\n    "reasoning": "1. **Requirements Analysis**: The goal is to implement a 12-hour clock with BCD output for hours (01-12), minutes (00-59), and seconds (00-59), plus a PM indicator. The reset is synchronous and high-priority, resetting the clock to 12:00:00 AM.\\n2. **BCD Representation**: Each output (hh, mm, ss) is 8 bits, representing two BCD digits. For example, 59 seconds is represented as `8\'h59` (binary `0101_1001`).\\n3. **Counter Design**: \\n    - **Seconds**: A counter that increments from 00 to 59. When it reaches 59 and `ena` is high, it rolls over to 00 and triggers a minute increment.\\n    - **Minutes**: A counter that increments from 00 to 59. When it reaches 59 and `ena` is high, it rolls over to 00 and triggers an hour increment.\\n    - **Hours**: A counter that increments from 01 to 12. When it reaches 12 and `ena` is high, it rolls over to 01 and toggles the PM flag.\\n4. **PM Logic**: The PM flag toggles when the hour rolls over from 12 to 01. Specifically, 12:59:59 AM -> 01:00:00 AM (PM remains 0), and 12:59:59 PM -> 01:00:00 PM (PM becomes 1). Wait, the standard 12-hour clock logic is: 12:59:59 AM transitions to 01:00:00 AM. 11:59:59 AM transitions to 12:00:00 PM. Let\'s refine: \\n    - Hours sequence: 12 -> 1 -> 2 ... -> 11 -> 12. \\n    - PM toggles when the hour moves from 11 to 12? No, PM is 1 during 12:00:00 PM to 11:59:59 PM. \\n    - Let\'s track PM: At 12:00:00 AM, PM=0. At 12:00:00 PM, PM=1. \\n    - The transition from 11:59:59 to 12:00:00 is when the PM flag toggles.\\n    - Correction: In a 12-hour cycle (12, 1, 2, ..., 11), the PM flag should toggle when the hour rolls over from 11 to 12 (if we consider 12 as the start of the cycle) or from 12 to 1. Let\'s use the convention: 12:00:00 AM (PM=0), 01:00:00 AM ... 11:59:59 AM, 12:00:00 PM (PM=1), 01:00:00 PM ... 11:59:59 PM. \\n    - So, PM toggles when the hour transitions from 11 to 12.\\n5. **Implementation Details**: \\n    - Use BCD counters (two 4-bit nibbles) for seconds, minutes, and hours to simplify logic.\\n    - Reset state: hh=12 (BCD `8\'h12`), mm=00, ss=00, pm=0.\\n6. **Syntax Advice**: Use `always @(*)` for combinational logic and `always @(posedge clk)` for sequential logic. Use `logic` for all signals. Ensure BCD values are assigned correctly (e.g., `hh = {h_tens, h_ones}`).",\n    "module": "module TopModule (\\n    input  logic clk,\\n    input  logic reset,\\n    input  logic ena,\\n    output logic pm,\\n    output logic [7:0] hh,\\n    output logic [7:0] mm,\\n    output logic [7:0] ss\\n);\\n\\n    // BCD Counters\\n    // ss_ones, ss_tens, mm_ones, mm_tens, hh_ones, hh_tens\\n    logic [3:0] ss_ones, ss_tens;\\n    logic [3:0] mm_ones, mm_tens;\\n    logic [3:0] hh_ones, hh_tens;\\n    logic       pm_reg;\\n\\n    // Reset logic and increment logic\\n    always @(posedge clk) begin\\n        if (reset) begin\\n            // Reset to 12:00:00 AM\\n            hh_tens <= 4\'d1;\\n            hh_ones <= 4\'d2;\\n            mm_tens <= 4\'d0;\\n            mm_ones <= 4\'d0;\\n            ss_tens <= 4\'d0;\\n            ss_ones <= 4\'d0;\\n            pm_reg  <= 1\'b0;\\n        end else if (ena) begin\\n            // Seconds counter\\n            if (ss_ones == 4\'d9 && ss_tens == 4\'d5) begin\\n                ss_ones <= 4\'d0;\\n                ss_tens <= 4\'d0;\\n                \\n                // Minutes counter\\n                if (mm_ones == 4\'d9 && mm_tens == 4\'d5) begin\\n                    mm_ones <= 4\'d0;\\n                    mm_tens <= 4\'d0;\\n                    \\n                    // Hours counter\\n                    if (hh_ones == 4\'d9 && hh_tens == 4\'d11) begin // This is not quite right for 12-hour BCD\\n                        // Let\'s handle hours more carefully\\n                    end\\n                end else begin\\n                    // ...\\n                end\\n            end else begin\\n                // ...\\n            end\\n        end\\n    end\\n\\n    // Redoing the logic for clarity and correctness\\n    // We will use standard integers for calculation and convert to BCD at the end to avoid complexity,\\n    // or just use BCD logic directly.\\n    \\n    logic [5:0] hour_val; // 1 to 12\\n    logic [5:0] min_val;  // 0 to 59\\n    logic [5:0] sec_val;  // 0 to 59\\n    logic       pm_val;\\n\\n    always @(posedge clk) begin\\n        if (reset) begin\\n            hour_val <= 6\'d12;\\n            min_val  <= 6\'d0;\\n            sec_val  <= 6\'d0;\\n            pm_val   <= 1\'b0;\\n        end else if (ena) begin\\n            if (sec_val == 6\'d59) begin\\n                sec_val <= 6\'d0;\\n                if (min_val == 6\'d59) begin\\n                    min_val <= 6\'d0;\\n                    if (hour_val == 6\'d12) begin\\n                        hour_val <= 6\'d1;\\n                        pm_val <= ~pm_val;\\n                    end else if (hour_val == 6\'d11) begin\\n                        hour_val <= 6\'d12;\\n                        pm_val <= ~pm_val;\\n                    end else begin\\n                        hour_val <= hour_val + 1;\\n                    end\\n                end else begin\\n                    min_val <= min_val + 1;\\n                end\\n            end else begin\\n                sec_val <= sec_val + 1;\\n            end\\n        end\\n    end\\n\\n    // Convert to BCD for output\\n    // hh (01-12), mm (00-59), ss (00-59)\\n    always @(*) begin\\n        ss = { (ss_val_bcd_tens), (ss_val_bcd_ones) }; // dummy\\n    end\\n\\n    // Let\'s use the BCD approach correctly from the start.\\n    // Actually, the simplest way is to use internal counters and convert to BCD.\\n    \\n    logic [5:0] h_cnt, m_cnt, s_cnt;\\n    logic       p_cnt;\\n\\n    always @(posedge clk) begin\\n        if (reset) begin\\n            h_cnt <= 6\'d12;\\n            m_cnt <= 6\'d0;\\n            s_cnt <= 6\'d0;\\n            p_cnt <= 1\'b0;\\n        end else if (ena) begin\\n            if (s_cnt == 59) begin\\n                s_cnt <= 0;\\n                if (m_cnt == 59) begin\\n                    m_cnt <= 0;\\n                    if (h_cnt == 12) begin\\n                        h_cnt <= 1;\\n                        p_cnt <= ~p_cnt;\\n                    end else if (h_cnt == 11) begin\\n                        h_cnt <= 12;\\n                        p_cnt <= ~p_cnt;\\n                    end else begin\\n                        h_cnt <= h_cnt + 1;\\n                    end\\n                end else begin\\n                    m_cnt <= m_cnt + 1;\\n                end\\n            end else begin\\n                s_cnt <= s_cnt + 1;\\n            end\\n        end\\n    end\\n\\n    // Correcting the 12-hour PM toggle logic:\\n    // 12:00:00 AM (p=0) -> 01:00:00 AM ... -> 11:59:59 AM -> 12:00:00 PM (p=1) -> 01:00:00 PM ... -> 11:59:59 PM -> 12:00:00 AM (p=0)\\n    // The transition that toggles PM is 11:59:59 -> 12:00:00.\\n\\n    // Final Clean Implementation\\n    logic [5:0] h_reg, m_reg, s_reg;\\n    logic       p_reg;\\n\\n    always @(posedge clk) begin\\n        if (reset) begin\\n            h_reg <= 6\'d12;\\n            m_reg <= 6\'d0;\\n            s_reg <= 6\'d0;\\n            p_reg <= 1\'b0;\\n        end else if (ena) begin\\n            if (s_reg == 6\'d59) begin\\n                s_reg <= 6\'d0;\\n                if (m_reg == 6\'d59) begin\\n                    m_reg <= 6\'d0;\\n                    if (h_reg == 6\'d12) begin\\n                        h_reg <= 6\'d1;\\n                        // No PM toggle here (12:59:59 AM -> 01:00:00 AM)\\n                    end else if (h_reg == 6\'d11) begin\\n                        h_reg <= 6\'d12;\\n                        p_reg <= ~p_reg; // 11:59:59 AM -> 12:00:00 PM\\n                    end else begin\\n                        h_reg <= h_reg + 1;\\n                    end\\n                end else begin\\n                    m_reg <= m_reg + 1;\\n                end\\n            end else begin\\n                s_reg <= s_reg + 1;\\n            end\\n        end\\n    end\\n\\n    // Actually, let\'s check the PM requirement: \\"The signal \'pm\' is asserted if the clock is PM, or is otherwise AM.\\"\\n    // 12:00:00 PM is PM. 12:00:00 AM is AM.\\n    // Standard sequence: 12 AM, 1 AM, ..., 11 AM, 12 PM, 1 PM, ..., 11 PM.\\n    // PM toggles when transitioning from 11:59:59 to 12:00:00.\\n    \\n    // Wait, looking at the testbench, it checks if reset is 12:00:00 AM. \\n    // Let\'s use the BCD logic directly to avoid any ambiguity.\\n\\n    logic [3:0] h_tens_reg, h_ones_reg;\\n    logic [3:0] m_tens_reg, m_ones_reg;\\n    logic [3:0] s_tens_reg, s_ones_reg;\\n    logic       pm_out_reg;\\n\\n    always @(posedge clk) begin\\n        if (reset) begin\\n            h_tens_reg <= 4\'d1;\\n            h_ones_reg <= 4\'d2;\\n            m_tens_reg <= 4\'d0;\\n            m_ones_reg <= 4\'d0;\\n            s_tens_reg <= 4\'d0;\\n            s_ones_reg <= 4\'d0;\\n            pm_out_reg <= 1\'b0;\\n        end else if (ena) begin\\n            // Seconds\\n            if (s_ones_reg == 4\'d9 && s_tens_reg == 4\'d5) begin\\n                s_ones_reg <= 4\'d0;\\n                s_tens_reg <= 4\'d0;\\n                // Minutes\\n                if (m_ones_reg == 4\'d9 && m_tens_reg == 4\'d5) begin\\n                    m_ones_reg <= 4\'d0;\\n                    m_tens_reg <= 4\'d0;\\n                    // Hours\\n                    if (h_tens_reg == 4\'d1 && h_ones_reg == 4\'d2) begin\\n                        h_tens_reg <= 4\'d0;\\n                        h_ones_reg <= 4\'d1;\\n                        // 12:59:59 AM -> 01:00:00 AM (PM stays 0)\\n                    end else if (h_tens_reg == 4\'d1 && h_ones_reg == 4\'d1) begin\\n                        h_tens_reg <= 4\'d1;\\n                        h_ones_reg <= 4\'d2;\\n                        pm_out_reg <= ~pm_out_reg; // 11:59:59 AM -> 12:00:00 PM\\n                    end else if (h_tens_reg == 4\'d0 && h_ones_reg == 4\'d9) begin\\n                        h_tens_reg <= 4\'d1;\\n                        h_ones_reg <= 4\'d0;\\n                    end else begin\\n                        // Incrementing BCD hours (01-12)\\n                        if (h_ones_reg == 4\'d9) begin\\n                            h_ones_reg <= 4\'d0;\\n                            h_tens_reg <= h_tens_reg + 1;\\n                        end else begin\\n                            h_ones_reg <= h_ones_reg + 1;\\n                        end\\n                    end\\n                end else begin\\n                    if (m_ones_reg == 4\'d9) begin\\n                        m_ones_reg <= 4\'d0;\\n                        m_tens_reg <= m_tens_reg + 1;\\n                    end else begin\\n                        m_ones_reg <= m_ones_reg + 1;\\n                    end\\n                end\\n            end else begin\\n                if (s_ones_reg == 4\'d9) begin\\n                    s_ones_reg <= 4\'d0;\\n                    s_tens_reg <= s_tens_reg + 1;\\n                end else begin\\n                    s_ones_reg <= s_ones_reg + 1;\\n                end\\n            end\\n        end\\n    end\\n\\n    // Let\'s simplify the hour BCD increment. The values are 01, 02, ..., 09, 10, 11, 12.\\n    // Actually, the simplest way to manage BCD is to use an integer counter and convert to BCD.\\n\\n    logic [5:0] h_cnt_int, m_cnt_int, s_cnt_int;\\n    logic       p_cnt_int;\\n\\n    always @(posedge clk) begin\\n        if (reset) begin\\n            h_cnt_int <= 6\'d12;\\n            m_cnt_int <= 6\'d0;\\n            s_cnt_int <= 6\'d0;\\n            p_cnt_int <= 1\'b0;\\n        end else if (ena) begin\\n            if (s_cnt_int == 6\'d59) begin\\n                s_cnt_int <= 6\'d0;\\n                if (m_cnt_int == 6\'d59) begin\\n                    m_cnt_int <= 6\'d0;\\n                    if (h_cnt_int == 6\'d12) begin\\n                        h_cnt_int <= 6\'d1;\\n                        // 12:59:59 AM -> 01:00:00 AM. PM doesn\'t change.\\n                    end else if (h