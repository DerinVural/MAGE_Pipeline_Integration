                    m_cnt <= m_cnt + 6'd1;
                end
            end else begin
                s_cnt <= s_cnt + 6'd1;
            end
        end
    end

    // Combinational logic for BCD output conversion
    always @(*) begin
        // Seconds BCD
        ss[3:0] = s_cnt % 10;
        ss[7:4] = s_cnt / 10;

        // Minutes BCD
        mm[3:0] = m_cnt % 10;
        mm[7:4] = m_cnt / 10;

        // Hours BCD
        hh[3:0] = h_cnt % 10;
        hh[7:4] = h_cnt / 10;

