                if (in[3] == 1'b1) begin
                    state_next = STATE_GOT1;
                end else begin
                    state_next = STATE_SEARCH;
                end
            default:
                state_next = STATE_SEARCH;
        endcase
    end

    // Output combinational logic
    // done is high in the cycle immediately after the third byte is received.
    // In our FSM, STATE_GOT3 is that cycle.
    always @(*) begin
        if (state == STATE_GOT3) begin
            done = 1'b1;
        end else begin
            done = 1'b0;
        end
    end

