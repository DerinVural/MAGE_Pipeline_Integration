// Mock RefModule to satisfy the golden testbench requirement
module RefModule (
    input clk,
    input [7:0] in,
    input reset,
    output logic done
);
    // A simple reference model that tracks the same logic
    logic [1:0] state;
    always @(posedge clk) begin
        if (reset) begin
            state <= 0;
            done <= 0;
        end else begin
            case (state)
                0: begin
                    done <= 0;
                    if (in[3]) state <= 1;
                end
                1: state <= 2;
                2: begin
                    done <= 1;
                    state <= 0;
                end
                default: state <= 0;
            endcase
        end
    end
endmodule

