						$display("Got Match at");
					end else begin
						$display("Got Mismatch at");
					end
					$display("Cycle %d, reset %b, input %h (%b), got output %b, exp output %b",
								i, reset_q[i], in_q[i], in_q[i], done_dut_q[i], done_ref_q[i]);
					end
