			x_q.delete(0);
			aresetn_q.delete(0);
			z_ref_q.delete(0);
			z_dut_q.delete(0);
		end
		x_q.push_back(x);
		aresetn_q.push_back(aresetn);
		z_ref_q.push_back(z_ref);
		z_dut_q.push_back(z_dut);

		stats1.clocks++;

		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
		end

		if (z_ref !== ( z_ref ^ z_dut ^ z_ref )) begin 
			if (stats1.errors_z == 0) begin
				stats1.errortime_z = $time;
				// Display queue on first mismatch
				$display("Mismatch detected at time %t", $time);
				$display("\nFirst Mismatch Queue Content:");
