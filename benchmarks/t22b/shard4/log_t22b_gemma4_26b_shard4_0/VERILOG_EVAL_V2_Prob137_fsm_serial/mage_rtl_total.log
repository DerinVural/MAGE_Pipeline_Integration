[2026-05-13 14:10:17,647 - mage.agent - INFO] module TopModule(
    input  logic clk,
    input  logic reset,
    input  logic in,
    output logic done
);

    // State definitions
    localparam STATE_IDLE         = 3'd0;
    localparam STATE_START_BIT    = 3'd1;
    localparam STATE_DATA         = 3'd2;
    localparam STATE_STOP_BIT     = 3'd3;
    localparam STATE_WAIT_FOR_STOP = 3'd4;

    // State register
    logic [2:0] state;
    logic [2:0] state_next;

    // Data and counter registers
    logic [7:0] data_reg;
    logic [3:0] bit_cnt;

    // Sequential logic
    always @(posedge clk) begin
        if (reset) begin
            state <= STATE_IDLE;
            data_reg <= 8'b0;
            bit_cnt <= 4'b0;
        end else begin
            state <= state_next;
            
            // Logic for data collection and bit counting
            if (state == STATE_DATA) begin
                data_reg <= {in, data_reg[7:1]}; // LSB first
                bit_cnt <= bit_cnt + 1'b1;
            end else if (state == STATE_START_BIT) begin
                bit_cnt <= 0;
            end else if (state == STATE_IDLE) begin
                bit_cnt <= 0;
            end else begin
                bit_cnt <= 0;
            end
        end
    end

    // Next state combinational logic
    always @(*) begin
        state_next = state;
        case (state) 
            STATE_IDLE: begin
                if (in == 1'b0) 
                    state_next = STATE_START_BIT;
                else
                    state_next = STATE_IDLE;
            end
            STATE_START_BIT: begin
                // After start bit is detected, we expect 8 data bits
                state_next = STATE_DATA;
            end
            STATE_DATA: begin
                if (bit_cnt == 4'd7) 
                    state_next = STATE_STOP_BIT;
                else
                    state_next = STATE_DATA;
            end
            STATE_STOP_BIT: begin
                if (in == 1'b1) 
                    state_next = STATE_IDLE;
                else
                    state_next = STATE_WAIT_FOR_STOP;
            end
            STATE_WAIT_FOR_STOP: begin
                // Wait until the line returns to 1 (idle/stop state)
                if (in == 1'b1) 
                    state_next = STATE_IDLE;
                else
                    state_next = STATE_WAIT_FOR_STOP;
            end
            default: state_next = STATE_IDLE;
        endcase
    end

    // Output logic
    // done is high for one cycle when a valid stop bit is detected
    always @(*) begin
        if (state == STATE_STOP_BIT && in == 1'b1) 
            done = 1'b1;
        else
            done = 1'b0;
    end

endmodule
