[2026-05-13 14:14:23,839 - mage.rtl_generator - INFO] RTL code: module TopModule(
    input  logic clk,
    input  logic reset,
    input  logic in,
    output logic done
);

    // State definitions
    localparam STATE_IDLE           = 3'd0;
    localparam STATE_START          = 3'd1;
    localparam STATE_DATA           = 3'd2;
    localparam STATE_STOP           = 3'd3;
    localparam STATE_ERROR_RECOVERY = 3'd4;

    // State registers
    logic [2:0] state;
    logic [2:0] state_next;
    logic [3:0] bit_cnt;
    logic [3:0] bit_cnt_next;
    logic       done_next;

    // Sequential logic
    always @(posedge clk) begin
        if (reset) begin
            state <= STATE_IDLE;
            bit_cnt <= 4'd0;
            done <= 1'b0;
        end else begin
            state <= state_next;
            bit_cnt <= bit_cnt_next;
            done <= done_next;
        end
    end

    // Combinational logic
    always @(*) begin
        state_next = state;
        bit_cnt_next = bit_cnt;
        done_next = 1'b0;

        case (state)
            STATE_IDLE:
                begin
                    if (in == 1'b0) begin
                        state_next = STATE_START;
                    end
                end

            STATE_START:
                begin
                    // Start bit is assumed detected. Move to data collection.
                    state_next = STATE_DATA;
                    bit_cnt_next = 4'd0;
                end

            STATE_DATA:
                begin
                    if (bit_cnt == 4'd7) begin
                        state_next = STATE_STOP;
                    end else begin
                        bit_cnt_next = bit_cnt + 4'd1;
                    end
                end

