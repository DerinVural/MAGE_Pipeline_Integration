[2026-05-13 14:14:23,878 - mage.rtl_generator - INFO] RTL code: module TopModule(
    input  logic clk,
    input  logic reset,
    input  logic in,
    output logic done
);

    // State definitions
    localparam logic [2:0] STATE_IDLE        = 3'd0;
    localparam logic [2:0] STATE_START_BIT  = 3'd1;
    localparam logic [2:0] STATE_DATA_BITS  = 3'd2;
    localparam logic [2:0] STATE_STOP_BIT   = 3'd3;
    localparam logic [2:0] STATE_WAIT_STOP  = 3'd4;

    // State and counter registers
    logic [2:0] state;
    logic [3:0] bit_cnt;

    // Sequential logic
    always @(posedge clk) begin
        if (reset) begin
            state <= STATE_IDLE;
            bit_cnt <= 4'd0;
        end else begin
            case (state)
                STATE_IDLE:
                    if (in == 1'b0) begin
                        state <= STATE_START_BIT;
                        bit_cnt <= 4'd0;
                    end else begin
                        state <= STATE_IDLE;
                    end

                STATE_START_BIT:
                    // We have just seen the start bit (0).
                    // The next bit is the first data bit.
                    state <= STATE_DATA_BITS;
                    bit_cnt <= 4'd1;

                STATE_DATA_BITS:
                    if (bit_cnt == 4'd8) begin
                        state <= STATE_STOP_BIT;
                    end else begin
                        bit_cnt <= bit_cnt + 4'd1;
                    end

                STATE_STOP_BIT:
                    if (in == 1'b1) begin
                        state <= STATE_IDLE;
                    end else begin
                        state <= STATE_WAIT_STOP;
                    end

                STATE_WAIT_STOP:
                    if (in == 1'b1) begin
                        state <= STATE_IDLE;
                    end else begin
                        state <= STATE_WAIT_STOP;
                    end

                default:
                    state <= STATE_IDLE;
            endcase
        end
    end

    // Combinational logic for output
    always @(*) begin
        done = 1'b0;
        // If we are in STOP_BIT state and the current input is 1, it means valid byte.
        // However, the FSM transitions to IDLE on the next cycle. 
        // To match the behavior where 'done' is a pulse, we check the condition here.
        if (state == STATE_STOP_BIT && in == 1'b1) begin
            done = 1'b1;
        end
    end

endmodule
