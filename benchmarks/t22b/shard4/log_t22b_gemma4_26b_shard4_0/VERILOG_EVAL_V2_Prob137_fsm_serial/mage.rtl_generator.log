    // State definitions
    localparam logic [2:0] STATE_IDLE       = 3'd0;
    localparam logic [2:0] STATE_DATA      = 3'd1;
    localparam logic [2:0] STATE_STOP      = 3'd2;
    localparam logic [2:0] STATE_WAIT_STOP = 3'd3;

    // State and counter registers
    logic [2:0] state;
    logic [3:0] bit_cnt;

    // Sequential logic
    always @(posedge clk) begin
