                        state <= STATE_STOP;
                    end else begin
                        bit_cnt <= bit_cnt + 4'd1;
                    end

                STATE_STOP:
                    if (in == 1'b1) begin
                        state <= STATE_IDLE;
                    end else begin
                        state <= STATE_WAIT_STOP;
                    end

                STATE_WAIT_STOP:
                    if (in == 1'b1) begin
                        state <= STATE_IDLE;
                    end else begin
                        state <= STATE_WAIT_STOP;
                    end

                default:
                    state <= STATE_IDLE;
            endcase
        end
    end

    // Combinational logic for output
    always @(*) begin
        done = 1'b0;
        // done is high when we are in the STOP state and the bit is valid (1)
        if (state == STATE_STOP && in == 1'b1) begin
            done = 1'b1;
        end
    end

