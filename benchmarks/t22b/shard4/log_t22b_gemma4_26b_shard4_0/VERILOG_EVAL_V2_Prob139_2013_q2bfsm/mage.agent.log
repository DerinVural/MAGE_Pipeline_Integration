			{x,y} <= $random;
		end;
		
		#1 $finish;
	end
	
endmodule

module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_f;
		int errortime_f;
		int errors_g;
		int errortime_g;

		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic resetn;
	logic x;
	logic y;
	logic f_ref;
	logic f_dut;
	logic g_ref;
	logic g_dut;

	// Queue for mismatch reporting
	logic clk_q [$];
	logic resetn_q [$];
	logic x_q [$];
	logic y_q [$];
	logic f_dut_q [$];
	logic g_dut_q [$];
	logic f_ref_q [$];
	logic g_ref_q [$];
	localparam MAX_QUEUE_SIZE = 10;

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,clk,resetn,x,y,f_ref,f_dut,g_ref,g_dut );
	end

	wire tb_match; // Verification
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk,
		.* ,
		.resetn,
		.x,
		.y );
	RefModule good1 (
		.clk,
		.resetn,
		.x,
		.y,
		.f(f_ref),
		.g(g_ref) );
		
	TopModule top_module1 (
		.clk,
		.resetn,
		.x,
		.y,
		.f(f_dut),
		.g(g_dut) );

	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
			strobe <= !strobe;  // Try to delay until the very end of the time step.
			@(strobe);
		end;
	endtask	

	assign tb_match = ( { f_ref, g_ref } === ( { f_ref, g_ref } ^ { f_dut, g_dut } ^ { f_ref, g_ref } ) );

	always @(posedge clk, negedge clk) begin
		// Maintain Queue
		if (clk_q.size() >= MAX_QUEUE_SIZE) begin
			clk_q.delete(0);
			resetn_q.delete(0);
			x_q.delete(0);
			y_q.delete(0);
			f_dut_q.delete(0);
			g_dut_q.delete(0);
			f_ref_q.delete(0);
			g_ref_q.delete(0);
		endif

		clk_q.push_back(clk);
		resetn_q.push_back(resetn);
		x_q.push_back(x);
		y_q.push_back(y);
		f_dut_q.push_back(f_dut);
		g_dut_q.push_back(g_dut);
		f_ref_q.push_back(f_ref);
		g_ref_q.push_back(g_ref);

		stats1.clocks++;

		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
			
			// Display queue on first mismatch
			if (stats1.errors == 1) begin
				$display("Mismatch detected at time %t", $time);
				$display("\nLast %d cycles of simulation:", clk_q.size());
				for (int i = 0; i < clk_q.size(); i++) begin
					$display("Cycle %d, reset %b, x %b, y %b, f_dut %b, g_dut %b, f_ref %b, g_ref %b",
							i, resetn_q[i], x_q[i], y_q[i], f_dut_q[i], g_dut_q[i], f_ref_q[i], g_ref_q[i]);
					end;
			end
		end

		if (f_ref !== ( f_ref ^ f_dut ^ f_ref )) begin 
			if (stats1.errors_f == 0) stats1.errortime_f = $time;
			stats1.errors_f = stats1.errors_f+1'b1; 
		end
		if (g_ref !== ( g_ref ^ g_dut ^ g_ref )) begin 
			if (stats1.errors_g == 0) stats1.errortime_g = $time;
			stats1.errors_g = stats1.errors_g+1'b1; 
		end
	end

	initial begin
		#1000000;
		$display("TIMEOUT");
		$finish();
	end

	final begin
		if (stats1.errors == 0) begin
			$display("SIMULATION PASSED");
		end else begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
		end

		if (stats1.errors_f) $display("Hint: Output '%s' has %0d mismatches. First mismatch occurred at time %0d.", "f", stats1.errors_f, stats1.errortime_f);
		else $display("Hint: Output '%s' has no mismatches.", "f");
		if (stats1.errors_g) $display("Hint: Output '%s' has %0d mismatches. First mismatch occurred at time %0d.", "g", stats1.errors_g, stats1.errortime_g);
		else $display("Hint: Output '%s' has no mismatches.", "g");

		$display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
		$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
	end

endmodule
