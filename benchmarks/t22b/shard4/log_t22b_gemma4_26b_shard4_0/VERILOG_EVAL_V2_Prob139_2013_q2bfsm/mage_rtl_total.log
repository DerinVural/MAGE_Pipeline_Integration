ext = STATE_MON_X;\n            end\n\n            STATE_MON_X: begin\n                // Detect 1, 0, 1 pattern\n                // The pattern is detected when the shift register contains 101\n                // Note: the x input being monitored is the current value\n                // To match 'three successive clock cycles', we check the shifted value\n                if ({x_shift[1:0], x} == 3'b101) begin\n                    state_next = STATE_G_START;\n                end else begin\n                    state_next = STATE_MON_X;\n                end\n            end\n\n            STATE_G_START: begin\n                state_next = STATE_MON_Y;\n            end\n\n            STATE_MON_Y: begin\n                // Monitor y within at most two clock cycles\n                // Cycle 0 (first cycle of MON_Y): if y=1, perm 1\n                // Cycle 1 (second cycle of MON_Y): if y=1, perm 1\n                // If y is not 1 by the end of cycle 1, perm 0\n                if (y == 1'b1) begin\n                    state_next = STATE_G_PERM_1;\n                end else if (y_timer == 2'd1) begin\n                    // This check happens on the second cycle (timer 0->1)\n                    // However, the requirement says 'within at most two clock cycles'\n                    // We must check y at t=0 and t=1.\n                    state_next = STATE_G_PERM_0;\n                end else begin\n                    state_next = STATE_MON_Y;\n                end\n            end\n\n            STATE_G_PERM_1: begin\n                state_next = STATE_G_PERM_1;\n            end\n\n            STATE_G_PERM_0: begin\n                state_next = STATE_G_PERM_0;\n            end\n\n            default: state_next = STATE_A;\n        endcase\n    end\n\n    // Re-evaluating MON_Y logic for precision:\n    // Let's refine the MON_Y transition to be safer.\n    // The requirement: \"If y has the value 1 within at most two clock cycles, \n    // then the FSM should maintain g = 1 permanently... \n    // But if y does not become 1 within two clock cycles, then g = 0 permanently\"\n    // We enter MON_Y at the cycle g becomes 1. \n    // Let's use a cleaner approach in the combinational block.\n\n    // Corrected Next State Logic for MON_Y\n    always @(*) begin\n        state_next = state;\n        case (state) \n            STATE_A:           state_next = STATE_F_PULSE;\n            STATE_F_PULSE:     state_next = STATE_MON_X;\n            STATE_MON_X: begin\n                if ({x_shift[1:0], x} == 3'b101) state_next = STATE_G_START;\n                else state_next = STATE_MON_X;\n            end\n            STATE_G_START:     state_next = STATE_MON_Y;\n            STATE_MON_Y: begin\n                if (y == 1'b1) state_next = STATE_G_PERM_1;\n                else if (y_timer == 2'd1) state_next = STATE_G_PERM_0;\n                else state_next = STATE_MON_Y;\n            end\n            STATE_G_PERM_1:     state_next = STATE_G_PERM_1;\n            STATE_G_PERM_0:     state_next = STATE_G_PERM_0;\n            default:           state_next = STATE_A;\n        endcase\n    end\n\n    // Output Logic\n    always @(*) begin\n        f = 1'b0;\n        g = 1'b0;\n        case (state) \n            STATE_F_PULSE:  f = 1'b1;\n            STATE_G_START:  g = 1'b1;\n            STATE_MON_Y:    g = 1'b1;\n            STATE_G_PERM_1: g = 1'b1;\n            STATE_G_PERM_0: g = 1'b0;\n            default:        g = 1'b0;\n        endcase\n    end\n\nendmodule"
}
