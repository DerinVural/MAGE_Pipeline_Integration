module stimulus_gen (
	input clk,
	output logic resetn,
	output logic x, y
);

	initial begin
		resetn = 0;
		x = 0;
		y = 0;
		@(posedge clk);
		@(posedge clk);
		resetn = 1;
		repeat(500) @(negedge clk) begin
			resetn <= ($random & 31) != 0;
			{x,y} <= $random;
		end
		
		#1 $finish;
	end
	
endmodule

module RefModule (
	input clk,
	input resetn,
	input x,
	input y,
	output logic f,
	output logic g
);

	typedef enum logic [1:0] {
		STATE_A,
		STATE_F_ON,
		STATE_MONITOR_X,
		STATE_G_ON,
		STATE_G_PERM,
		STATE_G_OFF
	} state_t;

	state_t state;
	logic [2:0] x_reg;
	logic [1:0] y_timer;
	logic g_permanent;

	always_ff @(posedge clk or negedge resetn) begin
		if (!resetn) begin
			state <= STATE_A;
			f <= 0;
			g <= 0;
			x_reg <= 3'b000;
			y_timer <= 0;
			g_permanent <= 0;
		end else begin
			case (state)
				STATE_A:
					state <= STATE_F_ON;
				STATE_F_ON:
					begin
						f <= 1;
						state <= STATE_MONITOR_X;
					end
				STATE_MONITOR_X:
					begin
						f <= 0;
						x_reg <= {x_reg[1:0], x};
						if (x_reg == 3'b101 || {x_reg[1:0], x} == 3'b101) begin
							state <= STATE_G_ON;
							g <= 1;
							y_timer <= 0;
						end
					end
					STATE_G_ON:
					begin
						g <= 1;
						if (y) begin
							g_permanent <= 1;
							state <= STATE_G_PERM;
						end else begin
							y_timer <= y_timer + 1;
							if (y_timer == 2) begin
								g_permanent <= 0;
								state <= STATE_G_OFF;
							end
						end
					end
					STATE_G_PERM:
					begin
						g <= 1;
					end
					STATE_G_OFF:
					begin
						g <= 0;
					end
				end
			end
		end
	end

	// Overriding logic for permanent behavior as per spec
	if (g_permanent) g <= 1;
	if (state == STATE_G_OFF) g <= 0;

endmodule

