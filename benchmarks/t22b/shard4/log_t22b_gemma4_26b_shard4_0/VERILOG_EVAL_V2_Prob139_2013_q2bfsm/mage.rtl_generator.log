delay until the very end of the time step.\n\t\t\t@(strobe);\n\t\tend;\n\tendtask\t\n\n\tassign tb_match = ( { f_ref, g_ref } === ( { f_ref, g_ref } ^ { f_dut, g_dut } ^ { f_ref, g_ref } ) );\n\n\talways @(posedge clk, negedge clk) begin\n\t\t// Maintain Queue\n\t\tif (clk_q.size() >= MAX_QUEUE_SIZE) begin\n\t\t\tclk_q.delete(0);\n\t\t\tresetn_q.delete(0);\n\t\t\tx_q.delete(0);\n\t\t\ty_q.delete(0);\n\t\t\tf_dut_q.delete(0);\n\t\t\tg_dut_q.delete(0);\n\t\t\tf_ref_q.delete(0);\n\t\t\tg_ref_q.delete(0);\n\t\tendif\n\n\t\tclk_q.push_back(clk);\n\t\tresetn_q.push_back(resetn);\n\t\tx_q.push_back(x);\n\t\ty_q.push_back(y);\n\t\tf_dut_q.push_back(f_dut);\n\t\tg_dut_q.push_back(g_dut);\n\t\tf_ref_q.push_back(f_ref);\n\t\tg_ref_q.push_back(g_ref);\n\n\t\tstats1.clocks++;\n\n\t\tif (!tb_match) begin\n\t\t\tif (stats1.errors == 0) stats1.errortime = $time;\n\t\t\tstats1.errors++;\n\t\t\t\n\t\t\t// Display queue on first mismatch\n\t\t\tif (stats1.errors == 1) begin\n\t\t\t\t$display("Mismatch detected at time %t", $time);\n\t\t\t\t$display("\\nLast %d cycles of simulation:", clk_q.size());\n\t\t\t\tfor (int i = 0; i < clk_q.size(); i++) begin\n\t\t\t\t\t$display("Cycle %d, reset %b, x %b, y %b, f_dut %b, g_dut %b, f_ref %b, g_ref %b",\n\t\t\t\t\t\t\ti, resetn_q[i], x_q[i], y_q[i], f_dut_q[i], g_dut_q[i], f_ref_q[i], g_ref_q[i]);\n\t\t\t\t\tend;\n\t\t\tend\n\t\tend\n\n\t\tif (f_ref !== ( f_ref ^ f_dut ^ f_ref )) begin \n\t\t\tif (stats1.errors_f == 0) stats1.errortime_f = $time;\n\t\t\tstats1.errors_f = stats1.errors_f+1\'b1; \n\t\tend\n\t\tif (g_ref !== ( g_ref ^ g_dut ^ g_ref )) begin \n\t\t\tif (stats1.errors_g == 0) stats1.errortime_g = $time;\n\t\t\tstats1.errors_g = stats1.errors_g+1\'b1; \n\t\tend\n\tend\n\n\tinitial begin\n\t\t#1000000;\n\t\t$display("TIMEOUT");\n\t\t$finish();\n\tend\n\n\tfinal begin\n\t\tif (stats1.errors == 0) begin\n\t\t\t$display("SIMULATION PASSED");\n\t\tend else begin\n\t\t\t$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %