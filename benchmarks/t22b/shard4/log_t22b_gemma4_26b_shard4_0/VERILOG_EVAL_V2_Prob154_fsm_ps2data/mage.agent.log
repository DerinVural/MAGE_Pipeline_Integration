[2026-05-13 18:25:52,711 - mage.agent - INFO] module TopModule (
    input  logic        clk,
    input  logic        reset,
    input  logic [7:0]  in,
    output logic [23:0] out_bytes,
    output logic        done
);

    // State definitions
    localparam STATE_IDLE = 2'd0;
    localparam STATE_B1   = 2'd1;
    localparam STATE_B2   = 2'd2;
    localparam STATE_B3   = 2'd3;

    // State and Data Registers
    logic [1:0] state;
    logic [7:0] b1, b2, b3;
    logic [23:0] out_reg;
    logic done_reg;

    // Sequential logic
    always @(posedge clk) begin
        if (reset) begin
            state    <= STATE_IDLE;
            b1       <= 8'h0;
            b2       <= 8'h0;
            b3       <= 8'h0;
            out_reg  <= 24'h0;
            done_reg <= 1'b0;
        end else begin
            // Default assignments
            done_reg <= 1'b0;

            case (state)
                STATE_IDLE:
                    if (in[3] == 1'b1) begin
                        b1    <= in;
                        state <= STATE_B1;
                    end else begin
                        state <= STATE_IDLE;
                    end

                STATE_B1:
                    begin
                        b2    <= in;
                        state <= STATE_B2;
                    end

                STATE_B2:
                    begin
                        b3    <= in;
                        state <= STATE_B3;
                    end

                STATE_B3:
                    begin
                        // In B3, we assert done and update the output register
                        done_reg <= 1'b1;
                        out_reg  <= {b1, b2, b3};
                        state    <= STATE_IDLE;
                    end

                default:
                    state <= STATE_IDLE;
            endcase
        end
    end

    // Combinational logic for output
    always @(*) begin
        done      = done_reg;
        out_bytes = out_reg;
    end

endmodule
