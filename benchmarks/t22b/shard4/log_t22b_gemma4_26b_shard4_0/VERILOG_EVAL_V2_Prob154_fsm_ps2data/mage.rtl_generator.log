                        if (in[3]) begin
                            reg_b1 <= in;
                            state  <= STATE_BYTE1;
                        end else begin
                            state  <= STATE_IDLE;
                        end
                    end

                default:
                    state <= STATE_IDLE;
            endcase
        end
    end

    // Combinational logic for outputs
    always @(*) begin
        done = 1'b0;
        out_bytes = 24'h0;
        if (state == STATE_BYTE3) begin
            done = 1'b1;
            out_bytes = {reg_b1, reg_b2, reg_b3};
        end else if (state == STATE_BYTE1 || state == STATE_BYTE2) begin
            // During the process, we can prepare the out_bytes for the moment done is high
            // but the spec says out_bytes needs to be valid whenever done is asserted.
            // To match the waveform, we need to ensure the registers hold the values.
            out_bytes = {reg_b1, reg_b2, reg_b3};
        end else if (state == STATE_IDLE) {
            // We need to handle the case where the 3rd byte is captured and we are in STATE_BYTE3
            // However, the waveform shows that the 3rd byte is actually 'in' during the cycle
            // where 'done' becomes 1.
            // Let's refine the logic.
        }
    end

    // Refined approach: 
    // The 'done' signal is high in the cycle IMMEDIATELY AFTER the 3rd byte was received.
