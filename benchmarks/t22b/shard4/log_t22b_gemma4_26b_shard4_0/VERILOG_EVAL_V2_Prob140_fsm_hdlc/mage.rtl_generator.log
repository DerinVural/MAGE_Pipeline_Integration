t_q.delete(0);\n\t\tend\n\t\tin_q.push_back(in);\n\t\treset_q.push_back(reset);\n\t\tdisc_ref_q.push_back(disc_ref);\n\t\tdisc_dut_q.push_back(disc_dut);\n\t\tflag_ref_q.push_back(flag_ref);\n\t\tflag_dut_q.push_back(flag_dut);\n\t\terr_ref_q.push_back(err_ref);\n\t\terr_dut_q.push_back(err_dut);\n\n\t\tstats1.clocks++;\n\t\tif (!tb_match) begin\n\t\t\tif (stats1.errors == 0) stats1.errortime = $time;\n\t\t\tstats1.errors++;\n\n\t\t\t// Display mismatch details once\n\t\t\t$display("Mismatch detected at time %t", $time);\n\t\t\t$display("\\nLast %d cycles of simulation:", in_q.size());\n\t\t\tfor (int i = 0; i < in_q.size(); i++) begin\n\t\t\t\t$display("Cycle %d, reset %b, in %b | Got: disc=%b flag=%b err=%b, Exp: disc=%b flag=%b err=%b", \n\t\t\t\t\ti, reset_q[i], in_q[i], disc_dut_q[i], flag_dut_q[i], err_dut_q[i], \n\t\t\t\t\tdisc_ref_q[i], flag_ref_q[i], err_ref_q[i]);\n\t\t\tend\n\t\tend\n\n\t\tif (disc_ref !== ( disc_ref ^ disc_dut ^ disc_ref )) begin \n\t\t\tif (stats1.errors_disc == 0) stats1.errortime_disc = $time;\n\t\t\tstats1.errors_disc = stats1.errors_disc+1\'b1; \n\t\tend\n\t\tif (flag_ref !== ( flag_ref ^ flag_dut ^ flag_ref )) begin \n\t\t\tif (stats1.errors_flag == 0) stats1.errortime_flag = $time;\n\t\t\tstats1.errors_flag = stats1.errors_flag+1\'b1; \n\t\tend\n\t\tif (err_ref !== ( err_ref ^ err_dut ^ err_ref )) begin \n\t\t\tif (stats1.errors_err == 0) stats1.errortime_err = $time;\n\t\t\tstats1.errors_err = stats1.errors_err+1\'b1; \n\t\tend\n\tend\n\n\t// add timeout after 100K cycles\n\tinitial begin\n\t\t#1000000\n\t\t$display("TIMEOUT");\n\t\t$finish();\n\tend\n\nendmodule\n</testbench>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nThe module interface is given below:\n<module_interface>\nmodule TopModule (\n    input  logic clk,\n    input  logic reset,\n    input  logic in,\n    output logic disc,\n    output logic flag,\n    output logic err\n);\nendmodule\n</modul