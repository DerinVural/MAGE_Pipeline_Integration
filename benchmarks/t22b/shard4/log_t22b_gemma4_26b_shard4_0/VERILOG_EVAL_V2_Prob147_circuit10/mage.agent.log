[2026-05-13 16:05:12,657 - mage.agent - INFO] module TopModule (
    input  logic clk,
    input  logic a,
    input  logic b,
    output logic q,
    output logic state
);

    logic state_reg;
    logic state_next;

    // Initialize the flip-flop to a known value
    initial begin
        state_reg = 1'b0;
    end

    // Sequential logic for the state register
    always @(posedge clk) begin
        state_reg <= state_next;
    end

    // Combinational logic for next state
    always @(*) begin
        // state_next = (state & a) | b
        state_next = (state_reg & a) | b;
    end

    // Combinational logic for output q
    always @(*) begin
        // q = (!state & !a & b) | (state & !(a ^ b))
        if (!state_reg) begin
            q = (!a && b);
        end else begin
            q = (a == b);
        end
    end

    // Assign state output
    assign state = state_reg;

endmodule
