    input  logic clk,
    input  logic a,
    input  logic b,
    output logic q,
    output logic state
);

    logic state_reg;
    logic next_state;

    initial begin
        state_reg = 1'b0;
    end

    always @(posedge clk) begin
        state_reg <= next_state;
    end

    always @(*) begin
        // S_next = (a & b) | (!a & b & !state);
        if ((a && b) || (!a && b && !state_reg)) begin
            next_state = 1'b1;
        end else begin
            next_state = 1'b0;
        end
    end

    always @(*) begin
        // q = (a & b & state) | (!a & b & !state) | (!a & !b & state)
        if ((a && b && state_reg) || (!a && b && !state_reg) || (!a && !b && state_reg)) begin
            q = 1'b1;
        end else begin
            q = 1'b0;
        end
    end

