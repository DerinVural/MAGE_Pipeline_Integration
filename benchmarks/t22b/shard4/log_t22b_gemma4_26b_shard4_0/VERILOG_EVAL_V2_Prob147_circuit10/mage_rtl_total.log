    always @(posedge clk) begin
        state_reg <= state_next;
    end

    // Combinational logic for next state
    always @(*) begin
        if (state_reg == 1'b0) begin
            state_next = a & b;
        end else begin
            state_next = a | b;
        end
    end

    // Combinational logic for output q
    always @(*) begin
        q = state_reg ^ a ^ b;
    end

    // Output assignment
    assign state = state_reg;

endmodule
