[2026-05-13 16:16:50,766 - mage.rtl_generator - INFO] RTL code: module TopModule (
    input  logic clk,
    input  logic a,
    input  logic b,
    output logic q,
    output logic state
);

    logic state_reg;
    logic state_next;

    // Initialize state to 0
    initial begin
        state_reg = 1'b0;
    end

    // Sequential logic
    always @(posedge clk) begin
        state_reg <= state_next;
    end

    // Combinational logic for next state
    always @(*) begin
        case ({state_reg, a, b})
            3'b000: state_next = 1'b0;
            3'b001: state_next = 1'b1;
            3'b010: state_next = 1'b0;
            3'b011: state_next = 1'b1;
            3'b100: state_next = 1'b0;
            3'b101: state_next = 1'b1;
            3'b110: state_next = 1'b0;
            3'b111: state_next = 1'b0;
            default: state_next = 1'b0;
        endcase
    end

    // Combinational logic for output q
    always @(*) begin
        case ({state_reg, a, b})
            3'b000: q = 1'b0;
            3'b001: q = 1'b1;
            3'b010: q = 1'b1;
            3'b011: q = 1'b0;
            3'b100: q = 1'b1;
            3'b101: q = 1'b1;
            3'b110: q = 1'b1;
            3'b111: q = 1'b1;
            default: q = 1'b0;
        endcase
    end

    // Assign state output
    assign state = state_reg;

endmodule
