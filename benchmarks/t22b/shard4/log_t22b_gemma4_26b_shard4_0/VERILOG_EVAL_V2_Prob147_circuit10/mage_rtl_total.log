[2026-05-13 16:29:56,817 - mage.rtl_generator - INFO] RTL code: module TopModule (
    input  logic clk,
    input  logic a,
    input  logic b,
    output logic q,
    output logic state
);

    logic state_next;

    // Sequential logic
    always @(posedge clk) begin
        state <= state_next;
    end

    // Combinational logic for next state
    always @(*) begin
        state_next = a ^ b ^ state;
    end

    // Combinational logic for output q
    always @(*) begin
        q = a ^ b ^ state;
    end

    // Initialization
    initial begin
        state = 1'b0;
    end

endmodule
