// Reference model based on FSM table
module RefModule (
	input clk,
	input x,
	input [2:0] y,
	output logic Y0,
	output logic z
);
	logic [2:0] state;
	logic [2:0] next_state;

	always @(posedge clk) begin
		state <= next_state;
	end

	always @(*) begin
		case (state)
			3'b000:
				begin
					if (x == 0) next_state = 3'b000;
					else        next_state = 3'b001;
					z = 0;
				end
				3'b001:
					begin
						if (x == 0) next_state = 3'b001;
						else        next_state = 3'b100;
						z = 0;
				end
				3'b010:
					begin
						if (x == 0) next_state = 3'b010;
						else        next_state = 3'b001;
						z = 0;
				end
				3'b011:
					begin
						if (x == 0) next_state = 3'b001;
						else        next_state = 3'b010;
						z = 1;
				end
				3'b100:
					begin
						if (x == 0) next_state = 3'b011;
						else        next_state = 3'b100;
						z = 1;
				end
				default:
					begin
						next_state = 3'b000;
						z = 0;
				end
			end
	end

	assign Y0 = next_state[0];
endmodule

