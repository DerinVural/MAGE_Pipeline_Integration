		int errors;
		int errortime;
		int errors_Y0;
		int errortime_Y0;
		int errors_z;
		int errortime_z;

		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic x;
	logic [2:0] y;
	logic Y0_ref;
	logic Y0_dut;
	logic z_ref;
	logic z_dut;

	// Queues for mismatch display
	logic x_q [$];
	logic [2:0] y_q [$];
	logic Y0_ref_q [$];
	logic Y0_dut_q [$];
	logic z_ref_q [$];
	logic z_dut_q [$];
	localparam MAX_QUEUE_SIZE = 10;

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,clk,x,y,Y0_ref,Y0_dut,z_ref,z_dut );
	end


	wire tb_match;       // Verification
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk,
		.* ,
		x,
		y );
	RefModule good1 (
		.clk,
		.x,
		y,
		.Y0(Y0_ref),
		z(z_ref) );
			
	TopModule top_module1 (
		.clk,
		.x,
		y,
		.Y0(Y0_dut),
		z(z_dut) );


