							i, x_q[i], y_q[i], Y0_ref_q[i], Y0_dut_q[i], z_ref_q[i], z_dut_q[i]);
					end
				end
		end
	end

		// Original logic for specific error counting
		if (Y0_ref !== ( Y0_ref ^ Y0_dut ^ Y0_ref ))
		begin 
			if (stats1.errors_Y0 == 0) stats1.errortime_Y0 = $time;
			stats1.errors_Y0 = stats1.errors_Y0+1'b1; 
