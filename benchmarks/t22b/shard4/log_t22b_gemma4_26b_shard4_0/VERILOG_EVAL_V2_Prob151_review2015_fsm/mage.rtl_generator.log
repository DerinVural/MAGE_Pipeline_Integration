    output logic done
);

    // State definitions
    localparam STATE_SEARCH   = 3'd0;
    localparam STATE_SHIFT    = 3'd1;
    localparam STATE_WAIT_CNT = 3'd2;
    localparam STATE_DONE     = 3'd3;

    // State register
    logic [2:0] state;
    logic [2:0] state_next;

    // Pattern detection register
    logic [3:0] pattern_reg;
    
    // Counter for shift_ena duration
    logic [2:0] shift_cnt;

    // Sequential logic
    always @(posedge clk) begin
        if (reset) begin
            state <= STATE_SEARCH;
            pattern_reg <= 4'b0000;
            shift_cnt <= 3'd0;
        end else begin
            state <= state_next;
            
            // Shift in data for pattern detection
            pattern_reg <= {pattern_reg[2:0], data};

            // Counter for shift_ena (only active in SHIFT state)
            if (state == STATE_SHIFT) begin
                shift_cnt <= shift_cnt + 1'b1;
            end else begin
                shift_cnt <= 3'd0;
            end
        end
    end

    // Next state logic
    always @(*) begin
        state_next = state;
        case (state)
            STATE_SEARCH:
                // Pattern 1101 detected
                if (pattern_reg == 4'b1101) 
                    state_next = STATE_SHIFT;
                else
                    state_next = STATE_SEARCH;

            STATE_SHIFT:
                // Assert shift_ena for exactly 4 cycles (0, 1, 2, 3)
                if (shift_cnt == 3'd3) 
                    state_next = STATE_WAIT_CNT;
                else
                    state_next = STATE_SHIFT;

            STATE_WAIT_CNT:
                if (done_counting) 
                    state_next = STATE_DONE;
                else
                    state_next = STATE_WAIT_CNT;

            STATE_DONE:
                if (ack) 
                    state_next = STATE_SEARCH;
                else
                    state_next = STATE_DONE;
            
            default:
                state_next = STATE_SEARCH;
        endcase
    end

    // Output logic
    always @(*) begin
        shift_ena = 1'b0;
        counting  = 1'b0;
        done      = 1'b0;

        case (state) 
            STATE_SHIFT:
                shift_ena = 1'b1;
            STATE_WAIT_CNT:
                counting  = 1'b1;
            STATE_DONE:
                done      = 1'b1;
        endcase
    end

