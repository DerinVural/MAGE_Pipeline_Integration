[2026-05-13 17:50:24,265 - mage.rtl_generator - INFO] RTL code: module TopModule (
    input  logic clk,
    input  logic reset,
    input  logic data,
    input  logic done_counting,
    input  logic ack,
    output logic shift_ena,
    output logic counting,
    output logic done
);

    // State definitions
    localparam STATE_IDLE          = 3'd0;
    localparam STATE_SHIFT         = 3'd1;
    localparam STATE_WAIT_COUNTING = 3'd2;
    localparam STATE_WAIT_ACK      = 3'd3;

    // State and control registers
    logic [2:0] state;
    logic [2:0] state_next;
    logic [4:0] shift_cnt;
    logic [3:0] pattern_reg;

    // Sequential logic
    always @(posedge clk) begin
        if (reset) begin
            state <= STATE_IDLE;
            shift_cnt <= 5'd0;
            pattern_reg <= 4'b0000;
        end else begin
            state <= state_next;
            
            // Pattern detection register: shift in the serial data
            pattern_reg <= {pattern_reg[2:0], data};

            // Shift counter for the 4-cycle shift_ena
            if (state == STATE_SHIFT) begin
                shift_cnt <= shift_cnt + 5'd1;
            end else begin
                shift_cnt <= 5'd0;
            end
        end
    end

    // Next state combinational logic
    always @(*) begin
        state_next = state;
        case (state)
            STATE_IDLE:
                // Check for pattern 1101. Since pattern_reg shifts in, 
                // we check if the current bit and the 3 previous bits form 1101.
                if ({pattern_reg[2:0], data} == 4'b1101) begin
                    state_next = STATE_SHIFT;
                end

            STATE_SHIFT:
                // After 4 cycles of shift_ena
                if (shift_cnt == 5'd3) begin
                    state_next = STATE_WAIT_COUNTING;
                end

            STATE_WAIT_COUNTING:
                // Wait for done_counting to be high
                if (done_counting) begin
                    state_next = STATE_WAIT_ACK;
                end

            STATE_WAIT_ACK:
                // Wait for user to acknowledge
                if (ack) begin
                    state_next = STATE_IDLE;
                end
            
            default:
                state_next = STATE_IDLE;
        endcase
    end

    // Output combinational logic
    always @(*) begin
        shift_ena = 1'b0;
        counting  = 1'b0;
        done      = 1'b0;

        case (state)
            STATE_IDLE:egin
                shift_ena = 1'b0;
                counting  = 1'b0;
                done      = 1'b0;
            end
            STATE_SHIFT:egin
                shift_ena = 1'b1;
                counting  = 1'b0;
                done      = 1'b0;
            end
            STATE_WAIT_COUNTING:egin
                shift_ena = 1'b0;
                counting  = 1'b1;
                done      = 1'b0;
            end
            STATE_WAIT_ACK:egin
                shift_ena = 1'b0;
                counting  = 1'b0;
                done      = 1'b1;
            end
            default:egin
                begin
                    shift_ena = 1'b0;
                    counting  = 1'b0;
                    done      = 1'b0;
                end
        endcase
    end

