lse begin\n                        shift_cnt_next = shift_cnt + 2'd1;\n                    end\n                end\n\n            STATE_WAIT_COUNTING:\n                begin\n                    counting = 1'b1;\n                    if (done_counting) begin\n                        state_next = STATE_WAIT_ACK;\n                    end else begin\n                        state_next = STATE_WAIT_COUNTING;\n                    end\n                end\n\n            STATE_WAIT_ACK:\n                begin\n                    done = 1'b1;\n                    if (ack) begin\n                        state_next = STATE_SEARCH;\n                    end else begin\n                        state_next = STATE_WAIT_ACK;\n                    end\n                end\n\n            default:\n                begin\n                    state_next = STATE_SEARCH;\n                end\n        endcase\n    end\n\nendmodule"
