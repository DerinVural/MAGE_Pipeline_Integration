[2026-05-13 17:45:09,744 - mage.agent - INFO] module TopModule (
    input  logic clk,
    input  logic reset,
    input  logic data,
    input  logic done_counting,
    input  logic ack,
    output logic shift_ena,
    output logic counting,
    output logic done
);

    // State encoding
    localparam STATE_SEARCH        = 3'd0;
    localparam STATE_SHIFT         = 3'd1;
    localparam STATE_WAIT_COUNTING = 3'd2;
    localparam STATE_WAIT_ACK      = 3'd3;

    logic [2:0] state;
    logic [2:0] state_next;

    // Pattern detection shift register
    logic [3:0] pattern_reg;
    logic [3:0] pattern_reg_next;

    // Shift counter (to count 4 cycles)
    logic [1:0] shift_cnt;
    logic [1:0] shift_cnt_next;

    // Sequential logic
    always @(posedge clk) begin
        if (reset) begin
            state <= STATE_SEARCH;
            pattern_reg <= 4'b0000;
            shift_cnt <= 2'b00;
        end else begin
            state <= state_next;
            pattern_reg <= pattern_reg_next;
            shift_cnt <= shift_cnt_next;
        end
    end

    // Next state and signal logic
    always @(*) begin
        // Defaults
        state_next = state;
        pattern_reg_next = {pattern_reg[2:0], data};
        shift_cnt_next = shift_cnt;
        shift_ena = 1'b0;
        counting = 1'b0;
        done = 1'b0;

        case (state)
            STATE_SEARCH:
                begin
                    if ({pattern_reg[2:0], data} == 4'b1101) begin
                        state_next = STATE_SHIFT;
                        shift_cnt_next = 2'd0;
                    end else begin
                        state_next = STATE_SEARCH;
                    end
                end

            STATE_SHIFT:
                begin
                    shift_ena = 1'b1;
                    if (shift_cnt == 2'd3) begin
                        state_next = STATE_WAIT_COUNTING;
                        shift_cnt_next = 2'd0;
                    end else begin
                        shift_cnt_next = shift_cnt + 2'd1;
                    end
                end

            STATE_WAIT_COUNTING:
                begin
                    counting = 1'b1;
                    if (done_counting) begin
                        state_next = STATE_WAIT_ACK;
                    end else begin
                        state_next = STATE_WAIT_COUNTING;
                    end
                end

            STATE_WAIT_ACK:
                begin
                    done = 1'b1;
                    if (ack) begin
                        state_next = STATE_SEARCH;
                    end else begin
                        state_next = STATE_WAIT_ACK;
                    end
                end

            default:
                begin
                    state_next = STATE_SEARCH;
                end
        endcase
    end

endmodule
