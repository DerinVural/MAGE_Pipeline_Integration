    always @(posedge clk) begin
        if (reset) begin
            shift_cnt <= 2'b00;
        end else begin
            shift_cnt <= shift_cnt_next;
        end
    end

    // Next state combinational logic
    always @(*) begin
        state_next = state;
        case (state)
            STATE_IDLE:
                if (data) state_next = STATE_S1;
                else      state_next = STATE_IDLE;

            STATE_S1:
                if (data) state_next = STATE_S2;
                else      state_next = STATE_IDLE;

            STATE_S2:
                if (data) state_next = STATE_S2;
                else      state_next = STATE_S3;

            STATE_S3:
                if (data) state_next = STATE_SHIFT;
                else      state_next = STATE_IDLE;

            STATE_SHIFT:
                if (shift_cnt == 2'd3) state_next = STATE_WAIT_COUNT;
                else                   state_next = STATE_SHIFT;

            STATE_WAIT_COUNT:
                if (done_counting) state_next = STATE_DONE;
                else               state_next = STATE_WAIT_COUNT;

            STATE_DONE:
                if (ack) state_next = STATE_IDLE;
                else     state_next = STATE_DONE;

            default:
                state_next = STATE_IDLE;
        endcase
    end

    // Next shift counter combinational logic
    always @(*) begin
        shift_cnt_next = shift_cnt;
        if (state == STATE_SHIFT) begin
            if (shift_cnt == 2'd3) shift_cnt_next = 2'b00;
            else                   shift_cnt_next = shift_cnt + 2'd1;
        end else if (state_next == STATE_SHIFT) begin
            // Initialize counter when entering SHIFT state
            shift_cnt_next = 2'd0;
        end
    end

    // Output combinational logic
    always @(*) begin
        shift_ena = 1'b0;
        counting  = 1'b0;
        done      = 1'b0;

        if (state == STATE_SHIFT) begin
            shift_ena = 1'b1;
        end else if (state == STATE_WAIT_COUNT) begin
            counting = 1'b1;
        end else if (state == STATE_DONE) begin
            done = 1'b1;
        end
    end

endmodule
