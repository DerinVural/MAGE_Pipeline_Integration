    always @(*) begin
        shift_ena = 1'b0;
        counting  = 1'b0;
        done      = 1'b0;

        case (state)
            STATE_SHIFT:
                shift_ena = 1'b1;
            STATE_WAIT_C:
                counting  = 1'b1;
            STATE_DONE:
                done      = 1'b1;
