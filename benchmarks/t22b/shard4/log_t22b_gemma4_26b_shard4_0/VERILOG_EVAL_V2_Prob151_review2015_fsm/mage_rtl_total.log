            state <= next_state;
            
            // Update pattern register every cycle
            pattern_reg <= {pattern_reg[2:0], data};

            // Counter logic for SHIFT state
            if (state == STATE_SHIFT) begin
                if (shift_cnt < 3'd3) begin
                    shift_cnt <= shift_cnt + 1'b1;
                end else begin
                    shift_cnt <= 3'b000;
                end
            end else begin
                shift_cnt <= 3'b000;
            end
        end
    end

    // Next state logic
