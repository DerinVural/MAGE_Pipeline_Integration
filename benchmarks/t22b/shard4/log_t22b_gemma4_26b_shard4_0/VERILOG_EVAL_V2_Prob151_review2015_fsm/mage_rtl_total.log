        next_state = state;
        case (state)
            STATE_IDLE: begin
                // Pattern 1101: pattern_reg will look like 1101
                if (pattern_reg == 4'b1101) begin
                    next_state = STATE_SHIFT;
                end else begin
                    next_state = STATE_IDLE;
                end
            end
            STATE_SHIFT: begin
                // Shift for exactly 4 cycles
