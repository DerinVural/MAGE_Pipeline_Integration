                    next_state = STATE_SHIFT;
                end
            end
            STATE_WAIT_COUNT: begin
                if (done_counting) begin
                    next_state = STATE_WAIT_ACK;
                end else begin
                    next_state = STATE_WAIT_COUNT;
                end
            end
            STATE_WAIT_ACK: begin
                if (ack) begin
                    next_state = STATE_IDLE;
                end else begin
                    next_state = STATE_WAIT_ACK;
                end
            end
            default: begin
                next_state = STATE_IDLE;
            end
        endcase
    end

    // Output logic
    always @(*) begin
        shift_ena = 1'b0;
        counting  = 1'b0;
        done      = 1'b0;

        case (state) 
            STATE_SHIFT: begin
                shift_ena = 1'b1;
            end
            STATE_WAIT_COUNT: begin
                counting = 1'b1;
            end
            STATE_WAIT_ACK: begin
                done = 1'b1;
            end
