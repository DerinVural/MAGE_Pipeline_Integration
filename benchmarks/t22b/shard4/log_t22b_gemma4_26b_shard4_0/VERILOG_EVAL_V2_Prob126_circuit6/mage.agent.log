    // Improved error reporting for first mismatch
    always @(posedge clk, negedge clk) begin
        if (!tb_match) begin
            if (stats1.errors == 0) begin
                stats1.errortime = $time;
                $display("FIRST MISMATCH DETECTED at %0t ps:", $time);
                $display("  a (input):    %h (bin: %b)", a, a);
                $display("  q_ref (exp):  %h (bin: %b)", q_ref, q_ref);
                $display("  q_dut (act):  %h (bin: %b)", q_dut, q_dut);
