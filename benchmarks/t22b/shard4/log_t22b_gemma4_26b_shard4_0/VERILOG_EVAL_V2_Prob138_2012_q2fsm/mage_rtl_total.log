[2026-05-13 14:18:20,211 - mage.agent - INFO] `timescale 1 ps/1 ps
`define OK 12
`define INCORRECT 13

module stimulus_gen (
	input clk,
	output logic reset,
	output logic w
);

	initial begin
		repeat(200) @(negedge clk) begin
			reset <= ($random & 'h1f) == 0;
			w <= $random;
		end
		
		#1 $finish;
		
	end
	
endmodule

module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_z;
		int errortime_z;

		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic reset;
	logic w;
	logic z_ref;
	logic z_dut;

	// Queue for mismatch display
	logic clk_q [$];
	logic reset_q [$];
	logic w_q [$];
	logic z_dut_q [$];
	logic z_ref_q [$];
	localparam MAX_QUEUE_SIZE = 10;
	bit first_mismatch_displayed = 0;

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,clk,reset,w,z_ref,z_dut );
	end

	wire tb_match;        // Verification
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk,
		.* ,
		.reset,
		.w );
	RefModule good1 (
		.clk,
		.reset,
		.w,
		.z(z_ref) );
		
	TopModule top_module1 (
		.clk,
		.reset,
		.w,
		.z(z_dut) );

	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
			strobe <= !strobe;  // Try to delay until the very end of the time step.
			@(strobe);
		end
	endtask	

	// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.
	assign tb_match = ( { z_ref } === ( { z_ref } ^ { z_dut } ^ { z_ref } ) );

	// Queue management and mismatch detection
	always @(posedge clk, negedge clk) begin
		// Push to queue
		if (clk_q.size() >= MAX_QUEUE_SIZE) begin
			clk_q.delete(0);
			reset_q.delete(0);
			w_q.delete(0);
			z_dut_q.delete(0);
			z_ref_q.delete(0);
		end
		clk_q.push_back(clk);
		reset_q.push_back(reset);
		w_q.push_back(w);
		z_dut_q.push_back(z_dut);
		z_ref_q.push_back(z_ref);

		// Stats and error counting
		stats1.clocks++;
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
			end
		end

		if (z_ref !== ( z_ref ^ z_dut ^ z_ref )) begin 
			if (stats1.errors_z == 0) stats1.errortime_z = $time;
			stats1.errors_z = stats1.errors_z + 1;
		end

		// Display first mismatch details
		if (!tb_match && !first_mismatch_displayed) begin
			first_mismatch_displayed = 1;
			$display("Mismatch detected at time %t", $time);
			$display("\nLast %d cycles of simulation:", clk_q.size());
			for (int i = 0; i < clk_q.size(); i++) begin
				$display("Cycle %d, clk %b, reset %b, w %b, got z %b, exp z %b", 
					i, clk_q[i], reset_q[i], w_q[i], z_dut_q[i], z_ref_q[i]);
			end
		end
	end

	// add timeout after 100K cycles
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

	final begin
		if (stats1.errors_z > 0) begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_z, stats1.errortime_z);
			$display("Hint: Output '%s' has %0d mismatches. First mismatch occurred at time %0d.", "z", stats1.errors_z, stats1.errortime_z);
		endn	else begin
			$display("SIMULATION PASSED");
			$display("Hint: Output '%s' has no mismatches.", "z");
		end

		$display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
		$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
	end

endmodule
