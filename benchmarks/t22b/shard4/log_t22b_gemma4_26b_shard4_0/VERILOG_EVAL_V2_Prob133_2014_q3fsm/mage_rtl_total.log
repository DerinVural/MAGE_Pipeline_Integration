			q_w.delete(0);
			q_z_dut.delete(0);
			q_z_ref.delete(0);
		end
		q_reset.push_back(reset);
		q_s.push_back(s);
		q_w.push_back(w);
		q_z_dut.push_back(z_dut);
		q_z_ref.push_back(z_ref);

		stats1.clocks++;
		
