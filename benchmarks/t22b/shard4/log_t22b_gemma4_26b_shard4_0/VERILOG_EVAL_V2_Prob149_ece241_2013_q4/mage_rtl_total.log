b0;\n47:                 fr0 = 1\'b0;\n48:             end\n49:             3\'b011: begin\n50:                 // Between s[2] and s[1]: fr0\n51:                 fr0 = 1\'b1;\n52:             end\n53:             3\'b001: begin\n54:                 // Between s[1] and s[0]: fr0, fr1\n55:                 fr0 = 1\'b1;\n56:                 fr1 = 1\'b1;\n57:             end\n58:             3\'b000: begin\n59:                 // Below s[0]: fr0, fr1, fr2\n60:                 fr0 = 1\'b1;\n61:                 fr1 = 1\'b1;\n62:                 fr2 = 1\'b1;\n63:             end\n64:             default: begin\n65:                 // For intermediate/undefined sensor states not explicitly in table\n66:                 // We treat them as 0 flow unless they match the pattern logic\n67:                 fr2 = 1\'b0;\n68:                 fr1 = 1\'b0;\n69:                 fr0 = 1\'b0;\n70:             end\n71:         endcase\n72: \n73:         // Supplemental flow (dfr) logic\n74:         // "If the sensor change indicates that the previous level was lower than the current level"\n75:         // Higher level corresponds to more bits set in \'s\' (e.g., 3\'b011 > 3\'b001)\n76:         // We check if the current sensor value \'s\' is numerically greater than \'prev_s\'\n77:         // but only if a change actually occurred.\n78:         if (s != prev_s && s > prev_s) begin\n79:             dfr = 1\'b1;\n80:         end else begin\n81:             dfr = 1\'b0;\n82:         end\n83: \n84:         // Handle Synchronous Reset Output state\n85:         // Requirement: "reset the state machine to a state equivalent to if the water level \n86:         // had been low for a long time (no sensors asserted, and all four outputs asserted)."\n87:         if (reset) begin\n88:             fr2 = 1\'b1;\n89:             fr1 = 1\'b1;\n90:             fr0 = 1\'b1;\n91:             dfr = 1\'b1;\n92:         end\n93:     end\n94: \n95: endmodule\n\n</previous_code>\n<previous_tb>\n1: `timescale 1 