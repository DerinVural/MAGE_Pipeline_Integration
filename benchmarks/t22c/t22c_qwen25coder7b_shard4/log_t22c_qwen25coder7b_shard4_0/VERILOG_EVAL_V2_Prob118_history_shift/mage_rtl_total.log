[2026-05-14 10:51:44,540 - mage.rtl_generator - INFO] RTL code: module TopModule(
    input logic clk,
    input logic areset,
    input logic predict_valid,
    input logic predict_taken,
    input logic train_mispredicted,
    input logic train_taken,
    input logic [31:0] train_history,
    output logic [31:0] predict_history
);

    // Register to hold the branch history
    logic [31:0] history_reg;

    // Initialize the register to 0
    initial begin
        history_reg = 32'b0;
    end

    // Sequential logic to update the register on the rising edge of the clock
    always_ff @(posedge clk) begin
        if (areset)
            history_reg <= 32'b0;
        else if (predict_valid)
            history_reg <= {history_reg[30:0], predict_taken};
    end

    // Always block to handle mispredictions
    always_comb begin
        if (train_mispredicted)
            history_reg = {train_history, train_taken};
    end

    // Assign the output
    assign predict_history = history_reg;

endmodule
