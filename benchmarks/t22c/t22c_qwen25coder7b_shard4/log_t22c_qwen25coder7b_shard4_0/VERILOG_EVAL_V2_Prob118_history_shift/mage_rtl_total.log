[2026-05-14 10:52:49,658 - mage.rtl_editor - INFO] module TopModule (
    input logic clk,
    input logic areset,
    input logic predict_valid,
    input logic predict_taken,
    input logic train_mispredicted,
    input logic [31:0] train_history,
    output logic [31:0] predict_history
);

    // Sequential logic
    logic [31:0] reg_history;
    always_ff @(posedge clk or posedge areset) begin
        if (areset)
            reg_history <= 32'b0;
        else if (predict_valid)
            reg_history <= {reg_history[30:0], predict_taken};
        else if (train_mispredicted)
            reg_history <= {train_history, train_mispredicted};
    end

    // Combinational logic
    always_comb begin
        if (train_mispredicted)
            predict_history = {train_history, train_mispredicted};
        else
            predict_history = reg_history;
    end

endmodule;
