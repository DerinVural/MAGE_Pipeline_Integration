[2026-05-14 11:18:44,291 - mage.agent - INFO] module tb();

typedef struct packed {
	int errors;
	int errortime;
	int errors_z;
	int errortime_z;

	int clocks;
} stats;

stats stats1;


wire[511:0] wavedrom_title;
wire wavedrom_enable;
int wavedrom_hide_after_time;

reg clk=0;
initial forever
	#5 clk = ~clk;

logic aresetn;
logic x;
logic z_ref;
logic z_dut;

initial begin 
	$dumpfile("wave.vcd");
	$dumpvars(1, stim1.clk, tb_mismatch ,clk,aresetn,x,z_ref,z_dut );
end

wire tb_match; 
wire tb_mismatch = ~tb_match;

stimulus_gen stim1 (
	.clk,
	.* ,
	.aresetn,
	.x );
RefModule good1 (
	.clk,
	.aresetn,
	.x,
	.z(z_ref) );
	
TopModule top_module1 (
	.clk,
	.aresetn,
	.x,
	.z(z_dut) );
	
bit strobe = 0;
task wait_for_end_of_timestep;
	repeat(5) begin
		strobe <= !strobe;  
		@(strobe);
	end
endtask
	
class SimulationStatus;
	static int errors = 0;
	static int errortime = 0;
	static int errors_z = 0;
	static int errortime_z = 0;
	static int clocks = 0;
	now() {
		return this;
	}

	add_error() {
		this.errors++;
		if (errors == 1) this.errortime = $time;
	}

	add_error_z() {
		this.errors_z++;
		if (errors_z == 1) this.errortime_z = $time;
	}

	add_clock() {
		this.clocks++;
	}

	simulate_passed(status) {
		status = this;
	}

display_results(status) {
		if (status.errors_z) begin
			$display("Hint: Output 'z' has %0d mismatches. First mismatch occurred at time %0d.", status.errors_z, status.errortime_z);
		end else begin
			$display("Simulation PASSED");
		end
		$display("Total mismatched samples is %1d out of %1d samples", status.errors, status.clocks);
		$display("Simulation finished at %0d ps", $time);
		$display("Mismatches: %1d in %1d samples", status.errors, status.clocks);
	}
endclass

final begin
	if (stats1.errors_z) begin
		SimulationStatus.display_results(stats1);
	end else begin
		SimulationStatus.simulate_passed(stats1);
	end
end

// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.
assign tb_match = ( { z_ref } === ( { z_ref } ^ { z_dut } ^ { z_ref } ) );
// Use explicit sensitivity list here. @(*) causes NetProc::nex_input() to be called when trying to compute
// the sensitivity list of the @(strobe) process, which isn't implemented.
always @(posedge clk, negedge clk) begin

	stats1.add_clock();
	if (!tb_match) begin
		if (stats1.errors == 0) stats1.errortime = $time;
		stats1.add_error();
	end
	if (z_ref !== ( z_ref ^ z_dut ^ z_ref ))
	begin if (stats1.errors_z == 0) stats1.errortime_z = $time;
		stats1.add_error_z(); end

end

   // add timeout after 100K cycles
initial begin
  #1000000
  $display("TIMEOUT");
  $finish();
end

endmodule
