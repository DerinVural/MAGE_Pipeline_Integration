    "module": "module TopModule (\n    input  logic clk,\n    input  logic aresetn,\n    input  logic x,\n    output logic z\n);\n\n    // State enum\n    localparam STATE_IDLE = 2'b00;\n    localparam STATE_ONE =  2'b01;\n    localparam STATE_ZERO = 2'b10;\n\n    // State register\n    logic [1:0] state;\n\n    // Next state logic\n    always @(*) begin\n        case (state)\n        STATE_IDLE:\n            if (x)\n                state = STATE_ONE;\n            else\n                state = STATE_IDLE;\n        STATE_ONE:\n            if (x)\n                state = STATE_ZERO;\n            else\n                state = STATE_ONE;\n        STATE_ZERO:\n            if (x)\n                state = STATE_IDLE;\n            else\n                state = STATE_ZERO;\n        default:\n            state = STATE_IDLE;\n        endcase\n    end\n\n    // Output logic\n    always @(*) begin\n        z = 1'b0;\n        case (state)\n        STATE_IDLE:\n        STATE_ONE:\n        STATE_ZERO:\n            z = 1'b0;\n        endcase\n    end\n\n    // Reset logic\n    always @(posedge clk or negedge aresetn) begin\n        if (!aresetn) begin\n            state <= STATE_IDLE;\n        end\n    end\n\nendmodule"
