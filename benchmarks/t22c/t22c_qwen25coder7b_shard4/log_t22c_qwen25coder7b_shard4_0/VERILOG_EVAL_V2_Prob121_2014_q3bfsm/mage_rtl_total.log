    reset = 1;
    x = 0;
    @(posedge clk);
    @(posedge clk);
    reset = 0;
    @(posedge clk);
    @(posedge clk);

    repeat(500) @(negedge clk) begin
        reset <= !($random & 63);
        x <= $random;
    end

    #1 $finish;
end
endmodule

