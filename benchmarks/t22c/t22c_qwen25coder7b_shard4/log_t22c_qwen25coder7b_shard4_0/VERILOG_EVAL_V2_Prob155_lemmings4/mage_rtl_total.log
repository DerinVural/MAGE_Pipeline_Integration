[2026-05-14 12:32:58,912 - mage.rtl_generator - INFO] RTL code: module TopModule (
  input logic clk,
  input logic areset,
  input logic bump_left,
  input logic bump_right,
  input logic ground,
  input logic dig,
  output logic walk_left,
  output logic walk_right,
  output logic aaah,
  output logic digging
);

  // States definition
  localparam IDLE = 2'b00;
  localparam WALK_LEFT = 2'b01;
  localparam WALK_RIGHT = 2'b10;
  localparam FALLING = 2'b11;
  localparam SPLAT = 2'b11;

  // Internal signals
  logic [1:0] state;
  logic [1:0] state_next;
  logic walking;
  logic digging_logic;
  logic ground_fall;
  logic fall_counter_reset;
  logic [4:0] fall_counter;

  // Initialization block
  initial begin
    state = IDLE;
    fall_counter = 5'd0;
    walking = 1'b0;
    digging_logic = 1'b0;
  end

  // Sequential logic
  always_ff @(posedge clk or posedge areset) begin
    if (areset) begin
      state <= IDLE;
      fall_counter <= 5'd0;
      walking <= 1'b0;
      digging_logic <= 1'b0;
    end else begin
      state <= state_next;
      fall_counter_reset = 1'b0;
      walking <= 1'b0;
      digging_logic <= 1'b0;
      if (state == FALLING)
        fall_counter <= fall_counter + 1'd1;
    end
  end

  // Next state logic
  always_comb begin
    state_next = state;
    fall_counter_reset = 1'b0;
    walking = 1'b0;
    digging_logic = 1'b0;

    case (state)
      IDLE: begin
        walking = 1'b0;
        digging_logic = 1'b0;
        if (ground && bump_left)
          state_next = WALK_RIGHT;
        else if (ground && bump_right)
          state_next = WALK_LEFT;
        else if (dig)
          state_next = DIGGING;
        else if (!ground)
          state_next = FALLING;
      end
      WALK_LEFT: begin
        walking = 1'b1;
        digging_logic = 1'b0;
        if (!ground)
          state_next = FALLING;
        else if (bump_left)
          state_next = WALK_RIGHT;
        else if (dig)
          state_next = DIGGING;
      end
      WALK_RIGHT: begin
        walking = 1'b1;
        digging_logic = 1'b0;
        if (!ground)
          state_next = FALLING;
        else if (bump_right)
          state_next = WALK_LEFT;
        else if (dig)
          state_next = DIGGING;
      end
      FALLING: begin
        walking = 1'b0;
        fall_counter_reset = 1'b1;
        if (ground)
          state_next = IDLE;
      end
      DIGGING: begin
        digging_logic = dig;
        if (digging_logic && !ground)
          state_next = FALLING;
        else
          state_next = DIGGING;
      end
      default: state_next = IDLE;
    endcase
  end

  // Ground fall detection
  always_comb begin
    ground_fall = !ground;
  end

  // Output logic
  assign walk_left = walking && (state == WALK_LEFT);
  assign walk_right = walking && (state == WALK_RIGHT);
  assign aaah = (state == FALLING) && (fall_counter >= 5'd20);
  assign digging = digging_logic;

endmodule
