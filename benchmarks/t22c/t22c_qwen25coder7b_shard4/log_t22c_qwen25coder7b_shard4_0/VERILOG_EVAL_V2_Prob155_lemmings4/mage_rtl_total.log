      next_state = DIG_LEFT;
      if (ground) begin
        next_state = IDLE;
        digging = 1'b0;
      end else if (!ground) begin
        next_state = FALL;
        aaah = 1'b1;
        fall_counter = 5'd0;
        digging = 1'b0;
      end else if (bump_left) begin
        next_state = WALK_RIGHT;
        walk_right = 1'b1;
        walk_left = 1'b0;
        digging = 1'b0;
