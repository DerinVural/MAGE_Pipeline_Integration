fall_counter + 1;\n      if (ground) begin\n        next_state = IDLE;\n        aaah = 1\'b0;\n        fall_counter = 5\'d0;\n      end\n    end\n    DIG_LEFT: begin\n      next_state = DIG_LEFT;\n      if (ground) begin\n        next_state = IDLE;\n        digging = 1\'b0;\n      end else if (!ground) begin\n        next_state = FALL;\n        aaah = 1\'b1;\n        fall_counter = 5\'d0;\n        digging = 1\'b0;\n      end else if (bump_left) begin\n        next_state = WALK_RIGHT;\n        walk_right = 1\'b1;\n        walk_left = 1\'b0;\n        digging = 1\'b0;\n      end else if (bump_right) begin\n        next_state = WALK_LEFT;\n        walk_right = 1\'b0;\n        walk_left = 1\'b1;\n        digging = 1\'b0;\n      end\n    end\n    DIG_RIGHT: begin\n      next_state = DIG_RIGHT;\n      if (ground) begin\n        next_state = IDLE;\n        digging = 1\'b0;\n      end else if (!ground) begin\n        next_state = FALL;\n        aaah = 1\'b1;\n        fall_counter = 5\'d0;\n        digging = 1\'b0;\n      end else if (bump_left) begin\n        next_state = WALK_RIGHT;\n        walk_right = 1\'b1;\n        walk_left = 1\'b0;\n        digging = 1\'b0;\n      end else if (bump_right) begin\n        next_state = WALK_LEFT;\n        walk_right = 1\'b0;\n        walk_left = 1\'b1;\n        digging = 1\'b0;\n      end\n    end\n    WALK_LEFT: begin\n      next_state = WALK_LEFT;\n      walk_left = 1\'b1;\n      walk_right = 1\'b0;\n      if (!ground) begin\n        next_state = FALL;\n        aaah = 1\'b1;\n        fall_counter = 5\'d0;\n      end else if (bump_left) begin\n        next_state = WALK_RIGHT;\n        walk_right = 1\'b1;\n        walk_left = 1\'b0;\n      end else if (bump_right) begin\n        next_state = WALK_LEFT;\n        walk_right = 1\'b0;\n        walk_left = 1\'b1;\n      end else if (dig && ground) begin\n        next_state = DIG_LEFT;\n        dig_side = 2\'b00;\n      end\n    end\n    WALK_RIGHT: begin\n      next_state = WALK_RIGHT;\n    