[2026-05-14 12:33:23,785 - mage.rtl_generator - INFO] RTL code: module TopModule (
  input logic clk,
  input logic areset,
  input logic bump_left,
  input logic bump_right,
  input logic ground,
  input logic dig,
  output logic walk_left,
  output logic walk_right,
  output logic aaah,
  output logic digging
);

// State definitions
localparam IDLE = 4'b0000;
localparam WALK_LEFT = 4'b0001;
localparam WALK_RIGHT = 4'b0010;
localparam FALLING = 4'b0011;
localparam DIGGING = 4'b0100;

// Internal signals
logic [3:0] state;
logic [3:0] state_next;
logic [4:0] fall_counter;

// Initializations
initial begin
  state = IDLE;
  fall_counter = 5'd0;
end

// Sequential logic
always @(posedge clk) begin
  if (areset)
    state <= IDLE;
  else
    state <= state_next;

  if (areset)
    fall_counter <= 5'd0;
  else if (fall_counter != 5'd20 && ground)
    fall_counter <= fall_counter + 1;
end

// Combinational logic
digging = 1'b0;
aaah = 1'b0;
walk_left = 1'b0;
walk_right = 1'b0;

always @(*) begin
  case (state)
    IDLE:
      begin
        walk_left = 1'b0;
        walk_right = 1'b0;
        aaah = 1'b0;
        digging = 1'b0;

        if (dig && ground)
          state_next = DIGGING;
        else if (bump_left)
          state_next = WALK_RIGHT;
        else if (bump_right)
          state_next = WALK_LEFT;
        else if (!ground)
          state_next = FALLING;
      end

    WALK_LEFT:
      begin
        walk_left = 1'b1;
        walk_right = 1'b0;
        aaah = 1'b0;
        digging = 1'b0;

        if (bump_left)
          state_next = WALK_RIGHT;
        else if (bump_right)
          state_next = WALK_LEFT;
        else if (!ground)
          state_next = FALLING;
      end

    WALK_RIGHT:
      begin
        walk_left = 1'b0;
        walk_right = 1'b1;
        aaah = 1'b0;
        digging = 1'b0;

        if (bump_left)
          state_next = WALK_RIGHT;
        else if (bump_right)
          state_next = WALK_LEFT;
        else if (!ground)
          state_next = FALLING;
      end

    FALLING:
      begin
        walk_left = 1'b0;
        walk_right = 1'b0;
        aaah = 1'b1;
        digging = 1'b0;

        if (fall_counter >= 20)
          state_next = IDLE;
      end

    DIGGING:
      begin
        walk_left = 1'b0;
        walk_right = 1'b0;
        aaah = 1'b0;
        digging = 1'b1;

        if (!ground)
          state_next = FALLING;
      end

    default:
      state_next = IDLE;
  endcase
end

endmodule
