[2026-05-14 12:33:55,443 - mage.rtl_generator - INFO] RTL code: module TopModule (
  input logic clk,
  input logic areset,
  input logic bump_left,
  input logic bump_right,
  input logic ground,
  input logic dig,
  output logic walk_left,
  output logic walk_right,
  output logic aaah,
  output logic digging
);

  // Define states
  localparam IDLE = 2'b00;
  localparam WALK_LEFT = 2'b01;
  localparam WALK_RIGHT = 2'b10;
  localparam FALL = 2'b11;

  // Internal signals
  logic [1:0] state;
  logic [1:0] next_state;
  logic [4:0] fall_count;
  logic digging_reg;

  // Initialization
  initial begin
    state = IDLE;
    fall_count = 5'b00000;
    digging_reg = 1'b0;
  end

  // Sequential logic
  always_ff @(posedge clk or posedge areset) begin
    if (areset) begin
      state <= IDLE;
      fall_count <= 5'b00000;
    end else begin
      state <= next_state;
      fall_count <= next_fall_count;
    end
  end

  // Combinational logic
  logic [4:0] next_fall_count;
  logic [1:0] next_next_state;

  always @(*) begin
    next_state = state;
    next_next_state = state;
    walk_left = 1'b0;
    walk_right = 1'b0;
    aaah = 1'b0;
    digging_reg = 1'b0;
    next_fall_count = fall_count;

    case (state)
      IDLE:
        begin
          walk_left = 1'b1;
          walk_right = 1'b0;
          if (bump_right)
            next_state = WALK_RIGHT;
          else if (ground == 1'b0)
            next_state = FALL;
        end

      WALK_LEFT:
        begin
          walk_left = 1'b1;
          walk_right = 1'b0;
          if (bump_right)
            next_state = WALK_RIGHT;
          else if (dig && ground == 1'b1)
            next_next_state = DIGGING;
          else if (ground == 1'b0)
            next_state = FALL;
        end

      WALK_RIGHT:
        begin
          walk_right = 1'b1;
          walk_left = 1'b0;
          if (bump_left)
            next_state = WALK_LEFT;
          else if (dig && ground == 1'b1)
            next_next_state = DIGGING;
          else if (ground == 1'b0)
            next_state = FALL;
        end

      FALL:
        begin
          aaah = 1'b1;
          walk_left = 1'b0;
          walk_right = 1'b0;
          if (ground == 1'b1 && fall_count == 5'b10100)
            next_state = FALL;
          else if (ground == 1'b1)
            next_next_state = WALK_LEFT;
          else if (fall_count == 5'b10100)
            next_next_state = WALK_RIGHT;
        end

      DIGGING:
        begin
          digging_reg = 1'b1;
          walk_left = 1'b0;
          walk_right = 1'b0;
          if (ground == 1'b0)
            next_state = FALL;
        end
    endcase

    if (next_next_state != state)
      next_state = next_next_state;
  end

  // Structural connections
  assign digging = digging_reg;

endmodule
