[2026-05-14 12:29:46,599 - mage.agent - INFO] Initial rtl:
[2026-05-14 12:29:46,600 - mage.agent - INFO] module TopModule (
  input logic clk,
  input logic areset,
  input logic bump_left,
  input logic bump_right,
  input logic ground,
  input logic dig,
  output logic walk_left,
  output logic walk_right,
  output logic aaah,
  output logic digging
);

// Define state parameters
localparam IDLE = 4'b0000;
localparam WALK_LEFT = 4'b0001;
localparam WALK_RIGHT = 4'b0010;
localparam FALLING = 4'b0011;
localparam DIGGING = 4'b0100;
localparam SPLAT = 4'b0101;

// Internal signals
logic [3:0] state;
logic [3:0] state_next;
logic [20:0] fall_counter;

// Initialize internal signals
initial begin
  state = IDLE;
  fall_counter = 0;
end

// Sequential logic
always @(posedge clk or posedge areset) begin
  if (areset) begin
    state <= IDLE;
    fall_counter <= 0;
  end else begin
    state <= state_next;
    if (state == FALLING) begin
      if (ground) begin
        if (fall_counter >= 20)
          state <= SPLAT;
        else
          fall_counter <= fall_counter + 1;
      end else
        fall_counter <= 0;
    end
  end
end

// Next state logic
always @(*) begin
  state_next = state;
  case (state)
    IDLE: begin
      if ((bump_left && !bump_right))
        state_next = WALK_RIGHT;
      else if ((!bump_left && bump_right))
        state_next = WALK_LEFT;
      else if (dig && ground)
        state_next = DIGGING;
      else if (!ground)
        state_next = FALLING;
    end
    WALK_LEFT: begin
      if (dig && ground)
        state_next = DIGGING;
      else if (!ground)
        state_next = FALLING;
      else if ((bump_left && !bump_right))
        state_next = WALK_RIGHT;
    end
    WALK_RIGHT: begin
      if (dig && ground)
        state_next = DIGGING;
      else if (!ground)
        state_next = FALLING;
      else if ((!bump_left && bump_right))
        state_next = WALK_LEFT;
    end
    FALLING: begin
      if (ground)
        state_next = IDLE;
    end
    DIGGING: begin
      if (!ground)
        state_next = FALLING;
    end
    SPLAT: begin
      state_next = SPLAT;
    end
    default: begin
      state_next = IDLE;
    end
  endcase
end

// Output logic
assign walk_left = (state == WALK_LEFT);
assign walk_right = (state == WALK_RIGHT);
assign aaah = (state == SPLAT);
assign digging = (state == DIGGING);

endmodule
