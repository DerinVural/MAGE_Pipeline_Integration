[2026-05-14 12:38:14,019 - mage.rtl_editor - INFO] module TopModule (
  input logic clk,
  input logic areset,
  input logic bump_left,
  input logic bump_right,
  input logic ground,
  input logic dig,
  output logic walk_left,
  output logic walk_right,
  output logic aaah,
  output logic digging
);

// Define states
localparam IDLE = 3'b000;
localparam FALL = 3'b001;
localparam DIG_LEFT = 3'b010;
localparam DIG_RIGHT = 3'b011;
localparam WALK_LEFT = 3'b100;
localparam WALK_RIGHT = 3'b101;

// State register
logic [2:0] current_state;
logic [2:0] next_state;

// Internal signals
logic [4:0] fall_counter;
logic [1:0] dig_side;
logic last_ground;

// Initial block to initialize internal signals
initial begin
  fall_counter = 5'd0;
  dig_side = 2'b00;
  last_ground = 1'b0;
  walk_left = 1'b0;
  walk_right = 1'b1;
  aaah = 1'b0;
  digging = 1'b0;
end

// Clock edge detection
always @(posedge clk) begin
  if (areset)
    current_state <= IDLE;
  else
    current_state <= next_state;
end

// Combinational logic for next state and outputs
always @(*) begin
  case (current_state)
    IDLE: begin
      next_state = IDLE;
      if (!ground) begin
        next_state = FALL;
        aaah = 1'b1;
      end else if (bump_left) begin
        next_state = WALK_RIGHT;
        walk_right = 1'b1;
        walk_left = 1'b0;
      end else if (bump_right) begin
        next_state = WALK_LEFT;
        walk_right = 1'b0;
        walk_left = 1'b1;
      end else if (dig && ground) begin
        next_state = DIG_LEFT;
        dig_side = 2'b00;
      end
    end
    FALL: begin
      next_state = FALL;
      fall_counter <= fall_counter + 1;
      if (ground) begin
        next_state = IDLE;
        aaah = 1'b0;
        fall_counter = 5'd0;
      end
    end
    DIG_LEFT: begin
      next_state = DIG_LEFT;
      if (ground) begin
        next_state = IDLE;
        digging = 1'b0;
      end else if (!ground) begin
        next_state = FALL;
        aaah = 1'b1;
        fall_counter = 5'd0;
        digging = 1'b0;
      end else if (bump_left) begin
        next_state = WALK_RIGHT;
        walk_right = 1'b1;
        walk_left = 1'b0;
        digging = 1'b0;
      end else if (bump_right) begin
        next_state = WALK_LEFT;
        walk_right = 1'b0;
        walk_left = 1'b1;
        digging = 1'b0;
      end
    end
    DIG_RIGHT: begin
      next_state = DIG_RIGHT;
      if (ground) begin
        next_state = IDLE;
        digging = 1'b0;
      end else if (!ground) begin
        next_state = FALL;
        aaah = 1'b1;
        fall_counter = 5'd0;
        digging = 1'b0;
      end else if (bump_left) begin
        next_state = WALK_RIGHT;
        walk_right = 1'b1;
        walk_left = 1'b0;
        digging = 1'b0;
      end else if (bump_right) begin
        next_state = WALK_LEFT;
        walk_right = 1'b0;
        walk_left = 1'b1;
        digging = 1'b0;
      end
    end
    WALK_LEFT: begin
      next_state = WALK_LEFT;
      walk_left = 1'b1;
      walk_right = 1'b0;
      if (!ground) begin
        next_state = FALL;
        aaah = 1'b1;
        fall_counter = 5'd0;
      end else if (bump_left) begin
        next_state = WALK_RIGHT;
        walk_right = 1'b1;
        walk_left = 1'b0;
      end else if (bump_right) begin
        next_state = WALK_LEFT;
        walk_right = 1'b0;
        walk_left = 1'b1;
      end else if (dig && ground) begin
        next_state = DIG_LEFT;
        dig_side = 2'b00;
      end
    end
    WALK_RIGHT: begin
      next_state = WALK_RIGHT;
      walk_left = 1'b0;
      walk_right = 1'b1;
      if (!ground) begin
        next_state = FALL;
        aaah = 1'b1;
        fall_counter = 5'd0;
      end else if (bump_left) begin
        next_state = WALK_RIGHT;
        walk_right = 1'b1;
        walk_left = 1'b0;
      end else if (bump_right) begin
        next_state = WALK_LEFT;
        walk_right = 1'b0;
        walk_left = 1'b1;
      end else if (dig && ground) begin
        next_state = DIG_RIGHT;
        dig_side = 2'b01;
      end
    end
  endcase
end

// Handle splat after falling
always @(posedge clk) begin
  if (fall_counter > 20) begin
    walk_left = 1'b0;
    walk_right = 1'b0;
    aaah = 1'b0;
    digging = 1'b0;
  end
end

endmodule

