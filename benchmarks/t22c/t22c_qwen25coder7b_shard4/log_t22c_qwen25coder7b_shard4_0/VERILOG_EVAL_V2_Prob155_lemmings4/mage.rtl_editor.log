end

// Clock edge detection
always @(posedge clk) begin
  if (areset)
    current_state <= IDLE;
  else
    current_state <= next_state;
end

// Combinational logic for next state and outputs
always @(*) begin
  case (current_state)
    IDLE: begin
      next_state = IDLE;
      if (!ground) begin
        next_state = FALL;
        aaah = 1'b1;
      end else if (bump_left) begin
        next_state = WALK_RIGHT;
        walk_right = 1'b1;
        walk_left = 1'b0;
      end else if (bump_right) begin
        next_state = WALK_LEFT;
        walk_right = 1'b0;
        walk_left = 1'b1;
      end else if (dig && ground) begin
        next_state = DIG_LEFT;
        dig_side = 2'b00;
      end
    end
    FALL: begin
      next_state = FALL;
      fall_counter <= fall_counter + 1;
      if (ground) begin
        next_state = IDLE;
        aaah = 1'b0;
        fall_counter = 5'd0;
      end
    end
    DIG_LEFT: begin
      next_state = DIG_LEFT;
      if (ground) begin
        next_state = IDLE;
        digging = 1'b0;
      end else if (!ground) begin
        next_state = FALL;
        aaah = 1'b1;
        fall_counter = 5'd0;
        digging = 1'b0;
      end else if (bump_left) begin
        next_state = WALK_RIGHT;
        walk_right = 1'b1;
        walk_left = 1'b0;
        digging = 1'b0;
      end else if (bump_right) begin
        next_state = WALK_LEFT;
        walk_right = 1'b0;
        walk_left = 1'b1;
        digging = 1'b0;
      end
    end
    DIG_RIGHT: begin
      next_state = DIG_RIGHT;
      if (ground) begin
        next_state = IDLE;
        digging = 1'b0;
      end else if (!ground) begin
        next_state = FALL;
        aaah = 1'b1;
        fall_counter = 5'd0;
        digging = 1'b0;
      end else if (bump_left) begin
        next_state = WALK_RIGHT;
        walk_right = 1'b1;
        walk_left = 1'b0;
        digging = 1'b0;
      end else if (bump_right) begin
        next_state = WALK_LEFT;
        walk_right = 1'b0;
        walk_left = 1'b1;
        digging = 1'b0;
      end
    end
    WALK_LEFT: begin
      next_state = WALK_LEFT;
      walk_left = 1'b1;
      walk_right = 1'b0;
      if (!ground) begin
        next_state = FALL;
        aaah = 1'b1;
        fall_counter = 5'd0;
      end else if (bump_left) begin
        next_state = WALK_RIGHT;
        walk_right = 1'b1;
        walk_left = 1'b0;
      end else if (bump_right) begin
        next_state = WALK_LEFT;
        walk_right = 1'b0;
        walk_left = 1'b1;
      end else if (dig && ground) begin
        next_state = DIG_LEFT;
        dig_side = 2'b00;
      end
    end
    WALK_RIGHT: begin
      next_state = WALK_RIGHT;
      walk_left = 1'b0;
      walk_right = 1'b1;
      if (!ground) begin
        next_state = FALL;
        aaah = 1'b1;
        fall_counter = 5'd0;
      end else if (bump_left) begin
        next_state = WALK_RIGHT;
        walk_right = 1'b1;
        walk_left = 1'b0;
      end else if (bump_right) begin
        next_state = WALK_LEFT;
        walk_right = 1'b0;
        walk_left = 1'b1;
      end else if (dig && ground) begin
        next_state = DIG_RIGHT;
        dig_side = 2'b01;
      end
    end
  endcase
end

// Handle splat after falling
always @(posedge clk) begin
  if (fall_counter > 20) begin
    walk_left = 1'b0;
    walk_right = 1'b0;
    aaah = 1'b0;
    digging = 1'b0;
  end
end

endmodule

