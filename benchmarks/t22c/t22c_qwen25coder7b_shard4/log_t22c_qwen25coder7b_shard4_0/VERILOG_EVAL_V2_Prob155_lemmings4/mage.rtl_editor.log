 = state == STATE_FALLING;\n\n// Initialize the \'digging\' signal to 0 outside the module\ninitial begin\ndigging = 1\'b0; // This initialization ensures that \'digging\' starts at 0 when the simulation begins\nend\n\nendmodule\n</rtl_code>\n')])]
