[2026-05-14 12:32:58,950 - mage.rtl_generator - INFO] RTL code: module TopModule (
  input logic clk,
  input logic areset,
  input logic bump_left,
  input logic bump_right,
  input logic ground,
  input logic dig,
  output logic walk_left,
  output logic walk_right,
  output logic aaah,
  output logic digging
);

parameter STATE_WALK_LEFT = 2'b00;
parameter STATE_WALK_RIGHT = 2'b01;
parameter STATE_DIGGING = 2'b10;
parameter STATE_SPLATTERED = 2'b11;

logic [1:0] state;
logic [1:0] state_next;
logic [4:0] fall_counter;

assign aaah = (state == STATE_SPLATTERED);
display "State: %b", state; 

always @(posedge clk or posedge areset) begin
  if (areset) begin
    state <= STATE_WALK_LEFT;
    fall_counter <= 5'd0;
  end else begin
    state <= state_next;
    if ((state == STATE_WALK_LEFT || state == STATE_WALK_RIGHT) && !ground)
      fall_counter <= fall_counter + 1;
    else
      fall_counter <= 5'd0;
  end
end

case (state)
  STATE_WALK_LEFT:
    walk_left = 1;
    walk_right = 0;
    digging = 0;
    if (bump_right)
      state_next = STATE_WALK_RIGHT;
    else if (dig && ground)
      state_next = STATE_DIGGING;

  STATE_WALK_RIGHT:
    walk_left = 0;
    walk_right = 1;
    digging = 0;
    if (bump_left)
      state_next = STATE_WALK_LEFT;
    else if (dig && ground)
      state_next = STATE_DIGGING;

  STATE_DIGGING:
    walk_left = 0;
    walk_right = 0;
    digging = 1;
    if (!ground)
      state_next = STATE_SPLATTERED;

  STATE_SPLATTERED:
    walk_left = 0;
    walk_right = 0;
    digging = 0;
  default:
    state_next = STATE_WALK_LEFT;
endcase

endmodule

