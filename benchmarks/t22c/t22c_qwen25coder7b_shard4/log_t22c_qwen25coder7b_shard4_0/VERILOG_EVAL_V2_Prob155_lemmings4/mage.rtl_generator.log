  // State register
  logic [2:0] state;

  // Internal signals
  logic is_falling;
  logic should_dig;
  logic should_turn_left;
  logic should_turn_right;
  logic was_ground;

  // Initialization block
  initial begin
    state = WALK_LEFT;
    is_falling = 0;
    should_dig = 0;
    should_turn_left = 0;
    should_turn_right = 0;
    was_ground = 1;
  end

  // Synchronous logic
  always @(posedge clk) begin
    if (areset)
      state <= IDLE;
    else begin
      // Handle state transitions
      unique case (state)
        IDLE:
          if (bump_left)
            state <= WALK_RIGHT;
          else if (bump_right)
            state <= WALK_LEFT;
        WALK_LEFT:
          if (ground) begin
            if (bump_left)
              state <= WALK_RIGHT;
            else if (bump_right)
              state <= WALK_LEFT;
            else if (dig)
              state <= DIGGING;
          end else begin
            state <= FALLING;
            is_falling = 1;
          end
        WALK_RIGHT:
          if (ground) begin
            if (bump_left)
              state <= WALK_RIGHT;
            else if (bump_right)
              state <= WALK_LEFT;
            else if (dig)
              state <= DIGGING;
          end else begin
            state <= FALLING;
            is_falling = 1;
          end
        FALLING:
          if (ground) begin
            state <= IDLE;
            is_falling = 0;
          end
        DIGGING:
          if (!ground) begin
            state <= FALLING;
            is_falling = 1;
          end else if (!dig)
            state <= WALK_LEFT;
      endcase
    end
  end

  // Combinational logic for outputs
  always @(*) begin
    walk_left = 0;
    walk_right = 0;
    aaah = 0;
    digging = 0;

    unique case (state)
      IDLE, WALK_LEFT, WALK_RIGHT:
        aaah = 0;
      FALLING:
        aaah = 1;
      DIGGING:
        digging = 1;
    endcase

    if (is_falling)
      walk_left = 0;
    else if (state == WALK_LEFT)
      walk_left = 1;

    if (is_falling)
      walk_right = 0;
    else if (state == WALK_RIGHT)
      walk_right = 1;
  end

