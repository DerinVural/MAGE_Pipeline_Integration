initial begin
  state = STATE_WALK_LEFT;
  splat = 0;
end

always @(posedge clk) begin
  if (areset)
    state <= STATE_WALK_LEFT;
  else
    state <= state_next;
end

always @(*) begin
  state_next = state;
  walk_left = 0;
  walk_right = 0;
  aaah = 0;
  digging = 0;
  dig_counter_en = 0;
  dig_counter_inc = 0;
  dig_counter_dec = 0;
  fall_timer_en = 0;
  fall_timer_inc = 0;
  fall_timer_dec = 0;

  case (state)
    STATE_IDLE:
      begin
        if (ground)
          state_next = STATE_WALK_LEFT;
        else
          state_next = STATE_FALLING;
      end
    STATE_WALK_LEFT:
      begin
        walk_left = 1;
        if (bump_left)
          state_next = STATE_WALK_RIGHT;
        else if (ground && dig)
        begin
          state_next = STATE_DIGGING;
          dig_counter_en = 1;
        end
        else if (!ground)
          state_next = STATE_FALLING;
      end
    STATE_WALK_RIGHT:
      begin
        walk_right = 1;
        if (bump_right)
          state_next = STATE_WALK_LEFT;
        else if (ground && dig)
        begin
          state_next = STATE_DIGGING;
          dig_counter_en = 1;
        end
        else if (!ground)
          state_next = STATE_FALLING;
      end
    STATE_FALLING:
      begin
        aaah = 1;
        fall_timer_en = 1;
        if (ground)
        begin
          state_next = STATE_WALK_LEFT;
          fall_timer_dec = 1;
        end
      end
    STATE_DIGGING:
      begin
        digging = 1;
        dig_counter_en = 1;
        if (!ground)
          state_next = STATE_FALLING;
      end
  endcase
end

always @(posedge clk or posedge areset) begin
  if (areset) begin
    fall_timer_dec = 0;
    splat = 0;
  end else begin
    if (fall_timer_dec)
      fall_timer_dec = 0;
    if (ground && state != STATE_FALLING && state != STATE_DIGGING)
      splat = 0;
    if (dig_counter_en) begin
      if (dig_counter_inc)
        fall_timer_inc = 1;
      if (dig_counter_dec)
        fall_timer_dec = 1;
    end
  end
end

assign aaah = splat;

endmodule
