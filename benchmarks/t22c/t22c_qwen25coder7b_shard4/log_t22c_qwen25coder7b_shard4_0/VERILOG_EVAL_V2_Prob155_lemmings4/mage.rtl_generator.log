[2026-05-14 12:34:33,036 - mage.rtl_generator - INFO] RTL code: module TopModule (
  input logic clk,
  input logic areset,
  input logic bump_left,
  input logic bump_right,
  input logic ground,
  input logic dig,
  output logic walk_left,
  output logic walk_right,
  output logic aaah,
  output logic digging
);

  // State definitions
  localparam IDLE = 2'b00;
  localparam WALK_LEFT = 2'b01;
  localparam WALK_RIGHT = 2'b10;
  localparam FALLING = 2'b11;

  // State register
  logic [1:0] state;
  logic [1:0] state_next;

  // Flags
  logic falling;
  logic digging_flag;
  logic direction_change;

  // Initialize flags
  initial begin
    falling = 0;
    digging_flag = 0;
    direction_change = 0;
  end

  // Always block for updating state
  always @(posedge clk or posedge areset) begin
    if (areset) begin
      state <= WALK_LEFT;
      falling <= 0;
      digging_flag <= 0;
      direction_change <= 0;
    end else begin
      state <= state_next;
    end
  end

  // Next state logic
  always @(*) begin
    state_next = state;
    case (state)
      IDLE:
        if (ground) begin
          if (dig) begin
            digging_flag = 1;
          end else if (bump_left || bump_right) begin
            direction_change = 1;
          end
        end
      WALK_LEFT:
        if (ground) begin
          if (dig) begin
            digging_flag = 1;
          end else if (bump_left) begin
            direction_change = 1;
          end else if (!ground) begin
            state_next = FALLING;
            falling = 1;
          end
        end
      WALK_RIGHT:
        if (ground) begin
          if (dig) begin
            digging_flag = 1;
          end else if (bump_right) begin
            direction_change = 1;
          end else if (!ground) begin
            state_next = FALLING;
            falling = 1;
          end
        end
      FALLING:
        if (ground) begin
          state_next = (direction_change) ? (bump_left ? WALK_RIGHT : WALK_LEFT) : IDLE;
          falling = 0;
        end
    endcase
  end

  // Outputs
  always @(*) begin
    walk_left = 0;
    walk_right = 0;
    aaah = 0;
    digging = 0;
    case (state)
      IDLE:
        if (ground) begin
          if (walking_left) walk_left = 1;
          else if (walking_right) walk_right = 1;
        end
      WALK_LEFT:
        walk_left = 1;
      WALK_RIGHT:
        walk_right = 1;
      FALLING:
        aaah = 1;
      default:
        // Should never reach here
        ;
    endcase
    if (digging_flag) digging = 1;
  end

endmodule
