  output logic walk_right,
  output logic aaah,
  output logic digging
);

  // States definition
  localparam IDLE = 2'b00;
  localparam WALK_LEFT = 2'b01;
  localparam WALK_RIGHT = 2'b10;
  localparam FALLING = 2'b11;
  localparam SPLAT = 2'b11;

  // Internal signals
  logic [1:0] state;
  logic [1:0] state_next;
  logic walking;
  logic digging_logic;
  logic ground_fall;
  logic fall_counter_reset;

  // Initialization block
  initial begin
    state = IDLE;
    walking = 1'b0;
    digging_logic = 1'b0;
    fall_counter_reset = 1'b0;
    fall_counter = 5'd0;
  end

  // Sequential logic
  always_ff @(posedge clk or posedge areset) begin
    if (areset)
      state <= IDLE;
    else
      state <= state_next;
  end

  // Next state logic
  always_comb begin
    state_next = state;
    case (state)
      IDLE: begin
        walking = 1'b0;
        digging_logic = 1'b0;
        fall_counter_reset = 1'b0;
        if (ground && bump_left)
          state_next = WALK_RIGHT;
        else if (ground && bump_right)
          state_next = WALK_LEFT;
        else if (dig)
          state_next = DIGGING;
        else if (!ground)
          state_next = FALLING;
      end
      WALK_LEFT: begin
        walking = 1'b1;
        digging_logic = 1'b0;
        fall_counter_reset = 1'b0;
        if (!ground)
          state_next = FALLING;
        else if (bump_left)
          state_next = WALK_RIGHT;
        else if (dig)
          state_next = DIGGING;
      end
      WALK_RIGHT: begin
        walking = 1'b1;
        digging_logic = 1'b0;
        fall_counter_reset = 1'b0;
        if (!ground)
          state_next = FALLING;
        else if (bump_right)
          state_next = WALK_LEFT;
        else if (dig)
          state_next = DIGGING;
      end
      FALLING: begin
        walking = 1'b0;
        digging_logic = 1'b0;
        ground_fall = !ground;
        if (ground_fall)
          state_next = IDLE;
        else begin
          state_next = FALLING;
          fall_counter_reset = 1'b0;
        end
      end
      default: state_next = IDLE;
    endcase
  end

  // Digging logic
  always_comb begin
digging_logic = 1'b0;
if (state != FALLING && state != SPLAT)
begin
digging_logic = dig;
end
else
digging_logic = 1'b0;
end

  // Ground fall detection
  always_comb begin
    ground_fall = !ground;
  end

  // Counter for fall duration
  always_ff @(posedge clk or posedge areset) begin
    if (areset)
      fall_counter <= 5'd0;
    else if (fall_counter_reset == 1'b0)
      fall_counter <= fall_counter + 1'd1;
  end

  // Output logic
  assign walk_left = walking && (state == WALK_LEFT);
  assign walk_right = walking && (state == WALK_RIGHT);
  assign aaah = (state == FALLING) && (fall_counter >= 5'd20);
  assign digging = digging_logic;

endmodule
