    "reasoning": "To implement the required functionality, a finite state machine (FSM) is designed to handle different states and transitions based on the inputs. The FSM transitions between states such as IDLE, FALL, DIG_LEFT, DIG_RIGHT, WALK_LEFT, and WALK_RIGHT. Each state represents a specific action or condition the Lemming can be in. The FSM uses synchronous reset for consistency. The `always @(*)` construct is used for combinational logic, ensuring it updates in every possible scenario. Initial values for signals are set in an initial block to ensure they are defined upon simulation start.",
    "module": "module TopModule (\n  input logic clk,\n  input logic areset,\n  input logic bump_left,\n  input logic bump_right,\n  input logic ground,\n  input logic dig,\n  output logic walk_left,\n  output logic walk_right,\n  output logic aaah,\n  output logic digging\n);\n\n// Define states\nlocalparam IDLE = 3'b000;\nlocalparam FALL = 3'b001;\nlocalparam DIG_LEFT = 3'b010;\nlocalparam DIG_RIGHT = 3'b011;\nlocalparam WALK_LEFT = 3'b100;\nlocalparam WALK_RIGHT = 3'b101;\n\n// State register\nreg [2:0] current_state;\nreg [2:0] next_state;\n\n// Internal signals\nreg [4:0] fall_counter;\nreg [1:0] dig_side;\nreg last_ground;\n\n// Initial block to initialize internal signals\ninitial begin\n  fall_counter = 5'd0;\n  dig_side = 2'b00;\n  last_ground = 1'b0;\n  walk_left = 1'b0;\n  walk_right = 1'b1;\n  aaah = 1'b0;\n  digging = 1'b0;\nend\n\n// Clock edge detection\nalways @(posedge clk) begin\n  if (areset)\n    current_state <= IDLE;\n  else\n    current_state <= next_state;\nend\n\n// Combinational logic for next state and outputs\ncase (current_state)\n  IDLE: begin\n    next_state = IDLE;\n    if (!ground) begin\n      next_state = FALL;\n      aaah = 1'b1;\n    end else if (bump_left) begin\n      next_state = WALK_RIGHT;\n      walk_right = 1'b1;\n      walk_left = 1'b0;\n    end else if (bump_right) begin\n      next_state = WALK_LEFT;\n      walk_right = 1'b0;\n      walk_left = 1'b1;\n    end else if (dig && ground) begin\n      next_state = DIG_LEFT;\n      dig_side = 2'b00;\n    end\n  end\n  FALL: begin\n    next_state = FALL;\n    fall_counter <= fall_counter + 1;\n    if (ground) begin\n      next_state = IDLE;\n      aaah = 1'b0;\n      fall_counter = 5'd0;\n    end\n  end\n  DIG_LEFT: begin\n    next_state = DIG_LEFT;\n    if (ground) begin\n      next_state = IDLE;\n      digging = 1'b0;\n    end else if (!ground) begin\n      next_state = FALL;\n      aaah = 1'b1;\n      fall_counter = 5'd0;\n      digging = 1'b0;\n    end else if (bump_left) begin\n      next_state = WALK_RIGHT;\n      walk_right = 1'b1;\n      walk_left = 1'b0;\n      digging = 1'b0;\n    end else if (bump_right) begin\n      next_state = WALK_LEFT;\n      walk_right = 1'b0;\n      walk_left = 1'b1;\n      digging = 1'b0;\n    end\n  end\n  DIG_RIGHT: begin\n    next_state = DIG_RIGHT;\n    if (ground) begin\n      next_state = IDLE;\n      digging = 1'b0;\n    end else if (!ground) begin\n      next_state = FALL;\n      aaah = 1'b1;\n      fall_counter = 5'd0;\n      digging = 1'b0;\n    end else if (bump_left) begin\n      next_state = WALK_RIGHT;\n      walk_right = 1'b1;\n      walk_left = 1'b0;\n      digging = 1'b0;\n    end else if (bump_right) begin\n      next_state = WALK_LEFT;\n      walk_right = 1'b0;\n      walk_left = 1'b1;\n      digging = 1'b0;\n    end\n  end\n  WALK_LEFT: begin\n    next_state = WALK_LEFT;\n    walk_left = 1'b1;\n    walk_right = 1'b0;\n    if (!ground) begin\n      next_state = FALL;\n      aaah = 1'b1;\n      fall_counter = 5'd0;\n    end else if (bump_left) begin\n      next_state = WALK_RIGHT;\n      walk_right = 1'b1;\n      walk_left = 1'b0;\n    end else if (bump_right) begin\n      next_state = WALK_LEFT;\n      walk_right = 1'b0;\n      walk_left = 1'b1;\n    end else if (dig && ground) begin\n      next_state = DIG_LEFT;\n      dig_side = 2'b00;\n    end\n  end\n  WALK_RIGHT: begin\n    next_state = WALK_RIGHT;\n    walk_left = 1'b0;\n    walk_right = 1'b1;\n    if (!ground) begin\n      next_state = FALL;\n      aaah = 1'b1;\n      fall_counter = 5'd0;\n    end else if (bump_left) begin\n      next_state = WALK_RIGHT;\n      walk_right = 1'b1;\n      walk_left = 1'b0;\n    end else if (bump_right) begin\n      next_state = WALK_LEFT;\n      walk_right = 1'b0;\n      walk_left = 1'b1;\n    end else if (dig && ground) begin\n      next_state = DIG_RIGHT;\n      dig_side = 2'b01;\n    end\n  end\nendcase\n\n// Handle splat after falling\nalways @(posedge clk) begin\n  if (fall_counter > 20) begin\n    walk_left = 1'b0;\n    walk_right = 1'b0;\n    aaah = 1'b0;\n    digging = 1'b0;\n  end\nend\n\nendmodule"
