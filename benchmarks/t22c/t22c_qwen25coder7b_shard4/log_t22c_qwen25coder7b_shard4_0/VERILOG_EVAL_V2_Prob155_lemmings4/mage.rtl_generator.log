    "reasoning": "The provided testbench requires a Moore state machine to handle the behavior of a Lemming in a 2D world. The state machine needs to manage multiple states such as walking left, walking right, falling, and digging. Each state must handle different combinations of inputs and update the outputs accordingly. The state machine should also handle asynchronous resets correctly. Additionally, the state machine should count the number of cycles a Lemming falls and transition to the splat state if it falls for more than 20 cycles.",
    "module": "module TopModule (\n  input logic clk,\n  input logic areset,\n  input logic bump_left,\n  input logic bump_right,\n  input logic ground,\n  input logic dig,\n  output logic walk_left,\n  output logic walk_right,\n  output logic aaah,\n  output logic digging\n);\n\n// Define state parameters\nlocalparam IDLE = 4'b0000;\nlocalparam WALK_LEFT = 4'b0001;\nlocalparam WALK_RIGHT = 4'b0010;\nlocalparam FALLING = 4'b0011;\nlocalparam DIGGING = 4'b0100;\nlocalparam SPLAT = 4'b0101;\n\n// Internal signals\nlogic [3:0] state;\nlogic [3:0] state_next;\nlogic [20:0] fall_counter;\n\n// Initialize internal signals\ninitial begin\n  state = IDLE;\n  fall_counter = 0;\nend\n\n// Sequential logic\nalways @(posedge clk or posedge areset) begin\n  if (areset) begin\n    state <= IDLE;\n    fall_counter <= 0;\n  end else begin\n    state <= state_next;\n    if (state == FALLING) begin\n      if (ground) begin\n        if (fall_counter >= 20)\n          state <= SPLAT;\n        else\n          fall_counter <= fall_counter + 1;\n      end else\n        fall_counter <= 0;\n    end\n  end\nend\n\n// Next state logic\nalways @(*) begin\n  state_next = state;\n  case (state)\n    IDLE: begin\n      if ((bump_left && !bump_right))\n        state_next = WALK_RIGHT;\n      else if ((!bump_left && bump_right))\n        state_next = WALK_LEFT;\n      else if (dig && ground)\n        state_next = DIGGING;\n      else if (!ground)\n        state_next = FALLING;\n    end\n    WALK_LEFT: begin\n      if (dig && ground)\n        state_next = DIGGING;\n      else if (!ground)\n        state_next = FALLING;\n      else if ((bump_left && !bump_right))\n        state_next = WALK_RIGHT;\n    end\n    WALK_RIGHT: begin\n      if (dig && ground)\n        state_next = DIGGING;\n      else if (!ground)\n        state_next = FALLING;\n      else if ((!bump_left && bump_right))\n        state_next = WALK_LEFT;\n    end\n    FALLING: begin\n      if (ground)\n        state_next = IDLE;\n    end\n    DIGGING: begin\n      if (!ground)\n        state_next = FALLING;\n    end\n    SPLAT: begin\n      state_next = SPLAT;\n    end\n    default: begin\n      state_next = IDLE;\n    end\n  endcase\nend\n\n// Output logic\nassign walk_left = (state == WALK_LEFT);\nassign walk_right = (state == WALK_RIGHT);\nassign aaah = (state == SPLAT);\nassign digging = (state == DIGGING);\n\nendmodule"
