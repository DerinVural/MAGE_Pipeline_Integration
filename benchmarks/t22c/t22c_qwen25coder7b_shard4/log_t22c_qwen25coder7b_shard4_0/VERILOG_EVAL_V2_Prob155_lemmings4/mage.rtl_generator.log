parameter STATE_IDLE = 2'b00;
parameter STATE_WALK_LEFT = 2'b01;
parameter STATE_WALK_RIGHT = 2'b10;
parameter STATE_FALLING = 2'b11;

logic [1:0] state;
logic [1:0] state_next;
logic [1:0] previous_state;
logic dig_counter_en;
logic dig_counter_inc;
logic dig_counter_dec;
logic fall_timer_en;
logic fall_timer_inc;
logic fall_timer_dec;
