     next_next_state = DIGGING;\n          else if (ground == 1'b0)\n            next_state = FALL;\n        end\n\n      FALL:\n        begin\n          aaah = 1'b1;\n          walk_left = 1'b0;\n          walk_right = 1'b0;\n          if (ground == 1'b1 && fall_count == 5'b10100)\n            next_state = FALL;\n          else if (ground == 1'b1)\n            next_next_state = WALK_LEFT;\n          else if (fall_count == 5'b10100)\n            next_next_state = WALK_RIGHT;\n        end\n\n      DIGGING:\n        begin\n          digging_reg = 1'b1;\n          walk_left = 1'b0;\n          walk_right = 1'b0;\n          if (ground == 1'b0)\n            next_state = FALL;\n        end\n    endcase\n\n    if (next_next_state != state)\n      next_state = next_next_state;\n  end\n\n  // Structural connections\n  assign digging = digging_reg;\n\nendmodule"
