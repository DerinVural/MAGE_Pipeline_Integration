        end

      WALK_LEFT:
        begin
          walk_left = 1'b1;
          walk_right = 1'b0;
          if (bump_right)
            next_state = WALK_RIGHT;
          else if (dig && ground == 1'b1)
            next_state = DIGGING;
          else if (ground == 1'b0)
            next_state = FALL;
        end

      WALK_RIGHT:
        begin
          walk_right = 1'b1;
          walk_left = 1'b0;
          if (bump_left)
            next_state = WALK_LEFT;
          else if (dig && ground == 1'b1)
            next_state = DIGGING;
          else if (ground == 1'b0)
            next_state = FALL;
        end

      FALL:
        begin
          aaah = 1'b1;
          walk_left = 1'b0;
          walk_right = 1'b0;
          if (ground == 1'b1 && fall_count >= 20)
            next_state = FALL;
          else if (ground == 1'b1)
            next_state = WALK_LEFT;
          else if (fall_count >= 20)
            next_state = WALK_RIGHT;
        end

      DIGGING:
        begin
          digging = 1'b1;
          walk_left = 1'b0;
          walk_right = 1'b0;
          if (ground == 1'b0)
            next_state = FALL;
        end
    endcase
  end

endmodule
