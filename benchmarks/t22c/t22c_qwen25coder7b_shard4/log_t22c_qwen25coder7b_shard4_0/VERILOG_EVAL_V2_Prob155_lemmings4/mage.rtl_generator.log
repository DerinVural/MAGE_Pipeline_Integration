      WALK_LEFT: begin
        walking = 1'b1;
        if (!ground)
          state_next = FALLING;
        else if (bump_left)
          state_next = WALK_RIGHT;
        else if (dig)
          state_next = DIGGING;
      end
      WALK_RIGHT: begin
        walking = 1'b1;
        if (!ground)
          state_next = FALLING;
        else if (bump_right)
          state_next = WALK_LEFT;
        else if (dig)
          state_next = DIGGING;
      end
      FALLING: begin
        walking = 1'b0;
        fall_counter_reset = 1'b1;
        if (ground)
          state_next = IDLE;
      end
      DIGGING: begin
        if (digging_logic && !ground)
          state_next = FALLING;
        else
          state_next = DIGGING;
        digging_logic = dig;
      end
      default: state_next = IDLE;
    endcase
  end

  // Ground fall detection
  always_comb begin
    ground_fall = !ground;
  end

  // Output logic
  assign walk_left = walking && (state == WALK_LEFT);
  assign walk_right = walking && (state == WALK_RIGHT);
  assign aaah = (state == FALLING) && (fall_counter >= 5'd20);
  assign digging = digging_logic;

endmodule
