total_stats.stats1 = 0;

total_stats.stats1.errors = 0;
total_stats.stats1.errortime = 0;
total_stats.stats1.errors_out = 0;
total_stats.stats1.errortime_out = 0;
total_stats.stats1.clocks = 0;

final begin
