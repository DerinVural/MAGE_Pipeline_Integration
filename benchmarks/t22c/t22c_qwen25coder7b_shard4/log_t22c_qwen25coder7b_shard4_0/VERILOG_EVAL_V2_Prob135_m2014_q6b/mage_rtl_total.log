                STATE_E: current_state <= (y[1]) ? STATE_D : STATE_E;
                STATE_F: current_state <= (y[1]) ? STATE_C : STATE_D;
                default: current_state <= STATE_A;
            endcase
        end
    end

    // Combinational logic to determine the output Y1
    always @(*) begin
        Y1 = current_state[1];
    end

