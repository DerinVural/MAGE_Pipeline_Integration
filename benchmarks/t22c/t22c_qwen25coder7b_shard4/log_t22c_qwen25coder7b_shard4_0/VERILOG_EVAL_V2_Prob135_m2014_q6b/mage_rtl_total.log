[2026-05-14 11:36:30,349 - mage.rtl_editor - INFO] module TopModule (
    input  logic [2:0] y,
    input  logic w,
    output logic Y1
);

    // State definitions
    localparam STATE_A = 3'b000;
    localparam STATE_B = 3'b001;
    localparam STATE_C = 3'b010;
    localparam STATE_D = 3'b011;
    localparam STATE_E = 3'b100;
    localparam STATE_F = 3'b101;

    // State register
    logic [2:0] state;

    // Initial state assignment
    initial begin
        state = STATE_A;
    end

    // Next-state logic
    always @(*) begin
        case (state)
            STATE_A: state = (w == 1'b0) ? STATE_B : STATE_A;
            STATE_B: state = (w == 1'b0) ? STATE_C : STATE_D;
            STATE_C: state = (w == 1'b0) ? STATE_E : STATE_D;
            STATE_D: state = (w == 1'b0) ? STATE_F : STATE_A;
            STATE_E: state = (w == 1'b1) ? STATE_D : STATE_E;
            STATE_F: state = (w == 1'b1) ? STATE_C : STATE_D;
            default: state = STATE_A;  // Default state to ensure determinism
        endcase
    end

    // Output logic
    assign Y1 = (state == STATE_B || state == STATE_D) ? 1'b1 : 1'b0;

