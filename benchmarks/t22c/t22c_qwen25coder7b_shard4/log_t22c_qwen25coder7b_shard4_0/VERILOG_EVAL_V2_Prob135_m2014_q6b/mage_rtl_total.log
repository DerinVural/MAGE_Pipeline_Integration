	input  logic [2:0] y,
	input  logic w,
	input  logic reset,
	output logic Y1,
	input  logic clk
);

	// State encoding
	localparam STATE_A = 3'b000;
	localparam STATE_B = 3'b001;
	localparam STATE_C = 3'b010;
	localparam STATE_D = 3'b011;
	localparam STATE_E = 3'b100;
	localparam STATE_F = 3'b101;

	// State registers
	logic [2:0] state;
	logic [2:0] state_next;

	// Initial block to set the default state
	initial begin
		state = STATE_A;
		state_next = STATE_A;
	end

	// Sequential logic
	after @(posedge clk or posedge reset) begin
		if (reset)
			state <= STATE_A;
		else
			state <= state_next;
	end

	// Next-state logic
	always @(*) begin
		case(state)
			STATE_A: state_next = (w) ? STATE_A : STATE_B;
			STATE_B: state_next = (w) ? STATE_D : STATE_C;
			STATE_C: state_next = (w) ? STATE_D : STATE_E;
