[2026-05-14 11:31:17,535 - mage.agent - INFO] module TopModule (
    input logic [2:0] y,
    input logic w,
    input logic reset,
    input logic clk,
    output logic Y1
);

    // Define state constants
    localparam STATE_A = 3'b000;
    localparam STATE_B = 3'b001;
    localparam STATE_C = 3'b010;
    localparam STATE_D = 3'b011;
    localparam STATE_E = 3'b100;
    localparam STATE_F = 3'b101;

    // Register to store current state
    logic [2:0] state;

    // Initialize state register
    initial begin
        state = STATE_A;
    end

    // Always_ff block for sequential logic
    always_ff @(posedge clk or posedge reset) begin
        if (reset)
            state <= STATE_A;
        else
            state <= state_table[state][w];
    end

    // Array to store state transition table
    logic [2:0] state_table [0:7][0:1];

    // Initialize state transition table
    initial begin
        state_table[STATE_A][0] = STATE_A;
        state_table[STATE_A][1] = STATE_A;
        state_table[STATE_B][0] = STATE_C;
        state_table[STATE_B][1] = STATE_D;
        state_table[STATE_C][0] = STATE_E;
        state_table[STATE_C][1] = STATE_D;
        state_table[STATE_D][0] = STATE_F;
        state_table[STATE_D][1] = STATE_A;
        state_table[STATE_E][0] = STATE_E;
        state_table[STATE_E][1] = STATE_D;
        state_table[STATE_F][0] = STATE_C;
        state_table[STATE_F][1] = STATE_D;
    end

    // Assign output Y1
    assign Y1 = state[1];

endmodule
