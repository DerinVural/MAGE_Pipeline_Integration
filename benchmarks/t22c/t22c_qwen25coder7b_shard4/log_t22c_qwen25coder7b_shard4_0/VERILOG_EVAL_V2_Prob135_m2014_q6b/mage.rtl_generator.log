	output logic Y1
);

	// Define state constants
	localparam A = 3'b000;
	localparam B = 3'b001;
	localparam C = 3'b010;
	localparam D = 3'b011;
	localparam E = 3'b100;
	localparam F = 3'b101;

	// Register to hold the current state
	reg [2:0] current_state;
	
