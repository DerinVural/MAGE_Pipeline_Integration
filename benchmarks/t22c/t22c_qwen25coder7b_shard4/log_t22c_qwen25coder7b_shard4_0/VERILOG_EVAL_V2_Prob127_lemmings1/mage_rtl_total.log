                        state <= WALKING_LEFT;
                    end
                end
                default: state <= WALKING_LEFT;
            endcase
        end
    end

    // Always block for setting output
    always @(*) begin
        walk_left = (state == WALKING_LEFT);
        walk_right = (state == IDLE);
    end

