                    if (bump_right)
                        current_state <= STATE_RIGHT;
                STATE_RIGHT:
                    if (bump_left)
                        current_state <= STATE_LEFT;
                default:
                    // This case should never occur
                    current_state <= STATE_LEFT;
            endcase
        end
    end

    // Combinational logic to drive the outputs
    always @(*) begin
        walk_left = 1'b0;
        walk_right = 1'b0;
        case (current_state)
            STATE_LEFT:
                walk_left = 1'b1;
            STATE_RIGHT:
                walk_right = 1'b1;
        endcase
    end

endmodule
