[2026-05-14 11:15:08,309 - mage.rtl_editor - INFO] module TopModule (
    input logic clk,
    input logic areset,
    input logic bump_left,
    input logic bump_right,
    output logic walk_left,
    output logic walk_right
);

    // Define states
    localparam WL = 0;
    localparam WR = 1;

    // State register
    logic [0:0] state;

    // Internal outputs
    logic walk_left_int;
    logic walk_right_int;

    // Next state logic
    logic [0:0] next_state;

    // Initialize state and internal outputs
    initial begin
        state = WL;
        walk_left_int = 0;
        walk_right_int = 0;
    end

    // Synchronous reset
    always @(posedge clk or posedge areset) begin
        if (areset)
            state <= WL;
        else
            state <= next_state;
    end

    // Next state logic
    always @(*) begin
        case (state)
            WL: begin
                if (bump_left)
                    next_state = WR;
                else
                    next_state = WL;
            end
            WR: begin
                if (bump_right)
                    next_state = WL;
                else
                    next_state = WR;
            end
            default: next_state = WL;
        endcase
    end

    // Output logic
    always @(*) begin
        walk_left_int = (state == WL);
        walk_right_int = (state == WR);
    end

    // Assign outputs
    assign walk_left = walk_left_int;
    assign walk_right = walk_right_int;

endmodule
