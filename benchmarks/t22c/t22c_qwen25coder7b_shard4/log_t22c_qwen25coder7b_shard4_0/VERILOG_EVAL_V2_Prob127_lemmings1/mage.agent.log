[2026-05-14 11:12:50,063 - mage.agent - INFO] module TopModule (
    input logic clk,
    input logic areset,
    input logic bump_left,
    input logic bump_right,
    output logic walk_left,
    output logic walk_right
);

    // Define constants for the states
    localparam STATE_LEFT = 1'b0;
    localparam STATE_RIGHT = 1'b1;

    // Register to hold the current state
    logic current_state;

    // Assign the initial state
    initial begin
        current_state = STATE_LEFT;
    end

    // Sequential logic block
    always @(posedge clk) begin
        if (areset)
            current_state <= STATE_LEFT;
        else begin
            case (current_state)
                STATE_LEFT:
                    if (bump_right)
                        current_state <= STATE_RIGHT;
                STATE_RIGHT:
                    if (bump_left)
                        current_state <= STATE_LEFT;
                default:
                    // This case should never occur
                    current_state <= STATE_LEFT;
            endcase
        end
    end

    // Combinational logic to drive the outputs
    always @(*) begin
        walk_left = 1'b0;
        walk_right = 1'b0;
        case (current_state)
            STATE_LEFT:
                walk_left = 1'b1;
            STATE_RIGHT:
                walk_right = 1'b1;
        endcase
    end

endmodule
