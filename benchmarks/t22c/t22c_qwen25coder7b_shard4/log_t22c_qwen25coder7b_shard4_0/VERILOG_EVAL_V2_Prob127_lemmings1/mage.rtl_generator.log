[2026-05-14 11:13:27,550 - mage.rtl_generator - INFO] RTL code: module TopModule (input logic clk, input logic areset, input logic bump_left, input logic bump_right, output logic walk_left, output logic walk_right); 

	// Define states
	localparam IDLE = 2'b00;
	localparam WALK_LEFT = 2'b01;
	localparam WALK_RIGHT = 2'b10;

	// State register
	logic [1:0] state;
	logic [1:0] next_state;

	// Initialize state to idle
	initial begin
		disable iff (1'b0)
		state = IDLE;
	end

	// Asynchronous reset logic
	always_ff @(posedge clk) begin
		if (areset)
			state <= IDLE;
		else
			state <= next_state;
	end

	// Next state logic
	always_comb begin
		next_state = state;
		case (state)
			IDLE:
				begin
					if (bump_left | bump_right)
						next_state = (bump_left) ? WALK_RIGHT : WALK_LEFT;
				end
			WALK_LEFT:
				begin
					if (bump_right)
						next_state = WALK_RIGHT;
					else
						next_state = IDLE;
				end
			WALK_RIGHT:
				begin
					if (bump_left)
						next_state = WALK_LEFT;
					else
						next_state = IDLE;
				end
			default:
					next_state = IDLE;
		endaese
	end

	// Output logic
	always_comb begin
		walk_left = 1'b0;
		walk_right = 1'b0;
		case (state)
			WALK_LEFT:
				walk_left = 1'b1;
			WALK_RIGHT:
				walk_right = 1'b1;
		endaese
	end

endmodule
