	input logic clk,
	input logic areset,
	input logic bump_left,
	input logic bump_right,
	output logic walk_left,
	output logic walk_right
);

	// Define states using localparams
	localparam STATE_LEFT = 1'b0;
	localparam STATE_RIGHT = 1'b1;

	// Internal state and outputs
	logic state_reg;
	logic walk_left_reg;
	logic walk_right_reg;

	// Initialize internal signals in the initial block
	initial begin
		state_reg = STATE_LEFT;
		walk_left_reg = 0;
		walk_right_reg = 0;
	end

	// Always block for the state transition
	always @(posedge clk) begin
		if (areset) begin
			state_reg <= STATE_LEFT;
			walk_left_reg <= 0;
			walk_right_reg <= 0;
		end else begin
			case (state_reg)
				STATE_LEFT: begin
					walk_left_reg <= 1;
					walk_right_reg <= 0;
					if (bump_right) state_reg <= STATE_RIGHT;
				end
				STATE_RIGHT: begin
					walk_left_reg <= 0;
					walk_right_reg <= 1;
					if (bump_left) state_reg <= STATE_LEFT;
				end
				default: begin
					walk_left_reg <= 0;
					walk_right_reg <= 0;
					state_reg <= STATE_LEFT;
				end
			endcase
		end
	end

	// Assign outputs
	assign walk_left = walk_left_reg;
	assign walk_right = walk_right_reg;

endmodule
