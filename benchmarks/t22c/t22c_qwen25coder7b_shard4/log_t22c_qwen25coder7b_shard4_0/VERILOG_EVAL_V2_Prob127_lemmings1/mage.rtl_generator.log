    // Define the states of the FSM
    localparam IDLE_LEFT = 2'b00;
    localparam WALKING_RIGHT = 2'b01;
    localparam WALKING_LEFT = 2'b10;

    // Register to store the current state of the FSM
    logic [1:0] current_state = IDLE_LEFT;

    // Register to store the next state of the FSM
    logic [1:0] next_state;

    // Always block to update the next state based on the current state and inputs
