					if (bump_right)
						next_state = WALK_RIGHT;
					else
						next_state = IDLE;
				end
			WALK_RIGHT:
				begin
					if (bump_left)
						next_state = WALK_LEFT;
					else
						next_state = IDLE;
				end
			default:
