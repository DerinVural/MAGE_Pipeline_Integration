	// Define states
	localparam WL = 0;
	localparam WR = 1;

	// State register
	logic [0:0] state;

	// Internal outputs
	logic walk_left_int;
	logic walk_right_int;

	// Initial block for state and internal outputs
	initial begin
		state = WL;
		walk_left_int = 0;
		walk_right_int = 0;
	end

	// Synchronous reset
	synchronous_reset: always @(posedge clk or posedge areset) begin
		if (areset)
