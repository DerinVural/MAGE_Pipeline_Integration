					if (bump_right)
						next_state = WALK_RIGHT;
					else
						next_state = IDLE;
				end
			WALK_RIGHT:
				begin
					if (bump_left)
						next_state = WALK_LEFT;
					else
						next_state = IDLE;
				end
			default:
						next_state = IDLE;
				endcase
	end

	// Output logic
	always_comb begin
		walk_left = 1'b0;
		walk_right = 1'b0;
		case (state)
			WALK_LEFT:
					walk_left = 1'b1;
			WALK_RIGHT:
					walk_right = 1'b1;
			endcase
	end

endmodule
