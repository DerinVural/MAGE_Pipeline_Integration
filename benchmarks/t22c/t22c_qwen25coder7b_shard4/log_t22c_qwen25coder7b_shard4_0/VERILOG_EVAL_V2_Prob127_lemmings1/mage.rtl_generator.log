    localparam IDLE = 1'b0;
    localparam WALKING_LEFT = 1'b1;

    // Register to hold current state
    logic state;

    // Initial state is WALKING_LEFT
    initial begin
        state = WALKING_LEFT;
    end

    // Always block for updating state and output
    always @(posedge clk or posedge areset) begin
        if (areset) begin
            state <= WALKING_LEFT;
        end else begin
            case (state)
                IDLE: begin
                    if (bump_left || bump_right) begin
                        state <= WALKING_LEFT;
                    end
                end
                WALKING_LEFT: begin
                    if (bump_left) begin
                        state <= WALKING_LEFT;
                    end else if (bump_right) begin
                        state <= IDLE;
                    end else begin
                        state <= WALKING_LEFT;
                    end
                end
                default: state <= WALKING_LEFT;
            endcase
        end
    end

    // Always block for setting output
    always @(*) begin
        walk_left = (state == WALKING_LEFT);
        walk_right = (state == IDLE);
    end

endmodule
