            begin
                next_state = (bump_left | bump_right) ? STATE_LEFT : STATE_RIGHT;
                walk_left_logic = (next_state == STATE_LEFT) ? 1 : 0;
                walk_right_logic = (next_state == STATE_RIGHT) ? 1 : 0;
            end
        default:
            begin
                next_state = STATE_LEFT;
                walk_left_logic = 1;
                walk_right_logic = 0;
            end
        endcase
    end

    // Assign the outputs
