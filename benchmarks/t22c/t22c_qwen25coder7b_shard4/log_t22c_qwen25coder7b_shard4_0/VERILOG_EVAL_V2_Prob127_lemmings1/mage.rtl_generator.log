	localparam IDLE = 2'b00;
	localparam WALK_LEFT = 2'b01;
	localparam WALK_RIGHT = 2'b10;

	// State register
	logic [1:0] state;
	logic [1:0] next_state;

	// Initialize state to idle
	initial begin
		state = IDLE;
	end

	// Asynchronous reset logic
	always_ff @(posedge clk) begin
		if (areset)
			state <= IDLE;
		else
			state <= next_state;
	end

	// Next state logic
	always_comb begin
		next_state = state;
		case (state)
