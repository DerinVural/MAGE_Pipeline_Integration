// State definitions
localparam WALK_LEFT = 1;
localparam WALK_RIGHT = 0;

// Internal state register
clock_wg_reg state = WALK_LEFT;

// Synchronous reset
always_ff @(posedge clk or posedge areset) begin
    if (areset)
        state <= WALK_LEFT;
    else
        state <= state_next;
end

// Next state determination
logic [1:0] state_next;
always_comb begin
    case (state)
        WALK_LEFT: state_next = (bump_left | bump_right) ? WALK_RIGHT : WALK_LEFT;
        WALK_RIGHT: state_next = (bump_left | bump_right) ? WALK_LEFT : WALK_RIGHT;
        default: state_next = WALK_LEFT;
    endcase
end

// Output determination
always_comb begin
    walk_left = (state == WALK_LEFT);
    walk_right = (state == WALK_RIGHT);
end

