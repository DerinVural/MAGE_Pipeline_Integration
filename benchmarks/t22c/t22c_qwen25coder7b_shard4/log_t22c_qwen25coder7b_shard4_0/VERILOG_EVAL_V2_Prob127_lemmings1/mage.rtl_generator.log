				else
					next_state = WR;
			end
			default: next_state = WL;
		endcase
	end

	// Output logic
	output_logic: always @(*) begin
		walk_left_int = (state == WL);
		walk_right_int = (state == WR);
	end

	// Assign outputs
	assign walk_left = walk_left_int;
	assign walk_right = walk_right_int;

endmodule
