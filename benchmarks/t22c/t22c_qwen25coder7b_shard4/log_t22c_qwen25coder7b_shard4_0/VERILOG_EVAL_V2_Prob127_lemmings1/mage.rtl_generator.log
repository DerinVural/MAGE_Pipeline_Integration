        case (current_state)
            IDLE_LEFT:
                next_state = (bump_right) ? WALKING_RIGHT : IDLE_LEFT;
            WALKING_RIGHT:
                next_state = (bump_left) ? IDLE_LEFT : WALKING_RIGHT;
            WALKING_LEFT:
                next_state = (bump_right) ? WALKING_RIGHT : IDLE_LEFT;
            default:
                next_state = IDLE_LEFT;
        endcase
    end

    // Always block to update the current state on the rising edge of the clock
    always @(posedge clk) begin
        if (areset) begin
            current_state <= IDLE_LEFT;
        end else begin
            current_state <= next_state;
        end
    end

    // Always block to drive the output based on the current state
    always @(*) begin
        case (current_state)
            IDLE_LEFT:
                walk_left = 1'b0;
                walk_right = 1'b1;
            WALKING_RIGHT:
                walk_left = 1'b1;
                walk_right = 1'b0;
            WALKING_LEFT:
                walk_left = 1'b0;
                walk_right = 1'b1;
            default:
                walk_left = 1'b0;
                walk_right = 1'b1;
        endcase
