[2026-05-14 11:52:12,316 - mage.agent - INFO] module TopModule(
    input  logic clk,
    input  logic a,
    input  logic b,
    output logic q,
    output logic state
);

    // Define states
    localparam IDLE = 2'b00;
    localparam COUNTING = 2'b01;
    localparam CHECKING = 2'b10;

    // State register
    logic [1:0] current_state;
    logic [1:0] next_state;

    // Initialize state register
    initial begin
current_state = IDLE;
end

    // Sequential logic for state update
    always @(posedge clk) begin
        current_state <= next_state;
    end

    // Combinational logic to determine next state and output
    always @(*) begin
        next_state = IDLE;
        q = 0;

        case (current_state)
        IDLE:
            begin
                if ((a && b))
                    next_state = COUNTING;
            end
        COUNTING:
            begin
                q = 1;
                if (!(a && b))
                    next_state = CHECKING;
            end
        CHECKING:
            begin
                if (a || b)
                    next_state = IDLE;
            end
        endcase
    end

    // Assign state output
    assign state = current_state;

endmodule
