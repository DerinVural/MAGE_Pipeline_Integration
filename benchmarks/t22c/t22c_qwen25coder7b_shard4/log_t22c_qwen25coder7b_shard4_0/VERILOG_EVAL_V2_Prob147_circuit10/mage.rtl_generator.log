[2026-05-14 11:53:25,271 - mage.rtl_generator - INFO] RTL code: module TopModule (
    input logic clk,
    input logic a,
    input logic b,
    input logic rst,
    output logic q,
    output logic state
);

    // Define states using parameters for clarity
    localparam STATE_A = 2'b00;
    localparam STATE_B = 2'b01;
    localparam STATE_C = 2'b10;

    // Register to hold the current state
    logic [1:0] current_state;
    logic [1:0] next_state;

    // Initialize the state register
    initial begin
        current_state = STATE_A;
    end

    // Sequential logic
    always_ff @(posedge clk or posedge rst) begin
        if (rst)
            current_state <= STATE_A;
        else
            current_state <= next_state;
    end

    // Combinational logic to determine the next state
    always @(*) begin
        next_state = STATE_A;
        case (current_state)
        STATE_A: begin
            if (a && !b)
                next_state = STATE_B;
        end
        STATE_B: begin
            if (!a && b)
                next_state = STATE_C;
        end
        STATE_C: begin
            if (!a && !b)
                next_state = STATE_A;
        end
        endcase
    end

    // Output logic
    always @(*) begin
        q = 1'b0;
        case (current_state)
        STATE_A: q = 1'b0;
        STATE_B: q = 1'b0;
        STATE_C: q = 1'b1;
        endcase
    end

    // Assigning the state to the output port
    assign state = current_state;

endmodule;
