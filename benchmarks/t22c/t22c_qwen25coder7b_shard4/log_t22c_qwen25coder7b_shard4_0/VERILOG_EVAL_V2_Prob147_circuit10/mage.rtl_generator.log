[2026-05-14 11:53:36,827 - mage.rtl_generator - INFO] RTL code: module TopModule (
    input logic clk,
    input logic a,
    input logic b,
    output logic q,
    output logic state
);

    // Parameters
    localparam IDLE = 2'b00;
    localparam COUNTING = 2'b01;
    localparam WAITING = 2'b10;

    // Registers
    logic [1:0] current_state;
    logic [1:0] next_state;
    logic [1:0] count;

    // Sequential Logic
    always_ff @(posedge clk) begin
        if (reset)
            current_state <= IDLE;
        else
            current_state <= next_state;
    end

    // Combinational Logic
    always_comb begin
        next_state = current_state;
        count = 2'b00;
        q = 1'b0;

        case (current_state)
            IDLE:
                if (a && b) begin
                    next_state = COUNTING;
                    count = 2'b00;
                end
            COUNTING:
                if (a || b) begin
                    next_state = IDLE;
                end else begin
                    count += 1;
                    if (count == 2'b10) begin
                        q = 1'b1;
                        next_state = WAITING;
                    end
                end
            WAITING:
                if (a || b) begin
                    next_state = IDLE;
                end
        endcase
    end

endmodule
