    input  logic clk,
    input  logic a,
    input  logic b,
    output logic q,
    output logic state
);

    // Define states
    localparam IDLE = 1'b0;
    localparam SET_Q = 1'b1;

    // Register to hold the current state
    logic current_state;
    always_ff @(posedge clk) begin
        if (reset)
            current_state <= IDLE;
        else
            current_state <= next_state;
    end

    // Deterministic next state
    logic next_state;
    always @(*) begin
        case ({current_state, a, b})
            IDLE: next_state = (a == 1 && b == 0) ? SET_Q : IDLE;
            SET_Q: next_state = IDLE;
            default: next_state = IDLE;
        endcase
    end

    // Deterministic Q output
    logic q_value;
    always @(*) begin
        case (current_state)
            IDLE: q_value = 0;
            SET_Q: q_value = 1;
            default: q_value = 0;
        endcase
    end

    // Assign outputs
    assign q = q_value;
    assign state = current_state;

endmodule
