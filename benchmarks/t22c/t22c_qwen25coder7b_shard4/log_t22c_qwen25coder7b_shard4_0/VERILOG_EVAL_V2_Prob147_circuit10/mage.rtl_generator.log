[2026-05-14 11:53:25,309 - mage.rtl_generator - INFO] RTL code: module TopModule (
    input  logic clk,
    input  logic a,
    input  logic b,
    output logic q,
    output logic state
);

    // State enum
    localparam IDLE = 2'b00;
    localparam ONE_DETECTED = 2'b01;
    localparam TWO_CONSECUTIVE_ONES = 2'b10;

    // State register
    logic [1:0] state_reg;
    logic [1:0] state_next;

    // Sequential logic
    always @(posedge clk) begin
        if (reset)
            state_reg <= IDLE;
        else
            state_reg <= state_next;
    end

    // Next state combinational logic
    always @(*) begin
        state_next = IDLE;
        case (state_reg)
            IDLE: begin
                if (a && b)
                    state_next = ONE_DETECTED;
            end
            ONE_DETECTED: begin
                if (b)
                    state_next = TWO_CONSECUTIVE_ONES;
                else
                    state_next = IDLE;
            end
            TWO_CONSECUTIVE_ONES: begin
                state_next = IDLE;
            end
        endcase
    end

    // Output combinational logic
    always @(*) begin
        q = 1'b0;
        state = state_reg;
        case (state_reg)
            IDLE: begin
                state = 2'b00;
            end
            ONE_DETECTED: begin
                state = 2'b01;
            end
            TWO_CONSECUTIVE_ONES: begin
                state = 2'b10;
                q = 1'b1;
            end
        endcase
    end

endmodule
