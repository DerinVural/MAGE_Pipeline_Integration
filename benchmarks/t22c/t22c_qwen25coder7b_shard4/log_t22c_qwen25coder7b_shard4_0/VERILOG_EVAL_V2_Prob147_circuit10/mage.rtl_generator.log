[2026-05-14 11:53:45,676 - mage.rtl_generator - INFO] RTL code: module TopModule (
    input logic clk,
    input logic a,
    input logic b,
    output logic q,
    output logic state
);

    // Register to store the previous value of 'a'
    logic prev_a;
    always_ff @(posedge clk) begin
        prev_a <= a;
    end

    // Combinational logic to decide whether to toggle the flip-flop
    logic toggle;
    always_comb begin
toggle = (prev_a && b);
    end

    // Flip-flop to store the state
    logic ff;
    always_ff @(posedge clk) begin
        if (toggle)
ff <= ~ff;
    end

    // Assignments to 'q' and 'state'
    assign q = ff;
    assign state = ff;

endmodule
