                if (a && b) begin
                    next_state = COUNTING;
                    count = 2'b00;
                end
            COUNTING:
                if (a || b) begin
                    next_state = IDLE;
                end else begin
                    count += 1;
                    if (count == 2'b10) begin
                        q = 1'b1;
                        next_state = WAITING;
                    end
                end
            WAITING:
                if (a || b) begin
                    next_state = IDLE;
                end
        endcase
    end

endmodule
