                    if (b) begin
                        current_state <= WAITING_FOR_ONE;
                    end
                WAITING_FOR_ONE:
                    if (b) begin
                        current_state <= RECEIVED_ONE;
                    end
                RECEIVED_ONE:
                    // Stay in this state indefinitely
                    ;
                default:
                    current_state <= IDLE;
            endcase
        end
    end

    // Combinational logic to set the outputs based on the current state
    always_comb begin
        q = 0;
        state = IDLE;

        case (current_state)
            IDLE:
                q = 0;
                state = IDLE;
            WAITING_FOR_ONE:
                q = 0;
                state = WAITING_FOR_ONE;
            RECEIVED_ONE:
                q = 1;
                state = RECEIVED_ONE;
            default:
                q = 0;
                state = IDLE;
        endcase
    end

endmodule
