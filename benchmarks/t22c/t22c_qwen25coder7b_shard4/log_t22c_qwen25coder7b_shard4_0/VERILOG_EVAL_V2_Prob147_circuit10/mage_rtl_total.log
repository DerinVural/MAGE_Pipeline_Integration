		q_reg = 0;
	end

	// Sequential logic
	always_ff @(posedge clk or posedge reset) begin
		if (reset)
			q_reg <= 0;
		else
			q_reg <= a && !b;
	end

	// Combinational logic to output the current state
	always @(*) begin
		state = q_reg;
	end

	// Connect the flip-flop to the output
	assign q = q_reg;

endmodule

module RefModule(
	input logic clk,
	input logic a,
	input logic b,
	output logic q,
	output logic state
);
	// This is just a dummy implementation for demonstration purposes
	assign q = a && !b;
	assign state = 1'b0;
endmodule

module tb();
	logic clk;
	logic reset;
	logic a;
	logic b;
	logic q_ref;
	logic q_dut;
	logic state_ref;
	logic state_dut;

	// Clock generation
	initial begin
		clk = 0;
		forever #(5) clk = ~clk;
	end

	// Reference model instantiation
	RefModule ref_model (
		.clk(clk),
		.a(a),
		.b(b),
		.q(q_ref),
		.state(state_ref)
	);

	// DUT instantiation
	TopModule dut (
		.clk(clk),
		.reset(reset),
		.a(a),
		.b(b),
		.q(q_dut),
		.state(state_dut)
	);

	// Simulation control
	initial begin
		// Initial conditions
		reset = 1;
		#10 reset = 0;

		// Test sequence
		for (int i = 0; i < 10; i++) begin
			#10 a = i[0];
			#10 b = i[1];
		end

		#100 $finish;
	end

	// Comparison logic
	wire tb_match;
	assign tb_match = (q_ref == q_dut && state_ref == state_dut);

	// Statistics collection
	integer errors;
	integer errors_q;
	integer errors_state;
	integer clocks;

	initial begin
		errors = 0;
		errors_q = 0;
		errors_state = 0;
		clocks = 0;

