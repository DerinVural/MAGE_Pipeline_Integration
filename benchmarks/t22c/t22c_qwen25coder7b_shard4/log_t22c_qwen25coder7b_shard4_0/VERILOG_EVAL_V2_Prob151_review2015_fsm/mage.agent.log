		.data(data),
		.done_counting(done_counting),
		.ack(ack ),
		.shift_ena(shift_ena_dut),
		.counting(counting_dut),
		.done(done_dut) );
		
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
			strobe <= !strobe; 
			@(strobe);
