);
	bit failed = 0;
	
	always @(posedge clk, negedge clk)
		if (!tb_match) 
			failed <= 1;
	
	initial begin
			@(posedge clk);
			failed <= 0;
			reset <= 1;
			data <= 0;
			done_counting <= 1'bx;
			ack <= 1'bx;
			@(posedge clk) 
