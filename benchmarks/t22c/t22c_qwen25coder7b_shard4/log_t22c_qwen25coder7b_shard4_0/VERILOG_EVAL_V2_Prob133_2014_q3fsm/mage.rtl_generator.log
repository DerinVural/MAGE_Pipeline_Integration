    // Define states
    localparam A = 2'b00;
    localparam B = 2'b01;
    localparam CHECK_W = 2'b10;
    localparam SET_Z = 2'b11;

    // State register
    logic [1:0] state;
    logic [1:0] state_next;
    logic [2:0] w_count;

    // Initialize state register
    initial begin
        state = A;
        w_count = 3'b000;
    end

    // Sequential logic
    always @(posedge clk or posedge reset) begin
        if (reset) begin
            state <= A;
            w_count <= 3'b000;
        end else begin
            state <= state_next;
            w_count <= (state == CHECK_W) ? (w_count + 1) : 3'b000;
        end
    end

    // Next state logic
    always @(*) begin
        state_next = state;
        case (state)
            A: begin
                if (s) state_next = B;
            end
            B: begin
                if (w_count == 2) state_next = SET_Z;
            end
            SET_Z: state_next = A;
        endcase
    end

    // Output logic
    always @(*) begin
        z = (state == SET_Z) ? 1'b1 : 1'b0;
    end

endmodule
