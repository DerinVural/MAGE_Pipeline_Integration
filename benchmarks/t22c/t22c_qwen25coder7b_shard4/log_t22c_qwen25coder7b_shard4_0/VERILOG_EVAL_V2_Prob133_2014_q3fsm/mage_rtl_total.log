                    state_next = STATE_Z_SET;
                else
                    state_next = STATE_A;
            STATE_Z_SET:
                state_next = STATE_A;
        endcase
    end

    // Output Assignment
    always @(*) begin
        z = 1'b0;
        if (state == STATE_Z_SET)
            z = 1'b1;
    end

endmodule;
