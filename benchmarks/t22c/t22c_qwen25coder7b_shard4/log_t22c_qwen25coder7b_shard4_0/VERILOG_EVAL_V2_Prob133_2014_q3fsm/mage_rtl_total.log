    initial begin
        state = STATE_A;
        count_w_one = 2'b00;
    end

    // Sequential Logic
    always_ff @(posedge clk or posedge reset) begin
        if (reset) begin
            state <= STATE_A;
            count_w_one <= 2'b00;
        end else begin
            state <= state_next;
            count_w_one <= count_w_one_next;
        end
    end

    // Next State Determination
    always @(*) begin
        state_next = state;
        count_w_one_next = count_w_one;

        case(state)
            STATE_A:
                if (s)
                    state_next = STATE_B;
            STATE_B:
                if (w)
