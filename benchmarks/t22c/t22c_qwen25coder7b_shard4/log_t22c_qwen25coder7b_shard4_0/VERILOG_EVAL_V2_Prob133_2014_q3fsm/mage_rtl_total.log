    // State definition
    localparam IDLE = 2'b00;
    localparam COUNT = 2'b01;
    localparam CHECK = 2'b10;

    // State variables
    logic [1:0] state;
    logic [1:0] next_state;

    // Counter to track consecutive ones
    logic [1:0] count;

    // Initialize state and count
    always_ff @(posedge clk or posedge reset) begin
        if (reset) begin
            state <= IDLE;
            count <= 2'b00;
        end else begin
            state <= next_state;
            count <= (state == COUNT) ? count + 1 : count;
        end
    end

    // Next state logic
    always @(*) begin
        next_state = state;
        case(state)
            IDLE: begin
                if (s) begin
                    next_state = COUNT;
                    count <= 2'b00;
                end
            end
            COUNT: begin
                if (w) begin
                    next_state = CHECK;
                end else begin
                    next_state = IDLE;
                end
            end
            CHECK: begin
                if (count == 2'b01) begin
                    next_state = IDLE;
                end else begin
                    next_state = COUNT;
                end
            end
        endcase
    end

    // Output logic
    always_comb begin
        z = 1'b0;
        if (count == 2'b01) begin
            z = 1'b1;
        end
    end

endmodule
