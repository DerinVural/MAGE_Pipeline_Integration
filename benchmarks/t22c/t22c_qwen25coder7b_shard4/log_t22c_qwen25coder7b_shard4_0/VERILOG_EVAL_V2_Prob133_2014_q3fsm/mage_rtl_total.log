[2026-05-14 11:29:25,670 - mage.rtl_editor - INFO] module TopModule (
    input logic clk,
    input logic reset,
    input logic s,
    input logic w,
    output logic z
);

    // Define states
    localparam STATE_A = 2'b00;
    localparam STATE_B = 2'b01;
    localparam STATE_CHECK = 2'b10;
    localparam STATE_Z_SET = 2'b11;

    // State Register
    logic [1:0] state;
    logic [1:0] state_next;

    // Counter for w = 1 occurrences
    logic [1:0] count_w_one;
    logic [1:0] count_w_one_next;

    // Initialize state and counter
    initial begin
        state = STATE_A;
        count_w_one = 2'b00;
    end

    // Sequential Logic
    always_ff @(posedge clk or posedge reset) begin
        if (reset) begin
            state <= STATE_A;
            count_w_one <= 2'b00;
        end else begin
            state <= state_next;
            count_w_one <= count_w_one_next;
        end
    end

    // Next State Determination
    always @(*) begin
        state_next = state;
        count_w_one_next = count_w_one;

        case(state)
            STATE_A:
                if (s)
                    state_next = STATE_B;
            STATE_B:
                if (w)
                    count_w_one_next = count_w_one + 1;
            STATE_CHECK:
                if (count_w_one == 2'b10)
                    state_next = STATE_Z_SET;
                else
                    state_next = STATE_A;
            STATE_Z_SET:
                state_next = STATE_A;
        endcase
    end

    // Output Assignment
    always @(*) begin
        z = 1'b0;
        if (state == STATE_Z_SET)
            z = 1'b1;
    end

endmodule;
