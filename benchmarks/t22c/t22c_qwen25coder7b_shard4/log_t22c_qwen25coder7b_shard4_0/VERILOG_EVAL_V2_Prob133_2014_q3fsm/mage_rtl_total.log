// Define states using localparams
localparam STATE_A = 2'b00;
localparam STATE_B = 2'b01;
localparam STATE_C = 2'b10;

// State Register
logic [1:0] state;

// Initialize the state register to state A
initial begin
    state = STATE_A;
end

// Clock Edge always block
always @(posedge clk) begin
    if (reset)
        state <= STATE_A;
    else begin
        case(state)
            STATE_A: state <= (s) ? STATE_B : STATE_A;
            STATE_B: state <= (w) ? STATE_C : STATE_A;
            STATE_C: state <= (w) ? STATE_C : STATE_A;
            default: state <= STATE_A;
        endcase
    end
end

// Output Logic
localparam Z_ENABLE = 2'b01;
localparam Z_DISABLE = 2'b00;

logic [1:0] z_state;

initial begin
    z_state = Z_DISABLE;
end

always @(*) begin
    z_state = Z_DISABLE;
    case(state)
        STATE_A: if (w) z_state = Z_ENABLE;
        STATE_B: if (w) z_state = Z_ENABLE;
        STATE_C: z_state = Z_DISABLE;
    endcase
end

assign z = (z_state == Z_ENABLE);

endmodule
