module stimulus_gen (
  input clk,
  output logic reset,
  output logic s, w,
  input tb_match
);
  bit spulse_fail = 0;
  bit failed = 0;
  always @(posedge clk, negedge clk)
    if (!tb_match) failed = 1;
  initial begin
    reset <= 1;
    s <= 0;
    w <= 0;
    @(posedge clk);
    @(posedge clk);
    reset <= 0;
    @(posedge clk);
    @(posedge clk);
    s <= 1;
    repeat(200) @(posedge clk, negedge clk) begin
      w <= $random;
    end
    reset <= 1;
    @(posedge clk);
    reset <= 0;
    @(posedge clk);
    @(posedge clk);
    repeat(200) @(posedge clk, negedge clk) begin
      w <= $random;
    end
