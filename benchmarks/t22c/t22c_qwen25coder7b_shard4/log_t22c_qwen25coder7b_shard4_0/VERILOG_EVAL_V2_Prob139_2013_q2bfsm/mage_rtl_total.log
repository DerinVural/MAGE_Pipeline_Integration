  stats stats1;
  wire[511:0] wavedrom_title;
  wire wavedrom_enable;
  int wavedrom_hide_after_time;

  reg clk = 0;
  initial forever
    #5 clk = ~clk;

  logic resetn;
  logic x;
  logic y;
  logic f_ref;
  logic f_dut;
  logic g_ref;
  logic g_dut;

  initial begin 
