			reset <= 0;
			@(posedge clk) data <= 0;
			@(posedge clk) data <= 0;
			@(posedge clk) data <= 1;
			@(posedge clk) data <= 1;
			@(posedge clk) data <= 0;
			@(posedge clk) data <= 1;
			@(posedge clk) data <= 0;
			@(posedge clk) data <= 0;
