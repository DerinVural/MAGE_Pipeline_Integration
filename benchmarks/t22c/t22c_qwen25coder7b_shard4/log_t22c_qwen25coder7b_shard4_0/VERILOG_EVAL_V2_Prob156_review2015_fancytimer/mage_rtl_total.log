    initial forever
        #5 clk = ~clk;

    logic reset;
    logic data;
    logic ack;
    logic [3:0] count_ref;
    logic [3:0] count_dut;
    logic counting_ref;
    logic counting_dut;
    logic done_ref;
    logic done_dut;

