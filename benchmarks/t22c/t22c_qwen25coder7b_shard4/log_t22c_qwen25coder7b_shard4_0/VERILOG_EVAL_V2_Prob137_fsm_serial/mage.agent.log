reg clk = 0;
initial forever
	#5 clk = ~clk;

logic in;
logic reset;
logic done_ref;
logic done_dut;

initial begin 
	$dumpfile("wave.vcd");
	$dumpvars(1, stim1.clk, tb_mismatch ,clk,in,reset,done_ref,done_dut );
end

signal tb_match;
