component stimulus_gen stim1 (
	.clock(clk),
	.out(in),
	.reset(reset)
);
component RefModule good1 (
	.clock(clk),
	.data_in(in),
	.reset(reset),
	.done(done_ref)
);
component TopModule top_module1 (
	.clock(clk),
	.data_in(in),
	.reset(reset),
	.done(done_dut)
);

