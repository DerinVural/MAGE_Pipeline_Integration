[2026-05-14 11:05:08,384 - mage.agent - INFO] Initial rtl:
[2026-05-14 11:05:08,384 - mage.agent - INFO] module TopModule (
	input do_sub,
	input [7:0] a,
	input [7:0] b,
	output logic [7:0] out,
	output logic result_is_zero
);

genvar i;

reg [7:0] out_reg;
reg zero_flag_reg;

initial begin
	out_reg = 8'b0;
	zero_flag_reg = 1'b0;
end

always @(*) begin
	out = 8'b0;
	zero_flag_reg = 1'b1;
	case(do_sub)
		0: begin
			out = a + b;
			if (out == 8'b0) zero_flag_reg = 1'b0;
		end
		1: begin
			out = a - b;
			if (out == 8'b0) zero_flag_reg = 1'b0;
		end
	endcase
end

assign result_is_zero = zero_flag_reg;

endmodule
