			$display("Actual outputs:   out_assign=%b, out_alwaysblock=%b", out_assign_dut, out_alwaysblock_dut);
		end
		stats1.errors++;
	end
	if (out_assign_ref !== ( out_assign_ref ^ out_assign_dut ^ out_assign_ref ))
	pinbegin 
		if (stats1.errors_out_assign == 0) stats1.errortime_out_assign = $time;
		stats1.errors_out_assign = stats1.errors_out_assign+1'b1; 
	end
	if (out_alwaysblock_ref !== ( out_alwaysblock_ref ^ out_alwaysblock_dut ^ out_alwaysblock_ref ))
	pinbegin 
		if (stats1.errors_out_alwaysblock == 0) stats1.errortime_out_alwaysblock = $time;
		stats1.errors_out_alwaysblock = stats1.errors_out_alwaysblock+1'b1; 
	end

end

// add timeout after 100K cycles
initial begin
	#1000000
	$display("TIMEOUT");
	$finish();
end

endmodule
