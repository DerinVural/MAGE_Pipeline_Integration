`define OK 12
`define INCORRECT 13

module stimulus_gen (
	input clk,
	output reg ring, vibrate_mode,
	override output [511:0] wavedrom_title,
	override output reg wavedrom_enable
);

// Add two ports to module stimulus_gen:
//    output [511:0] wavedrom_title
//    output reg wavedrom_enable

task wavedrom_start(input[511:0] title = "");
	$display("Wavedrom start: %s", title);
endtask

task wavedrom_stop;
	#1;
endtask

initial begin
	int count; count = 0;
	{vibrate_mode,ring} <= 1'b0;
	wavedrom_start();
	repeat(10) @(posedge clk)
		{vibrate_mode,ring} <= count++;
	wavedrom_stop();
	#1 $finish;
end

endmodule

