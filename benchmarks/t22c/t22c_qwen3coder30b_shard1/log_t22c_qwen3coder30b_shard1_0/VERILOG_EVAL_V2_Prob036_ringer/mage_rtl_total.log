		repeat(5) begin
			strobe <= !strobe;  // Try to delay until the very end of the time step.
			@(strobe);
		end
	endtask

	// Queue for storing last few cycles data for mismatch display
	reg ring_queue [$];
	reg vibrate_mode_queue [$];
