    input ring,
    input vibrate_mode,
    output ringer,
    output motor
);

    // Combinational logic to control ringer and motor
    always @(*) begin
        if (vibrate_mode)
            motor = 1'b1;
        else
            motor = 1'b0;
        
        if (vibrate_mode)
            ringer = 1'b0;
        else
            ringer = ring;
    end

endmodule
