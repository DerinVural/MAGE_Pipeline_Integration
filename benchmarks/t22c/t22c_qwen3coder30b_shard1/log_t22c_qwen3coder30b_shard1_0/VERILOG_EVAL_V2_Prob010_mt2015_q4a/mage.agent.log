			stats1.errors++;
		end
		if (z_ref !== ( z_ref ^ z_dut ^ z_ref ))
		pbegin 
			if (stats1.errors_z == 0) stats1.errortime_z = $time;
			stats1.errors_z = stats1.errors_z+1'b1; 
		end

		// Display first mismatch details
		if (stats1.errors_z == 1) begin
			$display("First mismatch details:");
			$display("Input x = %b, Input y = %b", x, y);
			$display("Expected output z_ref = %b, Got output z_dut = %b", z_ref, z_dut);
		end

	end

   // add timeout after 100K cycles
   initial begin
     #1000000
     $display("TIMEOUT");
     $finish();
   end

endmodule
