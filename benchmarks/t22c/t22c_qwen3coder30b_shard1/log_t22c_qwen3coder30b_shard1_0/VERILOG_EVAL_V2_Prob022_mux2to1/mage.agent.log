task wavedrom_stop;
	#1;
endtask	


initial begin
	{a, b, sel} <= 3'b000;
	@(negedge clk) wavedrom_start("<b>Sel</b> chooses between <b>a</b> and <b>b</b>");
		@(posedge clk) {a, b, sel} <= 3'b000;
		@(posedge clk) {a, b, sel} <= 3'b100;
		@(posedge clk) {a, b, sel} <= 3'b110;
