		@(posedge clk) {a, b, sel} <= 3'b110;
		@(posedge clk) {a, b, sel} <= 3'b111;
	@(negedge clk) wavedrom_stop();
	repeat(100) @(posedge clk, negedge clk)
		{a,b,sel} <= $random;
	$finish;
end

