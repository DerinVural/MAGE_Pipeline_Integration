			stats1.errors_out = stats1.errors_out+1'b1; end

	end

	// Add display for the first mismatch
	always @(negedge clk) begin
		if (stats1.errors == 1) begin
			$display("First mismatch detected at time %0d:", $time);
			$display("  in = %h (%b)", in, in);
			$display("  sel = %h", sel);
			$display("  out_ref = %b", out_ref);
			$display("  out_dut = %b", out_dut);
		end
	end

	// add timeout after 100K cycles
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

endmodule
