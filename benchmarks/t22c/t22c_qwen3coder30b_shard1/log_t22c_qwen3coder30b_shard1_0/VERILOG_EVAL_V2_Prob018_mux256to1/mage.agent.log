`define OK 12
`define INCORRECT 13

module stimulus_gen (
	input clk,
	override output logic [255:0] in,
	override output logic [7:0] sel
);

	always @(posedge clk, negedge clk) begin
		for (int i=0;i<8; i++)
			in[i*32+:32] <= $random;
		sel <= $random;
	end
	
	initial begin
		repeat(1000) @(negedge clk);
		$finish;
	end
	
endmodule

