b0, in[0]|in[1], in[1]|in[2], in[2]|in[3]};\n    \n    // (3) out_different: in[i] XOR in[i+1] (wrapping for i=3)\n    // out_different[2] should indicate if in[2] is different from in[3].\n    assign out_different = {in[0]!==in[1], in[1]!==in[2], in[2]!==in[3], in[3]!==in[0]};\n\nendmodule\n\n// --- Top Module Under Test (DUT) ---\nmodule TopModule (\n    input logic [3:0] in,\n    output logic [3:0] out_both,\n    output logic [3:0] out_any,\n    output logic [3:0] out_different\n);\n    // Placeholder for the DUT implementation\n    // Since we must test it, we assume it\'s combinational and implement the logic here for verification purposes.\n\n    // (1) out_both: in[i] AND in[i+1] (i+1 is left/higher index)\n    assign out_both = {1\'b0, in[3]&in[2], in[2]&in[1], in[1]&in[0]};\n\n    // (2) out_any: in[i] OR in[i-1] (i-1 is right/lower index)\n    assign out_any = {1\'b0, in[0]|in[1], in[1]|in[2], in[2]|in[3]};\n    \n    // (3) out_different: in[i] XOR in[i+1] (wrapping for i=3)\n    assign out_different = {in[0]!==in[1], in[1]!==in[2], in[2]!==in[3], in[3]!==in[0]};\n\nendmodule\n\n// ========================================================================\n// TESTBENCH\n// ========================================================================\nmodule tb();\n\n\t// --- Statistics Struct (Kept original) ---\n\ttypedef struct packed {\n\t\tint errors;\n\t\tint errortime;\n\t\tint errors_out_both;\n\t\tint errortime_out_both;\n\t\tint errors_out_any;\n\t\tint errortime_out_any;\n\t\tint errors_out_different;\n\t\tint errortime_out_different;\n\t\tint clocks;\n\t} stats;\n\t\n\tstats stats1;\n\t\n\t// --- Signal Declarations ---\n\twire[511:0] wavedrom_title;\n\twire wavedrom_enable;\n\tint wavedrom_hide_after_time;\n\t\n\treg clk=0;\n\t\n\t// Signals for DUT Inputs/Outputs\n\tlogic [3:0] in;\n\tlogic [3:0] out_both_ref;\n\tlogic [3:0] out_both_dut;\n\tlogic [3:0] out_any_ref;\n\tlogic [3:0] out_any_dut;\n\tlogic [3:0] out_different_ref;\n\tlogic [3:0] out_different_dut;\n\n\t// Verification Signals\n\twire tb_match;\n\twire tb_mismatch = ~tb_match;\n\n\t// --- Waveform Dumping ---\n\tinitial begin \n\t\t$dumpfile("wave.vcd");\n\t\t$dumpvars(1, stim1.clk, tb_mismatch ,in,out_both_ref,out_both_dut,out_any_ref,out_any_dut,out_different_ref,out_different_dut );\n\tend\n\n\t// --- Clock Generation ---\n\tinitial forever\n\t\t#5 clk = ~clk;\n\n\t// --- Queue Setup for Mismatch Logging (Rule 1) ---\n\t// Since the system is clocked, we use the queue approach.\n\t// Max queue size set conservatively, but small enough for log control.\n\tlocalparam MAX_QUEUE_SIZE = 10;\n\t\n\treg [3:0] input_queue [MAX_QUEUE_SIZE-1:0];\n\treg [3:0] got_output_queue [MAX_QUEUE_SIZE-1:0];\n\treg [3:0] golden_queue [MAX_QUEUE_SIZE-1:0];\n\treg [3:0] ref_output_queue [MAX_QUEUE_SIZE-1:0];\n\tint queue_index = 0;\n\n\t// --- Task to check and log mismatch ---\n\ttask check_and_log_mismatch;\n\t\tbegin\n\t\t\tif (stats1.errors == 0) begin\n\t\t\tstats1.errortime = $time;\n\t\t\tend\n\t\tstats1.errors++;\n\t\t\n\t\t\t$display("====================================================================");\n\t\t\t$display("!!! FIRST MISMATCH DETECTED AT TIME %0t !!!", $time);\n\t\t\t$display("====================================================================");\n\t\t\t$display("Displaying last %0d cycles leading to the first error:", MAX_QUEUE_SIZE);\n\t\t\t\n\t\t\tfor (int i = 0; i < MAX_QUEUE_SIZE; i++) begin\n\t\t\t\t$display("Cycle %0d (Time %0t): Input=%h, Ref_Out=%h, DUT_Out=%h",\n\t\t\t\t\t i, $time - (MAX_QUEUE_SIZE - 1 - i)*10, input_queue[i], ref_output_queue[i], got_output_queue[i]);\n\t\t\tend\n\t\t\tend\n\tendtask\n\n\t// --- DUT Instantiations ---\n\tstimulus_gen stim1 (\n\t\t.clk,\n\t\t.tb_match,\n\t\tin,\n\t\twavedrom_title,\n\t\twavedrom_enable\n\t);\n\t\n\tRefModule good1 (\n\t\t.in,\n\t\tout_both(out_both_ref),\n\t\tout_any(out_any_ref),\n\t\tout_different(out_different_ref) );\n\t\n\tTopModule top_module1 (\n\t\t.in,\n\t\tout_both(out_both_dut),\n\t\tout_any(out_any_dut),\n\t\tout_different(out_different_dut) );\n\n\t// --- Wait Task (Kept original) ---\n\tbit strobe = 0;\n\ttask wait_for_end_of_timestep;\n\t\trepeat(5) begin\n\t\t\tstrobe <= !strobe;  // Try to delay until the very end of the time step.\n\t\t\t@(strobe);\n\t\tend\n\tendtask\n\n\t// --- Clocked Sampling and Verification Logic ---\n\talways @(posedge clk, negedge clk) begin\n\t\t// Shift queue content\n\t\tif (queue_index == MAX_QUEUE_SIZE - 1) begin\n\t\t\t// Shift everything down by one, effectively dropping the oldest sample\n\t\t\tfor (int i = 0; i < MAX_QUEUE_SIZE - 1; i) begin\n\t\t\t\tinput_queue[i] = input_queue[i+1];\n\t\t\t\tgot_output_queue[i] = got_output_queue[i+1];\n\t\t\t\tgolden_queue[i] = golden_queue[i+1];\n\t\t\t\tref_output_queue[i] = ref_output_queue[i+1];\n\t\t\tend\n\t\t\tend\n\t\t\n\t\t// Store current values\n\t\tinput_queue[queue_index] = in;\n\t\tgot_output_queue[queue_index] = {out_both_dut, out_any_dut, out_different_dut};\n\t\tgolden_queue[queue_index] = {out_both_ref, out_any_ref, out_different_ref};\n\t\tref_output_queue[queue_index] = {out_both_ref, out_any_ref, out_different_ref};\n\t\tqueue_index = (queue_index + 1) % MAX_QUEUE_SIZE;\n\n\t\t// Check for mismatch based on golden logic\n\t\t// Replicate the comparison logic: (Ref == (Ref ^ DUT ^ Ref)) which simplifies to (Ref == DUT)\n\t\tlogic [3:0] ref_combined = {out_both_ref, out_any_ref, out_different_ref};\n\t\tlogic [3:0] dut_combined = {out_both_dut, out_any_dut, out_different_dut};\n\t\t\n\t\t// Simplified match condition derived from golden testbench logic:\n\t\t// tb_match = ( { out_both_ref, out_any_ref, out_different_ref } === ( { out_both_ref, out_any_ref, out_different_ref } ^ { out_both_dut, out_any_dut, out_different_dut } ^ { out_both_ref, out_any_ref, out_different_ref } ) );\n\t\t// Since X^Y^X = Y, this simplifies to: tb_match = (Ref === DUT);\n\t\t\n\t\tif (ref_combined !== dut_combined) begin\n\t\t\t// Mismatch detected\n\t\t\tch