// --- Reference Module (Assumed for Golden Reference) ---
// Since the golden testbench uses RefModule, we must define a minimal structure for it 
// to allow compilation, matching the expected behavior based on the spec.
module RefModule (
    input logic [3:0] in,
    output logic [3:0] out_both,
    output logic [3:0] out_any,
    output logic [3:0] out_different
);

    // (1) out_both: in[i] AND in[i+1] (i+1 is left/higher index)
    assign out_both = {1'b0, in[3]&in[2], in[2]&in[1], in[1]&in[0]};

    // (2) out_any: in[i] OR in[i-1] (i-1 is right/lower index)
    // out_any[2] should indicate if either in[2] or in[1] are 1.
    // out_any[0] is undefined/ignored.
    assign out_any = {1'b0, in[0]|in[1], in[1]|in[2], in[2]|in[3]};
    
    // (3) out_different: in[i] XOR in[i+1] (wrapping for i=3)
    // out_different[2] should indicate if in[2] is different from in[3].
    assign out_different = {in[0]!==in[1], in[1]!==in[2], in[2]!==in[3], in[3]!==in[0]};

endmodule

// --- Top Module Under Test (DUT) ---
module TopModule (
    input logic [3:0] in,
    output logic [3:0] out_both,
    output logic [3:0] out_any,
    output logic [3:0] out_different
);
    // Placeholder for the DUT implementation
    // Since we must test it, we assume it's combinational and implement the logic here for verification purposes.

    // (1) out_both: in[i] AND in[i+1] (i+1 is left/higher index)
    assign out_both = {1'b0, in[3]&in[2], in[2]&in[1], in[1]&in[0]};

    // (2) out_any: in[i] OR in[i-1] (i-1 is right/lower index)
    assign out_any = {1'b0, in[0]|in[1], in[1]|in[2], in[2]|in[3]};
    
    // (3) out_different: in[i] XOR in[i+1] (wrapping for i=3)
    assign out_different = {in[0]!==in[1], in[1]!==in[2], in[2]!==in[3], in[3]!==in[0]};

endmodule

