_time == $time && (out_ref !== ( out_ref ^ out_dut ^ out_ref ))) begin\n\t\t\tdisplay_signals($time);\n\t\t\tfirst_output_mismatch_time = -2; // Mark as displayed\n\t\tend\n\tend\n\n   // add timeout after 100K cycles\n   initial begin\n     #1000000\n     $display(\"TIMEOUT\");\n     $finish();\n   end\n\tendmodule"
