    "testbench": "`timescale 1 ps/1 ps\n`define OK 12\n`define INCORRECT 13\n\n\n// --- Stimulus Generator (Kept as is) ---\nmodule stimulus_gen (\n\tinput clk,\n\toutput logic [15:0] a,b,c,d,e,f,g,h,i,\n\toutput logic [3:0] sel,\n\toutput reg[511:0] wavedrom_title,\n\toutput reg wavedrom_enable\n);\n\n\ttask wavedrom_start(input[511:0] title = \"\");\n\tendtask\n\t\n\ttask wavedrom_stop;\n\t\t#1;\n\tendtask\n\t\t\n\tinitial begin\n\t\t{a,b,c,d,e,f,g,h,i,sel} <= { 16'ha, 16'hb, 16'hc, 16'hd, 16'he, 16'hf, 16'h11, 16'h12, 16'h13, 4'h0 };\n\t\t@(negedge clk) wavedrom_start();\n\t\t\t@(posedge clk) sel <= 4'h1;\n\t\t\t@(posedge clk) sel <= 4'h2;\n\t\t\t@(posedge clk) sel <= 4'h3;\n\t\t\t@(posedge clk) sel <= 4'h4;\n\t\t\t@(posedge clk) sel <= 4'h7;\n\t\t\t@(posedge clk) sel <= 4'h8;\n\t\t\t@(posedge clk) sel <= 4'h9;\n\t\t\t@(posedge clk) sel <= 4'ha;\n\t\t\t@(posedge clk) sel <= 4'hb;\n\t\t@(negedge clk) wavedrom_stop();\n\t\t\t\n\t\trepeat(200) @(negedge clk, posedge clk) begin\n\t\t\t{a,b,c,d,e,f,g,h,i,sel} <= {$random, $random, $random, $random, $random};\n\t\tend\n\t\t$finish;\n\tend\n\t\nendmodule\n\n// --- Reference Module (Assumed to exist for comparison) ---\nmodule RefModule (\n    input  [15:0] a,\n    input  [15:0] b,\n    input  [15:0] c,\n    input  [15:0] d,\n    input  [15:0] e,\n    input  [15:0] f,\n    input  [15:0] g,\n    input  [15:0] h,\n    input  [15:0] i,\n    input  [3:0] sel,\n    output [15:0] out\n);\n    // Placeholder implementation for golden reference\n    assign out = a; // Dummy logic\nendmodule\n\n// --- DUT (TopModule) ---\nmodule TopModule (\n    input  [15:0] a,\n    input  [15:0] b,\n    input  [15:0] c,\n    input  [15:0] d,\n    input  [15:0] e,\n    input  [15:0] f,\n    input  [15:0] g,\n    input  [15:0] h,\n    input  [15:0] i,\n    input  [3:0] sel,\n    output [15:0] out\n);\n    // 9-to-1 Multiplexer implementation\n    always_comb begin\n        case (sel) \n            4'h0: out = a;\n            4'h1: out = b;\n            4'h2: out = c;\n            4'h3: out = d;\n            4'h4: out = e;\n            4'h5: out = f;\n            4'h6: out = g;\n            4'h7: out = h;\n            4'h8: out = i;\n            4'h9: out = a; // Arbitrarily setting to 'a' for unused case demo, though logic implies '1'\n            default: out = 16'hFFFF; // Unused cases (sel=9 to 15) set all output bits to '1'\n        endcase\n    end\nendmodule\n\n// --- Testbench ---\nmodule tb();\n\n    // Stats structure to maintain original error counting logic\n    typedef struct packed {\n        int errors;\n        int errortime;\n        int errors_out;\n        int errortime_out;\n        int clocks;\n    } stats;\n    \n    stats stats1;\n    \n    // Signals from stimulus_gen\n    wire[511:0] wavedrom_title;\n    wire wavedrom_enable;\n    \n    reg clk = 0;\n    initial forever\n        #5 clk = ~clk;\n\n    // Inputs to DUT\n    logic [15:0] a_in;\n    logic [15:0] b_in;\n    logic [15:0] c_in;\n    logic [15:0] d_in;\n    logic [15:0] e_in;\n    logic [15:0] f_in;\n    logic [15:0] g_in;\n    logic [15:0] h_in;\n    logic [15:0] i_in;\n    logic [3:0] sel_in;\n\n    // Outputs\n    logic [15:0] out_ref;\n    logic [15:0] out_dut;\n\n    // Verification signals\n    wire tb_match;\n    wire tb_mismatch = ~tb_match;\n\n    // Variables to capture first mismatch data (Combinational requirement)\n    logic [15:0] first_mismatch_inputs_a, first_mismatch_inputs_b, first_mismatch_inputs_c, first_mismatch_inputs_d, first_mismatch_inputs_e, first_mismatch_inputs_f, first_mismatch_inputs_g, first_mismatch_inputs_h, first_mismatch_inputs_i;\n    logic [3:0] first_mismatch_sel;\n    logic [15:0] first_mismatch_out_ref;\n    logic [15:0] first_mismatch_out_dut;\n    integer first_mismatch_detected = 0;\n\n    // Task to display multi-bit values in HEX and BINARY\n    task display_hex_bin(input string name, input logic [15:0] value);\n        $display(\"%-20s: HEX = %h, BIN = %b\", name, value, value);\n    endtask\n\n    // Task to display all inputs and outputs at mismatch time\n    task display_mismatch_data;\n        $display(\"========================================================================\");\n        $display(\"!!! FIRST MISMATCH DETECTED AT TIME %0t ps !!!\", $time);\n        $display(\"--- INPUT SIGNALS ---\");\n        display_hex_bin(\"Input a\", first_mismatch_inputs_a);\n        display_hex_bin(\"Input b\", first_mismatch_inputs_b);\n        display_hex_bin(\"Input c\", first_mismatch_inputs_c);\n        display_hex_bin(\"Input d\", first_mismatch_inputs_d);\n        display_hex_bin(\"Input e\", first_mismatch_inputs_e);\n        display_hex_bin(\"Input f\", first_mismatch_inputs_f);\n        display_hex_bin(\"Input g\", first_mismatch_inputs_g);\n        display_hex_bin(\"Input h\", first_mismatch_inputs_h);\n        display_hex_bin(\"Input i\", first_mismatch_inputs_i);\n        $display(\"Input sel: %h\", first_mismatch_sel);\n        $display(\"--- OUTPUT SIGNALS ---\");\n        display_hex_bin(\"Expected Out (Ref)\", first_mismatch_out_ref);\n        display_hex_bin(\"Actual Out (DUT)\", first_mismatch_out_dut);\n        $display(\"========================================================================\");\n    endtask\n\n\n    // Initialization and Dumping\n    initial begin \n        $dumpfile(\"wave.vcd\");\n        $dumpvars(1, tb);\n    end\n\n    // Instantiate stimulus generator\n    stimulus_gen stim1 (\n        .clk(clk),\n        .a(a_in),\n        .b(b_in),\n        .c(c_in),\n        .d(d_in),\n        .e(e_in),\n        .f(f_in),\n        .g(g_in),\n        .h(h_in),\n        .i(i_in),\n        .sel(sel_in),\n        .wavedrom_title(),\n        .wavedrom_enable()\n    );\n\n    // Instantiate Reference Module\n    RefModule good1 (\n        .a(a_in),\n        .b(b_in),\n        .c(c_in),\n        .d(d_in),\n        .e(e_in),\n        .f(f_in),\n        .g(g_in),\n        .h(h_in),\n        .i(i_in),\n        .sel(sel_in),\n        .out(out_ref) \n    );\n        \n    // Instantiate DUT\n    TopModule top_module1 (\n        .a(a_in),\n        .b(b_in),\n        .c(c_in),\n        .d(d_in),\n        .e(e_in),\n        .f(f_in),\n        .g(g_in),\n        .h(h_in),\n        .i(i_in),\n        .sel(sel_in),\n        .out(out_dut) \n    );\n\n    // Original wait task (kept for functional compatibility)\n    bit strobe = 0;\n    task wait_for_end_of_timestep;\n        repeat(5) begin\n            strobe <= !strobe;  // Try to delay until the very end of the time step.\n            @(strobe);\n        end\n    endtask\n\n    // Verification Logic\n    // tb_match is true if outputs match (reference XORed with DUT XORed with reference = 0)\n    assign tb_match = ( { out_ref } === ( { out_ref } ^ { out_dut } ^ { out_ref } ) );\n\n    // Clocked comparison block (To maintain original timing logic)\n    always @(posedge clk, negedge clk) begin\n        stats1.clocks++;\n        \n        // Check for general mismatch (Original logic)\n        if (!tb_match) begin\n            if (stats1.errors == 0) stats1.errortime = $time;\n            stats1.errors++;\n        end\n\n        // Check for output specific mismatch (Original logic)\n        if (out_ref !== ( out_ref ^ out_dut ^ out_ref ))\n        begin \n            if (stats1.errors_out == 0) stats1.errortime_out = $time;\n            stats1.errors_out = stats1.errors_out + 1'b1;\n            \n            // *** IMPROVEMENT: Capture data on FIRST mismatch for combinational reporting ***\n            if (first_mismatch_detected == 0) begin\n                first_mismatch_detected = 1;\n                first_mismatch_inputs_a = a_in;\n                first_mismatch_inputs_b = b_in;\n                first_mismatch_inputs_c = c_in;\n                first_mismatch_inputs_d = d_in;\n                first_mismatch_inputs_e = e_in;\n                first_mismatch_inputs_f = f_in;\n                first_mismatch_inputs_g = g_in;\n                f