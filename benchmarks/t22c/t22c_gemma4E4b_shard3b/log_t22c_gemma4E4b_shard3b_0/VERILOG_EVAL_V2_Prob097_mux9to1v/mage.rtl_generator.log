y_hex_bin("Input c", first_mismatch_inputs_c);\n        display_hex_bin("Input d", first_mismatch_inputs_d);\n        display_hex_bin("Input e", first_mismatch_inputs_e);\n        display_hex_bin("Input f", first_mismatch_inputs_f);\n        display_hex_bin("Input g", first_mismatch_inputs_g);\n        display_hex_bin("Input h", first_mismatch_inputs_h);\n        display_hex_bin("Input i", first_mismatch_inputs_i);\n        $display("Input sel: %h", first_mismatch_sel);\n        $display("--- OUTPUT SIGNALS ---");\n        display_hex_bin("Expected Out (Ref)", first_mismatch_out_ref);\n        display_hex_bin("Actual Out (DUT)", first_mismatch_out_dut);\n        $display("========================================================================");\n    endtask\n\n\n    // Initialization and Dumping\n    initial begin \n        $dumpfile("wave.vcd");\n        $dumpvars(1, tb);\n    end\n\n    // Instantiate stimulus generator\n    stimulus_gen stim1 (\n        .clk(clk),\n        .a(a_in),\n        .b(b_in),\n        .c(c_in),\n        .d(d_in),\n        .e(e_in),\n        .f(f_in),\n        .g(g_in),\n        .h(h_in),\n        .i(i_in),\n        .sel(sel_in),\n        .wavedrom_title(),\n        .wavedrom_enable()\n    );\n\n    // Instantiate Reference Module\n    RefModule good1 (\n        .a(a_in),\n        .b(b_in),\n        .c(c_in),\n        .d(d_in),\n        .e(e_in),\n        .f(f_in),\n        .g(g_in),\n        .h(h_in),\n        .i(i_in),\n        .sel(sel_in),\n        .out(out_ref) \n    );\n        \n    // Instantiate DUT\n    TopModule top_module1 (\n        .a(a_in),\n        .b(b_in),\n        .c(c_in),\n        .d(d_in),\n        .e(e_in),\n        .f(f_in),\n        .g(g_in),\n        .h(h_in),\n        .i(i_in),\n        .sel(sel_in),\n        .out(out_dut) \n    );\n\n    // Original wait task (kept for functional compatibility)\n    bit strobe = 0;\n    task wait_for_end_of_timestep;\n        repeat(5) begin\n            strobe <= !strobe;  /