 // --- Testbench Module ---
 module tb();
 
 	typedef struct packed {
 		int errors;
 		int errortime;
 		int errors_out;
 		int errortime_out;
 		int clocks;
 	} stats;
 	
 	stats stats1;
 	
 	
 	wire[511:0] wavedrom_title;
 	wire wavedrom_enable;
 	int wavedrom_hide_after_time;
 	
 	reg clk=0;
 	initial forever
 		h#5 clk = ~clk;
 
