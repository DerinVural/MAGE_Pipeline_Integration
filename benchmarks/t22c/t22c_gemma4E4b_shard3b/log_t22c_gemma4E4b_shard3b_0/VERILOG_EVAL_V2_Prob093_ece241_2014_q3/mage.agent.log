// Implementation of TopModule based on K-map realization F_i(c, d) using 2-to-1 MUXes (functional equivalent)
module TopModule (
		input logic c,
		input logic d,
		output logic [3:0] mux_in
);
		// F0 = c AND ~d. Kmap entry: {0, 0, 0, 1} for AB=00
		// Interpreting F0 as a function of c, d based on the K-map values:
		// CD=00 (0): 0, CD=01 (1): 0, CD=11 (3): 0, CD=10 (2): 1
		// This logic seems to correspond to c & ~d if we map (c,d) to (d,c) or similar, matching the derived functions.
		// F0 = c AND ~d
		assign mux_in[0] = c & (~d);
		
		// F1 = ~c AND ~d
		assign mux_in[1] = (~c) & (~d);
		
		// F2 = c OR d
		assign mux_in[2] = c | d;
		
		// F3 = c XOR d
		assign mux_in[3] = c ^ d;

	endmodule


