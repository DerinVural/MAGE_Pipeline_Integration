	int total_errors = 0;
	int first_error_time = -1;
	int clocks = 0;

	// Signals
	reg clk = 0;
	logic c;
	logic d;
	logic [3:0] mux_in_ref;
	logic [3:0] mux_in_dut;

	// Verification status
	logic tb_match;
	logic tb_mismatch = ~tb_match;

	// Instantiate Stimulus Generator
	stimulus_gen stim1 (
		.clk, // Note: stimulus_gen doesn't use clk, but we connect it for consistency
		.c, // Original TB uses .* for c, d but stimulus_gen signature is modified to match
		.d, // We must adapt the instantiation based on the actual ports used in stimulus_gen's definition if it were fully consistent.
		.wavedrom_title,
		.wavedrom_enable
	);

	// Instantiate Reference Module		
	RefModule good1 (
		.c, // Connected to DUT inputs
		d, // Connected to DUT inputs
		mux_in(mux_in_ref)
	);

	// Instantiate DUT
	TopModule top_module1 (
		.c, // Connected to DUT inputs
		d, // Connected to DUT inputs
		mux_in(mux_in_dut)
	);

	// Clock generation
	initial forever
		h#5 clk = ~clk;

	// Initialization
	initial begin 
		dumpfile("wave.vcd");
		dumpvars(1, stim1.clk, tb_mismatch ,c,d,mux_in_ref,mux_in_dut );

		// Initial input setting before stimulus_gen takes over
		c = 0;
		d = 0;
		@(posedge clk);
		end

	// Task to wait for timestep stabilization (Retained from original TB structure)
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Assuming 'strobe' was meant to be a signal in the original TB, but since it's not defined, we simplify this wait mechanism.
		@(posedge clk);
		endtask

	// Task to handle error logging for combinational logic
	task log_mismatch;
		$display("\n==================================================================");
		$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", total_errors, first_error_time);
		$display("--- First Mismatch Details (Time %0d ps) ---", first_error_time);
		$display("Input Signals: c = %b, d = %b", c, d);
		$display("Reference Output (Golden): mux_in_ref = %h (%b)", mux_in_ref, mux_in_ref);
		$display("DUT Output: mux_in_dut = %h (%b)", mux_in_dut, mux_in_dut);
		$display("==================================================================\n");
	endtask

	// Main checking logic (Combinational Check)
	always @(*) begin
		// Check for mismatch
		if (mux_in_ref !== mux_in_dut)
		begin
			// If mismatch occurs and it's the first one
			if (total_errors == 0)
				first_error_time = $time;
				total_errors = 1;
			else
				total_errors = total_errors + 1;
			endif
		end
	end

	// Clocked logic to count cycles and trigger checks (Used for synchronization with stimulus generator clock)
	always @(posedge clk)
		begin
		clocks = clocks + 1;
		// Combinational check result is evaluated instantly, but we use this block to count cycles.
		end

	// Finalization
	initial begin
		// Wait long enough for stimulus_gen to run through its sequence
		@(negedge clk);
		#1000000; // Wait for simulation to finish or time out
		
		if (total_errors == 0)
			$display("\n==================================================");
			$display("SIMULATION PASSED");
			$display("==================================================\n");
		else
			log_mismatch();
		$finish;
	end

	// Timeout check (Retained from original TB)
	initial begin
		h#1000000
		$display("TIMEOUT");
		$finish();
	end

endmodule
