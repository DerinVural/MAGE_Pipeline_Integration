		.clk,
		a,
		.q(q_dut) );



bit strobe = 0;
task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end
task


	// Storage for mismatch details
time't first_mismatch_time = -1;
	logic first_mismatch_detected = 0;


	final begin
		if (stats1.errors > 0) begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
			// Display signals at the first mismatch time
			$display("\n--- FIRST MISMATCH DETAILS @ TIME %0d ps ---", stats1.errortime);
			$display("Input clk: %b, Input a: %b", clk, a);
			$display("Output q_dut (DUT): %b", q_dut);
			$display("Expected q_ref (GOOD): %b", q_ref);
			$display("-------------------------------------------");
		end
		if (stats1.errors == 0) begin
