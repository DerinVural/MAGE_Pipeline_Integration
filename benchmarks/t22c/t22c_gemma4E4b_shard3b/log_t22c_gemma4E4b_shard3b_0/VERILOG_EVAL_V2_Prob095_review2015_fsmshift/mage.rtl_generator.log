tes 1, 2, 3, 4)\n    assign shift_ena = (state == STATE_ENABLE_1) || \n                       (state == STATE_ENABLE_2) || \n                       (state == STATE_ENABLE_3) || \n                       (state == STATE_ENABLE_4);\n\nendmodule"
