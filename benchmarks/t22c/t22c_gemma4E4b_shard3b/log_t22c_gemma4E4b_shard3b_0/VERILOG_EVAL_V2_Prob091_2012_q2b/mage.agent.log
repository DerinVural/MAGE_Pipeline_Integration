	output logic[5:0] y,
	output logic w,
	input tb_match
);
	int errored1 = 0;
	int onehot_error = 0;
	int temp;
	
	initial begin
		// Test the one-hot cases first.
		repeat(200) @(posedge clk, negedge clk) begin
		y <= 1<< ($unsigned($random) % 6);
		w <= $random;
		if (!tb_match) onehot_error++;
		end
		
		// Random.
		errored1 = 0;
		repeat(400) @(posedge clk, negedge clk) begin
		do 
		temp = $random;
		while ( !{temp[5:4],temp[2:1]} == !{temp[3],temp[0]} );
