    "testbench": "`timescale 1 ps/1 ps\n`define OK 12\n`define INCORRECT 13\n\n\n// ===============================================================\n// Stimulus Generator (Kept exactly as provided)\n// ===============================================================\n\nmodule stimulus_gen (\n\tinput clk,\n\toutput reg reset, data,\n\toutput reg[511:0] wavedrom_title,\n\toutput reg wavedrom_enable,\n\tinput tb_match\n);\n\n\ttask reset_test(input async=0);\n\t\tbit arfail, srfail, datafail;\n\t\t\n\t\t@(posedge clk);\n\t\t@(posedge clk) reset <= 0;\n\t\trepeat(3) @(posedge clk);\n\t\t\n\t\t@(negedge clk) begin datafail = !tb_match ; reset <= 1; end\n\t\t@(posedge clk) arfail = !tb_match;\n\t\t@(posedge clk) begin\n\t\tsrfail = !tb_match;\n\t\treset <= 0;\n\t\tend\n\t\tif (srfail)\n\t\t\ts$display(\"Hint: Your reset doesn't seem to be working.\");\n\t\telse if (arfail && (async || !datafail))\n\t\t\ts$display(\"Hint: Your reset should be %0s, but doesn't appear to be.\", async ? \"asynchronous\" : \"synchronous\");\n\t\t// Don't warn about synchronous reset if the half-cycle before is already wrong. It's more likely\n\t\t// a functionality error than the reset being implemented asynchronously.\n\tendtask\n\n\n// Add two ports to module stimulus_gen:\n//    output [511:0] wavedrom_title\n//    output reg wavedrom_enable\n\n\ttask wavedrom_start(input[511:0] title = \"\");\n\tendtask\n\t\ntask wavedrom_stop;\n\t\th#1;\n\tendtask\n\t\n\n\twire [0:9] d = 10'b1110110011;\n\t\n\t\n\tinitial begin\n\t\treset <= 1;\n\t\t@(posedge clk) reset <= 0;\n\t\tdata <= 1;\n\t\trepeat(2) @(posedge clk) ;\n\t\tdata <= 0;\n\t\t@(posedge clk);\n\t\tdata <= 1;\n\t\t@(posedge clk);\n\t\tdata <= 0;\n\t\t\n\t\twavedrom_start(\"Reset and sequence detect\");\n\t\treset_test();\n\t\tfor (int i=0;i<10;i++) begin\n\t\t\t@(posedge clk) data <= d[i];\n\t\tend\n\t\twavedrom_stop();\n\t\trepeat(600) @(posedge clk, negedge clk) begin\n\t\t\treset <= !($random & 31);\n\t\t\tdata <= $random;\n\t\tend\n\n\t\th#1 $finish;\n\tend\n\t\nendmodule\n\n// ===============================================================\n// Reference Model (RefModule) - Assumed to exist and function correctly\n// ===============================================================\n\n// NOTE: RefModule implementation is not provided, so it is assumed to be correct\n// and matches the expected behavior of TopModule.\nmodule RefModule (\n\tinput clk,\n\tinput reset,\n\tinput data,\n\toutput start_shifting\n);\n\n    // Placeholder for RefModule implementation\n    always @(posedge clk)\n    begin\n        if (reset) start_shifting <= 1'b0;\n        else start_shifting <= 1'b0; // Dummy logic\n    end\n\nendmodule\n\n// ===============================================================\n// DUT Module (TopModule) - Implementation based on spec (FSM for 1101)\n// ===============================================================\nmodule TopModule (\n    input clk,\n    input reset,\n    input data,\n    output reg start_shifting\n);\n\n    // FSM States: 000 (Start), 100 (Seen 1), 110 (Seen 11), 1101 (Found)\n    parameter S_IDLE = 2'b00;  // Waiting for 1\n    parameter S_SEEN_1 = 2'b01; // Seen 1\n    parameter S_SEEN_11 = 2'b10; // Seen 11\n    parameter S_FOUND = 2'b11; // Found 1101\n\n    reg [1:0] state, next_state; // 2 bits for 4 states\n\n    // State Register Logic (Sequential)\n    always @(posedge clk, posedge reset)\n    begin\n        if (reset) \n            state <= S_IDLE;\n        else \n            state <= next_state;\n    end\n\n    // Next State Logic (Combinational)\n    always @(*) begin\n        next_state = state;\n        case (state) \n            S_IDLE:\n                if (data == 1'b1) next_state = S_SEEN_1;\n                else next_state = S_IDLE;\n            S_SEEN_1:\n                if (data == 1'b1) next_state = S_SEEN_11;\n                else next_state = S_IDLE;\n            S_SEEN_11:\n                if (data == 1'b0) next_state = S_SEEN_1;\n                else next_state = S_SEEN_11; // Sequence broken, check if it starts a new 11\n            S_FOUND:\n                next_state = S_FOUND; // Stay found\n        endcase\n    end\n\n    // Output Logic (Combinational/Sequential)\n    always @(posedge clk, posedge reset)\n    begin\n        if (reset) \n            start_shifting <= 1'b0;\n        else begin\n            if (state == S_FOUND || next_state == S_FOUND) begin\n                start_shifting <= 1'b1;\n            end else begin\n                start_shifting <= 1'b0;\n            end\n        end\n    end\n\nendmodule\n\n\n// ===============================================================\n// Testbench (Improved Golden Testbench)\n// ===============================================================\nmodule tb();\n\n    // --- Statistics Structure (Maintained) ---\n    typedef struct packed {\n        int errors;\n        int errortime;\n        int errors_start_shifting; // Note: This tracks the count, but we track first time via errortime_start_shifting\n        int errortime_start_shifting;\n        int clocks;\n    } stats;\n    \n    stats stats1;\n    \n\n    // --- Signal Declarations ---\n    wire[511:0] wavedrom_title;\n    wire wavedrom_enable;\n    int wavedrom_hide_after_time;\n    \n    reg clk = 0;\n    initial forever\n        #5 clk = ~clk;\n\n    logic reset;\n    logic data;\n    logic start_shifting_ref;\n    logic start_shifting_dut;\n    wire tb_match;\n    wire tb_mismatch = ~tb_match;\n\n    // --- Clocking and Timing Control ---\n    task wait_for_end_of_timestep;\n        repeat(5) begin\n            strobe <= !strobe;  // Try to delay until the very end of the time step.\n            @(strobe);\n        end\n    endtask\n    logic strobe = 0;\n\n    // --- Queue Declarations (For Sequential Logic Mismatch Display) ---\n    // Pattern length is 4 ('1101'). MAX_QUEUE_SIZE >= 4 + 1 = 5. Set to 10 (Max allowed).\n    localparam MAX_QUEUE_SIZE = 10;\n\n    reg clk_queue_sync = 0; // Synchroni