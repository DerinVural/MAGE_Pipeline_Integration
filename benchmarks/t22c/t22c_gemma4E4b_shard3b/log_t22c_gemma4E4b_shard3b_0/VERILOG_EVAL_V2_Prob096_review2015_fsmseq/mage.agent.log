// ===============================================================
// DUT Module (TopModule) - Implementation based on spec (FSM for 1101)
// ===============================================================
module TopModule (
    input clk,
    input reset,
    input data,
    output reg start_shifting
);

    // FSM States: 000 (Start), 100 (Seen 1), 110 (Seen 11), 1101 (Found)
    parameter S_IDLE = 2'b00;  // Waiting for 1
    parameter S_SEEN_1 = 2'b01; // Seen 1
    parameter S_SEEN_11 = 2'b10; // Seen 11
    parameter S_FOUND = 2'b11; // Found 1101

    reg [1:0] state, next_state; // 2 bits for 4 states

    // State Register Logic (Sequential)
    always @(posedge clk, posedge reset)
    begin
        if (reset) 
            state <= S_IDLE;
        else 
            state <= next_state;
    end

    // Next State Logic (Combinational)
    always @(*) begin
        next_state = state;
        case (state) 
            S_IDLE:
                if (data == 1'b1) next_state = S_SEEN_1;
                else next_state = S_IDLE;
            S_SEEN_1:
                if (data == 1'b1) next_state = S_SEEN_11;
                else next_state = S_IDLE;
            S_SEEN_11:
                if (data == 1'b0) next_state = S_SEEN_1;
                else next_state = S_SEEN_11; // Sequence broken, check if it starts a new 11
            S_FOUND:
                next_state = S_FOUND; // Stay found
        endcase
    end

    // Output Logic (Combinational/Sequential)
    always @(posedge clk, posedge reset)
    begin
        if (reset) 
            start_shifting <= 1'b0;
        else begin
            if (state == S_FOUND || next_state == S_FOUND) begin
                start_shifting <= 1'b1;
            end else begin
                start_shifting <= 1'b0;
            end
        end
    end

endmodule


// ===============================================================
// Testbench (Improved Golden Testbench)
// ===============================================================
module tb();

    // --- Statistics Structure (Maintained) ---
    typedef struct packed {
        int errors;
        int errortime;
        int errors_start_shifting; // Note: This tracks the count, but we track first time via errortime_start_shifting
        int errortime_start_shifting;
        int clocks;
    } stats;
    
    stats stats1;
    

    // --- Signal Declarations ---
    wire[511:0] wavedrom_title;
    wire wavedrom_enable;
    int wavedrom_hide_after_time;
    
    reg clk = 0;
    initial forever
        #5 clk = ~clk;

    logic reset;
    logic data;
    logic start_shifting_ref;
    logic start_shifting_dut;
    wire tb_match;
    wire tb_mismatch = ~tb_match;

    // --- Clocking and Timing Control ---
    task wait_for_end_of_timestep;
        repeat(5) begin
            strobe <= !strobe;  // Try to delay until the very end of the time step.
            @(strobe);
        end
    endtask
    logic strobe = 0;

    // --- Queue Declarations (For Sequential Logic Mismatch Display) ---
    // Pattern length is 4 ('1101'). MAX_QUEUE_SIZE >= 4 + 1 = 5. Set to 10 (Max allowed).
    localparam MAX_QUEUE_SIZE = 10;

    reg clk_queue_sync = 0; // Synchronization clock for queue updates
    
    // Queue elements must match signal widths
    reg input_clk_queue [$];
    reg input_reset_queue [$];
    reg input_data_queue [$];
    reg output_start_shifting_queue [$]; // DUT Output
    reg expected_start_shifting_queue [$]; // Reference Output

    // Reset signal queue (same width as the signal)
    reg reset_queue [$]; 


    // --- Initialization and Dumping ---
    initial begin 
        $dumpfile("wave.vcd");
        $dumpvars(1, stimulus_gen.clk, tb_mismatch ,clk,reset,data,start_shifting_ref,start_shifting_dut );
        
        // Initialize statistics
        stats1.errors = 0;
        stats1.errortime = 0;
        stats1.errors_start_shifting = 0;
        stats1.errortime_start_shifting = 0;
        stats1.clocks = 0;

        // Initialize queues
        $display("Initializing simulation queues with MAX_QUEUE_SIZE = %0d.", MAX_QUEUE_SIZE);
    end

    // --- Queue Management and Mismatch Checking (Synchronous) ---
    always @(posedge clk, negedge clk) begin
        
        // 1. Manage Queue Size
        if (input_clk_queue.size() >= MAX_QUEUE_SIZE) begin
            input_clk_queue.delete(0);
            input_reset_queue.delete(0);
            input_data_queue.delete(0);
            output_start_shifting_queue.delete(0);
            expected_start_shifting_queue.delete(0);
            reset_queue.delete(0);
        end

        // 2. Store Current Cycle Data
        input_clk_queue.push_back(clk);
        input_reset_queue.push_back(reset);
        input_data_queue.push_back(data);
        output_start_shifting_queue.push_back(start_shifting_dut);
        expected_start_shifting_queue.push_back(start_shifting_ref);
        reset_queue.push_back(reset);
        
        // 3. Update Statistics (Maintain original logic)
        stats1.clocks++;
        
        // Total Mismatch Check (tb_match)
        if (!tb_match) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
        end
        
        // Specific Start_Shifting Mismatch Check (Maintain original logic)
        // The original check was: start_shifting_ref !== ( start_shifting_ref ^ start_shifting_dut ^ start_shifting_ref )
        // This simplifies to: start_shifting_ref !== start_shifting_dut
        if (start_shifting_ref !== start_shifting_dut) begin
            if (stats1.errors_start_shifting == 0) stats1.errortime_start_shifting = $time;
            stats1.errors_start_shifting = stats1.errors_start_shifting + 1'b1;
        end

        // 4. Mismatch Detection and Display (Only upon first mismatch)
        if (stats1.errors == 1 && stats1.errors_start_shifting == 1) begin
            $display("========================================================");
            $display("*** FIRST MISMATCH DETECTED (Cycle %0d) ***", stats1.clocks);
            $display("Time of First Mismatch: %0t ps", $time);
            $display("Sequence Detected: start_shifting_dut != start_shifting_ref");

            $display("\n--- Displaying Last %0d Cycles of Queue (Up to First Error) ---", input_clk_queue.size());

            for (int i = 0; i < input_clk_queue.size(); i++) begin
                // Displaying cycle index relative to queue start
                int cycle_index = i;

                // Determine if this cycle matched or mismatched for the specific signal
                bit match_status = (output_start_shifting_queue[i] === expected_start_shifting_queue[i]);

                $display("Cycle %d, Time %0t: Reset=%b, Data=%b, Got_Out=%b, Expected_Out=%b, Status=%s",
                    cycle_index,
                    $time - (cycle_index * 10), // Approximation based on 10ps cycle time
                    input_reset_queue[i],
                    input_data_queue[i],
                    output_start_shifting_queue[i],
                    expected_start_shifting_queue[i],
                    match_status ? "MATCH" : "MISMATCH"
                );
            end
            $display("========================================================");
        end
    end


    // --- Test Sequence Execution ---
    initial begin
        // Initial setup
        reset = 1;
        data = 0;

        @(posedge clk);
        reset = 0;
        
        // Run Stimulus Generation
        stimulus_gen stim1 (
            .clk, 
            .reset, 
            .data, 
            .wavedrom_title, 
            .wavedrom_enable, 
            .tb_match
        );
        
        // Instantiate Reference Model
        RefModule good1 (
            .clk, 
            .reset, 
            .data, 
            .start_shifting(start_shifting_ref)
        );
        
        // Instantiate DUT
        TopModule top_module1 (
            .clk, 
            .reset, 
            .data, 
            .start_shifting(start_shifting_dut)
        );

        // Wait for stimulus generation to finish its sequence
        // The stimulus generation has a long random phase, so we rely on timeout/finish.

        // Timeout handler (Maintained)
        $display("Starting simulation monitoring...");
        #1000000
        if ($time > 1000000)
        begin
            $display("TIMEOUT REACHED.");
            $finish();
        end

        // Wait for the simulation to finish naturally (if stimulus finishes before timeout)
        wait ($finish);
    end

    // --- Final Reporting (Replaced to meet specific PASS/FAIL criteria) ---
    initial begin
        // Wait a little after stimulus_gen finishes its setup to ensure all queues are populated
        @(negedge clk);
        
        // Wait until simulation has stabilized or finished
        @(posedge clk);
        
        // Check final error counts
        if (stats1.errors == 0 && stats1.errors_start_shifting == 0) begin
            $display("\n=============================================");
            $display("SIMULATION PASSED");
            $display("=============================================");
        end else begin
            // Find the first mismatch time across all tracked errors
            int first_mismatch_time = 0;
            if (stats1.errors > 0) first_mismatch_time = stats1.errortime;
            if (stats1.errors_start_shifting > 0 && stats1.errortime_start_shifting < first_mismatch_time) 
                first_mismatch_time = stats1.errortime_start_shifting;

            $display("\n=============================================");
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", 
                     (stats1.errors > 0 ? stats1.errors : 0) + (stats1.errors_start_shifting > 0 ? stats1.errors_start_shifting : 0),
                     first_mismatch_time);
            $display("=============================================");
        end
    end

endmodule

