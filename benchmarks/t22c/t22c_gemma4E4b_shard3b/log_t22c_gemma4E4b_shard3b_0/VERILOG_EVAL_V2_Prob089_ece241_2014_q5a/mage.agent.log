module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_z;
		int errortime_z;

		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		h#5 clk = ~clk;

	logic areset;
	logic x;
	logic z_ref;
	logic z_dut;

	// --- Queue Definitions for Sequential Logic Monitoring ---
	// Based on interface signals: clk, areset, x, z (z_dut, z_ref)
	reg x_queue [$];
	reg z_dut_queue [$];
	reg z_ref_queue [$];
	reg areset_queue [$];

	// MAX_QUEUE_SIZE set to 6 (Control size < 10)
	localparam MAX_QUEUE_SIZE = 6;

	// State tracking for first error report
	logic first_mismatch_detected = 0;
	time first_mismatch_time = 0;

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,clk,areset,x,z_ref,z_dut );
	end

	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk, 
		.* , 
		.areset, 
		x );
	RefModule good1 (
		.clk,
		.areset,
		x,
		z(z_ref) );
	
	TopModule top_module1 (
		.clk,
		.areset,
		x,
		z(z_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		endtask	

	// --- Queue-based Error Reporting Logic ---
	always @(posedge clk, negedge clk) begin
		// 1. Manage Queue Size
		if (x_queue.size() >= MAX_QUEUE_SIZE - 1) begin
			x_queue.delete(0);
		z_dut_queue.delete(0);
		z_ref_queue.delete(0);
		areset_queue.delete(0);
		end

		// 2. Push Current Values
		x_queue.push_back(x);
		z_dut_queue.push_back(z_dut);
		z_ref_queue.push_back(z_ref);
		areset_queue.push_back(areset);

		// 3. Update Stats (Maintain Original Logic)
		stats1.clocks++;
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
		end
		// Original specific error tracking condition (z_ref !== z_dut)
		if (z_ref !== z_dut)
		begin 
			if (stats1.errors_z == 0) stats1.errortime_z = $time;
			sstats1.errors_z = stats1.errors_z+1'b1; 
		end

		// 4. Check for First Mismatch and Trigger Display
		// Mismatch condition: z_ref !== z_dut
		if (z_ref !== z_dut && !first_mismatch_detected) begin
			first_mismatch_detected = 1;
			first_mismatch_time = $time;
			$display("\n==================================================================");
			$display("Queue-based simulation mismatch display triggered at time %t", $time);
			$display("Last %0d cycles of simulation (MAX_QUEUE_SIZE: %0d):", x_queue.size(), MAX_QUEUE_SIZE);

			for (int i = 0; i < x_queue.size(); i++) begin
			if (z_dut_queue[i] === z_ref_queue[i]) begin
				s$display("Cycle %d: Got Match", i);
			end else begin
				s$display("Cycle %d: Got Mismatch", i);
			end
			$display("  -> Cycle %0d, Reset=%b, Input X=%b, Got Z=%b, Exp Z=%b",
				i, areset_queue[i], x_queue[i], z_dut_queue[i], z_ref_queue[i]);
			end
			$display("==================================================================\n");
		end
		end
	end

	final begin
		if (stats1.errors_z) $display("Hint: Output 'z' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_z, stats1.errortime_z);
		else $display("Hint: Output 'z' has no mismatches.");

		$display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
		$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
	end
	
	// --- Final Pass Check --- 
	initial begin
		@(negedge clk);
		// Wait for simulation to settle after random stimulus runs
		#500;
		
		if (stats1.errors == 0)
			$display("SIMULATION PASSED");
		else
			$display("SIMULATION FAILED - x MISMATCHES DETECTED, FIRST AT TIME %0d", first_mismatch_time);
		$finish;
	end

	// add timeout after 100K cycles
	initial begin
		h#1000000
		$display("TIMEOUT");
		$finish();
	end

endmodule


