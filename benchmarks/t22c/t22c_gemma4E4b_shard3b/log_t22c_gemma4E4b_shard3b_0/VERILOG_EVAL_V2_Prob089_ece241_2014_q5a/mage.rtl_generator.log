rst Mismatch and Trigger Display\n\t\t// Mismatch condition: z_ref !== z_dut\n\t\tif (z_ref !== z_dut && !first_mismatch_detected) begin\n\t\t\tfirst_mismatch_detected = 1;\n\t\t\tfirst_mismatch_time = $time;\n\t\t\t$display("\\n==================================================================");\n\t\t\t$display("Queue-based simulation mismatch display triggered at time %t", $time);\n\t\t\t$display("Last %0d cycles of simulation (MAX_QUEUE_SIZE: %0d):", x_queue.size(), MAX_QUEUE_SIZE);\n\n\t\t\tfor (int i = 0; i < x_queue.size(); i++) begin\n\t\t\tif (z_dut_queue[i] === z_ref_queue[i]) begin\n\t\t\t\ts$display("Cycle %d: Got Match", i);\n\t\t\tend else begin\n\t\t\t\ts$display("Cycle %d: Got Mismatch", i);\n\t\t\tend\n\t\t\t$display("  -> Cycle %0d, Reset=%b, Input X=%b, Got Z=%b, Exp Z=%b",\n\t\t\t\ti, areset_queue[i], x_queue[i], z_dut_queue[i], z_ref_queue[i]);\n\t\t\tend\n\t\t\t$display("==================================================================\\n");\n\t\tend\n\t\tend\n\tend\n\n\tfinal begin\n\t\tif (stats1.errors_z) $display("Hint: Output \'z\' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_z, stats1.errortime_z);\n\t\telse $display("Hint: Output \'z\' has no mismatches.");\n\n\t\t$display("Hint: Total mismatched samples is %1d out of %1d samples\\n", stats1.errors, stats1.clocks);\n\t\t$display("Simulation finished at %0d ps", $time);\n\t\t$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);\n\tend\n\t\n\t// --- Final Pass Check --- \n\tinitial begin\n\t\t@(negedge clk);\n\t\t// Wait for simulation to settle after random stimulus runs\n\t\t#500;\n\t\t\n\t\tif (stats1.errors == 0)\n\t\t\t$display("SIMULATION PASSED");\n\t\telse\n\t\t\t$display("SIMULATION FAILED - x MISMATCHES DETECTED, FIRST AT TIME %0d", first_mismatch_time);\n\t\t$finish;\n\tend\n\n\t// add timeout after 100K cycles\n\tinitial begin\n\t\th#1000000\n\t\t$display("TIMEOUT");\n\t\t$finish();\n\tend\n\nendmodule\n\n\n// Dummy modules required by the golden testbench structure\nmodule RefModule (\n    input logic clk,\n    input logic areset,\n    input logic x,\n    output logic z\n);\n\t// Placeholder implementation for golden reference\n\tassign z = x ^ 1\'b1; // Example: simple inverter\nendmodule\n\n</testbench>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nThe module interface is given below:\n<module_interface>\nmodule TopModule (\n    input logic clk,\n    input logic areset,\n    input logic x,\n    output logic z\n);\n    // Implementation details omitted as per instructions, but structure is defined.\nendmodule\n</module_interface>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nYour response will be processed by a program, not human.\nSo, please STRICTLY FOLLOW the output format given as XML tag content below to generate a VALID JSON OBJECT:\n<output_format>\n{\n    "reasoning": "All reasoning steps and advices to avoid syntax error",\n    "module": "Pure SystemVerilog code, a complete module"\n}\n</output_format>\nDO NOT include any other information in your response, like \'json\', \'reasoning\' or \'<output_format>\'.\n\nOther requirements:\n1. Don\'t use state_t to define the parameter. Use `localparam` or Use \'reg\' or \'logic\' for signals as registers or Flip-Flops.\n2. Declare all ports and signals as logic.\n3. Not all the sequential logic need to be reset to 0 when reset is asserted,\n    but these without-reset logic should be initialized to a known value with an initial block instead of being X.\n4. For combinational logic with an always block do not explicitly specify the sensitivity list; instead use always @(*).\n5. NEVER USE \'inside\' operator in RTL code. Code like \'state inside {STATE_B, STATE_C, STATE_D}\' should NOT be used.\n6. Never USE \'unique\' or \'unique0\' keywords in RTL code. Code like \'unique case\' should NOT be 