l logic of error counting;\n4. When simulation ends, ADD DISPLAY "SIMULATION PASSED" if no mismatch occurs, otherwise display:\n    "SIMULATION FAILED - x MISMATCHES DETECTED, FIRST AT TIME y".\nPlease also follow the display prompt below:\n\n1. If module to test is sequential logic (like including an FSM):\n    1.1. Store input signals, output signals, expected output signals and reset signals in a queue with MAX_QUEUE_SIZE;\n        When the first mismatch occurs, display the queue content after storing it. Make sure the mismatched signal can be displayed.\n    1.2. MAX_QUEUE_SIZE should be set according to the requirement of the module.\n        For example, if the module has a 3-bit state, MAX_QUEUE_SIZE should be at least 2 ** 3 = 8.\n        And if the module was to detect a pattern of 8 bits, MAX_QUEUE_SIZE should be at least (8 + 1) = 9.\n        However, to control log size, NEVER set MAX_QUEUE_SIZE > 10.\n    1.3. The clocking of queue and display should be same with the clocking of tb_match detection.\n        For example, if \'always @(posedge clk, negedge clk)\' is used to detect mismatch,\n        It should also be used to push queue and display first error.\n2. If module to test is combinational logic:\n    When the first mismatch occurs, display the input signals, output signals and expected output signals at that time.\n3. For multiple-bit signals displayed in HEX format, also display the BINARY format if its width <= 64.\n\n<display_queue_example>\n// Queue-based simulation mismatch display\n\nreg [INPUT_WIDTH-1:0] input_queue [$];\nreg [OUTPUT_WIDTH-1:0] got_output_queue [$];\nreg [OUTPUT_WIDTH-1:0] golden_queue [$];\nreg reset_queue [$];\n\nlocalparam MAX_QUEUE_SIZE = 5;\n\nalways @(posedge clk, negedge clk) begin\n    if (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin\n        input_queue.delete(0);\n        got_output_queue.delete(0);\n        golden_queue.delete(0);\n        reset_queue.delete(0);\n    end\n\n    input_queue.push_back(input_data);\n    got_output_queue.push_back(got_output);\n    golden_queue.push_back(golden_output);\n    reset_queue.push_back(rst);\n\n    // Check for first mismatch\n    if (got_output !== golden_output) begin\n        $display("Mismatch detected at time %t", $time);\n        $display("\\nLast %d cycles of simulation:", input_queue.size());\n\n\n        for (int i = 0; i < input_queue.size(); i++) begin\n            if (got_output_queue[i] === golden_queue[i]) begin\n                $display("Got Match at");\n            end else begin\n                $display("Got Mismatch at");\n            end\n            $display("Cycle %d, reset %b, input %h, got output %h, exp output %h",\n                i,\n                reset_queue[i],\n                input_queue[i],\n                got_output_queue[i],\n                golden_queue[i]\n            );\n        end\n    end\n\nend\n</display_queue_example>\n\n\n\nTry to understand the requirements above and give reasoning steps in natural language to achieve it.\nIn addition, try to give advice to avoid syntax error.\nAn SystemVerilog module always starts with a line starting with the keyword \'module\' followed by the module name.\nIt ends with the keyword \'endmodule\'.\n\nBelow is the golden testbench code for the module generated with the given natural language specification.\n<golden_testbench>\n`timescale 1 ps/1 ps\n`define OK 12\n`define INCORRECT 13\n\n\nmodule stimulus_gen (\n\tinput clk,\n\toutput logic x,\n\toutput logic areset,\n\toutput reg[511:0] wavedrom_title,\n\toutput reg wavedrom_enable,\n\tinput tb_match\n);\n\treg reset;\n\tassign areset = reset;\n\n// Add two ports to module stimulus_gen:\n//    output [511:0] wavedrom_title\n//    output reg wavedrom_enable\n\n\ttask wavedrom_start(input[511:0] title = "");\n\tendtask\n\t\n\ttask wavedrom_stop;\n\t\t#1;\n\tendtask\t\n\n\n\ttask reset_test(input async=0);\n\t\tbit arfail, srfail, datafail;\n\t\n\t\t@(posedge clk);\n\t\t@(posedge clk) reset <= 0;\n\t\trepeat(3) @(posedge clk);\n\t\n\t\t@(negedge clk) begin datafail = !tb_match ; reset <= 1; end\n\t\t@(posedge clk) arfail = !tb_match;\n\t\t@(posedge clk) begin\n\t\t\tsrfail = !tb_match;\n\t\t\treset <= 0;\n\t\tend\n\t\tif (srfail)\n\t\t\t$display("Hint: Your reset doesn\'t seem to be working.");\n\t\telse if (arfail && (async || !datafail))\n\t\t\t$display("Hint: Your reset should be %0s, but doesn\'t appear to be.", async ? "asynchronous" : "synchronous");\n\t\t// Don\'t warn about synchronous reset if the half-cycle before is already wrong. It\'s more likely\n\t\t// a functionality error than the reset being implemented asynchronously.\n\t\n\tendtask\n\n\n\tinitial begin\n\t\tx <= 0;\n\t\treset <= 1;\n\t\t@(posedge clk) reset <= 0; x <= 1;\n\t\t@(posedge clk) x <= 0;\n\t\treset_test(1);\n\t\t\n\t\t@(negedge clk) wavedrom_start();\n\t\t\t@(posedge clk) {reset,x} <= 2\'h2;\n\t\t\t@(posedge clk) {reset,x} <= 2\'h0;\n\t\t\t@(posedge clk) {reset,x} <= 2\'h0;\n\t\t\t@(posedge clk) {reset,x} <= 2\'h1;\n\t\t\t@(posedge clk) {reset,x} <= 2\'h0;\n\t\t\t@(posedge clk) {reset,x} <= 2\'h1;\n\t\t\t@(posedge clk) {reset,x} <= 2\'h1;\n\t\t\t@(posedge clk) {reset,x} <= 2\'h0;\n\t\t\t@(posedge clk) {reset,x} <= 2\'h0;\n\t\t@(negedge clk) wavedrom_stop();\n\t\trepeat(400) @(posedge clk, negedge clk)\n\t\t\t{reset,x} <= {($random&31) == 0, ($random&1)==0 };\n\n\t\t$finish;\n\tend\n\t\nendmodule\n\nmodule tb();\n\n\ttypedef struct packed {\n\t\tint errors;\n\t\tint errortime;\n\t\tint errors_z;\n\t\tint errortime_z;\n\n\t\tint clocks;\n\t} stats;\n\t\n\tstats stats1;\n\t\n\t\n\twire[511:0] wavedrom_title;\n\twire wavedrom_enable;\n\tint wavedrom_hide_after_time;\n\t\n\treg clk=0;\n\tinitial forever\n\t\t#5 clk = ~clk;\n\n\tlogic areset;\n\tlogic x;\n\tlogic z_ref;\n\tlogic z_dut;\n\n\tinitial begin \n\t\t$dumpfile("wave.vcd");\n\t\t$dumpvars(1, stim1.clk, tb_mismatch ,clk,areset,x,z_ref,z_dut );\n\tend\n\n\n\twire tb_match;\t\t// Verification\n\twire tb_mismatch = ~tb_match;\n\t\n\tstimulus_gen stim1 (\n\t\t.clk,\n\t\t.* ,\n\t\t.areset,\n\t\t.x );\n\tRefModule good1 (\n\t\t.clk,\n\t\t.areset,\n\t\t.x,\n\t\t.z(z_ref) );\n\t\t\n\tTopModule top_module1 (\n\t\t.clk,\n\t\t.areset,\n\t\t.x,\n\t\t.z(z_dut) );\n\n\t\n\tbit strobe = 0;\n\ttask wait_for_end_of_timestep;\n\t\trepeat(5) begin\n\t\t\tstrobe <= !strobe;  // Try to delay until the very end of the time step.\n\t\t\t@(strobe);\n\t\tend\n\tendtask\t\n\n\t\n\tfinal begin\n\t\tif (stats1.errors_z) $display("Hint: Output \'%s\' has %0d mismatches. First mismatch occurred at time %0d.", "z", stats1.errors_z, stats1.errortime_z);\n\t\telse $display("Hint: Output \'%s\' has no mismatches.", "z");\n\n\t\t$display("Hint: Total mismatched samples is %1d out of %1d samples\\n", stats1.errors, stats1.clocks);\n\t\t$display("Simulation finished at %0d ps", $time);\n\t\t$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);\n\tend\n\t\n\t// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.\n\tassign tb_match = ( { z_ref } === ( { z_ref } ^ { z_dut } ^ { z_ref } ) );\n\t// Use explicit sensitivity list here. @(*) causes NetProc::nex_input() to be called when trying to compute\n\t// the sensitivity list of the @(strobe) process, which isn\'t implemented.\n\talways @(posedge clk, negedge clk) begin\n\n\t\tstats1.clocks++;\n\t\tif (!tb_match) begin\n\t\t\tif (stats1.errors == 0) stats1.errortime = $time;\n\t\t\tstats1.errors++;\n\t\tend\n\t\tif (z_ref !== ( z_ref ^ z_dut ^ z_ref ))\n\t\tbegin if (stats1.errors_z == 0) stats1.errortime_z = $time;\n\t\t\tstats1.errors_z = stats1.errors_z+1\'b1; end\n\n\tend\n\n   // add timeout after 100K cycles\n   initial begin\n     #1000000\n     $display("TIMEOUT");\n     $finish();\n   end\n\nendmodule\n\n\n<golden_testbench>\n')]), ChatMessage(role=<MessageRole.ASSISTANT: 'assistant'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='{\n    "reasoning": "1. **Interface Generation:** The input specification requests `TopModule` with ports: `input clk`, `input areset`, `input x`, `output z`. However, the provided `golden_testbench` instantiates `TopModule` with these exact ports. Since the instruction states to follow the golden testbench if it contradicts the specification, and here they match for the core ports, I will define the interface based on the specification/golden TB structure.\\n\\n2. **Testbench Improvement:** The golden testbench is sequential logic (it monitors state over time) and involves checking mismatches on every clock edge. The requirement is to implement queue-based mismatch reporting for sequential logic, following the structure provided in `<display_queue_example>`. \\n\\n3. **Queue Sizing:** The module has 1 input (`x`), 1 output (`z`), and a reset signal (`areset`). The maximum required queue size must not exceed 10. Since the logic is simple state monitoring, a small queue size (e.g., 5 or 6) will suffice to capture the error context. I will use 6 for safety.\\n\\n4. **Mismatch Logic Adaptation:** The original TB uses `tb_match` derived from `z_ref` (golden reference) and `z_dut` (DUT output). The error counting logic needs to be integrated into the queue update mechanism.\\n\\n5. **Queue Implementation Details:**\\n    - I need queues for `x` (input), `z_dut` (got output), `z_ref` (golden output), and `areset` (reset).\\n    - The queue update and mismatch check must occur synchronously with the clocking used for mismatch detection in the original TB: `always @(posedge clk, negedge clk)`.\\n    - The original error counting logic (`stats1.errors++` and `stats1.errors_z++`) must be maintained, but the queue logic will replace/augment the display mechanism.\\n    - The final display must change from the original `Hint:` style to the required "  , "SIMULATION PASSED"  :"SIMULATION FAILED - x MISMATCHES DETECTED, FIRST AT TIME y"  ,  ".\\n\\n6. **Refining Error Reporting:** The original TB calculates errors separately (`stats1.errors` and `stats1.errors_z`) based on `tb_match` and a specific condition involving `z_ref ^ z_dut ^ z_ref`. I must maintain this original error counting logic while introducing the queue display for the *first* mismatch. Since the queue is for display, I will use the queue size to track the error count implicitly, and use a flag to capture the first error time, similar to the original structure, but ensure the detailed queue dump happens *only* on the first error.\\n\\n7. **Display Format:** The final $display must match the strict requirement: \\"SIMULATION PASSED\\" or \\"SIMULATION FAILED - x MISMATCHES DETECTED, FIRST AT TIME y\\".\\n\\n8. **Syntax Advice:** Ensure all signals used in the queue definitions (`x`, `z_dut`, `z_ref`, `areset`) are properly defined as `reg` or `logic` in the testbench scope. Since the original TB uses `logic` for inputs/outputs in `tb`, I will stick to `logic` for queue types where appropriate, or `reg` for queue elements if they need to be assigned inside an `always` block.\\n\\n9. **Module Instantiation:** The instantiation structure from the golden TB must be maintained, including the `stimulus_gen` and `RefModule` instantiations, even though they are not the primary focus of the required changes (TopModule testing).\\n\\n**Implementation Strategy:** I will wrap the queue logic inside the existing verification always block. I will use a state/flag to ensure the queue dump and final failure message only happen once upon the first mismatch, while still incrementing the error counters as in the original TB.\\n\\n*Self-Correction/Refinement:* The original TB calculates `tb_match` using XORs: `tb_match = ( { z_ref } === ( { z_ref } ^ { z_dut } ^ { z_ref } ) );`. This simplifies to `tb_match = ( { z_ref } === { z_dut } )`. I must maintain this calculation. The condition for `stats1.errors_z` is `z_ref !== ( z_ref ^ z_dut ^ z_ref )`, which also simplifies to `z_ref !== z_dut`. Therefore, both error counters track the same mismatch condition (`z_ref !== z_dut`). I will use this simplified check for consistency in the queue logic.\\n\\n*Constraint Check:* MAX_QUEUE_SIZE <= 10. I choose 6.\\n\\n*Final Output Generation:* Assemble the pieces into the required JSON structure.\\n\\n**Advice to avoid syntax error:** When dealing with queues and complex assignments inside an `always` block sensitive to both positive and negative edges (`@ (posedge clk, negedge clk)`), ensure that all assignments to queue elements (`push_back`, `delete`) are handled correctly within the synchronous block. Use `logic` or `reg` appropriately for queue elements depending on how they are driven, although for state capture in an always block, `logic` is generally safe in modern SystemVerilog.\\n\\n\\n*Note on Golden TB Contradiction:* The golden TB instantiates `TopModule` with 4 ports (`clk, areset, x, z`). The specification implies 4 ports. No conflict detected for the core module being tested.\\n\\n*Modification to Final Display:* The original TB uses `stats1.errors` and `stats1.errors_z`. I will use `stats1.errors` for the final failure message count, as it appears to be the primary error metric used in the original final block, and ensure the queue dump covers the necessary data for debugging.\\n\\nI will replace the existing error handling block in `tb` with the queue-based mechanism, ensuring error counters are updated correctly to fulfill the requirement to maintain original logic.\\n\\nSince the queue-based display requires tracking the first mismatch time, I will track a `first_mismatch_time` variable and only display the queue/fail message when this flag is set and the error count increases/at the end of simulation if errors exist.\\n\\nThis requires careful synchronization between the queue push/delete and the error counting.\\n\\nI will adapt the queue logic to check for mismatch *after* pushing the data for the current cycle, mimicking the original check at the end of the block.\\n\\nSince the original TB structure was: 1. Update stats, 2. Check match, 3. Increment errors. The queue must mirror this sequence.\\n\\nIf I use the queue, the check `if (got_output !== golden_output)` inside the queue logic will trigger the display.\\n\\nI will slightly simplify the original error tracking variables to align with the queue\'s ability to report the first error time directly upon mismatch detection in the queue logic, while still keeping the general error count.\\n\\nI must ensure the final message uses the correct format: \\"SIMULATION PASSED\\" or \\"SIMULATION FAILED - x MISMATCHES DETECTED, FIRST AT TIME y\\"."\n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n    \n 