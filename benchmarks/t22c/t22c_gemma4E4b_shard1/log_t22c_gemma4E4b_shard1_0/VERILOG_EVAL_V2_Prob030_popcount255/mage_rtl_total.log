			output_dut_at_mismatch = out_dut;
			output_ref_at_mismatch = out_ref;
			first_mismatch_captured = 1;
		end
	end

	
	initial begin
		// Wait until the first mismatch occurs to display the state (Combinational Logic)
		@(posedge clk);
