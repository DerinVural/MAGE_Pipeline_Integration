			begin 
				if (stats1.errors_out == 0) stats1.errortime_out = $time;
				sstats1.errors_out = stats1.errors_out+1'b1; 
			end
			
			// 3. Combinational Mismatch Display Logic (Triggered on state change)
			if (!tb_match && first_mismatch_time == -1) begin
				// Capture state at the time of first mismatch
