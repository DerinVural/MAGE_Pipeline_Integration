	logic [2:0] first_mismatch_in = 3'bx;
	logic [1:0] first_mismatch_out_dut = 2'bx;
	logic [1:0] first_mismatch_out_ref = 2'bx;
	integer first_mismatch_time = -1;

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,in,out_ref,out_dut );
	end


	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
