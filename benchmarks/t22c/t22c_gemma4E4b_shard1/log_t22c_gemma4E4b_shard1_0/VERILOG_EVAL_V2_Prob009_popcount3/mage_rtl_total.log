	task wavedrom_start(input[511:0] title = "");
endtask
	
	task wavedrom_stop;
		#1;
endtask
		
		
	initial begin
	in <= 7;
	@(negedge clk);
	wavedrom_start();
	repeat(9) @(posedge clk) in <= in + 1'b1;
	@(negedge clk);
	wavedrom_stop();
	repeat(200) @(posedge clk, negedge clk)
	in <= $random;
	$finish;
end
	endmodule

module tb();

