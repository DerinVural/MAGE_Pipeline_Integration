module tb();
	typedef struct packed {
		int errors;
		int errortime;
		int errors_out;
		int errortime_out;
		int clocks;
	} stats;
	
	stats stats1;
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic [99:0] in;
	logic [99:0] out_ref;
	logic [99:0] out_dut;

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,in,out_ref,out_dut );
	end

	wire tb_match; 
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk,
		.*,
		.in );
	RefModule good1 (
		.in,
		.out(out_ref) );
	
	TopModule top_module1 (
		.in,
		.out(out_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end
task
	
	// State tracking for improved error reporting (Combinational logic rule application)
	reg [99:0] last_in_val;
	reg [99:0] last_ref_val;
	reg [99:0] last_dut_val;
	reg first_mismatch_time = 0;
	reg mismatch_detected_flag = 0;

	// Verification: Direct comparison as the XOR logic in golden TB is redundant/flawed for simple matching.
	assign tb_match = (out_ref === out_dut);
	
	// Clocking and Error Counting Logic
	always @(posedge clk, negedge clk) begin
		stats1.clocks++;
		
		// Capture current inputs/outputs for logging if mismatch occurs
		last_in_val <= in;
		last_ref_val <= out_ref;
		last_dut_val <= out_dut;

		// --- Original Error Counting Logic Maintenance ---
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
		end
		
		// Check specific error count logic from golden TB (redundant check, but maintained)
		if (out_ref !== ( out_ref ^ out_dut ^ out_ref ))
		begin 
			if (stats1.errors_out == 0) stats1.errortime_out = $time;
			stats1.errors_out = stats1.errors_out+1'b1; 
		end
		end

	// Enhanced Mismatch Reporting for FIRST error (Combinational Logic Rule 2)
	always @(*) begin
		if (tb_mismatch && !mismatch_detected_flag) begin
			if (first_mismatch_time == 0) begin
			first_mismatch_time = $time;
			mismatch_detected_flag = 1;
			end
		end
	end

	// Monitor the clock edge where the first mismatch was registered to display state
	always @(posedge clk, negedge clk) begin
		if (tb_mismatch && first_mismatch_time == $time) begin
			$display("========================================================================================");
			$display("*** FIRST MISMATCH DETECTED AT TIME %0t ***", $time);
			$display("========================================================================================");
			$display("--- Input Signals ---");
			$display("Input (in): %h (Binary: %b)", last_in_val, last_in_val);
			$display("--- Expected Output Signals ---");
			$display("Golden Output (out_ref): %h (Binary: %b)", last_ref_val, last_ref_val);
			$display("--- Actual Output Signals ---");
			$display("DUT Output (out_dut): %h (Binary: %b)", last_dut_val, last_dut_val);
			end
	end

	
	// Original Final Block Modification
	initial begin
		// Wait for simulation to naturally finish or timeout
		@(negedge clk);
		
		// Replace original hints with required strict reporting
		if (stats1.errors_out) begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d.", stats1.errors_out, stats1.errortime_out);
		end else if (stats1.errors > 0) begin
			// Use the actual first mismatch time detected by the enhanced logic if errors exist
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d.", stats1.errors, first_mismatch_time);
		end else begin
			$display("SIMULATION PASSED");
		end
		
		$display("Simulation finished at %0d ps", $time);
		$finish;
	end

	// add timeout after 100K cycles
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

endmodule
