			$display("\n=========================================================================");
			$display("!!! COMBINATIONAL MISMATCH DETECTED AT TIME %0t !!!", $time);
			$display("Input Signals: x = %b (Hex: %h), y = %b (Hex: %h)", x, x, y, y);
