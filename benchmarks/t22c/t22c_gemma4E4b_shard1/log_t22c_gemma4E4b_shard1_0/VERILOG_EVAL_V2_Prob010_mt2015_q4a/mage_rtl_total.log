	// Which simplifies to z_ref === z_dut.
	assign tb_match = (z_ref === z_dut);

	// Error tracking for combinational logic: Check mismatch immediately after input changes (i.e., on clock edge)
	always @(posedge clk, negedge clk) begin
		stats1.clocks++;
		
		// Original mismatch counting logic
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			sstats1.errors++;
		end

		// Original z_ref vs z_dut check logic
		if (z_ref !== z_dut) // Simplified equivalent of (z_ref !== ( z_ref ^ z_dut ^ z_ref ))
		begin 
			if (stats1.errors_z == 0) stats1.errortime_z = $time;
			sstats1.errors_z = stats1.errors_z+1'b1; 
		end
	end

	// NEW: Combinational Mismatch Display Logic (Rule 2)
	always @(posedge clk, negedge clk) begin
