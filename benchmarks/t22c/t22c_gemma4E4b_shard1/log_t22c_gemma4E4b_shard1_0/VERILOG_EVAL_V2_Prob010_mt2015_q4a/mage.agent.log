	typedef struct packed {
		int errors;
		int errortime;
		int errors_z;
		int errortime_z;
		int clocks;
	} stats;
	
	stats stats1;
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic x;
	logic y;
	logic z_ref;
	logic z_dut;

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,x,y,z_ref,z_dut );
	end

	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk,
		.* , // Mapping inputs x, y from stimulus_gen
		.x,
		.y 
	);
	RefModule good1 (
		.x,
		.y,
		z(z_ref) 
	);
	
	TopModule top_module1 (
		.x,
		.y,
		z(z_dut) 
	);

	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end
	task

	// Verification check for combinational logic
	// tb_match = (z_ref === z_dut); 
	// The original golden testbench used: assign tb_match = ( { z_ref } === ( { z_ref } ^ { z_dut } ^ { z_ref } ) );
	// Which simplifies to z_ref === z_dut.
	assign tb_match = (z_ref === z_dut);

	// Error tracking for combinational logic: Check mismatch immediately after input changes (i.e., on clock edge)
	always @(posedge clk, negedge clk) begin
		stats1.clocks++;
		
		// Original mismatch counting logic
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			sstats1.errors++;
		end

		// Original z_ref vs z_dut check logic
		if (z_ref !== z_dut) // Simplified equivalent of (z_ref !== ( z_ref ^ z_dut ^ z_ref ))
		begin 
			if (stats1.errors_z == 0) stats1.errortime_z = $time;
			sstats1.errors_z = stats1.errors_z+1'b1; 
		end
	end

	// NEW: Combinational Mismatch Display Logic (Rule 2)
	always @(posedge clk, negedge clk) begin
		if (!tb_match && stats1.errors == 1) begin // Only trigger display on the FIRST mismatch
			$display("\n=========================================================================");
			$display("!!! COMBINATIONAL MISMATCH DETECTED AT TIME %0t !!!", $time);
			$display("Input Signals: x = %b (Hex: %h), y = %b (Hex: %h)", x, x, y, y);
			$display("Actual Output (DUT): z_dut = %b (Hex: %h)", z_dut, z_dut);
			$display("Expected Output (Reference): z_ref = %b (Hex: %h)", z_ref, z_ref);
			$display("=========================================================================");
		end
	end

	final begin
		if (stats1.errors_z) $display("Hint: Output 'z' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_z, stats1.errortime_z);
		else $display("Hint: Output 'z' has no mismatches.");

		$display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
		$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
	
		// Final required status display
		if (stats1.errors == 0) begin
			$display("SIMULATION PASSED");
		end else begin
			$display("SIMULATION FAILED - x MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errortime);
		end
	end

	// add timeout after 100K cycles
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

endmodule
