	initial begin
		repeat(1000) @(negedge clk);
		$finish;
	end
	
endmodule

module tb();
	
typedef struct packed {
		int errors;
		int errortime;
		int errors_out;
		int errortime_out;
		int clocks;
	} stats;
	
