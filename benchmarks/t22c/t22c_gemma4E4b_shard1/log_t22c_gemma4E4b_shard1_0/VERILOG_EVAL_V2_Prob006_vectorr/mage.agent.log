// --- Stimulus Generator (Copied from Golden TB) ---
module stimulus_gen (
	input clk,
	output logic [7:0] in,
	output reg[511:0] wavedrom_title,
	output reg wavedrom_enable
);

	// Add two ports to module stimulus_gen:
	//    output [511:0] wavedrom_title
	//    output reg wavedrom_enable

	task wavedrom_start(input[511:0] title = "");
	endtask
	
	task wavedrom_stop;
		#1;
	endtask
	
	
	initial begin
		in <= 0;
		@(negedge clk) wavedrom_start();
		@(posedge clk) in <= 8'h1;
		@(posedge clk) in <= 8'h2;
		@(posedge clk) in <= 8'h4;
		@(posedge clk) in <= 8'h8;
		@(posedge clk) in <= 8'h80;
		@(posedge clk) in <= 8'hc0;
		@(posedge clk) in <= 8'he0;
		@(posedge clk) in <= 8'hf0;
		@(negedge clk) wavedrom_stop();
		
		repeat(200) @(posedge clk, negedge clk)
			in <= $random;
		$finish;
	end
	endmodule


// --- Ref Module (Assumed to implement bit reversal for golden reference) ---
// Since the spec requires TopModule to reverse bits, RefModule must do the same to be golden.
module RefModule (
    input  logic [7:0] in,
    output logic [7:0] out
);
    // Bit Reversal Logic
    assign out = {in[0], in[1], in[2], in[3], in[4], in[5], in[6], in[7]};
endmodule


// --- DUT Module (Interface based on Spec) ---
module TopModule (
    input  logic [7:0] in,
    output logic [7:0] out
);
    // Implementation not required, but kept for completeness
    // Must reverse bits according to spec
    assign out = {in[0], in[1], in[2], in[3], in[4], in[5], in[6], in[7]};
endmodule


// --- Testbench ---
module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_out;
		int errortime_out;

		int clocks;
	} stats;
	
	stats stats1;
	
	// Signals from stimulus_gen
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	
	// Internal control signals
	reg clk=0;
	
	// DUT signals
	logic [7:0] in;
	logic [7:0] out_ref; // Expected (Golden)
	logic [7:0] out_dut; // Actual (DUT)

	// Verification signals
	wire tb_match;
	wire tb_mismatch = ~tb_match;

	// --- Mismatch Capture Variables for Combinational Logic Display ---
	logic capture_first_mismatch = 0;
	logic [7:0] captured_input_at_mismatch;
	logic [7:0] captured_out_ref_at_mismatch;
	logic [7:0] captured_out_dut_at_mismatch;
	
	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stimulus_gen::stim1.clk, tb_mismatch, in, out_ref, out_dut);
	end

	// Clock Generation
	initial forever
		#5 clk = ~clk;

	// Task for synchronization (Copied from Golden TB)
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		endtask

	// Instantiations
	stimulus_gen stim1 (
		.clk, 
		.in, 
		.wavedrom_title, 
		.wavedrom_enable 
	);
	RefModule good1 (
		.in, 
		.out(out_ref) );
	TopModule top_module1 (
		.in, 
		.out(out_dut) );

	// Verification Logic (Combinational Check)
	// The XOR check from the golden TB is maintained, even though it seems overly complex for simple equality.
	assign tb_match = ( { out_ref } === ( { out_ref } ^ { out_dut } ^ { out_ref } ) );

	// Main Clocked Logic and Error Counting
	always @(posedge clk, negedge clk) begin
		stats1.clocks++;
		
		// Mismatch tracking (Original logic)
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
			end
		
		// Output mismatch tracking (Original logic)
		if (out_ref !== ( out_ref ^ out_dut ^ out_ref ))
		begin 
			if (stats1.errors_out == 0) stats1.errortime_out = $time;
			stats1.errors_out = stats1.errors_out+1'b1; 
		end
		end

		// --- IMPROVEMENT: Capture First Mismatch for Combinational Display ---
		if (tb_mismatch && !capture_first_mismatch) begin
			capture_first_mismatch = 1;
			captured_input_at_mismatch = in;
			captured_out_ref_at_mismatch = out_ref;
			captured_out_dut_at_mismatch = out_dut;
		end
	end

	// Monitor/Display Task (For immediate feedback during simulation, optional but helpful)
	always @(posedge clk)
		begin
			if (tb_mismatch)
				$display("--- FIRST MISMATCH DETECTED AT TIME %0t ---", $time);
				$display("Input:  %h (Binary: %b)", in, in);
				$display("Expected Out: %h (Binary: %b)", out_ref, out_ref);
				$display("Actual Out:   %h (Binary: %b)", out_dut, out_dut);
			end
		end

	// Timeout
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

	// Final Reporting (Rule 4)
	final begin
		if (stats1.errors_out) 
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d.", stats1.errors_out, stats1.errortime_out);
		else 
			$display("SIMULATION PASSED");
		
		// Retain original hints for debugging if necessary
		$display("\n--- Original Debug Info ---");
		if (stats1.errors_out) $display("Hint: Output '%s' has %0d mismatches. First mismatch occurred at time %0d.", "out", stats1.errors_out, stats1.errortime_out);
		else $display("Hint: Output '%s' has no mismatches.", "out");
		$display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
		$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
	end

endmodule
