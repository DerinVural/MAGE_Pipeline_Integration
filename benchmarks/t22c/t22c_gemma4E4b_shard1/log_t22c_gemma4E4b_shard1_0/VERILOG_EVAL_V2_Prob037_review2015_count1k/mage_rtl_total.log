	reg [9:0] input_queue [$]; // Tracking relevant inputs (reset for sequential logic)
	reg [9:0] got_output_queue [$];
	reg [9:0] golden_queue [$];
	reg reset_queue [$]; // Reset signal tracking

	localparam MAX_QUEUE_SIZE = 10;

	// --- Original Testbench Setup ---
	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,clk,reset,q_ref,q_dut );
	end

	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk, 
		.* , 
		.reset );
	RefModule good1 (
		.clk,
		.reset,
		.q(q_ref) );
	
	TopModule top_module1 (
		.clk,
		.reset,
		.q(q_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end
task

	// Verification assignment, kept from golden testbench
	assign tb_match = ( { q_ref } === ( { q_ref } ^ { q_dut } ^ { q_ref } ) );

	// --- Synchronous Monitoring and Queue Management ---
	always @(posedge clk, negedge clk) begin

		stats1.clocks++;

		// 1. Update Queues
		input_queue.push_back(reset);
		got_output_queue.push_back(q_dut);
		golden_queue.push_back(q_ref);
		reset_queue.push_back(reset);

		// Maintain queue size
		if (input_queue.size() >= MAX_QUEUE_SIZE) begin
			input_queue.delete(0);
			got_output_queue.delete(0);
			golden_queue.delete(0);
			reset_queue.delete(0);
		end

		// 2. Original Error Counting (MUST BE MAINTAINED)
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			sstats1.errors++;
		end
		if (q_ref !== ( q_ref ^ q_dut ^ q_ref ))
		begin if (stats1.errors_q == 0) stats1.errortime_q = $time;
			sstats1.errors_q = stats1.errors_q+1'b1; end
		end

		// 3. Queue-based Mismatch Display (Only on FIRST mismatch detection)
		if (!tb_match && stats1.errors == 1) begin 
			$display("========================================================");
			$display("FIRST MISMATCH DETECTED AT TIME %0t", $time);
			$display("Displaying last %0d cycles of simulation leading to error:", input_queue.size());
			$display("========================================================");

			for (int i = 0; i < input_queue.size(); i++) begin
				// Check if the current sample (i) matches in the queue
				if (got_output_queue[i] === golden_queue[i]) begin
					$display("Cycle %0d: Match (Reset=%b)", i, reset_queue[i]);
				end else begin
					$display("Cycle %0d: MISMATCH (Reset=%b)", i, reset_queue[i]);
					$display("  Inputs/Reset: %b", input_queue[i]);
					$display("  Got Output (q_dut): %h (%b)", got_output_queue[i], got_output_queue[i]);
					$display("  Golden Output (q_ref): %h (%b)", golden_queue[i], golden_queue[i]);
				end
			end
		end
		// End of queue-based display logic
	end

	// add timeout after 100K cycles
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

	// Final reporting block (Replaces original final block to meet new requirements)
	initial begin
		// Wait for simulation to complete naturally or timeout
		@(negedge clk);
		// Check if any mismatch occurred using the original counter stats
		if (stats1.errors > 0) begin
			$display("\n========================================================");
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
			$display("========================================================");
			// Also print detailed stats from original testbench for completeness
			$display("Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
