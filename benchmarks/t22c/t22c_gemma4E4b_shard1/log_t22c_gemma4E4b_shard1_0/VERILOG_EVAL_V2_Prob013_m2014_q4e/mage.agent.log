module tb();
	
	typedef struct packed {
		int errors;
		int errortime;
		int errors_out;
		int errortime_out;
		int clocks;
	}
	stats;
	
	stats stats1;
	
	// Signals from golden testbench
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic in1;
	logic in2;
	logic out_ref;
	logic out_dut;

	// Signals for tracking the first mismatch (Combinational Logic Requirement)
	logic [1:0] first_error_inputs;
	logic first_error_out_ref;
	logic first_error_out_dut;
	integer first_mismatch_time = -1;

	initial begin 
		$dumpfile("wave.vcd");
		// Note: The original dumpvars included 'tb_mismatch' which is derived. 
		// We ensure all relevant signals are dumped.
		$dumpvars(1, tb, in1, in2, out_ref, out_dut);
	end

	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk,
		.* , // Maps in1, in2
		in1,
		in2 );
	
	// Reference Module (Assuming RefModule exists and implements NOR correctly)
	RefModule good1 (
		.in1,
		.in2,
		.out(out_ref) );
	
	// DUT Instantiation (Following input_spec and golden testbench structure)
	TopModule top_module1 (
		in1,
		in2,
		out_dut );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end
task
	
	// Verification Logic (Combinational check)
	// Logic: out_ref === (out_ref ^ out_dut ^ out_ref) which simplifies to out_ref === out_dut
	// Wait, the original logic was: assign tb_match = ( { out_ref } === ( { out_ref } ^ { out_dut } ^ { out_ref } ) );
	// Since all are 1-bit, this is: out_ref === ( out_ref ^ out_dut ^ out_ref )
	// out_ref ^ out_ref = 0. So, tb_match = ( out_ref === ( 0 ^ out_dut ) ) = ( out_ref === out_dut ).
	// Therefore, tb_match is true iff out_ref == out_dut.
	assign tb_match = ( out_ref === out_dut );

	// Clocked comparison and error counting
	always @(posedge clk, negedge clk) begin
		stats1.clocks++;
		
		// 1. Check for general mismatch (tb_match)
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			sstats1.errors++;
			end
		
		// 2. Check for specific output mismatch (out_ref !== ( out_ref ^ out_dut ^ out_ref ))
		if (out_ref !== ( out_ref ^ out_dut ^ out_ref ))
		begin 
			if (stats1.errors_out == 0) stats1.errortime_out = $time;
			sstats1.errors_out = stats1.errors_out+1'b1; 
		end
		end

		// 3. Capture state on FIRST mismatch (Combinational requirement)
		if (!tb_match && first_mismatch_time == -1) begin
			first_mismatch_time = $time;
			first_error_inputs = {in1, in2};
			first_error_out_ref = out_ref;
			first_error_out_dut = out_dut;
		end
	end

	// Timeout
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

	// Final Reporting
	initial begin
		@(negedge clk);
		$display("========================================");
		
		if (stats1.errors_out > 0) begin
			s$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_out, stats1.errortime_out);
			// Display first mismatch details as required for combinational logic
			s$display("\n--- FIRST MISMATCH DETAILS (Output) ---");
			s$display("Time: %0d ps", stats1.errortime_out);
			s$display("Inputs: in1=%b, in2=%b (Hex: %h)", first_error_inputs[0], first_error_inputs[1], first_error_inputs);
			s$display("Reference Output (Expected): %b (Hex: %h)", first_error_out_ref, first_error_out_ref);
			s$display("DUT Output (Got): %b (Hex: %h)", first_error_out_dut, first_error_out_dut);
		end else begin
			s$display("SIMULATION PASSED");
		end
		$display("========================================");
		
		$display("Total mismatched samples (tb_match): %1d out of %1d samples", stats1.errors, stats1.clocks);
		$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
		$finish;
	end
	endmodule
