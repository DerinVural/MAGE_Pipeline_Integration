		if (!tb_match && stats1.errors == 1) begin
			mismatch_inputs_state = {in1, in2};
			mismatch_outputs_state = {out_ref, out_dut};
		end
	end

   // Add timeout after 100K cycles
   initial begin
     #1000000
     $display("TIMEOUT");
     $finish();
   end

	// Final Reporting Logic (Improved)
	initial begin
		@(negedge clk);
