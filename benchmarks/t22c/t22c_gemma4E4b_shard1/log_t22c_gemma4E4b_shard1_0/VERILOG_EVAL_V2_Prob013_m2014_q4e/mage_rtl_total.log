		.* ,
		.in1,
		.in2 );
	RefModule good1 (
		.in1,
		.in2,
		.out(out_ref) );
	
	TopModule top_module1 (
		.in1,
		.in2,
		.out(out_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end
	task

	// Verification check (kept exactly as in golden testbench)
	assign tb_match = ( { out_ref } === ( { out_ref } ^ { out_dut } ^ { out_ref } ) );

	// Clocked logic for counting and state capture
always @(posedge clk, negedge clk) begin
		stats1.clocks++;
		
		// Error counting logic (General mismatch)
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			sats1.errors++; // Fixed typo here
		end
		
		// Error counting for output mismatch (stats1.errors_out)
		if (out_ref !== ( out_ref ^ out_dut ^ out_ref ))
