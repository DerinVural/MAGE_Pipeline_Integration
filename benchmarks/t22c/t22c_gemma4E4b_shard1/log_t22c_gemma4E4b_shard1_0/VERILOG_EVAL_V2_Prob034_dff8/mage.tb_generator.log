 64\n\ttask display_val(input logic [7:0] val, input string label);\n\t\t$display(\"%-10s: %h (Binary: %b)\", label, val, val);\n\tendtask\n\n\t// Function to display queue content upon first mismatch\n\ttask display_mismatch_queue();\n\t\t$display(\"======================================================================\");\n\t\t$display(\"!!! FIRST MISMATCH DETECTED AT TIME %0t !!!\", $time);\n\t\t$display(\"Showing last %0d cycles of simulation (Max Size: %0d):\n\", got_output_queue.size(), MAX_QUEUE_SIZE);\n\n\t\tfor (int i = 0; i < got_output_queue.size(); i++) begin\n\t\t\t$display(\"----------------------------------------------------------------------\");\n\t\t\t$display(\"Cycle %0d: \", i);\n\t\t\t\n\t\t\t// Display Control/Input\n\t\t\t$display(\"  Input D: \");\n\t\t\tdisplay_val(input_queue[i], \"D_in\");\n\t\t\t\n\t\t\t// Display Outputs\n\t\t\t$display(\"  Got Output Q: \");\n\t\t\tdisplay_val(got_output_queue[i], \"Q_dut\");\n\t\t\t$display(\"  Expected Output Q: \");\n\t\t\tdisplay_val(golden_queue[i], \"Q_ref\");\n\t\t\t\n\t\t\t// Display Match Status\n\t\t\tif (got_output_queue[i] === golden_queue[i]) begin\n\t\t\t\t$display(\"  STATUS: MATCHED\");\n\t\t\t\t$display(\"----------------------------------------------------------------------\");\n\t\t\t\tcontinue;\n\t\t\tend\n\t\t\t$display(\"  STATUS: MISMATCHED (Dut != Ref)\");\n\t\t\t$display(\"----------------------------------------------------------------------\");\n\t\tend\n\t\tendtask\n\n\tinitial begin \n\t\t$dumpfile(\"wave.vcd\");\n\t\t$dumpvars(1, stim1.clk, tb_mismatch ,clk,d_tb,q_ref,q_dut );\n\tend\n\n\t// Instantiate stimulus generator\n\tstimulus_gen stim1 (\n\t\t.clk, \n\t\t.d, \n\t\t.wavedrom_title, \n\t\t.wavedrom_enable \n\t);\n\n\t// Instantiate Reference Module\t\n\tRefModule good1 (\n\t\t.clk, \n\t\td_tb, \n\t\t.q(q_ref) );\n\t\n\t// Instantiate DUT\t\n\tTopModule top_module1 (\n\t\t.clk, \n\t\td_tb, \n\t\t.q(q_dut) );\n\n\t// Original wait_for_end_of_timestep task (retained for 