module tb();
	
	typedef struct packed {
		int errors;
		int errortime;
		int errors_q;
		int errortime_q;
		int clocks;
		
		// For detailed first mismatch logging
		int first_mismatch_time;
		logic [7:0] first_mismatch_d;
		logic [7:0] first_mismatch_q_dut;
		logic [7:0] first_mismatch_q_ref;
	}
	stats;
	
	stats stats1;
	
	// Helper task for formatted printing
	task print_signal_value(string signal_name, logic [7:0] value);
	begin
		$display("  %s: HEX = %h, BIN = %b", signal_name, value, value);
	end
	endtask
	
	// Helper task to display signals upon first mismatch
	task display_mismatch_details(string reason);
	begin
		$display("======================================================");
		$display("*** FIRST MISMATCH DETECTED ***");
		$display("Reason: %s", reason);
		$display("Time of first mismatch: %0d ps", stats1.first_mismatch_time);
		$display("------------------------------------------------------");
		$display("Input Signals (d): ");
		print_signal_value("d", stats1.first_mismatch_d);
		$display("Output Signals (q_dut): ");
		print_signal_value("q_dut", stats1.first_mismatch_q_dut);
		$display("Expected Output (q_ref): ");
		print_signal_value("q_ref", stats1.first_mismatch_q_ref);
		$display("======================================================");
	endtask
	endtask
	
	// =====================================================
	// Testbench Declarations
	// =====================================================
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	
	logic [7:0] d;
	logic [7:0] q_ref; // Expected output (from RefModule)
	logic [7:0] q_dut; // DUT output
	
	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	// Initial setup
	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stimulus_gen, tb);
	end
	
	// Clock generation
	initial forever
		#5 clk = ~clk;
	
	// Instantiate Stimulus Generator
	stimulus_gen stim1 (
		.clk, 
		d, 
		.wavedrom_title, 
		.wavedrom_enable 
	);
	
	// Instantiate Reference Module (Using RefModule as per golden testbench)
	RefModule good1 (
		.clk, 
		d, 
		.q(q_ref) 
	);
	
	// Instantiate DUT
	TopModule top_module1 (
		.clk, 
		d, 
		.q(q_dut) 
	);
	
	
	// Task to wait for the end of the timestep (Kept as per golden testbench)
	task wait_for_end_of_timestep;
		repeat(5) begin
		// Note: 'strobe' was not declared in the original TB, assuming it was intended to be local or part of the context
		// Since 'strobe' is missing, we simplify this task or remove it if it causes compilation issues.
		// Based on previous successful structure, we remove dependency on undeclared 'strobe'
		// If strict adherence to structure is needed, 'strobe' must be declared.
		// For compilation safety, we keep the structure but note the dependency.
		// Original logic: strobe <= !strobe; @(strobe);
		// We skip complex time-step synchronization if 'strobe' isn't defined.
		@(posedge clk);
	end
	endtask
	
	// Verification logic
	// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.
	assign tb_match = ( { q_ref } === ( { q_ref } ^ { q_dut } ^ { q_ref } ) );
	
	// Main clock and verification loop
	always @(posedge clk, negedge clk) begin
		stats1.clocks++;
		
		// Check 1: tb_match mismatch
		if (!tb_match) begin
			if (stats1.errors == 0) {
				stats1.errortime = $time;
				stats1.first_mismatch_time = $time;
				stats1.first_mismatch_d = d;
				stats1.first_mismatch_q_dut = q_dut;
				stats1.first_mismatch_q_ref = q_ref;
			}
			stats1.errors++;
		end
		
		// Check 2: Specific q_ref vs q_dut mismatch
		if (q_ref !== ( q_ref ^ q_dut ^ q_ref ))
		begin 
			if (stats1.errors_q == 0) {
				stats1.errortime_q = $time;
				stats1.first_mismatch_time = $time; // Capture time if this is the absolute first error
				stats1.first_mismatch_d = d;
				stats1.first_mismatch_q_dut = q_dut;
				stats1.first_mismatch_q_ref = q_ref;
			}
			stats1.errors_q = stats1.errors_q+1'b1;
		end
	end
	
	// Timeout mechanism
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end
	
	// Final reporting block
	final begin
		
		// Determine the absolute first mismatch time and corresponding error counts
		int final_errors = stats1.errors;
		int final_errors_q = stats1.errors_q;
		int report_errors = 0;
		int report_time = 0;
		
		if (final_errors > 0 && final_errors_q == 0) begin
			report_errors = final_errors;
			report_time = stats1.errortime;
		end else if (final_errors == 0 && final_errors_q > 0) begin
			report_errors = final_errors_q;
			report_time = stats1.errortime_q;
		end else if (final_errors > 0 && final_errors_q > 0) begin
			// Compare first recorded times
			if (stats1.errortime < stats1.errortime_q) begin
				report_errors = final_errors;
				report_time = stats1.errortime;
			end else begin
				report_errors = final_errors_q;
				report_time = stats1.errortime_q;
			end
		end
		
		if (report_errors == 0) begin
			$display("SIMULATION PASSED");
		end else begin
			// Display FIRST mismatch details only if we are reporting failure
			display_mismatch_details("Mismatch detected during simulation run.");
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", report_errors, report_time);
		end
		
		$display("------------------------------------------------------");
		$display("Total mismatched samples is %1d out of %1d samples\n", stats1.errors + stats1.errors_q, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
		$finish;
	end

endmodule
