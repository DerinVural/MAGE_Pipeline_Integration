[2026-05-14 18:01:03,399 - mage.agent - INFO] `timescale 1 ps/1 ps
`define OK 12
`define INCORRECT 13


// NOTE: stimulus_gen and RefModule are kept exactly as they were in the golden testbench 
// to maintain exact functionality and interface usage, even though they are not derived from the spec.

module stimulus_gen (
	input clk,
	output logic a,b,sel_b1, sel_b2,
	output reg[511:0] wavedrom_title,
	output reg wavedrom_enable
);

// Add two ports to module stimulus_gen:
//    output [511:0] wavedrom_title
//    output reg wavedrom_enable

	task wavedrom_start(input[511:0] title = "");
	endtask
	
	task wavedrom_stop;
		#1;
	endtask

	initial begin
		{a, b, sel_b1, sel_b2} <= 4'b000;
		@(negedge clk) wavedrom_start("");
		@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b0100;
		@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b1000;
		@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b1101;
		@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b0001;
		@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b0110;
		@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b1010;
		@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b1111;
		@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b0011;
		@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b0111;
		@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b1011;
		@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b1111;
		@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b0011;
		wavedrom_stop();
		repeat(100) @(posedge clk, negedge clk)
		{a,b,sel_b1,sel_b2} <= $urandom;
		$finish;
	end
	endmodule

module RefModule (
	input a,
	input b,
	input sel_b1,
	input sel_b2,
	output out_assign,
	output out_always
);
	// Reference MUX logic (must match TopModule specification)
	assign out_assign = (sel_b1 & sel_b2) ? b : a;
	always @* begin
		if (sel_b1 & sel_b2) 
			out_always = b;
		else 
			out_always = a;
	end
endmodule

module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_out_assign;
		int errortime_out_assign;
		int errors_out_always;
		int errortime_out_always;
		int clocks;
}
	stats stats1;
	
	
wire[511:0] wavedrom_title;
wire wavedrom_enable;
int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic a;
	logic b;
	logic sel_b1;
	logic sel_b2;
	logic out_assign_ref;
	logic out_assign_dut;
	logic out_always_ref;
	logic out_always_dut;

	
// Helper function to display signals based on width
	task display_signal(input string name, input logic value, int width = 1);
		$write("Time %0t: %s = ", $time, name);
		if (width == 1) begin
			$display("%b (0x%h)", value, value);
		end else begin
			$display("%h (Binary: %b)", value, value);
		end
		endtask

	// Mismatch display task
	task display_mismatch(input string msg, input logic a_val, input logic b_val, input logic sel_b1_val, input logic sel_b2_val, input logic expected_assign, input logic actual_assign, input logic expected_always, input logic actual_always);
		$display("===============================================================");
		$display("%s", msg);
		display_signal("Input a", a_val);
		display_signal("Input b", b_val);
		display_signal("Inputs sel_b1, sel_b2", {sel_b1_val, sel_b2_val}, 2);
		display_signal("Expected Output out_assign", expected_assign);
		display_signal("Actual Output out_assign", actual_assign);
		display_signal("Expected Output out_always", expected_always);
		display_signal("Actual Output out_always", actual_always);
		$display("===============================================================");
	endtask
	
	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stimulus_gen::stim1, tb_mismatch, a, b, sel_b1, sel_b2, out_assign_ref, out_assign_dut, out_always_ref, out_always_dut );
	end

	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk,
		a,
		b,
		.sel_b1,
		.sel_b2);
	RefModule good1 (
		a,
		b,
		.sel_b1,
		.sel_b2,
		.out_assign(out_assign_ref),
		.out_always(out_always_ref) );
	
	TopModule top_module1 (
		a,
		b,
		.sel_b1,
		.sel_b2,
		.out_assign(out_assign_dut),
		.out_always(out_always_dut) );
	
	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		endtask

	
final begin
		if (stats1.errors == 0) begin
			$display("SIMULATION PASSED");
		end else begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
		end
	end

	// Verification: Simplified match check
	assign tb_match = ( out_assign_ref === out_assign_dut ) && ( out_always_ref === out_always_dut );
	
	// Clocked check
always @(posedge clk, negedge clk) begin
		
		stats1.clocks++;
		
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
			end
		
		// Detailed check for out_assign
		if (out_assign_ref !== out_assign_dut) begin
			if (stats1.errors_out_assign == 0) stats1.errortime_out_assign = $time;
			stats1.errors_out_assign = stats1.errors_out_assign+1'b1;
			end
		
			// Display first mismatch for out_assign
			if (stats1.errors_out_assign == 1) begin
				display_mismatch("MISMATCH DETECTED on out_assign", a, b, sel_b1, sel_b2, out_assign_ref, out_assign_dut, out_always_ref, out_always_dut);
			end
			end
		
		// Detailed check for out_always
		if (out_always_ref !== out_always_dut) begin
			if (stats1.errors_out_always == 0) stats1.errortime_out_always = $time;
			stats1.errors_out_always = stats1.errors_out_always+1'b1;
			end
		
			// Display first mismatch for out_always
			if (stats1.errors_out_always == 1) begin
				display_mismatch("MISMATCH DETECTED on out_always", a, b, sel_b1, sel_b2, out_assign_ref, out_assign_dut, out_always_ref, out_always_dut);
			end
			end
		end

	// add timeout after 100K cycles
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

endmodule
