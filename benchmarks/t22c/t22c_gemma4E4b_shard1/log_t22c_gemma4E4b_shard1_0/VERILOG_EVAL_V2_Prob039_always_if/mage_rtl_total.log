    "testbench": "`timescale 1 ps/1 ps\n`define OK 12\n`define INCORRECT 13\n\n\n// --- Stimulus Generator (Copied from Golden TB for context) ---\nmodule stimulus_gen (\n\tinput clk,\n\toutput logic a,b,sel_b1, sel_b2,\n\toutput reg[511:0] wavedrom_title,\n\toutput reg wavedrom_enable\n);\n\n\t// Add two ports to module stimulus_gen:\n\t//    output [511:0] wavedrom_title\n\t//    output reg wavedrom_enable\n\n\ttask wavedrom_start(input[511:0] title = \"\");\n\tendtask\n\t\n\ttask wavedrom_stop;\n\t\t#1;\n\tendtask\t\n\n\tinitial begin\n\t\ta, b, sel_b1, sel_b2 <= 4'b000;\n\t\t@(negedge clk) wavedrom_start(\"\");\n\t\t@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b0100;\n\t\t@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b1000;\n\t\t@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b1101;\n\t\t@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b0001;\n\t\t@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b0110;\n\t\t@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b1010;\n\t\t@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b1111;\n\t\t@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b0011;\n\t\t@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b0111;\n\t\t@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b1011;\n\t\t@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b1111;\n\t\t@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b0011;\n\t\twavedrom_stop();\n\t\trepeat(100) @(posedge clk, negedge clk)\n\t\t{a,b,sel_b1,sel_b2} <= $urandom;\n\t\t\n\t$finish;\n\tend\n\t\nendmodule\n\n\n// --- DUT: TopModule Implementation ---\nmodule TopModule (\n    input  a,\n    input  b,\n    input  sel_b1,\n    input  sel_b2,\n    output out_assign,\n    output out_always\n);\n\n    // 1. Implementation using assign statements\n    assign out_assign = (sel_b1 && sel_b2) ? b : a;\n\n    // 2. Implementation using procedural if statement\n    always @* begin // Combinational sensitivity list\n        if (sel_b1 && sel_b2) begin\n            out_always = b;\n        end else begin\n            out_always = a;\n        end\n    end\n\nendmodule\n\n\n// --- Testbench ---\nmodule tb();\n\n    // Stats structure to maintain original error counting logic\n    typedef struct packed {\n        int errors;\n        int errortime;\n        int errors_out_assign;\n        int errortime_out_assign;\n        int errors_out_always;\n        int errortime_out_always;\n\n        int clocks;\n    } stats;\n    \n    stats stats1;\n    \n    // Wavedrom signals (kept for interface matching)\n    wire[511:0] wavedrom_title;\n    wire wavedrom_enable;\n    int wavedrom_hide_after_time;\n    \n    // Clock generation\n    reg clk=0;\n    initial forever\n        #5 clk = ~clk;\n\n    // DUT Signals\n    logic a; \n    logic b;\n    logic sel_b1;\n    logic sel_b2;\n    logic out_assign_ref;\n    logic out_assign_dut;\n    logic out_always_ref;\n    logic out_always_dut;\n\n    // Mismatch tracking signals and parameters\n    reg tb_match;\n    reg tb_mismatch;\n    \n    // Variables to capture state upon first mismatch (Combinational Logic requirement)\n    logic [1:0] input_capture_data;\n    logic [1:0] output_assign_capture_data;\n    logic [1:0] output_always_capture_data;\n    integer first_mismatch_time = 0;\n\n    initial begin \n        $dumpfile(\"wave.vcd\");\n        $dumpvars(1, tb, a, b, sel_b1, sel_b2, out_assign_ref, out_assign_dut, out_always_ref, out_always_dut );\n        \n        // Initialize variables\n        stats1.errors = 0;\n        stats1.errortime = 0;\n        stats1.errors_out_assign = 0;\n        stats1.errortime_out_assign = 0;\n        stats1.errors_out_always = 0;\n        stats1.errortime_out_always = 0;\n        stats1.clocks = 0;\n        \n        // Initialize control logic\n        tb_match = 1;\n        tb_mismatch = 0;\n    end\n\n\n    // Instantiate Stimulus Generator\n    stimulus_gen stim1 (\n        .clk, \n        .a, .b, .sel_b1, .sel_b2, \n        .wavedrom_title, .wav