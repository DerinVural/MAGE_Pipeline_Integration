    "testbench": "`timescale 1 ps/1 ps\n`define OK 12\n`define INCORRECT 13\n\n\n// NOTE: stimulus_gen and RefModule are kept exactly as they were in the golden testbench \n// to maintain exact functionality and interface usage, even though they are not derived from the spec.\n\nmodule stimulus_gen (\n\tinput clk,\n\toutput logic a,b,sel_b1, sel_b2,\n\toutput reg[511:0] wavedrom_title,\n\toutput reg wavedrom_enable\n);\n\n// Add two ports to module stimulus_gen:\n//    output [511:0] wavedrom_title\n//    output reg wavedrom_enable\n\n\ttask wavedrom_start(input[511:0] title = \"\");\n\tendtask\n\t\n\ttask wavedrom_stop;\n\t\t#1;\n\tendtask\n\n\tinitial begin\n\t\t{a, b, sel_b1, sel_b2} <= 4'b000;\n\t\t@(negedge clk) wavedrom_start(\"\");\n\t\t@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b0100;\n\t\t@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b1000;\n\t\t@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b1101;\n\t\t@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b0001;\n\t\t@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b0110;\n\t\t@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b1010;\n\t\t@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b1111;\n\t\t@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b0011;\n\t\t@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b0111;\n\t\t@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b1011;\n\t\t@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b1111;\n\t\t@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b0011;\n\t\twavedrom_stop();\n\t\trepeat(100) @(posedge clk, negedge clk)\n\t\t{a,b,sel_b1,sel_b2} <= $urandom;\n\t\t$finish;\n\tend\n\tendmodule\n\nmodule RefModule (\n\tinput a,\n\tinput b,\n\tinput sel_b1,\n\tinput sel_b2,\n\toutput out_assign,\n\toutput out_always\n);\n\t// Reference MUX logic (must match TopModule specification)\n\tassign out_assign = (sel_b1 & sel_b2) ? b : a;\n\talways @* begin\n\t\tif (sel_b1 & sel_b2) \n\t\t\tout_always = b;\n\t\telse \n\t\t\tout_always = a;\n\tend\nendmodule\n\nmodule tb();\n\n\ttypedef struct packed {\n\t\tint errors;\n\t\tint errortime;\n\t\tint errors_out_assign;\n\t\tint errortime_out_assign;\n\t\tint errors_out_always;\n\t\tint errortime_out_always;\n\t\tint clocks;\n}\n\tstats stats1;\n\n\nwire[511:0] wavedrom_title;\nwire wavedrom_enable;\nint wavedrom_hide_after_time;\n\t\nreg clk=0;\ninitial forever\n\t\t#5 clk = ~clk;\n\nlogic a;\nlogic b;\nlogic sel_b1;\nlogic sel_b2;\nlogic out_assign_ref;\nlogic out_assign_dut;\nlogic out_always_ref;\nlogic out_always_dut;\n\n\n// Helper function to display signals based on width\ntask display_signal(input string name, input logic value, int width = 1);\n\t$write(\"Time %0t: %s = \", $time, name);\n\tif (width == 1) begin\n\t\t$display(\"%b (0x%h)\", value, value);\n\tend else begin\n\t\t$display(\"%h (Binary: %b)\", value, value);\n\tend\n\tendtask\n\n// Mismatch display task\ntask display_mismatch(input string msg, input logic a_val, input logic b_val, input logic sel_b1_val, input logic sel_b2_val, input logic expected_assign, input logic actual_assign, input logic expected_always, input logic actual_always);\n\t$display(\"===============================================================\");\n\t$display(\"%s\", msg);\n\tdisplay_signal(\"Input a\", a_val);\n\tdisplay_signal(\"Input b\", b_val);\n\tdisplay_signal(\"Inputs sel_b1, sel_b2\", {sel_b1_val, sel_b2_val}, 2);\n\tdisplay_signal(\"Expected Output out_assign\", expected_assign);\n\tdisplay_signal(\"Actual Output out_assign\", actual_assign);\n\tdisplay_signal(\"Expected Output out_always\", expected_always);\n\tdisplay_signal(\"Actual Output out_always\", actual_always);\n\t$display(\"===============================================================\");\n\tendtask\n\t\ninitial begin \n\t\t$dumpfile(\"wave.vcd\");\n\t\t$dumpvars(1, stimulus_gen::stim1, tb_mismatch, a, b, sel_b1, sel_b2, out_assign_ref, out_assign_dut, out_always_ref, out_always_dut );\nend\n\nwire tb_match;\nwire tb_mismatch = ~tb_match;\n\t\nstimulus_gen stim1 (\n\t\t.clk,\n\t\ta,\n\tb,\t.sel_b1,\t.sel_b2);\n\tRefModule good1 (\n\t\ta,\n\tb,\t.sel_b1,\t.sel_b2,\n\t\tout_assign(out_assign_ref),\n\t\tout_always(out_always_ref) );\n\t\nTopModule top_module1 (\n\ta,\n\tb,\t.sel_b1,\t.sel_b2,\n\t\tout_assign(out_assign_dut),\n\t\tout_always(out_always_dut) );\n\t\n\n\tbit strobe = 0;\ntask wait_for_end_of_timestep;\n\t\trepeat(5) begin\n\t\tstrobe <= !strobe;  // Try to delay until the very end of the time step.\n\t\t@(strobe);\n\tendtask\n\n\nfinal begin\n\t\tif (stats1.errors == 0) begin\n\t\t\t$display(\"SIMULATION PASSED\");\n\t\tend else begin\n\t\t\t$display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\", stats1.errors, stats1.errortime);\n\t\tend\nend\n\n// Verification: Simplified match check\nassign tb_match = ( out_assign_ref === out_assign_dut ) && ( out_always_ref === out_always_dut );\n\t\n// Clocked check\nalways @(posedge clk, negedge clk) begin\n\t\t\n\t\tstats1.clocks++;\n\t\t\n\t\tif (!tb_match) begin\n\t\t\tif (stats1.errors == 0) stats1.errortime = $time;\n\t\t\tsstats1.errors++;\n\t\t\tend\n\t\t\n\t\t// Detailed check for out_assign\n\t\tif (out_assign_ref !== out_assign_dut) begin\n\t\t\tif (stats1.errors_out_assign == 0) stats1.errortime_out_assign = $time;\n\t\t\tsstats1.errors_out_assign = stats1.errors_out_assign+1'b1;\n\t\t\tend\n\t\t\n\t\t\t// Display first mismatch for out_assign\n\t\t\tif (stats1.errors_out_assign == 1) begin\n\t\t\t\tdisplay_mismatch(\"MISMATCH DETECTED on out_assign\", a, b, sel_b1, sel_b2, out_assign_ref, out_assign_dut, out_always_ref, out_always_dut);\n\t\t\tend\n\t\t\tend\n\t\t\n\t\t// Detailed check for out_always\n\t\tif (out_always_ref !== out_always_dut) begin\n\t\t\tif (stats1.errors_out_always == 0) stats1.errortime_out_always = $time;\n\t\t\tsstats1.errors_out_always = stats1.errors_out_always+1'b1;\n\t\t\tend\n\t\t\n\t\t\t// Display first mismatch for out_always\n\t\t\tif (stats1.errors_out_always == 1) begin\n\t\t\t\tdisplay_mismatch(\"MISMATCH DETECTED on out_always\", a, b, sel_b1, sel_b2, out_assign_ref, out_assign_dut, out_always_ref, out_always_dut);\n\t\t\tend\n\t\t\tend\n\t\tend\n\n// add timeout after 100K cycles\ninitial begin\n\t\t#1000000\n\t\t$display(\"TIMEOUT\");\n\t\t$finish();\nend\n\nendmodule"
}
