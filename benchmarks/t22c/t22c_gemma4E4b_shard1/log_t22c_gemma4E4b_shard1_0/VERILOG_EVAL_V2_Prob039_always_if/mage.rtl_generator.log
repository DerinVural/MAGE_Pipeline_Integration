on first mismatch (Combinational Logic reporting)\n                // Note: If this is the first mismatch overall, it was already captured above. If not, we capture it now.\n                if (first_mismatch_time == 0) begin\n                     first_mismatch_time = $time;\n                     input_capture_data = {a, b, sel_b1, sel_b2};\n                     output_assign_capture_data = {out_assign_ref, out_assign_dut};\n                     output_always_capture_data = {out_always_ref, out_always_dut};\n                end\n            end\n            stats1.errors_out_always = stats1.errors_out_always+1\'b1;\n        end\n    end\n\n    // Display Mismatch Information upon simulation end (Replaces old final block)\n    initial begin\n        // Wait for stimulus to finish its main sequence and run a few more cycles\n        @(negedge clk);\n        #50;\n        \n        if (stats1.errors == 0) begin\n            $display("SIMULATION PASSED");\n        end else begin\n            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d".\n                     , stats1.errors, stats1.errortime);\n        end\n        \n        // Detailed output for specific signal mismatches (Optional but helpful for debugging, maintaining original reporting style)\n        if (stats1.errors_out_assign > 0) begin\n            $display("Detailed Check: Output \'out_assign\' has %0d mismatches. First mismatch occurred at time %0d.", \n                     stats1.errors_out_assign, stats1.errortime_out_assign);\n            \n            // Display state at first mismatch time\n            $display("--- State at First \'out_assign\' Mismatch (Time %0d) ---", stats1.errortime_out_assign);\n            $display("Inputs: a=%b, b=%b, sel_b1=%b, sel_b2=%b", input_capture_data[0], input_capture_data[1], input_capture_data[2], input_capture_data[3]);\n            $display("Outputs: out_assign_ref=%b, out_assign_dut=%b", output_assign_capture_data[0], output_assign_cap