    // Helper function to display signals based on width
    task display_signal(input string name, input logic value, int width = 1);
        $write("Time %0t: %s = ", $time, name);
        if (width == 1) begin
            $display("%b (0x%h)", value, value);
        end else begin
            $display("%h (Binary: %b)", value, value);
        end
    endtask

    task display_mismatch(input string msg, input logic a_val, input logic b_val, input logic expected_val, input logic actual_val);
        $display("===============================================================");
        $display("%s", msg);
        display_signal("Input a", a_val);
        display_signal("Input b", b_val);
        display_signal("Inputs sel_b1, sel_b2", {sel_b1, sel_b2}, 2); // Displaying control signals
        display_signal("Expected Output", expected_val);
        display_signal("Actual Output", actual_val);
        $display("===============================================================");
    endtask

	initial begin 
		$dumpfile("wave.vcd");
