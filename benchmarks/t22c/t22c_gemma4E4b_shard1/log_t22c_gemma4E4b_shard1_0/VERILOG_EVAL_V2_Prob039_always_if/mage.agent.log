		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
			end
		
		// Detailed check for out_assign
		if (out_assign_ref !== out_assign_dut) begin
			if (stats1.errors_out_assign == 0) stats1.errortime_out_assign = $time;
			sstats1.errors_out_assign = stats1.errors_out_assign+1'b1;
			end
			// Display first mismatch for out_assign
			if (stats1.errors_out_assign == 1) begin
				display_mismatch("MISMATCH DETECTED on out_assign", a, b, out_assign_ref, out_assign_dut);
			end
		end
		
		// Detailed check for out_always
		if (out_always_ref !== out_always_dut) begin
			if (stats1.errors_out_always == 0) stats1.errortime_out_always = $time;
			sstats1.errors_out_always = stats1.errors_out_always+1'b1;
			end
			// Display first mismatch for out_always
			if (stats1.errors_out_always == 1) begin
				display_mismatch("MISMATCH DETECTED on out_always", a, b, out_always_ref, out_always_dut);
			end
		end
		end

