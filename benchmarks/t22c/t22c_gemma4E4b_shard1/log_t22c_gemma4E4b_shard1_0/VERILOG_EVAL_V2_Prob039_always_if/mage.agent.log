		@(strobe);
		endtask
	
	
	final begin
		if (stats1.errors_out_assign > 0) $display("Hint: Output 'out_assign' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_out_assign, stats1.errortime_out_assign);
		else $display("Hint: Output 'out_assign' has no mismatches.");
		if (stats1.errors_out_always > 0) $display("Hint: Output 'out_always' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_out_always, stats1.errortime_out_always);
		else $display("Hint: Output 'out_always' has no mismatches.");

		$display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
		$display("Final Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
		
