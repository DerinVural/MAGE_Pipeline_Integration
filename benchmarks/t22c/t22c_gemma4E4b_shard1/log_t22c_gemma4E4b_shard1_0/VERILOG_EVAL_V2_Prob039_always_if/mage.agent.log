// --- Stimulus Generator (Copied from Golden TB for context) ---
module stimulus_gen (
	input clk,
	output logic a,b,sel_b1, sel_b2,
	output reg[511:0] wavedrom_title,
	output reg wavedrom_enable
);

	// Add two ports to module stimulus_gen:
	//    output [511:0] wavedrom_title
	//    output reg wavedrom_enable

	task wavedrom_start(input[511:0] title = "");
	endtask
	
	task wavedrom_stop;
		#1;
	endtask	

	initial begin
		a, b, sel_b1, sel_b2 <= 4'b000;
		@(negedge clk) wavedrom_start("");
		@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b0100;
		@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b1000;
		@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b1101;
		@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b0001;
		@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b0110;
		@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b1010;
		@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b1111;
		@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b0011;
		@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b0111;
		@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b1011;
		@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b1111;
		@(posedge clk, negedge clk) {a,b,sel_b1,sel_b2} <= 4'b0011;
		wavedrom_stop();
		repeat(100) @(posedge clk, negedge clk)
		{a,b,sel_b1,sel_b2} <= $urandom;
		
	$finish;
	end
	
endmodule


// --- DUT: TopModule Implementation ---
module TopModule (
    input  a,
    input  b,
    input  sel_b1,
    input  sel_b2,
    output out_assign,
    output out_always
);

    // 1. Implementation using assign statements
    assign out_assign = (sel_b1 && sel_b2) ? b : a;

    // 2. Implementation using procedural if statement
    always @* begin // Combinational sensitivity list
        if (sel_b1 && sel_b2) begin
            out_always = b;
        end else begin
            out_always = a;
        end
    end

endmodule


// --- Testbench ---
module tb();

    // Stats structure to maintain original error counting logic
    typedef struct packed {
        int errors;
        int errortime;
        int errors_out_assign;
        int errortime_out_assign;
        int errors_out_always;
        int errortime_out_always;

        int clocks;
    } stats;
    
    stats stats1;
    
    // Wavedrom signals (kept for interface matching)
    wire[511:0] wavedrom_title;
    wire wavedrom_enable;
    int wavedrom_hide_after_time;
    
    // Clock generation
    reg clk=0;
    initial forever
        #5 clk = ~clk;

    // DUT Signals
    logic a; 
    logic b;
    logic sel_b1;
    logic sel_b2;
    logic out_assign_ref;
    logic out_assign_dut;
    logic out_always_ref;
    logic out_always_dut;

    // Mismatch tracking signals and parameters
    reg tb_match;
    reg tb_mismatch;
    
    // Variables to capture state upon first mismatch (Combinational Logic requirement)
    logic [1:0] input_capture_data;
    logic [1:0] output_assign_capture_data;
    logic [1:0] output_always_capture_data;
    integer first_mismatch_time = 0;

    initial begin 
        $dumpfile("wave.vcd");
        $dumpvars(1, tb, a, b, sel_b1, sel_b2, out_assign_ref, out_assign_dut, out_always_ref, out_always_dut );
        
        // Initialize variables
        stats1.errors = 0;
        stats1.errortime = 0;
        stats1.errors_out_assign = 0;
        stats1.errortime_out_assign = 0;
        stats1.errors_out_always = 0;
        stats1.errortime_out_always = 0;
        stats1.clocks = 0;
        
        // Initialize control logic
        tb_match = 1;
        tb_mismatch = 0;
    end


    // Instantiate Stimulus Generator
    stimulus_gen stim1 (
        .clk, 
        .a, .b, .sel_b1, .sel_b2, 
        .wavedrom_title, .wavedrom_enable
    );

    // Reference Model (Golden) Instantiation
    RefModule good1 (
        .a, .b, .sel_b1, .sel_b2,
        .out_assign(out_assign_ref),
        .out_always(out_always_ref) 
    );
        
    // DUT Instantiation
    TopModule top_module1 (
        .a, .b, .sel_b1, .sel_b2,
        .out_assign(out_assign_dut),
        .out_always(out_always_dut) 
    );

    // Task to wait for time step end (Kept from golden TB)
    bit strobe = 0;
    task wait_for_end_of_timestep;
        repeat(5) begin
            strobe <= !strobe;  // Try to delay until the very end of the time step.
            @(strobe);
        end
    endtask


    // --- Verification Logic ---
    
    // The original complex XOR logic for tb_match is maintained for strict compatibility,
    // although it simplifies to (ref === dut).
    assign tb_match = ( { out_assign_ref, out_always_ref } === ( { out_assign_ref, out_always_ref } ^ { out_assign_dut, out_always_dut } ^ { out_assign_ref, out_always_ref } ) );

    // Clocked logic to count errors and capture state on mismatch (Rule 3 & 4 for combinational logic)
    always @(posedge clk, negedge clk) begin
        stats1.clocks++;

        // Check overall match
        if (!tb_match) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
        end

        // --- Check out_assign Mismatch ---
        // Original check: out_assign_ref !== ( out_assign_ref ^ out_assign_dut ^ out_assign_ref )
        if (out_assign_ref !== ( out_assign_ref ^ out_assign_dut ^ out_assign_ref ))
        begin 
            if (stats1.errors_out_assign == 0) begin
                stats1.errortime_out_assign = $time;
                // Capture state upon first mismatch (Combinational Logic reporting)
                first_mismatch_time = $time;
                input_capture_data = {a, b, sel_b1, sel_b2};
                output_assign_capture_data = {out_assign_ref, out_assign_dut};
                output_always_capture_data = {out_always_ref, out_always_dut};
            end
            stats1.errors_out_assign = stats1.errors_out_assign+1'b1;
        end

        // --- Check out_always Mismatch ---
        // Original check: out_always_ref !== ( out_always_ref ^ out_always_dut ^ out_always_ref )
        if (out_always_ref !== ( out_always_ref ^ out_always_dut ^ out_always_ref ))
        begin 
            if (stats1.errors_out_always == 0) begin
                stats1.errortime_out_always = $time;
                // Capture state upon first mismatch (Combinational Logic reporting)
                // Note: If this is the first mismatch overall, it was already captured above. If not, we capture it now.
                if (first_mismatch_time == 0) begin
                     first_mismatch_time = $time;
                     input_capture_data = {a, b, sel_b1, sel_b2};
                     output_assign_capture_data = {out_assign_ref, out_assign_dut};
                     output_always_capture_data = {out_always_ref, out_always_dut};
                end
            end
            stats1.errors_out_always = stats1.errors_out_always+1'b1;
        end
    end

    // Display Mismatch Information upon simulation end (Replaces old final block)
    initial begin
        // Wait for stimulus to finish its main sequence and run a few more cycles
        @(negedge clk);
        #50;
        
        if (stats1.errors == 0) begin
            $display("SIMULATION PASSED");
        end else begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d".
                     , stats1.errors, stats1.errortime);
        end
        
        // Detailed output for specific signal mismatches (Optional but helpful for debugging, maintaining original reporting style)
        if (stats1.errors_out_assign > 0) begin
            $display("Detailed Check: Output 'out_assign' has %0d mismatches. First mismatch occurred at time %0d.", 
                     stats1.errors_out_assign, stats1.errortime_out_assign);
            
            // Display state at first mismatch time
            $display("--- State at First 'out_assign' Mismatch (Time %0d) ---", stats1.errortime_out_assign);
            $display("Inputs: a=%b, b=%b, sel_b1=%b, sel_b2=%b", input_capture_data[0], input_capture_data[1], input_capture_data[2], input_capture_data[3]);
            $display("Outputs: out_assign_ref=%b, out_assign_dut=%b", output_assign_capture_data[0], output_assign_capture_data[1]);
        end
        
        if (stats1.errors_out_always > 0) begin
            $display("Detailed Check: Output 'out_always' has %0d mismatches. First mismatch occurred at time %0d.", 
                     stats1.errors_out_always, stats1.errortime_out_always);
            
            // Display state at first mismatch time (if not already displayed by out_assign)
            if (stats1.errors_out_always > 0 && stats1.errors_out_assign == 0) begin
                 $display("--- State at First 'out_always' Mismatch (Time %0d) ---", stats1.errortime_out_always);
                 $display("Inputs: a=%b, b=%b, sel_b1=%b, sel_b2=%b", input_capture_data[0], input_capture_data[1], input_capture_data[2], input_capture_data[3]);
                 $display("Outputs: out_always_ref=%b, out_always_dut=%b", output_always_capture_data[0], output_always_capture_data[1]);
            end
        end
        
        $display("Simulation finished at %0d ps", $time);
        $display("Total Mismatches (All Outputs): %1d in %1d samples", stats1.errors, stats1.clocks);
        
        $finish;
    end

    // Timeout mechanism (Kept from golden TB)
    initial begin
     #1000000
     $display("TIMEOUT");
     $finish();
    end

endmodule

