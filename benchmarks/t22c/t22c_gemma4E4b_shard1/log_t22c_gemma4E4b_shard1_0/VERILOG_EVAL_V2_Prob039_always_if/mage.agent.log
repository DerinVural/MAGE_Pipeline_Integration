	// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.
	// Simplified: tb_match is true if the reference equals the DUT.
	assign tb_match = ( out_assign_ref === out_assign_dut ) && ( out_always_ref === out_always_dut );
	
