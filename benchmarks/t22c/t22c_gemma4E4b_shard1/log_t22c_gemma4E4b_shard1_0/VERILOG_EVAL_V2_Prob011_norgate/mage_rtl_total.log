	reg first_mismatch_detected = 0;
	reg first_mismatch_time_captured = 0;
	
	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch, a, b, out_ref, out_dut );
	end

	
