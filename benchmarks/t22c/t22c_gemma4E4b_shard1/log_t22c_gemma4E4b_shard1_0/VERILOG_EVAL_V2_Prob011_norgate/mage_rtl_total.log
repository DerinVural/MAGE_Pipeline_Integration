		// DUT: out_dut = NOR(a, b) => out_dut = ~(a | b)
		tb_match = (out_ref === out_dut);
	end

	// Clocked logic for error counting (maintaining original structure)
	always @(posedge clk, negedge clk) begin
		stats1.clocks++;
		
