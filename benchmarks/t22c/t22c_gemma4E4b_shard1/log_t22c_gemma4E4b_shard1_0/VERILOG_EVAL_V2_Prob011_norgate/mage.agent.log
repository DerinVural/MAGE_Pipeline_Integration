// Stimulus Generator (Must be kept exactly as provided)
module stimulus_gen (
	input clk,
	output reg a, b,
	output reg[511:0] wavedrom_title,
	output reg wavedrom_enable
);

	task wavedrom_start(input[511:0] title = "");
	endtask
	
	task wavedrom_stop;
		h#1;
	endtask	

	initial begin
		int count; count = 0;
		{a,b} <= 1'b0;
		wavedrom_start("NOR gate");
		repeat(10) @(posedge clk)
			{a,b} <= count++;	
		wavedrom_stop();
		
		repeat(200) @(posedge clk, negedge clk)
			{b,a} <= $random;
		
		#1 $finish;
	end
	endmodule

// Testbench Module
module tb();
	
typeof struct packed {
		int errors;
		int errortime;
		int errors_out;
		int errortime_out;

		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic a;
	logic b;
	logic out_ref;
	logic out_dut;

	reg tb_match = 1'b1;
	
	// Flag to capture state only on the FIRST mismatch
	reg first_mismatch_captured = 0;

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stimulus_gen::clk, tb_mismatch ,a,b,out_ref,out_dut );
	end

	// Instance the stimulus generator
	stimulus_gen stim1 (
		.clk, 
		.* , 
		.a, 
		.b );

	// Reference Model (Golden Reference)
	RefModule good1 (
		.a, 
		.b, 
		.out(out_ref) );
	
	// DUT Instantiation
	TopModule top_module1 (
		.a, 
		.b, 
		.out(out_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end
task

	// Combinational check for mismatch (This drives tb_match)
	always @(*) begin
		// For combinational logic, we check inputs vs outputs
		// Ref: out_ref = NOR(a, b) => out_ref = ~(a | b)
		// DUT: out_dut = NOR(a, b) => out_dut = ~(a | b)
		tb_match = (out_ref === out_dut);
	end

	// Clocked logic for error counting (maintaining original structure)
	always @(posedge clk, negedge clk) begin
		stats1.clocks++;
		
		// Error counting based on original logic
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			sstats1.errors++;
		end

		// Output specific error counting
		if (out_ref !== out_dut) begin 
			if (stats1.errors_out == 0) stats1.errortime_out = $time;
			sstats1.errors_out = stats1.errors_out+1'b1; 
		end
		end

	// COMBINATIONAL MISMATCH CAPTURE (Requirement 2)
	// This block executes whenever the combinational assignment changes and detects a mismatch.
	always @(*) begin
		if (!tb_match && !first_mismatch_captured) begin
			// Capture state on the first mismatch
			$display("========================================================");
			$display("*** FIRST MISMATCH DETECTED AT TIME %0t ***", $time);
			$display("--------------------------------------------------------");
			$display("Inputs: a=%b (%h), b=%b (%h)", a, a, b, b);
			$display("Reference Output (Expected): out_ref=%b (%h)", out_ref, out_ref);
			$display("DUT Output (Actual): out_dut=%b (%h)", out_dut, out_dut);
			$display("========================================================");
			first_mismatch_captured = 1;
		end
	end

	// Timeout
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

	// Finalization logic (Updated to match required output format)
	final begin
		if (stats1.errors_out) begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_out, stats1.errortime_out);
		end
		else begin
			$display("SIMULATION PASSED");
		end
		
		$display("--- Summary ---");
		$display("Total mismatched samples: %1d out of %1d samples", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
	end

endmodule

