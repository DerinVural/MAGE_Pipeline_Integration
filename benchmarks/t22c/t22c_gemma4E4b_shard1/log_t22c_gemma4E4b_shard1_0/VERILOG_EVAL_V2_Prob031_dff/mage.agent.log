// --- TopLevel Testbench ---
module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_q;
		int errortime_q;

		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		h#5 clk = ~clk;

	logic d;
	logic q_ref;
	logic q_dut;

	// --- Queueing Setup for Sequential Mismatch Logging ---
	// Since TopModule is sequential (DFF), we use queues.
	// MAX_QUEUE_SIZE <= 10 as per requirements.
	localparam MAX_QUEUE_SIZE = 10;

	// Inputs (clk is handled by clocking, d is the main input)
	logic [0:0] input_d_queue [$];
	logic [0:0] input_clk_queue [$]; // Storing clk state for context
	
	// Outputs
	logic [0:0] got_output_queue [$]; // q_dut
	logic [0:0] golden_queue [$];   // q_ref

	// Reset (Not explicitly used in DUT, but included for completeness)
	logic reset_queue [$];

	// --- Simulation Control and Monitoring ---
	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	// Task to handle queueing and mismatch checking
	task queue_monitor;
		begin
			// 1. Manage Queue Size
			if (input_d_queue.size() >= MAX_QUEUE_SIZE - 1) begin
				input_d_queue.delete(0);
				input_clk_queue.delete(0);
				got_output_queue.delete(0);
				golden_queue.delete(0);
				reset_queue.delete(0);
			end

			// 2. Push current state data
			input_d_queue.push_back(d);
			input_clk_queue.push_back(clk);
			got_output_queue.push_back(q_dut);
			golden_queue.push_back(q_ref);
			reset_queue.push_back(1'b0); // Assuming no reset is actively used

			// 3. Check for first mismatch based on tb_match
			if (tb_mismatch && stats1.errors == 0) begin
				$display("
============================================================");
				$display("QUEUE-BASED SIMULATION MISMATCH DETECTED AT TIME %0t", $time);
				$display("============================================================");
				$display("Last %0d cycles stored for analysis:", input_d_queue.size());
				
				for (int i = 0; i < input_d_queue.size(); i++) begin
					if (got_output_queue[i] === golden_queue[i]) begin
					$display("Cycle %0d: Match (Got: %b, Exp: %b)", i, got_output_queue[i], golden_queue[i]);
					// Original logic was confusing, simplifying display for queue context
				end else begin
					$display("Cycle %0d: MISMATCH! (Got: %b, Exp: %b) @ Time %0t", i, got_output_queue[i], golden_queue[i], $time - (i * 10)); // Approximate time
				end
				end
		end
	endtask

	// --- Initial Blocks ---
	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,clk,d,q_ref,q_dut );
	end

	// Instantiate stimulus generator (Kept as is)
	stimulus_gen stim1 (
		.clk, 
		.* , 
		d);

	// Instantiate Reference Module (Kept as is)
	RefModule good1 (
		.clk,
		d,
		.q(q_ref) );

	// Instantiate DUT	(Matches interface derived from usage)
	TopModule top_module1 (
		.clk,
		d,
		.q(q_dut) );

	// Task wait_for_end_of_timestep (Kept as is)
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end
	task

	// Clocking and Verification Logic
	always @(posedge clk, negedge clk) begin
		stats1.clocks++;
		
		// Original mismatch counting
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
		end
		
		// Original q_ref check (likely redundant given tb_match, but maintained)
		if (q_ref !== ( q_ref ^ q_dut ^ q_ref ))
		begin 
			if (stats1.errors_q == 0) stats1.errortime_q = $time;
			sats1.errors_q = stats1.errors_q+1'b1; 
		end
		end

		// Run Queue Monitor logic on the same clock edge
		queue_monitor();
	end

	// Original final block logic (Modified for required success/failure message)
	final begin
		if (stats1.errors_q > 0) 
			s$display("Hint: Output 'q' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_q, stats1.errortime_q);
		else
			s$display("Hint: Output 'q' has no mismatches.");

		$display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
		
		// REQUIRED FINAL DISPLAY FORMAT
		if (stats1.errors == 0) begin
			s$display("SIMULATION PASSED");
		end else begin
			s$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
		end
	end

	// add timeout after 100K cycles (Kept as is)
	initial begin
		h#1000000
		$display("TIMEOUT");
		$finish();
	end

endmodule

