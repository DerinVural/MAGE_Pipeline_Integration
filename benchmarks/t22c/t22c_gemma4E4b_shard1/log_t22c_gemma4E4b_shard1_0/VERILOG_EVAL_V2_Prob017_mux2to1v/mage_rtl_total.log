`define OK 12
`define INCORRECT 13


// --- Stimulus Generator (Kept as is, as per rule 1) ---
module stimulus_gen (
	input clk,
	output logic [99:0] a,b,
	output logic sel,
	output reg[511:0] wavedrom_title,
	output reg wavedrom_enable 
);

	// Add two ports to module stimulus_gen:
	//    output [511:0] wavedrom_title
	//    output reg wavedrom_enable

	task wavedrom_start(input[511:0] title = "");
	endtask
	
	task wavedrom_stop;
		h#1;
	endtask	

		initial begin
		a <= 'hdeadbeef;
		b <= 'h5eaf00d;
		sel <= 0;
		@(negedge clk);
		wavedrom_start("Beef or seafood?");
		repeat(6) @(posedge clk) sel <= ~sel;
		@(negedge clk);
		wavedrom_stop();
		repeat(100) @(posedge clk, negedge clk)
		{a,b,sel} <= {$random, $random, $random, $random, $random, $random, $random};
		$finish;
	end
	
endmodule


// --- Top Level Testbench (Modified) ---
module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_out;
		int errortime_out;

		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		h#5 clk = ~clk;

	logic [99:0] a;
	logic [99:0] b;
	logic sel;
	logic [99:0] out_ref;
	logic [99:0] out_dut;

	// Combined tracking for the very first mismatch across both checks
	int total_errors = 0;
	int first_mismatch_time = 0;
	
	initial begin 
		$dumpfile("wave.vcd");
		// Note: stim1 is used here, assuming it is the instance name for stimulus_gen
		$dumpvars(1, stim1.clk, tb_mismatch ,a,b,sel,out_ref,out_dut );
	end


	wire tb_match;		// Verification
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk,
		.a, // Replaced .* with explicit mapping based on spec/tb structure
		b, 
		sel, 
		wavedrom_title, 
		wavedrom_enable 
	);
	
	RefModule good1 (
		.a,
		b,
		.sel,
		.out(out_ref) );
	
	TopModule top_module1 (
		a,
		b,
		.sel,
		.out(out_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end	task

		// Main simulation loop execution
		@(posedge clk);
		wait_for_end_of_timestep();
		end

		// Verification logic moved into the main cycle to capture time accurately
		
		// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.
		assign tb_match = ( { out_ref } === ( { out_ref } ^ { out_dut } ^ { out_ref } ) );
		
		stats1.clocks++;
		
		// Check 1: tb_match
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
			
			if (stats1.errors < total_errors) begin
				total_errors = stats1.errors;
				first_mismatch_time = stats1.errortime;
			end
		end

		// Check 2: Direct comparison (equivalent to stats1.errors_out tracking)
		if (out_ref !== ( out_ref ^ out_dut ^ out_ref ))
		begin 
			if (stats1.errors_out == 0) stats1.errortime_out = $time;
			s	stats1.errors_out = stats1.errors_out+1'b1; 
			
				if (stats1.errors_out < total_errors) begin
				total_errors = stats1.errors_out;
				first_mismatch_time = stats1.errortime_out;
			end
		end
		end


		// Original clock/mismatch tracking (kept for functional equivalence to golden) 
		// The logic above supersedes this for final output reporting.
		always @(posedge clk, negedge clk) begin
			stats1.clocks++;
			if (!tb_match) begin
				if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
			end
			if (out_ref !== ( out_ref ^ out_dut ^ out_ref ))
			begin if (stats1.errors_out == 0) stats1.errortime_out = $time;
				s	stats1.errors_out = stats1.errors_out+1'b1; 
			end
		end

	end


	// --- Final Reporting Block (Improved) ---
	initial begin
		@(negedge clk);
		// Wait a short time after simulation is expected to finish, or use $finish() detection.
		end

		// Final check and display
		if (total_errors == 0) begin
			$display("SIMULATION PASSED");
			// Keep original success hint structure for debugging if needed, but prioritize the required message.
			end
		else begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", total_errors, first_mismatch_time);
			
			// Display details of the first mismatch
			$display("\n--- FIRST MISMATCH DETAILS (Time: %0d ps) ---", first_mismatch_time);
			
			// Display Inputs
			$display("Inputs at first mismatch:");
			$display("  a (HEX): %h | a (BIN): %b", a, a);
			$display("  b (HEX): %h | b (BIN): %b", b, b);
			$display("  sel (BIN): %b", sel);
			
			// Display Outputs
			$display("Outputs at first mismatch:");
			$display("  out_dut (HEX): %h | out_dut (BIN): %b", out_dut, out_dut);
			$display("  out_ref (HEX): %h | out_ref (BIN): %b", out_ref, out_ref);
			end
		
		// Final summary based on original structure
		$display("\n--- SUMMARY ---");
		$display("Total mismatched samples (tb_match): %1d out of %1d samples", stats1.errors, stats1.clocks);
		$display("Total mismatched samples (direct check): %1d out of %1d samples", stats1.errors_out, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
	end


	// add timeout after 100K cycles
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

endmodule

// Dummy modules required for compilation based on testbench usage
module RefModule (input logic [99:0] a, input logic [99:0] b, input logic sel, output logic [99:0] out);
    assign out = sel ? b : a;
endmodule

// TopModule instance definition (matching interface derived from testbench)
module TopModule (
    input  logic [99:0] a,
    input  logic [99:0] b,
    input  logic sel,
    output logic [99:0] out
);
    // 2-1 MUX implementation
    assign out = sel ? b : a;
endmodule

