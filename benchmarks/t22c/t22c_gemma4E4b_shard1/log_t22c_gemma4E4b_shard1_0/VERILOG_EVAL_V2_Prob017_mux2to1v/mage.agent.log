				total_mismatches = 1; 
				first_mismatch_time = $time;
				mismatch_detected = 1;
			end
		end
		
		stats1.clocks++;
	end
	
	// Ensure loop terminates near expected end time if stimulus finishes early
initial begin
	@(negedge clk);
end

