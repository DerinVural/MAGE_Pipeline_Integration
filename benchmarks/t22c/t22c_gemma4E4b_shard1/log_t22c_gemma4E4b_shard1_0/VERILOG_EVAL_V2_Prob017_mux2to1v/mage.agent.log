			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d.", stats1.errors_out, stats1.errortime_out);
		
		// Detailed display for the FIRST mismatch detected by the main verification (tb_mismatch)
		if (stats1.errors > 0 && stats1.errortime != 0) begin
			$display("\n============================================================");
			$display("!!! FIRST VERIFICATION MISMATCH DETECTED !!!");
			$display("Time of first mismatch: %0d ps", stats1.errortime);
			$display("--- Inputs --- ");
			$display("a: %h (Binary representation is too long for standard display)", a);
			$display("b: %h (Binary representation is too long for standard display)", b);
			$display("sel: %b", sel);
			$display("--- Outputs --- ");
			$display("Expected (out_ref): %h", out_ref);
			$display("Actual (out_dut): %h", out_dut);
			$display("============================================================\n");
		end
		
		$display("Total mismatches detected by main verification (tb_mismatch): %0d out of %0d samples.", stats1.errors, stats1.clocks);
		$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d.", stats1.errors, stats1.errortime);
		
		// The specific error count from the original TB (errors_out) is reported above.
		
		
		
		$finish;
	end

	// The original final block structure is replaced above to meet the strict required output format.

   // add timeout after 100K cycles
   initial begin
     #1000000
     if (!stats1.errors_out && stats1.errors == 0)
     begin
        $display("SIMULATION PASSED");
        $finish();
     end
     else
     begin
        // If timeout occurs before verification concludes, we rely on the final block above.
        $display("TIMEOUT REACHED. Simulation halted before full verification.");
        $finish();
     end
   end

endmodule

