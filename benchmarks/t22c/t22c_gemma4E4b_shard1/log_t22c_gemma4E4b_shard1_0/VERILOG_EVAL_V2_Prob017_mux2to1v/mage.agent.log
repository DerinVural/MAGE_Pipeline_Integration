	logic [99:0] b;
	logic sel;
	logic [99:0] out_ref;
	logic [99:0] out_dut;

	// Simulation Dump Setup
	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stimulus_gen::clk, tb_mismatch, a, b, sel, out_ref, out_dut );
	end

	wire tb_match; 
	wire tb_mismatch = ~tb_match;
	
	// Instantiate Stimulus Generator
	stimulus_gen stim1 (
		.clk, 
		.a, 
		b, 
		.sel, 
		wavedrom_title, 
		wavedrom_enable
	);
	
