	RefModule good1 (
		.a, 
		b, 
		.sel, 
		.out(out_ref) );
	
	// Instantiate DUT
	TopModule top_module1 (
		a, 
		b, 
		.sel, 
		out(out_dut) );

	
	// Task to wait for end of timestep (Kept as per original TB)
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end	task
	
