	// Since TopModule is sequential (4-bit counter), MAX_QUEUE_SIZE must be at least 2^4 = 16. 
	// Adhering to the strict constraint: NEVER set MAX_QUEUE_SIZE > 10.
	localparam MAX_QUEUE_SIZE = 10;

	reg [3:0] input_queue [$];
	reg [3:0] got_output_queue [$];
	reg [3:0] golden_queue [$];	
	// Reset queue tracks the state of the reset signal at the sampling edge
	reg reset_queue [$];

	// Variables to track first mismatch time/count using the queue structure
	integer first_mismatch_time = -1;
	integer total_mismatches = 0;

	initial begin
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,clk,reset,q_ref,q_dut );
	end


	wire tb_match; 
	// Original verification logic: ( { q_ref } === ( { q_ref } ^ { q_dut } ^ { q_ref } ) ) is equivalent to q_ref === q_dut
	wire tb_mismatch = q_ref !== q_dut;

	stimulus_gen stim1 (
		.clk, 
		.reset, 
		.tb_match, 
		wavedrom_enable, 
		wavedrom_title 
	);
	
	// Golden reference model (Must match specification) 
	RefModule good1 (
		.clk, 
		.reset, 
		.q(q_ref) 
	);

	// DUT instantiation
	TopModule top_module1 (
		.clk,
		.reset,
		.q(q_dut) 
	);

	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		endtask

	// --- Queue Management and Mismatch Checking ---
	// Check on the clock edge corresponding to the data capture
	always @(posedge clk, negedge clk) begin

		// 1. Handle Queue Sliding (Dequeue oldest element if full)
		if (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin
			input_queue.delete(0);
			got_output_queue.delete(0);
			golden_queue.delete(0);
			reset_queue.delete(0);
		end

		// 2. Store current cycle data
		input_queue.push_back(reset); // Input data for sequential logic is often the reset signal for state capture
		got_output_queue.push_back(q_dut);
		golden_queue.push_back(q_ref);
		reset_queue.push_back(reset);

		// 3. Check for first mismatch and track errors
		if (tb_mismatch) begin
			// Track total errors (Original functionality)
			total_mismatches++;
			if (first_mismatch_time == -1) begin
				first_mismatch_time = $time;
			end

			// Check for first error queue tracking (Original functionality using errors_q)
			if (stats1.errors_q == 0) stats1.errortime_q = $time;
			s$display("--- MISMATCH DETECTED AT TIME %0d --- ", $time);
			s$display("Displaying last %0d cycles before mismatch.", input_queue.size());

			// Display Queue Content on first mismatch
			for (int i = 0; i < input_queue.size(); i++) begin
				// Check if the current cycle in the queue matched
				if (got_output_queue[i] === golden_queue[i]) begin
					s$display("Cycle %d: Match", i);
				end else begin
					s$display("Cycle %d: MISMATCH", i);
				end

				// Display required format: Cycle, reset, input (reset state), got output, exp output
				s$display("Cycle %d, reset %b, input %b, got output %h (%b), exp output %h (%b)",
				i,
				reset_queue[i],
				input_queue[i],
				got_output_queue[i],
				got_output_queue[i], // Display in binary format
				golden_queue[i],
				golden_queue[i]  // Display in binary format
			); 
			end
		end
		
		// Update stats for original final reporting
		stats1.clocks++;
		if (!tb_match) begin
			s$display("Original Error Count Increment: %0d", stats1.errors);
			s$display("Original Error Time Update: %0d", stats1.errortime);
			stats1.errors++;
			end
		end

	// --- End Queue Management ---

	// add timeout after 100K cycles
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end


	// Final Reporting Logic
	initial begin
		@(negedge clk);
		#1; // Wait slightly after the last clocked event
		
		if (total_mismatches == 0) begin
			s$display("SIMULATION PASSED");
			// Retaining original pass message structure if needed, but prioritizing the strict requirement.
			and $display("Hint: Output 'q' has no mismatches.");
		end else begin
			s$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", 
				total_mismatches, first_mismatch_time);
			// Retaining original failure message structure.
			s$display("Hint: Output 'q' has %0d mismatches. First mismatch occurred at time %0d.", 
			total_mismatches, first_mismatch_time);
		end
		
		$display("Total mismatched samples tracked by original counter is %1d out of %1d samples", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
		end

endmodule

