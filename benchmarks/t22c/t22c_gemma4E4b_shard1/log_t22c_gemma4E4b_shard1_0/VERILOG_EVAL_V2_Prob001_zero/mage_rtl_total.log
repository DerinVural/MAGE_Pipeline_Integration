		$display("Expected Output Signals (Reference): zero = %b (HEX: %h)", zero_ref, zero_ref);
		$display("-----------------------------------------------------------------");
	end
	end

	// add timeout after 100K cycles
	initial begin
		h#1000000
		$display("TIMEOUT");
		$finish();
	end

endmodule
