	typedef struct packed {
		int errors;
		int errortime;
		int errors_zero;
		int errortime_zero;
		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic zero_ref;
	logic zero_dut;

	// Variables to capture first mismatch details for combinational display
	logic mismatch_captured = 0;
	logic [511:0] captured_input_data = 0;
	logic captured_got_output = 0;
	logic captured_golden_output = 0;

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,zero_ref,zero_dut );
	end


	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk,
		.*  );
	RefModule good1 (
		.zero(zero_ref) );
		
	TopModule top_module1 (
		.zero(zero_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end
	task
	
		// Combinational Mismatch Display Logic (Rule 2)
		always @(*) begin
			if (tb_mismatch && !mismatch_captured) begin
				mismatch_captured = 1;
				// Record the state at the time of first mismatch
				captured_got_output = zero_dut;
				captured_golden_output = zero_ref;
				// Input is implicitly zero_ref as the driving reference
				captured_input_data = zero_ref;
				
				$display("\n==================================================================");
				$display("!!! FIRST COMBINATIONAL MISMATCH DETECTED at time %0t !!!", $time);
				$display("------------------------------------------------------------------");
				$display("Expected (Golden) Output (zero_ref): %b (%h)", captured_golden_output, captured_golden_output);
				$display("Actual DUT Output (zero_dut):     %b (%h)", captured_got_output, captured_got_output);
				$display("Input Reference (zero_ref):     %b (%h)", captured_input_data, captured_input_data);
				$display("==================================================================\n");
				if (tb_mismatch) begin
					// Update error stats using the original sequential counting logic
					if (stats1.errors == 0) stats1.errortime = $time;
					stats1.errors++;
				end
				
				// Update zero mismatch stats using original logic
				if (zero_ref !== ( zero_ref ^ zero_dut ^ zero_ref ))
				begin 
					if (stats1.errors_zero == 0) stats1.errortime_zero = $time;
					sstats1.errors_zero = stats1.errors_zero+1'b1; 
				end
				
				end
		end
		endtask

	// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.
	assign tb_match = ( { zero_ref } === ( { zero_ref } ^ { zero_dut } ^ { zero_ref } ) );

	// Sequential Logic Check (Main Loop)
	always @(posedge clk, negedge clk) begin
		stats1.clocks++;
		// Note: Error counting for general mismatch is handled in the combinatorial block above for the first error detection timing.
		// We keep this structure for sequential clock tracking.
	end

   // add timeout after 100K cycles
   initial begin
     #1000000
     if (stats1.errors == 0)
     begin
       $display("SIMULATION PASSED");
     end
     else
     begin
       $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
     end
     $finish();
   end

	// Final block replacement based on requirement
	final begin
		if (stats1.errors_zero) $display("Hint: Output 'zero' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_zero, stats1.errortime_zero);
		else $display("Hint: Output 'zero' has no mismatches.");

		$display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		// Final required status display
		if (stats1.errors == 0) begin
			$display("SIMULATION PASSED");
		end
		else begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
		end
		$display("Simulation finished at %0d ps", $time);
		$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
	end

endmodule
