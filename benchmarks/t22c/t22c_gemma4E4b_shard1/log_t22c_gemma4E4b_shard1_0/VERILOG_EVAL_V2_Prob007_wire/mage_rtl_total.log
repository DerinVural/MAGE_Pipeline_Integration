// Stimulus Generator (Retained from golden testbench)
module stimulus_gen (
	input clk,
	output reg in,
	output reg[511:0] wavedrom_title,
	output reg wavedrom_enable
);

	task wavedrom_start(input[511:0] title = "");
	endtask
	
task wavedrom_stop;
		h#1;
	endtask	

	initial begin
		wavedrom_start("Output should follow input");
		repeat(20) @(posedge clk, negedge clk)
			in <= $random;
		wavedrom_stop();
		repeat(100) @(posedge clk, negedge clk) begin
			in <= $random;
		end
		
		h#1 $finish;
	end
	endmodule

// Reference Module (Assuming simple buffer for golden reference)
module RefModule (
    input logic in,
    output logic out
);
    assign out = in;
endmodule

// DUT Module (TopModule implementation - Wire behavior)
module TopModule (
    input logic in,
    output logic out
);
    assign out = in;
endmodule

// Testbench
module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_out;
		int errortime_out;
		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		h#5 clk = ~clk;

	logic in;
	logic out_ref;
	logic out_dut;

	// Signals for mismatch reporting (Combinational Logic Display)
	logic mismatch_detected_at_time;
	
	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stimulus_gen::stim1, tb);
	end

	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk, 
		.* , 
		in);
	RefModule good1 (
		.in, 
		out(out_ref) );
	TopModule top_module1 (
		in,
		out(out_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end
	task

	// Verification Logic: Based on golden testbench structure
	// tb_match = ( { out_ref } === ( { out_ref } ^ { out_dut } ^ { out_ref } ) );
	// Since out_ref and out_dut are 1-bit, this simplifies to out_ref === out_dut
	assign tb_match = (out_ref === out_dut);
	
	// Mismatch detection for display purposes (Combinational logic rule 2)
	// Mismatch occurs if actual output != expected output
	assign mismatch_detected_at_time = (out_ref !== out_dut);

	// Clocked logic for error counting and state tracking	
always @(posedge clk, negedge clk) begin

		stats1.clocks++;

		// Original error counting logic
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
		end
		// Second error counting logic (retained)
		if (out_ref !== ( out_ref ^ out_dut ^ out_ref ))
		begin 
			if (stats1.errors_out == 0) stats1.errortime_out = $time;
			stats1.errors_out = stats1.errors_out + 1'b1; 
		end
	end

	// Combinational Mismatch Display Logic (Rule 2)
	always @(posedge clk, negedge clk) begin
		if (mismatch_detected_at_time && stats1.errors == 0) begin
			// First mismatch detected at this clock edge
			s$display("====================================================================");
			s$display("*** COMBINATIONAL MISMATCH DETECTED AT TIME %0d ps ***", $time);
			$display("--------------------------------------------------------------------");
			$display("Input Signal (in): %b (Hex: %h)", in, in);
			$display("Expected Output (out_ref): %b (Hex: %h)", out_ref, out_ref);
			$display("Actual Output (out_dut): %b (Hex: %h)", out_dut, out_dut);
			$display("====================================================================");
			// Set a flag or adjust state if necessary to prevent re-displaying on every cycle
			// Since stats1.errors is updated in the clocked block, this should suffice.
		end
	end


	// add timeout after 100K cycles
	initial begin
		h#1000000
		$display("TIMEOUT");
		$finish();
	end

	// Final reporting logic (Replaced old final block)
	initial begin
		// Wait a moment for final clock cycles to settle
		@(negedge clk);
		#1;
		
		if (stats1.errors == 0 && stats1.errors_out == 0) begin
			$display("SIMULATION PASSED");
		end else begin
			// Determine the first error time based on the lowest non-zero error time recorded
			int first_error_time = (stats1.errors > 0) ? stats1.errortime : stats1.errortime_out;
			if (stats1.errors == 0 && stats1.errors_out == 0) first_error_time = 0; // Should be covered by PASS case
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors + stats1.errors_out, first_error_time);
		end
		$finish;
	end

endmodule
