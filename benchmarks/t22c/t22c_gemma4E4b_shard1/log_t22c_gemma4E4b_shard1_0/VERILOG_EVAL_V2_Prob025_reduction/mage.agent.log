			end
			// If only sample errors occurred (and parity errors were zero)
			else if (stats1.errors > 0) begin
				$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d.", stats1.errors, stats1.errortime);
				$display("Note: Total parity errors: 0.");
			end
			// If both error types occurred, the parity failure time (errortime_parity) should be prioritized if it represents a more critical failure, but sticking to the rule structure: if any mismatch exists, report failure.
			if (stats1.errors > 0 && stats1.errors_parity > 0) begin
				// Report based on sample error timing if it occurred first, otherwise parity error timing
				if (stats1.errortime < stats1.errortime_parity) begin
					$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d.", stats1.errors, stats1.errortime);
					$display("Note: Parity error detected first at time %0d.", stats1.errortime_parity);
				end else begin
