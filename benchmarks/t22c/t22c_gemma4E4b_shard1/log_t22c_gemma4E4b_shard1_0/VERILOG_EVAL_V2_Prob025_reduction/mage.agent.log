					$display("Note: Sample error detected first at time %0d.", stats1.errortime);
				end
			end
			
			// If no errors
			else begin
				$display("SIMULATION PASSED");
			end
			
			$display("Simulation finished at %0d ps", $time);
			$display("Total mismatched samples: %0d out of %0d samples.", stats1.errors, stats1.clocks);
			$display("Total parity mismatches: %0d.", stats1.errors_parity);
		end
