cks++;\n\t\t\n\t\t// Update errors based on the state *before* this clock edge if it was a mismatch\n\t\t// Since this is combinational, we use the current state (tb_mismatch) for counting.\n\t\tif (!tb_match) begin\n\t\t\tif (stats1.errors == 0) stats1.errortime = $time;\n\t\t\tstats1.errors++;\n\t\t\tend\n\t\t\n\t\t// Original parity error counting logic\n\t\tif (parity_ref !== ( parity_ref ^ parity_dut ^ parity_ref ))\n\t\tbegin \n\t\t\tif (stats1.errors_parity == 0) stats1.errortime_parity = $time;\n\t\t\tstats1.errors_parity = stats1.errors_parity+1\'b1; \n\t\tend\n\tend\n\n\t// --- Combinational Mismatch Display Logic (First Mismatch) ---\n\t// Since this is combinational, we monitor the change in mismatch status.\n\t// We use a flag to only display on the very first occurrence.\n\t\n\treg mismatch_detected_flag = 0;\n\t\n\talways @(tb_mismatch)\n\tbegin\n\t\tif (tb_mismatch && !mismatch_detected_flag)\n\t\tbegin\n\t\t\t$display("\\n========================================================================");\n\t\t\t$display("*** FIRST MISMATCH DETECTED AT TIME %0t ***", $time);\n\t\t\t$display("========================================================================");\n\t\t\t$display("Cycle Count at Mismatch: %0d", stats1.clocks);\n\t\t\t$display("--- Input Signals ---");\n\t\t\t$display("Input in: %h (Binary: %b)", in, in);\n\t\t\t$display("--- Output Signals ---");\n\t\t\t$display("DUT Output parity_dut: %b (Hex: %h)", parity_dut, parity_dut);\n\t\t\t$display("Reference parity_ref: %b (Hex: %h)", parity_ref, parity_ref);\n\t\t\t$display("--- Expected Output ---");\n\t\t\t// Expected output is derived from the original mismatch check:\n\t\t\t// Expected = { parity_ref } ^ { parity_dut } ^ { parity_ref } = 0\n\t\t\t$display("Expected Parity (based on original check): 0 (Hex: 00)");\n\t\t\t$display("========================================================================");\n\t\t\tmismatch_detected_flag = 1;\n\t\tend\n\tend\n\n\t// --- Simulation Control and Final Report ---\n\tinitial begin\n\t\t// Wait for stimulus to run\n\t\tend\n\n\t\t// Wait for simulation to finish or timeout\n\t\tend\n\n\t\t// Final Reporting Logic (Replaces original final block)\n\t\tif (stats1.errors > 0 || stats1.errors_parity > 0) begin\n\t\t\t// Check parity errors first if both metrics exist\n\t\t\tif (stats1.errors_parity > 0) begin\n\t\t\t\t$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d.", stats1.errors_parity, stats1.errortime_parity);\n\t\t\t\t// Display all errors for completeness, though the prompt asks for only the first detected error\n\t\t\t\t$display("Note: Total sample errors: %0d out of %0d samples.", stats1.errors, stats1.clocks);\n\t\t\t\t$display("Note: Total parity errors: %0d.", stats1.errors_parity);\n\t\t\tend\n\t\t\t// If only sample errors occurred (and parity errors were zero)\n\t\t\telse if (stats1.errors > 0) begin\n\t\t\t\t$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d.", stats1.errors, stats1.errortime);\n\t\t\t\t$display("Note: Total parity errors: 0.");\n\t\t\tend\n\t\t\t// If both error types occurred, the parity failure time (errortime_parity) should be prioritized if it represents a more critical failure, but sticking to the rule structure: if any mismatch exists, report failure.\n\t\t\tif (stats1.errors > 0 && stats1.errors_parity > 0) begin\n\t\t\t\t// Report based on sample error timing if it occurred first, otherwise parity error timing\n\t\t\t\tif (stats1.errortime < stats1.errortime_parity) begin\n\t\t\t\t\t$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d.", stats1.errors, stats1.errortime);\n\t\t\t\t\t$display("Note: Parity error detected first at time %0d.", stats1.errortime_parity);\n\t\t\t\tend else begin\n\t\t\t\t\t$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d.", stats1.errors_parity, stats1.errortime_parity);\n\t\t\t\t\t$display("Note: Sample error detected first at time %0d.", stats1.errortime);\n