, overflow_ref);\n\t\t\t$display("========================================================");\n\t\tend\n\t\terrors_s++;\n\t\tend\n\n\t\t// 3. Check overflow mismatch\n\t\tif (overflow_ref !== overflow_dut) begin\n\t\t\tif (errors_overflow == 0) begin\n\t\t\tfirst_overflow_mismatch_time = $time;\n\t\t\t// Display signals at FIRST overflow Mismatch\n\t\t\t$display("========================================================");\n\t\t\t$display("!!! FIRST \'overflow\' MISMATCH DETECTED AT TIME %0d ps !!!", $time);\n\t\t\t$display("--- INPUTS ---");\n\t\t\t$display("a: HEX=%h, BIN=%b", a, a);\n\t\t\t$display("b: HEX=%h, BIN=%b", b, b);\n\t\t\t$display("--- DUT OUTPUTS ---");\n\t\t\ts_dut: HEX=%h, BIN=%b", s_dut, s_dut);\n\t\t\t$display("overflow_dut: %b", overflow_dut);\n\t\t\t$display("--- GOLDEN OUTPUTS ---");\n\t\t\ts_ref: HEX=%h, BIN=%b", s_ref, s_ref);\n\t\t\t$display("overflow_ref: %b", overflow_ref);\n\t\t\t$display("========================================================");\n\t\tend\n\t\terrors_overflow++;\n\t\tend\n\n\t// Timeout\n\tinitial begin\n\t\t#1000000\n\t\t$display("TIMEOUT");\n\t\t$finish();\n\tend\n\n\t// Final Reporting (Replaces original \'final\' block)\n\tinitial begin\n\t\t// Wait for simulation to complete naturally or timeout\n\t\t@(negedge clk);\n\t\t\n\t\tif (total_errors == 0) begin\n\t\t\t$display("SIMULATION PASSED");\n\t\tend else begin\n\t\t\t$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", total_errors, first_mismatch_time);\n\t\tend\n\t\t$finish;\n\tend\n\nendmodule\n</testbench>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nThe module interface is given below:\n<module_interface>\ninterface TopModule_if;\n    logic [7:0] a;\n    logic [7:0] b;\n    logic [7:0] s;\n    logic overflow;\nendinterface;\n</module_interface>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nYou