// --- Stimulus Generator (Kept as is, since it drives inputs) ---
module stimulus_gen (
	input clk,
	output logic [7:0] a, b,
	output reg[511:0] wavedrom_title,
	output reg wavedrom_enable
);

	// Add two ports to module stimulus_gen:
	//    output [511:0] wavedrom_title
	//    output reg wavedrom_enable

	task wavedrom_start(input[511:0] title = "");
	endtask
	
	task wavedrom_stop;
		#1;
	endtask	

	initial begin
		{a, b} <= 0;
		@(negedge clk) wavedrom_start();
			@(posedge clk) {a, b} <= 16'h0;
			@(posedge clk) {a, b} <= 16'h0070;
			@(posedge clk) {a, b} <= 16'h7070;
			@(posedge clk) {a, b} <= 16'h7090;
			@(posedge clk) {a, b} <= 16'h9070;
			@(posedge clk) {a, b} <= 16'h9090;
			@(posedge clk) {a, b} <= 16'h90ff;
		@(negedge clk) wavedrom_stop();
		repeat(100) @(posedge clk, negedge clk)
			{a,b} <= $random;
		$finish;
	end

endmodule

// --- Testbench ---
module tb();

	// Statistics tracking
	int total_errors = 0;
	int errors_s = 0;
	int errors_overflow = 0;
	int first_mismatch_time = -1;
	int first_s_mismatch_time = -1;
	int first_overflow_mismatch_time = -1;
	int clocks_counted = 0;

	// Signals from Stimulus Generator
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	
	// Clock
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	// DUT Interface signals
	logic [7:0] a;
	logic [7:0] b;
	logic [7:0] s_dut;
	logic overflow_dut;
	
	// Reference Model signals
	logic [7:0] s_ref;
	logic overflow_ref;

	// Verification
	wire tb_match;
	wire tb_mismatch = ~tb_match;

	// --- DUT Instantiation ---
	// RefModule (Golden Reference Model) -- Assumed to exist and match spec
	RefModule good1 (
		a,
		b,
		s(s_ref),
		overflow(overflow_ref) );
	
	// TopModule (DUT)
	TopModule top_module1 (
		a,
		b,
		s(s_dut),
		overflow(overflow_dut) );

	// --- Stimulus Generator Instantiation ---
	stimulus_gen stim1 (
		.clk,
		.a,
		.b,
		.wavedrom_title,
		.wavedrom_enable
	);

	// --- Logging and Dumping ---
	initial begin 
		dumpfile("wave.vcd");
		dumpvars(1, stim1.clk, tb_mismatch ,a,b,s_ref,s_dut,overflow_ref,overflow_dut );
	end

	// --- Timing Helper (Kept for structure integrity) ---
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		endtask	

	// --- Verification Logic ---
	// tb_match is true if {s_ref, overflow_ref} == {s_dut, overflow_dut}
	assign tb_match = ( { s_ref, overflow_ref } === { s_dut, overflow_dut } );

	// Combinational Check Logic (Driven by clock edge as per original TB structure)
	always @(posedge clk, negedge clk) begin
		clocks_counted++;

		// 1. Check overall mismatch
		if (!tb_match) begin
			if (first_mismatch_time == -1) begin
			first_mismatch_time = $time;
			// Display signals at FIRST mismatch
			$display("========================================================");
			$display("!!! FIRST OVERALL MISMATCH DETECTED AT TIME %0d ps !!!", $time);
			$display("--- INPUTS ---");
			$display("a: HEX=%h, BIN=%b", a, a);
			$display("b: HEX=%h, BIN=%b", b, b);
			$display("--- DUT OUTPUTS ---");
			$display("s_dut: HEX=%h, BIN=%b", s_dut, s_dut);
			$display("overflow_dut: %b", overflow_dut);
			$display("--- GOLDEN OUTPUTS ---");
			$display("s_ref: HEX=%h, BIN=%b", s_ref, s_ref);
			$display("overflow_ref: %b", overflow_ref);
			$display("========================================================");
			// Note: We do not stop simulation here to maintain original error counting structure.
		end
		total_errors = total_errors + (tb_mismatch ? 1 : 0);

		// 2. Check s mismatch
		if (s_ref !== s_dut) begin
			if (errors_s == 0) begin
			first_s_mismatch_time = $time;
			// Display signals at FIRST s Mismatch
			$display("========================================================");
			$display("!!! FIRST 's' MISMATCH DETECTED AT TIME %0d ps !!!", $time);
			$display("--- INPUTS ---");
			$display("a: HEX=%h, BIN=%b", a, a);
			$display("b: HEX=%h, BIN=%b", b, b);
			$display("--- DUT OUTPUTS ---");
			s_dut: HEX=%h, BIN=%b", s_dut, s_dut);
			$display("overflow_dut: %b", overflow_dut);
			$display("--- GOLDEN OUTPUTS ---");
			s_ref: HEX=%h, BIN=%b", s_ref, s_ref);
			$display("overflow_ref: %b", overflow_ref);
			$display("========================================================");
		end
		errors_s++;
		end

		// 3. Check overflow mismatch
		if (overflow_ref !== overflow_dut) begin
			if (errors_overflow == 0) begin
			first_overflow_mismatch_time = $time;
			// Display signals at FIRST overflow Mismatch
			$display("========================================================");
			$display("!!! FIRST 'overflow' MISMATCH DETECTED AT TIME %0d ps !!!", $time);
			$display("--- INPUTS ---");
			$display("a: HEX=%h, BIN=%b", a, a);
			$display("b: HEX=%h, BIN=%b", b, b);
			$display("--- DUT OUTPUTS ---");
			s_dut: HEX=%h, BIN=%b", s_dut, s_dut);
			$display("overflow_dut: %b", overflow_dut);
			$display("--- GOLDEN OUTPUTS ---");
			s_ref: HEX=%h, BIN=%b", s_ref, s_ref);
			$display("overflow_ref: %b", overflow_ref);
			$display("========================================================");
		end
		errors_overflow++;
		end

	// Timeout
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

	// Final Reporting (Replaces original 'final' block)
	initial begin
		// Wait for simulation to complete naturally or timeout
		@(negedge clk);
		
		if (total_errors == 0) begin
			$display("SIMULATION PASSED");
		end else begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", total_errors, first_mismatch_time);
		end
		$finish;
	end

endmodule
