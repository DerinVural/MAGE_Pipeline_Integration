	task wavedrom_start(input[511:0] title = "");
	endtask
	
	task wavedrom_stop;
		h#1;
	endtask	

	initial begin
		in <= 1'b0;
		wavedrom_start("Inversion");
		repeat(20) @(posedge clk)
		int <= $random;	
		wavedrom_stop();
		
		repeat(200) @(posedge clk, negedge clk)
		in <= $random;
		
		#1 $finish;
	end
	
endmodule

module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_out;
		int errortime_out;
		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		h#5 clk = ~clk;

	logic in;
	logic out_ref;
	logic out_dut;

	// Variables to capture first mismatch state for combinational logic display
	logic capture_mismatch = 0;
	logic captured_in;
	logic captured_out_ref;
	logic captured_out_dut;
	integer first_error_time = -1;

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,in,out_ref,out_dut );
	end


	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk,
		.* , 
		.in );
	RefModule good1 (
		.in,
		.out(out_ref) );
	
	TopModule top_module1 (
		.in,
		.out(out_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end	ask
	

	final begin
		if (stats1.errors_out) $display("Hint: Output '%s' has %0d mismatches. First mismatch occurred at time %0d.", "out", stats1.errors_out, stats1.errortime_out);
		else $display("Hint: Output '%s' has no mismatches.", "out");

		$display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
		$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
	end
	
	// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.
	assign tb_match = ( { out_ref } === ( { out_ref } ^ { out_dut } ^ { out_ref } ) );
	
	// State capture and error detection logic
	always @(posedge clk, negedge clk) begin
		
		stats1.clocks++;
		
		// Logic for stats1.errors (Primary Mismatch)
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			sstats1.errors++;
			
			// Capture state upon first primary mismatch (Combinational Logic Requirement)
			if (stats1.errors == 1) begin
				capture_mismatch = 1;
				first_error_time = $time;
				captured_in = in;
				captured_out_ref = out_ref;
				captured_out_dut = out_dut;
				end
				end
		end
		
		// Logic for stats1.errors_out (Secondary Mismatch Check)
		if (out_ref !== ( out_ref ^ out_dut ^ out_ref ))
		begin 
			if (stats1.errors_out == 0) stats1.errortime_out = $time;
			sstats1.errors_out = stats1.errors_out+1'b1; 
		end
		
		end

	
	// Display logic based on first mismatch detection
	always @(*) begin
		if (capture_mismatch && (stats1.errors == 1)) begin
			$display("\n=====================================================");
			$display("FIRST MISMATCH DETECTED (Primary Error) at Time: %0d ps", first_error_time);
			$display("-----------------------------------------------------");
			$display("Input Signal (in):  %b (Hex: %h)", captured_in, captured_in);
			$display("Expected Output (out_ref): %b (Hex: %h)", captured_out_ref, captured_out_ref);
			$display("Actual Output (out_dut):  %b (Hex: %h)", captured_out_dut, captured_out_dut);
			$display("=====================================================\n");
			// Deactivate capture flag after display
			capture_mismatch = 0;
		end
	end


	// add timeout after 100K cycles
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

endmodule
