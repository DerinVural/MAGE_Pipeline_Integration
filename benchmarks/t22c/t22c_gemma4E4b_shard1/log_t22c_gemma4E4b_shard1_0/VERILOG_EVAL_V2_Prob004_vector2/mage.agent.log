// --- Improved Testbench ---
module tb();
	
	typedef struct packed {
		int errors;
		int errortime;
		int errors_out;
		int errortime_out;
		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic [31:0] in;
	logic [31:0] out_ref;
	logic [31:0] out_dut;

	// State tracking for first mismatch display (Combinational Logic)
	logic first_mismatch_detected = 0;
	logic [31:0] mismatch_input_data = 32'hX;
	logic [31:0] mismatch_got_output = 32'hX;
	logic [31:0] mismatch_golden_output = 32'hX;
	
	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch, in, out_ref, out_dut );
	end

	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk,
		.* ,
		.in );
	RefModule good1 (
		.in,
		.out(out_ref) );
	TopModule top_module1 (
		.in,
		.out(out_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end
task

	
	// Combinational Mismatch Checker
	// Since the DUT is combinational, we check for mismatch whenever 'in' changes, 
	// which is synchronized by the clock edges in the stimulus_gen, but the check itself is combinatorial.
	always @(*) begin
		tb_match = ( out_ref === out_dut );
		end

	// Clocked logic for statistics accumulation (Maintaining original structure)
	always @(posedge clk, negedge clk) begin
		stats1.clocks++;
		
		// 1. Error Counting (Original Logic)
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
			end
		
		// 2. Output Error Counting (Original Logic)
		if (out_ref !== ( out_ref ^ out_dut ^ out_ref ))
		begin 
			if (stats1.errors_out == 0) stats1.errortime_out = $time;
			stats1.errors_out = stats1.errors_out+1'b1; 
		end
		end

		// 3. First Mismatch Detection (For combinational display)
		if (!tb_match && !first_mismatch_detected) begin
			first_mismatch_detected = 1;
			mismatch_input_data = in;
			mismatch_got_output = out_dut;
			mismatch_golden_output = out_ref;
		end
	end

	// Combinational display triggered by first_mismatch_detected flag
	always @(*) begin
		if (first_mismatch_detected && !($time > 1000000)) begin
			// Only display the first mismatch details once
			if (stats1.errors == 1) begin
				$display("========================================================");
				$display("COMBINATIONAL MISMATCH DETECTED AT TIME %0t", $time);
				$display("--------------------------------------------------------");
				$display("Input Data (in):");
				$display("  HEX: %h", mismatch_input_data);
				$display("  BIN: %b", mismatch_input_data);
				$display("--------------------------------------------------------");
				$display("DUT Output (out_dut) - GOT:");
				$display("  HEX: %h", mismatch_got_output);
				$display("  BIN: %b", mismatch_got_output);
				$display("--------------------------------------------------------");
				$display("Reference Output (out_ref) - GOLDEN:");
				$display("  HEX: %h", mismatch_golden_output);
				$display("  BIN: %b", mismatch_golden_output);
				s$display("========================================================");
			end
			if (first_mismatch_detected && stats1.errors > 1) begin
			// Avoid spamming this display block if we are past the first mismatch
			end
		end
	end

	// Final check logic
	initial begin
		@(negedge clk);
		// Wait a bit longer to ensure all expected stimuli have run
		#500000;
		
		if (stats1.errors == 0 && stats1.errors_out == 0) begin
			$display("SIMULATION PASSED");
			$finish;
			
		end else begin
			if (stats1.errors > 0) begin
				$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0t", stats1.errors, stats1.errortime);
			end else begin
				$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0t", stats1.errors_out, stats1.errortime_out);
			end
			$finish;
		end
	end

	// add timeout after 100K cycles
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

endmodule
