			int failure_time = (stats1.errors > 0) ? stats1.errortime : stats1.errortime_out;
			int total_mismatches = stats1.errors; 
			
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", total_mismatches, failure_time);
			
