		int errors;
		int errortime;
		int errors_out;
		int errortime_out;

		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic a;
	logic b;
	logic sel;
	logic out_ref;
	logic out_dut;

	// Variables to capture first mismatch state for combinational logic display
	logic first_mismatch_detected = 0;
	logic [1:0] mismatch_inputs = 0; // Store {a, b, sel}
	logic mismatch_expected_out = 0; 
	logic mismatch_actual_out = 0;

	initial begin 
		$dumpfile("wave.vcd");
		dumpvars(1, stim1.clk, tb_mismatch ,a,b,sel,out_ref,out_dut );
	end

	
	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk,
		.* , 
		.a,
		.b,
		.sel );
	RefModule good1 (
		.a,
		.b,
		.sel,
		.out(out_ref) );
	
	TopModule top_module1 (
		a,
		b,
		sel,
		out_dut );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
			strobe <= !strobe;  // Try to delay until the very end of the time step.
			@(strobe);
		end
	endtask

	
	final begin
		if (stats1.errors_out) begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_out, stats1.errortime_out);
			$display("--- FIRST MISMATCH DETAILS ---");
			$display("Time of First Mismatch: %0d ps", stats1.errortime_out);
			$display("Inputs (a, b, sel): %b, %b, %b", mismatch_inputs[0], mismatch_inputs[1], mismatch_inputs[2]);
			$display("Expected Output (out_ref): %b (0x%h)", mismatch_expected_out, mismatch_expected_out);
			$display("Actual Output (out_dut): %b (0x%h)", mismatch_actual_out, mismatch_actual_out);
		end else begin
			$display("SIMULATION PASSED");
		end
	
		$display("Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
	end
	
	// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.
	assign tb_match = ( { out_ref } === ( { out_ref } ^ { out_dut } ^ { out_ref } ) );

	// Combinational logic check: Detect mismatch immediately upon change, but use clock edge to register error count.
	always @(*) begin
		if (out_ref !== out_dut) begin
			// Mismatch detected immediately. Capture state if it's the first one.
			if (!first_mismatch_detected) begin
				first_mismatch_detected = 1;
				mismatch_inputs = {a, b, sel};
				mismatch_expected_out = out_ref;
				mismatch_actual_out = out_dut;
				end
			// For combinational logic, we rely on the clock block to record the error count at the sampled time.
		end
		end
	end

	// Clocked block for timing and error counting (Adhering to golden testbench structure)
	always @(posedge clk, negedge clk) begin
		stats1.clocks++;
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			sstats1.errors++;
		end
		if (out_ref !== ( out_ref ^ out_dut ^ out_ref ))
		begin 
			if (stats1.errors_out == 0) stats1.errortime_out = $time;
			sstats1.errors_out = stats1.errors_out+1'b1; 
		end
		end

	// add timeout after 100K cycles
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

endmodule
