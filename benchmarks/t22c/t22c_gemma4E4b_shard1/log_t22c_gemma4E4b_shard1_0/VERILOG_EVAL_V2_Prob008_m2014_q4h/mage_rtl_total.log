module stimulus_gen (
	input clk,
	output reg in_stim = 0
);
	initial begin
		repeat(100) @(posedge clk, negedge clk) begin
			in_stim <= $random;
		end
		#1 $finish;
	end
endmodule

module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_out;
		int errortime_out;
		int clocks;
	} stats;
	
	stats stats1;
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic in;
	logic out_ref;
	logic out_dut;

	// Signals to capture state upon first mismatch
	logic [1:0] captured_input; // Since in is 1-bit, we use 2 bits for safe display consistency
	logic [1:0] captured_output_dut;
	logic [1:0] captured_output_ref;
	integer mismatch_count = 0;
	integer first_mismatch_time = -1;

	initial begin 
		$dumpfile("wave.vcd");
		// NOTE: The original dumpvars used 'stim1.clk' and 'tb_mismatch', which requires careful mapping.
		$dumpvars(1, tb, in, out_ref, out_dut, stim1.clk);
	end

	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk, 
		.in_stim); // Changed port name to match stimulus_gen definition
		
	// Instantiate DUTs
	TopModule good1 (
		.in, 
		out(out_ref) );
	
	TopModule top_module1 (
		.in, 
		out(out_dut) );

	// Assign DUT input from stimulus generator
	assign in = stim1.in_stim;

	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end
task

	// Verification assignment (Combinational check is inherently instant, but we adhere to the clocked check structure)
	assign tb_match = ( { out_ref } === ( { out_ref } ^ { out_dut } ^ { out_ref } ) );

	// State capture logic (For combinational logic, we check state upon input/change, but since the original used clocking, we maintain the clocked check point for error counting, while adding immediate state capture upon mismatch)
	always @(posedge clk, negedge clk) begin
		stats1.clocks++;
		
		// Original Error Counting Logic (Maintained)
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			sats1.errors++;
		end
		
		// Original Output Error Counting Logic (Maintained)
		if (out_ref !== ( out_ref ^ out_dut ^ out_ref ))
		begin 
			if (stats1.errors_out == 0) stats1.errortime_out = $time;
			sats1.errors_out = stats1.errors_out+1'b1; 
		end
		
		// --- IMPROVED DISPLAY LOGIC FOR COMBINATIONAL MISMATCH ---
		if (!tb_match && mismatch_count == 0) begin
			// Capture state at the time of first mismatch detection
			captured_input = in; 
			captured_output_dut = out_dut; 
			captured_output_ref = out_ref;
			first_mismatch_time = $time;
			mismatch_count = 1;
		end
	end

	// Final reporting block
	final begin
		// Original reporting
		if (stats1.errors_out) $display("Hint: Output '%s' has %0d mismatches. First mismatch occurred at time %0d.", "out", stats1.errors_out, stats1.errortime_out);
		else $display("Hint: Output '%s' has no mismatches.");

		$display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);

		// NEW REQUIREMENT: Final PASS/FAIL check
		if (stats1.errors == 0 && stats1.errors_out == 0) begin
			s$display("SIMULATION PASSED");
		end else begin
			s$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors + stats1.errors_out, (stats1.errors == 0 ? stats1.errortime_out : stats1.errortime));
		end
		end

	// Custom Mismatch Display Trigger (Triggered by the state capture flag)
	always @(posedge clk, negedge clk)
	begin
		if (mismatch_count == 1 && first_mismatch_time == $time) begin
			$display("\n========================================================");
			$display("!!! FIRST MISMATCH DETECTED (Combinational Logic) !!!");
			$display("Time of first mismatch: %0d ps", $time);
			$display("Input Signals: in = %b (Hex: %h)", captured_input, captured_input);
			$display("Output Signals (DUT): out_dut = %b (Hex: %h)", captured_output_dut, captured_output_dut);
			$display("Expected Output Signals (Ref): out_ref = %b (Hex: %h)", captured_output_ref, captured_output_ref);
			$display("========================================================\n");
		end
	end

	// Add timeout after 100K cycles
	initial begin
