    assign sum = x + y; 
endmodule

module stimulus_gen (
	input logic clk,
	output logic [3:0] x,
	output logic [3:0] y
);
	initial begin
		repeat(100) @(posedge clk, negedge clk) begin
			{x,y} <= $random;
		end
		
		#1 $finish;
	end
endmodule

module tb();
	typedef struct packed {
		int errors;
		int errortime;
		int errors_sum;
		int errortime_sum;
		int clocks;
	} stats;
	
	stats stats1;
	
	// Variables to capture first mismatch state
	logic [3:0] first_error_x;
	logic [3:0] first_error_y;
	logic [4:0] first_error_sum_ref;
	logic [4:0] first_error_sum_dut;
	integer first_error_detected = 0;
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic [3:0] x;
	logic [3:0] y;
	logic [4:0] sum_ref;
	logic [4:0] sum_dut;

	initial begin 
		$dumpfile("wave.vcd");
		// Note: tb_mismatch is derived from tb_match, which is continuous. 
		// Dumping signals used in continuous logic and clocked logic.
		$dumpvars(1, tb, x, y, sum_ref, sum_dut, stim1, stats1, first_error_x, first_error_y, first_error_sum_ref, first_error_sum_dut);
	end

	wire tb_match; 
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk, 
		.x, 
		.y 
	);
	RefModule good1 (
		.x, 
		y, 
		sum(sum_ref) 
	);
	
	TopModule top_module1 (
		.x, 
		y, 
		sum(sum_dut) 
	);

	
	// Task definition is kept from original golden testbench
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end
	endtask

	reg strobe = 0;
	
	// Simulation Control and Reporting
	initial begin
		$display("Starting simulation...");
		stats1.errors = 0;
		stats1.errors_sum = 0;
		stats1.clocks = 0;
		
		// Wait for enough cycles to run simulation based on stimulus_gen
		// The stimulus_gen runs for 100 cycles of clk.
		repeat(100) @(posedge clk);
		
		// Final checks and reporting
		if (stats1.errors == 0 && stats1.errors_sum == 0) begin
			$display("SIMULATION PASSED");
		end else begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
		end
		
		$display("Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
	end

	// Original timeout mechanism kept
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

	// Verification logic: Simplified based on mathematical equivalence of original check
	// Original: assign tb_match = ( { sum_ref } === ( { sum_ref } ^ { sum_dut } ^ { sum_ref } ) );
	// Simplified: sum_ref === sum_dut
	assign tb_match = (sum_ref === sum_dut);

	// Clocked logic for counting and capturing first error (Combinational Check Logic)
	always @(posedge clk, negedge clk) begin
		stats1.clocks++;
		
		// Check 1: Based on tb_match
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
			end
		
		// Check 2: Based on sum_ref !== ( sum_ref ^ sum_dut ^ sum_ref )
		if (sum_ref !== ( sum_ref ^ sum_dut ^ sum_ref ))
		begin 
			if (stats1.errors_sum == 0) stats1.errortime_sum = $time;
			sstats1.errors_sum = stats1.errors_sum+1'b1;
		end
		end

		// Capture state ONLY upon the first detection of ANY mismatch (Rule 2 application)
		if (stats1.errors == 1 && stats1.errors_sum == 0) begin
			// Capture state at the time of the first mismatch (or close to it)
			first_error_x = x;
			first_error_y = y;
			first_error_sum_ref = sum_ref;
			first_error_sum_dut = sum_dut;
			end
		
		end

	// Final Display Block for First Mismatch (Combinational Logic Requirement)
	always @(posedge clk, negedge clk) begin
		if (stats1.errors == 1 && stats1.errors_sum == 0) begin
			$display("\n====================================================================");
			$display("FIRST MISMATCH DETECTED AT TIME %0d", $time);
			$display("====================================================================");
			$display("Inputs:");
			$display("  x: HEX=%h, BIN=%b", first_error_x, first_error_x);
			$display("  y: HEX=%h, BIN=%b", first_error_y, first_error_y);
			$display("Reference Output (Expected): HEX=%h, BIN=%b", first_error_sum_ref, first_error_sum_ref);
			$display("DUT Output (Actual): HEX=%h, BIN=%b", first_error_sum_dut, first_error_sum_dut);
			end
	end

endmodule
