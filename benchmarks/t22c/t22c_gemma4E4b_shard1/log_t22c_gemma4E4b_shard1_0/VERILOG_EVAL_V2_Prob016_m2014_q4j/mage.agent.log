	);
	RefModule good1 (
		.x, 
		y, 
		sum(sum_ref) 
	);
	
	TopModule top_module1 (
		.x, 
		y, 
		sum(sum_dut) 
	);

	
	// Task definition is kept from original golden testbench
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end
	endtask

	reg strobe = 0;
	
	// Simulation Control and Reporting
	initial begin
		$display("Starting simulation...");
		stats1.errors = 0;
		stats1.errors_sum = 0;
		stats1.clocks = 0;
		
		// Wait for enough cycles to run simulation based on stimulus_gen
		// The stimulus_gen runs for 100 cycles of clk.
		repeat(100) @(posedge clk);
		
		// Final checks and reporting
		if (stats1.errors == 0 && stats1.errors_sum == 0) begin
