		$display("Final statistics: Total Clocks=%0d, Total Mismatches=%0d", stats1.clocks, stats1.errors);
		$finish();
end

// add timeout after 100K cycles
initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
end

endmodule

