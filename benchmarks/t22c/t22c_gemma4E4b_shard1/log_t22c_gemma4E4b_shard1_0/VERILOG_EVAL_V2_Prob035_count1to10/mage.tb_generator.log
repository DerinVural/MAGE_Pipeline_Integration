efore reset is asserted\n    initial begin\n        counter_reg = 4'b0000;\n    end\n\n    // Synchronous Decade Counter Logic (Counts 1 to 10, loops 1 -> 2 -> ... -> 10 -> 1)\n    always @(posedge clk)\n    begin\n        if (reset)\n        begin\n            // Synchronous reset sets the counter to 1\n            counter_reg <= 4'b0001;\n        end\n        else\n        begin\n            // Check for the wrap-around condition (10 -> 1)\n            if (counter_reg == 4'd10) begin\n                counter_reg <= 4'b0001; // Wrap back to 1\n            end\n            // Normal increment\n            else begin\n                counter_reg <= counter_reg + 1'b1;\n            end\n        end\n    end\n\n    // Assign the internal register to the output port\n    assign q = counter_reg;\n\nendmodule\n\n// --- Reference Module (Must exist for TB to compile) ---\nmodule RefModule (\n    input clk,\n    input reset,\n    output logic [3:0] q\n);\n    // Reference implementation (same logic)\n    reg [3:0] counter = 4'd1;\n    always @(posedge clk)\n    begin\n        if (reset)\n        begin\n            counter <= 4'd1;\n        end\n        else if (counter == 4'd10)\n        begin\n            counter <= 4'd1;\n        end\n        else\n        begin\n            counter <= counter + 1'b1;\n        end\n    end\n    assign q = counter;\nendmodule\n\n// --- Testbench ---\nmodule tb();\n\n    typedef struct packed {\n        int errors;          // Total mismatches\n        int errortime;       // Time of first mismatch\n        int errors_q;        // Mismatches specific to q output\n        int errortime_q;     // Time of first q mismatch\n\n        // State capture for detailed failure reporting\n        logic [3:0] mismatch_q_dut_capture; \n        logic [3:0] mismatch_q_ref_capture; \n        logic [3:0] mismatch_q_expected_capture; \n        int clocks;\n    } stats;\n    \n    stats stats1;\n    \n    \n    wire[511:0] wavedrom_title;\n    wire wavedrom_e