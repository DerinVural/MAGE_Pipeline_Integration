 -1;\n\tend\n\n\t// --- DUT Instantiations ---\n\twire tb_match;\n\twire tb_mismatch = ~tb_match;\n\t\n\tstimulus_gen stim1 (\n\t\t.clk, \n\t\t.reset, \n\t\t.wavedrom_title, \n\t\t.wavedrom_enable, \n\t\t.tb_match \n\t);\n\tRefModule good1 (\n\t\t.clk,\n\t\t.reset,\n\t\t.q(q_ref) );\n\tTopModule top_module1 (\n\t\t.clk,\n\t\t.reset,\n\t\t.q(q_dut) );\n\n\t\n\tbit strobe = 0;\n\ttask wait_for_end_of_timestep;\n\t\trepeat(5) begin\n\t\tstrobe <= !strobe;  // Try to delay until the very end of the time step.\n\t\t@(strobe);\n\t\tendtask\t\n\n\t// --- Clocked Logic for Stats Tracking and Queueing ---\n\talways @(posedge clk, negedge clk) begin\n\t\tstats1.clocks++;\n\n\t\t// 1. Queue Management (FIFO behavior)\n\t\tif (input_q_dut_hist.size() >= MAX_QUEUE_SIZE - 1) begin\n\t\t\tinput_q_dut_hist.delete(0);\n\t\t\tgolden_q_hist.delete(0);\n\t\t\treset_hist.delete(0);\n\t\t\ttb_match_hist.delete(0);\n\t\tend\n\n\t\t// 2. Store current state\n\t\tinput_q_dut_hist.push_back(q_dut);\n\t\tgolden_q_hist.push_back(q_ref);\n\t\treset_hist.push_back(reset);\n\t\ttb_match_hist.push_back(tb_match);\n\n\t\t// 3. Original Error Counting Logic\n\t\tif (!tb_match) begin\n\t\t\tif (stats1.errors == 0) stats1.errortime = $time;\n\t\t\tsstats1.errors++;\n\t\tend\n\t\t\n\t\t// Original specific error check for q_ref vs q_dut\n\t\tif (q_ref !== ( q_ref ^ q_dut ^ q_ref ))\n\t\tbegin \n\t\t\tif (stats1.errors_q == 0) stats1.errortime_q = $time;\n\t\t\tsstats1.errors_q = stats1.errors_q+1\'b1; \n\t\tend\n\t\tend\n\n\t\t// 4. Queue-based Mismatch Detection and Display (As required for sequential logic)\n\t\tif (tb_mismatch && first_mismatch_time == -1) begin\n\t\t\tfirst_mismatch_time = $time;\n\t\t\t$display("\\n====================================================================================");\n\t\t\t$display("!!! FIRST MISMATCH DETECTED AT TIME %0t !!!", $time);\n\t\t\t$display("====================================================================================");\n\t\t\t$display("Last %0d cycles of simulation (Max Queue Size %0d):", input_q_dut_hist.size(), MAX_QUEUE_SIZE);\n\n\t\t\t// Display history from the queue\n\t\t\tfor (int i = 0; i < input_q_dut_hist.size(); i++) begin\n\t\t\t\t// Note: We check the current state against the historical state in the queue\n\t\t\t\tif (input_q_dut_hist[i] !== golden_q_hist[i]) begin\n\t\t\t\t\t$display("--> Mismatch detected in queue history at index %0d", i);\n\t\t\t\tend\n\t\t\t\t\n\t\t\t\t// Display format requirements: HEX and BINARY if width <= 64\n\t\t\t\t$display("Cycle %0d, reset %b, input_q_dut=%h (%b), golden_q_ref=%h (%b), match=%b",\n\t\t\t\ti,\n\t\t\t\treset_hist[i],\n\t\t\t\tinput_q_dut_hist[i], input_q_dut_hist[i], \n\t\t\t\tgolden_q_hist[i], golden_q_hist[i], \n\t\t\t\ttb_match_hist[i]);\n\t\t\tend\n\t\tend\n\tend\n\n\t// Add timeout after 100K cycles\n\tinitial begin\n\t\t#1000000\n\t\t$display("TIMEOUT");\n\t\t$finish();\n\tend\n\n\t// Final reporting block (Replaces the original final block)\n\tinitial begin\n\t\t@(negedge clk);\n\t\t#1;\n\t\t\n\t\tif (stats1.errors == 0 && stats1.errors_q == 0) begin\n\t\t\t$display("SIMULATION PASSED");\n\t\tend else begin\n\t\t\tint total_mismatches = stats1.errors;\n\t\t\tint first_error_time = (stats1.errors == 0) ? -1 : stats1.errortime;\n\t\t\tif (stats1.errors_q > 0 && first_error_time == -1) first_error_time = stats1.errortime_q;\n\t\t\tif (first_error_time == -1) first_error_time = 0; // Should not happen if errors > 0\n\t\t\t$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", total_mismatches, first_error_time);\n\t\tend\n\t\t$finish;\n\tend\n\nendmodule\n\n</testbench>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nThe module interface is given below:\n<module_interface>\nmodule TopModule(\n    input logic clk,\n    input logic reset,\n    output logic [3:0] q\n);\n// Implementation of TopModule would go here\nendmodule\n</module_interface>\n')]), Ch