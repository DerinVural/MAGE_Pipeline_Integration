/*
	Midterm 2015 Question 1k. 2-bit equality comparator.
*/


module stimulus_gen (
	input clk,
	output logic [1:0] A,
	output logic [1:0] B
);

	always @(posedge clk, negedge clk)
		{A, B} <= $random % 16;
	
	initial begin
		repeat(1000) @(negedge clk);
		#1 $finish;
	end

endmodule

module RefModule (
	input [1:0] A,
	input [1:0] B,
	output z
);
	// Implementation for comparison: z=1 if A=B, else z=0
	assign z = (A == B);
endmodule

module TopModule (
	input  [1:0] A,
	input  [1:0] B,
	output z
);
	// Implementation: z=1 if A=B, else z=0
	assign z = (A == B);
endmodule

module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_z;
		int errortime_z;
		int clocks;
	} stats;
	
	stats stats1;
	
	// Removed unused wavedrom signals for cleaner code based on structure
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic [1:0] A;
	logic [1:0] B;
	logic z_ref;
	logic z_dut;

	// State tracking for enhanced error reporting
	integer first_mismatch_time = -1;

	initial begin 
		$dumpfile("wave.vcd");
		// Note: Original dumpvars included tb_mismatch, which is derived, and top_module1.
		$dumpvars(1, tb);
	end

	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk, 
		.A, 
		.B );
	RefModule good1 (
		.A, 
		.B, 
		z_ref );
	TopModule top_module1 (
		.A, 
		.B, 
		z_dut );

	// Task wait_for_end_of_timestep remains for functional adherence
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end
	endtask

	// New signal required for the task, initialized here
	reg strobe = 0;

	// --- Core Verification Logic --- 
	// tb_match check based on original code logic
	assign tb_match = ( { z_ref } === ( { z_ref } ^ { z_dut } ^ { z_ref } ) );

	// Clocked verification and statistics update
	always @(posedge clk, negedge clk) begin
		stats1.clocks++;

		// Update standard error counters (Original logic maintained)
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
		end

		// Update specific z error counter (Original logic maintained)
		if (z_ref !== ( z_ref ^ z_dut ^ z_ref ))
		begin 
			if (stats1.errors_z == 0) stats1.errortime_z = $time;
			stats1.errors_z = stats1.errors_z+1'b1;
		end

		// --- COMBINATIONAL FIRST MISMATCH DISPLAY (NEW REQUIREMENT) ---
		if (stats1.errors == 1 && z_ref !== z_dut) begin // Check for the absolute first mismatch
			first_mismatch_time = $time;
			$display("\n==================================================================");
			$display("*** FIRST MISMATCH DETECTED (Combinational Logic Check) ***");
			$display("Time of First Mismatch: %0d ps", $time);
			$display("------------------------------------------------------------------");
			// Display Inputs
			$display("Input A: Expected %b, Got %b", A, A);
			$display("Input B: Expected %b, Got %b", B, B);
			// Display Outputs
			$display("Reference Output z_ref: %b (Hex: %h)", z_ref, z_ref);
			$display("DUT Output z_dut: %b (Hex: %h)", z_dut, z_dut);
			$display("Expected Output (z_ref): %b (Hex: %h)", z_ref, z_ref);
			$display("==================================================================\n");
		end
	end

	// add timeout after 100K cycles
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

	// Final summary block - Updated to meet strict failure/success criteria
	final begin
		if (stats1.errors_z) $display("Hint: Output 'z' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_z, stats1.errortime_z);
		$display("Mismatches in Z (Reference vs DUT): %0d out of %0d samples.", stats1.errors_z, stats1.clocks);
		
		if (stats1.errors > 0) begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
			$display("Total mismatched samples (General): %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		end else begin
			$display("SIMULATION PASSED");
			end
		$display("Simulation finished at %0d ps", $time);
	end

endmodule
