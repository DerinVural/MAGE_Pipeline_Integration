	integer first_mismatch_time = -1;

	initial begin 
		$dumpfile("wave.vcd");
		// Note: Original dumpvars included tb_mismatch, which is derived, and top_module1.
		$dumpvars(1, tb);
	end

	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
