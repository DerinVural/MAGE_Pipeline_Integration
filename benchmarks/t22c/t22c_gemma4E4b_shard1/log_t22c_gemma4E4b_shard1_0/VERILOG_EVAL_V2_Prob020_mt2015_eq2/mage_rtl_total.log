	assign tb_match = ( { z_ref } === ( { z_ref } ^ { z_dut } ^ { z_ref } ) );

	// Clocked verification and statistics update
	always @(posedge clk, negedge clk) begin
		stats1.clocks++;

		// Update standard error counters (Original logic maintained)
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
		end

		// Update specific z error counter (Original logic maintained)
		if (z_ref !== ( z_ref ^ z_dut ^ z_ref ))
		begin 
			if (stats1.errors_z == 0) stats1.errortime_z = $time;
			stats1.errors_z = stats1.errors_z+1'b1;
		end

		// --- COMBINATIONAL FIRST MISMATCH DISPLAY (NEW REQUIREMENT) ---
		if (stats1.errors == 1 && z_ref !== z_dut) begin // Check for the absolute first mismatch
			first_mismatch_time = $time;
			$display("\n==================================================================");
