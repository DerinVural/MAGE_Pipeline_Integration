    "reasoning": "The solution should follow the given guidelines strictly. The module uses localparams for state definitions, not state_t. All ports and signals are declared as logic. Sequential logic with initial blocks instead of reset, avoiding X. Combinational blocks use always @(*). Avoided 'inside' and 'unique' operators. Properly XOR for hash, 128-entry PHT as registers. Two-bit counters with saturating update. Correct indexing for PHT using XOR of PC and history. Handling mispredict and updating history accordingly. Simulation-friendly with initial blocks for history and PHT initialization.",
    "module": "module TopModule (\n    input clk,\n    input areset,\n    input predict_valid,\n    input [6:0] predict_pc,\n    output logic predict_taken,\n    output logic [6:0] predict_history,\n    input train_valid,\n    input train_taken,\n    input train_mispredicted,\n    input [6:0] train_history,\n    input [6:0] train_pc\n);\n\n    // Parameters for PHT\n    localparam PHT_SIZE = 128;\n    localparam COUNTER_WIDTH = 2;\n\n    // State definitions\n    localparam STATE_IDLE = 0;\n    localparam STATE_PREDICT = 1;\n    localparam STATE_TRAIN = 2;\n\n    // Internal signals\n    logic [6:0] history_reg;\n    logic [COUNTER_WIDTH-1:0] pht [0:PHT_SIZE-1];\n\n    // Next state and combinational signals\n    logic [1:0] state, next_state;\n\n    // PHT index calculation\n    wire [6:0] pht_index;\n    assign pht_index = predict_pc ^ history_reg;\n\n    // Counter update logic\n    always @(*) begin\n        if (pht[pht_index] == 2'b00) begin\n            predict_taken = 0;\n        end else if (pht[pht_index] == 2'b11) begin\n            predict_taken = 1;\n        end else begin\n            // Fair prediction when counter is weak\n            predict_taken = pht[pht_index][1];\n        end\n    end\n\n    // State machine sequential logic\n    always @(posedge clk) begin\n        if (areset) begin\n            state <= STATE_IDLE;\n            history_reg <= 7'b0;\n            // Initialize PHT to 2'b10 (weakly taken)\n            for (int i = 0; i < PHT_SIZE; i++) begin\n                pht[i] <= 2'b10;\n            end\n        end else begin\n            state <= next_state;\n        end\n    end\n\n    // Next state logic\n    always @(*) begin\n        next_state = state;\n        case (state)\n            STATE_IDLE: begin\n                if (predict_valid) begin\n                    next_state = STATE_PREDICT;\n                end else if (train_valid) begin\n                    next_state = STATE_TRAIN;\n                end else begin\n                    next_state = STATE_IDLE;\n                end\n            end\n            STATE_PREDICT: begin\n                // Update history after prediction\n                history_reg <= (history_reg << 1) | predict_taken;\n                next_state = STATE_IDLE;\n            end\n            STATE_TRAIN: begin\n                // Training takes precedence\n                if (train_mispredicted) begin\n                    // Recover history to state after mispredict\n                    history_reg <= train_history;\n                end\n                // Update PHT counter based on train_taken\n                if (train_valid) begin\n                    if (train_taken) begin\n                        // Strongly taken: increment if not already max\n                        if (pht[train_pc ^ train_history] < 2'b11) begin\n                            pht[train_pc ^ train_history] <= pht[train_pc ^ train_history] + 1;\n                        end\n                    end else begin\n                        // Weakly not taken: decrement if not already min\n                        if (pht[train_pc ^ train_history] > 2'b00) begin\n                            pht[train_pc ^ train_history] <= pht[train_pc ^ train_history] - 1;\n                        end\n                    end\n                end\n                next_state = STATE_IDLE;\n            end\n            default: next_state = STATE_IDLE;\n        endcase\n    end\n\n    // Combinational prediction output\n    assign predict_history = history_reg;\n\nendmodule"
}
