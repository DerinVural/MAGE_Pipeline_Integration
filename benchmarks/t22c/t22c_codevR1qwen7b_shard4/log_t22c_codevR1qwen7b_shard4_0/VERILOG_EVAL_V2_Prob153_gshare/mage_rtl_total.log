                    $finish;
                end
            end
        end
        stats1.clocks++;
    end

    initial begin
        areset = 1;
        predict_valid = 0;
        train_valid = 0;
        // ... (stimulus from golden testbench)
    end

    initial begin
        // Timeout after 1e6 cycles
        #1000000;
        $display("TIMEOUT");
        $finish;
    end

    // Final checks and display
    final begin
        if (stats1.errors == 0)
            $display("SIMULATION PASSED");
    end
endmodule
