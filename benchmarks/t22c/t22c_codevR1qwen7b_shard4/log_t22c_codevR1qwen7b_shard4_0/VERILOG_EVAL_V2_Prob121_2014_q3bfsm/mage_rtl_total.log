`define OK 12
`define INCORRECT 13

module stimulus_gen (
    input clk,
    output logic reset,
    output logic x
);

    initial begin
        reset = 1;
        x = 0;
        @(posedge clk);
        @(posedge clk);
        reset = 0;
        @(posedge clk);
        @(posedge clk);
        
        repeat(500) @(negedge clk) begin
            reset <= !($random & 63);
            x <= $random;
        end
        
        #1 $finish;
    end

endmodule

module tb();
    typedef struct packed {
        int errors;
        int errortime;
        int errors_z;
        int errortime_z;
        int clocks;
    } stats;
    
    stats stats1;
    wire clk;
    reg clk_rst = 0;
    initial forever #5 clk_rst = ~clk_rst;
    assign clk = clk_rst;
    
    logic reset;
    logic x;
    logic z_ref;
    logic z_dut;
    
    stimulus_gen stim1 (
        .clk(clk),
        .reset(reset),
        .x(x)
    );
    
    RefModule good1 (
        .clk(clk),
        .reset(reset),
        .x(x),
        .z(z_ref)
    );
    
    TopModule top_module1 (
        .clk(clk),
        .reset(reset),
        .x(x),
        .z(z_dut)
    );
    
    wire tb_match;
    wire tb_mismatch = ~tb_match;
    
    assign tb_match = ( { z_ref } === ( { z_ref } ^ { z_dut } ^ { z_ref } ) );
    
    // Queue-based mismatch detection
    reg [2:0] state_queue [$:0];
    reg [2:0] next_state_x0_queue [$:0];
    reg [2:0] next_state_x1_queue [$:0];
    reg got_z_queue [$:0];
    reg reset_queue [$:0];
    
    localparam MAX_QUEUE_SIZE = 8;
    
    always @(posedge clk, negedge clk) begin
        if (state_queue.size() >= MAX_QUEUE_SIZE) begin
            state_queue.delete(0);
            next_state_x0_queue.delete(0);
            next_state_x1_queue.delete(0);
            got_z_queue.delete(0);
            reset_queue.delete(0);
        end
        
        state_queue.push_back($sformatf("%b", reset_queue[0]) == "1" ? $sformatf("%b", top_module1.y) : "---");
        next_state_x0_queue.push_back($sformatf("%b", reset_queue[0]) == "1" ? $sformatf("%b", top_module1.y_next_x0) : "---");
        next_state_x1_queue.push_back($sformatf("%b", reset_queue[0]) == "1" ? $sformatf("%b", top_module1.y_next_x1) : "---");
        got_z_queue.push_back(z_dut);
        reset_queue.push_back(reset);
        
        if (!tb_match) begin
            if (stats1.errors == 0) begin
                $display("FIRST MISMATCH AT TIME %0d", $time);
                $display("STATE QUEUE: %p", state_queue);
                $display("NEXT X0 QUEUE: %p", next_state_x0_queue);
                $display("NEXT X1 QUEUE: %p", next_state_x1_queue);
                $display("GOT Z QUEUE: %p", got_z_queue);
                $display("RESET QUEUE: %p", reset_queue);
                $display("SIMULATION FAILED - 1 MISMATCHES DETECTED, FIRST AT TIME %0d", $time);
                $finish;
            end
            stats1.errors++;
        end
    end
    
    initial begin
        stats1.errors = 0;
        stats1.errortime = 0;
        stats1.errors_z = 0;
        stats1.errortime_z = 0;
        stats1.clocks = 0;
    end
    
    // Simulation timeout
    initial begin
        #1000000 $display("TIMEOUT"); $finish;
    end
    
    // Simulation end display
    final begin
        if (stats1.errors) begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
        end else begin
            $display("SIMULATION PASSED");
        end
    end
endmodule
