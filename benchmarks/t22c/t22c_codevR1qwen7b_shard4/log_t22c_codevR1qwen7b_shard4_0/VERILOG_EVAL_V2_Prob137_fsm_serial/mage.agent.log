  localparam IDLE = 3'b000,
            START = 3'b001,
            DATA = 3'b010,
            STOP = 3'b011,
            ERROR = 3'b100;

  // State register
  always @(posedge clk) begin
    if (reset) state <= IDLE;
    else state <= next_state;
  end

