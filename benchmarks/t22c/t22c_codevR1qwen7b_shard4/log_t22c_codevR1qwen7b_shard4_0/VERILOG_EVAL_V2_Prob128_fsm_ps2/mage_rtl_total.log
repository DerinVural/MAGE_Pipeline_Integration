    input logic clk;
    input logic reset;
    input logic [7:0] in;
    output logic done;

    // State definitions
    localparam [1:0] IDLE = 2'b00,
                     FIRST = 2'b01,
                     SECOND = 2'b10,
                     THIRD = 2'b11;

    logic [1:0] state;
    logic [1:0] next_state;
    logic [1:0] byte_count;
    logic [1:0] next_byte_count;
    logic done_reg;

    // Initialize state and byte_count
    initial begin
        state = IDLE;
        byte_count = 0;
        done_reg = 0;
    end

    // Sequential block for state and byte_count updates
    always @(posedge clk) begin
        if (reset) begin
            state <= IDLE;
            byte_count <= 0;
        end else begin
            state <= next_state;
            byte_count <= next_byte_count;
        end
    end

    // Combinational next state logic
    always @(*) begin
        next_state = state;
        next_byte_count = byte_count;
        done_reg = 1'b0;
        case (state)
            IDLE: begin
                if (in[3]) begin
                    next_state = FIRST;
                    next_byte_count = 1;
                end else begin
                    next_state = IDLE;
                    next_byte_count = 0;
