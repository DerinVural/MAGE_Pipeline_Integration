[2026-05-14 13:03:07,980 - mage.rtl_editor - INFO] module TopModule (
    input clk,
    input reset,
    input [7:0] in,
    output done
);
    // Declare state variables and other registers
    reg [1:0] state, next_state;
    reg [2:0] byte_count;
    reg [7:0] message [0:2];
    reg done_reg;

    // State definitions using localparam
    localparam IDLE = 2'b00,
               WAIT_SECOND_BYTE = 2'b01,
               WAIT_THIRD_BYTE = 2'b10;

    // Sequential block for state transitions and reset
    always @(posedge clk) begin
        if (reset) begin
            state <= IDLE;
            byte_count <= 0;
            done_reg <= 0;
        end else begin
            state <= next_state;
            // Track incoming bytes with in[3]
            if (in[3]) begin
                message[byte_count] <= in;
                byte_count <= byte_count + 1;
            end
            // Reset byte_count and done after third byte received
            if (byte_count == 2 && in[3]) begin
                done_reg <= 1;
                byte_count <= 0;
            end else begin
                done_reg <= 0;
            end
        end
    end

    // Combinational logic for next_state
    always @(*) begin
        case (state)
            IDLE: next_state = (in[3]) ? WAIT_SECOND_BYTE : IDLE;
            WAIT_SECOND_BYTE: next_state = (in[3]) ? WAIT_THIRD_BYTE : IDLE;
            WAIT_THIRD_BYTE: begin
                if (in[3]) begin
                    next_state = IDLE;
                end else begin
                    next_state = IDLE;
                end
            end
            default: next_state = IDLE;
        endcase
    end

    // Assign output
    assign done = done_reg;
endmodule
