                next_byte_count = 1;
                if (in[3]) begin
                    next_state = SECOND;
                end else begin
                    next_state = FIRST;
                end
            end
            SECOND: begin
                next_byte_count = 2;
                if (in[3]) begin
                    next_state = THIRD;
                end else begin
                    next_state = SECOND;
                end
            end
            THIRD: begin
                next_byte_count = 3;
                next_state = IDLE;
            end
            default: begin
                next_state = IDLE;
                next_byte_count = 0;
            end
        endcase
    end

    // Assign output done from register
    assign done = done_reg;

endmodule
