[2026-05-14 12:58:52,260 - mage.agent - INFO] `timescale 1ps/1ps

module stimulus_gen (
    input clk,
    output logic [7:0] in,
    output logic reset
);

    initial begin
        repeat(200) @(negedge clk) begin
            in <= $random;
            reset <= !($random & 31);
        end
        #1 $finish;
    end

endmodule

module tb();
    typedef struct packed {
        int errors;
        int errortime;
        int errors_done;
        int errortime_done;
        int clocks;
    } stats;

    stats stats1 = '{errors:0, errortime:0, errors_done:0, errortime_done:0, clocks:0};

    reg clk = 0;
    initial forever #5 clk = ~clk;

    logic [7:0] in;
    logic reset;
    logic done_ref;
    logic done_dut;

    wire tb_match, tb_mismatch;

    stimulus_gen stim1 (
        .clk(clk),
        .in(in),
        .reset(reset)
    );

    RefModule good1 (
        .clk(clk),
        .in(in),
        .reset(reset),
        .done(done_ref)
    );

    TopModule top_module1 (
        .clk(clk),
        .in(in),
        .reset(reset),
        .done(done_dut)
    );

    // Mismatch check
    assign tb_match = ( { done_ref } === ( { done_ref } ^ { done_dut } ^ { done_ref } ) );
    assign tb_mismatch = ~tb_match;

    // Queue logic for display
    localparam MAX_QUEUE_SIZE = 5;
    reg [7:0] input_queue [0:MAX_QUEUE_SIZE-1];
    reg [0:0] got_output_queue [0:MAX_QUEUE_SIZE-1];
    reg [0:0] golden_queue [0:MAX_QUEUE_SIZE-1];
    reg [0:0] reset_queue [0:MAX_QUEUE_SIZE-1];

    integer push_ptr = 0;
    integer pop_ptr = 0;

    // Push to queue on clock edge
    always @(posedge clk, negedge clk) begin
        if (push_ptr >= MAX_QUEUE_SIZE) begin
            push_ptr <= 0;
        end
        input_queue[push_ptr] <= in;
        got_output_queue[push_ptr] <= done_dut;
        golden_queue[push_ptr] <= done_ref;
        reset_queue[push_ptr] <= reset;
        push_ptr <= push_ptr + 1;
    end

    // Check for first mismatch
    reg first_mismatch = 0;
    reg [1:0] error_count_done = 0;
    reg [1:0] error_count = 0;

    always @(posedge clk, negedge clk) begin
        stats1.clocks++;
        if (tb_mismatch && !first_mismatch) begin
            first_mismatch = 1;
            $display("Mismatch detected at time %t", $time);
            $display("Last %d cycles of simulation:", MAX_QUEUE_SIZE);
            for (int i = 0; i < MAX_QUEUE_SIZE; i++) begin
                $display("Cycle %d, reset %b, input %h, got output %b, exp output %b",
                    (push_ptr - i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE,
                    reset_queue[(push_ptr - i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE],
                    input_queue[(push_ptr - i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE],
                    got_output_queue[(push_ptr - i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE],
                    golden_queue[(push_ptr - i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE]);
            end
        end
        if (!tb_match) begin
            error_count++;
            if (stats1.errors == 0) stats1.errortime = $time;
        end
        if (done_ref !== ( done_ref ^ done_dut ^ done_ref )) begin
            error_count_done++;
            if (stats1.errors_done == 0) stats1.errortime_done = $time;
        end
    end

    // Timeout after 100K cycles
    initial begin
        #1000000 $display("TIMEOUT"); $finish();
    end

    // Simulation end
    initial begin
        #10000000; // Adjust as needed for normal finish
        $finish();
    end

    final begin
        if (error_count_done == 0) begin
            $display("SIMULATION PASSED");
        end else begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", error_count_done, stats1.errortime_done);
        end
    end
endmodule
