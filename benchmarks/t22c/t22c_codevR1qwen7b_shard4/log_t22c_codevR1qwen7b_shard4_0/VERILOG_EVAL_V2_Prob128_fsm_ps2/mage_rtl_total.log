                next_byte_count = 0;
            end
            default: begin
                next_state = IDLE;
                next_byte_count = 0;
            end
        endcase
    end

    // Update state and counters
    always @(posedge clk) begin
        if (reset) begin
            state <= IDLE;
            byte_count <= 0;
