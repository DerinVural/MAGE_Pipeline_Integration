[2026-05-14 13:03:15,786 - mage.rtl_editor - INFO] module TopModule (
    input clk,
    input reset,
    input [7:0] in,
    output done
);
    // Declare state variables
    reg [1:0] state, next_state;
    reg [2:0] byte_count;
    reg [7:0] msg [0:2]; // Store three bytes of message
    reg done_reg;

    // State definitions
    localparam IDLE = 2'b00,
               WAIT_SECOND = 2'b01,
               WAIT_THIRD = 2'b10;

    // Sequential state transition with synchronous reset
    always @(posedge clk) begin
        if (reset) begin
            state <= IDLE;
            byte_count <= 0;
            done_reg <= 0;
        end else begin
            state <= next_state;
            // Capture incoming bytes with in[3] high
            if (in[3]) begin
                msg[byte_count] <= in;
                byte_count <= byte_count + 1;
            end
            // Reset byte count after third valid byte
            if (byte_count == 2 && in[3]) begin
                done_reg <= 1;
                byte_count <= 0;
            end else begin
                done_reg <= 0;
            end
        end
    end

    // Combinational next state logic
    always @(*) begin
        case (state)
            IDLE: next_state = (in[3]) ? WAIT_SECOND : IDLE;
            WAIT_SECOND: next_state = (in[3]) ? WAIT_THIRD : IDLE;
            WAIT_THIRD: begin
                if (in[3])
                    next_state = IDLE;
                else
                    next_state = IDLE;
            end
            default: next_state = IDLE;
        endcase
    end

    // Assign output
    assign done = done_reg;
endmodule
