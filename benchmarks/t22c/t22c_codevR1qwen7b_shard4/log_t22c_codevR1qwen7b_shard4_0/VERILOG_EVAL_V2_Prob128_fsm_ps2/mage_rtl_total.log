[2026-05-14 13:04:19,617 - mage.rtl_editor - INFO] module TopModule (
    input clk,
    input reset,
    input [7:0] in,
    output done
);
    // State variables and parameters
    localparam IDLE = 2'b00,
               FIRST = 2'b01,
               SECOND = 2'b10,
               THIRD = 2'b11;

    reg [1:0] state, next_state;
    reg [2:0] byte_count;
    reg done_reg;
    reg [7:0] message [0:2];

    // Sequential state update
    always @(posedge clk) begin
        if (reset) begin
            state <= IDLE;
            byte_count <= 0;
            done_reg <= 0;
        end else begin
            state <= next_state;
            // Capture valid bytes when in[3] is high
            if (in[3]) begin
                case (state)
                    IDLE: begin
                        message[0] <= in;
                        byte_count <= 1;
                    end
                    FIRST: begin
                        message[1] <= in;
                        byte_count <= 2;
                    end
                    SECOND: begin
                        message[2] <= in;
                        byte_count <= 3;
                    end
                    THIRD: begin
                        byte_count <= 0;
                        done_reg <= 1;
                    end
                endcase
            end else begin
                done_reg <= 0;
            end
        end
    end

    // Combinational next state logic
    always @(*) begin
        next_state = state;
        case (state)
            IDLE: next_state = (in[3]) ? FIRST : IDLE;
            FIRST: next_state = (in[3]) ? SECOND : IDLE;
            SECOND: next_state = (in[3]) ? THIRD : IDLE;
            THIRD: next_state = IDLE;
            default: next_state = IDLE;
        endcase
    end

    // Output assignment after three valid bytes
    assign done = done_reg && (byte_count == 3);

endmodule
