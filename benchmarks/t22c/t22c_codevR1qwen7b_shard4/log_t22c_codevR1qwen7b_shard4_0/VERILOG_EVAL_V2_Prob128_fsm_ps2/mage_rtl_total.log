    // Declare state registers
    reg [1:0] state, next_state;
    reg [2:0] byte_count;
    reg done_reg;
    reg [7:0] msg [0:2]; // Store three bytes

    // State definitions using localparam
    localparam IDLE = 2'b00,
               FIRST_BYTE = 2'b01,
               SECOND_BYTE = 2'b10,
               THIRD_BYTE = 2'b11;

    // Sequential state transition and reset handling
    always @(posedge clk) begin
        if (reset) begin
            state <= IDLE;
            byte_count <= 0;
            done_reg <= 0;
        end else begin
            state <= next_state;
            // Capture byte if in[3] is high
            if (in[3]) begin
                msg[byte_count] <= in;
                byte_count <= byte_count + 1;
            end
            // Reset after three valid bytes
            if (byte_count == 3) begin
                done_reg <= 1;
                byte_count <= 0;
            end else begin
                done_reg <= 0;
            end
        end
    end

    // Next state logic
    always @(*) begin
        case (state)
            IDLE: next_state = (in[3]) ? FIRST_BYTE : IDLE;
            FIRST_BYTE: next_state = (in[3]) ? SECOND_BYTE : IDLE;
            SECOND_BYTE: next_state = (in[3]) ? THIRD_BYTE : IDLE;
            THIRD_BYTE: next_state = (in[3]) ? IDLE : IDLE;
            default: next_state = IDLE;
        endcase
    end

    // Output assignment
    assign done = done_reg;

endmodule
