    // State definitions
    localparam IDLE = 2'b00,
               FIRST_BYTE = 2'b01,
               SECOND_BYTE = 2'b10,
               THIRD_BYTE = 2'b11;

    reg [1:0] state, next_state;
    reg done_reg;
    reg [2:0] byte_count;
    reg [7:0] msg [0:2];

    // Sequential state and byte_count update
    always @(posedge clk) begin
        if (reset) begin
            state <= IDLE;
            byte_count <= 0;
            done_reg <= 0;
        end else begin
            state <= next_state;
            if (in[3]) begin
