    input clk,
    input reset,
    input [7:0] in,
    output done
);
    // Declare state variables and registers
    reg [1:0] state, next_state;
    reg [2:0] byte_count;
    reg done_reg;
    reg [7:0] message [0:2]; // Store the three message bytes

    // State definitions using localparam
    localparam IDLE = 2'b00,
               FIRST_BYTE = 2'b01,
               SECOND_BYTE = 2'b10,
               THIRD_BYTE = 2'b11;

    // Sequential logic for state and byte_count
    always @(posedge clk) begin
        if (reset) begin
            state <= IDLE;
            byte_count <= 0;
            done_reg <= 0;
        end else begin
            state <= next_state;
            // Capture valid bytes when in[3] is high
            if (in[3]) begin
                message[byte_count] <= in;
                byte_count <= (byte_count == 2) ? 0 : byte_count + 1;
            end
            // Reset byte_count after third valid byte and set done_reg
            if (byte_count == 2 && in[3]) begin
                done_reg <= 1;
                byte_count <= 0;
            end else begin
                done_reg <= 0;
            end
        end
    end

    // Combinational logic for next_state
    always @(*) begin
        next_state = state; // Default to current state
        case (state)
            IDLE: begin
                if (in[3])
                    next_state = FIRST_BYTE;
                else
                    next_state = IDLE;
            end
            FIRST_BYTE: begin
                if (in[3])
                    next_state = SECOND_BYTE;
                else
                    next_state = IDLE;
            end
            SECOND_BYTE: begin
                if (in[3])
                    next_state = THIRD_BYTE;
                else
                    next_state = IDLE;
            end
            THIRD_BYTE: begin
                next_state = IDLE; // Return to IDLE after third byte
            end
            default: next_state = IDLE;
        endcase
    end

    // Assign output done signal
    assign done = done_reg;

endmodule
