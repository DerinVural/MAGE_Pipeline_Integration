    input clk,
    input reset,
    input [7:0] in,
    output done
);
    // FSM states
    localparam IDLE = 2'b00,
               FIRST_BYTE = 2'b01,
               SECOND_BYTE = 2'b10,
               THIRD_BYTE = 2'b11;

    reg [1:0] state, next_state;
    reg [2:0] byte_count;
    reg done_reg;
    reg [7:0] msg_buffer [0:2];

    // Sequential state update
    always @(posedge clk) begin
        if (reset) begin
            state <= IDLE;
            byte_count <= 0;
            done_reg <= 0;
        end else begin
            state <= next_state;
            // Capture message bytes on valid in[3]
            if (in[3]) begin
                case (state)
                    IDLE: begin
                        msg_buffer[0] <= in;
                        byte_count <= 1;
                    end
                    FIRST_BYTE: begin
                        msg_buffer[1] <= in;
                        byte_count <= 2;
                    end
                    SECOND_BYTE: begin
                        msg_buffer[2] <= in;
                        byte_count <= 3;
                    end
                    THIRD_BYTE: begin
                        byte_count <= 0;
                        done_reg <= 1;
                    end
                endcase
            end else begin
                done_reg <= 0;
            end
        end
    end

    // Combinational next state logic
    always @(*) begin
        next_state = state;
        case (state)
            IDLE: next_state = (in[3]) ? FIRST_BYTE : IDLE;
            FIRST_BYTE: next_state = (in[3]) ? SECOND_BYTE : IDLE;
            SECOND_BYTE: next_state = (in[3]) ? THIRD_BYTE : IDLE;
            THIRD_BYTE: next_state = IDLE;
            default: next_state = IDLE;
        endcase
    end

    // Done is asserted after three valid bytes received
    assign done = (byte_count == 3) && done_reg;

endmodule
