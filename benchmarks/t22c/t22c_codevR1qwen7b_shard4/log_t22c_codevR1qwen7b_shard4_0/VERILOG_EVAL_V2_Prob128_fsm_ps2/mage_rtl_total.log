   // Check for first mismatch\n    reg first_mismatch = 0;\n    reg [1:0] error_count_done = 0;\n    reg [1:0] error_count = 0;\n\n    always @(posedge clk, negedge clk) begin\n        stats1.clocks++;\n        if (tb_mismatch && !first_mismatch) begin\n            first_mismatch = 1;\n            $display("Mismatch detected at time %t", $time);\n            $display("Last %d cycles of simulation:", MAX_QUEUE_SIZE);\n            for (int i = 0; i < MAX_QUEUE_SIZE; i++) begin\n                $display("Cycle %d, reset %b, input %h, got output %b, exp output %b",\n                    (push_ptr - i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE,\n                    reset_queue[(push_ptr - i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE],\n                    input_queue[(push_ptr - i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE],\n                    got_output_queue[(push_ptr - i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE],\n                    golden_queue[(push_ptr - i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE]);\n            end\n        end\n        if (!tb_match) begin\n            error_count++;\n            if (stats1.errors == 0) stats1.errortime = $time;\n        end\n        if (done_ref !== ( done_ref ^ done_dut ^ done_ref )) begin\n            error_count_done++;\n            if (stats1.errors_done == 0) stats1.errortime_done = $time;\n        end\n    end\n\n    // Timeout after 100K cycles\n    initial begin\n        #1000000 $display("TIMEOUT"); $finish();\n    end\n\n    // Simulation end\n    initial begin\n        #10000000; // Adjust as needed for normal finish\n        $finish();\n    end\n\n    final begin\n        if (error_count_done == 0) begin\n            $display("SIMULATION PASSED");\n        end else begin\n            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", error_count_done, stats1.errortime_done);\n        end\n    end\nendmodule\n</testbench>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='te