[2026-05-14 13:03:57,410 - mage.rtl_editor - INFO] module TopModule (
    input clk,
    input reset,
    input [7:0] in,
    output done
);
    // State parameters and registers
    reg [1:0] state, next_state;
    reg [2:0] byte_count;
    reg done_reg;
    reg [7:0] message [0:2]; // To store three bytes

    // State definitions
    localparam IDLE = 2'b00,
               FIRST_BYTE = 2'b01,
               SECOND_BYTE = 2'b10,
               THIRD_BYTE = 2'b11;

    // Sequential logic for state and byte_count
    always @(posedge clk) begin
        if (reset) begin
            state <= IDLE;
            byte_count <= 0;
            done_reg <= 0;
        end else begin
            state <= next_state;
            // Capture valid bytes when in[3] is high
            if (in[3]) begin
                case (state)
                    IDLE: begin
                        message[0] <= in;
                        byte_count <= 1;
                    end
                    FIRST_BYTE: begin
                        message[1] <= in;
                        byte_count <= 2;
                    end
                    SECOND_BYTE: begin
                        message[2] <= in;
                        byte_count <= 3;
                    end
                    THIRD_BYTE: begin
                        byte_count <= 0;
                        done_reg <= 1;
                    end
                endcase
            end else begin
                done_reg <= 0;
            end
        end
    end

    // Combinational logic for next_state
    always @(*) begin
        next_state = state;
        case (state)
            IDLE: next_state = (in[3]) ? FIRST_BYTE : IDLE;
            FIRST_BYTE: next_state = (in[3]) ? SECOND_BYTE : IDLE;
            SECOND_BYTE: next_state = (in[3]) ? THIRD_BYTE : IDLE;
            THIRD_BYTE: next_state = IDLE;
            default: next_state = IDLE;
        endcase
    end

    // Output assignment
    assign done = done_reg && (byte_count == 3);

endmodule
