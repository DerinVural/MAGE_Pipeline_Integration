[2026-05-14 13:04:36,667 - mage.rtl_editor - INFO] module TopModule (
    input clk,
    input reset,
    input [7:0] in,
    output done
);
    // Declare state parameters
    localparam IDLE = 2'b00,
               FIRST = 2'b01,
               SECOND = 2'b10,
               THIRD = 2'b11;

    reg [1:0] current_state, next_state;
    reg [2:0] byte_count;
    reg done_reg;
    reg [7:0] message [0:2];

    // Sequential logic for state transitions and byte_count
    always @(posedge clk) begin
        if (reset) begin
            current_state <= IDLE;
            byte_count <= 0;
            done_reg <= 0;
        end else begin
            current_state <= next_state;
            // Capture bytes when in[3] is high
            if (in[3]) begin
                case (current_state)
                    IDLE: begin
                        message[0] <= in;
                        byte_count <= 1;
                    end
                    FIRST: begin
                        message[1] <= in;
                        byte_count <= 2;
                    end
                    SECOND: begin
                        message[2] <= in;
                        byte_count <= 3;
                    end
                    THIRD: begin
                        byte_count <= 0;
                        done_reg <= 1;
                    end
                    default: byte_count <= 0;
                endcase
            end
        end
    end

    // Combinational logic for next_state and conditions
    always @(*) begin
        next_state = current_state;
        done_reg = 0; // Default assignment
        case (current_state)
            IDLE: next_state = (in[3]) ? FIRST : IDLE;
            FIRST: next_state = (in[3]) ? SECOND : IDLE;
            SECOND: next_state = (in[3]) ? THIRD : IDLE;
            THIRD: next_state = IDLE;
            default: next_state = IDLE;
        endcase
        // If third byte is received, set done after transition
        if (current_state == SECOND && in[3]) begin
            done_reg = 1;
        end
    end

    // Assign done output
    assign done = done_reg && (byte_count == 3);

endmodule
