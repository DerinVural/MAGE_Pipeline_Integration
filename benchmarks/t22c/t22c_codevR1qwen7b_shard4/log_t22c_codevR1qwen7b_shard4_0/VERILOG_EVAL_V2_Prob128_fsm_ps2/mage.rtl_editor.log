[2026-05-14 13:03:00,373 - mage.rtl_editor - INFO] module TopModule (
    input clk,
    input reset,
    input [7:0] in,
    output done
);
    // State variables
    reg [1:0] state, next_state;
    reg [2:0] byte_count;
    reg [7:0] message [0:2];
    reg done_reg;

    // State definitions
    localparam IDLE = 2'b00,
              WAIT_SECOND_BYTE = 2'b01,
              WAIT_THIRD_BYTE = 2'b10;

    // Sequential block for state transitions
    always @(posedge clk) begin
        if (reset) begin
            state <= IDLE;
            byte_count <= 0;
            done_reg <= 0;
        end else begin
            state <= next_state;
            // Track bytes
            if (byte_count < 3 && in[3]) begin
                message[byte_count] <= in;
                byte_count <= byte_count + 1;
            end
            // Assert done after third byte
            if (byte_count == 2 && in[3]) begin
                done_reg <= 1;
                byte_count <= 0;
            end else begin
                done_reg <= 0;
            end
        end
    end

    // Next state logic
    always @(*) begin
        case (state)
            IDLE: begin
                next_state = in[3] ? WAIT_SECOND_BYTE : IDLE;
            end
            WAIT_SECOND_BYTE: begin
                next_state = in[3] ? WAIT_THIRD_BYTE : IDLE;
            end
            WAIT_THIRD_BYTE: begin
                if (in[3]) begin
                    next_state = IDLE;
                    done_reg <= 1;
                end else begin
                    next_state = IDLE;
                end
            end
            default: next_state = IDLE;
        endcase
    end

    assign done = done_reg;
