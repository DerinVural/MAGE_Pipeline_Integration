    input clk,
    input reset,
    input [7:0] in,
    output done
);
    // State definitions
    reg [1:0] state, next_state;
    reg [2:0] byte_count;
    reg [7:0] message [0:2];
    reg done_reg;

    // State parameters
    localparam IDLE = 2'd0,
               FIRST_BYTE = 2'd1,
               SECOND_BYTE = 2'd2,
               THIRD_BYTE = 2'd3;

    // Sequential block for state and byte_count
    always @(posedge clk) begin
        if (reset) begin
            state <= IDLE;
            byte_count <= 0;
            done_reg <= 0;
        end else begin
            state <= next_state;
            // Capture valid bytes with in[3] == 1
            if (in[3]) begin
                message[byte_count] <= in;
                byte_count <= (byte_count == 2) ? 0 : byte_count + 1;
            end
            // Reset when third byte is received
            if (state == THIRD_BYTE && in[3]) begin
                done_reg <= 1;
            end else begin
                done_reg <= 0;
            end
        end
    end

    // Combinational next state logic
    always @(*) begin
        case (state)
            IDLE: next_state = (in[3]) ? FIRST_BYTE : IDLE;
            FIRST_BYTE: next_state = (in[3]) ? SECOND_BYTE : IDLE;
            SECOND_BYTE: next_state = (in[3]) ? THIRD_BYTE : IDLE;
            THIRD_BYTE: next_state = IDLE;
            default: next_state = IDLE;
        endcase
    end

    assign done = done_reg;
endmodule
