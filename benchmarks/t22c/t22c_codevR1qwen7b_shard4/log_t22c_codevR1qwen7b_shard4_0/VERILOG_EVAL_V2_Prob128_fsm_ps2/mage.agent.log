                    reset_queue[(push_ptr - i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE],
                    input_queue[(push_ptr - i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE],
                    got_output_queue[(push_ptr - i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE],
                    golden_queue[(push_ptr - i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE]);
            end
        end
        if (!tb_match) begin
            error_count++;
            if (stats1.errors == 0) stats1.errortime = $time;
        end
        if (done_ref !== ( done_ref ^ done_dut ^ done_ref )) begin
            error_count_done++;
            if (stats1.errors_done == 0) stats1.errortime_done = $time;
        end
    end

    // Timeout after 100K cycles
    initial begin
        #1000000 $display("TIMEOUT"); $finish();
    end

    // Simulation end
    initial begin
        #10000000; // Adjust as needed for normal finish
        $finish();
    end

    final begin
        if (error_count_done == 0) begin
            $display("SIMULATION PASSED");
        end else begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", error_count_done, stats1.errortime_done);
        end
    end
endmodule
