    localparam MAX_QUEUE_SIZE = 5;
    reg [7:0] input_queue [0:MAX_QUEUE_SIZE-1];
    reg [0:0] got_output_queue [0:MAX_QUEUE_SIZE-1];
    reg [0:0] golden_queue [0:MAX_QUEUE_SIZE-1];
    reg [0:0] reset_queue [0:MAX_QUEUE_SIZE-1];

    integer push_ptr = 0;
    integer pop_ptr = 0;

    // Push to queue on clock edge
    always @(posedge clk, negedge clk) begin
        if (push_ptr >= MAX_QUEUE_SIZE) begin
            push_ptr <= 0;
        end
        input_queue[push_ptr] <= in;
        got_output_queue[push_ptr] <= done_dut;
        golden_queue[push_ptr] <= done_ref;
        reset_queue[push_ptr] <= reset;
        push_ptr <= push_ptr + 1;
    end

    // Check for first mismatch
    reg first_mismatch = 0;
    reg [1:0] error_count_done = 0;
    reg [1:0] error_count = 0;

    always @(posedge clk, negedge clk) begin
        stats1.clocks++;
        if (tb_mismatch && !first_mismatch) begin
            first_mismatch = 1;
            $display("Mismatch detected at time %t", $time);
            $display("Last %d cycles of simulation:", MAX_QUEUE_SIZE);
            for (int i = 0; i < MAX_QUEUE_SIZE; i++) begin
                $display("Cycle %d, reset %b, input %h, got output %b, exp output %b",
