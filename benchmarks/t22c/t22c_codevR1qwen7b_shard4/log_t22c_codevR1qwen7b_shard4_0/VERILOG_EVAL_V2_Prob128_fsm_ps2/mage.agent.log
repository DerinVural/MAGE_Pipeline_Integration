[2026-05-14 12:58:58,944 - mage.agent - INFO] module TopModule (clk, reset, in, done);
    input logic clk;
    input logic reset;
    input logic [7:0] in;
    output logic done;

    // States
    localparam IDLE = 2'b00;
    localparam COLLECT = 2'b01;
    localparam DONE_STATE = 2'b10;

    reg [1:0] state = IDLE;
    reg [1:0] next_state;
    reg [1:0] byte_count = 0;
    reg [1:0] next_byte_count;

    // State transition
    always @(*) begin
        case (state)
            IDLE: begin
                next_state = (in[3]) ? COLLECT : IDLE;
                next_byte_count = 1;
            end
            COLLECT: begin
                if (byte_count == 2) begin
                    next_state = DONE_STATE;
                    next_byte_count = 0;
                end else begin
                    next_state = COLLECT;
                    next_byte_count = byte_count + 1;
                end
            end
            DONE_STATE: begin
                next_state = IDLE;
                next_byte_count = 0;
            end
            default: begin
                next_state = IDLE;
                next_byte_count = 0;
            end
        endcase
    end

    // Update state and counters
    always @(posedge clk) begin
        if (reset) begin
            state <= IDLE;
            byte_count <= 0;
        end else begin
            state <= next_state;
            byte_count <= next_byte_count;
        end
    end

    // Output logic
    assign done = (state == DONE_STATE);
endmodule
