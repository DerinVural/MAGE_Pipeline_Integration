    output logic done;

    // State definitions
    localparam STATE_IDLE = 0;
    localparam STATE_BYTE1 = 1;
    localparam STATE_WAIT2 = 2;

    reg [1:0] state, next_state;
    reg [1:0] byte_count;
    reg [1:0] byte_count_next;

    // Initialize states and counters
    initial begin
        state = STATE_IDLE;
        byte_count = 0;
    end

    // State transition
    always @(*) begin
        next_state = state;
        case (state)
            STATE_IDLE: begin
