[2026-05-14 13:02:42,665 - mage.rtl_generator - INFO] RTL code: module TopModule (clk, reset, in, done);
    input logic clk;
    input logic reset;
    input logic [7:0] in;
    output logic done;

    // States
    localparam IDLE = 0,
              BYTE1 = 1,
              BYTE2 = 2,
              BYTE3 = 3;
    logic [1:0] state, next_state;

    // State register
    always @(posedge clk) begin
        if (reset)
            state <= IDLE;
        else
            state <= next_state;
    end

    // Next state logic
    always @(*) begin
        next_state = state;
        case (state)
            IDLE: begin
                if (in[3])
                    next_state = BYTE1;
            end
            BYTE1: next_state = BYTE2;
            BYTE2: next_state = BYTE3;
            BYTE3: next_state = IDLE;
        endcase
    end

    // Output logic: done asserted in the cycle after third byte
    reg done_reg;
    always @(posedge clk) begin
        if (reset)
            done_reg <= 0;
        else
            done_reg <= (state == BYTE3);
    end
    assign done = done_reg;

endmodule
