    input logic clk;
    input logic reset;
    input logic [7:0] in;
    output logic done;

    // State definitions
    localparam IDLE = 1'b0;
    localparam COLLECT = 1'b1;
    reg state;
    reg [1:0] count;

    // Initialize registers
    initial begin
        state = IDLE;
        count = 0;
    end

    // FSM transitions
    always @(posedge clk) begin
        if (reset) begin
            state <= IDLE;
            count <= 0;
        end else begin
            case (state)
                IDLE: begin
                    if (in[3]) begin
                        state <= COLLECT;
                        count <= 1;
                    end else begin
                        state <= IDLE;
                        count <= 0;
                    end
                end
                COLLECT: begin
                    if (in[3]) begin
                        if (count == 2) begin
                            state <= IDLE;
                            count <= 0;
                        end else begin
                            count <= count + 1;
                        end
                    end else begin
                        // If next byte doesn't have in[3], discard and stay in COLLECT
                        state <= COLLECT;
                        count <= 0; // Reset counter if invalid byte? Or wait until next valid in[3]?
                    end
                end
                default: state <= IDLE;
            endcase
        end
    end

    // Done signal: Assert when third byte received
    always @(posedge clk) begin
        if (reset) begin
            done <= 0;
        end else begin
            if (state == COLLECT && count == 2 && in[3]) begin
                done <= 1;
            end else begin
                done <= 0;
            end
        end
    end

endmodule
