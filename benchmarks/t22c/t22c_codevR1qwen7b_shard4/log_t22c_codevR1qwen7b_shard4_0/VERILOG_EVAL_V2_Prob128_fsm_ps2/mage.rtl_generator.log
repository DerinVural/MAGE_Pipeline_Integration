[2026-05-14 13:02:42,587 - mage.rtl_generator - INFO] RTL code: module TopModule (clk, reset, in, done);
    input logic clk;
    input logic reset;
    input logic [7:0] in;
    output logic done;

    // State definitions
    localparam STATE_IDLE = 0;
    localparam STATE_BYTE1 = 1;
    localparam STATE_BYTE2 = 2;
    localparam STATE_DONE = 3;

    // State register and counters
    logic [1:0] state = STATE_IDLE;
    logic [2:0] byte_count = 0;

    // FSM transitions
    always @(posedge clk) begin
        if (reset) begin
            state <= STATE_IDLE;
            byte_count <= 0;
        end else begin
            case (state)
                STATE_IDLE: begin
                    if (in[3]) begin
                        state <= STATE_BYTE1;
                        byte_count <= byte_count + 1;
                    end
                end
                STATE_BYTE1: begin
                    if (in[3]) begin
                        state <= STATE_BYTE2;
                        byte_count <= byte_count + 1;
                    end else begin
                        state <= STATE_IDLE;
                    end
                end
                STATE_BYTE2: begin
                    if (in[3]) begin
                        state <= STATE_DONE;
                        byte_count <= byte_count + 1;
                    end else begin
                        state <= STATE_IDLE;
                    end
                end
                STATE_DONE: begin
                    state <= STATE_IDLE;
                end
                default: state <= STATE_IDLE;
            endcase
        end
    end

    // Done signal logic
    always @(posedge clk) begin
        done <= (state == STATE_DONE);
    end

endmodule
