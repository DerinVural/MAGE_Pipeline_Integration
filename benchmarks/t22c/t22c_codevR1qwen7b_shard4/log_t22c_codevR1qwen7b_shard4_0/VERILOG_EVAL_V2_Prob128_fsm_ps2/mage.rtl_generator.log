[2026-05-14 13:01:47,068 - mage.rtl_generator - INFO] RTL code: module TopModule (clk, reset, in, done);
    input clk;
    input reset;
    input [7:0] in;
    output logic done;

    localparam STATE_IDLE = 0;
    localparam STATE_WAIT_B2 = 1;
    localparam STATE_WAIT_B3 = 2;
    localparam STATE_DONE_WAIT = 3;

    logic [1:0] state = STATE_IDLE;
    logic [1:0] next_state;

    // Combinational logic for next state
    always @(*) begin
        next_state = state;
        case (state)
            STATE_IDLE: begin
                if (in[3])
                    next_state = STATE_WAIT_B2;
            end
            STATE_WAIT_B2: begin
                if (in[3])
                    next_state = STATE_WAIT_B3;
            end
            STATE_WAIT_B3: begin
                if (in[3])
                    next_state = STATE_DONE_WAIT;
            end
            STATE_DONE_WAIT: begin
                next_state = STATE_IDLE;
            end
            default: next_state = STATE_IDLE;
        endcase
    end

    // Sequential logic
    always @(posedge clk) begin
        if (reset) begin
            state <= STATE_IDLE;
        end else begin
            state <= next_state;
        end
    end

    // Output logic: done asserted for one cycle after third byte
    assign done = (state == STATE_DONE_WAIT);

endmodule
