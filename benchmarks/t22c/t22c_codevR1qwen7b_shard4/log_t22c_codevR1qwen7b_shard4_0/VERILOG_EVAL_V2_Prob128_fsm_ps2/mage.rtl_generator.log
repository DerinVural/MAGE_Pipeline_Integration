                    next_state = STATE_BYTE1;
                end else begin
                    next_state = STATE_IDLE;
                end
            end
            STATE_BYTE1: begin
                next_state = STATE_WAIT2;
            end
            STATE_WAIT2: begin
                if (in[3]) begin
                    next_state = STATE_BYTE1;
                    byte_count_next = byte_count + 1;
                end else begin
                    next_state = STATE_WAIT2;
                end
            end
            default: next_state = STATE_IDLE;
        endcase
    end

    // Sequential logic
    always @(posedge clk) begin
        if (reset) begin
            state <= STATE_IDLE;
            byte_count <= 0;
        end else begin
            state <= next_state;
            byte_count <= byte_count_next;
        end
    end

    // Done signal: After receiving third byte (count 2 since starts at 0)
    assign done = (state == STATE_WAIT2) && (byte_count == 2'd2);
endmodule
