[2026-05-14 13:02:42,554 - mage.rtl_generator - INFO] RTL code: module TopModule (clk, reset, in, done);
    input logic clk;
    input logic reset;
    input logic [7:0] in;
    output logic done;

    // State definitions
    localparam IDLE = 2'b00;
    localparam FIRST = 2'b01;
    localparam SECOND = 2'b10;
    localparam DONE_STATE = 2'b11;

    // State register and byte counters
    logic [1:0] state;
    logic [1:0] byte_count;

    // Initialize states and counters
    initial begin
        state = IDLE;
        byte_count = 0;
    end

    // Sequential logic
    always @(posedge clk) begin
        if (reset) begin
            state <= IDLE;
            byte_count <= 0;
        end else begin
            case (state)
                IDLE: begin
                    if (in[3]) begin
                        state <= FIRST;
                        byte_count <= 1;
                    end else begin
                        state <= IDLE;
                    end
                end
                FIRST: begin
                    if (in[3]) begin
                        state <= SECOND;
                        byte_count <= 2;
                    end else begin
                        state <= FIRST; // Stay if current byte doesn't have in[3]
                    end
                end
                SECOND: begin
                    if (in[3]) begin
                        state <= DONE_STATE;
                    end else begin
                        state <= SECOND;
                    end
                end
                DONE_STATE: begin
                    state <= IDLE;
                    byte_count <= 0;
                end
                default: state <= IDLE;
            endcase
        end
    end

    // Combinational logic for done (asserted when third byte is received)
    assign done = (state == DONE_STATE);

endmodule
