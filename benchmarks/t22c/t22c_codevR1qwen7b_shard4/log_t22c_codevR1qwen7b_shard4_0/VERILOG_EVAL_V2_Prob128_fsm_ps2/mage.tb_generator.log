    "testbench": "`timescale 1ps/1ps\n\nmodule stimulus_gen (\n    input clk,\n    output logic [7:0] in,\n    output logic reset\n);\n\n    initial begin\n        repeat(200) @(negedge clk) begin\n            in <= $random;\n            reset <= !($random & 31);\n        end\n        #1 $finish;\n    end\n\nendmodule\n\nmodule tb();\n    typedef struct packed {\n        int errors;\n        int errortime;\n        int errors_done;\n        int errortime_done;\n        int clocks;\n    } stats;\n\n    stats stats1 = '{errors:0, errortime:0, errors_done:0, errortime_done:0, clocks:0};\n\n    reg clk = 0;\n    initial forever #5 clk = ~clk;\n\n    logic [7:0] in;\n    logic reset;\n    logic done_ref;\n    logic done_dut;\n\n    wire tb_match, tb_mismatch;\n\n    stimulus_gen stim1 (\n        .clk(clk),\n        .in(in),\n        .reset(reset)\n    );\n\n    RefModule good1 (\n        .clk(clk),\n        .in(in),\n        .reset(reset),\n        .done(done_ref)\n    );\n\n    TopModule top_module1 (\n        .clk(clk),\n        .in(in),\n        .reset(reset),\n        .done(done_dut)\n    );\n\n    // Mismatch check\n    assign tb_match = ( { done_ref } === ( { done_ref } ^ { done_dut } ^ { done_ref } ) );\n    assign tb_mismatch = ~tb_match;\n\n    // Queue logic for display\n    localparam MAX_QUEUE_SIZE = 5;\n    reg [7:0] input_queue [0:MAX_QUEUE_SIZE-1];\n    reg [0:0] got_output_queue [0:MAX_QUEUE_SIZE-1];\n    reg [0:0] golden_queue [0:MAX_QUEUE_SIZE-1];\n    reg [0:0] reset_queue [0:MAX_QUEUE_SIZE-1];\n\n    integer push_ptr = 0;\n    integer pop_ptr = 0;\n\n    // Push to queue on clock edge\n    always @(posedge clk, negedge clk) begin\n        if (push_ptr >= MAX_QUEUE_SIZE) begin\n            push_ptr <= 0;\n        end\n        input_queue[push_ptr] <= in;\n        got_output_queue[push_ptr] <= done_dut;\n        golden_queue[push_ptr] <= done_ref;\n        reset_queue[push_ptr] <= reset;\n        push_ptr <= push_ptr + 1;\n    end\n\n    // Check for first mismatch\n    reg first_mismatch = 0;\n    reg [1:0] error_count_done = 0;\n    reg [1:0] error_count = 0;\n\n    always @(posedge clk, negedge clk) begin\n        stats1.clocks++;\n        if (tb_mismatch && !first_mismatch) begin\n            first_mismatch = 1;\n            $display(\"Mismatch detected at time %t\", $time);\n            $display(\"Last %d cycles of simulation:\", MAX_QUEUE_SIZE);\n            for (int i = 0; i < MAX_QUEUE_SIZE; i++) begin\n                $display(\"Cycle %d, reset %b, input %h, got output %b, exp output %b\",\n                    (push_ptr - i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE,\n                    reset_queue[(push_ptr - i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE],\n                    input_queue[(push_ptr - i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE],\n                    got_output_queue[(push_ptr - i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE],\n                    golden_queue[(push_ptr - i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE]);\n            end\n        end\n        if (!tb_match) begin\n            error_count++;\n            if (stats1.errors == 0) stats1.errortime = $time;\n        end\n        if (done_ref !== ( done_ref ^ done_dut ^ done_ref )) begin\n            error_count_done++;\n            if (stats1.errors_done == 0) stats1.errortime_done = $time;\n        end\n    end\n\n    // Timeout after 100K cycles\n    initial begin\n        #1000000 $display(\"TIMEOUT\"); $finish();\n    end\n\n    // Simulation end\n    initial begin\n        #10000000; // Adjust as needed for normal finish\n        $finish();\n    end\n\n    final begin\n        if (error_count_done == 0) begin\n            $display(\"SIMULATION PASSED\");\n        end else begin\n            $display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\", error_count_done, stats1.errortime_done);\n        end\n    end\nendmodule"
}
