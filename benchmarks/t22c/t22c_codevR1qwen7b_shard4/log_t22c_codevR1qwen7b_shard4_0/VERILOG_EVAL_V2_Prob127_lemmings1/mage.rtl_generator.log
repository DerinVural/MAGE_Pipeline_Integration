mp_left, bump_right, walk_left_dut, walk_right_dut, walk_left_ref, walk_right_ref.\n    // Or track each relevant variable. Let\'s track the current state, inputs, outputs.\n\n    // To implement the queue as per the example.\n    // Assume state is a single bit since two states (left and right walk), but in the display example, it\'s not the state. Since the module\'s state is internal, we track inputs and outputs.\n    // Let\'s track: areset, bump_left, bump_right, walk_left_dut, walk_right_dut, walk_left_ref, walk_right_ref over 5 cycles.\n    reg [4:0] input_sequence [0:4]; // Each entry contains areset, bump_left, bump_right, time\n    reg [1:0] got_sequence [0:4];\n    reg [1:0] golden_sequence [0:4];\n    integer queue_ptr = 0;\n\n    always @(posedge clk, negedge clk) begin\n        if (queue_ptr >= MAX_QUEUE_SIZE) queue_ptr <= 0;\n        input_sequence[queue_ptr] = {areset, bump_left, bump_right};\n        got_sequence[queue_ptr] = {walk_left_dut, walk_right_dut};\n        golden_sequence[queue_ptr] = {walk_left_ref, walk_right_ref};\n        queue_ptr <= queue_ptr + 1;\n    end\n\n    // Detect first mismatch\n    always @(posedge clk, negedge clk) begin\n        if (!error_flag && !tb_match) begin\n            error_count <= error_count + 1;\n            if (error_count == 0) first_error_time <= $time;\n            error_flag <= 1;\n            // Display mismatch\n            $display("Mismatch detected at time %t", $time);\n            // Display queue\n            $display("Last %0d cycles of simulation:", MAX_QUEUE_SIZE);\n            for (int i=0; i < MAX_QUEUE_SIZE; i++) begin\n                if (i >= queue_ptr) begin\n                    // Handle wrap-around\n                    $display("Cycle %0d: areset=%b, bump_left=%b, bump_right=%b, got=%b%b, golden=%b%b",\n                        (queue_ptr + i) % MAX_QUEUE_SIZE,\n                        input_sequence[(queue_ptr + i) % MAX_QUEUE_SIZE][4],\n                        input_sequence[(queue_ptr + i) % MAX_QUEUE_SIZE][3],\n                        input_sequence[(queue_ptr + i) % MAX_QUEUE_SIZE][2],\n                        got_sequence[(queue_ptr + i) % MAX_QUEUE_SIZE][1],\n                        got_sequence[(queue_ptr + i) % MAX_QUEUE_SIZE][0],\n                        golden_sequence[(queue_ptr + i) % MAX_QUEUE_SIZE][1],\n                        golden_sequence[(queue_ptr + i) % MAX_QUEUE_SIZE][0]);\n                end else begin\n                    $display("Cycle %0d: areset=%b, bump_left=%b, bump_right=%b, got=%b%b, golden=%b%b",\n                        i,\n                        input_sequence[i][4],\n                        input_sequence[i][3],\n                        input_sequence[i][2],\n                        got_sequence[i][1],\n                        got_sequence[i][0],\n                        golden_sequence[i][1],\n                        golden_sequence[i][0]);\n                end\n            end\n        end\n    end\n\n    // Simulation control\n    initial begin\n        areset = 1;\n        bump_left = 0;\n        bump_right = 0;\n        error_count = 0;\n        error_flag = 0;\n        // Reset test sequence\n        // Add test cases here: areset pulses, bump inputs.\n        #10;\n        // After reset, apply stimuli\n        areset = 0;\n        #20;\n        bump_left = 1;\n        bump_right = 0;\n        #10;\n        bump_left = 0;\n        bump_right = 1;\n        // Continue for more cycles\n        #100;\n        // Check for mismatches\n        if (error_count > 0) begin\n            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", error_count, first_error_time);\n        end else begin\n            $display("SIMULATION PASSED");\n        end\n        $finish;\n    end\nendmodule\n\n// Reference module (assumed to be correct behavior)\nmodule RefModule (\n    input clk,\n    input areset,\n    input bump_left,\n    input bump_right,\n    output reg walk_left,\n    output reg walk_right\n);\n    always @(posedge clk) begin\n        if (areset) begin\n            walk_left <= 1;\n            walk_right <= 0;\n        end else begin\n            if (bump_left) begin\n                walk_left <= 0;\n                walk_right <= 1;\n            end else if (bump_right) begin\n                walk_left <= 1;\n                walk_right <= 0;\n            end else begin\n                walk_left <= walk_left;\n                walk_right <= walk_right;\n            end\n        end\n    end\nendmodule\n</testbench>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nThe module interface is given below:\n<module_interface>\nmodule TopModule (input clk, input areset, input bump_left, input bump_right, output walk_left, output walk_right);\n</module_interface>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nYour response will be processed by a program, not human.\nSo, please STRICTLY FOLLOW the output format given as XML tag content below to generate a VALID JSON OBJECT:\n<output_format>\n{\n    "reasoning": "All reasoning steps and advices to avoid syntax error",\n    "module": "Pure SystemVerilog code, a complete module"\n}\n</output_format>\nDO NOT include any other information in your response, like \'json\', \'reasoning\' or \'<output_format>\'.\n\nOther requirements:\n1. Don\'t use state_t to define the parameter. Use `localparam` or Use \'reg\' or \'logic\' for signals as registers or Flip-Flops.\n2. Declare all ports and signals as logic.\n3. Not all the sequential logic need to be reset to 0 when reset is asserted,\n    but these without-reset logic should be initialized to a known value with an initial block instead of being X.\n4. For combinational logic with an always block do not explicitly specify the sensitivity list; instead use always @(*).\n5. NEVER USE \'inside\' operator in RTL code. Code like \