[2026-05-14 13:53:32,627 - mage.rtl_editor - INFO] module TopModule(input clk, input reset, input [7:0] data_in, output logic [7:0] data_out);
    localparam STATE_IDLE = 0, STATE_BUSY = 1;
    logic [1:0] state;

    // Initialize states
    initial begin
        state = STATE_IDLE;
    end

    // Combinational logic for data_out
    always @(*) begin
        data_out = data_in + 1;
    end

    // Sequential logic
    always @(posedge clk) begin
        if (reset) begin
            state <= STATE_IDLE;
        end else begin
            case (state)
                STATE_IDLE: state <= STATE_BUSY;
                STATE_BUSY: state <= STATE_IDLE;
            endcase
        end
    end
endmodule
