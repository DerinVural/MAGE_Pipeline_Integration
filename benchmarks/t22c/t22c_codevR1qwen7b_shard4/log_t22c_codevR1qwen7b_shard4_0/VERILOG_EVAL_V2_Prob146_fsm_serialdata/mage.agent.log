[2026-05-14 13:46:55,083 - mage.agent - INFO] module TopModule (input logic clk, input logic in, input logic reset, output logic [7:0] out_byte, output logic done);

localparam IDLE = 0,
           START = 1,
           DATA0 = 2,
           DATA1 = 3,
           DATA2 = 4,
           DATA3 = 5,
           DATA4 = 6,
           DATA5 = 7,
           DATA6 = 8,
           DATA7 = 9,
           STOP = 10;

reg [3:0] state;
logic [2:0] bit_count;
logic [7:0] data_reg;
reg start_bit_detected;

// Initialize signals
initial begin
  state = IDLE;
  done = 0;
  out_byte = 8'h00;
  bit_count = 0;
  data_reg = 8'h00;
end

// FSM transitions
always @(posedge clk) begin
  if (reset) begin
    state <= IDLE;
    bit_count <= 0;
    data_reg <= 0;
    done <= 0;
  end else begin
    case (state)
      IDLE: begin
        if (!in) begin // Start bit detected
          state <= START;
          start_bit_detected <= 1;
        end
      end
      START: begin
        if (bit_count == 0) begin
          state <= DATA0;
          bit_count <= bit_count + 1;
        end else begin
          bit_count <= 0;
        end
      end
      DATA0: begin
        data_reg[0] <= in;
        state <= DATA1;
      end
      DATA1: begin
        data_reg[1] <= in;
        state <= DATA2;
      end
      DATA2: begin
        data_reg[2] <= in;
        state <= DATA3;
      end
      DATA3: begin
        data_reg[3] <= in;
        state <= DATA4;
      end
      DATA4: begin
        data_reg[4] <= in;
        state <= DATA5;
      end
      DATA5: begin
        data_reg[5] <= in;
        state <= DATA6;
      end
      DATA6: begin
        data_reg[6] <= in;
        state <= DATA7;
      end
      DATA7: begin
        data_reg[7] <= in;
        state <= STOP;
      end
      STOP: begin
        if (in) begin // Valid stop bit
          out_byte <= data_reg;
          done <= 1;
        end else begin
          done <= 0;
        end
        state <= IDLE;
      end
      default: state <= IDLE;
    endcase
  end
end

// No combinational logic needed for done as it's handled in FSM

endmodule
