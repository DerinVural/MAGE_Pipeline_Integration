		if (state == STATE_STOP && in) begin
			out_byte <= data_reg;
			done <= 1'b1;
		end else begin
			done <= 1'b0;
		end
	end

	// Initial state
	initial begin
		state = STATE_IDLE;
		bit_count = 0;
		data_reg = 8'h00;
		done = 0;
		out_byte = 8'h00;
