[2026-05-14 13:50:53,404 - mage.rtl_generator - INFO] RTL code: module TopModule (input clk, input in, input reset, output logic [7:0] out_byte, output logic done);

localparam STATE_IDLE = 0;
localparam STATE_START = 1;
localparam STATE_DATA = 2;
localparam STATE_STOP = 3;
localparam STATE_WAIT_STOP =4;

logic [2:0] state;
logic [2:0] next_state;
logic [7:0] shift_reg;
logic [3:0] bit_count;
logic stop_bit_valid;

// Initialize states and registers
initial begin
    state = STATE_IDLE;
    shift_reg = 8'h00;
    bit_count = 0;
    done = 0;
    out_byte = 8'h00;
end

// State transition
always @(posedge clk) begin
    if (reset) begin
        state <= STATE_IDLE;
        shift_reg <= 8'h0;
        bit_count <= 0;
        done <= 0;
    end else begin
        state <= next_state;
        // Update shift register and bit_count based on state
        case (state)
            STATE_IDLE: begin
                if (!in) begin // start bit detected
                    next_state = STATE_START;
                end else begin
                    next_state = STATE_IDLE;
                end
            end
            STATE_START: begin
                next_state = STATE_DATA;
            end
            STATE_DATA: begin
                if (bit_count < 8) begin
                    shift_reg <= {in, shift_reg[7:1]}; // LSB first
                    bit_count <= bit_count + 1;
                    next_state = STATE_DATA;
                end else begin
                    next_state = STATE_STOP;
                end
            end
            STATE_STOP: begin
                // Check if stop bit is 1
                if (in) begin
                    stop_bit_valid = 1;
                    out_byte <= shift_reg;
                    done <= 1;
                    next_state = STATE_IDLE;
                end else begin
                    // Invalid stop bit, wait in STATE_WAIT_STOP
                    next_state = STATE_WAIT_STOP;
                end
            end
            STATE_WAIT_STOP: begin
                if (in) begin // wait until stop bit is 1
                    done <=1;
                    out_byte <= shift_reg;
                    next_state = STATE_IDLE;
                end else begin
                    next_state = STATE_WAIT_STOP;
                end
            end
            default: next_state = STATE_IDLE;
        endcase
    end
end

// Combinational logic for next_state and outputs
always @(*) begin
    case (state)
        STATE_IDLE: next_state = (!in) ? STATE_START : STATE_IDLE;
        STATE_DATA: next_state = (bit_count < 8) ? STATE_DATA : STATE_STOP;
        STATE_STOP: next_state = (in) ? STATE_IDLE : STATE_WAIT_STOP;
        STATE_WAIT_STOP: next_state = (in) ? STATE_IDLE : STATE_WAIT_STOP;
        default: next_state = STATE_IDLE;
    endcase
end

// Reset done after one clock cycle
clock @(posedge clk) begin
    if (state == STATE_STOP && in) done <= 1;
    else if (state == STATE_WAIT_STOP && in) done <=1;
    else done <=0;
end

endmodule
