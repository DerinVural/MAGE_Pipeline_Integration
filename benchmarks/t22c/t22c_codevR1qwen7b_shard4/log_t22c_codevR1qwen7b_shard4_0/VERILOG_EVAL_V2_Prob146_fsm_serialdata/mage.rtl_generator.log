	// States
	localparam IDLE = 0;
	localparam START = 1;
	localparam DATA = 2;
	localparam STOP = 3;

	// State and data registers
	logic [1:0] state = IDLE;
	logic [3:0] bit_count = 0;
	logic [7:0] data_reg = 0;
	logic [7:0] out_byte_next = 0;
	logic done_next = 0;

	// Combinational logic for state transitions and outputs
	auto (state, bit_count, data_reg, out_byte_next, done_next) {
		state_next = state;
		bit_count_next = bit_count;
		data_reg_next = data_reg;
		done_next = 0;
		out_byte_next = out_byte;

		case (state)
			IDLE: begin
				if (in == 0) {
					state_next = START;
					bit_count_next = 0;
				}
			end
			START: begin
				if (in == 1) {
					state_next = DATA;
				}
			end
			DATA: begin
				data_reg_next = {in, data_reg[7:1]};
				bit_count_next = bit_count + 1;
				if (bit_count == 7) {
					state_next = STOP;
				}
			end
			STOP: begin
				if (in == 1) {
					state_next = IDLE;
					out_byte_next = data_reg;
					done_next = 1;
				} else {
					state_next = DATA;
					bit_count_next = 0;
				}
			end
		endcase
	}

	// Sequential logic with reset
	always @(posedge clk) begin
		if (reset) {
			state <= IDLE;
			bit_count <= 0;
			data_reg <= 0;
			done <= 0;
			out_byte <= 0;
		} else {
			state <= state_next;
			bit_count <= bit_count_next;
			data_reg <= data_reg_next;
			done <= done_next;
			out_byte <= out_byte_next;
		}
	end

