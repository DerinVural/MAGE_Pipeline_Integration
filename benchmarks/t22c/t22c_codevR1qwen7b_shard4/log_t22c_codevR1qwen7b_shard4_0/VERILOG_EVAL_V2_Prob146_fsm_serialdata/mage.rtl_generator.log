			bit_count <= 0;
		end else begin
			if (state == STATE_DATA && next_state == STATE_DATA) begin
				bit_count <= bit_count + 1;
			end else if (state == STATE_DATA && next_state == STATE_STOP) begin
				bit_count <= 0;
			end else if (state == STATE_STOP) begin
				bit_count <= 0;
			end else begin
				bit_count <= 0;
			end
		end
	end

	// Data shift logic
	always @(posedge clk) begin
		if (state == STATE_DATA) begin
			data_reg <= {data_reg[6:0], in};
		end else if (reset) begin
			data_reg <= 8'h00;
		end
	end

