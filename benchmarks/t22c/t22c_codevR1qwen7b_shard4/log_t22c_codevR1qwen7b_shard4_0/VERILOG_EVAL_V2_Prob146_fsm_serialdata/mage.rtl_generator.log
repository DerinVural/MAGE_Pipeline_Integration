    // State definitions
    localparam STATE_IDLE = 3'd0;
    localparam STATE_START = 3'd1;
    localparam STATE_DATA = 3'd2;
    localparam STATE_STOP = 3'd3;
    localparam STATE_WAIT_STOP = 3'd4;

    // Registers
    logic [2:0] state;
    logic [2:0] bit_counter;
    logic [7:0] data_reg;
    logic [7:0] next_data;
    logic [2:0] next_bit_counter;
    logic next_done;
    logic [7:0] next_out_byte;
    logic [2:0] next_state;

    // Initialize state variables
    initial begin
        state = STATE_IDLE;
        bit_counter = 0;
        data_reg = 0;
        done = 0;
        out_byte = 0;
    end

    // Combinational logic for next state
    always @(*) begin
        next_state = state;
        next_bit_counter = bit_counter;
        next_data = data_reg;
        next_done = 0;
        next_out_byte = out_byte;

        case (state)
            STATE_IDLE: begin
                if (!in) begin
                    next_state = STATE_START;
                end
            end
            STATE_START: begin
                next_state = STATE_DATA;
                next_bit_counter = 0;
            end
            STATE_DATA: begin
                next_data[bit_counter] = in;
                next_bit_counter = bit_counter + 1;
                if (bit_counter == 7) begin
                    next_state = STATE_STOP;
                end
            end
            STATE_STOP: begin
                if (in) begin
                    next_out_byte = next_data;
                    next_done = 1;
                    next_state = STATE_IDLE;
                end else begin
                    next_state = STATE_WAIT_STOP;
                end
            end
            STATE_WAIT_STOP: begin
                if (in) begin
                    next_state = STATE_IDLE;
                end
            end
            default: next_state = STATE_IDLE;
        endcase
    end

    // Sequential logic
    always @(posedge clk) begin
        if (reset) begin
            state <= STATE_IDLE;
            bit_counter <= 0;
            data_reg <= 0;
            done <= 0;
            out_byte <= 0;
        end else begin
            state <= next_state;
            bit_counter <= next_bit_counter;
            data_reg <= next_data;
            done <= next_done;
            out_byte <= next_out_byte;
        end
    end

endmodule
