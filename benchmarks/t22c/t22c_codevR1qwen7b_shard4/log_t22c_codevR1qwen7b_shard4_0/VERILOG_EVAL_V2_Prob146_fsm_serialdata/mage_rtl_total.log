    // States
    localparam IDLE  = 3'b000;
    localparam START = 3'b001;
    localparam DATA  = 3'b010;
    localparam STOP  = 3'b011;
    localparam WAIT  = 3'b100;

    reg [2:0] state, next_state;
    reg [3:0] bit_count;
    reg [7:0] data_reg;
    reg done_reg;
    reg [7:0] out_byte_reg;

    // State registers
    initial begin
        state = IDLE;
        bit_count = 0;
        data_reg = 8'h00;
        done_reg = 0;
        out_byte_reg = 8'h00;
    end

    // State transition
    always @(posedge clk) begin
        if (reset) begin
            state <= IDLE;
            bit_count <= 0;
            data_reg <= 0;
            done_reg <= 0;
            out_byte_reg <= 0;
        end else begin
            state <= next_state;
            if (state == DATA && next_state == DATA) begin
                data_reg <= {in, data_reg[7:1]}; // LSB first
                bit_count <= bit_count + 1;
            end else if (state == STOP) begin
                if (in) begin
                    done_reg <= 1;
                    out_byte_reg <= data_reg;
                end else begin
                    done_reg <= 0;
                    // Enter WAIT state until stop bit is valid
                end
                bit_count <= 0;
            end else if (state == WAIT && in) begin
                done_reg <= 1;
                out_byte_reg <= data_reg;
                bit_count <= 0;
            end else begin
                done_reg <= 0;
            end
        end
    end

    // Next state logic
    always @(*) begin
        next_state = state;
        case (state)
            IDLE: begin
                if (!in) next_state = START; // Start bit detected
            end
            START: begin
                next_state = DATA;
            end
            DATA: begin
                if (bit_count == 8) next_state = STOP;
            end
            STOP: begin
                if (in) begin
                    next_state = IDLE; // Valid stop bit
                end else begin
                    next_state = WAIT; // Wait for valid stop
                end
            end
            WAIT: begin
                if (in) next_state = IDLE;
            end
            default: next_state = IDLE;
        endcase
    end

    // Output assignments
    assign done = done_reg;
    assign out_byte = out_byte_reg;

endmodule
