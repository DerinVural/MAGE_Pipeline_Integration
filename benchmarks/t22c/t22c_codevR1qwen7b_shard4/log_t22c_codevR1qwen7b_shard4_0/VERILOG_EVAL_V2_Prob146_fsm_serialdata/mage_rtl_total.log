    // State definitions
    localparam STATE_IDLE = 0;
    localparam STATE_START = 1;
    localparam STATE_DATA = 2;
    localparam STATE_STOP = 3;
    localparam STATE_WAIT_STOP = 4;

    logic [2:0] state = STATE_IDLE;
    logic [2:0] next_state;
    logic [2:0] bit_counter = 0;
    logic [7:0] data_reg = 0;
    logic done_next = 0;
    logic [7:0] out_byte_reg = 0;

    // Combinational logic for done removed
    assign done = done_next;

    // Sequential logic
    always @(posedge clk) begin
        state <= next_state;
        if (state == STATE_DATA) begin
            if (bit_counter < 7) begin
                data_reg <= {in, data_reg[7:1]}; // LSB first, shift right
                bit_counter <= bit_counter + 1;
            end else begin
                data_reg <= {in, data_reg[7:1]};
                out_byte_reg <= {in, data_reg[7:1]};
                bit_counter <= 0;
            end
        end else if (state == STATE_STOP) begin
            done_next <= (in == 1);
            if (in == 1) begin
                done_next <= 1;
                next_state <= STATE_IDLE;
            end else begin
                next_state <= STATE_WAIT_STOP;
            end
        end else if (state == STATE_WAIT_STOP) begin
            if (in == 1) begin
                done_next <= 1;
                next_state <= STATE_IDLE;
            end else begin
                next_state <= STATE_WAIT_STOP;
            end
        end
        // Handle reset
        if (reset) begin
            state <= STATE_IDLE;
            done_next <= 0;
            bit_counter <= 0;
            data_reg <= 0;
            out_byte_reg <= 0;
        end
    end

    // FSM transitions
    always @(*) begin
        next_state = state;
        case (state)
            STATE_IDLE: begin
                if (in == 0) begin
                    next_state = STATE_START;
                end
            end
            STATE_START: begin
                next_state = STATE_DATA;
            end
            STATE_DATA: begin
                if (bit_counter == 7) begin
                    next_state = STATE_STOP;
                end
            end
            STATE_STOP: begin
                if (in == 1) begin
                    done_next = 1;
                    next_state = STATE_IDLE;
                end else begin
                    done_next = 0;
                    next_state = STATE_WAIT_STOP;
                end
            end
            STATE_WAIT_STOP: begin
                if (in == 1) begin
                    done_next = 1;
                    next_state = STATE_IDLE;
                end else begin
                    next_state = STATE_WAIT_STOP;
                end
            end
            default: next_state = STATE_IDLE;
        endcase
    end

    assign out_byte = out_byte_reg;

endmodule
