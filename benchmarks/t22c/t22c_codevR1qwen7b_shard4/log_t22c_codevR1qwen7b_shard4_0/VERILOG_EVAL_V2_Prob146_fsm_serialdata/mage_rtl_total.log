[2026-05-14 13:49:02,090 - mage.rtl_generator - INFO] RTL code: module TopModule (input clk, input in, input reset, output logic [7:0] out_byte, output logic done);

	// States
	localparam IDLE = 0;
	localparam START = 1;
	localparam DATA = 2;
	localparam STOP = 3;

	// State register
	logic [1:0] state = IDLE;

	// Data bits counter
	logic [3:0] bit_count = 0;

	// Data shift register
	logic [7:0] data_reg = 0;

	// Stop bit flag
	logic stop_received;

	// Next state and outputs logic
	ever @(*) begin
		// Default assignments
		state_next = state;
		bit_count_next = bit_count;
		data_reg_next = data_reg;
		stop_received = 0;
		done_next = 0;
		out_byte_next = out_byte;

		case (state)
			IDLE: begin
				if (in == 0) begin
					state_next = START;
					bit_count_next = 0;
				end
			end
			START: begin
				if (in == 1) begin
					state_next = DATA;
				end
			end
			DATA: begin
				data_reg_next = {in, data_reg[7:1]}; // LSB first
				bit_count_next = bit_count + 1;
				if (bit_count == 7) begin
					state_next = STOP;
				end
			end
			STOP: begin
				if (in == 1) begin
					state_next = IDLE;
					done_next = 1;
					out_byte_next = data_reg;
				end else begin
					state_next = DATA; // Wait for correct stop bit
					bit_count_next = 0;
				end
			end
		endcase
	end

	ever @(posedge clk) begin
		if (reset) begin
			state <= IDLE;
			bit_count <= 0;
			data_reg <= 0;
			done <= 0;
			out_byte <= 0;
		end else begin
			state <= state_next;
			bit_count <= bit_count_next;
			data_reg <= data_reg_next;
			done <= done_next;
			out_byte <= out_byte_next;
		end
	end

