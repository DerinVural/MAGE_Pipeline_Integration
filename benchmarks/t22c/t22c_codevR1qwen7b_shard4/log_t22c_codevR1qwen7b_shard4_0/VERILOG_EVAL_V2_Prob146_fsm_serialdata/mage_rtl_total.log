                next_bit_counter = bit_counter + 1;
                if (bit_counter == 7) begin
                    next_state = STATE_STOP;
                end
            end
            STATE_STOP: begin
                if (in) begin
                    next_out_byte = next_data;
                    next_done = 1;
                    next_state = STATE_IDLE;
                end else begin
                    next_state = STATE_WAIT_STOP;
                end
            end
            STATE_WAIT_STOP: begin
                if (in) begin
                    next_state = STATE_IDLE;
                end
            end
            default: next_state = STATE_IDLE;
        endcase
    end

    // Sequential logic
    always @(posedge clk) begin
        if (reset) begin
            state <= STATE_IDLE;
            bit_counter <= 0;
            data_reg <= 0;
            done <= 0;
            out_byte <= 0;
        end else begin
            state <= next_state;
            bit_counter <= next_bit_counter;
            data_reg <= next_data;
            done <= next_done;
            out_byte <= next_out_byte;
        end
    end

