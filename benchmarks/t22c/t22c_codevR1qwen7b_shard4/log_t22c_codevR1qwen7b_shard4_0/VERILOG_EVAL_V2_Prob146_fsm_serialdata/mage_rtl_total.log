	// State definitions
	localparam STATE_IDLE = 3'd0;
	localparam STATE_START = 3'd1;
	localparam STATE_DATA = 3'd2;
	localparam STATE_STOP = 3'd3;

	reg [2:0] state, next_state;
	reg [3:0] bit_count;
	reg [7:0] data_reg;

	// FSM state register
	always @(posedge clk) begin
		if (reset) state <= STATE_IDLE;
		else state <= next_state;
	end

	// Bit counter and data shift register
	always @(posedge clk) begin
		if (reset) begin
			bit_count <= 0;
		end else begin
			if (state == STATE_DATA && next_state == STATE_DATA) begin
				bit_count <= bit_count + 1;
			end else if (state == STATE_DATA && next_state == STATE_STOP) begin
				bit_count <= 0;
			end else if (state == STATE_STOP) begin
				bit_count <= 0;
			end else begin
				bit_count <= 0;
			end
		end
	end

	// Data shift logic
	always @(posedge clk) begin
		if (state == STATE_DATA) begin
			data_reg <= {data_reg[6:0], in};
		end else if (reset) begin
			data_reg <= 8'h00;
		end
	end

	// Next state logic
	always @(*) begin
		next_state = state;
		case (state)
			STATE_IDLE: begin
				if (!in) next_state = STATE_START; // Start bit detected
			end
			STATE_START: begin
				next_state = STATE_DATA;
			end
			STATE_DATA: begin
				if (bit_count == 4'd7) next_state = STATE_STOP;
			end
			STATE_STOP: begin
				if (in == 1'b1) next_state = STATE_IDLE;
			end
		endcase
	end

	// Output assignments
	always @(posedge clk) begin
		if (state == STATE_STOP && in) begin
			out_byte <= data_reg;
			done <= 1'b1;
		end else begin
			done <= 1'b0;
		end
	end

	// Initial state
	initial begin
		state = STATE_IDLE;
		bit_count = 0;
		data_reg = 8'h00;
		done = 0;
		out_byte = 8'h00;
		if (!reset) begin
			state = STATE_IDLE;
		end
	end

endmodule
