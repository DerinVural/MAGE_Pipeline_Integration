    // State definitions
    localparam IDLE = 0;
    localparam START = 1;
    localparam DATA = 2;
    localparam STOP = 3;
    localparam WAIT_STOP = 4;

    logic [2:0] state = IDLE;
    logic [3:0] bit_count;
    logic [7:0] data_reg;
    logic stop_bit_valid;

    // FSM transitions
    always @(posedge clk) begin
        if (reset) begin
            state <= IDLE;
        end else begin
            case (state)
                IDLE: begin
                    if (!in) // Start bit detected (0)
                        state <= START;
                end
                START: begin
                    state <= DATA;
                    bit_count <= 0;
                end
                DATA: begin
                    if (bit_count < 7) begin
                        data_reg[bit_count] <= in;
                        bit_count <= bit_count + 1;
                    end else begin
                        data_reg[bit_count] <= in;
                        state <= STOP;
                    end
                end
                STOP: begin
                    stop_bit_valid <= in;
                    if (in) begin // Valid stop bit
                        out_byte <= data_reg;
                        done <= 1;
                        state <= IDLE;
                    end else begin
                        done <= 0;
                        state <= WAIT_STOP;
                    end
                end
                WAIT_STOP: begin
                    if (in) begin // Wait until stop bit found
                        state <= IDLE;
                    end else begin
                        state <= WAIT_STOP;
                    end
                end
                default: state <= IDLE;
            endcase
        end
    end

    // Reset done signal after one clock cycle
    always @(posedge clk) begin
        if (!reset) done <= 0;
    end

endmodule
