        case (state)
            STATE_IDLE: begin
                if (!in) begin // start bit detected
                    next_state = STATE_START;
                end else begin
                    next_state = STATE_IDLE;
                end
            end
            STATE_START: begin
                next_state = STATE_DATA;
            end
            STATE_DATA: begin
                if (bit_count < 8) begin
                    shift_reg <= {in, shift_reg[7:1]}; // LSB first
                    bit_count <= bit_count + 1;
                    next_state = STATE_DATA;
                end else begin
                    next_state = STATE_STOP;
                end
            end
            STATE_STOP: begin
                // Check if stop bit is 1
                if (in) begin
                    stop_bit_valid = 1;
                    out_byte <= shift_reg;
                    done <= 1;
                    next_state = STATE_IDLE;
                end else begin
                    // Invalid stop bit, wait in STATE_WAIT_STOP
                    next_state = STATE_WAIT_STOP;
                end
            end
            STATE_WAIT_STOP: begin
                if (in) begin // wait until stop bit is 1
                    done <=1;
                    out_byte <= shift_reg;
                    next_state = STATE_IDLE;
                end else begin
                    next_state = STATE_WAIT_STOP;
                end
            end
            default: next_state = STATE_IDLE;
        endcase
    end
end

// Combinational logic for next_state and outputs
always @(*) begin
    case (state)
        STATE_IDLE: next_state = (!in) ? STATE_START : STATE_IDLE;
        STATE_DATA: next_state = (bit_count < 8) ? STATE_DATA : STATE_STOP;
        STATE_STOP: next_state = (in) ? STATE_IDLE : STATE_WAIT_STOP;
        STATE_WAIT_STOP: next_state = (in) ? STATE_IDLE : STATE_WAIT_STOP;
        default: next_state = STATE_IDLE;
    endcase
end

// Reset done after one clock cycle
clock @(posedge clk) begin
    if (state == STATE_STOP && in) done <= 1;
    else if (state == STATE_WAIT_STOP && in) done <=1;
    else done <=0;
end

endmodule
