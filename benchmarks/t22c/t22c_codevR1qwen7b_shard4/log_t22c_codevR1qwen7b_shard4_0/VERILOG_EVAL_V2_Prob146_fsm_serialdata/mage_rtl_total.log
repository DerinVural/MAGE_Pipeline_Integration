  localparam STATE_IDLE = 3'd0; 
  localparam STATE_START = 3'd1; 
  localparam STATE_DATA = 3'd2; 
  localparam STATE_STOP = 3'd3; 
  
  logic [2:0] state; 
  logic [2:0] next_state; 
  logic [3:0] bit_count; 
  logic [7:0] data_reg; 
  logic done_reg; 
  logic [7:0] out_byte_reg; 
  
  // State register with initial 
  initial begin 
    state = STATE_IDLE; 
  end 
  always_ff @(posedge clk) begin 
    if (reset) 
      state <= STATE_IDLE; 
    else 
      state <= next_state; 
  end 
  
  // Next state logic 
  always_comb begin 
    next_state = state; 
    case (state) 
      STATE_IDLE: begin 
        if (!in) 
          next_state = STATE_START; 
      end 
      STATE_START: begin 
        if (in == 1'b1) 
          next_state = STATE_IDLE; // Invalid start bit, back to idle 
        else 
          next_state = STATE_DATA; 
      end 
      STATE_DATA: begin 
        if (bit_count == 4'd8) 
          next_state = STATE_STOP; 
        else 
          next_state = STATE_DATA; 
      end 
      STATE_STOP: begin 
        if (in) 
          next_state = STATE_IDLE; 
        else 
          next_state = STATE_START; // Invalid stop, wait for start 
      end 
      default: next_state = STATE_IDLE; 
    endcase 
  end 
  
  // Bit counter and data shift 
  always @(posedge clk) begin 
    if (state == STATE_IDLE) begin 
      bit_count <= 4'd0; 
    end else if (state == STATE_DATA) begin 
      if (bit_count < 4'd8) 
        bit_count <= bit_count + 1; 
    end 
  end 
  
  // Data register shifting 
  always @(posedge clk) begin 
    if (state == STATE_DATA) begin 
      if (bit_count < 4'd8) 
        data_reg <= {in, data_reg[7:1]}; 
    end else begin 
      data_reg <= 'h0; 
    end 
  end 
  
  // Stop bit check 
  always @(posedge clk) begin 
    if (state == STATE_STOP) begin 
      done_reg <= in; // Done asserted if stop bit valid 
    end else begin 
      done_reg <= 1'b0; 
    end 
  end 
  
  // Output assignments 
  always @(posedge clk) begin 
    if (state == STATE_STOP && in) begin 
      out_byte_reg <= data_reg; 
    end 
  end 
  
  assign done = done_reg; 
  assign out_byte = out_byte_reg; 
endmodule
