        bit_counter = 0;
        data_reg = 0;
        done = 0;
        out_byte = 0;
    end

    // Combinational logic for next state
    always @(*) begin
        next_state = state;
        next_bit_counter = bit_counter;
        next_data = data_reg;
        next_done = 0;
        next_out_byte = out_byte;

        case (state)
            STATE_IDLE: begin
                if (!in) begin
                    next_state = STATE_START;
                end
            end
            STATE_START: begin
                next_state = STATE_DATA;
                next_bit_counter = 0;
