    "module": "module TopModule (input clk, input in, input reset, output logic [7:0] out_byte, output logic done);\n\n    localparam STATE_IDLE = 0;\n    localparam STATE_START = 1;\n    localparam STATE_DATA = 2;\n    localparam STATE_STOP = 3;\n\n    logic [1:0] state;\n    logic [3:0] bit_count;\n    logic [7:0] data_reg;\n\n    initial begin\n        state = STATE_IDLE;\n        bit_count = 0;\n        data_reg = 0;\n        done = 0;\n    end\n\n    always @(posedge clk) begin\n        if (reset) begin\n            state <= STATE_IDLE;\n            bit_count <= 0;\n            data_reg <= 0;\n            done <= 0;\n        end else begin\n            case (state)\n                STATE_IDLE: begin\n                    done <= 0;\n                    if (in == 0) begin // Start bit detected\n                        state <= STATE_START;\n                    end\n                end\n\n                STATE_START: begin\n                    if (in) begin // Start bit check failed\n                        state <= STATE_IDLE;\n                    end else begin\n                        state <= STATE_DATA;\n                        bit_count <= 0;\n                    end\n                end\n\n                STATE_DATA: begin\n                    if (bit_count < 8) begin\n                        data_reg <= {in, data_reg[7:1]}; // LSB first\n                        bit_count <= bit_count + 1;\n                    end else begin\n                        state <= STATE_STOP;\n                    end\n                end\n\n                STATE_STOP: begin\n                    if (in) begin // Valid stop bit\n                        out_byte <= data_reg;\n                        done <= 1;\n                        state <= STATE_IDLE;\n                    end else begin // Invalid stop bit: wait for it\n                        state <= STATE_IDLE; // Wait until line is high again\n                    end\n                end\n\n                default: state <= STATE_IDLE;\n            endcase\n        end\n    end\n\n    // Combinational done? Or registered? Since done is output reg and assigned in sequential, stays as 0 until stop bit.\n\nendmodule"
