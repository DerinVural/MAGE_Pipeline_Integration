        int clocks;
    } stats;
    stats stats1 = '{errors:0, errortime:0, ...}; // Default values
    // ... other signals and declarations

    reg clk = 0;
    initial forever #5 clk = ~clk;
    logic areset;
    logic bump_left;
    logic bump_right;
    logic ground;
    logic dig;
    logic walk_left_ref;
    logic walk_right_ref;
    logic aaah_ref;
    logic digging_ref;
    logic walk_left_dut;
    logic walk_right_dut;
    logic aaah_dut;
    logic digging_dut;
    wire tb_match;
    wire tb_mismatch = ~tb_match;

    // ... instantiate modules and stimuli as before

    always @(posedge clk, negedge clk) begin
        stats1.clocks++;
        if (!tb_match) begin
            stats1.errors++;
            if (stats1.errors == 1) stats1.errortime = $time;
            // Check individual outputs
            if (walk_left_ref !== (walk_left_ref ^ walk_left_dut ^ walk_left_ref)) begin
                stats1.errors_walk_left++;
                if (stats1.errors_walk_left == 1) stats1.errortime_walk_left = $time;
            end
            // Similarly for others
        end
    end
    // ... other code for display and error counting

    // Display on finish
    final begin
        // ... display passed/failed
    end
endmodule

