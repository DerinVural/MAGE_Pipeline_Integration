(posedge clk) begin\n        stats1.clocks++;\n        if (!tb_match) begin\n            stats1.errors++;\n            if (stats1.errors == 1) stats1.errortime = $time;\n        end\n        // Check per-output errors similarly\n    end\n\n    // Timeout and simulation end\n    initial begin\n        #1000000;\n        $display("    , "TIMEOUT);\n        $finish;\n    end\n\n    initial begin\n        // Wait for simulation end\n        #1;\n        if (stats1.errors) begin\n            $display("    :    ", "    , ", "    :    ", "    , ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    ", "    :    ", "    ,    