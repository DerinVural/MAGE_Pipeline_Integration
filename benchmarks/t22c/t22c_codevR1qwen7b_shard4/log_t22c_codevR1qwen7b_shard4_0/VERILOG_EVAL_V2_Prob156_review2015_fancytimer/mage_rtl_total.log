ter to capture the start sequence.\n    reg [3:0] shift_reg;\n    always @(posedge clk) begin\n        if (~reset) begin\n            shift_reg <= 4'b0;\n        end else begin\n            shift_reg <= {shift_reg[2:0], data};\n        end\n    end\n\n    // Detect 1101 in shift_reg (bit 3 is MSB)\n    wire start_detected;\n    assign start_detected = (shift_reg == 4'b1101);\n\n    // State machine transitions\n    always @(*) begin\n        next_state = state;\n        case (state)\n            STATE_IDLE: begin\n                if (start_detected) begin\n                    next_state = STATE_CAPTURE;\n                end\n            end\n            STATE_CAPTURE: begin\n                if (capture_done) begin // Assuming capture_done is when 4 bits captured\n                    next_state = STATE_COUNTING;\n                end\n            end\n            STATE_COUNTING: begin\n                if (cycle_count == (remaining_time * 1000) -1) begin\n                    next_state = STATE_DONE;\n                end\n            end\n            STATE_DONE: begin\n                if (ack) begin\n                    next_state = STATE_IDLE;\n                end\n            end\n        endcase\n    end\n\n    // Capture 4 bits for delay\n    reg [2:0] capture_count;\n    always @(posedge clk) begin\n        if (state == STATE_IDLE && start_detected) begin\n            capture_count <= 0;\n        end else if (state == STATE_CAPTURE) begin\n            if (capture_count <4) begin\n                captured_delay[capture_count] <= data;\n                capture_count <= capture_count +1;\n            end else begin\n                // All 4 bits captured\n            end\n        end\n    end\n\n    // Convert captured delay to number and compute delay+1 *1000 cycles\n    always @(posedge clk) begin\n        if (state == STATE_CAPTURE && capture_count ==3) begin // Fourth bit is captured\n            captured_delay <= {data, captured_delay[3:1]}; // Wait: MSB first. S