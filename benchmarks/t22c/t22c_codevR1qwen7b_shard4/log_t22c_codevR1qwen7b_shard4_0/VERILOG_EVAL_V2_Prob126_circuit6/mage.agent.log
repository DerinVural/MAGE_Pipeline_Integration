module tb();
    typedef struct {
        int errors;
        int errortime;
        int errors_q;
        int errortime_q;
        int clocks;
    } stats;
    stats stats1;
    logic [2:0] a;
    logic [15:0] q_ref;
    logic [15:0] q_dut;
    reg clk = 0;
    initial forever #5 clk = ~clk;
    // Instantiate DUT
    TopModule top_module1 (
        .a(a),
        .q(q_dut)
    );
    // Reference module (assumed to be named RefModule)
    RefModule ref_module1 (
        .a(a),
        .q(q_ref)
    );
    // Stimulus generation tasks and initial block as per golden
    // ...

    // Matching logic similar to golden
    assign tb_match = ( { q_ref } === ( { q_ref } ^ { q_dut } ^ { q_ref } ) );
    wire tb_mismatch = ~tb_match;

    // Queue display
    reg [2:0] input_queue [0:4];
    reg [15:0] got_queue [0:4];
    reg [15:0] exp_queue [0:4];
    localparam MAX_QUEUE_SIZE = 5;
    integer queue_ptr;
    always @(posedge clk, negedge clk) begin
        if (stats1.clocks >= MAX_QUEUE_SIZE -1) begin
            queue_ptr = (queue_ptr + 1) % MAX_QUEUE_SIZE;
        end else begin
            queue_ptr = queue_ptr +1;
        end
        input_queue[queue_ptr] = a;
        got_queue[queue_ptr] = q_dut;
        exp_queue[queue_ptr] = q_ref;
        if (!tb_match) begin
            if (stats1.errors ==0) stats1.errortime = $time;
            stats1.errors +=1;
        end
        if (q_ref !== q_ref ^ q_dut ^ q_ref) begin
            if (stats1.errors_q ==0) stats1.errortime_q = $time;
            stats1.errors_q +=1;
        end
    end
    // Final display
    final begin
        if (stats1.errors_q) begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_q, stats1.errortime_q);
            for (int i=0; i<MAX_QUEUE_SIZE; i++) begin
                $display("Time %0t: Input a=%h, Got q=%h, Expected q=%h",
                    (i >= queue_ptr) ? (i - MAX_QUEUE_SIZE + queue_ptr) *10 : (i + queue_ptr)*10,
                    input_queue[(i + queue_ptr)%MAX_QUEUE_SIZE],
                    got_queue[(i + queue_ptr)%MAX_QUEUE_SIZE],
                    exp_queue[(i + queue_ptr)%MAX_QUEUE_SIZE]
                );
            end
        end else begin
            $display("SIMULATION PASSED");
        end
    end
    // Timeout from golden testbench
    initial begin #1e6; $display("TIMEOUT"); $finish; end
endmodule
