    "module": "module TopModule (input logic clk, input logic load, input logic [511:0] data, output logic [511:0] q);\n\n  logic [511:0] next_q;\n  logic [511:0] q_reg;\n\n  // Initialize registers and next state\n  initial begin\n    q_reg = 0;\n    next_q = 0;\n  end\n\n  // Combinational logic for next state\n  always @(*) begin\n    for (int i = 0; i < 512; i++) begin\n      // Left neighbor is q_reg[i-1], which is 0 for i=0\n      // Right neighbor is q_reg[i+1], which is 0 for i=511\n      logic left = (i == 0) ? 1'b0 : q_reg[i-1];\n      logic center = q_reg[i];\n      logic right = (i == 511) ? 1'b0 : q_reg[i+1];\n\n      // Lookup table based on Rule 110's table\n      case ({left, center, right})\n        3'b111: next_q[i] = 0;\n        3'b110: next_q[i] = 1;\n        3'b101: next_q[i] = 1;\n        3'b100: next_q[i] = 0;\n        3'b011: next_q[i] = 1;\n        3'b010: next_q[i] = 1;\n        3'b001: next_q[i] = 1;\n        3'b000: next_q[i] = 0;\n        default: next_q[i] = 0;\n      endcase\n    end\n  end\n\n  // Sequential logic with load\n  always @(posedge clk) begin\n    if (load) begin\n      q_reg <= data;\n    end else begin\n      q_reg <= next_q;\n    end\n  end\n\n  assign q = q_reg;\n\nendmodule"
