    logic f_dut;
    logic g_ref;
    logic g_dut;

    initial begin
        $dumpfile("wave.vcd");
        $dumpvars(1, stim1.clk, tb_mismatch, clk, resetn, x, y, f_ref, f_dut, g_ref, g_dut);
    end

    wire tb_match, tb_mismatch = ~tb_match;

    stimulus_gen stim1 (
        .clk(clk),
        .resetn(resetn),
        .x(x),
        .y(y)
    );

    RefModule good1 (
        .clk(clk),
