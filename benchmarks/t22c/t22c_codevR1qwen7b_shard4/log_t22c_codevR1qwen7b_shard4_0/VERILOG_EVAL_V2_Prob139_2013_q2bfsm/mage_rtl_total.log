                    reset_queue[i],
                    input_queue[i][2],
                    input_queue[i][1],
                    input_queue[i][0],
                    got_output_queue[i],
                    golden_queue[i]
                );
            end
            $finish;
        end

        stats1.clocks++;
        if (!tb_match) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
        end
        if (f_ref !== (f_ref ^ f_dut ^ f_ref)) begin
            if (stats1.errors_f == 0) stats1.errortime_f = $time;
            stats1.errors_f++;
        end
