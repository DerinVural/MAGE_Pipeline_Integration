        $dumpvars(1, stim1.clk, tb_mismatch, clk, resetn, x, y, f_ref, f_dut, g_ref, g_dut);
    end

    wire tb_match, tb_mismatch = ~tb_match;

    stimulus_gen stim1 (
        .clk(clk),
        .resetn(resetn),
        .x(x),
        .y(y)
    );

    RefModule good1 (
        .clk(clk),
        .resetn(resetn),
        .x(x),
        .y(y),
        .f(f_ref),
        .g(g_ref)
    );

    TopModule top_module1 (
        .clk(clk),
        .resetn(resetn),
        .x(x),
        .y(y),
        .f(f_dut),
        .g(g_dut)
    );

    bit strobe = 0;
    task wait_for_end_of_timestep;
        repeat(5) begin
            strobe <= !strobe;
            @(strobe);
        end
    endtask

    reg [511:0] input_queue [0:8];
    reg [0:8] got_output_queue [0:8];
    reg [0:8] golden_queue [0:8];
    reg [0:8] reset_queue [0:8];

    localparam MAX_QUEUE_SIZE = 9;

    always @(posedge clk, negedge clk) begin
        if (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin
            input_queue.delete(0);
            got_output_queue.delete(0);
            golden_queue.delete(0);
            reset_queue.delete(0);
        end

        input_queue.push_back({resetn, x, y});
        got_output_queue.push_back({f_dut, g_dut});
        golden_queue.push_back({f_ref, g_ref});
        reset_queue.push_back(resetn);

        if ( {f_dut, g_dut} !== {f_ref, g_ref} ) begin
            $display("Mismatch detected at time %t", $time);
            $display("\nLast %d cycles of simulation:", input_queue.size());

            for (int i = 0; i < input_queue.size(); i++) begin
                if (got_output_queue[i] === golden_queue[i]) begin
                    $display("Got Match at");
                end else begin
                    $display("Got Mismatch at");
                end
                $display("Cycle %0d, reset %b, x %b, y %b, got output %h, expected %h",
                    i,
                    reset_queue[i],
                    input_queue[i][2],
                    input_queue[i][1],
                    input_queue[i][0],
                    got_output_queue[i],
                    golden_queue[i]
                );
            end
            $finish;
        end

        stats1.clocks++;
        if (!tb_match) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
        end
        if (f_ref !== (f_ref ^ f_dut ^ f_ref)) begin
            if (stats1.errors_f == 0) stats1.errortime_f = $time;
            stats1.errors_f++;
        end
        if (g_ref !== (g_ref ^ g_dut ^ g_ref)) begin
            if (stats1.errors_g == 0) stats1.errortime_g = $time;
            stats1.errors_g++;
        end

        if (stats1.errors > 0 && $time > 1000000) begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
            $finish;
        end
    end

    // Timeout after 100K cycles
    initial begin
        #1000000 $display("TIMEOUT"); $finish();
    end

    initial begin
        @(stats1.clocks == 1000);
        if (stats1.errors == 0) begin
            $display("SIMULATION PASSED");
        end else begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
        end
        $finish;
    end
endmodule
