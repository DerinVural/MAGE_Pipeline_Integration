	// FSM states
	localparam IDLE = 2'b00;
	localparam WAIT_1 = 2'b01;
	localparam WAIT_2 = 2'b10;
	localparam DONE_ST = 2'b11;

	// State and buffer variables
	logic [1:0] state;
	logic [7:0] bytes [0:2];
	logic [1:0] count;

	// State machine and buffer handling
	always @(posedge clk) begin
		if (reset) begin
			state <= IDLE;
			count <= 0;
			out_bytes <= 24'h0;
			done <= 0;
		end else begin
			case (state)
				IDLE: begin
					if (in[3]) begin
						bytes[0] <= in;
						state <= WAIT_1;
						count <= 1;
					end
				end
				WAIT_1: begin
					if (in[3]) begin
						bytes[1] <= in;
						state <= WAIT_2;
						count <= 2;
					end else begin
						bytes[0] <= in;
						count <= 1;
					end
				end
				WAIT_2: begin
					if (in[3]) begin
						bytes[2] <= in;
						done <= 1;
						out_bytes <= {bytes[0], bytes[1], in};
						state <= DONE_ST;
					end else begin
						bytes[1] <= in;
						count <= 2;
					end
				end
				DONE_ST: begin
					done <= 0;
					state <= IDLE;
				end
				default: state <= IDLE;
			endcase
		end
	end

	// Combinational logic for done and outputs? No, done is registered here.

endmodule
