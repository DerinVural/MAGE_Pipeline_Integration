    // State definitions
    localparam [1:0] IDLE = 2'b00;
    localparam [1:0] COLLECT2 = 2'b01;
    localparam [1:0] COLLECT3 = 2'b10;
    localparam [1:0] DONE_STATE = 2'b11;

    logic [1:0] state, next_state;
    logic [7:0] byte1, byte2, byte3;
    logic done_reg;

    // Sequential logic
    always @(posedge clk) begin
        if (reset) begin
            state <= IDLE;
            byte1 <= 8'h00;
            byte2 <= 8'h00;
            byte3 <= 8'h00;
            done_reg <= 0;
        end else begin
            state <= next_state;
            case (state)
                IDLE: begin
                    if (in[3]) begin
                        byte1 <= in;
                        next_state <= COLLECT2;
                    end else begin
                        next_state <= IDLE;
                    end
                end
                COLLECT2: begin
                    byte2 <= in;
                    next_state <= COLLECT3;
                end
                COLLECT3: begin
                    byte3 <= in;
                    next_state <= DONE_STATE;
                end
                DONE_STATE: begin
                    done_reg <= 1;
                    next_state <= DONE_STATE;
                end
                default: next_state <= IDLE;
            endcase
        end
    end

    // Combinational logic for next state and outputs
    always @(*) begin
        if (state == IDLE) {
            done_reg = 0;
        } else if (state == DONE_STATE) {
            done_reg = 1;
        } else {
            done_reg = 0;
        }
    end

    // Assign outputs
    assign out_bytes = {byte1, byte2, byte3};
    assign done = done_reg;

    // Initial block for registers initialization
    initial begin
        state = IDLE;
        byte1 = 8'h00;
        byte2 = 8'h00;
        byte3 = 8'h00;
        done_reg = 0;
    end

endmodule
