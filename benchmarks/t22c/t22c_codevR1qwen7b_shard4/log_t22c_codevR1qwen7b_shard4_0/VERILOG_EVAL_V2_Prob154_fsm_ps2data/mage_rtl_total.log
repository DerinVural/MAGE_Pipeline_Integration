[2026-05-14 14:11:41,803 - mage.rtl_generator - INFO] RTL code: module TopModule (input clk, input reset, input [7:0] in, output logic [23:0] out_bytes, output logic done);
    // State definitions
    localparam IDLE = 2'b00;
    localparam COLLECT2 = 2'b01;
    localparam COLLECT3 = 2'b10;
    localparam DONE_STATE = 2'b11;

    reg [1:0] state, next_state;
    reg [7:0] byte1, byte2, byte3;
    reg done_reg;

    // Sequential logic
    always @(posedge clk) begin
        if (reset) begin
            state <= IDLE;
            byte1 <= 8'h00;
            byte2 <= 8'h00;
            byte3 <= 8'h00;
            done_reg <= 0;
        end else begin
            state <= next_state;
            case (state)
                IDLE: begin
                    if (in[3]) begin
                        byte1 <= in;
                        next_state <= COLLECT2;
                    end else begin
                        next_state <= IDLE;
                    end
                end
                COLLECT2: begin
                    byte2 <= in;
                    next_state <= COLLECT3;
                end
                COLLECT3: begin
                    byte3 <= in;
                    next_state <= DONE_STATE;
                end
                DONE_STATE: begin
                    done_reg <= 1;
                    next_state <= DONE_STATE;
                end
                default: next_state <= IDLE;
            endcase
        end
    end

    // Combinational logic for next state and outputs
    always @(*) begin
        if (state == IDLE) begin
            done_reg = 0;
        end else if (state == DONE_STATE) {
            done_reg = 1;
        } else {
            done_reg = 0;
        }
    end

    // Assign outputs
    assign out_bytes = {byte1, byte2, byte3};
    assign done = done_reg;

    // Initial block for registers initialization
    initial begin
        state = IDLE;
        byte1 = 8'h00;
        byte2 = 8'h00;
        byte3 = 8'h00;
        done_reg = 0;
    end

endmodule
