// FSM states
localparam IDLE = 2'b00;
localparam FIRST_BYTE = 2'b01;
localparam SECOND_BYTE = 2'b10;
localparam THIRD_BYTE = 2'b11;

reg [1:0] current_state, next_state;
reg [7:0] byte1, byte2;

// Sequential logic
always @(posedge clk) begin
    if (reset) begin
        current_state <= IDLE;
        byte1 <= 8'h0;
        byte2 <= 8'h0;
        out_bytes <= 24'h0;
        done <= 0;
    end
    else begin
        current_state <= next_state;
        // Capture bytes when in IDLE or FIRST_BYTE state
        if (current_state == IDLE && in[3]) begin
            byte1 <= in;
            next_state <= FIRST_BYTE;
        end
        else if (current_state == FIRST_BYTE) begin
            byte2 <= in;
            next_state <= SECOND_BYTE;
        end
        else if (current_state == SECOND_BYTE) begin
            // Wait for third byte and transition to THIRD_BYTE
            next_state <= THIRD_BYTE;
        end
        else if (current_state == THIRD_BYTE) {
            out_bytes <= {byte1, byte2, in}; // Concatenate all three bytes
            done <= 1;
            next_state <= IDLE; // Return to IDLE after three bytes
        end
        else {
            done <= 0; // Clear done in other states
        }
    end
end

// Combinational next state logic
always @(*) begin
    next_state = current_state;
    case (current_state)
        IDLE: begin
            if (in[3]) next_state = FIRST_BYTE;
        end
        FIRST_BYTE: next_state = SECOND_BYTE;
        SECOND_BYTE: next_state = THIRD_BYTE;
        THIRD_BYTE: next_state = IDLE;
    endcase
end

// Output assignment
