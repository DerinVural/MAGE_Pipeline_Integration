// State definitions
localparam STATE_IDLE = 0;
localparam STATE_WAIT_1ST = 1;
localparam STATE_WAIT_2ND = 2;
localparam STATE_COLLECT_3RD = 3;
localparam STATE_DONE = 4;

// Internal registers
logic [1:0] state;
logic [1:0] byte_count;
logic [7:0] buffer [0:2];
logic [23:0] out_reg;
logic done_reg;

// Initialize registers
initial begin
    state = STATE_IDLE;
    byte_count = 0;
    out_reg = 0;
    done_reg = 0;
end

// Sequential logic
always @(posedge clk) begin
    if (reset) begin
        state <= STATE_IDLE;
        byte_count <= 0;
        out_reg <= 0;
        done_reg <= 0;
    end else begin
        case (state)
            STATE_IDLE: begin
                if (in[3]) begin
                    buffer[0] <= in;
                    state <= STATE_WAIT_1ST;
                    byte_count <= 1;
                end
            end
            STATE_WAIT_1ST: begin
                buffer[1] <= in;
                state <= STATE_WAIT_2ND;
                byte_count <= 2;
            end
            STATE_WAIT_2ND: begin
                buffer[2] <= in;
                state <= STATE_COLLECT_3RD;
                byte_count <= 3;
            end
            STATE_COLLECT_3RD: begin
                out_reg <= {buffer[0], buffer[1], buffer[2], in};
                done_reg <= 1;
                state <= STATE_DONE;
            end
            STATE_DONE: begin
                done_reg <= 0;
                state <= STATE_IDLE;
                byte_count <= 0;
            end
            default: state <= STATE_IDLE;
        endcase
    end
end

// Combinational logic for done and out_bytes
always @(*) begin
    done = done_reg;
    out_bytes = out_reg;
end

endmodule
