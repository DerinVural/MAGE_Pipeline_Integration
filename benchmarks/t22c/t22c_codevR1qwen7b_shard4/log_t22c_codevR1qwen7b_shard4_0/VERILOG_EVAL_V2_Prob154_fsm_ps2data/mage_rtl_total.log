    // State definitions
    localparam STATE_IDLE = 3'b000;
    localparam STATE_FIRST = 3'b001;
    localparam STATE_SECOND = 3'b010;
    localparam STATE_DONE = 3'b011;
    localparam STATE_WAIT = 3'b100;
    localparam STATE_FLUSH = 3'b101;

    // State register and storage registers
    logic [2:0] state, next_state;
    logic [7:0] first_byte, second_byte;
    logic byte_received;

    // Initialization
    initial begin
        state = STATE_IDLE;
        byte_received = 1'b0;
        first_byte = 8'h00;
        second_byte = 8'h00;
        out_bytes = 24'h000000;
        done = 1'b0;
    end

    // State transition and storage update
    always @(posedge clk) begin
        if (reset) begin
            state <= STATE_IDLE;
        end else begin
            state <= next_state;
            if (state == STATE_IDLE && in[3]) begin
                first_byte <= in;
                next_state <= STATE_FIRST;
            end else if (state == STATE_FIRST) begin
                second_byte <= in;
                next_state <= STATE_SECOND;
            end else if (state == STATE_SECOND) begin
                out_bytes <= {first_byte, second_byte, in};
                next_state <= STATE_DONE;
            end else if (state == STATE_DONE) begin
                done <= 1'b1;
                next_state <= STATE_WAIT;
            end else if (state == STATE_WAIT) begin
                done <= 1'b0;
                next_state <= STATE_IDLE;
                byte_received <= 1'b0;
            end
            // Flush after done if necessary
            if (state != STATE_IDLE && next_state == STATE_IDLE) begin
                next_state <= STATE_IDLE;
            end
        end
    end

    // Combinational logic for next state and byte reception
    always @(*) begin
        case (state)
            STATE_IDLE: begin
                if (in[3]) begin
                    next_state = STATE_FIRST;
                end else begin
                    next_state = STATE_IDLE;
                end
            end
            STATE_FIRST: next_state = STATE_SECOND;
            STATE_SECOND: next_state = STATE_DONE;
            STATE_DONE: next_state = STATE_WAIT;
            STATE_WAIT: next_state = STATE_IDLE;
            default: next_state = STATE_IDLE;
        endcase
    end

    // Output done logic
    assign done = (state == STATE_DONE);

    // Byte received storage
