module tb();

    typedef struct packed {
        int errors;
        int errortime;
        int errors_out_bytes;
        int errortime_out_bytes;
        int errors_done;
        int errortime_done;
        
        int clocks;
    } stats;
    
    stats stats1 = '0;
    
