[2026-05-14 14:09:51,188 - mage.agent - INFO] module TopModule (input logic clk, input logic reset, input logic [7:0] in, output logic [23:0] out_bytes, output logic done);

localparam STATE_IDLE = 2'b00;
localparam STATE_WAIT_BYTE1 = 2'b01;
localparam STATE_WAIT_BYTE2 = 2'b10;
localparam STATE_WAIT_BYTE3 = 2'b11;

logic [1:0] state;
logic [7:0] byte1_reg, byte2_reg, byte3_reg;
logic [1:0] byte_count;

initial begin
    state = STATE_IDLE;
    byte_count = 0;
    byte1_reg = 0;
    byte2_reg = 0;
    byte3_reg = 0;
    done = 0;
    out_bytes = 0;
end

always @(posedge clk) begin
    if (reset) begin
        state <= STATE_IDLE;
        byte_count <= 0;
        byte1_reg <= 0;
        byte2_reg <= 0;
        byte3_reg <= 0;
        done <= 0;
        out_bytes <= 0;
    end
    else begin
        case (state)
            STATE_IDLE: begin
                if (in[3]) begin
                    byte1_reg <= in;
                    state <= STATE_WAIT_BYTE2;
                    byte_count <= 1;
                end
            end
            STATE_WAIT_BYTE2: begin
                if (in[3]) begin
                    byte2_reg <= in;
                    state <= STATE_WAIT_BYTE3;
                    byte_count <= 2;
                end
                else if (!in[3]) begin
                    byte1_reg <= in;
                    byte_count <= 1;
                end
            end
            STATE_WAIT_BYTE3: begin
                if (in[3]) begin
                    byte3_reg <= in;
                    state <= STATE_IDLE;
                    done <= 1;
                    out_bytes <= {byte1_reg, byte2_reg, byte3_reg};
                    byte_count <= 0;
                end
                else if (!in[3]) begin
                    case (byte_count)
                        1: begin
                            byte1_reg <= in;
                            byte_count <= 1;
                        end
                        2: begin
                            byte2_reg <= in;
                            byte_count <= 2;
                        end
                        default: byte_count <= 0;
                    endcase
                end
            end
            default: state <= STATE_IDLE;
        endcase
        if (state == STATE_WAIT_BYTE3 && byte_count == 2 && in[3]) begin
done <= 1;
out_bytes <= {byte1_reg, byte2_reg, in};
end
if (state == STATE_WAIT_BYTE3 && in[3]) begin
done <= 1;
end else done <= 0;
end
end

endmodule
