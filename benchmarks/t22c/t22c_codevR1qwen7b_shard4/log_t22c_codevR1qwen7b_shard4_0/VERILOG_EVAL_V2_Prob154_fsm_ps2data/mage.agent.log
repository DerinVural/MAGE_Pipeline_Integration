module tb();
    wire clk;
    logic [7:0] in;
    logic reset;
    logic [23:0] out_bytes_dut;
    logic done_dut;

    reg [511:0] input_queue [0:9];
    reg [23:0] got_out_bytes_queue [0:9];
    reg [23:0] golden_out_bytes_queue [0:9];
    reg reset_queue [0:9];
    reg clk_queue [0:9];
    reg [31:0] time_queue [0:9];
    reg tb_match_queue [0:9];
    localparam MAX_QUEUE_SIZE = 5;
    integer queue_size;

    TopModule dut (
        .clk(clk),
        .reset(reset),
        .in(in),
        .out_bytes(out_bytes_dut),
        .done(done_dut)
    );

    reg [7:0] in_stim [0:199];
    reg reset_stim [0:199];
    integer i;

    initial begin
        clk = 0;
        fork
            forever #5 clk = ~clk;
        join

        // Stimulus generation
        repeat(200) begin
            in = $random;
            reset = !($random & 31);
            @(negedge clk);
        end
        reset <= 1'b0;
        in <= 0;
        repeat(10) @(posedge clk);

        repeat(200) begin
            in = $random;
            in[3] = 1'b1;
            @(posedge clk);
            in = $random;
            @(posedge clk);
            in = $random;
            @(posedge clk);
        end

        #1 $finish;
    end

    // Check for mismatches on every clock edge
    always @(posedge clk, negedge clk) begin
        if (queue_size >= MAX_QUEUE_SIZE-1) begin
            queue_size = queue_size - 1;
        end

        input_queue[queue_size] = in;
        got_out_bytes_queue[queue_size] = out_bytes_dut;
        golden_out_bytes_queue[queue_size] = {16'h0, in_stim[0], in_stim[1], in_stim[2]}; // Example, depends on state
        reset_queue[queue_size] = reset;
        clk_queue[queue_size] = clk;
        time_queue[queue_size] = $time;
        tb_match_queue[queue_size] = (out_bytes_dut === golden_out_bytes_queue[queue_size]) && (done_dut === (/* expected done */));
        queue_size = queue_size + 1;

        // Check for first mismatch
        if (!tb_match_queue[queue_size]) begin
            if (stats1.errors == 0) begin
                stats1.errortime = time_queue[queue_size];
                $display("SIMULATION FAILED - %d MISMATCHES DETECTED, FIRST AT TIME %d", stats1.errors, stats1.errortime);
                // Display the queue contents after the first error
                $display("%d cycles before error:", queue_size);
                for (int i = 0; i < queue_size; i++) begin
                    $display("Cycle %0d, Reset %b, Input %h, Got Out Bytes %h, Expected %h, Got Done %b, Expected %b",
                        i,
                        reset_queue[i],
                        input_queue[i],
                        got_out_bytes_queue[i][23:16],
                        golden_out_bytes_queue[i][23:16],
                        got_out_bytes_queue[i][15:8],
                        golden_out_bytes_queue[i][15:8],
                        got_out_bytes_queue[i][7:0],
                        golden_out_bytes_queue[i][7:0],
                        done_dut,
                        (/* expected done */));
                end
                $display("ERROR AT TIME %d", time_queue[queue_size]);
                $finish;
            end
        end
    end

    // Final display
    final begin
        if (stats1.errors) begin
            $display("SIMULATION FAILED - %d MISMATCHES DETECTED, FIRST AT TIME %d", stats1.errors, stats1.errortime);
        end else begin
            $display("SIMULATION PASSED");
        end
    end
endmodule

