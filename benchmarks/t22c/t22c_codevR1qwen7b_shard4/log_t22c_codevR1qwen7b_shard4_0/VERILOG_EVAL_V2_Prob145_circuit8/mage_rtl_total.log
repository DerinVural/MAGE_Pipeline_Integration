`timescale 1ps/1ps
module stimulus_gen (input clk, output logic clock=0, output logic a); // Clock gen and stimuli
	initial forever #5 clock = ~clock;
	// Stimuli code adjusted to match input_spec timeline
endmodule

module tb(); // Main testbench
	reg clk = 0;
	initial forever #5 clk = ~clk;
	logic a, p, q;
	logic p_ref, q_ref;
	// Queue variables
	localparam MAX_QUEUE_SIZE = 10;
	reg [0:0] clk_queue [MAX_QUEUE_SIZE-1:0]; // 1-bit clock (0 or 1)
	reg a_queue [MAX_QUEUE_SIZE-1:0];
	reg p_queue [MAX_QUEUE_SIZE-1:0];
	reg q_queue [MAX_QUEUE_SIZE-1:0];
	reg p_ref_queue [MAX_QUEUE_SIZE-1:0];
	reg q_ref_queue [MAX_QUEUE_SIZE-1:0];
	integer queue_ptr = 0;
	integer errors = 0;
	integer errors_p = 0, errortime_p = -1;
	integer errors_q = 0, errortime_q = -1;

	// Instantiate DUT and reference model
	TopModule dut(.clock(clk), .a(a), .p(p), .q(q));
	RefModule ref(.clock(clk), .a(a), .p(p_ref), .q(q_ref));

	// Check at clock edges
	always @(posedge clk, negedge clk) begin
		a_queue[queue_ptr] = a;
		p_queue[queue_ptr] = p;
		q_queue[queue_ptr] = q;
		p_ref_queue[queue_ptr] = p_ref;
		q_ref_queue[queue_ptr] = q_ref;
		clk_queue[queue_ptr] = clk;
		queue_ptr = (queue_ptr + 1) % MAX_QUEUE_SIZE;

		// Check for mismatches
		if ((p !== p_ref) || (q !== q_ref)) begin
			if (errors == 0) begin
				$display("First Mismatch at Time %0t", $time);
				$display("Queue Content at Mismatch:");
				for (int i=0; i<MAX_QUEUE_SIZE; i++) begin
					$display("Time %0t: clk=%b, a=%b, p=%b, q=%b | ref_p=%b, ref_q=%b",
							$time - (10*i), clk_queue[(queue_ptr -1 -i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE], a_queue[(queue_ptr -1 -i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE], p_queue[(queue_ptr -1 -i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE], q_queue[(queue_ptr -1 -i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE], p_ref_queue[(queue_ptr -1 -i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE], q_ref_queue[(queue_ptr -1 -i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE]);
				end
			end
			errors += 1;
			if (p !== p_ref) begin errors_p +=1; if (errortime_p <0) errortime_p = $time; end
			if (q !== q_ref) begin errors_q +=1; if (errortime_q <0) errortime_q = $time; end
		end
	end

	// Final report
	initial begin
		@(negedge clk); // Adjust wait time based on sim duration
		if (errors == 0) $display("SIMULATION PASSED");
		else begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", errors, errortime_p >=0 ? errortime_p : errortime_q);
		end
		#100 $finish;
	end
endmodule
