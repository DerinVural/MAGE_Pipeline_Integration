[2026-05-14 13:15:37,428 - mage.agent - INFO] module TopModule (input logic clk, input logic reset, input logic s, input logic w, output logic z);
    localparam A = 0, B = 1, C = 2, D = 3;
    logic [1:0] state, next_state;
    logic [1:0] count;
    logic [2:0] w_history;

    // State register
    always @(posedge clk) begin
        if (reset)
            state <= A;
        else
            state <= next_state;
    end

    // Next state logic
    always @(*) begin
        next_state = state;
        case (state)
            A: next_state = s ? B : A;
            B: begin
                if (count == 3) begin
                    if (w_history[0] + w_history[1] + w_history[2] == 2)
                        next_state = D;
                    else
                        next_state = A;
                end else begin
                    next_state = B;
                end
            end
            D: next_state = A;
            default: next_state = A;
        endcase
    end

    // History and count update
    always @(posedge clk) begin
        if (reset) begin
            count <= 0;
            w_history <= 0;
        end else if (state == B) begin
            if (count < 3) begin
                w_history <= {w_history[1:0], w};
                count <= count + 1;
            end
        end else begin
            count <= 0;
            w_history <= 0;
        end
    end

    // Output logic
    assign z = (state == D);
endmodule
