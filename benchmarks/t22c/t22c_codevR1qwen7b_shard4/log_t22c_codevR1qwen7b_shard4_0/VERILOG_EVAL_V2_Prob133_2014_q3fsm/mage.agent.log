        if (z_ref !== ( z_ref ^ z_dut ^ z_ref )) begin
            if (stats1.errors_z == 0) stats1.errortime_z = $time;
            stats1.errors_z++;
        end
    end
endmodule

// Queue-based simulation mismatch display
reg [0:0] input_queue [0:9]; // Adjust size as needed
reg [0:0] got_output_queue [0:9];
reg [0:0] golden_queue [0:9];
reg [0:0] reset_queue [0:9];
localparam MAX_QUEUE_SIZE = 5;

always @(posedge clk, negedge clk) begin
    if (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin
        // Delete old entries to prevent overflow
        input_queue.delete(0);
        got_output_queue.delete(0);
        golden_queue.delete(0);
        reset_queue.delete(0);
    end

    // Store signals
    input_queue.push_back({reset, s, w}); // Combining reset, s, w into a single bit for queue storage
    got_output_queue.push_back(z_dut);
    golden_queue.push_back(z_ref);
    reset_queue.push_back(reset);

    // Check for first mismatch
    if (z_dut !== z_ref) begin
        $display("Mismatch detected at time %t", $time);
        $display("Last %0d cycles of simulation: ", input_queue.size());

        for (int i=0; i<input_queue.size(); i++) begin
            if (got_output_queue[i] === golden_queue[i])
                $display("Got Match at");
            else
                $display("Got Mismatch at");

            $display("Cycle %0d, reset %b, inputs %b, got %b, expected %b",
                i,
                reset_queue[i],
                input_queue[i][2:0], // Assuming 3 bits: reset, s, w (if stored as a 3-bit vector)
                got_output_queue[i],
                golden_queue[i]
            );
        end
        // Display simulation result after all mismatches are captured
        if (stats1.errors == 0) begin
            if ($time > 1000000)
                $display("SIMULATION PASSED");
            else
                $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
        end
    end
end
