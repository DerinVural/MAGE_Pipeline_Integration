[2026-05-14 13:18:47,613 - mage.rtl_generator - INFO] RTL code: module TopModule (input logic clk, input logic reset, input logic s, input logic w, output logic z);

  localparam STATE_A = 0;
  localparam STATE_B = 1;

  logic state;
  logic [1:0] sum;
  logic [1:0] counter;
  logic next_state;
  logic [1:0] next_sum;
  logic [1:0] next_counter;
  logic next_z;
  logic z_reg;

  assign z = z_reg;

  // Initialization via initial block
  initial begin
    state = STATE_A;
    sum = 0;
    counter = 0;
    next_state = STATE_A;
    next_sum = 0;
    next_counter = 0;
    next_z = 0;
    z_reg = 0;
  end

  // Sequential logic
  always @(posedge clk) begin
    if (reset) begin
      state <= STATE_A;
      sum <= 0;
      counter <= 0;
      z_reg <= 0;
    end else begin
      state <= next_state;
      sum <= next_sum;
      counter <= next_counter;
      z_reg <= next_z;
    end
  end

  // Combinational logic
  always @(*) begin
    // Default assignments
    next_state = state;
    next_sum = sum;
    next_counter = counter;
    next_z = z_reg;

    case (state)
      STATE_A: begin
        if (s) begin
          next_state = STATE_B;
          next_sum = 0;
          next_counter = 0;
        end else begin
          next_counter = 0;
        end
      end
      STATE_B: begin
        next_sum = sum + w;
        if (counter == 2'd2) begin
          if (next_sum == 2) begin
            next_z = 1'b1;
          end else begin
            next_z = 1'b0;
          end
          next_sum = 0;
          next_counter = 0;
        end else begin
          next_counter = counter + 1;
        end
      end
      default: begin
        next_state = STATE_A;
        next_sum = 0;
        next_counter = 0;
        next_z = 0;
      end
    endcase
  end

endmodule
