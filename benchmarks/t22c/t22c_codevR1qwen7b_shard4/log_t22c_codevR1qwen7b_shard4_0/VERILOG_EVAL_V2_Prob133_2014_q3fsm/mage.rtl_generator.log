      w_history <= {w_history[1:0], w};
      count <= $countones(w_history[0], w_history[1], w);
    end else begin
      w_history <= 3'b000;
      count <= 0;
    end
  end

  // Output logic
  always @(posedge clk) begin
    if (reset)
      z_reg <= 0;
    else if (state == STATE_B && count == 2)
