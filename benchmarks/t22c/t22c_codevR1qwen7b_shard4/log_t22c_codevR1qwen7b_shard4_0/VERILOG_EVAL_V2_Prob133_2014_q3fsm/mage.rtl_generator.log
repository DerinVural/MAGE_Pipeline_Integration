  localparam STATE_A = 0, STATE_B = 1;
  logic state, next_state;
  logic [2:0] w_history;
  logic [2:0] count;
  logic z_reg;

  // State transition
  always @(posedge clk) begin
    if (reset)
      state <= STATE_A;
    else
      state <= next_state;
  end

  // Next state logic
  always @(*) begin
    case (state)
