      STATE_B: next_state = (count == 2) ? STATE_A : STATE_B;
      default: next_state = STATE_A;
    endcase
  end

  // W history and counter
  always @(posedge clk) begin
    if (reset) begin
      w_history <= 3'b000;
      count <= 0;
