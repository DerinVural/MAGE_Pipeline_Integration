[2026-05-14 13:18:47,651 - mage.rtl_generator - INFO] RTL code: module TopModule(input clk, input reset, input s, input w, output logic z);

	localparam [1:0] STATE_A = 2'b00, STATE_B = 2'b01;
	logic [1:0] state, next_state;
	logic [2:0] w_history; // Stores last three w values
	logic [1:0] count;

	// Initialize state and history to known values
	initial begin
		state = STATE_A;
		w_history = 3'b000;
		count = 0;
	end

	// State transition and history update
	always @(posedge clk) begin
		if (reset) begin
			state <= STATE_A;
			w_history <= 3'b000;
		end else begin
			state <= next_state;
			// Shift in new w value
			w_history <= {w_history[1:0], w};
		end
	end

	// Next state logic
	always @(*) begin
		next_state = state;
		if (state == STATE_A) begin
			if (s) next_state = STATE_B;
		end else begin
			// After three cycles, remain in B
			if (w_history[2:0] != 3'b111 && w_history[2:0] != 3'b000) // Check after three cycles
				// Stay in B until three cycles pass, no reset needed
		end
	end

	// Count the number of ones in w_history (needs to be updated after three cycles in state B)
	always @(*) begin
		count = w_history[0] + w_history[1] + w_history[2];
	end

	// Output logic
	auto z = (state == STATE_B) && (count == 2) ? 1 : 0;

