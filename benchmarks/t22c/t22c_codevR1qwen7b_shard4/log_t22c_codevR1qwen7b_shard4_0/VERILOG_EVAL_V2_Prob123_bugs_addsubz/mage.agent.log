module tb();
    typedef struct packed {int errors; int errortime; int errors_out; int errortime_out; int errors_result_is_zero; int errortime_result_is_zero; int clocks;} stats;
    stats stats1 = 0;
    reg clk=0; always #5 clk=~clk;
    logic [7:0] a, b;
    logic do_sub;
    logic [7:0] out_ref, out_dut;
    logic result_is_zero_ref, result_is_zero_dut;
    wire tb_match = ( {out_ref, result_is_zero_ref} === ({out_ref, result_is_zero_ref} ^ {out_dut, result_is_zero_dut} ^ {out_ref, result_is_zero_ref}) );

    // Queue-based mismatch detection
    reg [7:0] input_queue [0:4]; reg [7:0] got_out_queue [0:4]; reg got_is_zero_queue [0:4]; reg [7:0] golden_out_queue [0:4]; reg golden_is_zero_queue [0:4]; reg reset_queue [0:4];
    localparam MAX_QUEUE_SIZE=5;
    always @(posedge clk, negedge clk) begin
        if (input_queue.size() >= MAX_QUEUE_SIZE) begin input_queue.delete(0); end
        input_queue.push_back({do_sub, a, b});
        got_out_queue.push_back(out_dut);
        golden_out_queue.push_back(out_ref);
        got_is_zero_queue.push_back(result_is_zero_dut);
        golden_is_zero_queue.push_back(result_is_zero_ref);
        reset_queue.push_back(0); // Assuming no reset in original
        if (!tb_match) begin
            if (stats1.errors ==0) $display("Mismatch @%0t", $time);
            stats1.errors +=1;
            if (stats1.errors ==1) begin
                $display("First Mismatch: do_sub=%b, a=%h, b=%h", do_sub, a, b);
                $display("Got: out=%h is_zero=%b", out_dut, result_is_zero_dut);
                $display("Expected: out=%h is_zero=%b", out_ref, result_is_zero_ref);
                if ($bits(a) <=64) $display("Binary: a=%b", a);
                if ($bits(b) <=64) $display("Binary: b=%b", b);
            end
        end
    end
    initial $dumpfile("wave.vcd");
    TopModule topu(do_sub, a, b, out_dut, result_is_zero_dut);
    RefModule refm(do_sub, a, b, out_ref, result_is_zero_ref);
    always @* begin result_is_zero_ref = (out_ref ==0); end // Correct logic
    initial $monitor("Time=%0t do_sub=%b a=%h b=%h", $time, do_sub, a, b);
    initial begin repeat(1e5) @(posedge clk, negedge clk); $display("TIMEOUT"); $finish; end
    initial stats1.clocks =0; always @(posedge clk, negedge clk) stats1.clocks +=1;
    initial $display(stats1.errors ? "SIMULATION FAILED - %0d MISMATCHES, FIRST AT %0t" : "SIMULATION PASSED", stats1.errors, stats1.errortime);
endmodule
