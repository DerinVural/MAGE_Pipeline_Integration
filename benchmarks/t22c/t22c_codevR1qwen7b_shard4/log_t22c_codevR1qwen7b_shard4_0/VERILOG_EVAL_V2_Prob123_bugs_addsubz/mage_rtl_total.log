    TopModule topu(do_sub, a, b, out_dut, result_is_zero_dut);
    RefModule refm(do_sub, a, b, out_ref, result_is_zero_ref);
    always @* begin result_is_zero_ref = (out_ref ==0); end // Correct logic
    initial $monitor("Time=%0t do_sub=%b a=%h b=%h", $time, do_sub, a, b);
    initial begin repeat(1e5) @(posedge clk, negedge clk); $display("TIMEOUT"); $finish; end
    initial stats1.clocks =0; always @(posedge clk, negedge clk) stats1.clocks +=1;
    initial $display(stats1.errors ? "SIMULATION FAILED - %0d MISMATCHES, FIRST AT %0t" : "SIMULATION PASSED", stats1.errors, stats1.errortime);
