ogic result_is_zero_ref, result_is_zero_dut;\\n  wire tb_match = ~({out_ref, result_is_zero_ref} === {out_dut, result_is_zero_dut});\\n  reg [511:0] wavedrom_title = 0;\\n  reg wavedrom_enable = 0;\\n  stimulus_gen stim1 (clk, do_sub, a, b, wavedrom_title, wavedrom_enable);\\n  RefModule refmod (.do_sub(do_sub), .a(a), .b(b), .out(out_ref), .result_is_zero(result_is_zero_ref));\\n  TopModule dut (do_sub, a, b, out_dut, result_is_zero_dut);\\n  bit strobe = 0;\\n  task wait_for_stable; repeat(5) begin strobe <= !strobe; @(strobe); end endtask\\n  always @(posedge clk, negedge clk) begin\\n    stats1.clocks++;\\n    if (!tb_match) begin\\n      if (stats1.errors == 0) stats1.errortime = $time;\\n      stats1.errors++;\\n    end\\n    if (out_ref !== (out_ref ^ out_dut ^ out_ref)) begin\\n      if (stats1.errors_out == 0) stats1.errortime_out = $time;\\n      stats1.errors_out++;\\n    end\\n    if (result_is_zero_ref !== (result_is_zero_ref ^ result_is_zero_dut ^ result_is_zero_ref)) begin\\n      if (stats1.errors_result_is_zero == 0) stats1.errortime_result_is_zero = $time;\\n      stats1.errors_result_is_zero++;\\n    end\\n  end\\n  final begin\\n    if (stats1.errors) begin\\n      $display("  , \t"); // Adjust indentation\\n      $display("                                                                               \t                                                                               \t                                                                               \t                                                                               \t                                                                               \t                                                                               \t                                                                               \t                                                                               \t                                                                               \t       