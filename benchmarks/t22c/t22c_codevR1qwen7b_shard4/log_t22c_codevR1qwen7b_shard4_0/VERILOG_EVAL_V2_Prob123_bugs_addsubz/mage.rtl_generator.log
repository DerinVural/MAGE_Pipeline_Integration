ult_is_zero_ref}) );\n\n    // Queue-based mismatch detection\n    reg [7:0] input_queue [0:4]; reg [7:0] got_out_queue [0:4]; reg got_is_zero_queue [0:4]; reg [7:0] golden_out_queue [0:4]; reg golden_is_zero_queue [0:4]; reg reset_queue [0:4];\n    localparam MAX_QUEUE_SIZE=5;\n    always @(posedge clk, negedge clk) begin\n        if (input_queue.size() >= MAX_QUEUE_SIZE) begin input_queue.delete(0); end\n        input_queue.push_back({do_sub, a, b});\n        got_out_queue.push_back(out_dut);\n        golden_out_queue.push_back(out_ref);\n        got_is_zero_queue.push_back(result_is_zero_dut);\n        golden_is_zero_queue.push_back(result_is_zero_ref);\n        reset_queue.push_back(0); // Assuming no reset in original\n        if (!tb_match) begin\n            if (stats1.errors ==0) $display("Mismatch @%0t", $time);\n            stats1.errors +=1;\n            if (stats1.errors ==1) begin\n                $display("First Mismatch: do_sub=%b, a=%h, b=%h", do_sub, a, b);\n                $display("Got: out=%h is_zero=%b", out_dut, result_is_zero_dut);\n                $display("Expected: out=%h is_zero=%b", out_ref, result_is_zero_ref);\n                if ($bits(a) <=64) $display("Binary: a=%b", a);\n                if ($bits(b) <=64) $display("Binary: b=%b", b);\n            end\n        end\n    end\n    initial $dumpfile("wave.vcd");\n    TopModule topu(do_sub, a, b, out_dut, result_is_zero_dut);\n    RefModule refm(do_sub, a, b, out_ref, result_is_zero_ref);\n    always @* begin result_is_zero_ref = (out_ref ==0); end // Correct logic\n    initial $monitor("Time=%0t do_sub=%b a=%h b=%h", $time, do_sub, a, b);\n    initial begin repeat(1e5) @(posedge clk, negedge clk); $display("TIMEOUT"); $finish; end\n    initial stats1.clocks =0; always @(posedge clk, negedge clk) stats1.clocks +=1;\n    initial $display(stats1.errors ? "SIMULATION FAILED - %0d MISMATCHES, FIRST AT %0t" : "SIMULATION PASSED", stats1.errors, stats1.errortime);\nendmodule\n</testbench>\n')])