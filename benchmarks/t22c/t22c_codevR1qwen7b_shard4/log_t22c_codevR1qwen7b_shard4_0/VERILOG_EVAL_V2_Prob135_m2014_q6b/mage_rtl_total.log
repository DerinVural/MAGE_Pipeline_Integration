module stimulus_gen(clk, y, w);
    input clk;
    output reg [2:0] y;
    output reg w;
    
    initial begin
        repeat(100) @(posedge clk) {y, w} <= $random;
        #1 $finish;
    end
endmodule

module RefModule(y, w, Y1);
    input [2:0] y;
    input w;
    output Y1;
    
    assign Y1 = y[1]; // Output is y[1]
endmodule
