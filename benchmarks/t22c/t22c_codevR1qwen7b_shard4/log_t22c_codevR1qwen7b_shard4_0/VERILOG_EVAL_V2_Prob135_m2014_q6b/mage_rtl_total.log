[2026-05-14 13:21:25,121 - mage.agent - INFO] `timescale 1ps/1ps

module stimulus_gen (
    input clk,
    output reg [2:0] y,
    output reg w
);

    initial begin
        repeat(100) @(posedge clk, negedge clk) begin
            {y, w} <= $random;
        end
        #1 $finish;
    end

endmodule

module tb();
    typedef struct packed {
        int errors;
        int errortime;
        int errors_Y1;
        int errortime_Y1;
        int clocks;
    } stats;
    stats stats1 = '0;

    reg clk = 0;
    initial forever #5 clk = ~clk;

    logic [2:0] y;
    logic w;
    logic Y1_ref;
    logic Y1_dut;
    wire tb_match, tb_mismatch;

    stimulus_gen stim1 ( .clk(clk), .y(y), .w(w) );
    RefModule good1 ( .y(y), .w(w), .Y1(Y1_ref) );
    TopModule top_module1 ( .y(y), .w(w), .Y1(Y1_dut) );

    assign tb_match = ( {Y1_ref} === ( {Y1_ref} ^ {Y1_dut} ^ {Y1_ref} ) );
    assign tb_mismatch = ~tb_match;

    localparam MAX_QUEUE_SIZE = 5;
    reg [2:0] input_queue [$];
    reg [0:0] got_Y1_queue [$];
    reg [0:0] golden_Y1_queue [$];
    reg [2:0] reset_queue [$];

    always @(posedge clk, negedge clk) begin
        if (input_queue.size() >= MAX_QUEUE_SIZE-1) begin
            input_queue.delete(0);
            got_Y1_queue.delete(0);
            golden_Y1_queue.delete(0);
            reset_queue.delete(0);
        end
        input_queue.push_back( {y, w} );
        got_Y1_queue.push_back(Y1_dut);
        golden_Y1_queue.push_back(Y1_ref);
        reset_queue.push_back(1'b0);

        if (!tb_match) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors += 1;
        end
        if (Y1_ref !== (Y1_ref ^ Y1_dut ^ Y1_ref)) begin
            if (stats1.errors_Y1 == 0) stats1.errortime_Y1 = $time;
            stats1.errors_Y1 += 1;
        end
        stats1.clocks += 1;

        // Check for first mismatch
        if (got_Y1_queue.size() > 0 && got_Y1_queue[0] !== golden_Y1_queue[0]) begin
            $display("Mismatch detected at time %0t", $time);
            $display("\nLast %0d cycles of simulation:", input_queue.size());
            for (int i = 0; i < input_queue.size(); i++) begin
                $display("Cycle %0d, reset %b, y %h, w %b, got Y1 %b, exp Y1 %b",
                    i, reset_queue[i], input_queue[i][2:0], input_queue[i][3],
                    got_Y1_queue[i], golden_Y1_queue[i]);
            end
        end
    end

    final begin
        if (stats1.errors_Y1)
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0t", stats1.errors_Y1, stats1.errortime_Y1);
        else
            $display("SIMULATION PASSED");
    end

    initial begin
        #1000000 $display("TIMEOUT"); $finish;
    end

endmodule
