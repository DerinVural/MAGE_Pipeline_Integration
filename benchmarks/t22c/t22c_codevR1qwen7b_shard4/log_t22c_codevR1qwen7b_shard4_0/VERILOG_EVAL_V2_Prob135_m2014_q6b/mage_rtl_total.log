module tb();
	reg clk = 0;
	reg [2:0] y;
	reg w;
	logic Y1_ref, Y1_dut;
	initial begin
		forever #5 clk = ~clk;
	end

	stimulus_gen stim1 (.clk(clk), .y(y), .w(w));
	RefModule ref_mod (.y(y), .w(w), .Y1(Y1_ref));
	TopModule top_mod (.y(y), .w(w), .Y1(Y1_dut));

	stats stats1;
	initial begin
		$dumpfile("wave.vcd");
		$dumpvars(1, tb, clk, y, w, Y1_ref, Y1_dut);
	end

	wire tb_match = (Y1_ref === (Y1_ref ^ Y1_dut ^ Y1_ref));
	always @(posedge clk, negedge clk) begin
		stats1.clocks++;
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
		end
		if (Y1_ref !== (Y1_ref ^ Y1_dut ^ Y1_ref)) begin
			if (stats1.errors_Y1 == 0) stats1.errortime_Y1 = $time;
			stats1.errors_Y1++;
		end
	end

	initial begin
		sreg {stats1} = '0;
		repeat(100) @(posedge clk, negedge clk) {y, w} <= $random;
		#1 $finish;
	end

	initial begin
		if (stats1.errors_Y1) $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_Y1, stats1.errortime_Y1);
		else $display("SIMULATION PASSED");
		$display("Total samples: %0d, Mismatches: %0d", stats1.clocks, stats1.errors);
	end
endmodule

module stimulus_gen (clk, y, w);
	input clk;
	output reg [2:0] y;
	output reg w;
	initial begin
		repeat(100) @(posedge clk, negedge clk) {y, w} <= $random;
		#1 $finish;
	end
endmodule

module RefModule (y, w, Y1);
	input [2:0] y;
	input w;
	public logic Y1;
	assign Y1 = y[1];
endmodule

module TopModule (y, w, Y1);
	input [2:0] y;
	input w;
	public logic Y1;
	// Implement state machine logic here, but according to input_spec, only next-state for y[1].
endmodule

struct packed stats {
	int errors;
	int errortime;
	int errors_Y1;
	int errortime_Y1;
	int clocks;
};
