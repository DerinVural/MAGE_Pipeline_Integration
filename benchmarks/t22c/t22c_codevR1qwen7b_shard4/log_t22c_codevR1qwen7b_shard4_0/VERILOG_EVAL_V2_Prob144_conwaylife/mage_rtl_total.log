    "reasoning": "The module TopModule has to implement the Game of Life on a 16x16 toroidal grid with synchronous load. The key steps are calculating each cell's neighbors, applying the rules, and updating the grid on clock edges. Use a combinational block to count live neighbors with wrap-around. Sequential logic updates q based on rules using current state. Initialize q to 0 with reset or initial block. Ensure no syntax errors by using logic, always @(*), localparams for grid size, and proper neighbor calculation with modulo arithmetic for toroidal wrap. Avoid using inside keyword and unique cases.",
    "module": "module TopModule (logic clk, logic load, logic [255:0] data, logic [255:0] q);\n\n  // Grid size 16x16\n  localparam int SIZE = 16;\n  localparam int TOTAL = SIZE * SIZE;\n\n  // Current state and next state\n  logic [TOTAL-1:0] q_reg;\n  logic [TOTAL-1:0] q_next;\n\n  // Initialize q to 0\n  initial begin\n    q_reg = 0;\n  end\n\n  // Load data when load is high on clock edge\n  always @(posedge clk) begin\n    if (load) begin\n      q_reg <= data;\n    end else begin\n      q_reg <= q_next;\n    end\n  end\n\n  assign q = q_reg;\n\n  // Function to count neighbors with toroidal wrap\n  function automatic logic [5:0] count_neighbors(int x, y);\n    input x, y;\n    int x_adj, y_adj;\n    logic [5:0] count;\n    begin\n      count = 0;\n      for (int dx = -1; dx <= 1; dx++) begin\n        for (int dy = -1; dy <= 1; dy++) begin\n          if (dx == 0 && dy == 0) continue;\n          x_adj = (x + dx + SIZE) % SIZE;\n          y_adj = (y + dy + SIZE) % SIZE;\n          count += q_reg[y * SIZE + x_adj];\n        end\n      end\n      count_neighbors = count;\n    end\n  endfunction\n\n  // Generate next state logic\n  generate\n    genvar i, j;\n    for (i = 0; i < SIZE; i++) begin: row\n      for (j = 0; j < SIZE; j++) begin: col\n        // Current cell's state\n        logic current_state;\n        assign current_state = q_reg[i * SIZE + j];\n\n        // Get neighbors count\n        logic [5:0] neighbor_count;\n        assign neighbor_count = count_neighbors(j, i);\n\n        // Apply Game of Life rules\n        always @(*) begin\n          if (current_state) begin\n            // Alive: 0-1 -> die; 3 -> revive; else stay\n            if (neighbor_count <= 1 || neighbor_count >= 4) begin\n              q_next[i * SIZE + j] = 0;\n            end else if (neighbor_count == 3) begin\n              q_next[i * SIZE + j] = 1;\n            end else begin\n              q_next[i * SIZE + j] = current_state;\n            end\n          end else begin\n            // Dead: 3 -> revive; else stay\n            if (neighbor_count == 3) begin\n              q_next[i * SIZE + j] = 1;\n            end else begin\n              q_next[i * SIZE + j] = current_state;\n            end\n          end\n        end\n      end\n    end\n  endgenerate\n\nendmodule\n"
}
