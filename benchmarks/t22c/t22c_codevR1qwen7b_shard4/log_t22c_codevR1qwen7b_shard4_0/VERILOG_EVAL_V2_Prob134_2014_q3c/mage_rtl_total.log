module tb();
	displayio(); // Function to display results
	yypdStruct stats1;

	random_gen random1();
	estimulus_gen stim1(clk, x, y);
	RefModule good1(clk, x, y, Y0_ref, z_ref);
	TopModule top_module1(clk, x, y, Y0_dut, z_dut);

	logic clk=0;
	initial forever #5 clk=~clk;

	logic x;
	logic [2:0] y;
	logic Y0_ref, Y0_dut;
	logic z_ref, z_dut;
	logic tb_match;

	assign tb_match = (Y0_ref === (Y0_ref ^ Y0_dut ^ Y0_ref)) && (z_ref === (z_ref ^ z_dut ^ z_ref));

	subroutine error_check {
		if (!tb_match) begin
			stats1.errors++;
			if (stats1.errors == 1) stats1.errortime = $time;
			stats1.errors_Y0 = Y0_mismatch ? stats1.errors_Y0 + 1 : stats1.errors_Y0;
			if (Y0_mismatch && stats1.errors_Y0 == 0) stats1.errortime_Y0 = $time;
			stats1.errors_z = z_mismatch ? stats1.errors_z + 1 : stats1.errors_z;
			if (z_mismatch && stats1.errors_z == 0) stats1.errortime_z = $time;
		end
	}

	event on_time_step {
		stats1.clocks++;
		error_check();
	}

	// Simulation end and display
	initial begin
		repeat(200) @(posedge clk);
		#1 $finish;
	end
	final begin
		if (stats1.errors) $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
		otherwise $display("SIMULATION PASSED");
	end
endmodule
