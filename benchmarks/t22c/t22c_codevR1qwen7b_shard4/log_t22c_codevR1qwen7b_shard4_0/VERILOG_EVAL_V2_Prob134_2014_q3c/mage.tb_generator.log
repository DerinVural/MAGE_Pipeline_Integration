    "testbench": "`timescale 1ps/1ps\nmodule tb();\n    logic clk = 0;\n    logic x;\n    logic [2:0] y;\n    logic Y0_ref, Y0_dut;\n    logic z_ref, z_dut;\n    logic tb_match;\n\n    // Stimulus generator\n    stimulus_gen stim_gen (\n        .clk(clk),\n        .x(x),\n        .y(y)\n    );\n\n    // Reference module instance\n    RefModule ref_mod (\n        .clk(clk),\n        .x(x),\n        .y(y),\n        .Y0(Y0_ref),\n        .z(z_ref)\n    );\n\n    // DUT instance\n    TopModule dut_inst (\n        .clk(clk),\n        .x(x),\n        .y(y),\n        .Y0(Y0_dut),\n        .z(z_dut)\n    );\n\n    // Error tracking variables\n    typedef struct {\n        integer errors;\n        integer errortime;\n        integer errors_Y0;\n        integer errortime_Y0;\n        integer errors_z;\n        integer errortime_z;\n        integer clocks;\n    } stats_t;\n    stats_t stats1 = {0, 0, 0, 0, 0, 0, 0};\n\n    // Check for matches on every clock edge\n    always @(posedge clk) begin\n        stats1.clocks = stats1.clocks + 1;\n        if (!(Y0_ref === (Y0_ref ^ Y0_dut ^ Y0_ref)) && (z_ref === (z_ref ^ z_dut ^ z_ref))) begin\n            if (stats1.errors == 0) stats1.errortime = $time;\n            stats1.errors += 1;\n            if (Y0_ref !== Y0_dut) begin\n                if (stats1.errors_Y0 == 0) stats1.errortime_Y0 = $time;\n                stats1.errors_Y0 += 1;\n            end\n            if (z_ref !== z_dut) begin\n                if (stats1.errors_z == 0) stats1.errortime_z = $time;\n                stats1.errors_z += 1;\n            end\n        end\n    end\n\n    // Simulation timeout\n    initial begin\n        #100000 $display(\"TIMEOUT\");\n        $finish;\n    end\n\n    // Simulation end and report\n    final begin\n        if (stats1.errors == 0) begin\n            $display(\"SIMULATION PASSED\");\n        end else begin\n            $display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\", stats1.errors, stats1.errortime)