rors++;\n        end\n        if (z_ref !== (z_ref ^ z_dut ^ z_ref)) begin\n            if (stats1.errors_z == 0) stats1.errortime_z = $time;\n            stats1.errors_z++;\n        end\n\n        if (!tb_match && stats1.errors == 1) begin\n            $display(\"Mismatch detected at time %0t\", $time);\n            $display(\"Last %0d cycles of simulation: \", queue_count);\n            for (int i=0; i < queue_count; i++) begin\n                $display(\"Cycle %0d: reset %b, input %b, got %b, expected %b\",\n                    i, reset_queue[i], input_queue[i], got_output_queue[i], golden_queue[i]);\n            end\n            $display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0t\", stats1.errors, stats1.errortime);\n            $finish;\n        end\n    end\n\n    initial begin\n        stats1 = '0;\n        queue_count = 0;\n        clk = 0;\n        // Additional initializations if needed\n    end\n\n    final begin\n        if (stats1.errors_z) begin\n            $display(\"Hint: Output 'z' has %0d mismatches. First at time %0t\", stats1.errors_z, stats1.errortime_z);\n        end else begin\n            $display(\"SIMULATION PASSED\");\n        end\n    end\n\n    // Timeout handling\n    initial begin\n        #1_000_000 $display(\"TIMEOUT\"); $finish;\n    end\nendmodule"
