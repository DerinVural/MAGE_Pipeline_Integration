,\n            output logic out\n        );\n\n            assign out = in0 ^ in1;\n\n        endmodule\n    </module>\n</example>\nExample 2:\n<example>\n    <input_spec>\n        Implement the SystemVerilog module based on the following description.\n        Assume that sigals are positive clock/clk triggered unless otherwise stated.\n\n        The module should implement an 8-bit registered incrementer.\n        The 8-bit input is first registered and then incremented by one on the next cycle.\n        The reset input is active high synchronous and should reset the output to zero.\n    </input_spec>\n    <module>\n        module TopModule(\n            input  logic       clk,\n            input  logic       reset,\n            input  logic [7:0] in_,\n            output logic [7:0] out\n        );\n\n            // Sequential logic\n            logic [7:0] reg_out;\n            always @( posedge clk ) begin\n                if ( reset )\n                reg_out <= 0;\n                else\n                reg_out <= in_;\n            end\n\n            // Combinational logic\n            logic [7:0] temp_wire;\n            always @(*) begin\n                temp_wire = reg_out + 1;\n            end\n\n            // Structural connections\n            assign out = temp_wire;\n\n        endmodule\n    </module>\n</example>\nExample 3:\n<example>\n    <input_spec>\n        Implement the SystemVerilog module based on the following description.\n        Assume that sigals are positive clock/clk triggered unless otherwise stated.\n\n        The module should implement an n-bit registered incrementer where the bitwidth is specified by the parameter nbits.\n        The n-bit input is first registered and then incremented by one on the next cycle.\n        The reset input is active high synchronous and should reset the output to zero.\n    </input_spec>\n    <module>\n        module TopModule #(\n            parameter nbits\n        )(\n            input  logic             clk,\n            input  logic             reset,\n            input  logic [nbits-1:0] in_,\n            output logic [nbits-1:0] out\n        );\n\n            // Sequential logic\n            logic [nbits-1:0] reg_out;\n            always @( posedge clk ) begin\n                if ( reset )\n                reg_out <= 0;\n                else\n                reg_out <= in_;\n            end\n\n            // Combinational logic\n            logic [nbits-1:0] temp_wire;\n            always @(*) begin\n                temp_wire = reg_out + 1;\n            end\n\n            // Structural connections\n            assign out = temp_wire;\n\n        endmodule\n    </module>\n</example>\nExample 4:\n<example>\n    <input_spec>\n        Implement the SystemVerilog module based on the following description.\n        Assume that sigals are positive clock/clk triggered unless otherwise stated.\n\n        Build a finite-state machine that takes as input a serial bit stream,\n            and outputs a one whenever the bit stream contains two consecutive one\'s.\n        The output is one on the cycle _after_ there are two consecutive one\'s.\n        The reset input is active high synchronous,\n            and should reset the finite-state machine to an appropriate initial state.\n    </input_spec>\n    <module>\n        module TopModule(\n            input  logic clk,\n            input  logic reset,\n            input  logic in_,\n            output logic out\n        );\n\n            // State enum\n            localparam STATE_A = 2\'b00;\n            localparam STATE_B = 2\'b01;\n            localparam STATE_C = 2\'b10;\n\n            // State register\n            logic [1:0] state;\n            logic [1:0] state_next;\n            always @(posedge clk) begin\n                if ( reset )\n                state <= STATE_A;\n                else\n                state <= state_next;\n            end\n\n            // Next state combinational logic\n            always @(*) begin\n                state_next = state;\n                case ( state )\n                STATE_A: state_next = ( in_ ) ? STATE_B : STATE_A;\n                STATE_B: state_next = ( in_ ) ? STATE_C : STATE_A;\n                STATE_C: state_next = ( in_ ) ? STATE_C : STATE_A;\n                endcase\n            end\n\n            // Output combinational logic\n            always @(*) begin\n                out = 1\'b0;\n                case ( state )\n                STATE_A: out = 1\'b0;\n                STATE_B: out = 1\'b0;\n                STATE_C: out = 1\'b1;\n                endcase\n            end\n\n        endmodule\n    </module>\n</example>\n\n<input_spec>\n\nI would like you to implement a module named TopModule with the following\ninterface. All input and output ports are one bit unless otherwise\nspecified.\n\n - input  clk\n - input  reset\n - input  w\n - output z\n\nThe module should implement the state machine shown below:\n\n  A (0) --0--> B\n  A (0) --1--> A\n  B (0) --0--> C\n  B (0) --1--> D\n  C (0) --0--> E\n  C (0) --1--> D\n  D (0) --0--> F\n  D (0) --1--> A\n  E (1) --0--> E\n  E (1) --1--> D\n  F (1) --0--> C\n  F (1) --1--> D\n\nAssume all sequential logic is triggered on the positive edge of the\nclock.\n\n\n</input_spec>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nAnother agent has generated a testbench regarding the given input_spec:\n<testbench>\n`timescale 1ps/1ps\n\nmodule stimulus_gen (\n    input clk,\n    output logic reset,\n    output logic w\n);\n    initial begin\n        repeat(200) @(posedge clk, negedge clk) begin\n            w <= $random;\n            reset <= ($random & 15) == 0;\n        end\n        #1 $finish;\n    end\nendmodule\n\nmodule tb();\n    typedef struct packed {\n        int errors;\n        int errortime;\n        int errors_z;\n        int errortime_z;\n        int clocks;\n    } stats;\n\n    stats stats1;\n    reg clk = 0;\n    initial forever #5 clk = ~clk;\n    logic reset;\n    logic w;\n    logic z_ref;\n    logic z_dut;\n    wire tb_match;\n    wire tb_mismatch = ~tb_match;\n    TopModule top_module1 (.*);\n    RefModule good1 (.*);\n\n    bit strobe = 0;\n    task wait_for_end_of_timestep; repeat(5) begin strobe <= !strobe; @(strobe); end endtask\n\n    reg [1:0] state;\n    reg [7:0] queue_count = 0;\n    localparam MAX_QUEUE_SIZE = 8;\n    reg [$bits(w)-1:0] input_queue [MAX_QUEUE_SIZE-1:0];\n    reg [$bits(z_dut)-1:0] got_output_queue [MAX_QUEUE_SIZE-1:0];\n    reg [$bits(z_ref)-1:0] golden_queue [MAX_QUEUE_SIZE-1:0];\n    reg reset_queue [MAX_QUEUE_SIZE-1:0];\n\n    always @(posedge clk, negedge clk) begin\n        if (queue_count >= MAX_QUEUE_SIZE) begin\n            for (int i=0; i<MAX_QUEUE_SIZE-1; i++) begin\n                input_queue[i] = input_queue[i+1];\n                got_output_queue[i] = got_output_queue[i+1];\n                golden_queue[i] = golden_queue[i+1];\n                reset_queue[i] = reset_queue[i+1];\n            end\n        end\n        input_queue[queue_count] = w;\n        got_output_queue[queue_count] = z_dut;\n        golden_queue[queue_count] = z_ref;\n        reset_queue[queue_count] = reset;\n        queue_count = (queue_count >= MAX_QUEUE_SIZE-1) ? 0 : queue_count + 1;\n\n        stats1.clocks++;\n        if (!tb_match) begin\n            if (stats1.errors == 0) stats1.errortime = $time;\n            stats1.errors++;\n        end\n        if (z_ref !== (z_ref ^ z_dut ^ z_ref)) begin\n            if (stats1.errors_z == 0) stats1.errortime_z = $time;\n            stats1.errors_z++;\n        end\n\n        if (!tb_match && stats1.errors == 1) begin\n            $display("Mismatch detected at time %0t", $time);\n            $display("Last %0d cycles of simulation: ", queue_count);\n            for (int i=0; i < queue_count; i++) begin\n                $display("Cycle %0d: reset %b, input %b, got %b, expected %b",\n                    i, reset_queue[i], input_queue[i], got_output_queue[i], golden_queue[i]);\n            end\n            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0t", stats1.errors, stats1.errortime);\n            $finish;\n        end\n    end\n\n    initial begin\n        stats1 = \'0;\n        queue_count = 0;\n        clk = 0;\n        // Additional initializations if needed\n    end\n\n    final begin\n        if (stats1.errors_z) begin\n            $display("Hint: Output \'z\' has %0d mismatches. First at time %0t", stats1.errors_z, stats1.errortime_z);\n        end else begin\n            $display("SIMULATION PASSED");\n        end\n    end\n\n    // Timeout handling\n    initial begin\n        #1_000_000 $display("TIMEOUT"); $finish;\n    end\nendmodule\n</testbench>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nThe module interface is given below:\n<module_interface>\nmodule stimulus_gen (\n    input clk,\n    output logic reset,\n    output logic w\n);\n\nendmodule\n\nmodule tb();\n    // Declarations and instantiations\nendmodule\n\nmodule TopModule (\n    input clk,\n    input reset,\n    input w,\n    output z\n);\n    // State machine implementation\nendmodule\n</module_interface>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nYour response will be processed by a program, not human.\nSo, please STRICTLY FOLLOW the output format given as XML tag content below to generate a VALID JSON OBJECT:\n<output_format>\n{\n    "reasoning": "All reasoning steps and advices to avoid syntax error",\n    "module": "Pure SystemVerilog code, a complete module"\n}\n</output_format>\nDO NOT include any other information in your response, like \'json\', \'reasoning\' or \'<output_format>\'.\n\nOther requirements:\n1. Don\'t use state_t to define the parameter. Use `localparam` or Use \'reg\' or \'logic\' for signals