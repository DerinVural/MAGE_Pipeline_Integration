    TopModule top_module1 (.*);
    RefModule good1 (.*);

    bit strobe = 0;
    task wait_for_end_of_timestep; repeat(5) begin strobe <= !strobe; @(strobe); end endtask

    reg [1:0] state;
    reg [7:0] queue_count = 0;
    localparam MAX_QUEUE_SIZE = 8;
    reg [$bits(w)-1:0] input_queue [MAX_QUEUE_SIZE-1:0];
    reg [$bits(z_dut)-1:0] got_output_queue [MAX_QUEUE_SIZE-1:0];
    reg [$bits(z_ref)-1:0] golden_queue [MAX_QUEUE_SIZE-1:0];
    reg reset_queue [MAX_QUEUE_SIZE-1:0];

    always @(posedge clk, negedge clk) begin
        if (queue_count >= MAX_QUEUE_SIZE) begin
            for (int i=0; i<MAX_QUEUE_SIZE-1; i++) begin
                input_queue[i] = input_queue[i+1];
                got_output_queue[i] = got_output_queue[i+1];
                golden_queue[i] = golden_queue[i+1];
                reset_queue[i] = reset_queue[i+1];
            end
        end
        input_queue[queue_count] = w;
        got_output_queue[queue_count] = z_dut;
        golden_queue[queue_count] = z_ref;
        reset_queue[queue_count] = reset;
        queue_count = (queue_count >= MAX_QUEUE_SIZE-1) ? 0 : queue_count + 1;

        stats1.clocks++;
        if (!tb_match) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
        end
        if (z_ref !== (z_ref ^ z_dut ^ z_ref)) begin
            if (stats1.errors_z == 0) stats1.errortime_z = $time;
            stats1.errors_z++;
        end

        if (!tb_match && stats1.errors == 1) begin
            $display("Mismatch detected at time %0t", $time);
            $display("Last %0d cycles of simulation: ", queue_count);
            for (int i=0; i < queue_count; i++) begin
                $display("Cycle %0d: reset %b, input %b, got %b, expected %b",
