            end
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0t", stats1.errors, stats1.errortime);
            $finish;
        end
    end

    initial begin
        stats1 = '0;
        queue_count = 0;
        clk = 0;
        // Additional initializations if needed
    end

    final begin
        if (stats1.errors_z) begin
            $display("Hint: Output 'z' has %0d mismatches. First at time %0t", stats1.errors_z, stats1.errortime_z);
        end else begin
            $display("SIMULATION PASSED");
        end
    end

    // Timeout handling
    initial begin
        #1_000_000 $display("TIMEOUT"); $finish;
    end
endmodule
