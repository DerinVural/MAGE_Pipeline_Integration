    // State definitions
    localparam S0 = 2'b00, S1 = 2'b01, S2 = 2'b10;
    logic [1:0] state, next_state;

    // State register with async reset (active low aresetn)
    always @(posedge clk or negedge aresetn) begin
        if (!aresetn) state <= S0;
        else state <= next_state;
