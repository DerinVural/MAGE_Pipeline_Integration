[2026-05-14 13:58:57,719 - mage.rtl_generator - INFO] RTL code: module TopModule (input clk, input resetn, input [2:0] r, output logic [2:0] g);

localparam STATE_A = 0,
           STATE_B = 1,
           STATE_C = 2,
           STATE_D = 3;

reg [1:0] state, next_state;

// State register
always @(posedge clk) begin
    if (!resetn) begin
        state <= STATE_A;
    end else begin
        state <= next_state;
    end
end

// Next state logic
always @(*) begin
    next_state = state; // default to stay in current state
    case (state)
        STATE_A: begin
            if (r == 3'b000) begin
                next_state = STATE_A;
            end else if (r[0]) begin
                next_state = STATE_B;
            end else if (r[1]) begin
                next_state = STATE_C;
            end else if (r[2]) begin
                next_state = STATE_D;
            end
        end
        STATE_B: begin
            if (r[0]) begin
                next_state = STATE_B;
            end else begin
                next_state = STATE_A;
            end
        end
        STATE_C: begin
            if (r[1]) begin
                next_state = STATE_C;
            end else begin
                next_state = STATE_A;
            end
        end
        STATE_D: begin
            if (r != 3'b000) begin
                // Handle based on priority if any requests are active
                if (r[0]) begin
                    next_state = STATE_B;
                end else if (r[1]) begin
                    next_state = STATE_C;
                end else if (r[2]) begin
                    next_state = STATE_D;
                end else begin
                    next_state = STATE_A;
                end
            end else begin
                next_state = STATE_A;
            end
        end
        default: next_state = STATE_A;
    endcase
end

// Output logic
assign g[0] = (state == STATE_B);
assign g[1] = (state == STATE_C);
assign g[2] = (state == STATE_D);

endmodule
