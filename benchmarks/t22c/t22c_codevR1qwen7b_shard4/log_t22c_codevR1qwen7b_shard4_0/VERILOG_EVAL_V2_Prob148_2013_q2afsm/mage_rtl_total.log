[2026-05-14 13:58:26,402 - mage.rtl_generator - INFO] RTL code: module TopModule (input clk, input resetn, input [2:0] r, output logic [2:0] g);

  // Define states using localparam
  localparam [1:0] STATE_A = 2'b00,
                   STATE_B = 2'b01,
                   STATE_C = 2'b10;
  logic [1:0] state = 2'b00, next_state;

  // Next state logic
  always_comb begin
    case (state)
      STATE_A: begin
        if (r[0])
          next_state = STATE_B;
        else if (!r[0] && r[1])
          next_state = STATE_C;
        else if (!r[0] && !r[1] && r[2])
          next_state = STATE_B; // Assuming grant for g2 is state D not present here, so adjust as per original description
        else
          next_state = STATE_A;
      end
      STATE_B: next_state = r[0] ? STATE_B : STATE_A;
      STATE_C: next_state = r[1] ? STATE_C : STATE_A;
      default: next_state = STATE_A;
    endcase
  end

  // State transition
  always_ff @(posedge clk) begin
    state <= next_state;
  end

  // Output logic
  assign g = (state == STATE_B) ? 3'b001 :
             (state == STATE_C) ? 3'b010 :
             3'b000;

endmodule
