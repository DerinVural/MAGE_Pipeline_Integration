[2026-05-14 13:57:45,167 - mage.rtl_generator - INFO] RTL code: module TopModule (input logic clk, input logic resetn, input logic [2:0] r, output logic [2:0] g);

localparam [2:0] A = 3'b000, B = 3'b001, C = 3'b010, D = 3'b011;

logic [2:0] state, next_state;

// State register
always_ff @(posedge clk) begin
    if (!resetn)
        state <= A;
    else
        state <= next_state;
end

// Next state logic
always_comb begin
    next_state = state; // Default to current state
    case (state)
        A: begin
            if (r == 3'b001) next_state = B;
            else if (r == 3'b011) next_state = C;
            else if (r == 3'b000) next_state = D;
            // else remain in A
        end
        B: next_state = r[0] ? B : A;
        C: next_state = r[1] ? C : A;
        default: next_state = A; // Handle other states
    endcase
end

// Output logic
always_comb begin
    g = 3'b000;
    case (state)
        B: g[0] = 1'b1;
        C: g[1] = 1'b1;
        // D: No grant, as per state transitions
    endcase
end

endmodule
