 g_reg = 3'b010;
 if (r[1]) next_state = C;
 else next_state = A;
 end
 D: begin
 g_reg = 3'b100;
 next_state = (r == 3'b000) ? A : D;
 end
 default: next_state = A;
 endcase
 end

 assign g = g_reg;

endmodule
