[2026-05-14 13:59:07,539 - mage.rtl_generator - INFO] RTL code: module TopModule (input logic clk, input logic resetn, input logic [2:0] r, output logic [2:0] g);

  // State definitions
  localparam A = 0,
             B = 1,
             C = 2,
             D = 3;
  logic [1:0] state, next_state;
  logic [2:0] g_reg;

  // Initialize state to A on reset
  always_ff @(posedge clk) begin
    if (!resetn) begin
      state <= A;
    end else begin
      state <= next_state;
    end
  end

  // Next state logic
  always_comb begin
    next_state = state;
    case (state)
      A: begin
        if (r[0])
          next_state = B;
        else if (!r[0] && r[1])
          next_state = C;
        else if (r == 3'b000)
          next_state = D;
        // else stay in A
      end
      B: if (!r[0]) next_state = A;
      C: if (!r[1]) next_state = A;
      D: if (!r[2]) next_state = A;
      default: next_state = A;
    endcase
  end

  // Output logic
  always_comb begin
    g = 3'b000;
    case (state)
      B: g = 3'b001;
      C: g = 3'b010;
      D: g = 3'b100;
      default: g = 3'b000;
    endcase
  end

endmodule
