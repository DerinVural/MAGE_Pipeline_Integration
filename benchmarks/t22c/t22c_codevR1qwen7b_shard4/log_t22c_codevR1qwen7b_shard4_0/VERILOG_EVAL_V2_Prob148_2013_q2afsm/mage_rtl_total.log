    "module": "module TopModule(input logic clk, input logic resetn, input logic [2:0] r, output logic [2:0] g); \n\n localparam [2:0] A = 3'b000, B = 3'b001, C = 3'b010, D = 3'b011;\n logic [2:0] current_state, next_state;\n logic [2:0] g_reg;\n\n // Sequential block for state and output registers\n always @(posedge clk) begin\n if (!resetn) begin\n current_state <= A;\n g_reg <= 0;\n end else begin\n current_state <= next_state;\n end\n end\n\n // Combinational block for next state and outputs\n always @(*) begin\n next_state = current_state;\n g_reg = g_reg; // Default to hold value\n case (current_state)\n [A]: begin\n if (r == 3'b001) next_state = B;\n else if (r == 3'b011) next_state = C;\n else if (r == 3'b000) next_state = D;\n else if (r == 3'b010) next_state = A; // Wait for priority check\n else next_state = A;\n // Default grant remains 0\n if (r[0]) g_reg = 3'b001;\n else if (r[1] && !r[0]) g_reg = 3'b010;\n else if (r[2] && !r[1] && !r[0]) g_reg = 3'b100;\n else g_reg = 3'b000;\n end\n [B]: begin\n g_reg = 3'b001;\n if (r[0]) next_state = B;\n else next_state = A;\n end\n [C]: begin\n g_reg = 3'b010;\n if (r[1]) next_state = C;\n else next_state = A;\n end\n [D]: begin\n g_reg = 3'b100;\n // Wait until requests are off\n next_state = (r == 3'b000) ? A : D;\n end\n default: next_state = A;\n endcase\n end\n\n // Output assignment\n assign g = g_reg;\n\nendmodule"
