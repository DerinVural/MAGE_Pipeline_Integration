[2026-05-14 13:54:44,452 - mage.agent - INFO] module TopModule (input logic clk, input logic resetn, input logic [2:0] r, output logic [2:0] g); 

 localparam [2:0] A = 3'b000, B = 3'b001, C = 3'b010, D = 3'b011;
 logic [2:0] current_state, next_state;
 logic [2:0] g_reg;

 // Sequential block for state and output registers
 always_ff @(posedge clk) begin
 if (!resetn) begin
 current_state <= A;
 g_reg <= 0;
 end else begin
 current_state <= next_state;
 end
 end

 // Combinational block for next state and outputs
 always_comb begin
 next_state = current_state;
 g_reg = g_reg; // Default to hold value
 case (current_state)
 A: begin
 if (r == 3'b001) next_state = B;
 else if (r == 3'b011) next_state = C;
 else if (r == 3'b000) next_state = D;
 else if (r == 3'b010) next_state = A;
 else next_state = A;

 if (r[0]) g_reg = 3'b001;
 else if (r[1] && !r[0]) g_reg = 3'b010;
 else if (r[2] && !r[1] && !r[0]) g_reg = 3'b100;
 else g_reg = 3'b000;
 end
 B: begin
 g_reg = 3'b001;
 if (r[0]) next_state = B;
 else next_state = A;
 end
 C: begin
 g_reg = 3'b010;
 if (r[1]) next_state = C;
 else next_state = A;
 end
 D: begin
 g_reg = 3'b100;
 next_state = (r == 3'b000) ? A : D;
 end
 default: next_state = A;
 endcase
 end

 assign g = g_reg;

endmodule
