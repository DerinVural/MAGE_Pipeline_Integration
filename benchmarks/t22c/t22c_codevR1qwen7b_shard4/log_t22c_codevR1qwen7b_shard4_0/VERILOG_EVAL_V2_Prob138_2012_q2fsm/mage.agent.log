[2026-05-14 13:26:20,909 - mage.agent - INFO] module TopModule (input logic clk, input logic reset, input logic w, output logic z);

    // State definitions
    localparam STATE_A = 3'd0;
    localparam STATE_B = 3'd1;
    localparam STATE_C = 3'd2;
    localparam STATE_D = 3'd3;
    localparam STATE_E = 3'd4;
    localparam STATE_F = 3'd5;

    logic [2:0] state, next_state;

    // Initialize state to A using initial block
    initial state = STATE_A;

    // State register
    always @(posedge clk) begin
        state <= next_state;
    end

    // Next state logic
    always @(*) begin
        next_state = state; // Default to current state
        case (state)
            STATE_A: begin
                next_state = w ? STATE_B : STATE_A;
            end
            STATE_B: begin
                next_state = w ? STATE_C : STATE_D;
            end
            STATE_C: begin
                next_state = w ? STATE_E : STATE_D;
            end
            STATE_D: begin
                next_state = w ? STATE_F : STATE_A;
            end
            STATE_E: begin
                next_state = w ? STATE_E : STATE_D;
            end
            STATE_F: begin
                next_state = w ? STATE_C : STATE_D;
            end
            default: next_state = STATE_A;
        endcase
    end

    // Output logic: z is 1 when state is E
    assign z = (state == STATE_E);

endmodule
