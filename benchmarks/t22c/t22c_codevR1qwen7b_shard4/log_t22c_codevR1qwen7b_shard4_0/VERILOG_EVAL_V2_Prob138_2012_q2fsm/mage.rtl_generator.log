  // State definitions
  localparam STATE_A = 3'b000;
  localparam STATE_B = 3'b001;
  localparam STATE_C = 3'b010;
  localparam STATE_D = 3'b011;
  localparam STATE_E = 3'b100;
  localparam STATE_F = 3'b101;

  // State register and next state variables
  logic [2:0] state, next_state;

  // Initialize state to A on reset or initial block
  initial begin
    state = STATE_A;
  end

  // Sequential state update with synchronous reset
  always @(posedge clk) begin
    if (reset) begin
      state <= STATE_A;
    end else begin
      state <= next_state;
    end
  end

  // Combinational next state logic
  always @(*) begin
    next_state = state; // Default to current state
    case (state)
      STATE_A: next_state = w ? STATE_B : STATE_A;
      STATE_B: begin
        if (w) next_state = STATE_C;
        else next_state = STATE_D;
      end
      STATE_C: next_state = w ? STATE_E : STATE_D;
      STATE_D: begin
        if (w) next_state = STATE_F;
        else next_state = STATE_A;
      end
      STATE_E: begin
        if (w) next_state = STATE_E;
        else next_state = STATE_D;
      end
      STATE_F: begin
        if (w) next_state = STATE_C;
        else next_state = STATE_D;
      end
      default: next_state = STATE_A;
    endcase
  end

  // Output logic: z is 1 in C and E
  assign z = (state == STATE_C) || (state == STATE_E);

endmodule
