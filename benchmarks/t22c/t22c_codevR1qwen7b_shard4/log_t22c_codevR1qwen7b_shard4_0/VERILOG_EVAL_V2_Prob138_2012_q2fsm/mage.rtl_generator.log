    // State definitions
    localparam STATE_A = 3'b000;
    localparam STATE_B = 3'b001;
    localparam STATE_C = 3'b010;
    localparam STATE_D = 3'b011;
    localparam STATE_E = 3'b100;
    localparam STATE_F = 3'b101;

    // State and next state variables
    logic [2:0] state, next_state;

    // Initialize state to A
    initial begin
        state = STATE_A;
    end

    // Synchronous state update with reset
    always @(posedge clk) begin
        if (reset)
            state <= STATE_A;
        else
            state <= next_state;
    end

    // Combinational logic for next state
    always @(*) begin
        case (state)
            STATE_A: begin
                next_state = w ? STATE_B : STATE_A;
            end
            STATE_B: begin
                next_state = w ? STATE_C : STATE_D;
            end
            STATE_C: begin
                next_state = w ? STATE_E : STATE_D;
            end
            STATE_D: begin
                next_state = w ? STATE_F : STATE_A;
            end
            STATE_E: begin
                next_state = w ? STATE_E : STATE_D;
            end
            STATE_F: begin
                next_state = w ? STATE_C : STATE_D;
            end
            default: begin
                next_state = STATE_A;
            end
        endcase
    end

    // Output logic
    assign z = ( (state == STATE_E && w) || (state == STATE_F && w) ) ? 1'b1 : 1'b0;
endmodule
