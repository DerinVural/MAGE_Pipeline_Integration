localparam STATE_A = 3'b000;
localparam STATE_B = 3'b001;
localparam STATE_C = 3'b010;
localparam STATE_D = 3'b011;
localparam STATE_E = 3'b100;
localparam STATE_F = 3'b101;

reg [2:0] state, next_state;

// State flip-flops
always @(posedge clk) begin
    if (reset)
        state <= STATE_A;
    else
        state <= next_state;
end

// Next state logic
always @(*) begin
    next_state = state; // default to current state
    case (state)
        STATE_A: next_state = w ? STATE_B : STATE_A;
        STATE_B: next_state = w ? STATE_C : STATE_D;
        STATE_C: next_state = w ? STATE_E : STATE_D;
        STATE_D: next_state = w ? STATE_F : STATE_A;
        STATE_E: next_state = w ? STATE_E : STATE_D;
        STATE_F: next_state = w ? STATE_C : STATE_D;
        default: next_state = STATE_A;
    endcase
end

// Output logic
logic z_reg;

always @(*) begin
    z_reg = 1'b0; // default value
    case (state)
        STATE_A: z = 1'b0;
        STATE_B: z = 1'b0;
        STATE_C: z = 1'b1;
        STATE_D: z = 1'b0;
        STATE_E: z = 1'b0;
        STATE_F: z = 1'b1;
        default: z = 1'b0;
    endcase
end

endmodule
