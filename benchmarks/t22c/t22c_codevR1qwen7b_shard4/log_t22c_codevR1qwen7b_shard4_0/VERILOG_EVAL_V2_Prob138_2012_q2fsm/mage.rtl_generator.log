        STATE_E: next_state = w ? STATE_E : STATE_D;
        STATE_F: next_state = w ? STATE_C : STATE_D;
        default: next_state = STATE_A;
    endcase
end

// State flip-flops with synchronous reset
always @(posedge clk) begin
    if (reset)
        state <= STATE_A;
    else
        state <= next_state;
end

// Output logic
assign z = (state == STATE_C || state == STATE_E || state == STATE_F);

// Initialize unknown states
initial begin
    state = STATE_A;
    next_state = STATE_A;
end

endmodule
