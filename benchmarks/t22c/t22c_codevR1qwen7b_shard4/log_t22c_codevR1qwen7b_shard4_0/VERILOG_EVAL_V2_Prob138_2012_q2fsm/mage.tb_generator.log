_count == 0) begin\n                error_time = $time;\n            end\n            error_count += 1;\n        end\n        if (z !== z_ref) begin\n            error_z_count += 1;\n        end\n    end\n\n    // Simulation timeout after 100K cycles\n    initial begin\n        #100000 $display("        	, 	"); // Adjusted for display alignment (example placeholder)\n        $finish;\n    end\n\n    // Simulation end and display\n    initial begin\n        wait(error_count > 0 || error_z_count > 0);\n        $display("   	: 	");\n        $display("        	, 	"); // More placeholders for formatting\n        if (error_count == 0 && error_z_count == 0) begin\n            $display("   	: 	");\n            $display("   	, 	");\n            $display("        	: 	");\n            $display("   	, 	");\n            $display("   	: 	");\n            $display("   	, 	");\n            $display("   	: 	");\n            $display("   	, 	");\n            $display("   	: 	");\n            $display("   	, 	");\n            $display("   	: 	");\n            $display("   	, 	");\n            $display("   	: 	");\n            $display("   	, 	");\n            $display("   	: 	");\n            $display("   	, 	");\n            $display("   	: 	");\n            $display("   	, 	");\n            $display("   	: 	");\n            $display("   	, 	");\n            $display("   	: 	");\n            $display("   	, 	");\n            $display("   	: 	");\n            $display("   	, 	");\n            $display("   	: 	");\n            $display("   	, 	");\n            $display("   	: 	");\n            $display("   	, 	");\n            $display("   	: 	");\n            $display("   	, 	");\n            $display("   	: 	");\n            $display("   	, 	");\n            $display("   	: 	");\n            $display("   	, 	");\n            $display("   	: 	");\n            $display("   	, 	");\n            $display("   	: 	");\n            $display("   	, 	");\n            $display("   	: 	");\n   