        if (!ground) begin
          next_state = STATE_FALLING;
          aaah_reg = 1'b1;
        end else if (dig && ground) begin
          next_state = STATE_DIGGING;
          digging_reg = 1'b1;
        end else if (bump_left || bump_right) begin
          next_state = STATE_WALK_LEFT;
          walk_left_reg = 1'b1;
          walk_right_reg = 1'b0;
        end
      end
      STATE_FALLING: begin
        aaah_reg = 1'b1;
        if (ground) begin
