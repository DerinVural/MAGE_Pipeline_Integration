nments\n41:     next_state = state;\n42:     walk_left_reg = walk_left_reg;\n43:     walk_right_reg = walk_right_reg;\n44:     aaah_reg = aaah_reg;\n45:     digging_reg = digging_reg;\n46: \n47:     case (state)\n48:       STATE_WALK_LEFT: begin\n49:         if (!ground) begin\n50:           next_state = STATE_FALLING;\n51:           aaah_reg = 1\'b1;\n52:         end else if (dig && ground) begin\n53:           next_state = STATE_DIGGING;\n54:           digging_reg = 1\'b1;\n55:         end else if (bump_left || bump_right) begin\n56:           next_state = STATE_WALK_RIGHT;\n57:           walk_right_reg = 1\'b1;\n58:           walk_left_reg = 1\'b0;\n59:         end\n60:       end\n61:       STATE_WALK_RIGHT: begin\n62:         if (!ground) begin\n63:           next_state = STATE_FALLING;\n64:           aaah_reg = 1\'b1;\n65:         end else if (dig && ground) begin\n66:           next_state = STATE_DIGGING;\n67:           digging_reg = 1\'b1;\n68:         end else if (bump_left || bump_right) begin\n69:           next_state = STATE_WALK_LEFT;\n70:           walk_left_reg = 1\'b1;\n71:           walk_right_reg = 1\'b0;\n72:         end\n73:       end\n74:       STATE_FALLING: begin\n75:         aaah_reg = 1\'b1;\n76:         if (ground) begin\n77:           next_state = state; // Resume original direction\n78:         end\n79:       end\n80:       STATE_DIGGING: begin\n81:         if (!ground) begin\n82:           next_state = STATE_FALLING;\n83:           aaah_reg = 1\'b1;\n84:         end else if (dig && ground) begin\n85:           digging_reg = 1\'b1;\n86:         end else if (ground && !dig) begin\n87:           next_state = state; // Continue digging\n88:         end else if (!ground) begin\n89:           next_state = STATE_FALLING;\n90:         end\n91:       end\n92:       default: begin\n93:         next_state = STATE_WALK_LEFT;\n94:       end\n95:     endcase\n96:   end\n97: \n98:   // Assign outputs\n99:   assign walk_left = walk_left_reg;\n100:   assi