                            end
                        end
                        else begin
                            mm_tens <= mm_tens + 1;
                        end
                    end
                    else begin
                        mm_units <= mm_units + 1;
                    end
                end
                else begin
                    ss_tens <= ss_tens + 1;
                end
            end
            else begin
                ss_units <= ss_units + 1;
            end
        end
    end

endmodule
