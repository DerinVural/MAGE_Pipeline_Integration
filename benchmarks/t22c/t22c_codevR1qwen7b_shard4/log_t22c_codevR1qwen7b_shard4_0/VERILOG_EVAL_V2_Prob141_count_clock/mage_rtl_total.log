[2026-05-14 13:38:50,789 - mage.rtl_generator - INFO] RTL code: module TopModule (input clk, input reset, input ena, output logic pm, output logic [7:0] hh, output logic [7:0] mm, output logic [7:0] ss);

localparam [1:0] STATE_AM = 2'b00, STATE_PM = 2'b01;
reg [1:0] pm_reg;
reg [3:0] hh1, hh0, mm1, mm0, ss1, ss0;

// Initialize counters with initial block
initial begin
    hh1 = 4'd1; hh0 = 4'd2; // Start at 12
    mm1 = 4'd0; mm0 = 4'd0;
    ss1 = 4'd0; ss0 = 4'd0;
    pm_reg = STATE_AM;
end

// HH counters: BCD increment
always @(posedge clk) begin
    if (reset) begin
        hh1 <= 4'd1; hh0 <= 4'd2; // Reset to 12
        pm_reg <= STATE_AM;
    end else if (ena) begin
        if (ss0 == 4'd9) begin
            ss0 <= 4'd0;
            if (ss1 == 4'd5 && ss0 == 4'd9) begin
                ss1 <= 4'd0;
                if (mm0 == 4'd9) begin
                    mm0 <= 4'd0;
                    if (mm1 == 4'd5 && mm0 == 4'd9) begin
                        mm1 <= 4'd0;
                        // Increment hour after minute wraps
                        if (hh1 == 4'd1 && hh0 == 4'd2) begin // 12 -> 1
                            hh1 <= 4'd1; hh0 <= 4'd1;
                            pm_reg <= STATE_PM;
                        end else if (hh0 == 4'd9 && hh1 == 4'd1) begin // 11 -> 12
                            hh1 <= 4'd1; hh0 <= 4'd2;
                            pm_reg <= STATE_PM;
                        end else if (hh0 == 4'd2 && hh1 == 4'd3) begin // 3 -> 4 etc.
                            hh1 <= hh1 + 1;
                            hh0 <= hh0 + 1;
                        end else if (hh0 == 4'd9 && hh1 == 4'd2) begin // 9 -> 10
                            hh1 <= 4'd1; hh0 <= 4'd0;
                        end else begin // Increment BCD	hh0 <= hh0 + 1;
                            if (hh0 == 4'd9) begin hh0 <= 4'd0; hh1 <= hh1 + 1; end
                        end
                    end else begin mm1 <= mm1 + 1; end
                end else begin mm0 <= mm0 + 1; end
            end else begin ss0 <= ss0 + 1; end
        end
    end
end

// Assign outputs from registers
assign pm = pm_reg;
assign hh = {hh1, hh0};
assign mm = {mm1, mm0};
assign ss = {ss1, ss0};

endmodule
