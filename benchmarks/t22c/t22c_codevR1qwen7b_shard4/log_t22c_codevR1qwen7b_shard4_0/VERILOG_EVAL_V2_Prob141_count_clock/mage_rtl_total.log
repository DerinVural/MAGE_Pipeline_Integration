localparam [7:0] BCD_9 = 4'h9;
localparam [7:0] BCD_59 = {4'h5, 4'h9}; // Minutes and seconds max value
localparam [7:0] BCD_12 = 8'h12;
localparam [7:0] BCD_1 = 8'h01;
localparam [7:0] BCD_0 = 8'h00;

// State flags for AM/PM
localparam PM_OFF = 1'b0;
localparam PM_ON = 1'b1;

// Initialize registers with initial blocks
initial begin
    hh = BCD_12;
    mm = BCD_0;
    ss = BCD_0;
    pm = PM_OFF;
end

// Hours logic
always @(posedge clk) begin
    if (reset) begin
        hh <= BCD_12;
    end else if (ena) begin
        if (ss == BCD_59) begin
            ss <= BCD_0;
            if (mm == BCD_59) begin
