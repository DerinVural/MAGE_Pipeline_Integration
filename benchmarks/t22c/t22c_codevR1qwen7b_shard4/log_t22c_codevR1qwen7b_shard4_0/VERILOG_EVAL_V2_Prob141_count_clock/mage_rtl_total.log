[2026-05-14 13:37:58,633 - mage.rtl_generator - INFO] RTL code: module TopModule (
    input logic clk,
    input logic reset,
    input logic ena,
    output logic pm,
    output logic [7:0] hh,
    output logic [7:0] mm,
    output logic [7:0] ss
);

    // Registers for BCD counters (4 bits per decimal digit)
    logic [3:0] ss_low;
    logic [3:0] ss_high;
    logic [3:0] mm_low;
    logic [3:0] mm_high;
    logic [3:0] hh_low;
    logic [3:0] hh_high;

    // State variables for each counter
    reg [7:0] ss_reg;
    reg [7:0] mm_reg;
    reg [7:0] hh_reg;
    reg pm_reg;

    // Initialize all outputs to known values
    initial begin
        ss_low = 0;
        ss_high = 0;
        mm_low = 0;
        mm_high = 0;
        hh_low = 2;
        hh_high = 1; // 12:00 initial state
        pm_reg = 0; // AM
    end

    // Seconds logic
    always @(posedge clk) begin
        if (reset) begin
            ss_low <= 0;
            ss_high <= 0;
        end else if (ena) begin
            if (ss_low == 9) begin
                ss_low <= 0;
                ss_high <= ss_high + 1;
            end else begin
                ss_low <= ss_low + 1;
            end
        end
    end

    // Minutes logic
    always @(posedge clk) begin
        if (reset) begin
            mm_low <= 0;
            mm_high <= 0;
        end else if (ena && (ss_high == 5 && ss_low == 9)) begin
            if (mm_low == 9) begin
                mm_low <= 0;
                mm_high <= mm_high + 1;
            end else begin
                mm_low <= mm_low + 1;
            end
        end
    end

    // Hours logic
    always @(posedge clk) begin
        if (reset) begin
            hh_high <= 1;
            hh_low <= 2;
            pm_reg <= 0;
        end else if (ena && (mm_high == 5 && mm_low == 9 && ss_high == 5 && ss_low == 9)) begin
            if (hh_high == 1 && hh_low == 2) begin
                // 12 -> 12, PM flips to AM next day?
                if (pm_reg) begin
                    hh_high <= 1;
                    hh_low <= 2;
                    pm_reg <= 0;
                end else begin
                    // Do not change (12:00 PM to 12:00 AM, but per reset? Wait, reset is AM to 12:00. Let's adjust logic.
                    // Wait, after 12:59:59 PM comes 1:00 PM? Wait, the logic should go 12 -> 1, then 12 again at 11:59:59 PM?
                    // Adjust hour rollover logic here.
                    if (hh_high == 1 && hh_low == 1) begin
                        hh_high <= 0;
                        hh_low <= 0;
                    end else if (hh_high == 0) begin
                        if (hh_low == 9) begin
                            hh_high <= 1;
                            hh_low <= 0;
                        end else begin
                            hh_low <= hh_low + 1;
                        end
                    end else if (hh_high == 1) begin
                        if (hh_low == 2) begin
                            hh_high <= 1;
                            hh_low <= 2;
                        end else begin
                            hh_low <= hh_low + 1;
                        end
                    end
                end
            end else begin
                // Increment normally if not 12
                if (hh_low == 9) begin
                    hh_high <= hh_high + 1;
                    hh_low <= 0;
                end else begin
                    hh_low <= hh_low + 1;
                end
            end
        end
    end

    // Assign outputs
    assign ss = {ss_high, ss_low};
    assign mm = {mm_high, mm_low};
    assign hh = {hh_high, hh_low};
