    logic [3:0] mm_units;
    logic [3:0] mm_tens;
    logic [3:0] hh_units;
    logic [3:0] hh_tens;

    // Reset and initial values
    initial begin
        ss_units = 0;
        ss_tens = 0;
        mm_units = 0;
        mm_tens = 0;
        hh_units = 0;
        hh_tens = 1; // Initialize to 1 (for '12')
        pm = 0; // AM initially
    end

    // Assign outputs as 8-bit packed BCD digits (tens and units concatenated)
    assign ss = {ss_tens, ss_units};
    assign mm = {mm_tens, mm_units};
    assign hh = {hh_tens, hh_units};

    // Handle ena increments on posedge clk
    always @(posedge clk) begin
        if (reset) begin
            // Reset to 12:00 AM
            ss_units <= 0;
            ss_tens <= 0;
            mm_units <= 0;
            mm_tens <= 0;
            hh_units <= 0;
            hh_tens <= 1; // Tens is 1 (for 12)
            pm <= 0; // AM
        end
        else if (ena) begin
            // Increment seconds
            if (ss_units == 9) begin
                ss_units <= 0;
                if (ss_tens == 5) begin
                    ss_tens <= 0;
                    // Increment minutes
                    if (mm_units == 9) begin
