                end else if (hh == BCD_00) begin
                    hh <= BCD_12;
                    pm <= PM_OFF;
                end else begin
                    hh <= hh + 1;
                end
            end else begin
                mm <= mm + 1;
            end
        end else begin
            ss <= ss + 1;
        end
    end
end

endmodule
