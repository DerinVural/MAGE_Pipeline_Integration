[2026-05-14 13:34:40,606 - mage.agent - INFO] module TopModule (
    input clk,
    input reset,
    input ena,
    output logic pm,
    output logic [7:0] hh,
    output logic [7:0] mm,
    output logic [7:0] ss
);

    // Split into tens and units for each digit
    logic [3:0] ss_tens, ss_units;
    logic [3:0] mm_tens, mm_units;
    logic [3:0] hh_tens, hh_units;

    // Initialize values to known state
    initial begin
        ss_tens = 0;
        ss_units = 0;
        mm_tens = 0;
        mm_units = 0;
        hh_tens = 1;
        hh_units = 2; // Start at 12
        pm = 0; // AM
    end

    // Update ss every ena pulse
    always_ff @(posedge clk) begin
        if (reset) begin
            ss_tens <= 0;
            ss_units <= 0;
            mm_tens <= 0;
            mm_units <= 0;
            hh_tens <= 1;
            hh_units <= 2;
            pm <= 0;
        end else if (ena) begin
            if (ss_units == 4'h9) begin
                ss_units <= 0;
                if (ss_tens == 4'h5) begin
                    ss_tens <= 0;
                    // Increment mm
                    if (mm_units == 4'h9) begin
                        mm_units <= 0;
                        if (mm_tens == 4'h5) begin
                            mm_tens <= 0;
                            // Increment hh
                            if (hh_tens == 1 && hh_units == 2) begin
                                // 12 -> 12 PM transition
                                hh_tens <= 1;
                                hh_units <= 1;
                                pm <= ~pm;
                            end else if (hh_units == 9) begin
                                hh_tens <= 1;
                                hh_units <= 0;
                            end else if (hh_units == 1 && hh_tens == 1) begin
                                // 11 -> 12
                                hh_tens <= 1;
                                hh_units <= 2;
                                pm <= ~pm;
                            end else begin
                                hh_units <= hh_units + 1;
                            end
                        end else begin
                            mm_tens <= mm_tens + 1;
                        end
                    end else begin
                        mm_units <= mm_units + 1;
                    end
                end else begin
                    ss_tens <= ss_tens + 1;
                end
            end else begin
                ss_units <= ss_units + 1;
            end
        end
    end

    // Combine BCD digits into outputs
    assign hh = {hh_tens, hh_units};
    assign mm = {mm_tens, mm_units};
    assign ss = {ss_tens, ss_units};

endmodule
