    "testbench": "// Testbench for TopModule\n`timescale 1ps/1ps\nmodule tb();\n  reg clk = 0;\n  reg reset;\n  reg ena;\n  wire pm;\n  wire [7:0] hh, mm, ss;\n  // Clock generation\n  always #5 clk = ~clk;\n\n  // Queue parameters for error display\n  localparam MAX_QUEUE_SIZE = 10;\n  reg [2:0] input_queue [0:MAX_QUEUE_SIZE-1]; // Assuming inputs are clk, reset, ena\n  reg [9:0] hh_queue [0:MAX_QUEUE_SIZE-1];\n  reg [9:0] mm_queue [0:MAX_QUEUE_SIZE-1];\n  reg [9:0] ss_queue [0:MAX_QUEUE_SIZE-1];\n  reg pm_queue [0:MAX_QUEUE_SIZE-1];\n  reg [31:0] time_queue [0:MAX_QUEUE_SIZE-1];\n  integer queue_ptr = 0;\n\n  // Error counters\n  integer errors_pm = 0, errors_hh = 0, errors_mm = 0, errors_ss = 0;\n  integer err_time_pm = 0, err_time_hh = 0, err_time_mm = 0, err_time_ss = 0;\n  integer total_errors = 0;\n\n  // Instantiate the DUT\n  TopModule dut (\n    .clk(clk),\n    .reset(reset),\n    .ena(ena),\n    .pm(pm),\n    .hh(hh),\n    .mm(mm),\n    .ss(ss)\n  );\n\n  // Reference module\n  reg pm_ref;\n  reg [7:0] hh_ref, mm_ref, ss_ref;\n\n  always @(posedge clk) begin\n    // Reset handling and reference logic\n    if (reset) begin\n      pm_ref <= 0;\n      hh_ref <= 8'h12; // 12 in BCD\n      mm_ref <= 0;\n      ss_ref <= 0;\n    end else if (ena) begin\n      // BCD increment logic for seconds, minutes, hours\n      // Seconds\n      if (ss_ref == 8'h59) begin\n        ss_ref <= 8'h00;\n        // Minutes\n        if (mm_ref == 8'h59) begin\n          mm_ref <= 8'h00;\n          // Hours\n          if (hh_ref == 8'h12 && pm_ref) begin\n            hh_ref <= 8'h12; // 12-hour wrap\n            pm_ref <= 0;\n          end else if (hh_ref == 8'h11) begin\n            hh_ref <= (pm_ref) ? 8'h12 : 8'h1;\n            pm_ref <= ~pm_ref;\n          end else if (hh_ref == 8'h00) begin\n            hh_ref <= 8'h12;\n            pm_ref <= 0;\n          end else begin\n            hh_ref <= (hh_ref[7:4] == 4'h1 && hh_ref[3:0] == 4'h2) ? 8'h1 : {hh_ref[7:4], hh_ref[3:0] + 1};\n          end\n        end else begin\n          mm_ref <= mm_ref + 1;\n        end\n      end else begin\n        ss_ref <= ss_ref + 1;\n      end\n    end\n  end\n\n  // Error checking\n  always @(posedge clk) begin\n    // BCD validity check for hh, mm, ss\n    if (hh_queue.size() >= MAX_QUEUE_SIZE) begin\n      hh_queue.delete(0);\n      mm_queue.delete(0);\n      ss_queue.delete(0);\n      pm_queue.delete(0);\n      time_queue.delete(0);\n    end\n    hh_queue.push_back(hh);\n    mm_queue.push_back(mm);\n    ss_queue.push_back(ss);\n    pm_queue.push_back(pm);\n    time_queue.push_back($time);\n\n    // Check PM validity (AM/PM should be either 0 or 1)\n    if (pm !== (pm_ref)) begin\n      if (errors_pm == 0) begin\n        $display(","Mismatch detected at time %0d: PM mismatch. Expected %b, got %b\nCurrent state: %0d %0d %0d %b\nFirst error at time %0d\nSIMULATION FAILED - 1 MISMATCHES DETECTED, FIRST AT TIME %0d\n        errors_pm = 1;\n        err_time_pm = $time;\n      end\n      total_errors++;\n    end\n    // Similar checks for hh, mm, ss BCD digits\n    // Check each BCD digit for hh, mm, ss\n    // Each BCD digit is 4 bits; values must be 0-9\n    // For hh: 01-12 in two digits\n    // hh[7:4] is tens digit (0-1), hh[3:0] is ones (0-9 or 2 for 12?)\n    // Assume hh is in BCD format: 0x1 0x2 to 12: 01, 12, etc.\n    // For each digit (tens and ones), check if >= 10\n    if (hh_queue[0][7:4] >= 4'd10 || hh_queue[0][3:0] >=4'd10) begin\n      if (errors_hh == 0) begin\n        $display("         		 	:               	", "           	                          		, "hh[7:4]=%d >=10 or hh[3:0]=%d >=10 at %0d\n         ,$time ,hh_queue[0][7:4], hh_queue[0][3:0], $time);\n        errors_hh = 1;\n        err_time_hh = $time;\n      end\n      total_errors++;\n    end\n    // Similar checks for mm and ss (00-59)\n    if (mm_queue[0][7:4] >=4'd6 || mm_queue[0][3:0] >=4'd10) begin\n      if (errors_mm ==0) ... \n    end\n  end\n\n  // Display simulation result