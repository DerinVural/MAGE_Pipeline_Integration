    logic [2:0] prev_state;

    // Initialize state and prev_state
    initial begin
        state = STATE_A;
        prev_state = STATE_A;
    end

    // State transitions
    always @(posedge clk) begin
        if (reset) begin
            state <= STATE_A;
            prev_state <= STATE_A;
        end else begin
            prev_state <= state;
            state <= next_state;
        end
    end

    // Next state logic
    always @(*) begin
        next_state = state;
        case (state)
