    always_comb begin
        case (addr) 
            3'b000: selected_bit = Q[0];
            3'b001: selected_bit = Q[1];
            3'b010: selected_bit = Q[2];
            3'b011: selected_bit = Q[3];
            3'b100: selected_bit = Q[4];
            3'b101: selected_bit = Q[5];
            3'b110: selected_bit = Q[6];
            3'b111: selected_bit = Q[7];
            default: selected_bit = 1'bx; // Should not happen
        endcase
    end

    assign Z = selected_bit;
