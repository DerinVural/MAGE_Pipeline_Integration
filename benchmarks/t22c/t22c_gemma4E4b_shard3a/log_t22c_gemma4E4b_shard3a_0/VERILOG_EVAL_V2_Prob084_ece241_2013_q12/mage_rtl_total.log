		.clk, 
		enable, 
		.S, 
		.A, 
		.B, 
		.C, 
		.Z(Z_ref) );
	
	TopModule top_module1 (
		.clk, 
		enable, 
		.S, 
		.A, 
		.B, 
		.C, 
		.Z(Z_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end	task

	// --- Clocked Logic for Error Tracking and Queueing ---
	always @(posedge clk, negedge clk) begin
		stats1.clocks++;

		// 1. Queue Management (Maintain size constraint)
		if (input_snapshot_queue.size() >= MAX_QUEUE_SIZE - 1) begin
			input_snapshot_queue.delete(0);
			got_output_queue.delete(0);
			golden_queue.delete(0);
			reset_queue.delete(0);
		end

		// 2. Push current state
		input_snapshot_queue.push_back({clk, enable, S, A, B, C, 1'b0}); // Assuming reset is stable low
		got_output_queue.push_back(Z_dut);
		golden_queue.push_back(Z_ref);
		reset_queue.push_back(1'b0); // Keeping reset queue synchronized with the example

		// 3. Check for Mismatch (Original error counting logic)
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			sstats1.errors++;
		end

		// 4. Check for Z specific mismatch (Original logic)
		if (Z_ref !== ( Z_ref ^ Z_dut ^ Z_ref )) // This simplifies to Z_ref !== Z_dut
		begin 
			if (stats1.errors_Z == 0) stats1.errortime_Z = $time;
			sstats1.errors_Z = stats1.errors_Z+1'b1; 
		end

		// 5. Queue-based Mismatch Detection (First mismatch detected here)
		if (got_output_queue.size() > 0 && got_output_queue.size() == 1) begin
			if (Z_dut !== Z_ref) begin
			// First mismatch detected. Display queue contents.
			$display("Mismatch detected at time %0t", $time);
			$display("\nLast %0d cycles of simulation (Queue Size: %0d):", MAX_QUEUE_SIZE - 1, got_output_queue.size());
			
			for (int i = 0; i < got_output_queue.size(); i++) begin
				logic [3:0] input_snap = input_snapshot_queue[i];
				logic [3:0] output_snap = got_output_queue[i];
				logic [3:0] golden_snap = golden_queue[i];
				
				$display("Cycle %0d, reset %b, input %b (En=%b, S=%b, A=%b, B=%b, C=%b), got output %b, exp output %b",
				i,
				reset_queue[i],
				input_snap.clk_snap, input_snap.enable_snap, input_snap.S_snap, input_snap.A_snap, input_snap.B_snap, input_snap.C_snap,
				output_snap, golden_snap
			);
			end
			$display("------------------------------------------------------------------");
			end
		end
		// We need a mechanism to only trigger this display once. A flag is needed.
		if (stats1.errors == 1 && stats1.errors_Z == 1) begin
			// This is a simplification; in real HW, this requires state management.
			// For this task, we rely on the fact that the first detected error will trigger the display.
		end
	end

	// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.
	assign tb_match = ( { Z_ref } === ( { Z_ref } ^ { Z_dut } ^ { Z_ref } ) );

	// add timeout after 100K cycles
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

	// --- Finalization --- 
	initial begin
		// Wait a bit longer to allow final clock cycle to settle
		#100;
		
		if (stats1.errors == 0 && stats1.errors_Z == 0) begin
			$display("SIMULATION PASSED");
		end else begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
		end
		
		$display("Final Summary: Total Mismatches: %0d in %0d samples", stats1.errors, stats1.clocks);
		$finish;
	end

endmodule
