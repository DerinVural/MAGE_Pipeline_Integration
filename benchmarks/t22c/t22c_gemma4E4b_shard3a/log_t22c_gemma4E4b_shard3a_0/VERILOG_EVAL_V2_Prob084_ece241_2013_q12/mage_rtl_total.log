	// We must include all inputs used by the DUT for a complete state snapshot.
	typedef struct packed { 
	    logic clk_snap;
	    logic enable_snap;
	    logic S_snap;
	    logic A_snap;
	    logic B_snap;
	    logic C_snap;
	    logic reset_snap; // Used to match example structure
	} input_snapshot_t;
	
	input_snapshot_t input_snapshot_queue [$];
	
