module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_Z;
		int errortime_Z;
		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		h#5 clk = ~clk;

	logic enable;
	logic S;
	logic A;
	logic B;
	logic C;
	logic Z_ref;
	logic Z_dut;

	// --- Queue Definition for Sequential Logic Check ---
	// Since Z is 1 bit, we track 1 bit data. MAX_QUEUE_SIZE <= 10.
	reg input_queue [$];
	reg got_output_queue [$];
	reg golden_queue [$];	
	localparam MAX_QUEUE_SIZE = 10;
	reg reset_queue [$];

