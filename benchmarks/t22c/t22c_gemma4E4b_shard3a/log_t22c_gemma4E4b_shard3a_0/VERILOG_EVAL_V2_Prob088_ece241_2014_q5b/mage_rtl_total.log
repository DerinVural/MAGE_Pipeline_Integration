// --- Stimulus Generator (Copied from Golden TB) ---
module stimulus_gen (
	input clk,
	output logic x,
	output logic areset,
	output reg[511:0] wavedrom_title,
	output reg wavedrom_enable,
	input tb_match
);
	reg reset;
	assign areset = reset;

// Add two ports to module stimulus_gen:
//    output [511:0] wavedrom_title
//    output reg wavedrom_enable

	task wavedrom_start(input[511:0] title = "");
	endtask
	
	task wavedrom_stop;
		#1;
	endtask	

	task reset_test(input async=0);
		bit arfail, srfail, datafail;
		
		@(posedge clk);
		@(posedge clk) reset <= 0;
		repeat(3) @(posedge clk);
		
		@(negedge clk) begin datafail = !tb_match ; reset <= 1; end
		@(posedge clk) arfail = !tb_match;
		@(posedge clk) begin
		srfail = !tb_match;
		reset <= 0;
		end
		if (srfail)
			$display("Hint: Your reset doesn't seem to be working.");
		else if (arfail && (async || !datafail))
			$display("Hint: Your reset should be %0s, but doesn't appear to be.", async ? "asynchronous" : "synchronous");
		// Don't warn about synchronous reset if the half-cycle before is already wrong. It's more likely
		// a functionality error than the reset being implemented asynchronously.
	endtask

	initial begin
		x <= 0;
		reset <= 1;
		@(posedge clk) reset <= 0; x <= 1;
		@(posedge clk) x <= 0;
		reset_test(1);
		
		@(negedge clk) wavedrom_start();
			@(posedge clk) {reset,x} <= 2'h2;
			@(posedge clk) {reset,x} <= 2'h0;
			@(posedge clk) {reset,x} <= 2'h0;
			@(posedge clk) {reset,x} <= 2'h1;
			@(posedge clk) {reset,x} <= 2'h0;
			@(posedge clk) {reset,x} <= 2'h1;
			@(posedge clk) {reset,x} <= 2'h1;
			@(posedge clk) {reset,x} <= 2'h0;
			@(posedge clk) {reset,x} <= 2'h0;
		@(negedge clk) wavedrom_stop();
		repeat(400) @(posedge clk, negedge clk)
			{reset,x} <= {($random&31) == 0, ($random&1)==0 };

		$finish;
	end
	
endmodule

// --- Reference Module (Assuming implementation exists for comparison) ---
module RefModule (
    input clk,
    input areset,
    input x,
    output z
);
    // Dummy implementation for compilation/testing structure adherence
    reg z_ref;
    always @(posedge clk or posedge areset) begin
        if (areset) begin
            z_ref <= 1'b0;
        end else begin
            // Placeholder logic
            z_ref <= x;
        end
    end
    assign z = z_ref;
endmodule

// --- DUT Module (Must be implemented based on specification) ---
module TopModule (
    input clk,
    input areset,
    input x,
    output z
);
    // FSM Implementation for 2's Complementer using One-Hot Encoding

    // State definitions: A (00), B (01) - Since one-hot is required, we use 2 bits max, though only 2 states exist.
    // Let's use 2 bits to represent 2 states (A and B) as one-hot, where one bit is high for the active state.
    // State A: SA=1, SB=0
    // State B: SA=0, SB=1
    reg sa, sb;

    // State registers (Sequential logic on posedge clk)
    always @(posedge clk or posedge areset) begin
        if (areset) begin
            sa <= 1'b1; // Reset to State A
            sb <= 1'b0;
        end else begin
            case ({sa, sb}) 
                2'b10: begin // State A
                    if (x == 0) begin
                        // A --x=0 (z=0)--> A
                        sa <= 1'b1; sb <= 1'b0;
                    end else begin
                        // A --x=1 (z=1)--> B
                        sa <= 1'b0; sb <= 1'b1;
                    end
                end
                2'b01: begin // State B
                    if (x == 0) begin
                        // B --x=0 (z=1)--> B
                        sa <= 1'b0; sb <= 1'b1;
                    end else begin
                        // B --x=1 (z=0)--> B
                        sa <= 1'b0; sb <= 1'b1;
                    end
                end
                default: begin
                    sa <= 1'b1; sb <= 1'b0; // Safety fallback to A
                end
            endcase
        end
    end

    // Output logic (Mealy: depends on current state and input x)
    reg z_out;
    always @(*) begin
        if (sa && !sb) begin // State A
            if (x == 0) begin // A --x=0 (z=0)--> A
                z_out = 1'b0;
            end else begin // A --x=1 (z=1)--> B
                z_out = 1'b1;
            end
        end else if (!sa && sb) begin // State B
            if (x == 0) begin // B --x=0 (z=1)--> B
                z_out = 1'b1;
            end else begin // B --x=1 (z=0)--> B
                z_out = 1'b0;
            end
        end else begin
            // Should not happen if reset works, default to 0
            z_out = 1'b0;
        end
    end

    assign z = z_out;
endmodule

// --- Testbench (Improved Golden Testbench) ---
module tb();

    // --- Queue Definitions (Sequential Logic Handling) ---
    // Inputs: areset, x
    // Outputs: z_dut
    // Golden: z_ref

    // MAX_QUEUE_SIZE <= 10
    localparam MAX_QUEUE_SIZE = 10;

    reg areset_queue [MAX_QUEUE_SIZE-1:0];
    reg x_queue [MAX_QUEUE_SIZE-1:0];
    reg z_dut_queue [MAX_QUEUE_SIZE-1:0];
    reg z_ref_queue [MAX_QUEUE_SIZE-1:0];

    // Error tracking variables (Retaining original functionality)
    typedef struct packed {
        int errors;
        int errortime;
        int errors_z;
        int errortime_z;
        int clocks;
    } stats;
    
    stats stats1;
    
    // --- Signals from Golden TB ---
    wire[511:0] wavedrom_title;
    wire wavedrom_enable;
    int wavedrom_hide_after_time;
    
    reg clk=0;
    initial forever
        #5 clk = ~clk;

    logic areset;
    logic x;
    logic z_ref;
    logic z_dut;

    // --- Verification Logic ---
    wire tb_match;       // Verification
    wire tb_mismatch = ~tb_match;
    
    // --- Instantiations (Maintaining Golden TB structure) ---
    stimulus_gen stim1 (
        .clk, .areset, .x, .wavedrom_title, .wavedrom_enable, .tb_match
    );
    RefModule good1 (
        .clk, .areset, .x, .z(z_ref) 
    );
    TopModule top_module1 (
        .clk, .areset, .x, .z(z_dut) 
    );

    // --- Control Signals ---
    bit strobe = 0;
    
    // Task to delay until the end of the time step
    task wait_for_end_of_timestep;
        repeat(5) begin
            strobe <= !strobe;  // Try to delay until the very end of the time step.
            @(strobe);
        end
    endtask

    // --- Mismatch Detection and Queue Logic (Improved) ---
    always @(posedge clk or negedge clk) begin
        if (!areset) begin // Assuming asynchronous reset on TB signals
             // Initialization or handling of reset cycle
        end else begin

            // 1. Shift Queue
            for (int i = MAX_QUEUE_SIZE - 1; i > 0; i--) begin
                areset_queue[i] = areset_queue[i-1];
                x_queue[i] = x_queue[i-1];
                z_dut_queue[i] = z_dut_queue[i-1];
                z_ref_queue[i] = z_ref_queue[i-1];
            end

            // 2. Push Current Values (at the current time step)
            areset_queue[0] = areset;
            x_queue[0] = x;
            z_dut_queue[0] = z_dut;
            z_ref_queue[0] = z_ref;

            // 3. Update Counters (Original Logic)
            stats1.clocks++;
            if (!tb_match) begin
                if (stats1.errors == 0) stats1.errortime = $time;
                stats1.errors++;
            end
            if (z_ref !== ( z_ref ^ z_dut ^ z_ref )) // Original check for z mismatch
            begin if (stats1.errors_z == 0) stats1.errortime_z = $time;
                stats1.errors_z = stats1.errors_z+1'b1; end
            end

            // 4. Check for First Mismatch using Queue State
            // We check the most recent cycle (index 0) for mismatch.
            if (z_dut !== z_ref) begin
                // Check if this is the very first mismatch detected overall
                if (stats1.errors == 1) begin
                    $display("==============================================================================");
                    $display("Mismatch detected at time %0t", $time);
                    $display("\nLast %0d cycles (up to MAX_QUEUE_SIZE) of simulation:", MAX_QUEUE_SIZE);

                    // Display Queue Content
                    for (int i = 0; i < MAX_QUEUE_SIZE; i++) begin
                        // Display logic matching requirements (HEX/BIN for multi-bit, though here all are 1-bit)
                        $display("Cycle %0d, reset %b, input x: %b (0x%h), got z_dut: %b (0x%h), exp z_ref: %b (0x%h)",
                            i,
                            areset_queue[i],
                            x_queue[i],
                            x_queue[i], // Single bit displayed as hex
                            z_dut_queue[i],
                            z_dut_queue[i],
                            z_ref_queue[i],
                            z_ref_queue[i]
                        );
                    end
                    $display("==============================================================================");
                end
            end
        end
    end

    // --- Verification Assignment (Maintaining Original Logic) ---
    // Note: The original TB used a complex XOR logic. We maintain it exactly.
    assign tb_match = ( { z_ref } === ( { z_ref } ^ { z_dut } ^ { z_ref } ) );

    // --- Finalization Block (Improved) ---
    final begin
        // Original functionality display
        if (stats1.errors_z) $display("Hint: Output 'z' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_z, stats1.errortime_z);
        else $display("Hint: Output 'z' has no mismatches.");

        // New final summary display
        if (stats1.errors == 0) begin
            $display("SIMULATION PASSED");
        end else begin
            $display("SIMULATION FAILED - x MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errortime);
        end
        
        $display("\nTotal mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
        $display("Simulation finished at %0d ps", $time);
        $display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
    end
    
    // --- Timeout ---
    initial begin
     #1000000
     $display("TIMEOUT");
     $finish();
    end

endmodule

