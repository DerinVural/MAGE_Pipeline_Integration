Try to delay until the very end of the time step.\n118: \t\t@(strobe);\n119: \t\tendtask\n120: \n121: \n122: \t// Helper function to display signals in HEX and BIN if width <= 64\t\n123: \ttask display_signals;\n124: \t\tinput string label;\n125: \t\tinput logic [511:0] signal;\n126: \t\tinput string type;\n127: \t\tbegin\n128: \t\t\t$write("\\n--- Signal Dump: %s at time %0t ---\\n", label, $time);\n129: \t\t\t$write("| %s | %h | %b |\n130: ", type, signal, signal);\n131: \t\tend\n132: \tendtask\n133: \n134: \t// Overload for single bits\n135: \ttask display_signals_1bit;\n136: \t\tinput string label;\n137: \t\tinput logic signal;\n138: \t\tbegin\n139: \t\t\t$write("\\n--- Signal Dump: %s at time %0t ---\\n", label, $time);\n140: \t\t\t$write("| %s | %b |\n141: ", label, signal);\n142: \t\tend\n143: \tendtask\n144: \n145: \t// Function to handle display logic\n146: \tfunction void display_signal_formatted(input string name, input logic signal, input logic [9:0] data_sig, input logic tc_sig, input logic [511:0] wavedrom_sig);\n147: \t\tbegin\n148: \t\t\tdisplay_signals_1bit(name + "_load", signal);\n149: \t\t\tdisplay_signals_1bit(name + "_tc_ref", tc_sig);\n150: \t\t\tdisplay_signals_1bit(name + "_tc_dut", tc_sig);\n151: \t\t\tdisplay_signals_1bit(name + "_tb_match", signal);\n152: \t\t\tdisplay_signals_1bit(name + "_tb_mismatch", signal);\n153: \t\t\tdisplay_signals_1bit(name + "_clk", signal);\n154: \t\t\tdisplay_signals_1bit(name + "_data", data_sig);\n155: \t\t\tdisplay_signals_1bit(name + "_wavedrom_title", wavedrom_sig);\n156: \t\tend\n157: \tendfunction\n158: \n159: \t\n160: \t\t// Initialize stats\n161: \t\tstats1 = \'{errors: 0, errortime: 0, errors_tc: 0, errortime_tc: 0, clocks: 0};\n162: \t\n163: \t\t// Store context for first mismatch\n164: \t\tlogic [9:0] first_mismatch_data_ref = 0;\n165: \t\tlogic [9:0] first_mismatch_data_dut = 0;\n166: \t\tlogic first_mismatch_tc_ref = 0;\n167: \t\tlogic first_mismatch_tc_dut = 0;\n168: \t\t\n169: \t\t// Main clock/verification loop\n170: \t\talways @(posedge clk)\n171: \t\tbegin\n172: \t\t\tstats1.clocks++;\n173: \n174: \t\t\t// Check main match (tb_match logic)\n175: \t\t\tif (!tb_match) begin\n176: \t\t\t\tif (stats1.errors == 0) stats1.errortime = $time;\n177: \t\t\t\tstats1.errors++;\n178: \t\t\t\t\n179: \t\t\t\t// Log first mismatch details\n180: \t\t\t\tif (stats1.errors == 1) begin\n181: \t\t\t\t\t$display("\\n========================================================================");\n182: \t\t\t\t\t$display("!!! FIRST MISMATCH DETECTED !!!");\n183: \t\t\t\t\t$display("Time: %0t ps", $time);\n184: \t\t\t\t\t$display("------------------------------------------------------------------------");\n185: \t\t\t\t\t$display("--- Inputs ---");\n186: \t\t\t\t\tdisplay_signals_1bit("INPUT_clk", clk, data, tc_ref, wavedrom_title);\n187: \t\t\t\t\t$write("| load | %b | data | %h | %b |\n188: ", load, data, data);\n189: \t\t\t\t\t$write("| tb_match | %b | tb_mismatch | %b |\n190: ", tb_match, tb_mismatch);\n191: \t\t\t\t\t$display("--- Outputs (DUT/REF) ---");\n192: \t\t\t\t\tdisplay_signals_1bit("OUTPUT_tc_ref", tc_ref);\n193: \t\t\t\t\tdisplay_signals_1bit("OUTPUT_tc_dut", tc_dut);\n194: \t\t\t\t\t$display("========================================================================\\n");\n195: \t\t\t\tend\n196: \t\t\t\t// Store data for subsequent error logging if needed (though requirement only asks for first error details)\n197: \t\t\tif (stats1.errors == 1) begin\n198: \t\t\t\t\tfirst_mismatch_data_ref = data;\n199: \t\t\t\t\tfirst_mismatch_data_dut = data;\n200: \t\t\t\t\tfirst_mismatch_tc_ref = tc_ref;\n201: \t\t\t\t\tfirst_mismatch_tc_dut = tc_dut;\n202: \t\t\t\tend\n203: \t\t\tend\n204: \n205: \t\t// Check specific TC mismatch\n206: \t\t\tif (tc_ref !== tc_dut) begin\n207: \t\t\tif (stats1.errors_tc == 0) stats1.errortime_tc = $time;\n208: \t\t\tstats1.errors_tc++;\n209: \t\t\tend\n210: \t\t\t\n211: \t\t\t// Detailed logging for TC mismatch (if it is the first one)\n212: \t