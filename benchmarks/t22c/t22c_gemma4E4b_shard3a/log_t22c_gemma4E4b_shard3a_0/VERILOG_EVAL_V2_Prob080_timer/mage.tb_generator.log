6: \n37: endmodule\n\n</previous_code>\n<previous_tb>\n1: `timescale 1 ps/1 ps\n2: `define OK 12\n3: `define INCORRECT 13\n4: \n5: module stimulus_gen(\n6: \tinput clk,\n7: \toutput logic load,\n8: \toutput logic [9:0] data,\n9: \tinput tb_match,\n10: \toutput logic [511:0] wavedrom_title,\n11: \toutput logic wavedrom_enable,\n12: \toutput int wavedrom_hide_after_time\n13: );\n14: \n15: \n16: \ttask wavedrom_start(input[511:0] title = "");\n17: endtask\n18: \t\n19: \ttask wavedrom_stop;\n20: \t\th#1;\n21: \tendtask\t\n22: \t\n23: \tinitial begin\n24: \t\tload <= 1\'b0;\n25: \t\twavedrom_start("Count 3, then 10 cycles");\n26: \t\t@(posedge clk) {data, load} <= {10\'d3, 1\'b1};\n27: \t\t@(posedge clk) {data, load} <= {10\'hx, 1\'b0};\n28: \t\t@(posedge clk) load <= 0;\n29: \t\t@(posedge clk) load <= 0;\n30: \t\t@(posedge clk) load <= 0;\n31: \t\t@(posedge clk) {data, load} <= {10\'d10, 1\'b1};\n32: \t\t@(posedge clk) {data, load} <= {10\'hx, 1\'b0};\n33: \t\trepeat(12) @(posedge clk);\n34: \t\twavedrom_stop();\n35: \n36: \t\t@(posedge clk) {load, data} <= {1\'b1, 10\'h10};\n37: \t\t@(posedge clk) {load, data} <= {1\'b0, 10\'h10};\n38: \t\t@(posedge clk) {load, data} <= {1\'b1, 10\'h0};   // Load 0\n39: \t\t@(posedge clk) {load, data} <= {1\'b1, 10\'h3ff}; // Load 1023\n40: \t\t@(posedge clk) {load, data} <= {1\'b0, 10\'h0};\n41: \t\trepeat(1040) @(posedge clk);\n42: \n43: \t\trepeat(2500) @(posedge clk) begin\n44: \t\tload <= !($urandom & 10\'hf);\n45: \t\tdata <= $urandom_range(0,32);\n46: \t\tend\n47: \n48: \t\t#1 $finish;\n49: \tend\n50: \n51: endmodule\n52: module tb();\n53: \n54: \t// Define statistics structure\n55: \ttypedef struct packed {\n56: \t\tint errors;\n57: \t\tint errortime;\n58: \t\tint errors_tc;\n59: \t\tint errortime_tc;\n60: \t\tint clocks;\n61: \t} stats;\n62: \t\n63: \tstats stats1;\n64: \t\n65: \t\n66: \twire[511:0] wavedrom_title;\n67: \twire wavedrom_enable;\n68: \tint wavedrom_hide_after_time;\n69: \t\n70: \treg clk=0;\n71: \tinitial foreve