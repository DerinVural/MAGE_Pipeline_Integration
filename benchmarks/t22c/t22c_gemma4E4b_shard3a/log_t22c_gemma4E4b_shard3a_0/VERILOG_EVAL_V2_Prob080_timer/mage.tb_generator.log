ime;\n\t\t\ttotal_errors++;\n\t\tend\n\n\t\t// Specific TC error counting\n\t\tif (tc_ref !== tc_dut) begin\n\t\t\tif (tc_errors == 0) first_tc_error_time = $time;\n\t\t\ttc_errors++;\n\t\tend\n\tend\n\n\t// --- Final Reporting --- \n\tfinal begin\n\t\tif (tc_errors > 0) begin\n\t\t\t$display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\", tc_errors, first_tc_error_time);\n\t\t\t$display(\"Detailed TC Mismatch Log:\");\n\t\t\tfor (int i = 0; i < input_data_queue.size(); i++) begin\n\t\t\t\t$display(\"Cycle %d, Input Data: %h, Ref TC: %b, Got TC: %b\",\n\t\t\t\ti, input_data_queue[i], tc_ref_queue[i], tc_dut_queue[i]);\n\t\t\tend\n\t\tend\n\t\t\n\t\tif (total_errors > 0) begin\n\t\t\t$display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\", total_errors, first_error_time);\n\t\t\tend\n\t\t\n\t\tif (total_errors == 0 && tc_errors == 0) begin\n\t\t\t$display(\"SIMULATION PASSED\");\n\t\tend\n\t\t$display(\"Simulation finished at %0d ps\", $time);\n\tend\n\n\t// add timeout after 100K cycles\n\tinitial begin\n\t\t#1000000\n\t\t$display(\"TIMEOUT\");\n\t\t$finish();\n\tend\n\nendmodule"
