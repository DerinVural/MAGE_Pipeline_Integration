	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic load;
	logic [9:0] data;
	logic tc_ref;
	logic tc_dut;

	// --- Queue Declarations for improved logging ---
	localparam MAX_QUEUE_SIZE = 11; // Sufficient for 10-bit counter + safety
	
	reg [9:0] input_data_queue [$]; // Data input
	reg load_queue [$];             // Load input
	reg tc_ref_queue [$];           // Reference output
	reg tc_dut_queue [$];           // DUT output
	reg tb_match_queue [$];         // Match status
	
	// For tracking error time and count as per original logic
	int total_errors = 0;
	int first_error_time = 0;
	int tc_errors = 0;
	int first_tc_error_time = 0;
	
	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,clk,load,data,tc_ref,tc_dut );
	end


	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk, 
		.* , 
		.load, 
		.data );
	RefModule good1 (
		.clk, 
		.load, 
		.data,
		.tc(tc_ref) );
	
	TopModule top_module1 (
		.clk,
		.load,
		.data,
		.tc(tc_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end	task


	// --- Queue and Mismatch Detection Logic (Clocked) ---
	always @(posedge clk, negedge clk) begin
		
		stats1.clocks++;
		
		// Queue management: Keep size <= MAX_QUEUE_SIZE - 1
		if (input_data_queue.size() >= MAX_QUEUE_SIZE - 1) begin
			input_data_queue.delete(0);
			load_queue.delete(0);
			tc_ref_queue.delete(0);
			tc_dut_queue.delete(0);
			tb_match_queue.delete(0);
		end

		// Store current state
		input_data_queue.push_back(data);
		load_queue.push_back(load);
		tc_ref_queue.push_back(tc_ref);
		tc_dut_queue.push_back(tc_dut);
		
		// Check for mismatch (Original condition: tc_ref !== tc_dut)
		tb_match = ( { tc_ref } === ( { tc_ref } ^ { tc_dut } ^ { tc_ref } ) );
		tb_match_queue.push_back(tb_match);

		// Error counting based on original logic
		if (!tb_match) begin
			if (total_errors == 0) total_errors = 1; // Flag first error occurrence
			first_error_time = $time;
			total_errors++;
		end

		// Specific TC error counting
		if (tc_ref !== tc_dut) begin
			if (tc_errors == 0) first_tc_error_time = $time;
			tc_errors++;
		end
	end

	// --- Final Reporting --- 
	final begin
		if (tc_errors > 0) begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", tc_errors, first_tc_error_time);
			$display("Detailed TC Mismatch Log:");
			for (int i = 0; i < input_data_queue.size(); i++) begin
				$display("Cycle %d, Input Data: %h, Ref TC: %b, Got TC: %b",
				i, input_data_queue[i], tc_ref_queue[i], tc_dut_queue[i]);
			end
		end
		
		if (total_errors > 0) begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", total_errors, first_error_time);
			end
		
		if (total_errors == 0 && tc_errors == 0) begin
			$display("SIMULATION PASSED");
		end
		$display("Simulation finished at %0d ps", $time);
	end

	// add timeout after 100K cycles
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

endmodule
