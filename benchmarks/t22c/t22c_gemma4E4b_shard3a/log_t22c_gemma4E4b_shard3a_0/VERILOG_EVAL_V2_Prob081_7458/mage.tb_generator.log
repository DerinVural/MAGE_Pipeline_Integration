tats1.errors_p2y + 1'b1;\n\t\tend\n\t\tend\n\n\t// --- Simulation Control and Final Reporting ---\n\n\tinitial begin \n\t\t$dumpfile(\"wave.vcd\");\n\t\t// Updated dumpvars to include all relevant signals\n\t\t$dumpvars(1, stim1.clk, tb_mismatch, p1a,p1b,p1c,p1d,p1e,p1f,p2a,p2b,p2c,p2d,p1y_ref,p1y_dut,p2y_ref,p2y_dut);\n\t\t\n\t\t// Initial state logging (Optional but good practice)\n\t\t$display(\"--- Starting Simulation ---\");\n\t\tend\n\n\t// Task to report the first mismatch details when an error is detected\n\ttask report_current_state;\n\t\tbegin\n\t\t\t// Inputs\n\t\t\tdisplay_inputs(\"P_IN\", {p1a,p1b,p1c,p1d,p1e,p1f,p2a,p2b,p2c,p2d}, {p1a,p1b,p1c,p1d,p1e,p1f,p2a,p2b,p2c,p2d});\n\t\t\t// Outputs\n\t\t\t$display(\"Output Signals: DUT = %h (%b) | Expected = %h (%b)\", p1y_dut, p1y_dut, p1y_ref, p1y_ref);\n\t\t\t$display(\"Output Signals: DUT = %h (%b) | Expected = %h (%b)\", p2y_dut, p2y_dut, p2y_ref, p2y_ref);\n\t\tend\n\tendtask\n\n\t// Overriding the error detection logic to call the detailed report when first error occurs\n\talways @(posedge clk, negedge clk) begin\n\t\tstats1.clocks++;\n\t\t\n\t\t// Check overall mismatch\n\t\tif (!tb_match) begin\n\t\t\tif (stats1.errors == 0) begin\n\t\t\tstats1.errortime = $time;\n\t\t\treport_current_state(); // Report detailed state on first error\n\t\t\tend\n\t\t\tstats1.errors++;\n\t\tend\n\t\t\n\t\t// Check p1y mismatch\n\t\tif (p1y_ref !== ( p1y_ref ^ p1y_dut ^ p1y_ref ))\n\t\tbegin \n\t\t\tif (stats1.errors_p1y == 0) begin\n\t\t\tstats1.errortime_p1y = $time;\n\t\t\treport_current_state(); // Report detailed state on first error\n\t\t\tend\n\t\t\tstats1.errors_p1y = stats1.errors_p1y + 1'b1;\n\t\tend\n\t\t\n\t\t// Check p2y mismatch\n\t\tif (p2y_ref !== ( p2y_ref ^ p2y_dut ^ p2y_ref ))\n\t\tbegin \n\t\t\tif (stats1.errors_p2y == 0) begin\n\t\t\tstats1.errortime_p2y = $time;\n\t\t\treport_current_state(); // Report detailed state on first error\n\t\t\tend\n\t\t\tstats1.errors_p2y = stats1.errors_p2y + 1'b1;\n\t\