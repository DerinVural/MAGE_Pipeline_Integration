e;\n\t\t\tstats1.errors++;\n\t\t\t\n\t\t\t// Check p1y mismatch\n\t\t\tif (p1y_ref !== p1y_dut) begin\n\t\t\t\tif (stats1.errors_p1y == 0) stats1.errortime_p1y = $time;\n\t\t\t\tstats1.errors_p1y = stats1.errors_p1y + 1\'b1;\n\t\t\tend\n\t\t\t// Check p2y mismatch\n\t\t\tif (p2y_ref !== p2y_dut) begin\n\t\t\t\tif (stats1.errors_p2y == 0) stats1.errortime_p2y = $time;\n\t\t\t\tstats1.errors_p2y = stats1.errors_p2y + 1\'b1;\n\t\t\tend\n\t\tend\n\tend\n\n\t// Clocked update for statistics and state capture (to synchronize with clocking events)\n\talways @(posedge clk)\n\tbegin\n\t\tstats1.clocks++;\n\t\t// Since it\'s combinational, we capture the inputs and outputs that caused the mismatch\n\t\t// We update the stored values on every clock edge to represent the state *after* inputs have settled\n\t\tinput_data_storage = {p1a, p1b, p1c, p1d, p1e, p1f, p2a, p2b, p2c, p2d};\n\t\toutput_data_storage = {p1y_dut, p2y_dut};\n\t\tgolden_output_storage = {p1y_ref, p2y_ref};\n\tend\n\n\tfinal begin\n\t\tif (stats1.errors_p1y) $display("Hint: Output \'p1y\' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_p1y, stats1.errortime_p1y);\n\t\telse $display("Hint: Output \'p1y\' has no mismatches.");\n\t\tif (stats1.errors_p2y) $display("Hint: Output \'p2y\' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_p2y, stats1.errortime_p2y);\n\t\telse $display("Hint: Output \'p2y\' has no mismatches.");\n\n\t\tif (stats1.errors == 0) begin\n\t\t\ts$display("SIMULATION PASSED");\n\t\tend else begin\n\t\t\ts$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);\n\t\tend\n\t\t$display("Total mismatched samples is %1d out of %1d samples\\n", stats1.errors, stats1.clocks);\n\t\t$display("Simulation finished at %0d ps", $time);\n\t\t$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);\n\tend\n\n\t// add timeout after 100K cycles\n\tinitial begin\n\t\t#1000000\n\t\t$display("TIM