// --- Testbench ---
module tb();

	// Helper structure to hold statistics and error details
	typedef struct packed {
		int errors;
		int errortime;
		int errors_p1y;
		int errortime_p1y;
		int errors_p2y;
		int errortime_p2y;
		int clocks;
	} stats;
	
	stats stats1;
	
	// Signal Declarations
	logic[511:0] wavedrom_title;
	logic wavedrom_enable;
	int wavedrom_hide_after_time;
	
	// Clock Generation	
	logic clk = 0;
	initial forever
		h#5 clk = ~clk;

	// DUT/Reference Signal Declarations
	logic p1a, p1b, p1c, p1d, p1e, p1f;
	logic p2a, p2b, p2c, p2d;
	logic p1y_ref, p1y_dut;
	logic p2y_ref, p2y_dut;

	// Testbench Utilities
	
	// Task to display signals (Hex and Bin if <= 64 bits)
	task display_signals;
		input logic[7:0] name_out;
		input logic[7:0] val_dut;
		input logic[7:0] val_ref;
		begin
			$display("Time=%0t: Signal %s | DUT: %h (%b) | REF: %h (%b)",
				$time,
				name_out,
				val_dut,
				val_ref);
		end
	endtask

	// Task to display inputs (All inputs are 1 bit here)
	task display_inputs;
		input logic[7:0] name_in;
		input logic[7:0] val_in;
		begin
			$display("Time=%0t: Input Signals | %s: %h (%b)",
				$time,
				name_in,
				val_in,
				val_in);
		end
	endtask

	// Task to display mismatch details (As required by prompt)
	task report_mismatch;
		input logic[7:0] signal_name;
		input logic[7:0] dut_val;
		input logic[7:0] ref_val;
		input logic[7:0] inputs_val;
		begin
			$display("\n==================================================================");
			$display("FIRST MISMATCH DETECTED at Time = %0t ps for Signal %s", $time, signal_name);
			$display("------------------------------------------------------------------");
			$display("Input Signals:  %h (%b)", inputs_val, inputs_val);
			$display("Output Signals: DUT = %h (%b) | Expected = %h (%b)", dut_val, dut_val, ref_val, ref_val);
			$display("==================================================================");
		endtask

	// --- Testbench Instantiations ---
	
	// 1. Stimulus Generator
	stimulus_gen stim1 (
		.clk, clk,
		.p1a, p1a,
		.p1b, p1b,
		.p1c, p1c,
		.p1d, p1d,
		.p1e, p1e,
		.p1f, p1f,
		.p2a, p2a,
		.p2b, p2b,
		.p2c, p2c,
		.p2d, p2d,
		.wavedrom_title, wavedrom_title,
		.wavedrom_enable, wavedrom_enable
	);

	// 2. Reference Module (Golden) - Assumed to exist and match logic
	// Note: RefModule definition is assumed to be available in the simulation environment.
	// We must follow the structure from the golden testbench.
	RefModule good1 (
		.p1a, p1a,
		.p1b, p1b,
		.p1c, p1c,
		.p1d, p1d,
		.p1e, p1e,
		.p1f, p1f,
		.p2a, p2a,
		.p2b, p2b,
		.p2c, p2c,
		.p2d, p2d,
		.p1y(p1y_ref),
		.p2y(p2y_ref) 
	);
	
	// 3. DUT Instantiation
	TopModule top_module1 (
		.p1a, p1a,
		.p1b, p1b,
		.p1c, p1c,
		.p1d, p1d,
		.p1e, p1e,
		.p1f, p1f,
		.p2a, p2a,
		.p2b, p2b,
		.p2c, p2c,
		.p2d, p2d,
		.p1y(p1y_dut),
		.p2y(p2y_dut) 
	);

	// --- Verification Logic ---
	wire tb_match;
	wire tb_mismatch = ~tb_match;

	// Verification: XOR comparison logic
	assign tb_match = ( { p1y_ref, p2y_ref } === ( { p1y_ref, p2y_ref } ^ { p1y_dut, p2y_dut } ^ { p1y_ref, p2y_ref } ) );

	// Global state tracking for error reporting
	// We use 'int' for tracking counts and times as in the golden testbench.
	
	always @(posedge clk, negedge clk) begin
		stats1.clocks++;
		
		// Check overall mismatch
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
			end
		
		// Check p1y mismatch
		if (p1y_ref !== ( p1y_ref ^ p1y_dut ^ p1y_ref ))
		begin 
			if (stats1.errors_p1y == 0) stats1.errortime_p1y = $time;
			stats1.errors_p1y = stats1.errors_p1y + 1'b1;
		end
		
		// Check p2y mismatch
		if (p2y_ref !== ( p2y_ref ^ p2y_dut ^ p2y_ref ))
		begin 
			if (stats1.errors_p2y == 0) stats1.errortime_p2y = $time;
			stats1.errors_p2y = stats1.errors_p2y + 1'b1;
		end
		end

	// --- Simulation Control and Final Reporting ---

	initial begin 
		$dumpfile("wave.vcd");
		// Updated dumpvars to include all relevant signals
		$dumpvars(1, stim1.clk, tb_mismatch, p1a,p1b,p1c,p1d,p1e,p1f,p2a,p2b,p2c,p2d,p1y_ref,p1y_dut,p2y_ref,p2y_dut);
		
		// Initial state logging (Optional but good practice)
		$display("--- Starting Simulation ---");
		end

	// Task to report the first mismatch details when an error is detected
	task report_current_state;
		begin
			// Inputs
			display_inputs("P_IN", {p1a,p1b,p1c,p1d,p1e,p1f,p2a,p2b,p2c,p2d}, {p1a,p1b,p1c,p1d,p1e,p1f,p2a,p2b,p2c,p2d});
			// Outputs
			$display("Output Signals: DUT = %h (%b) | Expected = %h (%b)", p1y_dut, p1y_dut, p1y_ref, p1y_ref);
			$display("Output Signals: DUT = %h (%b) | Expected = %h (%b)", p2y_dut, p2y_dut, p2y_ref, p2y_ref);
		end
	endtask

	// Overriding the error detection logic to call the detailed report when first error occurs
	always @(posedge clk, negedge clk) begin
		stats1.clocks++;
		
		// Check overall mismatch
		if (!tb_match) begin
			if (stats1.errors == 0) begin
			stats1.errortime = $time;
			report_current_state(); // Report detailed state on first error
			end
			stats1.errors++;
		end
		
		// Check p1y mismatch
		if (p1y_ref !== ( p1y_ref ^ p1y_dut ^ p1y_ref ))
		begin 
			if (stats1.errors_p1y == 0) begin
			stats1.errortime_p1y = $time;
			report_current_state(); // Report detailed state on first error
			end
			stats1.errors_p1y = stats1.errors_p1y + 1'b1;
		end
		
		// Check p2y mismatch
		if (p2y_ref !== ( p2y_ref ^ p2y_dut ^ p2y_ref ))
		begin 
			if (stats1.errors_p2y == 0) begin
			stats1.errortime_p2y = $time;
			report_current_state(); // Report detailed state on first error
			end
			stats1.errors_p2y = stats1.errors_p2y + 1'b1;
		end
		end

	// Timeout mechanism
	initial begin
		#1000000
		$display("\n!!! TIMEOUT REACHED !!!");
		$finish();
	end

	// Final Reporting Block (Replaces original final block)
	initial begin
		@(negedge clk);
		// Wait a bit longer after simulation finishes naturally
		#10;
		
		$display("\n==================================================================");
		$display("SIMULATION SUMMARY");
		$display("==================================================================");
		
		// Check p1y
		if (stats1.errors_p1y > 0) begin
			s$display("SIMULATION FAILED - x%0d MISMATCHES DETECTED, FIRST AT TIME %0d (p1y)", stats1.errors_p1y, stats1.errortime_p1y);
		end else begin
			s$display("Output 'p1y' passed all checks.");
		end
		
		// Check p2y
		if (stats1.errors_p2y > 0) begin
			s$display("SIMULATION FAILED - x%0d MISMATCHES DETECTED, FIRST AT TIME %0d (p2y)", stats1.errors_p2y, stats1.errortime_p2y);
		end else begin
			s$display("Output 'p2y' passed all checks.");
		end
		
		// Final overall check (Prioritizing the first overall error if any)
		if (stats1.errors > 0) begin
			s$display("SIMULATION FAILED - x%0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
		end else begin
			s$display("SIMULATION PASSED");
		end
		$display("Total mismatched samples: %0d out of %0d samples.", stats1.errors, stats1.clocks);
		$finish();
	end
	endmodule
