    assign p2y = (p2a & p2b) | (p2c & p2d);
endmodule

// DUT Module (must match interface)
module TopModule (
    input p1a,
    input p1b,
    input p1c,
    input p1d,
    input p1e,
    input p1f,
    input p2a,
    input p2b,
    input p2c,
    input p2d,
    output p1y,
    output p2y
);
    // Implementation based on spec: p1y = (p1a&p1b&p1c) | (p1d&p1e&p1f); p2y = (p2a&p2b) | (p2c&p2d);
    assign p1y = (p1a & p1b & p1c) | (p1d & p1e & p1f);
    assign p2y = (p2a & p2b) | (p2c & p2d);
endmodule


module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_p1y;
		int errortime_p1y;
		int errors_p2y;
		int errortime_p2y;
		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic p1a;
	logic p1b;
	logic p1c;
	logic p1d;
	logic p1e;
	logic p1f;
	logic p2a;
	logic p2b;
	logic p2c;
	logic p2d;
	logic p1y_ref;
	logic p1y_dut;
	logic p2y_ref;
	logic p2y_dut;

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,p1a,p1b,p1c,p1d,p1e,p1f,p2a,p2b,p2c,p2d,p1y_ref,p1y_dut,p2y_ref,p2y_dut );
	end

	
	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk,
		.p1a, // Explicit mapping for consistency
		.p1b,
		.p1c,
		.p1d,
		.p1e,
		.p1f,
		.p2a,
		.p2b,
		.p2c,
		.p2d,
		.wavedrom_title,
		.wavedrom_enable
	);
	RefModule good1 (
		.p1a,
		.p1b,
		.p1c,
		.p1d,
		.p1e,
		.p1f,
		.p2a,
		.p2b,
		.p2c,
		.p2d,
		.p1y(p1y_ref),
		.p2y(p2y_ref) );
	
	TopModule top_module1 (
		.p1a,
		.p1b,
		.p1c,
		.p1d,
		.p1e,
		.p1f,
		.p2a,
		.p2b,
		.p2c,
		.p2d,
		.p1y(p1y_dut),
		.p2y(p2y_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		endtask
	
	// Store initial values for combinational check comparison
	logic [9:0] input_data_storage;
	logic [1:0] output_data_storage;
	logic [1:0] golden_output_storage;
	
	initial begin
		// Initialize storage with current values before simulation starts processing
		input_data_storage = {p1a, p1b, p1c, p1d, p1e, p1f, p2a, p2b, p2c, p2d};
		output_data_storage = {p1y_dut, p2y_dut};
		golden_output_storage = {p1y_ref, p2y_ref};
	end

	// Verification and Mismatch Logic (Combinational Check)
	always @(*) begin
		// Check for mismatch based on the current state
		if (p1y_ref !== p1y_dut || p2y_ref !== p2y_dut) begin
			// Mismatch detected
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
			
			// Check p1y mismatch
			if (p1y_ref !== p1y_dut) begin
				if (stats1.errors_p1y == 0) stats1.errortime_p1y = $time;
				stats1.errors_p1y = stats1.errors_p1y + 1'b1;
			end
			// Check p2y mismatch
			if (p2y_ref !== p2y_dut) begin
				if (stats1.errors_p2y == 0) stats1.errortime_p2y = $time;
				stats1.errors_p2y = stats1.errors_p2y + 1'b1;
			end
		end
	end

	// Clocked update for statistics and state capture (to synchronize with clocking events)
	always @(posedge clk)
	begin
		stats1.clocks++;
		// Since it's combinational, we capture the inputs and outputs that caused the mismatch
		// We update the stored values on every clock edge to represent the state *after* inputs have settled
		input_data_storage = {p1a, p1b, p1c, p1d, p1e, p1f, p2a, p2b, p2c, p2d};
		output_data_storage = {p1y_dut, p2y_dut};
		golden_output_storage = {p1y_ref, p2y_ref};
	end

	final begin
		if (stats1.errors_p1y) $display("Hint: Output 'p1y' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_p1y, stats1.errortime_p1y);
		else $display("Hint: Output 'p1y' has no mismatches.");
		if (stats1.errors_p2y) $display("Hint: Output 'p2y' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_p2y, stats1.errortime_p2y);
		else $display("Hint: Output 'p2y' has no mismatches.");

		if (stats1.errors == 0) begin
			s$display("SIMULATION PASSED");
		end else begin
			s$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
		end
		$display("Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
		$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
	end

	// add timeout after 100K cycles
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

endmodule
