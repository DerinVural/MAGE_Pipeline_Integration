k(q_ref);\n\t\treset_queue.push_back(reset);\n\n\t\t// 3. Check for Mismatch (q_dut vs q_ref)\n\t\tif (q_dut !== q_ref) begin\n\t\t\t// If this is the first mismatch, capture the time\n\t\t\tif (stats1.errors_q == 0) stats1.errortime_q = $time;\n\t\t\tstats1.errors_q = stats1.errors_q + 1\'b1;\n\n\t\t\t// --- Display Queue Content on First Mismatch (Rule 1.1) ---\n\t\t\tif (stats1.errors_q == 1) begin\n\t\t\t\t$display("Mismatch detected at time %t", $time);\n\t\t\t\t$display("\\nLast %d cycles of simulation:", input_reset_queue.size());\n\n\t\t\t\tfor (int i = 0; i < input_reset_queue.size(); i++) begin\n\t\t\t\t\t// Check for match for queue display context\n\t\t\t\t\tif (got_output_queue[i] === golden_queue[i]) begin\n\t\t\t\t\t\t$display("Match at Cycle %d", i);\n\t\t\t\t\tend else begin\n\t\t\t\t\t\t$display("Mismatch at Cycle %d", i);\n\t\t\t\t\tend\n\t\t\t\t\t$display("Cycle %d, reset %b, got output %h, exp output %h",\n\t\t\t\t\ti,\n\t\t\t\t\treset_queue[i],\n\t\t\t\t\tgot_output_queue[i],\n\t\t\t\t\tgolden_queue[i]\n\t\t\t\t);\n\t\t\t\tend\n\t\t\tendif\n\t\tend\n\n\t\t// Original Error Counting Logic (Rule 3 maintained)\n\t\tif (!tb_match) begin\n\t\t\tif (stats1.errors == 0) stats1.errortime = $time;\n\t\t\tsstats1.errors++;\n\t\tend\n\n\tend\n\n\t// Verification Assignment (Must be maintained)\n\tassign tb_match = ( { q_ref } === ( { q_ref } ^ { q_dut } ^ { q_ref } ) );\n\n\n\t// Timeout\n\tinitial begin\n\t\t#1000000\n\t\t$display("TIMEOUT");\n\t\t$finish();\n\tend\n\n\t// --- Final Simulation Summary (Improved Display Logic) ---\n\tinitial begin\n\t\t@(negedge clk); // Wait for initial settling\n\t\twait(stats1.clocks > 0);\n\n\t\tif (stats1.errors == 0 && stats1.errors_q == 0) begin\n\t\t\t$display("SIMULATION PASSED");\n\t\tend else begin\n\t\t\t// Use the time recorded for the first mismatch (errors_q) as required.\n\t\t\t$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_q, stats1.errortime_q);\n\t\tend\n\t\t$fi