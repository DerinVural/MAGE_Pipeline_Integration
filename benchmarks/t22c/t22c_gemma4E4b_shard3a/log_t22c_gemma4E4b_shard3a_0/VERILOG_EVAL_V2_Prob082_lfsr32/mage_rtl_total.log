s @(*) begin\n                state_next = state;\n                case ( state )\n                STATE_A: state_next = ( in_ ) ? STATE_B : STATE_A;\n                STATE_B: state_next = ( in_ ) ? STATE_C : STATE_A;\n                STATE_C: state_next = ( in_ ) ? STATE_C : STATE_A;\n                endcase\n            end\n\n            // Output combinational logic\n            always @(*) begin\n                out = 1\'b0;\n                case ( state )\n                STATE_A: out = 1\'b0;\n                STATE_B: out = 1\'b0;\n                STATE_C: out = 1\'b1;\n                endcase\n            end\n\n        endmodule\n    </module>\n</example>\n\n<input_spec>\n\nI would like you to implement a module named TopModule with the following\ninterface. All input and output ports are one bit unless otherwise\nspecified.\n\n - input  clk\n - input  reset\n - output q (32 bits)\n\nA linear feedback shift register is a shift register usually with a few\nXOR gates to produce the next state of the shift register. A Galois LFSR\nis one particular arrangement that shifts right, where a bit position with\na "tap" is XORed with the LSB output bit (q[0]) to produce its next value,\nwhile bit positions without a tap shift right unchanged. \n\nThe module should implement a 32-bit Galois LFSR with taps at bit\npositions 32, 22, 2, and 1. Reset should be active high synchronous, and\nshould reset the output q to 32\'h1. Assume all sequential logic is\ntriggered on the positive edge of the clock.\n\n\n</input_spec>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nAnother agent has generated a testbench regarding the given input_spec:\n<testbench>\n`timescale 1 ps/1 ps\n`define OK 12\n`define INCORRECT 13\n\n\nmodule stimulus_gen (\n\tinput clk,\n\toutput reg reset\n);\n\n\t\tinitial begin\n\t\t\trepeat(400) @(posedge clk, negedge clk) begin\n\t\t\t\treset <= !($random & 31);\n\t\t\tend\n\t\t\t@(posedge clk) reset <= 1\'b0;\n\t\t\trepeat(200000) @(posedge clk);\n\t\t\treset <= 1\'b1;\n\t\t\trepeat(5) @(posedge clk);\n\t\t\t#1 $finish;\n\t\tend\n\tendmodule\n\nmodule tb();\n\n\ttypedef struct packed {\n\t\tint errors;\n\t\tint errortime;\n\t\tint errors_q;\n\t\tint errortime_q;\n\n\t\tint clocks;\n\t} stats;\n\t\n\tstats stats1;\n\t\n\t\n\twire[511:0] wavedrom_title;\n\twire wavedrom_enable;\n\tint wavedrom_hide_after_time;\n\t\n\treg clk=0;\n\tinitial forever\n\t\t#5 clk = ~clk;\n\n\tlogic reset;\n\tlogic [31:0] q_ref;\n\tlogic [31:0] q_dut;\n\n\t// --- Queue Definitions for Sequential Logic Mismatch Tracking ---\n\tlogic [31:0] input_reset_queue [$];\n\tlogic [31:0] got_output_queue [$];\n\tlogic [31:0] golden_queue [$];\n\tlogic reset_queue [$];\n\n\t// MAX_QUEUE_SIZE set to 10 as per constraints, although state space is much larger.\n\tlocalparam MAX_QUEUE_SIZE = 10;\n\n\t// --- Original Testbench Setup ---\n\tinitial begin \n\t\t$dumpfile("wave.vcd");\n\t\t$dumpvars(1, stim1.clk, tb_mismatch ,clk,reset,q_ref,q_dut );\n\tend\n\n\twire tb_match;\n\twire tb_mismatch = ~tb_match;\n\t\n\tstimulus_gen stim1 (\n\t\t.clk, \n\t\t.* , \n\t\t.reset );\n\tRefModule good1 (\n\t\t.clk,\n\t\t.reset,\n\t\t.q(q_ref) );\n\t\n\tTopModule top_module1 (\n\t\t.clk,\n\t\t.reset,\n\t\t.q(q_dut) );\n\n\t\n\tbit strobe = 0;\n\ttask wait_for_end_of_timestep;\n\t\trepeat(5) begin\n\t\tstrobe <= !strobe;  // Try to delay until the very end of the time step.\n\t\t@(strobe);\n\t\tend\ntask\n\n\t// --- Queue and Mismatch Detection Logic (Sequential) ---\n\talways @(posedge clk, negedge clk) begin\n\n\t\tstats1.clocks++;\n\n\t\t// 1. Manage Queue Size\n\t\tif (input_reset_queue.size() >= MAX_QUEUE_SIZE - 1) begin\n\t\t\tinput_reset_queue.delete(0);\n\t\t\tgot_output_queue.delete(0);\n\t\t\tgolden_queue.delete(0);\n\t\t\treset_queue.delete(0);\n\t\tend\n\n\t\t// 2. Push Current State\n\t\tinput_reset_queue.push_back(reset);\n\t\tgot_output_queue.push_back(q_dut);\n\t\tgolden_queue.push_back(q_ref);\n\t\treset_queue.push_back(reset);\n\n\t\t// 3. Check for Mismatch (q_dut vs q_ref)\n\t\tif (q_dut !== q_ref) begin\n\t\t\t// If this is the first mismatch, capture the time\n\t\t\tif (stats1.errors_q == 0) stats1.errortime_q = $time;\n\t\t\tstats1.errors_q = stats1.errors_q + 1\'b1;\n\n\t\t\t// --- Display Queue Content on First Mismatch (Rule 1.1) ---\n\t\t\tif (stats1.errors_q == 1) begin\n\t\t\t\t$display("Mismatch detected at time %t", $time);\n\t\t\t\t$display("\\nLast %d cycles of simulation:", input_reset_queue.size());\n\n\t\t\t\tfor (int i = 0; i < input_reset_queue.size(); i++) begin\n\t\t\t\t\t// Check for match for queue display context\n\t\t\t\t\tif (got_output_queue[i] === golden_queue[i]) begin\n\t\t\t\t\t\t$display("Match at Cycle %d", i);\n\t\t\t\t\tend else begin\n\t\t\t\t\t\t$display("Mismatch at Cycle %d", i);\n\t\t\t\t\tend\n\t\t\t\t\t$display("Cycle %d, reset %b, got output %h, exp output %h",\n\t\t\t\t\ti,\n\t\t\t\t\treset_queue[i],\n\t\t\t\t\tgot_output_queue[i],\n\t\t\t\t\tgolden_queue[i]\n\t\t\t\t);\n\t\t\t\tend\n\t\t\tendif\n\t\tend\n\n\t\t// Original Error Counting Logic (Rule 3 maintained)\n\t\tif (!tb_match) begin\n\t\t\tif (stats1.errors == 0) stats1.errortime = $time;\n\t\t\tsstats1.errors++;\n\t\tend\n\n\tend\n\n\t// Verification Assignment (Must be maintained)\n\tassign tb_match = ( { q_ref } === ( { q_ref } ^ { q_dut } ^ { q_ref } ) );\n\n\n\t// Timeout\n\tinitial begin\n\t\t#1000000\n\t\t$display("TIMEOUT");\n\t\t$finish();\n\tend\n\n\t// --- Final Simulation Summary (Improved Display Logic) ---\n\tinitial begin\n\t\t@(negedge clk); // Wait for initial settling\n\t\twait(stats1.clocks > 0);\n\n\t\tif (stats1.errors == 0 && stats1.errors_q == 0) begin\n\t\t\t$display("SIMULATION PASSED");\n\t\tend else begin\n\t\t\t// Use the time recorded for the first mismatch (errors_q) as required.\n\t\t\t$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_q, stats1.errortime_q);\n\t\tend\n\t\t$fi