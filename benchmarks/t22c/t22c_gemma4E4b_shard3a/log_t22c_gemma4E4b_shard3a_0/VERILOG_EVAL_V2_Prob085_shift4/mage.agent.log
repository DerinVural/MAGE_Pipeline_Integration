`timescale 1 ps/1 ps
`define OK 12
`define INCORRECT 13

module stimulus_gen (
	input clk,
	output areset,
	output reg load,
	output reg ena,
	output reg[3:0] data,
	output reg[511:0] wavedrom_title,
	output reg wavedrom_enable,
	input tb_match
);
	reg reset;
	assign areset = reset;

	task reset_test(input async=0);
	bit arfail, srfail, datafail;
	
	@(posedge clk);
	@(posedge clk) reset <= 0;
	repeat(3) @(posedge clk);
	
	@(negedge clk) begin datafail = !tb_match ; reset <= 1; end
	@(posedge clk) arfail = !tb_match;
	@(posedge clk) begin
	srfail = !tb_match;
	reset <= 0;
	end
	if (srfail)
		s$display("Hint: Your reset doesn't seem to be working.");
	else if (arfail && (async || !datafail))
		s$display("Hint: Your reset should be %0s, but doesn't appear to be.", async ? "asynchronous" : "synchronous");
	// Don't warn about synchronous reset if the half-cycle before is already wrong. It's more likely
	// a functionality error than the reset being implemented asynchronously.
	endtask

// Add two ports to module stimulus_gen:
//    output [511:0] wavedrom_title
//    output reg wavedrom_enable

	task wavedrom_start(input[511:0] title = "");	endtask
	task wavedrom_stop;
		#1;
	endtask
	

	initial begin
		{load, ena, reset, data} <= 7'h40;
		@(posedge clk) {load, ena, reset, data} <= 7'h4f;
		wavedrom_start("Load and reset");
		@(posedge clk) {load, ena, reset, data} <= 7'h0x;
		@(posedge clk) {load, ena, reset, data} <= 7'h2x;
		@(posedge clk) {load, ena, reset, data} <= 7'h2x;
		@(posedge clk) {load, ena, reset, data} <= 7'h0x;
		reset_test(1);
		@(posedge clk);
		@(posedge clk);
		wavedrom_stop();
		
		repeat(400) @(posedge clk, negedge clk) begin
		reset <= !($random & 31);
		load <= !($random & 15);
		ena <= |($random & 31);
		data <= $random;
		end
		#1 $finish;
	end
	endmodule

module tb();

	// Statistics structure maintained from original
	typedef struct packed {
		int errors;
		int errortime;
		int errors_q;
		int errortime_q;

		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		h#5 clk = ~clk;

	logic areset;
	logic load;
	logic ena;
	logic [3:0] data;
	logic [3:0] q_ref;
	logic [3:0] q_dut;

	// Signals used for queueing (must match DUT/RefModule ports)
	logic [3:0] ref_data; // Not used in original logic, but kept for context if needed
	logic [3:0] dut_data; // Not used in original logic, but kept for context if needed

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stimulus_gen.clk, tb_mismatch ,clk,areset,load,ena,data,q_ref,q_dut );
	end

	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	// Instantiate stimulus generator
	stimulus_gen stim1 (
		.clk, 
		.* , 
		.areset, 
		.load, 
		ena, 
		.data );

	// Instantiate Reference Module	
	RefModule good1 (
		.clk, 
		areset, 
		.load, 
		ena, 
		.data, 
		.q(q_ref) );
	
	// Instantiate DUT	
	TopModule top_module1 (
		.clk, 
		areset, 
		.load, 
		ena, 
		.data, 
		.q(q_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		endtask
	
	// --- QUEUE IMPLEMENTATION FOR SEQUENTIAL LOGIC CHECKING ---

	// Signals to queue (Match interface: clk, areset, load, ena, data, q_ref, q_dut)
	logic [3:0] input_data_q; // data input to DUT
	logic [3:0] got_output_q; // q_dut
	logic [3:0] golden_output_q; // q_ref
	logic reset_q; // areset

	// MAX_QUEUE_SIZE <= 10 as per instruction
	localparam MAX_QUEUE_SIZE = 10;

	logic [3:0] input_queue [$];
	logic [3:0] got_output_queue [$];
	logic [3:0] golden_queue [$];
	logic reset_queue_storage [$];

	// Helper task to display queue content upon mismatch
task display_mismatch_queue;
	input int current_index;
	
	begin
		$display("======================================================================================");
		$display("!! MISMATCH DETECTED AT TIME %0t !!", $time);
		$display("Displaying last %0d cycles leading up to and including the mismatch:", input_queue.size());
		$display("======================================================================================");
		
		for (int i = 0; i < input_queue.size(); i++) begin
			$display("Cycle %0d, Reset: %b, Data In: %h (%b), Got Q: %h (%b), Exp Q: %h (%b)",
						i,
						reset_queue_storage[i],
						input_queue[i],
						input_queue[i], // Displaying data input in both formats
						got_output_queue[i],
						got_output_queue[i], // Displaying got output in both formats
						golden_queue[i],
						golden_queue[i]  // Displaying expected output in both formats
			);
		$display("======================================================================================");
	endtask

	// Clocked comparison and queue update
	always @(posedge clk, negedge clk) begin
		
		// 1. Manage Queue Size
		if (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin
			input_queue.delete(0);
			got_output_queue.delete(0);
			golden_queue.delete(0);
			reset_queue_storage.delete(0);
		end

		// 2. Store Current State
		input_queue.push_back(data);
		got_output_queue.push_back(q_dut);
		golden_queue.push_back(q_ref);
		reset_queue_storage.push_back(areset);

		// 3. Check for first mismatch (using the comparison from original TB)
		if (q_ref !== q_dut) begin 
			if (stats1.errors_q == 0) stats1.errortime_q = $time;
			s	stats1.errors_q = stats1.errors_q + 1'b1;
				display_mismatch_queue(input_queue.size());
		end
		
		// 4. Update Stats (maintaining original logic)
		stats1.clocks++;
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			s	stats1.errors++;
		end
	end

	// End of clocked comparison logic

	// Verification assignment (maintaining original logic)
	assign tb_match = ( { q_ref } === ( { q_ref } ^ { q_dut } ^ { q_ref } ) );

	// Timeout mechanism	
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

	final begin
		if (stats1.errors_q > 0) begin
			s$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d.", stats1.errors_q, stats1.errortime_q);
		end
		else begin
			s$display("SIMULATION PASSED");
		end
		
		// Keep original summary display, though the final message is now strictly required
		$display("Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
		$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
	end

endmodule
