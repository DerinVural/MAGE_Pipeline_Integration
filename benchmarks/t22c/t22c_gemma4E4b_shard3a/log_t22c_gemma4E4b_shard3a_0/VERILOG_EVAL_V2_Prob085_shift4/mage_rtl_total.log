    "testbench": "`timescale 1 ps/1 ps\n`define OK 12\n`define INCORRECT 13\n\n// NOTE: RefModule is assumed to be defined elsewhere as it was not provided.\nmodule RefModule (\n    input  logic clk,\n    input  logic areset,\n    input  logic load,\n    input  logic ena,\n    input  logic [3:0] data,\n    output logic [3:0] q\n);\n    // Placeholder implementation to allow testbench structure to compile\n    assign q = 4'h0;\nendmodule\n\nmodule stimulus_gen (\n    input logic clk,\n    output logic areset,\n    output logic load,\n    output logic ena,\n    output logic [3:0] data,\n    \n    output logic [511:0] wavedrom_title,\n    output logic wavedrom_enable,\n    input logic tb_match\n);\n    logic reset;\n    assign areset = reset;\n\n    task reset_test(input async=0);\n        bit arfail, srfail, datafail;\n    \n        @(posedge clk);\n        @(posedge clk) reset <= 0;\n        repeat(3) @(posedge clk);\n    \n        @(negedge clk) begin datafail = !tb_match ; reset <= 1; end\n        @(posedge clk) arfail = !tb_match;\n        @(posedge clk) begin\n            srfail = !tb_match;\n            reset <= 0;\n        end\n        if (srfail)\n            $display(\"Hint: Your reset doesn't seem to be working.\");\n        else if (arfail && (async || !datafail))\n            $display(\"Hint: Your reset should be %0s, but doesn't appear to be.\", async ? \"asynchronous\" : \"synchronous\");\n        // Don't warn about synchronous reset if the half-cycle before is already wrong. It's more likely\n        // a functionality error than the reset being implemented asynchronously.\n    \n    endtask\n    \n    // Add two ports to module stimulus_gen:\n    //    output [511:0] wavedrom_title\n    //    output reg wavedrom_enable\n\n    task wavedrom_start(input[511:0] title = \"\");\n    endtask\n    \n    task wavedrom_stop;\n        #1;\n    endtask\n    \n\n    initial begin\n        {load, ena, reset, data} <= 7'h40;\n        @(posedge clk) {load, ena, reset, data} <= 7'h4f;\n        wavedrom_start(\"Load and reset\");\n        @(posedge clk) {load, ena, reset, data} <= 7'h0x;\n        @(posedge clk) {load, ena, reset, data} <= 7'h2x;\n        @(posedge clk) {load, ena, reset, data} <= 7'h2x;\n        @(posedge clk) {load, ena, reset, data} <= 7'h0x;\n        reset_test(1);\n        @(posedge clk);\n        @(posedge clk);\n        wavedrom_stop();\n        \n        repeat(400) @(posedge clk, negedge clk) begin\n            reset <= !($random & 31);\n            load <= !($random & 15);\n            ena <= |($random & 31);\n            data <= $random;\n        end\n        #1 $finish;\n    end\n    \nendmodule\n\nmodule tb();\n\n    typedef struct packed {\n        int errors;\n        int errortime;\n        int errors_q;\n        int errortime_q;\n        \n        int clocks;\n        \n        // Variables to capture state at first error\n        logic [3:0] q_dut_at_error;\n        logic [3:0] q_ref_at_error;\n        logic [3:0] data_at_error;\n    }\n    stats;\n    \n    stats stats1;\n    \n    \n    wire[511:0] wavedrom_title;\n    wire wavedrom_enable;\n    int wavedrom_hide_after_time;\n    \n    reg clk=0;\n    initial forever\n        #5 clk = ~clk;\n\n    logic areset;\n    logic load;\n    logic ena;\n    logic [3:0] data;\n    logic [3:0] q_ref;\n    logic [3:0] q_dut;\n\n    initial begin \n        $dumpfile(\"wave.vcd\");\n        $dumpvars(1, stim1.clk, tb_mismatch ,clk,areset,load,ena,data,q_ref,q_dut );\n    end\n\n    \n    wire tb_match;\n    wire tb_mismatch = ~tb_match;\n    \n    stimulus_gen stim1 (\n        .clk, \n        .areset, // Mapping inputs required by stimulus_gen\n        .load,\n        .ena,\n        .data,\n        .tb_match\n    );\n    RefModule good1 (\n        .clk,\n        areset,\n        .load,\n        ena,\n        .data,\n        .q(q_ref) );\n        \n    TopModule top_module1 (\n        .clk,\n        areset,\n        .load,\n        ena,\n        .data,\n        .q(q_dut) );\n\n    \n    bit strobe = 0;\n    task wait_for_end_of_timestep;\n        repeat(5) begin\n            strobe <= !strobe;  // Try to delay until the very end of the time step.\n            @(strobe);\n        end\n    endtask\n    \n    \n    // --- Error Logging and Display Tasks ---\n    task display_error_details;\n        input $time t_err;\n        input [3:0] q_ref_val;\n        input [3:0] q_dut_val;\n        input [3:0] data_val;\n        \n        $display(\"========================================================================"  
        , "\n*** MISMATCH DETECTED AT TIME %0d ps ***\n------------------------------------------------------------------------\nINPUTS:\n  Data: HEX=%h, BIN=%b\nOUTPUTS:\n  Q_REF: HEX=%h, BIN=%b\n  Q_DUT: HEX=%h, BIN=%b\n========================================================================\");\n    endtask\n    \n    // --- Final Reporting Logic ---\n    initial begin\n        @(negedge clk);\n        // Wait a little extra time to ensure final states are captured before $finish\n        #10;\n        \n        if (stats1.errors == 0 && stats1.errors_q == 0) begin\n            $display(\"\n****************************************\");\n            $display(\"SIMULATION PASSED\");\n            $display(\"****************************************\\n\");\n        end else begin\n            string result_msg;\n            if (stats1.errors > 0) begin\n                result_msg = $sformatf(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\", stats1.errors, stats1.errortime);\n            end else begin\n                // This branch handles cases where only output mismatch error_q was recorded, but total error count is 0 (unlikely with the current check, but safer)\n                result_msg = $sformatf(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\", stats1.errors_q, stats1.errortime_q);\n            end\n            $display(\"\n****************************************\");\n            $display(\"%s\", result_msg);\n            $display(\"****************************************\\n\");\n        end\n    end\n    \n    // Initialization of statistics\n    initial begin\n        stats1.errors = 0;\n        stats1.errortime = 0;\n        stats1.errors_q = 0;\n        stats1.errortime_q = 0;\n        stats1.clocks = 0;\n    end\n    \n    // Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.\n    assign tb_match = ( { q_ref } === ( { q_ref } ^ { q_dut } ^ { q_ref } ) );\n    \n    // Use explicit sensitivity list here.\n    always @(posedge clk, negedge clk) begin\n        \n        stats1.clocks++;\n        \n        // 1. Check Total Mismatch\n        if (!tb_match) begin\n            if (stats1.errors == 0) begin\n                stats1.errortime = $time;\n                stats1.q_dut_at_error = q_dut;\n                stats1.q_ref_at_error = q_ref;\n                stats1.data_at_error = data;\n            end\n            display_error_details($time, q_ref, q_dut, data);\n            stats1.errors++;\n        end\n        \n        // 2. Check Output Mismatch (Original logic preserved)\n        if (q_ref !== ( q_ref ^ q_dut ^ q_ref ))\n        begin \n            if (stats1.errors_q == 0) begin\n                stats1.errortime_q = $time;\n                stats1.q_dut_at_error = q_dut;\n                stats1.q_ref_at_error = q_ref;\n                stats1.data_at_error = data;\n            end\n            display_error_details($time, q_ref, q_dut, data);\n            stats1.errors_q = stats1.errors_q+1'b1;\n        end\n    end\n\n    // add timeout after 100K cycles\n    initial begin\n      #1000000\n      $display(\"\\nTIMEOUT REACHED. Terminating simulation.\");\n      $finish();\n    end\n\nendmodule"
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  
  

