    "testbench": "`timescale 1 ps/1 ps\n`define OK 12\n`define INCORRECT 13\n\n\n// stimulus_gen module remains unchanged as per instruction #1\nmodule stimulus_gen (\n\tinput clk,\n\toutput logic x,\n\toutput logic y,\n\toutput reg[511:0] wavedrom_title,\n\toutput reg wavedrom_enable\n);\n\n\t// Add two ports to module stimulus_gen:\n\t//    output [511:0] wavedrom_title\n\t//    output reg wavedrom_enable\n\n\ttask wavedrom_start(input[511:0] title = \"\");\n\tendtask\n\t\n\ttask wavedrom_stop;\n\t\th#1;\n\tendtask\t\n\n\t\tinitial begin\n\t\t\t{x,y} <= 0;\n\t\t\t@(negedge clk) wavedrom_start();\n\t\t\t\t@(posedge clk) {y,x} <= 0;\n\t\t\t\t@(posedge clk) {y,x} <= 1;\n\t\t\t\t@(posedge clk) {y,x} <= 2;\n\t\t\t\t@(posedge clk) {y,x} <= 3;\n\t\t\t@(negedge clk) wavedrom_stop();\n\t\t\trepeat(100) @(posedge clk, negedge clk)\n\t\t\t\t{x, y} <= $random % 4;\n\t\t\t#1 $finish;\n\t\tend\n\tendmodule\n\n\nmodule tb();\n\n\ttypedef struct packed {\n\t\tint errors;\n\t\tint errortime;\n\t\tint errors_z;\n\t\tint errortime_z;\n\n\t\tint clocks;\n\t} stats;\n\t\n\tstats stats1;\n\t\n\t\n\twire[511:0] wavedrom_title;\n\twire wavedrom_enable;\n\tint wavedrom_hide_after_time;\n\t\n\treg clk=0;\n\tinitial forever\n\t\t#5 clk = ~clk;\n\n\tlogic x;\n\tlogic y;\n\tlogic z_ref;\n\tlogic z_dut;\n\n\t// --- Queue Implementation for Mismatch Tracking ---\n\t// Since the module is sequential, we use queues for state tracking.\n\treg input_x_queue [$];\n\treg input_y_queue [$];\n\treg got_output_queue [$];\n\treg golden_queue [$];\n\treg error_indicator_queue [$]; // Tracks if mismatch occurred in this cycle\n\n\tlocalparam MAX_QUEUE_SIZE = 5; // Small size as per constraints\n\n\t// --- Clocking and Mismatch Detection ---\n\twire tb_match;\n\twire tb_mismatch = ~tb_match;\n\n\t// --- Initialization and Dumping ---\n\tinitial begin \n\t\t$dumpfile(\"wave.vcd\");\n\t\t// Adjusted dumpvars to include all relevant signals\n\t\t$dumpvars(1, stim1.clk, tb_mismatch, x, y, z_ref, z_dut, stats1);\n\tend\n\n\t// --- Instantiate Components ---\n\tstimulus_gen stim1 (\n\t\t.clk, \n\t\t.* , \n\t\t.x, \n\t\t.y );\n\tRefModule good1 (\n\t\t.x, \n\t\ty, \n\t\tz(z_ref) );\n\t\n\tTopModule top_module1 (\n\t\t.x, \n\t\ty, \n\t\tz(z_dut) );\n\n\t\n\tbit strobe = 0;\n\ttask wait_for_end_of_timestep;\n\t\trepeat(5) begin\n\t\tstrobe <= !strobe;  // Try to delay until the very end of the time step.\n\t\t@(strobe);\n\t\tend\ntask\n\n\t// --- Verification Logic and Queue Filling --- \n\t// This block implements the queue logic for sequential verification\n\nalways @(posedge clk, negedge clk) begin\n    // 1. Manage Queue Size\n    if (input_x_queue.size() >= MAX_QUEUE_SIZE - 1) begin\n        input_x_queue.delete(0);\n        input_y_queue.delete(0);\n        got_output_queue.delete(0);\n        golden_queue.delete(0);\n        error_indicator_queue.delete(0);\n    end\n\n    // 2. Push Current State\n    input_x_queue.push_back(x);\n    input_y_queue.push_back(y);\n    got_output_queue.push_back(z_dut);\n    golden_queue.push_back(z_ref);\n    \n    // Check for mismatch using the standard verification principle (z_ref vs z_dut)\n    // We use the condition z_ref != z_dut as the primary mismatch signal for queue logging,\n    // as this aligns with standard DUT verification, while preserving original counter logic.\n    if (z_ref !== z_dut) begin\n        error_indicator_queue.push_back(1'b1);\n    end else begin\n        error_indicator_queue.push_back(1'b0);\n    end\n\n    // 3. Update Statistics (Original Logic)\n    stats1.clocks++;\n    if (!tb_match) begin\n        if (stats1.errors == 0) stats1.errortime = $time;\n        stats1.errors++;\n    end\n    // Original specific check for z_ref vs z_dut XOR logic\n    if (z_ref !== ( z_ref ^ z_dut ^ z_ref ))\n    begin \n        if (stats1.errors_z == 0) stats1.errortime_z = $time;\n        stats1.errors_z = stats1.errors_z+1'b1; \n    end\n\n    // 4. Check for First Mismatch and Display Queue Content (Only upon first mismatch)\n    if (error_indicator_queue.size() == 1 && error_indicator_queue[0] == 1'b1) begin\n        $display(\"\\n==================================================================\");\n        $display(\"*** FIRST MISMATCH DETECTED ***\");\n        $display(\"Mismatch detected at time %0t\", $time);\n        $display(\"\\nLast %0d cycles of simulation (Trigger Cycle Included):\", error_indicator_queue.size());\n\n        for (int i = 0; i < error_indicator_queue.size(); i++) begin\n            $display(\"Cycle %0d, Inputs: x=%b, y=%b, Got z=%b, Exp z=%b, Mismatch=%b\",\n                i, \n                input_x_queue[i], \n                input_y_queue[i], \n                got_output_queue[i], \n                golden_queue[i], \n                error_indicator_queue[i]);\n        end\n        $display(\"==================================================================\\n\");\n    end\n\n\tend\n\n// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.\nassign tb_match = ( { z_ref } === ( { z_ref } ^ { z_dut } ^ { z_ref } ) );\n\n\n\t// --- Final Reporting --- \n\tfinal begin\n\t\tif (stats1.errors_z) $display(\"Hint: Output 'z' has %0d mismatches. First mismatch occurred at time %0d.\", stats1.errors_z, stats1.errortime_z);\n\t\telse $display(\"Hint: Output 'z' has no mismatches.\");\n\n\t\t$display(\"Hint: Total mismatched samples is %1d out of %1d samples\\n\", stats1.errors, stats1.clocks);\n\t\t$display(\"Simulation finished at %0d ps\", $time);\n\t\t\n\t\t// Final required output format\n\t\tif (stats1.errors == 0) \n\t\t\ts$display(\"SIMULATION PASSED\");\n\t\telse \n\t\t\t$display(\"SIMULATION FAILED - x MISMATCHES DETECTED, FIRST AT TIME %0d\", stats1.errortime);\n\tend\n\n\n   // add timeout after 100K cycles\n   initial begin\n     #1000000\n     if ($time > 0) $display(\"TIMEOUT\");\n     $finish();\n   end\n\nendmodule\n"
