mplements the queue logic for sequential verification\n\nalways @(posedge clk, negedge clk) begin\n    // 1. Manage Queue Size\n    if (input_x_queue.size() >= MAX_QUEUE_SIZE - 1) begin\n        input_x_queue.delete(0);\n        input_y_queue.delete(0);\n        got_output_queue.delete(0);\n        golden_queue.delete(0);\n        error_indicator_queue.delete(0);\n    end\n\n    // 2. Push Current State\n    input_x_queue.push_back(x);\n    input_y_queue.push_back(y);\n    got_output_queue.push_back(z_dut);\n    golden_queue.push_back(z_ref);\n    \n    // Check for mismatch using the standard verification principle (z_ref vs z_dut)\n    // We use the condition z_ref != z_dut as the primary mismatch signal for queue logging,\n    // as this aligns with standard DUT verification, while preserving original counter logic.\n    if (z_ref !== z_dut) begin\n        error_indicator_queue.push_back(1\'b1);\n    end else begin\n        error_indicator_queue.push_back(1\'b0);\n    end\n\n    // 3. Update Statistics (Original Logic)\n    stats1.clocks++;\n    if (!tb_match) begin\n        if (stats1.errors == 0) stats1.errortime = $time;\n        stats1.errors++;\n    end\n    // Original specific check for z_ref vs z_dut XOR logic\n    if (z_ref !== ( z_ref ^ z_dut ^ z_ref ))\n    begin \n        if (stats1.errors_z == 0) stats1.errortime_z = $time;\n        stats1.errors_z = stats1.errors_z+1\'b1; \n    end\n\n    // 4. Check for First Mismatch and Display Queue Content (Only upon first mismatch)\n    if (error_indicator_queue.size() == 1 && error_indicator_queue[0] == 1\'b1) begin\n        $display("\\n==================================================================");\n        $display("*** FIRST MISMATCH DETECTED ***");\n        $display("Mismatch detected at time %0t", $time);\n        $display("\\nLast %0d cycles of simulation (Trigger Cycle Included):", error_indicator_queue.size());\n\n        for (int i = 0; i < error_indicator_queue.size(); i++) begin\n           