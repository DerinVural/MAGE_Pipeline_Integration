`define OK 12
`define INCORRECT 13

// Assuming stimulus_gen and RefModule exist as per golden testbench

module tb_improved();

    typedef struct packed {
        int errors;
        int errortime;
        int errors_out_and;
        int errortime_out_and;
        int errors_out_or;
        int errortime_out_or;
        int errors_out_xor;
        int errortime_out_xor;
        int errors_out_nand;
        int errortime_out_nand;
        int errors_out_nor;
        int errortime_out_nor;
        int errors_out_xnor;
        int errortime_out_xnor;
        int errors_out_anotb;
        int errortime_out_anotb;

        int clocks;
        int first_mismatch_time; // New variable to track the absolute first mismatch
    } stats;
    
    stats stats1;
    
    
    wire[511:0] wavedrom_title;
    wire wavedrom_enable;
    int wavedrom_hide_after_time;
    
    reg clk=0;
    initial forever
        #5 clk = ~clk;

    logic a;
    logic b;
    logic out_and_ref;
    logic out_and_dut;
    logic out_or_ref;
    logic out_or_dut;
    logic out_xor_ref;
    logic out_xor_dut;
    logic out_nand_ref;
    logic out_nand_dut;
    logic out_nor_ref;
    logic out_nor_dut;
    logic out_xnor_ref;
    logic out_xnor_dut;
    logic out_anotb_ref;
    logic out_anotb_dut;

    // Wire for verification
    wire tb_match;
    wire tb_mismatch = ~tb_match;

    initial begin 
        $dumpfile("wave.vcd");
        $dumpvars(1, tb_improved.clk, tb_improved.a, tb_improved.b, out_and_ref, out_and_dut, out_or_ref, out_or_dut, out_xor_ref, out_xor_dut, out_nand_ref, out_nand_dut, out_nor_ref, out_nor_dut, out_xnor_ref, out_xnor_dut, out_anotb_ref, out_anotb_dut );
    end

    // Instantiate stimulus generator
    stimulus_gen stim1 (
        .clk, 
        .wavedrom_title(wavedrom_title), 
        .wavedrom_enable(wavedrom_enable), 
        .a, 
        .b 
    );

    // Instantiate Golden Reference Module
    RefModule good1 (
        .a, 
        .b, 
        .out_and(out_and_ref),
        .out_or(out_or_ref),
        .out_xor(out_xor_ref),
        .out_nand(out_nand_ref),
        .out_nor(out_nor_ref),
        .out_xnor(out_xnor_ref),
        .out_anotb(out_anotb_ref) 
    );
        
    // Instantiate DUT
    TopModule top_module1 (
        .a, 
        .b, 
        .out_and(out_and_dut),
        .out_or(out_or_dut),
        .out_xor(out_xor_dut),
        .out_nand(out_nand_dut),
        .out_nor(out_nor_dut),
        .out_xnor(out_xnor_dut),
        .out_anotb(out_anotb_dut) 
    );

    // Verification Logic: Check if all outputs match
    // Note: The original TB used a complex XOR logic for tb_match; we simplify to direct comparison
    assign tb_match = ( out_and_ref == out_and_dut ) &&
                      ( out_or_ref == out_or_dut ) &&
                      ( out_xor_ref == out_xor_dut ) &&
                      ( out_nand_ref == out_nand_dut ) &&
                      ( out_nor_ref == out_nor_dut ) &&
                      ( out_xnor_ref == out_xnor_dut ) &&
                      ( out_anotb_ref == out_anotb_dut );

    // Task to wait for a delay (retained from golden TB)
    bit strobe = 0;
    task wait_for_end_of_timestep;
        repeat(5) begin
            strobe <= !strobe;  // Try to delay until the very end of the time step.
            @(strobe);
        end
    endtask

    // Main comparison and logging logic (Combinational Check Adaptation)
    always @(posedge clk, negedge clk) begin
        stats1.clocks++;
        
        // Check for total mismatch
        if (!tb_match) begin
            if (stats1.errors == 0) stats1.first_mismatch_time = $time;
            stats1.errors++;
        end

        // Individual output checks
        // We check if the DUT output differs from the reference output.
        
        // out_and
        if (out_and_ref !== out_and_dut) begin 
            if (stats1.errors_out_and == 0) stats1.errortime_out_and = $time;
            stats1.errors_out_and = stats1.errors_out_and + 1'b1;
        end
        // out_or
        if (out_or_ref !== out_or_dut) begin 
            if (stats1.errors_out_or == 0) stats1.errortime_out_or = $time;
            stats1.errors_out_or = stats1.errors_out_or + 1'b1;
        end
        // out_xor
        if (out_xor_ref !== out_xor_dut) begin 
            if (stats1.errors_out_xor == 0) stats1.errortime_out_xor = $time;
            stats1.errors_out_xor = stats1.errors_out_xor + 1'b1;
        end
        // out_nand
        if (out_nand_ref !== out_nand_dut) begin 
            if (stats1.errors_out_nand == 0) stats1.errortime_out_nand = $time;
            stats1.errors_out_nand = stats1.errors_out_nand + 1'b1;
        end
        // out_nor
        if (out_nor_ref !== out_nor_dut) begin 
            if (stats1.errors_out_nor == 0) stats1.errortime_out_nor = $time;
            stats1.errors_out_nor = stats1.errors_out_nor + 1'b1;
        end
        // out_xnor
        if (out_xnor_ref !== out_xnor_dut) begin 
            if (stats1.errors_out_xnor == 0) stats1.errortime_out_xnor = $time;
            stats1.errors_out_xnor = stats1.errors_out_xnor + 1'b1;
        end
        // out_anotb
        if (out_anotb_ref !== out_anotb_dut) begin 
            if (stats1.errors_out_anotb == 0) stats1.errortime_out_anotb = $time;
            stats1.errors_out_anotb = stats1.errors_out_anotb + 1'b1;
        end

        // Enhanced Display for FIRST Mismatch (Combinational Logic Requirement)
        if (!tb_match && stats1.errors == 1) begin
            $display("\n========================================================================");
            $display("!!! FIRST MISMATCH DETECTED AT TIME %0d ps !!!", $time);
            $display("Inputs: a=%b, b=%b", a, b);
            $display("Reference Outputs: Out_AND=%b, Out_OR=%b, Out_XOR=%b, Out_NAND=%b, Out_NOR=%b, Out_XNOR=%b, Out_ANOTB=%b", 
                    out_and_ref, out_or_ref, out_xor_ref, out_nand_ref, out_nor_ref, out_xnor_ref, out_anotb_ref);
            $display("DUT Outputs:      Out_AND=%b, Out_OR=%b, Out_XOR=%b, Out_NAND=%b, Out_NOR=%b, Out_XNOR=%b, Out_ANOTB=%b", 
                    out_and_dut, out_or_dut, out_xor_dut, out_nand_dut, out_nor_dut, out_xnor_dut, out_anotb_dut);
            $display("========================================================================\n");
        end

    end

    // Timeout mechanism
    initial begin
        #1000000
        $display("TIMEOUT REACHED.");
        $finish();
    end

    // Final reporting logic (Replaced original Hint logic)
    final begin
        if (stats1.errors == 0) begin
            $display("\n*****************************************");
            $display("SIMULATION PASSED");
            $display("*****************************************");
        end else begin
            $display("\n*****************************************");
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.first_mismatch_time);
            $display("*****************************************");
        end
        $display("Total samples checked: %0d", stats1.clocks);
    end

endmodule
