    assign out_nand = ~(a & b);

    // (5) out_nor: a nor b (NOT (a OR b))
    assign out_nor = ~(a | b);

    // (6) out_xnor: a xnor b (Equivalent to a == b)
    assign out_xnor = ~(a ^ b);

    // (7) out_anotb: a and-not b (a AND NOT b)
    assign out_anotb = a & ~b;

endmodule
