            PROCESS: begin
                if (x == 1'b1)
                    next_state = PROCESS;
                else
                    next_state = OUTPUT;
            end
            OUTPUT: begin
                next_state = IDLE;
            end
            default:
                next_state = IDLE;
        endcase
    end
    
