    // Define states for the Moore FSM
    localparam IDLE   = 2'b00;
    localparam PROCESS = 2'b01;
    localparam OUTPUT = 2'b10;
    
    // Current and next state registers
    logic [1:0] state, next_state;
    
    // Register to store the result
    logic result;
    
