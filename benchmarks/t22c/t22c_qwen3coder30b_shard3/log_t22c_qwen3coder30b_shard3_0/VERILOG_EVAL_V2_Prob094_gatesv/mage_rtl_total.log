[2026-05-14 14:01:59,997 - mage.rtl_generator - INFO] RTL code: module TopModule (
    input [3:0] in,
    output [3:0] out_both,
    output [3:0] out_any,
    output [3:0] out_different
);

    // out_both: Each bit indicates if both the corresponding input bit and its neighbor to the left are '1'
    // out_both[3] is undefined since in[3] has no neighbor to the left
    always @(*) begin
        out_both[3] = 1'b0; // Undefined, set to 0
        out_both[2] = in[2] & in[3];
        out_both[1] = in[1] & in[2];
        out_both[0] = in[0] & in[1];
    end

    // out_any: Each bit indicates if either the corresponding input bit or its neighbor to the right are '1'
    // out_any[0] is undefined since in[0] has no neighbor to the right
    always @(*) begin
        out_any[0] = 1'b0; // Undefined, set to 0
        out_any[1] = in[1] | in[0];
        out_any[2] = in[2] | in[1];
        out_any[3] = in[3] | in[2];
    end

    // out_different: Each bit indicates if the corresponding input bit is different from its neighbor to the left
    // Treat the vector as wrapping around, so in[3]'s neighbor to the left is in[0]
    always @(*) begin
        out_different[0] = in[0] ^ in[3];
        out_different[1] = in[1] ^ in[0];
        out_different[2] = in[2] ^ in[1];
        out_different[3] = in[3] ^ in[2];
    end

endmodule
