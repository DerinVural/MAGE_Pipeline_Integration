        out_any[1] = in[1] | in[0];
        out_any[2] = in[2] | in[1];
        out_any[3] = in[3] | in[2];

        // out_different: Each bit indicates if current bit is different from left neighbor
        // Treating vector as wrapping around, so in[0]'s left neighbor is in[3]
