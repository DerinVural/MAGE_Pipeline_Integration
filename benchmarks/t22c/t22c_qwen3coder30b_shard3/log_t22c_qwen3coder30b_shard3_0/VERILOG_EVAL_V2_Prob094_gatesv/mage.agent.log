	always @(posedge clk, negedge clk) begin

		stats1.clocks++;
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
		end
		if (out_both_ref !== ( out_both_ref ^ out_both_dut ^ out_both_ref ))
		pbegin if (stats1.errors_out_both == 0) stats1.errortime_out_both = $time;
			stats1.errors_out_both = stats1.errors_out_both+1'b1; end
		if (out_any_ref !== ( out_any_ref ^ out_any_dut ^ out_any_ref ))
		pbegin if (stats1.errors_out_any == 0) stats1.errortime_out_any = $time;
			stats1.errors_out_any = stats1.errors_out_any+1'b1; end
		if (out_different_ref !== ( out_different_ref ^ out_different_dut ^ out_different_ref ))
		pbegin if (stats1.errors_out_different == 0) stats1.errortime_out_different = $time;
			stats1.errors_out_different = stats1.errors_out_different+1'b1; end

	end

	// add timeout after 100K cycles
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

	// Display inputs and outputs at first mismatch
	always @(posedge clk, negedge clk) begin
		if (!tb_match && stats1.errors == 1) begin
			$display("First mismatch detected at time %t:", $time);
			$display("Input: %b (%h)", in, in);
			$display("Expected out_both: %b (%h)", out_both_ref, out_both_ref);
			$display("Got out_both: %b (%h)", out_both_dut, out_both_dut);
			$display("Expected out_any: %b (%h)", out_any_ref, out_any_ref);
			$display("Got out_any: %b (%h)", out_any_dut, out_any_dut);
			$display("Expected out_different: %b (%h)", out_different_ref, out_different_ref);
			$display("Got out_different: %b (%h)", out_different_dut, out_different_dut);
		end
	end

endmodule
