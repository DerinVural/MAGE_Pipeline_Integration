module stimulus_gen (
	input clk,
	input tb_match,
	output logic [3:0] in,
	output reg[511:0] wavedrom_title,
	output reg wavedrom_enable
);


// Add two ports to module stimulus_gen:
//	output [511:0] wavedrom_title
//	output reg wavedrom_enable

task wavedrom_start(input[511:0] title = "");
	endtask

task wavedrom_stop;
	#1;
	endtask	



initial begin
	in <= 4'h3;
	@(negedge clk);
	wavedrom_start();
		@(posedge clk) in <= 3;
		@(posedge clk) in <= 6;
		@(posedge clk) in <= 12;
		@(posedge clk) in <= 9;
		@(posedge clk) in <= 5;
	@(negedge clk);
	wavedrom_stop();
	in <= $random;
	repeat(100) begin
		@(negedge clk) in <= $random;
		@(posedge clk) in <= $random;
	end
	#1 $finish;
end
	
endmodule

module tb();

