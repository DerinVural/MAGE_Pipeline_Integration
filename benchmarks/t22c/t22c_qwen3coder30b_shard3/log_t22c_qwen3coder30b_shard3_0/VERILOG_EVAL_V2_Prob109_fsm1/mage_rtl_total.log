				stats1.errortime = $time;
				$display("First mismatch detected at time %0d:", $time);
				$display("  clk=%b, areset=%b, in=%b, out_ref=%b, out_dut=%b", clk, areset, in, out_ref, out_dut);
			end
			stats1.errors++;
		end
		if (out_ref !== ( out_ref ^ out_dut ^ out_ref ))
		begin 
			if (stats1.errors_out == 0) stats1.errortime_out = $time;
			stats1.errors_out = stats1.errors_out+1'b1; 
		end

	end

	// add timeout after 100K cycles
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

endmodule
