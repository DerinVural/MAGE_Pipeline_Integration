twire[511:0] wavedrom_title;
twire wavedrom_enable;
int wavedrom_hide_after_time;

reg clk=0;
initial forever
	#5 clk = ~clk;

logic in;
logic areset;
logic out_ref;
logic out_dut;

initial begin 
	$dumpfile("wave.vcd");
	$dumpvars(1, stim1.clk, tb_mismatch ,clk,in,areset,out_ref,out_dut );
end


wire tb_match;      // Verification
wire tb_mismatch = ~tb_match;

stimulus_gen stim1 (
	.clk,
	.* ,
	.in,
	.areset );
RefModule good1 (
	.clk,
	.in,
	.areset,
	.out(out_ref) );

TopModule top_module1 (
	.clk,
	.in,
	.areset,
	.out(out_dut) );

bit strobe = 0;
task wait_for_end_of_timestep;
	repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
	end
endtask

// Queue-based simulation mismatch display
reg in_queue [$];
reg areset_queue [$];
reg out_ref_queue [$];
reg out_dut_queue [$];

localparam MAX_QUEUE_SIZE = 10;

always @(posedge clk, negedge clk) begin
	if (in_queue.size() >= MAX_QUEUE_SIZE - 1) begin
		in_queue.delete(0);
		areset_queue.delete(0);
		out_ref_queue.delete(0);
		out_dut_queue.delete(0);
	end

	in_queue.push_back(in);
	areset_queue.push_back(areset);
	out_ref_queue.push_back(out_ref);
