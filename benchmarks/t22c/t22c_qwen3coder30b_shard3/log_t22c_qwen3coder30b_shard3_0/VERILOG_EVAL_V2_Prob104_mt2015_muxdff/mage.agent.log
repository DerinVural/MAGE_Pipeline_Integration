				$display("FIRST MISMATCH AT TIME %0d:", $time);
				$display("Input signals - clk=%b L=%b q_in=%b r_in=%b", clk, L, q_in, r_in);
				$display("Expected output (Q_ref) = %b (%h)", Q_ref, Q_ref);
				$display("Actual output (Q_dut) = %b (%h)", Q_dut, Q_dut);
			end
		end
		if (Q_ref !== ( Q_ref ^ Q_dut ^ Q_ref ))
		begin 
			if (stats1.errors_Q == 0) stats1.errortime_Q = $time;
			stats1.errors_Q = stats1.errors_Q+1'b1; 
		end

	end

	// add timeout after 100K cycles
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

endmodule
