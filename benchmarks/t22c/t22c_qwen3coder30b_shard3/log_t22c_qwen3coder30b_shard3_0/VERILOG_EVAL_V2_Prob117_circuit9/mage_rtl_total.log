task wavedrom_start(input[511:0] title = "");
	endtask

task wavedrom_stop;
	#1;
endtask	


initial begin
	a <= 1;
	@(negedge clk) {a} <= 1;
	@(negedge clk) wavedrom_start("Unknown circuit");
		repeat(2) @(posedge clk);
		@(posedge clk) {a} <= 0;
		repeat(11) @(posedge clk);
		@(negedge clk) a <= 1;
		repeat(5) @(posedge clk, negedge clk);
		a <= 0;
		repeat(4) @(posedge clk);
	wavedrom_stop();

