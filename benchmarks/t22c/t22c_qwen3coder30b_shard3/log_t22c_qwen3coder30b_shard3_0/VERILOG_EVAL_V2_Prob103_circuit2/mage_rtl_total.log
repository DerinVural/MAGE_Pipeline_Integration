    // Which is equivalent to: q = (~a & ~b & ~c & ~d) | (a & b & ~c & ~d) | (a & ~b & c & ~d) | (a & ~b & ~c & d) | (~a & b & c & ~d) | (~a & b & ~c & d) | (~a & ~b & c & d) | (a & b & c & d)
    // Simpler form: q = (a == b) && (c == d)
    assign q = (a == b) && (c == d);

endmodule
