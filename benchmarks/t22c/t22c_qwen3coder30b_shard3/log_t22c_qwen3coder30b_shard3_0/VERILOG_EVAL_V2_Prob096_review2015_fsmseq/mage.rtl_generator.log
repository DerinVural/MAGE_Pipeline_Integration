ueue.delete(0);\n\t\t\tstart_shifting_got_queue.delete(0);\n\t\t\tstart_shifting_expected_queue.delete(0);\n\t\t\treset_queue.delete(0);\n\t\tend\n\n\t\tinput_queue.push_back(data);\n\t\tstart_shifting_got_queue.push_back(start_shifting_dut);\n\t\tstart_shifting_expected_queue.push_back(start_shifting_ref);\n\t\treset_queue.push_back(reset);\n\n\t\t// Check for first mismatch\n\t\tif (start_shifting_dut !== start_shifting_ref) begin\n\t\t\t$display("Mismatch detected at time %t", $time);\n\t\t\t$display("\\nLast %d cycles of simulation:");\n\n\n\t\t\tfor (int i = 0; i < input_queue.size(); i++) begin\n\t\t\t\tif (start_shifting_got_queue[i] === start_shifting_expected_queue[i]) begin\n\t\t\t\t\t$display("Got Match at");\n\t\t\t\tend else begin\n\t\t\t\t\t$display("Got Mismatch at");\n\t\t\t\tend\n\t\t\t\t$display("Cycle %d, reset %b, input %b, got output %b, exp output %b",\n\t\t\t\t\ti,\n\t\t\t\t\treset_queue[i],\n\t\t\t\t\tinput_queue[i],\n\t\t\t\t\tstart_shifting_got_queue[i],\n\t\t\t\t\tstart_shifting_expected_queue[i]\n\t\t\t\t);\n\t\t\tend\n\t\tend\n\tend\n\n\talways @(posedge clk, negedge clk) begin\n\n\t\tstats1.clocks++;\n\t\tif (!tb_match) begin\n\t\t\tif (stats1.errors == 0) stats1.errortime = $time;\n\t\t\tstats1.errors++;\n\t\tend\n\t\tif (start_shifting_ref !== ( start_shifting_ref ^ start_shifting_dut ^ start_shifting_ref ))\n\t\tpbegin if (stats1.errors_start_shifting == 0) stats1.errortime_start_shifting = $time;\n\t\t\tstats1.errors_start_shifting = stats1.errors_start_shifting+1\'b1; end\n\n\tend\n\n\t// add timeout after 100K cycles\n\tinitial begin\n\t\t#1000000\n\t\t$display("TIMEOUT");\n\t\t$finish();\n\tend\n\nendmodule\n</testbench>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nThe module interface is given below:\n<module_interface>\nmodule TopModule (\n    input clk,\n    input reset,\n    input data,\n    output start_shifting\n);\n</module_interface>\n')]), ChatMess