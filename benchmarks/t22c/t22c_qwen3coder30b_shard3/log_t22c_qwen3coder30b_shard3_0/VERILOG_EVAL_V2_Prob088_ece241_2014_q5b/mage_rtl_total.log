    // Define states using localparam
    localparam STATE_A = 2'b01;
    localparam STATE_B = 2'b10;

    // State register
    logic [1:0] state;
    logic [1:0] state_next;

    // Intermediate signal for output
    logic z_internal;

    // Initialize state register to reset state (A)
    initial begin
        state <= STATE_A;
    end

    // Sequential logic - Positive edge clock, asynchronous reset
    always @(posedge clk or posedge areset) begin
        if (areset)
            state <= STATE_A; // Reset to state A
        else
            state <= state_next;
    end

    // Combinational logic for next state
    always @(*) begin
        case (state)
            STATE_A: begin
                if (x)
                    state_next = STATE_B; // Transition to B
                else
                    state_next = STATE_A; // Stay in A
            end
            STATE_B: begin
                state_next = STATE_B; // Stay in B
            end
            default:
                state_next = STATE_A; // Default to A
        endcase
    end

    // Combinational logic for output
    always @(*) begin
        case (state)
            STATE_A: begin
                if (x)
                    z_internal = 1'b1;
                else
                    z_internal = 1'b0;
            end
            STATE_B: begin
                if (x)
                    z_internal = 1'b0;
                else
                    z_internal = 1'b1;
            end
            default:
                z_internal = 1'b0;
        endcase
    end

    // Continuous assignment to output
    assign z = z_internal;

endmodule
