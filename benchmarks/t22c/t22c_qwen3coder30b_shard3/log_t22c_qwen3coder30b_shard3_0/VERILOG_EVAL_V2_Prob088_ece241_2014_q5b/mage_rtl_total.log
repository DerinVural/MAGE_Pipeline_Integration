    // Define states using one-hot encoding
    localparam logic state_A = 1'b1;
    localparam logic state_B = 1'b0;

    // State register
    logic state_q;
    logic state_q_next;

    // Initialize state to A
    initial begin
        state_q = state_A;
    end

    // Sequential logic - state register
    always @(posedge clk or posedge areset) begin
