[2026-05-14 13:28:15,712 - mage.rtl_generator - INFO] RTL code: module TopModule (
    input clk,
    input areset,
    input x,
    output z
);

    // Define states
    localparam STATE_A = 0;
    localparam STATE_B = 1;

    // One-hot encoded state signals
    logic [1:0] state, state_next;

    // State register
    always @(posedge clk or posedge areset) begin
        if (areset)
            state <= 2'b01;  // Reset to state A
        else
            state <= state_next;
    end

    // Combinational logic for next state and output
    always @(*) begin
        // Default values
        state_next = state;
        z = 0;

        // State transition and output logic
        case (state)
            2'b01: begin  // State A
                if (x) begin
                    state_next = 2'b10;  // Transition to B
                    z = 1;
                end
                // Stay in A if x=0
            end
            2'b10: begin  // State B
                if (x) begin
                    state_next = 2'b10;  // Stay in B
                    z = 0;
                end else begin
                    state_next = 2'b10;  // Stay in B
                    z = 1;
                end
            end
        endcase
    end

