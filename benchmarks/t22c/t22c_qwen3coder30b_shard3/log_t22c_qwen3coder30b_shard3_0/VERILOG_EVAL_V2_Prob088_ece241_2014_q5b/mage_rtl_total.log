    // Define states using one-hot encoding
    localparam STATE_A = 2'b01;
    localparam STATE_B = 2'b10;

    // State register
    logic [1:0] state, state_next;

    // Initialize state to A
    initial begin
        state <= STATE_A;
    end

    // Asynchronous reset
    always @(posedge clk or posedge areset) begin
        if (areset)
            state <= STATE_A;
        else
            state <= state_next;
    end

    // Next state logic
    always @(*) begin
        case (state)
            STATE_A: begin
                if (x)
                    state_next = STATE_B;
                else
                    state_next = STATE_A;
            end
            STATE_B: begin
                // Regardless of x, stay in B
                state_next = STATE_B;
            end
            default:
                state_next = STATE_A;
        endcase
    end

    // Output logic
    always @(*) begin
        case (state)
            STATE_A: z = 1'b0;
            STATE_B: z = 1'b1; // Based on transition rules
            default: z = 1'b0;
        endcase
    end

endmodule
