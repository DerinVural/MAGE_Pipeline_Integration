    input clk,
    input areset,
    input x,
    output z
);

    // Define states using localparam
    localparam STATE_A = 1'b1;
    localparam STATE_B = 1'b0;

    // State register
    logic [1:0] state;
    logic [1:0] state_next;

    // Initialize state register to reset state (A)
    initial begin
        state <= {STATE_A, STATE_B};
    end

    // Sequential logic - Positive edge clock, asynchronous reset
    always @(posedge clk or posedge areset) begin
        if (areset)
            state <= {STATE_A, STATE_B}; // Reset to state A
        else
            state <= state_next;
    end

    // Combinational logic for next state
    always @(*) begin
        case (state)
            {STATE_A, STATE_B}: begin
                if (x)
                    state_next = {STATE_B, STATE_A}; // Transition to B
                else
                    state_next = {STATE_A, STATE_B}; // Stay in A
            end
            {STATE_B, STATE_A}: begin
                state_next = {STATE_B, STATE_A}; // Stay in B
            end
            default:
                state_next = {STATE_A, STATE_B}; // Default to A
        endcase
    end

    // Combinational logic for output
    always @(*) begin
        case (state)
            {STATE_A, STATE_B}: begin
                if (x)
                    z = 1'b1;
                else
                    z = 1'b0;
            end
            {STATE_B, STATE_A}: begin
                if (x)
                    z = 1'b0;
                else
                    z = 1'b1;
            end
            default:
                z = 1'b0;
        endcase
    end

endmodule
