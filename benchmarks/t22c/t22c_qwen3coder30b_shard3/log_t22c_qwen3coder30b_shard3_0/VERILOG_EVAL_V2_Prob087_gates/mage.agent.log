        @(posedge clk) {a,b} <= 0;
        @(posedge clk) {a,b} <= 1;
        @(posedge clk) {a,b} <= 2;
        @(posedge clk) {a,b} <= 3;
        @(negedge clk);
    wavedrom_stop();
    repeat(200) @(posedge clk, negedge clk)
    {a,b} <= $random;
    $finish;
end

