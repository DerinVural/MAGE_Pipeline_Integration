generate
	for (genvar i = 0; i < 7; i++) begin : gen_out_ports
		if (i == 0) begin : gen_and
			assign out_and_ref = a & b;
			assign out_and_dut = a & b;
		end
		else if (i == 1) begin : gen_or
			assign out_or_ref = a | b;
			assign out_or_dut = a | b;
		end
		else if (i == 2) begin : gen_xor
			assign out_xor_ref = a ^ b;
			assign out_xor_dut = a ^ b;
		end
		else if (i == 3) begin : gen_nand
			assign out_nand_ref = ~(a & b);
			assign out_nand_dut = ~(a & b);
		end
		else if (i == 4) begin : gen_nor
			assign out_nor_ref = ~(a | b);
			assign out_nor_dut = ~(a | b);
		end
		else if (i == 5) begin : gen_xnor
			assign out_xnor_ref = ~(a ^ b);
			assign out_xnor_dut = ~(a ^ b);
		end
		else if (i == 6) begin : gen_anotb
			assign out_anotb_ref = a & ~b;
			assign out_anotb_dut = a & ~b;
		end
	end
