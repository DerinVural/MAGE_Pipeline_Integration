	if (stats1.errors == 1 && !tb_match) begin
		$display("First mismatch at time %0d:", $time);
		$display("  Input: %b (%h)", in, in);
		$display("  Got Output: %b (%h)", pos_dut, pos_dut);
		$display("  Expected Output: %b (%h)", pos_ref, pos_ref);
	end

end

// add timeout after 100K cycles
initial begin
	#1000000
	$display("TIMEOUT");
	$finish();
end

endmodule
