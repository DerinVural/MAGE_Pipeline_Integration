    input clk,
    input enable,
    input S,
    input A,
    input B,
    input C,
    output logic Z
);

    // 8-bit shift register
    logic [7:0] Q;
    
    // Initialize shift register to 0
    initial begin
        Q = 8'b0;
    end
    
    // Shift register behavior
    always @(posedge clk) begin
        if (enable) begin
            Q[7] <= Q[6];
            Q[6] <= Q[5];
            Q[5] <= Q[4];
            Q[4] <= Q[3];
            Q[3] <= Q[2];
            Q[2] <= Q[1];
            Q[1] <= Q[0];
            Q[0] <= S;
        end
    end
    
    // Multiplexer to select output based on A, B, C
    always @(*) begin
        case ({A,B,C})
            3'b000: Z = Q[0];
            3'b001: Z = Q[1];
            3'b010: Z = Q[2];
            3'b011: Z = Q[3];
            3'b100: Z = Q[4];
            3'b101: Z = Q[5];
            3'b110: Z = Q[6];
            3'b111: Z = Q[7];
            default: Z = 1'bX;
        endcase
    end

