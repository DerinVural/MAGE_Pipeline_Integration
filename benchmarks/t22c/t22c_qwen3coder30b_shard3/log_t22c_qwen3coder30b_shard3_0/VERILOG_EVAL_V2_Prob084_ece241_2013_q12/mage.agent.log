task wavedrom_start(input[511:0] title = "");
	endtask
	
ntask wavedrom_stop;
	#1;
endtask	



initial begin
	enable <= 0;
	{A,B,C} <= 0;
	S <= 1'bx;
	@(negedge clk) wavedrom_start("A 3-input AND gate");
		@(posedge clk);
		@(posedge clk) enable <= 1; S <= 1;
		@(posedge clk) S <= 0;
		@(posedge clk) S <= 0;
		@(posedge clk) S <= 0;
