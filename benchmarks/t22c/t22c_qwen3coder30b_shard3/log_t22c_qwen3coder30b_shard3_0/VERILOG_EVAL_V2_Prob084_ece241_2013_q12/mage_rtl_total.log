[2026-05-14 13:05:29,075 - mage.rtl_generator - INFO] RTL code: module TopModule (
    input clk,
    input enable,
    input S,
    input A,
    input B,
    input C,
    output Z
);

    // 8-bit shift register
    logic [7:0] Q;

    // Sequential logic for shift register
    always @(posedge clk) begin
        if (enable)
            Q <= {S, Q[7:1]};
    end

    // Combinational logic for multiplexer
    always @(*) begin
        case ({C, B, A})
            3'b000: Z = Q[0];
            3'b001: Z = Q[1];
            3'b010: Z = Q[2];
            3'b011: Z = Q[3];
            3'b100: Z = Q[4];
            3'b101: Z = Q[5];
            3'b110: Z = Q[6];
            3'b111: Z = Q[7];
            default: Z = 1'bx;
        endcase
    end

endmodule
