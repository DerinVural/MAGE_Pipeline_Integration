[2026-05-14 13:07:06,904 - mage.rtl_generator - INFO] RTL code: module TopModule (
    input clk,
    input enable,
    input S,
    input A,
    input B,
    input C,
    output Z
);

    // Shift register
    logic [7:0] Q;

    // Shift register flip-flops
    always @(posedge clk) begin
        if (enable)
            Q <= {S, Q[7:1]};
    end

    // Multiplexer to select output based on A, B, C
    always @(*) begin
        case ({C, B, A})
            3'b000: Z = Q[0];
            3'b001: Z = Q[1];
            3'b010: Z = Q[2];
            3'b011: Z = Q[3];
            3'b100: Z = Q[4];
            3'b101: Z = Q[5];
            3'b110: Z = Q[6];
            3'b111: Z = Q[7];
            default: Z = 1'bX; // Default case for undefined values
        endcase
    end

endmodule
