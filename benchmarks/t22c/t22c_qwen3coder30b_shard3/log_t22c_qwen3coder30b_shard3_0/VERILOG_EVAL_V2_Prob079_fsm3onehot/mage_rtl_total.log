	// Queue-based simulation mismatch display
	reg [3:0] input_queue [$];
	reg [3:0] got_next_state_queue [$];
	reg [3:0] golden_next_state_queue [$];
	reg got_out_queue [$];
	reg golden_out_queue [$];
	reg [3:0] state_queue [$];
	
	localparam MAX_QUEUE_SIZE = 8;

	always @(posedge clk, negedge clk) begin
		if (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin
			input_queue.delete(0);
