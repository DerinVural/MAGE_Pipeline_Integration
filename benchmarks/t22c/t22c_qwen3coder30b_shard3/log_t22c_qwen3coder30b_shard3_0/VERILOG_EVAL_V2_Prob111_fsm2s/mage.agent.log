	reset_test();
	for (int i=0;i<12;i++)
		@(posedge clk) {k, j} <= d[i];
	wavedrom_stop();
	repeat(200) @(posedge clk, negedge clk) begin
		{j,k} <= $random;
		reset <= !($random & 7);
	end

	#1 $finish;
end

