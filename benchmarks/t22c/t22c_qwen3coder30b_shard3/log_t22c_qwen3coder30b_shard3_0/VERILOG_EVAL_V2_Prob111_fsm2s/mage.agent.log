	$dumpvars(1, stim1.clk, tb_mismatch ,clk,j,k,reset,out_ref,out_dut );
end


typedef struct {
	logic j;
	logic k;
	logic reset;
	logic out;
	logic out_expected;
} sample;

sample queue[$];
parameter MAX_QUEUE_SIZE = 5;

wire tb_match;          // Verification
wire tb_mismatch = ~tb_match;

stimulus_gen stim1 (
	.clk,
	.* ,
	.j,
	.k,
	.reset );
