module TopModule (
    input clk,
    input reset,
    input in,
    output out
);

	reg [1:0] current_state;

	localparam STATE_A = 2'b01;
	localparam STATE_B = 2'b10;

	always @(posedge clk or posedge reset) begin
		if (reset) begin
			current_state <= STATE_B;
		end else begin
			case (current_state)
				STATE_B: begin
					if (in == 1'b0)
						current_state <= STATE_A;
					// else stay in STATE_B
				end
				STATE_A: begin
					if (in == 1'b0)
						current_state <= STATE_B;
					// else stay in STATE_A
				end
			endcase
		end
	end

	always @(*) begin
		case (current_state)
			STATE_A: out = 1'b0;
			STATE_B: out = 1'b1;
			default: out = 1'b0;
		endcase
	end

endmodule

