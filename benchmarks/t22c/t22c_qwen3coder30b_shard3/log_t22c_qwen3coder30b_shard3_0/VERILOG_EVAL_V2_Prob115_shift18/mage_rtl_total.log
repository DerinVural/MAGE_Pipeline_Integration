		ena <= |($random & 15);
		amount <= $random;
		data <= {$random,$random};
	end
	#1 $finish;
end

endmodule

module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_q;
		int errortime_q;

		int clocks;
	} stats;

