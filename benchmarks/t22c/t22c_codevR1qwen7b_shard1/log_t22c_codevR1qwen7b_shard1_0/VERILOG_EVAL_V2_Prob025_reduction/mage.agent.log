            error_count++;
        end
        if (parity_ref !== (parity_ref ^ parity_dut ^ parity_ref)) begin // Parity check condition for even parity
            if (error_parity == 0) error_time_parity = $time;
            error_parity = error_parity + 1;
        end

        // Store previous values for mismatch display
        if ($time > 0) begin
            in_queue[in_queue.size()] = in_tb;
            exp_parity[exp_parity.size()] = parity_ref;
