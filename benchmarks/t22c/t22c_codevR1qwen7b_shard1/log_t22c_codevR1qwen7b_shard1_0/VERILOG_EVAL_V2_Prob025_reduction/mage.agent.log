            reset_queue[reset_queue.size()] = reset_count;
        end

        // Queue management
        if ($time > 0 && (in_queue.size() >= MAX_QUEUE_SIZE)) begin
            in_queue.delete(0);
            exp_parity.delete(0);
            got_parity.delete(0);
            reset_queue.delete(0);
        end

        // Check for first mismatch
        if (parity_ref !== parity_dut && error_count == 1) begin
            $display("Mismatch detected at time %t", $time);
