            end
            $finish;
        end

        // Update in_tb each cycle
        in_tb = $urandom;
    end

    // Timeout after 100K cycles
    initial #100000 $display("TIMEOUT"); $finish;

    // Dump VCD if needed
    initial begin
        $dumpfile("wave.vcd");
        $dumpvars(1, tb);
    end
endmodule

