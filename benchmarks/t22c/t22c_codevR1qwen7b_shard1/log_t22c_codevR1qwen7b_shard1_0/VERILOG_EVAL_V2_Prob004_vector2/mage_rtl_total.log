    "testbench": "`timescale 1ps/1ps\nmodule tb();\n    typedef struct packed {\n        int errors;\n        int errortime;\n        int errors_out;\n        int errortime_out;\n        int clocks;\n    } stats;\n    stats stats1;\n    logic clk = 0;\n    initial forever #5 clk = ~clk;\n    logic [31:0] in;\n    logic [31:0] out_ref;\n    logic [31:0] out_dut;\n    logic [511:0] wavedrom_title;\n    logic wavedrom_enable;\n    // Instantiate DUT and RefModule with all ports from golden testbench\n    TopModule top_module_inst (.clk(clk), .in(in), .out(out_dut), .wavedrom_title(wavedrom_title), .wavedrom_enable(wavedrom_enable));\n    RefModule ref_module_inst (.clk(clk), .in(in), .out(out_ref), .wavedrom_title(wavedrom_title), .wavedrom_enable(wavedrom_enable));\n    // Wait for initial clock edge and allow some cycles to settle\n    reg [31:0] prev_time;\n    initial begin\n        prev_time = 0;\n        stats1 = stats'(0, 0, 0, 0, 0);\n        in = 0;\n        #10; // Allow initial state to stabilize\n        // Generate inputs in the golden testbench's style\n        repeat(10) begin\n            @(negedge clk);\n            in = $random;\n        end\n        repeat(100) @(negedge clk);\n        $finish;\n    end\n    // Error checking\n    always @(negedge clk) begin\n        stats1.clocks++;\n        if (out_ref !== out_dut) begin\n            if (stats1.errors == 0) stats1.errortime = $time - 20; // Adjust time calculation to align with clock edge\n            stats1.errors++;\n        end\n        if (out_ref !== out_dut) begin\n            if (stats1.errors_out == 0) stats1.errortime_out = $time - 20;\n            stats1.errors_out++;\n        end\n    end\n    // Simulation end and display messages\n    reg [31:0] end_time;\n    initial begin\n        @(posedge clk until $time > 1000000);\n        #1; // Allow final error counts to be logged\n        if (stats1.errors == 0 && stats1.errors_out == 0) begin\n            $display("    		 	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	                                                                                    	
