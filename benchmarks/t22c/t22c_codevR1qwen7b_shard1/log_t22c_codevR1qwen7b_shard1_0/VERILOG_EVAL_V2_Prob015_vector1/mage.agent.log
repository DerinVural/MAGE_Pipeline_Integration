    localparam MAX_QUEUE_SIZE = 5;
    reg [15:0] in_queue [0:MAX_QUEUE_SIZE-1];
    reg [7:0] got_out_hi_queue [0:MAX_QUEUE_SIZE-1];
    reg [7:0] exp_out_hi_queue [0:MAX_QUEUE_SIZE-1];
    reg [7:0] got_out_lo_queue [0:MAX_QUEUE_SIZE-1];
    reg [7:0] exp_out_lo_queue [0:MAX_QUEUE_SIZE-1];
    reg [0:0] has_mismatch;

    // Reference module and DUT instantiations
    RefModule ref_inst (.in(in), .out_hi(out_hi_ref), .out_lo(out_lo_ref));
