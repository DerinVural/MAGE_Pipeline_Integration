[2026-05-14 11:48:53,237 - mage.agent - INFO] `timescale 1ps/1ps

module tb();
    typedef struct packed {
        int errors;
        int errortime;
        int errors_q;
        int errortime_q;
        int clocks;
    } stats;
    stats stats1 = {0, 0, 0, 0, 0};

    reg clk = 0;
    logic d;
    logic q_ref, q_dut;

    // Clock generation
    initial forever #5 clk = ~clk;

    // Instantiate DUT and ref module
    RefModule good1 (
        .clk(clk),
        .d(d),
        .q(q_ref)
    );
    TopModule top_module1 (
        .clk(clk),
        .d(d),
        .q(q_dut)
    );

    // Mismatch detection and queue
    reg [2:0] q_queue [0:1]; // 2 entries (1-bit state, 2 possible states, MAX_QUEUE_SIZE=2)
    reg [1:0] q_expected_queue [0:1];
    reg [1:0] q_got_queue [0:1];
    integer queue_ptr = 0;
    integer max_queue_size = 2;

    always @(posedge clk, negedge clk) begin
        if (stats1.errors == 0 && q_ref !== q_dut) begin
            $display("Mismatch detected at time %t", $time);
            $display("Last %d cycles of simulation: ", queue_ptr + 1);
            for (int i = 0; i <= queue_ptr; i++) begin
                $display("Cycle %d: clk=%b, d=%b, q_expected=%b, q_got=%b", i, q_queue[i], q_queue[i], q_expected_queue[i], q_got_queue[i]);
            end
        end
        if (q_ref !== q_dut) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors += 1;
        end
        if (stats1.errors_q == 0 && q_ref !== q_dut) begin
            stats1.errortime_q = $time;
            stats1.errors_q += 1;
        end
    end

    // Simulation control
    initial begin
        // Simulation timeout after 100000 cycles
        #1000000 $display("TIMEOUT"); $finish();
    end

    initial begin
        // Wait for some cycles before finish
        #500000;
        // Check errors and finish simulation
        if (stats1.errors) begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
        end else begin
            $display("SIMULATION PASSED");
        end
        $finish;
