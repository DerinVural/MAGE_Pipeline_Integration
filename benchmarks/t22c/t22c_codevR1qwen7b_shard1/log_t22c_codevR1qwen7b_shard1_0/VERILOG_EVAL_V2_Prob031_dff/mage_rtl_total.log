module tb();
    typedef struct {
        int errors;
        int errortime;
        int errors_q;
        int errortime_q;
        int clocks;
    } stats;
    stats stats1 = {0, 0, 0, 0, 0};

    reg clk = 0;
    logic d;
    logic q_ref;
    logic q_dut;

    initial forever #5 clk = ~clk;

    // Clock generation
    initial begin
        d = 0;
        #10 d = 1;
        #10 d = 0;
        #1000 $finish;
    end

    // Stimulus
    initial begin
        // Instantiate the modules
        TopModule top_module1 (clk, d, q_dut);
        RefModule good1 (clk, d, q_ref);

        // Wait for some clock edges
        @(posedge clk); // Wait for first edge
        @(posedge clk);
        @(posedge clk);

        // Check data
        stats1.clocks = 3; // Assuming 3 cycles checked
        if (q_ref !== q_dut) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
        end
        if (q_ref !== q_dut) begin
            if (stats1.errors_q == 0) stats1.errortime_q = $time;
            stats1.errors_q++;
        end

        $finish;
    end

    // Final report
    final begin
        if (stats1.errors_q)
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_q, stats1.errortime_q);
        else
            $display("SIMULATION PASSED");
        $display("Simulation finished at %0d ps", $time);
        $display("Mismatches: %0d in %0d samples", stats1.errors, stats1.clocks);
