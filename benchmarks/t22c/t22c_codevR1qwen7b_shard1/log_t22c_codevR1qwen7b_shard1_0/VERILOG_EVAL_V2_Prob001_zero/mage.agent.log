        int errortime;
        int errors_zero;
        int errortime_zero;
        int clocks;
    } stats;
    stats stats1;
    wire [511:0] wavedrom_title;
    wire wavedrom_enable;
    reg clk = 0;
    initial forever #5 clk = ~clk;
    logic zero_ref;
    logic zero_dut;
    wire tb_match = ( {zero_ref} === ( {zero_ref} ^ {zero_dut} ^ {zero_ref} ) );
    assign tb_match = ( {zero_ref} === ( {zero_ref} ^ {zero_dut} ^ {zero_ref} ) );
    always @(posedge clk, negedge clk) begin
        stats1.clocks++;
        if (!tb_match) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
        end
        if (zero_ref !== (zero_ref ^ zero_dut ^ zero_ref)) begin
            if (stats1.errors_zero == 0) stats1.errortime_zero = $time;
            stats1.errors_zero++;
        end
    end
    stimulus_gen stim1 (
        .clk(clk),
        .wavedrom_title(wavedrom_title),
        .wavedrom_enable(wavedrom_enable)
    );
    RefModule good1 (.zero(zero_ref));
    TopModule top_module1 (.zero(zero_dut));
