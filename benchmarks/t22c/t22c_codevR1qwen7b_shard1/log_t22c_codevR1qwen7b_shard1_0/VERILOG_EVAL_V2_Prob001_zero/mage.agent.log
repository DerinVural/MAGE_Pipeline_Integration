        $dumpvars(1, stim1.clk, tb_mismatch, zero_ref, zero_dut);
    end
    initial begin
        #1000000 $display("TIMEOUT"); $finish();
    end
    final begin
        if (stats1.errors_zero) begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_zero, stats1.errortime_zero);
        end else begin
            $display("SIMULATION PASSED");
        end
    end
endmodule

