        if (out !== out_ref) begin
            if (errors == 0) errortime = $time;
            errors++;
        end
        clocks++;
    end
    // Display results at end
    final begin
        if (errors) begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", errors, errortime);
        end else begin
            $display("SIMULATION PASSED");
        end
    end
    // Timeout after 100000 time units
    initial begin
        #100000 $display("TIMEOUT");
        $finish;
    end
endmodule
