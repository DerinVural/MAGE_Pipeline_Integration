module tb();
    reg clk = 0;
    initial forever #5 clk = ~clk;
    logic [7:0] in;
    logic [7:0] out_ref, out_dut;
    logic [7:0] out;
    // Wavedrom signals (original testbench had them, need to include)
    logic [511:0] wavedrom_title;
    logic wavedrom_enable;
    logic [511:0] wavedrom_title_reg = 0;
    assign wavedrom_title = wavedrom_title_reg;
    assign wavedrom_enable = 1;
    // Instantiate DUT and reference module
    TopModule top_module1(.clk(), .in(in), .out(out)); // Adjusted based on previous TB structure if needed
    RefModule good1(.clk(), .in(in), .out(out_ref)); // Assuming RefModule has same ports
    // Error counting variables
    int errors = 0, errortime = -1, clocks = 0;
    int errors_out = 0, errortime_out = -1;
    // Wait for a few cycles
    initial begin
        @(negedge clk);
    end
    // Generate loop for bit reversal (maybe part of the DUT?)
    // Alternatively, use the generate block in DUT, assuming it's correct now
    // For testbench, focus on checking output
    // Check after each posedge and negedge? Or specific clock edges
