        $display(\"Input: %b, Expected Output: %b, Got: %b\", input_queue, golden_queue, got_output_queue);\n            $display(\"Simulation FAILED - %d MISMATCHES DETECTED, FIRST AT TIME %t\", stats1.errors, stats1.errortime);\n        end else begin\n            $display(\"Simulation PASSED\");\n        end\n        $finish;\n    end\nendmodule"
