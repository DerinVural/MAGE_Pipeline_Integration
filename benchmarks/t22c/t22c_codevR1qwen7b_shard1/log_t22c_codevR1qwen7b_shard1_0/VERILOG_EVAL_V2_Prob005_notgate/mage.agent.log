module tb();
    typedef struct packed { int errors; int errortime; int errors_out; int errortime_out; int clocks; } stats;
    stats stats1 = {0, 0, 0, 0, 0};

    reg clk = 0;
    initial forever #5 clk = ~clk;

    logic in;
    logic out_ref;
    logic out_dut;
    wire tb_match = ( {out_ref} === ( {out_ref} ^ {out_dut} ^ {out_ref} ) );

    stimulus_gen stim1 ( .clk(clk), .in(in) );
    TopModule top_module1 ( .in(in), .out(out_dut) );
    RefModule good1 ( .in(in), .out(out_ref) );

    always @(posedge clk, negedge clk) begin
        stats1.clocks++;
        if (!tb_match) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
        end
        if (out_ref !== (out_ref ^ out_dut ^ out_ref)) begin
            if (stats1.errors_out == 0) stats1.errortime_out = $time;
            stats1.errors_out++;
        end
    end

    final begin
        if (stats1.errors_out)
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_out, stats1.errortime_out);
        else
            $display("SIMULATION PASSED");
        if (stats1.errors > 0 && stats1.errortime != 0)
            $display("First Mismatch at time %0d: in=%b out=%b expected=%b", stats1.errortime, in, out_dut, out_ref);
    end

    initial begin #1000000; $display("TIMEOUT"); $finish; end
endmodule

module stimulus_gen( input clk, output reg in );
    task wavedrom_start( input [511:0] title = "" ); endtask
    task wavedrom_stop; #1; endtask

    initial begin
        in = 0;
        wavedrom_start("Inversion");
        repeat(20) @(posedge clk) in = $random;
        wavedrom_stop();
        repeat(200) @(posedge clk, negedge clk) in = $random;
        #1 $finish;
    end
endmodule

module RefModule( input in, output out );
    assign out = ~in;
endmodule
