        initial begin in <=0; wavedrom_start("Inversion"); repeat(20) @(posedge clk) in <= $random; wavedrom_stop(); repeat(200) @(posedge clk, negedge clk) in <= $random; #1 $finish; end
    endmodule
    module RefModule (input in, output out); assign out = ~in; endmodule
