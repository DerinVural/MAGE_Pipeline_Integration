    RefModule good1 ( .in(in), .out(out_ref) );
    TopModule top_module1 ( .in(in), .out(out_dut) );
    bit strobe = 0; task wait_for_end_of_timestep; repeat(5) begin strobe <= !strobe; @(strobe); end endtask
