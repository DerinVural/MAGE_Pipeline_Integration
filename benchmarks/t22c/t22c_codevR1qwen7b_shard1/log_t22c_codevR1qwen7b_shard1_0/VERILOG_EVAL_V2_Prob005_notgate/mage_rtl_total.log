endmodule

module stimulus_gen( input clk, output reg in );
    task wavedrom_start( input [511:0] title = "" ); endtask
    task wavedrom_stop; #1; endtask

    initial begin
        in = 0;
        wavedrom_start("Inversion");
        repeat(20) @(posedge clk) in = $random;
        wavedrom_stop();
        repeat(200) @(posedge clk, negedge clk) in = $random;
        #1 $finish;
    end
endmodule

module RefModule( input in, output out );
    assign out = ~in;
endmodule
