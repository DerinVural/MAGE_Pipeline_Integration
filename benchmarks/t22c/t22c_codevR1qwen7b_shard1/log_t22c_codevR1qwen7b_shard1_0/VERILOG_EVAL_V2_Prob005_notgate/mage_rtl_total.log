module tb();
    typedef struct packed {
        int errors;
        int errortime;
        int errors_out;
        int errortime_out;
        int clocks;
    } stats;
    stats stats1 = {0, 0, 0, 0, 0};
    wire [511:0] wavedrom_title;
    reg wavedrom_enable;
    reg clk = 0;
    initial forever #5 clk = ~clk;
    logic in;
    logic out_ref, out_dut;
    // Connect to DUT
    TopModule top_module1(.in(in), .out(out_dut));
    RefModule good1(.in(in), .out(out_ref));
    // Error detection
    wire tb_match = ( {out_ref} === ( {out_ref} ^ {out_dut} ^ {out_ref} ) );
    // Queue variables
    reg [1:0] input_queue;
    reg [0:0] got_output_queue, golden_queue;
    reg reset_queue;
    localparam MAX_QUEUE_SIZE = 2;
    // Queue management
    always @(posedge clk, negedge clk) begin
        input_queue <= {in, input_queue[1]};
        got_output_queue <= out_dut;
        golden_queue <= out_ref;
        reset_queue <= 0;
        stats1.clocks++;
        if (!tb_match) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
        end
        if (out_dut !== out_ref) begin
            if (stats1.errors_out == 0) stats1.errortime_out = $time;
            stats1.errors_out++;
        end
    end
    // Display on first mismatch
    always @(negedge clk) begin
        if (stats1.errors) begin
            $display("First mismatch at time %t", stats1.errortime);
            $display("Input: %b, Expected Output: %b, Got: %b", input_queue, golden_queue, got_output_queue);
            $display("Simulation FAILED - %d MISMATCHES DETECTED, FIRST AT TIME %t", stats1.errors, stats1.errortime);
        end else begin
            $display("Simulation PASSED");
        end
        $finish;
    end
endmodule
