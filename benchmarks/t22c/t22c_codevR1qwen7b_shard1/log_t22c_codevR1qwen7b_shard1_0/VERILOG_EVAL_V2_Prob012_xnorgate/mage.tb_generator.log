T TIME %0d\", stats1.errors, stats1.errortime);\n            else $display(\"SIMULATION FAILED - 1 MISMATCH DETECTED AT TIME %0d\", stats1.errortime);\n        end else begin\n            $display(\"SIMULATION PASSED\");\n        end\n    end\nendmodule"
