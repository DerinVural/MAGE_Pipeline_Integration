[2026-05-14 11:11:24,112 - mage.agent - INFO] `timescale 1ps/1ps
module tb();
	typedef struct packed {
		int errors;
		int errortime;
		int errors_out;
		int errortime_out;
		int clocks;
	} stats;
	stats stats1 = '0;

	reg clk = 0;
	initial forever #5 clk = ~clk;

	reg a, b;
	wire out_ref, out_dut;

	// Clock generation and stimulus
	sample_stim stim1 (.clk(clk), .a(a), .b(b));

	assign out_ref = a ~^ b;
	TopModule top_inst (.a(a), .b(b), .out(out_dut));

	reg strobe = 0;
	task wait_for_stable; repeat(5) begin strobe <= !strobe; @(posedge clk); end endtask

	// Error checking
	initial begin
		stats1.clocks = 0;
		stats1.errors = 0;
		stats1.errortime = -1;
		stats1.errors_out = 0;
		stats1.errortime_out = -1;
		wait_for_stable();
	end

	always @(posedge clk) begin
		stats1.clocks++;
		if (out_ref !== out_dut) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
		end
		if (out_dut !== (a ~^ b)) begin
			if (stats1.errors_out == 0) stats1.errortime_out = $time;
			stats1.errors_out++;
		end
	end

	// Timeout and finish
	initial begin
		s#1000000 $display("TIMEOUT"); $finish;
	end

	// Simulation end
	event end_sim;
	initial begin
		wait fork; // Wait for all threads
		if (stats1.errors) begin
			display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
		end else begin
			display("SIMULATION PASSED");
		end
		-> end_sim;
	end

endmodule

// Sample stimulus module
class sample_stim extends uvm_test; // Hypothetical class if allowed
	random a_rnd, b_rnd;
	task run_phase(uvm_phase phase); // Simplified example
		repeat(20) begin
			randomize(a_rnd, b_rnd);
			@(posedge clk); // Wait for clock edge
			a <= a_rnd;
			b <= b_rnd;
		end
	endtask
endclass
