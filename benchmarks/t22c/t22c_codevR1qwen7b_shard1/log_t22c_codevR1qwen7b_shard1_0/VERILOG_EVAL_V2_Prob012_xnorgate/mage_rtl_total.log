module tb();
    typedef struct packed {
        int errors;
        int errortime;
        int errors_out;
        int errortime_out;
        int clocks;
    } stats;
    stats stats1;

    wire [511:0] wavedrom_title;
    wire wavedrom_enable;
    reg clk = 0;
    initial forever #5 clk = ~clk;
    logic a;
    logic b;
    logic out_ref;
    logic out_dut;

    // Instantiate modules
    RefModule good1 (
        .a(a),
        .b(b),
        .out(out_ref)
    );
    TopModule top_module1 (
        .a(a),
        .b(b),
        .out(out_dut)
    );

    // Mismatch logic
    wire tb_match = (out_ref === (out_ref ^ out_dut ^ out_ref));

    // Mismatch detection and queue storage
    localparam MAX_QUEUE_SIZE = 5;
    reg [1:0] input_queue [$];
    reg [0:0] got_output_queue [$];
    reg [0:0] golden_queue [$];
    reg reset_queue [$];

    reg strobe = 0;
    task wait_for_end_of_timestep;
        repeat(5) begin strobe <= !strobe; @(strobe); end
    endtask

    // Wait for simulation to stabilize
    wait_for_end_of_timestep();

    always @(posedge clk, negedge clk) begin
        stats1.clocks++;
        if (!tb_match) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
        end
        // Output check logic
        if (out_ref !== (out_ref ^ out_dut ^ out_ref)) begin
            if (stats1.errors_out == 0) stats1.errortime_out = $time;
            stats1.errors_out++;
        end
        // Queue management
        if (input_queue.size() >= MAX_QUEUE_SIZE-1) begin
            input_queue.delete(0);
            got_output_queue.delete(0);
            golden_queue.delete(0);
            reset_queue.delete(0);
        end
        input_queue.push_back({a, b});
        got_output_queue.push_back(out_dut);
        golden_queue.push_back(out_ref);
        reset_queue.push_back(0); // Assuming no reset in this module
    end

    // Simulation end and display
    initial begin
        $dumpfile("wave.vcd");
        $dumpvars(1, tb);
    end

    initial begin
        // Timeout after 1e6 ps
        #1000000 $display("TIMEOUT"); $finish();
    end

    initial begin
        // Wait for initial conditions
        #0;
        // Mismatch display handling
        if (stats1.errors_out) begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0t", stats1.errors_out, stats1.errortime_out);
        end else begin
            $display("SIMULATION PASSED");
        end
    end
endmodule
