module tb();
    typedef struct packed {
        int errors;
        int errortime;
        int errors_out;
        int errortime_out;
        int clocks;
    } stats;

    stats stats1;

    wire clk;
    reg clk_reg = 0;
    initial forever #5 clk_reg = ~clk_reg;
    assign clk = clk_reg;

    logic in1, in2, in3;
    logic out_ref, out_dut;

    // Stimulus generation
    stimulus_gen stim1 (
        .clk(clk),
        .in1(in1),
        .in2(in2),
        .in3(in3)
    );

    // Reference module and DUT
    RefModule good1 (
        .in1(in1),
        .in2(in2),
        .in3(in3),
        .out(out_ref)
    );

    TopModule top_module1 (
        .in1(in1),
        .in2(in2),
        .in3(in3),
        .out(out_dut)
    );

    // Match checking
    wire tb_match = ( {out_ref} === ( {out_ref} ^ {out_dut} ^ {out_ref} ) );
    wire tb_mismatch = ~tb_match;

    // Mismatch counting and queue for display
    reg [2:0] input_queue [0:4]; // MAX_QUEUE_SIZE 5
    reg [3:0] got_output_queue [0:4];
    reg [3:0] golden_queue [0:4];
    reg [0:4] reset_queue;

    localparam MAX_QUEUE_SIZE = 5;
    integer idx;

    always @(posedge clk, negedge clk) begin
        // Queue management
        if (input_queue[0] !== 'bx) begin
            for (idx = 0; idx < MAX_QUEUE_SIZE-1; idx = idx + 1) begin
                input_queue[idx] = input_queue[idx+1];
                got_output_queue[idx] = got_output_queue[idx+1];
                golden_queue[idx] = golden_queue[idx+1];
                reset_queue[idx] = reset_queue[idx+1];
            end
        end
        input_queue[MAX_QUEUE_SIZE-1] = {in1, in2, in3}; // 3 bits stored
        got_output_queue[MAX_QUEUE_SIZE-1] = out_dut;
        golden_queue[MAX_QUEUE_SIZE-1] = out_ref;
        reset_queue[MAX_QUEUE_SIZE-1] = 1'b0; // Assuming no reset in combinational testbench

        // Check for mismatch
        if (!tb_match && stats1.errors == 0) begin
            $display("Mismatch detected at time %t", $time);
            $display("\nLast %d cycles of simulation:", MAX_QUEUE_SIZE);
            for (idx = 0; idx < MAX_QUEUE_SIZE; idx = idx + 1) begin
                if (idx == MAX_QUEUE_SIZE-1)
                    $display("Got Mismatch at");
                else
                    $display("Got Match at");
                $display("Cycle %0d, inputs %b, got output %h, expected %h", idx, input_queue[idx], got_output_queue[idx], golden_queue[idx]);
            end
        end
        stats1.clocks++;
        if (!tb_match) stats1.errors++;
        if (out_dut !== out_ref) begin
            if (stats1.errors_out == 0) stats1.errortime_out = $time;
            stats1.errors_out++;
        end
    end

    // Simulation control
    initial begin
        stats1 = '{errors:0, errortime:0, errors_out:0, errortime_out:0, clocks:0};
    end

    initial begin
        // Run for a few clock cycles
        #200;
        $finish;
    end

    initial begin
        if (stats1.errors_out == 0) begin
            $display("SIMULATION PASSED");
        end else begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0t", stats1.errors_out, stats1.errortime_out);
        end
    end
endmodule

module stimulus_gen (
    input clk,
    output logic in1,
    output logic in2,
    output logic in3
);
    initial begin
        repeat(40) @(posedge clk, negedge clk) begin
            {in1, in2, in3} <= $random;
        end
        #1 $finish;
    end
endmodule

module RefModule (
    input in1, in2, in3,
    output out
);
    // Reference implementation for XOR and XNOR logic
    assign out = ( ~( ~in1 ~^ ~in2 ) ) ^ in3; // XNOR followed by XOR with in3
endmodule

module TopModule (
    input in1, in2, in3,
    output out
);
    wire xnor_out = ~( ~in1 ~^ ~in2 ); // XNOR of in1 and in2
    assign out = xnor_out ^ in3;
endmodule
