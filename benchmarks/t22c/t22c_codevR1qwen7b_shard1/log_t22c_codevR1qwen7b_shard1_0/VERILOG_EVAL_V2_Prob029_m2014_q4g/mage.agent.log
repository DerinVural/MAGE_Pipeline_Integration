        int clocks;
    } stats;
    stats stats1 = {0,0,0,0,0};

    wire wavedrom_title;
    wire wavedrom_enable;
    int wavedrom_hide_after_time;

    reg clk = 0;
    initial forever #5 clk = ~clk;

    logic in1;
    logic in2;
    logic in3;
    logic out_ref;
    logic out_dut;

    initial begin
        $dumpfile("wave.vcd");
        $dumpvars(1, stim1.clk, tb_mismatch, in1, in2, in3, out_ref, out_dut);
    end

    wire tb_match, tb_mismatch = ~tb_match;

    stimulus_gen stim1 (
        .clk(clk),
        .*
    );

    RefModule good1 (
        .in1(in1),
        .in2(in2),
        .in3(in3),
        .out(out_ref)
    );

    TopModule top_module1 (
        .in1(in1),
        .in2(in2),
        .in3(in3),
        .out(out_dut)
    );

    bit strobe = 0;
    task wait_for_end_of_timestep;
        repeat(5) begin
            strobe <= !strobe;
            @(strobe);
        end
    endtask

    final begin
        if (stats1.errors_out) $display("Hint: Output 'out' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_out, stats1.errortime_out);
        else $display("Hint: Output 'out' has no mismatches.");

        $display("Simulation finished at %0d ps", $time);
        if (stats1.errors == 0) begin
            if (stats1.errors_out == 0) $display("SIMULATION PASSED");
            else $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_out, stats1.errortime_out);
        end else begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
        end
    end

    initial begin
        #1000000 $display("TIMEOUT"); $finish;
    end

    // XOR Verification logic
    assign tb_match = ({out_ref} === ({out_ref} ^ {out_dut} ^ {out_ref}));
    always @(posedge clk, negedge clk) begin
        stats1.clocks++;
        if (!tb_match) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
        end
        // Output verification
