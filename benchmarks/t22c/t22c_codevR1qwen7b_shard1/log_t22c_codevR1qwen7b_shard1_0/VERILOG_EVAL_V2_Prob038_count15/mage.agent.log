module tb();
    reg clk = 0;
    reg reset;
    logic [3:0] q_ref;
    logic [3:0] q_dut;
    wire tb_match;
    localparam MAX_QUEUE_SIZE = 10;
    reg [3:0] q_got_queue [0:MAX_QUEUE_SIZE-1];
    reg [3:0] q_golden_queue [0:MAX_QUEUE_SIZE-1];
    reg [3:0] input_data_queue [0:MAX_QUEUE_SIZE-1];
    reg [3:0] reset_queue [0:MAX_QUEUE_SIZE-1];
    reg queue_ptr = 0;

    // Instantiate reference module and DUT
    RefModule ref_inst (.clk(clk), .reset(reset), .q(q_ref));
    TopModule dut_inst (.clk(clk), .reset(reset), .q(q_dut));

    // Initialize signals and generate clock
    initial begin
        reset = 1;
        clk = 0;
        forever #5 clk = ~clk;
    end

    // Match calculation
    assign tb_match = (q_ref === (q_ref ^ q_dut ^ q_ref));
    reg [15:0] errors = 0;
    reg [31:0] first_error_time = 0;
    reg [31:0] error_count = 0;

    // Queue storage on every clock edge
    always @(posedge clk, negedge clk) begin
        if (queue_ptr >= MAX_QUEUE_SIZE-1) begin
            queue_ptr = 0;
        end

        input_data_queue[queue_ptr] = clk;
        q_got_queue[queue_ptr] = q_dut;
        q_golden_queue[queue_ptr] = q_ref;
        reset_queue[queue_ptr] = reset;

        // Check for first error
        if (!tb_match && error_count == 0) begin
            $display("Mismatch detected at time %t", $time);
            error_count = 1;
            first_error_time = $time;

            // Display all previous entries and the first mismatch
            for (int i = 0; i < MAX_QUEUE_SIZE; i++) begin
                if (i >= queue_ptr) break;
                $display("Cycle %d: clk %b, reset %b, q_got %h, q_golden %h", i, input_data_queue[i], reset_queue[i], q_got_queue[i], q_golden_queue[i]);
            end
            $display("Got Mismatch at time %t", first_error_time);
        end

        queue_ptr = queue_ptr + 1;
    end

    // Simulation timeout
    initial begin
        #1000000 $display("TIMEOUT"); $finish;
    end

    // Simulation end
    initial begin
        #10000000;
        if (error_count == 0) begin
            $display("SIMULATION PASSED");
        end else begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", error_count, first_error_time);
        end
        $finish;
    end
endmodule
module TopModule (input clk, input reset, output [3:0] q);
    // Implementation not required per user instruction, as per interface-only requirement.
endmodule
