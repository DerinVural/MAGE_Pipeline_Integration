    // Simulation status
    final begin
        if (errors == 0)
            $display("SIMULATION PASSED");
        else
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0t", errors, errortime);
    end

endmodule
