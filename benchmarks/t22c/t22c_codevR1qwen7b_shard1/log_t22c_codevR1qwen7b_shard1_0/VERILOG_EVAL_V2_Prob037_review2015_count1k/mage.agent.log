module tb();
	typedef struct packed {
		int errors;
		int errortime;
		int errors_q;
		int errortime_q;
		int clocks;
	} stats;
	stats stats1;

	reg clk = 0;
	initial forever #5 clk = ~clk;

	logic reset;
	logic [9:0] q_ref, q_dut;

	wire tb_match = ( { q_ref } === ( { q_ref } ^ { q_dut } ^ { q_ref } ) );

	// Queue for mismatch display
	reg [9:0] got_output_queue [0:9];
	reg [9:0] golden_queue [0:9];
	reg reset_queue [0:9];
	reg [31:0] time_queue [0:9];

	localparam MAX_QUEUE_SIZE = 10;

	always @(posedge clk, negedge clk) begin
		if ($time > MAX_QUEUE_SIZE*100) begin // Adjust based on clock period
			if (got_output_queue[0] !== golden_queue[0]) begin
				$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, time_queue[0]);
			end else begin
				$display("SIMULATION PASSED");
			end
		end
	end

	always @(posedge clk) begin
		// Maintain original error counting
		stats1.clocks++;
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
		end
		if (q_ref !== ( q_ref ^ q_dut ^ q_ref )) begin
			if (stats1.errors_q == 0) stats1.errortime_q = $time;
			stats1.errors_q++;
		end
		// Push to queue on every clock edge
		if ($time < MAX_QUEUE_SIZE*100) begin
			got_output_queue[$size(got_output_queue)] = q_dut;
			golden_queue[$size(golden_queue)] = q_ref;
			reset_queue[$size(reset_queue)] = reset;
			time_queue[$size(time_queue)] = $time;
		end
	end

	// Instantiate modules
	stimulus_gen stim1 (.*);
	RefModule good1 (.clk(clk), .reset(reset), .q(q_ref));
	TopModule top_module1 (.clk(clk), .reset(reset), .q(q_dut));

	// Timeout
	initial begin
		#1000000 $display("TIMEOUT"); $finish();
	end

	// Dump VCD
	src_all: initial begin
		$dumpfile("wave.vcd");
		$dumpvars(0, tb);
	end

	// Error display on mismatch
	src_err: always @(posedge clk) begin
		if (!tb_match && stats1.errors == 0) begin
			$display("Mismatch detected at time %0d", $time);
			$display("Last %0d cycles of simulation:", $size(got_output_queue));
			for (int i=0; i<$size(got_output_queue); i++) begin
				if (got_output_queue[i] === golden_queue[i])
				$display("Got Match at");
				else
				$display("Got Mismatch at");
				$display("Cycle %0d, reset %b, got %h, expected %h", i, reset_queue[i], got_output_queue[i], golden_queue[i]);
			end
		end
	end

endmodule
