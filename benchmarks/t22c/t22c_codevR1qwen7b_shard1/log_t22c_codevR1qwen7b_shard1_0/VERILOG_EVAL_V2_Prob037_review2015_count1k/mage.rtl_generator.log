in\n\t\tif ($time > MAX_QUEUE_SIZE*100) begin // Adjust based on clock period\n\t\t\tif (got_output_queue[0] !== golden_queue[0]) begin\n\t\t\t\t$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, time_queue[0]);\n\t\t\tend else begin\n\t\t\t\t$display("SIMULATION PASSED");\n\t\t\tend\n\t\tend\n\tend\n\n\talways @(posedge clk) begin\n\t\t// Maintain original error counting\n\t\tstats1.clocks++;\n\t\tif (!tb_match) begin\n\t\t\tif (stats1.errors == 0) stats1.errortime = $time;\n\t\t\tstats1.errors++;\n\t\tend\n\t\tif (q_ref !== ( q_ref ^ q_dut ^ q_ref )) begin\n\t\t\tif (stats1.errors_q == 0) stats1.errortime_q = $time;\n\t\t\tstats1.errors_q++;\n\t\tend\n\t\t// Push to queue on every clock edge\n\t\tif ($time < MAX_QUEUE_SIZE*100) begin\n\t\t\tgot_output_queue[$size(got_output_queue)] = q_dut;\n\t\t\tgolden_queue[$size(golden_queue)] = q_ref;\n\t\t\treset_queue[$size(reset_queue)] = reset;\n\t\t\ttime_queue[$size(time_queue)] = $time;\n\t\tend\n\tend\n\n\t// Instantiate modules\n\tstimulus_gen stim1 (.*);\n\tRefModule good1 (.clk(clk), .reset(reset), .q(q_ref));\n\tTopModule top_module1 (.clk(clk), .reset(reset), .q(q_dut));\n\n\t// Timeout\n\tinitial begin\n\t\t#1000000 $display("TIMEOUT"); $finish();\n\tend\n\n\t// Dump VCD\n\tsrc_all: initial begin\n\t\t$dumpfile("wave.vcd");\n\t\t$dumpvars(0, tb);\n\tend\n\n\t// Error display on mismatch\n\tsrc_err: always @(posedge clk) begin\n\t\tif (!tb_match && stats1.errors == 0) begin\n\t\t\t$display("Mismatch detected at time %0d", $time);\n\t\t\t$display("Last %0d cycles of simulation:", $size(got_output_queue));\n\t\t\tfor (int i=0; i<$size(got_output_queue); i++) begin\n\t\t\t\tif (got_output_queue[i] === golden_queue[i])\n\t\t\t\t$display("Got Match at");\n\t\t\t\telse\n\t\t\t\t$display("Got Mismatch at");\n\t\t\t\t$display("Cycle %0d, reset %b, got %h, expected %h", i, reset_queue[i], got_output_queue[i], golden_queue[i]);\n\t\t\tend\n\t\tend\n\tend\n\nendmodule\n</testbench>\n')