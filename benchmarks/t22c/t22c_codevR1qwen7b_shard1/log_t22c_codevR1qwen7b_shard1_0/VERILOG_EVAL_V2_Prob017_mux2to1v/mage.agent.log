    $finish;
end
endmodule

module tb();
    typedef struct packed {
        int errors;
        int errortime;
        int errors_out;
        int errortime_out;
        int clocks;
    } stats;
    stats stats1;
    wire [511:0] wavedrom_title;
    wire wavedrom_enable;
    int wavedrom_hide_after_time;
    reg clk = 0;
    initial forever #5 clk = ~clk;
    logic [99:0] a, b, sel;
    logic [99:0] out_ref, out_dut;
    wire tb_match, tb_mismatch = ~tb_match;
    stimulus_gen stim1 (
        .clk(clk),
        .a(a),
        .b(b),
        .sel(sel)
    );
    RefModule good1 (
        .a(a),
        .b(b),
        .sel(sel),
        .out(out_ref)
    );
    TopModule top_module1 (
        .a(a),
        .b(b),
        .sel(sel),
        .out(out_dut)
    );
    bit strobe = 0;
    task wait_for_end_of_timestep; repeat(5) begin strobe <= !strobe; @(strobe); end endtask
    final begin
        if (stats1.errors_out) $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_out, stats1.errortime_out);
        else $display("SIMULATION PASSED");
        $display("Simulation finished at %0d ps", $time);
    end
    assign tb_match = ({out_ref} === ( {out_ref} ^ {out_dut} ^ {out_ref} ));
    reg [99:0] input_queue [0:199];
    reg [99:0] got_output_queue [0:199];
    reg [99:0] golden_queue [0:199];
    reg reset_queue [0:199];
    localparam MAX_QUEUE_SIZE = 200;
    integer queue_ptr = 0;
    always @(posedge clk, negedge clk) begin
        if (input_queue[queue_ptr] !== golden_queue[queue_ptr]) begin
            $display("Mismatch detected at time %t", $time);
            $display("Last %0d cycles of simulation:", queue_ptr + 1);
            for (int i = 0; i <= queue_ptr; i++) begin
                if (i < queue_ptr) begin
                    if (got_output_queue[i] === golden_queue[i]) $display("Got Match");
                    else $display("Got Mismatch");
                end
                $display("Cycle %0d, reset %b, input %h, got %b, expected %b", i, reset_queue[i], input_queue[i], got_output_queue[i], golden_queue[i]);
            end
        end
        input_queue[queue_ptr] = {a, b, sel};
        got_output_queue[queue_ptr] = out_dut;
        golden_queue[queue_ptr] = out_ref;
        reset_queue[queue_ptr] = 0;
        queue_ptr = (queue_ptr == MAX_QUEUE_SIZE - 1) ? 0 : queue_ptr + 1;
        stats1.clocks++;
        if (!tb_match) begin
            stats1.errors++;
            if (stats1.errors == 1) stats1.errortime = $time;
        end
        if (out_ref !== (out_ref ^ out_dut ^ out_ref)) begin
            stats1.errors_out++;
            if (stats1.errors_out == 1) stats1.errortime_out = $time;
        end
    end
    initial begin
        stats1 = 0;
        clk = 0;
        #5; // Let clock settle
        $finish;
    end
endmodule
