module stimulus_gen (
    input clk,
    output logic [99:0] a, b,
    output logic sel,
    output reg [511:0] wavedrom_title,
    output reg wavedrom_enable
);

task wavedrom_start(input[511:0] title = ""); endtask
task wavedrom_stop; #1; endtask

initial begin
    a <= 'hdeadbeef;
    b <= 'h5eaf00d;
    sel <= 0;
    @(negedge clk);
    wavedrom_start("Beef or seafood?" );
    repeat(6) @(posedge clk) sel <= ~sel;
    @(negedge clk);
    wavedrom_stop();
