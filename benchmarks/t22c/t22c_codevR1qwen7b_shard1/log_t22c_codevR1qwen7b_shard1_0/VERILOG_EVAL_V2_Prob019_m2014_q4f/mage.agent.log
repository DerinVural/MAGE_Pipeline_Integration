module stimulus_gen (
    input clk,
    output logic in1,
    in2
);

    initial begin
        repeat(100) @(posedge clk, negedge clk) {
            {in1, in2} <= $random;
        }
        #1 $finish;
    end

endmodule

module tb();
    typedef struct {
        int errors;
        int errortime;
        int errors_out;
        int errortime_out;
        int clocks;
    } stats;
    stats stats1 = '{errors:0, errortime:0, errors_out:0, errortime_out:0, clocks:0};

    reg clk = 0;
    initial forever #5 clk = ~clk;

    logic in1, in2;
    logic out_ref, out_dut;
    wire tb_match = ( {out_ref} === ( {out_ref} ^ {out_dut} ^ {out_ref} ) );
    wire tb_mismatch = ~tb_match;

    stimulus_gen stim1 (
        .clk(clk),
        .*
    );
    RefModule good1 (
        .in1(in1),
        .in2(in2),
        .out(out_ref)
    );
    TopModule top_module1 (
        .in1(in1),
        .in2(in2),
        .out(out_dut)
    );

    bit strobe = 0;
    task wait_for_stable; repeat(5) @strobe; endtask

    localparam MAX_QUEUE_SIZE = 5;
    reg [1:0] input_queue [MAX_QUEUE_SIZE-1:0];
    reg [OUTPUT_WIDTH-1:0] got_output_queue [MAX_QUEUE_SIZE-1:0]; // Assuming OUTPUT_WIDTH is 1 as per spec
    reg [OUTPUT_WIDTH-1:0] golden_queue [MAX_QUEUE_SIZE-1:0];
    reg rst_queue [MAX_QUEUE_SIZE-1:0];

    reg [$bits(input_queue)-1:0] queue_ptr = 0;

    always @(posedge clk, negedge clk) begin
        // Push to queue and check for mismatches
        input_queue[queue_ptr] = {in1, in2};
        got_output_queue[queue_ptr] = out_dut;
        golden_queue[queue_ptr] = out_ref;
        rst_queue[queue_ptr] = clk; // Reset not used here; placeholder

        if (tb_mismatch) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
        end

        if (tb_mismatch) begin
            if (stats1.errors_out == 0) stats1.errortime_out = $time;
            stats1.errors_out++;
        end

        stats1.clocks++;
        queue_ptr = (queue_ptr + 1) % MAX_QUEUE_SIZE;

        // Display on mismatch or end
        if (tb_mismatch) begin
            $display("Mismatch at time %t", $time);
            $display("Queue contents (last %0d entries):", MAX_QUEUE_SIZE);
            for (int i = 0; i < MAX_QUEUE_SIZE; i++) begin
                $display("Cycle %0d: in=%b, got=%b, exp=%b",
                    (queue_ptr - i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE,
                    input_queue[(queue_ptr - i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE],
                    got_output_queue[(queue_ptr - i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE],
                    golden_queue[(queue_ptr - i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE]
                );
            end
        end

        if (stats1.clocks >= 1000000) begin
            $display("TIMEOUT after 1M cycles");
            $finish;
        end
    end

    initial begin
        $dumpfile("wave.vcd");
        $dumpvars(1, tb);
    end

    final begin
        if (stats1.errors_out) begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_out, stats1.errortime_out);
        end else begin
            $display("SIMULATION PASSED");
        end
        $display("Total errors: %0d, clocks: %0d", stats1.errors, stats1.clocks);
        $display("Simulation finished at %0t", $time);
        $finish;
    end
endmodule
