module tb();
	reg clk = 0;
	initial forever #5 clk = ~clk;
	wire in1, in2;
	logic out_ref, out_dut;
	logic tb_match;
	reg [511:0] wavedrom_title;
	reg wavedrom_enable;
	integer wavedrom_hide_after_time;
	snpsdm_stats stats1 = 0;
	snpsdm_strobe strobe = 0;
	task wait_for_end_of_timestep();
		repeat(5) begin strobe <= ~strobe; @(strobe); end
	endtask

	// Stimulus
	stimulus_gen stim1(.clk(clk), .in1(in1), .in2(in2));

	// Reference model
	RefModule good1(.in1(in1), .in2(in2), .out(out_ref));

	// DUT
	TopModule top_module1(.in1(in1), .in2(in2), .out(out_dut));

	// Verification
	assign tb_match = ({out_ref} === ({out_ref} ^ {out_dut} ^ {out_ref}));

	snpsdm_strobe strobe = 0;
	initial begin
		$dumpfile("wave.vcd");
		$dumpvars(1, tb.clk, in1, in2, out_ref, out_dut);
	end

	always @(posedge clk, negedge clk) begin
		stats1.clocks += 1;
		if (!tb_match) begin
			stats1.errors += 1;
			if (stats1.errors == 1) begin
				$display("TIME: %0t, in1=%b, in2=%b, out=%b, expected=%b", $time, in1, in2, out_dut, out_ref);
			end
		end
		if (out_ref !== (out_ref ^ out_dut ^ out_ref)) begin
			stats1.errors_out += 1;
			if (stats1.errors_out == 1) stats1.errortime_out = $time;
		end
	end

	// Timeout
	initial begin
		#1000000;
		$display("TIMEOUT");
		$finish();
	end

	// Simulation end
	final begin
		if (stats1.errors_out) begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0t", stats1.errors_out, stats1.errortime_out);
		end else begin
			$display("SIMULATION PASSED");
		end
		$display("Total errors: %0d in %0d clocks", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0t ps", $time);
		$finish();
	end
endmodule

