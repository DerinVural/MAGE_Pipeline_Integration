           stats1.errors_out++;\n        end\n\n        stats1.clocks++;\n        queue_ptr = (queue_ptr + 1) % MAX_QUEUE_SIZE;\n\n        // Display on mismatch or end\n        if (tb_mismatch) begin\n            $display(\"Mismatch at time %t\", $time);\n            $display(\"Queue contents (last %0d entries):\", MAX_QUEUE_SIZE);\n            for (int i = 0; i < MAX_QUEUE_SIZE; i++) begin\n                $display(\"Cycle %0d: in=%b, got=%b, exp=%b\",\n                    (queue_ptr - i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE,\n                    input_queue[(queue_ptr - i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE],\n                    got_output_queue[(queue_ptr - i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE],\n                    golden_queue[(queue_ptr - i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE]\n                );\n            end\n        end\n\n        if (stats1.clocks >= 1000000) begin\n            $display(\"TIMEOUT after 1M cycles\");\n            $finish;\n        end\n    end\n\n    initial begin\n        $dumpfile(\"wave.vcd\");\n        $dumpvars(1, tb);\n    end\n\n    final begin\n        if (stats1.errors_out) begin\n            $display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\", stats1.errors_out, stats1.errortime_out);\n        end else begin\n            $display(\"SIMULATION PASSED\");\n        end\n        $display(\"Total errors: %0d, clocks: %0d\", stats1.errors, stats1.clocks);\n        $display(\"Simulation finished at %0t\", $time);\n        $finish;\n    end\nendmodule"
