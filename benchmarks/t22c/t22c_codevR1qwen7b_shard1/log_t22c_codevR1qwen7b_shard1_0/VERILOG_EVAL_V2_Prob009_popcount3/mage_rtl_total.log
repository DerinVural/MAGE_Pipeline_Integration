[2026-05-14 11:07:16,387 - mage.agent - INFO] `timescale 1 ps/1 ps
module tb();
    wire[511:0] wavedrom_title;
    wire wavedrom_enable;
    reg clk = 0;
    logic [2:0] in;
    logic [1:0] out_ref, out_dut;
    integer errors, errortime, errors_out;
    integer clocks;

    // Clock generation
    initial forever #5 clk = ~clk;

    // Instantiate DUT and reference module
    TopModule top_module1 (.in(in), .out(out_dut));
    RefModule ref_mod (.in(in), .out(out_ref));

    // Stimulus generation
    stimulus_gen stim_gen (
        .clk(clk),
        .in(in),
        .wavedrom_title(wavedrom_title),
        .wavedrom_enable(wavedrom_enable)
    );

    // Error checking
    always @(posedge clk, negedge clk) begin
        clocks++;
        if (out_ref !== out_dut) begin
            if (errors == 0) errortime = $time;
            errors++;
        end
    end

    // Timeout handling
    initial #1000000 begin $display("TIMEOUT"); $finish; end

    // Simulation end
    final begin
        if (errors_out) $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", errors_out, errortime_out);
        else $display("SIMULATION PASSED");
    end
endmodule

module stimulus_gen (
    input clk,
    output logic [2:0] in,
    output reg [511:0] wavedrom_title,
    output reg wavedrom_enable
);
    task wavedrom_start(input [511:0] title = ""); endtask
    task wavedrom_stop; #1; endtask
    initial begin
        in = 7;
        @(negedge clk);
        wavedrom_start();
        repeat(9) @(posedge clk) in <= in + 1;
        @(negedge clk);
        wavedrom_stop();
        repeat(200) @(posedge clk, negedge clk) in <= $random;
        $finish;
    end
endmodule

module RefModule (input [2:0] in, output [1:0] out);
    assign out = in[0] + in[1] + in[2];
endmodule
