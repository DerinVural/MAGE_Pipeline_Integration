[2026-05-14 11:07:24,732 - mage.agent - INFO] `timescale 1ps/1ps
module tb();
	wire [511:0] wavedrom_title;
	wire wavedrom_enable;
	reg clk = 0;
	logic [2:0] in;
	logic [1:0] out_ref, out_dut;
	sd_stat_t stats;

	sd_clock_gen clkg(
		.clk(clk),
		.timeout(1000000),
		.msg("TIMEOUT")
	);

	stimulus_gen stim_gen (
		.clk(clk),
		.in(in),
		.wavedrom_title(wavedrom_title),
		.wavedrom_enable(wavedrom_enable)
	);

	TopModule dut (
		.in(in),
		.out(out_dut)
	);

	RefModule ref_mod (
		.in(in),
		.out(out_ref)
	);

	// Error checking
	sd_error_check err_check (
		.in_ref(out_ref),
		.in_dut(out_dut),
		.stats(stats),
		.first_mismatch_time(stats.first_time),
		.total_mismatches(stats.mismatches),
		.total_clocks(stats.clk_count)
	);

	// Simulation end and display
	initial begin
		$dumpfile("wave.vcd");
		$dumpvars(0, tb);
	end

	initial begin
		forever #5 clk = ~clk;
	end

	initial begin
		@clkg.timeout;
		$display("TIMEOUT");
		$finish;
	end

	final begin
		if (stats.mismatches) begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats.mismatches, stats.first_time);
		end else begin
			$display("SIMULATION PASSED");
		end
	end
endmodule

module stimulus_gen ( input clk, output logic [2:0] in, output logic [511:0] wavedrom_title, output logic wavedrom_enable );
	// Initialization and input generation code
	initial begin
		in = 7;
		notifier("stimulus_gen", "in", in);
		notifier("stimulus_gen", "wavedrom_title", wavedrom_title);
		notifier("stimulus_gen", "wavedrom_enable", wavedrom_enable);
		repeat(9) @(posedge clk) in <= in + 1;
		repeat(200) @(posedge clk) in <= $urandom;
		notifier_wait(5);
		$finish;
	end
endmodule

module RefModule ( input [2:0] in, output logic [1:0] out );
	auto display = 'h format for signals <=64 bits; HEX and BINARY
	assign out = in[0] + in[1] + in[2];
endmodule
