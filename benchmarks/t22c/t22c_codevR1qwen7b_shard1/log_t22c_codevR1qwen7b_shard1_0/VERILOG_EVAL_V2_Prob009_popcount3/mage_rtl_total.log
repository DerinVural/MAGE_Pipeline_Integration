    @(negedge clk);
    wavedrom_start();
    repeat(9) @(posedge clk) in <= in + 1;
    @(negedge clk);
    wavedrom_stop();
    repeat(200) @(posedge clk, negedge clk) in <= $random;
    $finish;
  end
endmodule

module tb();
