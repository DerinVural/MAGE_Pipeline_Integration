    "testbench": "`timescale 1ps/1ps\nmodule stimulus_gen (\n    input clk,\n    output logic d, ar\n);\n    initial begin\n        repeat(100) @(posedge clk, negedge clk) {d, ar} <= $random;\n        #1 $finish;\n    end\nendmodule\n\nmodule tb();\n    typedef struct {\n        int errors;\n        int errortime;\n        int errors_q;\n        int errortime_q;\n        int clocks;\n    } stats;\n    stats stats1;\n    reg clk = 0;\n    reg ar, d;\n    wire q_ref, q_dut;\n    reg [0:0] input_queue [0:9];\n    reg [0:0] got_output_queue [0:9];\n    reg [0:0] golden_queue [0:9];\n    reg reset_queue [0:0];\n    reg tb_match;\n    localparam MAX_QUEUE_SIZE = 2;\n\n    TopModule top_module1 (clk, d, ar, q_dut);\n    RefModule good1 (clk, d, ar, q_ref);\n    stimulus_gen stim_gen (clk, d, ar);\n\n    assign tb_match = (q_ref === (q_ref ^ q_dut ^ q_ref));\n\n    integer queue_ptr;\n    initial queue_ptr = 0;\n    always @(posedge clk, negedge clk) begin\n        if (stats1.errors_q == 0) begin\n            if (tb_match) begin\n                if (queue_ptr < MAX_QUEUE_SIZE-1) queue_ptr += 1;\n                else queue_ptr = MAX_QUEUE_SIZE - 1;\n                input_queue[queue_ptr] = {d, ar};\n                got_output_queue[queue_ptr] = q_dut;\n                golden_queue[queue_ptr] = q_ref;\n                reset_queue[queue_ptr] = 0;\n            end\n        end\n        if (!tb_match) begin\n            if (stats1.errors == 0) stats1.errortime = $time;\n            stats1.errors += 1;\n            if (stats1.errors == 1) begin\n                if (queue_ptr < MAX_QUEUE_SIZE-1) queue_ptr += 1;\n                else queue_ptr = MAX_QUEUE_SIZE - 1;\n                input_queue[queue_ptr] = {d, ar};\n                got_output_queue[queue_ptr] = q_dut;\n                golden_queue[queue_ptr] = q_ref;\n                reset_queue[queue_ptr] = 0;\n            end\n        end\n        if (queue_ptr >= MAX_QUEUE_SIZE) queue_ptr = MAX_QUEUE_SIZE -1;\n    end\n\n    fin