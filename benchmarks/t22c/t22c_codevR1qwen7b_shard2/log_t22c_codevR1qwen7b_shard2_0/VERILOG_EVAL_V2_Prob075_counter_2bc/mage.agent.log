                end
            end
            $finish;
        end
    end

    // Add timeout after 100K cycles
    initial begin #100000 $display("TIMEOUT"); $finish; end

endmodule

module RefModule (
    input clk,
    input areset,
    input train_valid,
    input train_taken,
    output reg [1:0] state = 2'b01
);
    always @(posedge clk) begin
        if (areset) state <= 2'b01;
        else begin
            if (train_valid) begin
                if (train_taken) state <= (state == 3) ? state : state +1;
                else state <= (state == 0) ? state : state -1;
            end
        end
    end
endmodule
