        .clk(clk),
        .areset(areset),
        .train_valid(train_valid),
        .train_taken(train_taken),
        .state(state)
    );

    RefModule ref_inst (
        .clk(clk),
        .areset(areset),
        .train_valid(train_valid),
        .train_taken(train_taken),
        .state(state_ref)
    );

    // Check for mismatches
    always @(posedge clk, negedge clk) begin
        if (input_queue.size() >= MAX_QUEUE_SIZE -1) begin
            input_queue.delete(0);
            got_state_queue.delete(0);
            golden_state_queue.delete(0);
            reset_queue.delete(0);
        end
        input_queue.push_back({clk, areset, train_valid, train_taken});
        got_state_queue.push_back(state);
        golden_state_queue.push_back(state_ref);
        reset_queue.push_back(areset);

        if (state !== state_ref) begin
            $display("SIMULATION FAILED - 1 MISMATCHES DETECTED, FIRST AT TIME %0t", $time);
