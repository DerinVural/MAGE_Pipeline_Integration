te_queue [0:3];\n    reg reset_queue [0:3];\n    localparam MAX_QUEUE_SIZE = 4;\n\n    always #(5) clk = ~clk;\n\n    initial begin\n        areset = 1;\n        #10 areset = 0;\n        $dumpfile("wave.vcd");\n        $dumpvars(1, tb, clk, areset, train_valid, train_taken, state, state_ref);\n    end\n\n    // Instantiate DUT and reference\n    TopModule top_inst (\n        .clk(clk),\n        .areset(areset),\n        .train_valid(train_valid),\n        .train_taken(train_taken),\n        .state(state)\n    );\n\n    RefModule ref_inst (\n        .clk(clk),\n        .areset(areset),\n        .train_valid(train_valid),\n        .train_taken(train_taken),\n        .state(state_ref)\n    );\n\n    // Check for mismatches\n    always @(posedge clk, negedge clk) begin\n        if (input_queue.size() >= MAX_QUEUE_SIZE -1) begin\n            input_queue.delete(0);\n            got_state_queue.delete(0);\n            golden_state_queue.delete(0);\n            reset_queue.delete(0);\n        end\n        input_queue.push_back({clk, areset, train_valid, train_taken});\n        got_state_queue.push_back(state);\n        golden_state_queue.push_back(state_ref);\n        reset_queue.push_back(areset);\n\n        if (state !== state_ref) begin\n            $display("SIMULATION FAILED - 1 MISMATCHES DETECTED, FIRST AT TIME %0t", $time);\n            $display("Last %0d cycles of simulation:", input_queue.size());\n            for (int i =0; i < input_queue.size(); i=i+1) begin\n                if (i ==0) begin\n                    $display("Got Mismatch at");\n                end else begin\n                    $display("Cycle %0d, reset %b, inputs %h, got state %h, expected %h",\n                        i, reset_queue[i], input_queue[i], got_state_queue[i], golden_state_queue[i]);\n                end\n            end\n            $finish;\n        end\n    end\n\n    // Add timeout after 100K cycles\n    initial begin #100000 $display("TIMEOUT"); $finish; end\n\nendmodule\n\nmodule RefModule (\n    input clk,\n    input areset,\n    input train_valid,\n    input train_taken,\n    output reg [1:0] state = 2\'b01\n);\n    always @(posedge clk) begin\n        if (areset) state <= 2\'b01;\n        else begin\n            if (train_valid) begin\n                if (train_taken) state <= (state == 3) ? state : state +1;\n                else state <= (state == 0) ? state : state -1;\n            end\n        end\n    end\nendmodule\n</testbench>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nThe module interface is given below:\n<module_interface>\nmodule TopModule (\n    input clk,\n    input areset,\n    input train_valid,\n    input train_taken,\n    output logic [1:0] state\n);\n</module_interface>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nYour response will be processed by a program, not human.\nSo, please STRICTLY FOLLOW the output format given as XML tag content below to generate a VALID JSON OBJECT:\n<output_format>\n{\n    "reasoning": "All reasoning steps and advices to avoid syntax error",\n    "module": "Pure SystemVerilog code, a complete module"\n}\n</output_format>\nDO NOT include any other information in your response, like \'json\', \'reasoning\' or \'<output_format>\'.\n\nOther requirements:\n1. Don\'t use state_t to define the parameter. Use `localparam` or Use \'reg\' or \'logic\' for signals as registers or Flip-Flops.\n2. Declare all ports and signals as logic.\n3. Not all the sequential logic need to be reset to 0 when reset is asserted,\n    but these without-reset logic should be initialized to a known value with an initial block instead of being X.\n4. For combinational logic with an always block do not explicitly specify the sensitivity list; instead use always @(*).\n5. NEVER USE \'inside\' operator in RTL code. Code like \'state inside {STATE_B, STATE_C, STATE_D}\' shou