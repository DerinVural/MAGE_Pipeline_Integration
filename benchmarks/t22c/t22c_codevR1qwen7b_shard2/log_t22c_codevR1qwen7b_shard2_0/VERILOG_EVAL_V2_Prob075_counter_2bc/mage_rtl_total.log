module tb();
    reg clk = 0;
    reg areset;
    reg train_valid;
    reg train_taken;
    wire [1:0] state;
    reg [1:0] state_ref;
    reg tb_match;
    reg [3:0] input_queue [0:3];
    reg [1:0] got_state_queue [0:3];
    reg [1:0] golden_state_queue [0:3];
    reg reset_queue [0:3];
    localparam MAX_QUEUE_SIZE = 4;

    always #(5) clk = ~clk;

    initial begin
        areset = 1;
        #10 areset = 0;
        $dumpfile("wave.vcd");
        $dumpvars(1, tb, clk, areset, train_valid, train_taken, state, state_ref);
    end

    // Instantiate DUT and reference
    TopModule top_inst (
        .clk(clk),
        .areset(areset),
        .train_valid(train_valid),
        .train_taken(train_taken),
        .state(state)
    );

    RefModule ref_inst (
        .clk(clk),
        .areset(areset),
        .train_valid(train_valid),
        .train_taken(train_taken),
        .state(state_ref)
    );

    // Check for mismatches
    always @(posedge clk, negedge clk) begin
        if (input_queue.size() >= MAX_QUEUE_SIZE -1) begin
            input_queue.delete(0);
            got_state_queue.delete(0);
            golden_state_queue.delete(0);
            reset_queue.delete(0);
        end
        input_queue.push_back({clk, areset, train_valid, train_taken});
        got_state_queue.push_back(state);
        golden_state_queue.push_back(state_ref);
        reset_queue.push_back(areset);

        if (state !== state_ref) begin
            $display("SIMULATION FAILED - 1 MISMATCHES DETECTED, FIRST AT TIME %0t", $time);
            $display("Last %0d cycles of simulation:", input_queue.size());
            for (int i =0; i < input_queue.size(); i=i+1) begin
                if (i ==0) begin
                    $display("Got Mismatch at");
                end else begin
                    $display("Cycle %0d, reset %b, inputs %h, got state %h, expected %h",
                        i, reset_queue[i], input_queue[i], got_state_queue[i], golden_state_queue[i]);
                end
            end
            $finish;
        end
    end

    // Add timeout after 100K cycles
    initial begin #100000 $display("TIMEOUT"); $finish; end

endmodule

module RefModule (
    input clk,
    input areset,
    input train_valid,
    input train_taken,
    output reg [1:0] state = 2'b01
);
    always @(posedge clk) begin
        if (areset) state <= 2'b01;
        else begin
            if (train_valid) begin
                if (train_taken) state <= (state == 3) ? state : state +1;
                else state <= (state == 0) ? state : state -1;
            end
        end
    end
endmodule
