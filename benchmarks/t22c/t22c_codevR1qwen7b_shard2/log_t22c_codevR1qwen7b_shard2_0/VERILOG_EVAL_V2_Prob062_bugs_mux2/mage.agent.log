[2026-05-14 12:05:12,301 - mage.agent - INFO] // Testbench for TopModule (fixed version)
`timescale 1ps/1ps

module stimulus_gen (
    input clk,
    output logic sel,
    output logic [7:0] a, b,
    output [511:0] wavedrom_title,
    output reg wavedrom_enable
);

    task wavedrom_start(input[511:0] title = ""); endtask
    task wavedrom_stop; #1; endtask

    initial begin
        {a, b, sel} <= '0;
        @(negedge clk) wavedrom_start();
        @(posedge clk, negedge clk) {a, b, sel} <= {8'haa, 8'hbb, 1'b0};
        repeat(5) @(posedge clk, negedge clk) {a, b, sel} <= {8'haa, 8'hbb, sel + 1};
        {a, b, sel} <= {8'hff, 8'h00, 1'b0};
        repeat(6) @(posedge clk, negedge clk) sel <= sel + 1;
        wavedrom_stop();
        repeat(100) @(posedge clk, negedge clk) {a, b, sel} <= $urandom;
        $finish;
    end
endmodule

module tb();
    typedef struct packed {
        int errors;
        int errortime;
        int errors_out;
        int errortime_out;
        int clocks;
    } stats;
    stats stats1 = '{errors:0, errortime:0, errors_out:0, errortime_out:0, clocks:0};

    wire [511:0] wavedrom_title;
    wire wavedrom_enable;
    integer wavedrom_hide_after_time;

    reg clk = 0;
    initial forever #5 clk = ~clk;

    logic sel;
    logic [7:0] a, b;
    logic [7:0] out_ref, out_dut;
    wire tb_match = (out_ref === out_dut);

    stimulus_gen stim1 (.*);
    RefModule good1 (.*, .out(out_ref));
    TopModule top_module1 (.*, .out(out_dut));

    always @(posedge clk, negedge clk) begin
        stats1.clocks++;
        if (!tb_match) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
        end
        if (out_ref !== out_dut) begin
            if (stats1.errors_out == 0) stats1.errortime_out = $time;
            stats1.errors_out++;
        end
    end

    initial begin
        $dumpfile("wave.vcd");
        $dumpvars(1, tb, stats1, clk, sel, a, b, out_ref, out_dut);
    end

    initial begin
        repeat(2000) @(posedge clk);
        $display(stats1.errors ? "SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d" : "SIMULATION PASSED",
            stats1.errors, stats1.errortime);
        $finish;
    end
endmodule
