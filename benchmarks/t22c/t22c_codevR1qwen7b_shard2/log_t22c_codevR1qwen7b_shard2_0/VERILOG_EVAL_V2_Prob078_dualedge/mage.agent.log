	reg d;
	wire q;
	
	// Instantiate the DUT
	TopModule dut (
		.clk(clk),
		.d(d),
		.q(q)
	);
	
	// Reference model
	reg q_ref;
	always @(posedge clk, negedge clk) begin
		q_ref <= d;
	end
	
	// Error checking
	reg [10:0] input_queue [$];
	reg [10:0] got_queue [$];
	reg [10:0] expected_queue [$];
	
	localparam MAX_QUEUE_SIZE = 8;
	
	always @(posedge clk, negedge clk) begin
		if (input_queue.size() >= MAX_QUEUE_SIZE) begin
			drop_entries(input_queue);
			drop_entries(got_queue);
			drop_entries(expected_queue);
		end
		input_queue.push_back(d);
		got_queue.push_back(q);
		expected_queue.push_back(q_ref);
		
		if (q !== q_ref) begin
			if ($error_count == 0) begin
				$error_time = $time;
			end
			$error_count = $error_count + 1;
			$error_q_count = $error_q_count + 1;
		end
		$error_clocks = $error_clocks + 1;
	end
	
	// Simulation timeout
	initial begin
		sleep(100000000);
		$display("TIMEOUT");
		$finish;
	end
	
	// Finish simulation
	initial begin
		sleep(1000000000);
		$display("Simulation finished at time %t", $time);
		if ($error_count == 0) begin
			$display("SIMULATION PASSED");
		end else begin
