module stimulus_gen (
    input clk,
    output tb_match,
    output reg [99:0] in
);
    task wavedrom_start(); endtask
    task wavedrom_stop(); endtask
    initial begin
        reg [3:0] count = 0;
        in = 0;
        // AND gate test
        @(negedge clk); wavedrom_start();
        @(posedge clk); in = 0;
        @(posedge clk); in = ~0;
        @(posedge clk); in = 32'h3ffff;
        @(posedge clk); in = ~32'h3ffff;
        @(posedge clk); in = 32'h80;
        @(posedge clk); in = ~32'h80;
        wavedrom_stop();
        // OR and XOR tests
        @(negedge clk); wavedrom_start();
        @(posedge clk); in = 0;
        @(posedge clk); in = 7;
        repeat(10) @(posedge clk, negedge clk) in = count++;
        @(posedge clk); in = 0;
        wavedrom_stop();
        // Random tests
        in = $random;
        repeat(100) begin @(negedge clk); in = $random; @(posedge clk); in = $random; end
        for (int i=0; i<100; i++) begin @(negedge clk); in = 1 << i; @(posedge clk); in = ~(1 << i); end
        @(posedge clk); in = 0;
        @(posedge clk); in = ~0;
        #1 $finish;
    end
endmodule

module tb();
    typedef struct {
        int errors;
        int errortime;
        int errors_out_and;
        int errortime_out_and;
        int errors_out_or;
        int errortime_out_or;
        int errors_out_xor;
        int errortime_out_xor;
        int clocks;
    } stats;
    stats stats1 = 0;
    reg clk = 0;
    initial forever #5 clk = ~clk;
    logic [99:0] in;
    logic out_and_ref, out_and_dut;
    logic out_or_ref, out_or_dut;
    logic out_xor_ref, out_xor_dut;
    logic tb_match;
    wire tb_mismatch = ~tb_match;
    TopModule dut (in, out_and_dut, out_or_dut, out_xor_dut);
    RefModule golden (in, out_and_ref, out_or_ref, out_xor_ref);
    queue {
        reg [99:0] input_queue [0:9];
        reg [0:9] got [out_and_ref:out_xor_dut]; // Assuming single bit outputs for simplicity
        reg [0:9] expected [out_and_ref:out_xor_dut];
        localparam MAX_QUEUE_SIZE = 10;
        always @(posedge clk, negedge clk) begin
            if (input_queue.size() >= MAX_QUEUE_SIZE -1) {
                input_queue.delete(0);
                // Dequeue expected and got
            }
            input_queue.push_back(in);
            got[out_and_ref] = out_and_dut;
            got[out_or_ref] = out_or_dut;
            got[out_xor_ref] = out_xor_dut;
            expected[out_and_ref] = &in;
            expected[out_or_ref] = |in;
            expected[out_xor_ref] = ^in;
            if (out_and_dut !== expected[out_and_ref] || out_or_dut !== expected[out_or_ref] || out_xor_dut !== expected[out_xor_ref]) begin
                $display("Mismatch detected at %t", $time);
                $display("First mismatch at time %t", stats1.errortime);
                $display("Input: %h, out_and: got %b (%h), expected %b (%h)", in, got[out_and_ref], got[out_and_ref], expected[out_and_ref], got[out_or_ref], got[out_or_ref], expected[out_or_ref], got[out_xor_ref], got[out_xor_ref], expected[out_xor_ref]);
                $finish;
            end
        end
    }
    final begin
        if (stats1.errors) $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
        else $display("SIMULATION PASSED");
    end
endmodule
