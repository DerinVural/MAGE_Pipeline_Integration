	stimulus_gen stim1(.clk(clk), .a(a), .b(b), .c(c), .d(d));
	RefModule good1(.a(a), .b(b), .c(c), .d(d), .out(out_ref), .out_n(out_n_ref));
	TopModule top1(.a(a), .b(b), .c(c), .d(d), .out(out_dut), .out_n(out_n_dut));
	assign tb_match = ({out_ref, out_n_ref} === ( {out_ref, out_n_ref} ^ {out_dut, out_n_dut} ^ {out_ref, out_n_ref} )));
	localparam MAX_QUEUE_SIZE=10;
	reg [3:0] input_queue [0:MAX_QUEUE_SIZE-1];
	reg got_queue [0:MAX_QUEUE_SIZE-1];
	reg golden_queue [0:MAX_QUEUE_SIZE-1];
	reg [3:0] input_err=0;
	reg [3:0] clk_err=0;
	integer i;
	event display_err;

	system task display_mismatch;
		input integer idx;
		$display("Mismatch detected at time %t", $time);
		$display("Cycle %d, inputs a=%b b=%b c=%b d=%b", idx, a, b, c, d);
		$display("Expected: out=%b out_n=%b; Got: out=%b out_n=%b", golden_queue[idx], out_n_ref, got_queue[idx], out_n_dut);
	endtask

	always @(posedge clk, negedge clk) begin
		if (tb_mismatch) begin
			if (input_err ==0) input_err = $time;
			input_queue[input_err] = {a,b,c,d};
			golden_queue[input_err] = {out_ref, out_n_ref};
			got_queue[input_err] = {out_dut, out_n_dut};
			input_err++;
			if (input_err >= MAX_QUEUE_SIZE) input_err=0;
		end
		if (input_err !=0 && $time - clk_err >100) begin
			->display_err;
			clk_err=$time;
		end
	end

	sync accept on(display_err) begin
		$display("SIMULATION PASSED")
	end

	sync always @(input_err) begin
		if (input_err !=0) begin
			display_mismatch(input_err);
		end
	end

	sync always @(clk_err) begin
		if (clk_err !=0) begin
			$display("SIMULATION FAILED - %d MISMATCHES DETECTED, FIRST AT TIME %t", input_err, input_err);
		end
	end
endmodule

module stimulus_gen (clk, a, b, c, d);
	public reg clk;
	public logic a,b,c,d;
	initial begin
		{a,b,c,d} =0;
		@(negedge clk);
		repeat(20) @(posedge clk, negedge clk) {d,c,b,a} <= {d,c,b,a} +1;
		repeat(100) @(posedge clk, negedge clk) {a,b,c,d} <= $random;
		#1 $finish;
	end
endmodule

module RefModule (a, b, c, d, out, out_n);
	public input a,b,c,d;
	public output out, out_n;
	wire and1_out = a & b;
	wire and2_out = c & d;
	wire or_out = and1_out | and2_out;
	affect out = or_out;
	affect out_n = ~or_out;
endmodule
