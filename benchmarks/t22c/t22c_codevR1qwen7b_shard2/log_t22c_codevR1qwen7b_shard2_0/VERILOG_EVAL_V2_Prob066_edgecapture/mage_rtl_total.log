[2026-05-14 12:21:14,922 - mage.agent - INFO] `timescale 1ps/1ps

module tb();
    typedef struct packed {
        int errors;
        int errortime;
        int errors_out;
        int errortime_out;
        int clocks;
    } stats;

    stats stats1 = '{errors:0, errortime:0, errors_out:0, errortime_out:0, clocks:0};
    reg clk = 0;
    reg reset;
    reg [31:0] in;
    wire [31:0] out_ref;
    wire [31:0] out_dut;
    reg [511:0] wavedrom_title;
    reg wavedrom_enable;
    reg tb_match;
    reg tb_mismatch;
    wire logic_tb_match;

    // Clock generation
    initial forever #5 clk = ~clk;

    // Stimulus instance
    stimulus_gen stim1 (
        .clk(clk),
        .tb_match(tb_match),
        .in(in),
        .reset(reset),
        .wavedrom_title(wavedrom_title),
        .wavedrom_enable(wavedrom_enable)
    );

    // Reference and DUT modules
    RefModule good1 (
        .clk(clk),
        .reset(reset),
        .in(in),
        .out(out_ref)
    );

    TopModule top_module1 (
        .clk(clk),
        .reset(reset),
        .in(in),
        .out(out_dut)
    );

    // Timeout after 1e6 cycles
    initial begin
        #1000000 $display("TIMEOUT"); $finish;
    end

    // Monitor changes
    always @(posedge clk) begin
        // Check for mismatches
        if (out_ref !== out_dut) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
        end
        if (out_ref !== out_dut) begin
            if (stats1.errors_out == 0) stats1.errortime_out = $time;
            stats1.errors_out++;
        end
        stats1.clocks++;
    end

    // Display results on finish
    initial begin
        #1 wait(stats1.clocks); // Wait for last clock event
        if (stats1.errors) begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
            $display("First Mismatch Details:\n in: %h (%b), out: %h (%b), expected: %h (%b)\n", in, in, out_dut, out_dut, out_ref, out_ref);
        end else begin
            $display("SIMULATION PASSED");
        end
        $finish;
    end
endmodule

module stimulus_gen (
    input clk,
    input tb_match,
    output reg [31:0] in,
    output reg reset,
    output reg [511:0] wavedrom_title,
    output reg wavedrom_enable
);

    // Define dummy tasks since not used
    task wavedrom_start(input [511:0] title = ""); endtask
    task wavedrom_stop; #1; endtask

    initial begin
        // Initial conditions
        in = 0;
        reset = 1;
        @(posedge clk);
        reset = 1;
        in = 0;
        @(negedge clk); // Example usage (not used in test)
        // Stimulus sequence
        repeat(1) @(posedge clk);
        reset = 0;
        @(posedge clk) in = 32'h2;
        repeat(4) @(posedge clk);
        in = 32'he;
        repeat(2) @(posedge clk);
        in = 0;
        @(posedge clk) in = 32'h2;
        repeat(2) @(posedge clk);
        reset = 1;
        @(posedge clk);
        reset = 0; in = 0;
        repeat(3) @(posedge clk);
        // More stimuli...
        // Real test ends here
        #1000000;
        $finish;
    end
endmodule
