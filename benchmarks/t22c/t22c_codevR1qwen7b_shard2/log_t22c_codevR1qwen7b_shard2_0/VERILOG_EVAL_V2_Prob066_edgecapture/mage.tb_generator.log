ble;\n    reg clk = 0;\n    initial forever #5 clk = ~clk;\n    reg reset;\n    reg [31:0] in;\n    reg [31:0] out_ref;\n    reg [31:0] out_dut;\n    wire tb_match = ~|{ out_ref ^ out_dut };\n    wire tb_mismatch = ~tb_match;\n    reg [511:0] wavedrom_title_u;\n    reg wavedrom_enable_u;\n    stimulus_gen stim1 (\n        .clk(clk),\n        .tb_match(tb_match),\n        .in(in),\n        .reset(reset),\n        .wavedrom_title(wavedrom_title_u),\n        .wavedrom_enable(wavedrom_enable_u)\n    );\n    RefModule good1 (.clk(clk), .reset(reset), .in(in), .out(out_ref));\n    TopModule top_module1 (.clk(clk), .reset(reset), .in(in), .out(out_dut));\n    reg strobe = 0;\n    task wait_for_end_of_timestep; repeat(5) begin strobe <= !strobe; @(strobe); end endtask\n    initial begin $dumpfile(\"wave.vcd\"); $dumpvars(1, stim1.clk, tb_mismatch, clk, reset, in, out_ref, out_dut); end\n    always @(posedge clk, negedge clk) begin stats1.clocks++; if (!tb_match) begin if (stats1.errors == 0) stats1.errortime = $time; stats1.errors++; end if (out_ref !== (out_ref ^ out_dut ^ out_ref)) begin if (stats1.errors_out == 0) stats1.errortime_out = $time; stats1.errors_out++; end end\n    initial begin #1000000 $display(\"TIMEOUT\"); $finish; end\n    initial begin #1; end\n    always @(stats1.clocks) begin // Display on final clock if (stats1.errors) $display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\", stats1.errors, stats1.errortime); else $display(\"SIMULATION PASSED\"); $finish; end\nendmodule\n"
