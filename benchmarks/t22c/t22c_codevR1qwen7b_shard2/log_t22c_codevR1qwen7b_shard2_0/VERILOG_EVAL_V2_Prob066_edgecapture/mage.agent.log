    reg clk = 0;
    reg reset;
    reg [31:0] in;
    wire [31:0] out_ref;
    wire [31:0] out_dut;
    reg [511:0] wavedrom_title;
    reg wavedrom_enable;
    reg tb_match;
    reg tb_mismatch;
    wire logic_tb_match;

    // Clock generation
    initial forever #5 clk = ~clk;

    // Stimulus instance
