        .clk(clk),
        .reset(reset),
        .in(in),
        .out(out_ref)
    );

    TopModule top_module1 (
        .clk(clk),
        .reset(reset),
        .in(in),
        .out(out_dut)
    );

    // Timeout after 1e6 cycles
    initial begin
        #1000000 $display("TIMEOUT"); $finish;
    end

    // Monitor changes
    always @(posedge clk) begin
        // Check for mismatches
