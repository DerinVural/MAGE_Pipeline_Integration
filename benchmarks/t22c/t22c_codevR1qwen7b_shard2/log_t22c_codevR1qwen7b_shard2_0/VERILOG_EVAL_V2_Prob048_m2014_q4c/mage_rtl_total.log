[2026-05-14 11:33:54,654 - mage.agent - INFO] Revised tb:
[2026-05-14 11:33:54,654 - mage.agent - INFO] `timescale 1ps/1ps
module tb();
	packet_t stats1;
	logic clk;
	logic d, r;
	logic q_ref, q_dut;
	wire tb_match, tb_mismatch;

	stimulus_gen stim1 (clk, d, r);
	RefModule ref_mod (clk, d, r, q_ref);
	TopModule top_mod (clk, d, r, q_dut);

	assign tb_match = (q_ref === q_dut);
	assign tb_mismatch = ~tb_match;

	event start_sim;

	initial begin
		stats1 = '0;
		clk = 0;
		fork
			begin
				forever #5 clk = ~clk;
			end
			begin
				sample_dut();
			end
		endfork
	end

	task automatic sample_dut();
		wait (clk === 1);
		sample();
		repeat(100) @posedge clk wait_for_sample();
		#1 $finish;
	endtask

	task automatic wait_for_sample();
		wait forked;
	endtask

	task automatic sample();
		stats1.clocks++;
		if (stats1.errors == 0 && !tb_match) stats1.errortime = $time;
		if (!tb_match) stats1.errors++;
		if (q_ref !== (q_ref ^ q_dut ^ q_ref)) begin
			if (stats1.errors_q == 0) stats1.errortime_q = $time;
			stats1.errors_q++;
		end
	endtask

	initial begin
		$dumpfile("wave.vcd");
		$dumpvars(1, tb, clk, d, r, q_ref, q_dut);
	end

	initial begin
		sim_timeout();
	end

	task automatic sim_timeout();
		#1000000 $display("TIMEOUT"); $finish();
	endtask

	initial begin
		if (stats1.errors) begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
		end else begin
			$display("SIMULATION PASSED");
		end
	end

endmodule

module stimulus_gen (clk, d, r);
	output logic clk;
	output logic d, r;

	packet_t params;

	initial begin
		repeat(100) @(posedge clk, negedge clk) {d, r} <= $urandom;
		#1 $finish;
	end
endmodule

module RefModule (input clk, input d, input r, output reg q);
	always @(posedge clk) begin
		if (r) q <= 0;
		else q <= d;
	end
endmodule

module TopModule (input clk, input d, input r, output reg q);
	always @(posedge clk) begin
		if (r) q <= 0;
		else q <= d;
	end
endmodule
