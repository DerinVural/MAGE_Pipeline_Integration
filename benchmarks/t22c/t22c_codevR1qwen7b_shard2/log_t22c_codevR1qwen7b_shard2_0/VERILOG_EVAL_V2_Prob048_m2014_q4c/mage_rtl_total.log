[2026-05-14 11:33:09,367 - mage.agent - INFO] // BEGIN_OF_TESTBENCH
`timescale 1ps/1ps
`define OK 12
`define INCORRECT 13

module stimulus_gen (
    input clk,
    output logic d,
    output logic r
);

    initial begin
        repeat(100) @(posedge clk, negedge clk) {d, r} <= $random;
        #1 $finish;
    end

endmodule

module tb();
    typedef struct packed {
        int errors;
        int errortime;
        int errors_q;
        int errortime_q;
        int clocks;
    } stats;

    stats stats1 = '{errors:0, errortime:0, errors_q:0, errortime_q:0, clocks:0};
    wire [511:0] wavedrom_title;
    wire wavedrom_enable;
    int wavedrom_hide_after_time;

    reg clk = 0;
    initial forever #5 clk = ~clk;

    logic d;
    logic r;
    logic q_ref;
    logic q_dut;

    // Instantiate the DUT
    TopModule top_module1 (
        .clk(clk),
        .d(d),
        .r(r),
        .q(q_dut)
    );

    // Reference module
    RefModule good1 (
        .clk(clk),
        .d(d),
        .r(r),
        .q(q_ref)
    );

    // Stimulus generator
    stimulus_gen stim1 (
        .clk(clk),
        .d(d),
        .r(r)
    );

    // VCD waveform generation
    initial begin
        $dumpfile("wave.vcd");
        $dumpvars(1, clk, d, r, q_ref, q_dut);
    end

    // Mismatch detection
    assign tb_match = ( {q_ref} === ( {q_ref} ^ {q_dut} ^ {q_ref} ) );
    wire tb_mismatch = ~tb_match;

    // Error counting
    always @(posedge clk, negedge clk) begin
        stats1.clocks++;
        if (!tb_match) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
        end
        if (q_ref !== (q_ref ^ q_dut ^ q_ref)) begin
            if (stats1.errors_q == 0) stats1.errortime_q = $time;
            stats1.errors_q++;
        end
    end

    // Queue variables for error display
    reg [7:0] input_queue [$];
    reg [7:0] got_queue [$];
    reg [7:0] golden_queue [$];
    reg reset_queue [$];
    localparam MAX_QUEUE_SIZE = 8;

    // Queue management and error display
    always @(posedge clk, negedge clk) begin
        if (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin
            input_queue.delete(0);
            got_queue.delete(0);
            golden_queue.delete(0);
            reset_queue.delete(0);
        end
        input_queue.push_back({d, r});
        got_queue.push_back(q_dut);
        golden_queue.push_back(q_ref);
        reset_queue.push_back(r);

        if (!tb_match) begin
            $display("Mismatch detected at time %0t", $time);
            $display("Last %0d cycles of simulation:", input_queue.size());
            for (int i = 0; i < input_queue.size(); i++) begin
                if (i == 0) $display("Got Mismatch");
                $display("Cycle %0d, reset %b, inputs %h / %h, got %h, expected %h",
                    i,
                    reset_queue[i],
                    input_queue[i][7:0], input_queue[i][15:8],
                    got_queue[i], golden_queue[i]);
            end
        end
    end

    // Simulation timeout after 100K cycles
    initial begin
        #1000000 $display("TIMEOUT");
        $finish();
    end

    // Final simulation message
    final begin
        if (stats1.errors_q) begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0t",
                stats1.errors_q, stats1.errortime_q);
        end else begin
            $display("SIMULATION PASSED");
        end
    end

endmodule
// END_OF_TESTBENCH
