    "testbench": "// BEGIN_OF_TESTBENCH\n`timescale 1ps/1ps\n`define OK 12\n`define INCORRECT 13\n\nmodule stimulus_gen (\n    input clk,\n    output logic d,\n    output logic r\n);\n\n    initial begin\n        repeat(100) @(posedge clk, negedge clk) {d, r} <= $random;\n        #1 $finish;\n    end\n\nendmodule\n\nmodule tb();\n    typedef struct packed {\n        int errors;\n        int errortime;\n        int errors_q;\n        int errortime_q;\n        int clocks;\n    } stats;\n\n    stats stats1 = '{errors:0, errortime:0, errors_q:0, errortime_q:0, clocks:0};\n    wire [511:0] wavedrom_title;\n    wire wavedrom_enable;\n    int wavedrom_hide_after_time;\n\n    reg clk = 0;\n    initial forever #5 clk = ~clk;\n\n    logic d;\n    logic r;\n    logic q_ref;\n    logic q_dut;\n\n    // Instantiate the DUT\n    TopModule top_module1 (\n        .clk(clk),\n        .d(d),\n        .r(r),\n        .q(q_dut)\n    );\n\n    // Reference module\n    RefModule good1 (\n        .clk(clk),\n        .d(d),\n        .r(r),\n        .q(q_ref)\n    );\n\n    // Stimulus generator\n    stimulus_gen stim1 (\n        .clk(clk),\n        .d(d),\n        .r(r)\n    );\n\n    // VCD waveform generation\n    initial begin\n        $dumpfile(\"wave.vcd\");\n        $dumpvars(1, clk, d, r, q_ref, q_dut);\n    end\n\n    // Mismatch detection\n    assign tb_match = ( {q_ref} === ( {q_ref} ^ {q_dut} ^ {q_ref} ) );\n    wire tb_mismatch = ~tb_match;\n\n    // Error counting\n    always @(posedge clk, negedge clk) begin\n        stats1.clocks++;\n        if (!tb_match) begin\n            if (stats1.errors == 0) stats1.errortime = $time;\n            stats1.errors++;\n        end\n        if (q_ref !== (q_ref ^ q_dut ^ q_ref)) begin\n            if (stats1.errors_q == 0) stats1.errortime_q = $time;\n            stats1.errors_q++;\n        end\n    end\n\n    // Queue variables for error display\n    reg [7:0] input_queue [$];\n    reg [7:0] got_queue [$];\n    reg [7:0] golden_queue [$];\n    reg reset_queue [$];\n    localparam MAX_QUEUE_SIZE = 8;\n\n    // Queue management and error display\n    always @(posedge clk, negedge clk) begin\n        if (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin\n            input_queue.delete(0);\n            got_queue.delete(0);\n            golden_queue.delete(0);\n            reset_queue.delete(0);\n        end\n        input_queue.push_back({d, r});\n        got_queue.push_back(q_dut);\n        golden_queue.push_back(q_ref);\n        reset_queue.push_back(r);\n\n        if (!tb_match) begin\n            $display(\"Mismatch detected at time %0t\", $time);\n            $display(\"Last %0d cycles of simulation:\", input_queue.size());\n            for (int i = 0; i < input_queue.size(); i++) begin\n                if (i == 0) $display(\"Got Mismatch\");\n                $display(\"Cycle %0d, reset %b, inputs %h / %h, got %h, expected %h\",\n                    i,\n                    reset_queue[i],\n                    input_queue[i][7:0], input_queue[i][15:8],\n                    got_queue[i], golden_queue[i]);\n            end\n        end\n    end\n\n    // Simulation timeout after 100K cycles\n    initial begin\n        #1000000 $display(\"TIMEOUT\");\n        $finish();\n    end\n\n    // Final simulation message\n    final begin\n        if (stats1.errors_q) begin\n            $display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0t\",\n                stats1.errors_q, stats1.errortime_q);\n        end else begin\n            $display(\"SIMULATION PASSED\");\n        end\n    end\n\nendmodule\n// END_OF_TESTBENCH"
