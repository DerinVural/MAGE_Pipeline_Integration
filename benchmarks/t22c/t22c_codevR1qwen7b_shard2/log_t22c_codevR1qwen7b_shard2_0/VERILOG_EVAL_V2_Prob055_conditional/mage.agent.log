    stimulus_gen stim1 (.clk(clk), .a(a), .b(b), .c(c), .d(d));
    RefModule good1 (.a(a), .b(b), .c(c), .d(d), .min(min_ref));
    TopModule top_module1 (.a(a), .b(b), .c(c), .d(d), .min(min_dut));
    assign tb_match = (min_ref === (min_ref ^ min_dut ^ min_ref));
    reg [INPUT_WIDTH-1:0] input_queue [0:MAX_QUEUE_SIZE-1]; // Adjust if needed
    reg [7:0] got_output_queue [0:MAX_QUEUE_SIZE-1];
    reg [7:0] golden_queue [0:MAX_QUEUE_SIZE-1];
    reg [64:0] reset_queue [0:MAX_QUEUE_SIZE-1];
    localparam MAX_QUEUE_SIZE = 10;
    always @(posedge clk, negedge clk) begin
        if (input_queue.size() >= MAX_QUEUE_SIZE) begin
            input_queue.delete(0);
            got_output_queue.delete(0);
            golden_queue.delete(0);
            reset_queue.delete(0);
        end
        input_queue.push_back({$time, a, b, c, d});
        got_output_queue.push_back(min_dut);
        golden_queue.push_back(min_ref);
        reset_queue.push_back(1'b0);
        if (!tb_match) begin
            if (stats1.errors == 0) begin
                $display("First mismatch at time %0d", $time);
                for (int i = 0; i < input_queue.size(); i++) begin
