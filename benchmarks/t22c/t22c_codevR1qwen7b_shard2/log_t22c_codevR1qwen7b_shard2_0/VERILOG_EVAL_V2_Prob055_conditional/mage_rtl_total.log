                for (int i = 0; i < input_queue.size(); i++) begin
                    $display("Cycle %0d: a=%h, b=%h, c=%h, d=%h, got=%h, expected=%h", i, input_queue[i].a, input_queue[i].b, input_queue[i].c, input_queue[i].d, got_output_queue[i], golden_queue[i]);
