	hwire tb_match = (out_ref === (out_ref ^ out_dut ^ out_ref));
	always @(posedge clk, negedge clk) begin
		stats1.clocks++;
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
			input_queue[stats1.errors][0] = clk;
			input_queue[stats1.errors][5:1] = {a, b, c, d, e};
			got_queue[stats1.errors] = out_dut;
			golden_queue[stats1.errors] = out_ref;
		end
		if (stats1.errors >= MAX_QUEUE_SIZE) begin
			for (int i=0; i < MAX_QUEUE_SIZE-1; i++) begin
				input_queue[i] = input_queue[i+1];
				got_queue[i] = got_queue[i+1];
				golden_queue[i] = golden_queue[i+1];
			end
		end
	end
	stimulus_gen stim_gen (.clk(clk), .a(a), .b(b), .c(c), .d(d), .e(e));
	RefModule ref_mod (.a(a), .b(b), .c(c), .d(d), .e(e), .out(out_ref));
	TopModule top_mod (.a(a), .b(b), .c(c), .d(d), .e(e), .out(out_dut));
	final begin
		display_first_mismatch();
		if (stats1.errors) $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
		esle $display("SIMULATION PASSED");
	end
	task display_first_mismatch();
		if (stats1.errors > 0) begin
			$display("First mismatch occurred at %0d ps", stats1.errortime);
			for (int i=1; i <= stats1.errors && i <= MAX_QUEUE_SIZE; i++) begin
