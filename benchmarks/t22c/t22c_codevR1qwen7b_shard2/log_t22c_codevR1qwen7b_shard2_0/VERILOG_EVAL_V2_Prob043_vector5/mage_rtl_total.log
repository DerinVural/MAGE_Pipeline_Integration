			end
		end else begin
			$display("SIMULATION PASSED");
		end
	endtask
endmodule
module stimulus_gen (input clk, output logic a, b, c, d, e);
	initial repeat(100) @(posedge clk) {a,b,c,d,e} = $random;
endmodule
