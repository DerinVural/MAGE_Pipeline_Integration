module tb();
    reg clk;
    logic a, b, c, d, e;
    logic [24:0] out_ref, out_dut;
    int errors, errortime, errors_out;
    int clocks;

    // Clock generation
    initial clk = 0;
    always #5 clk = ~clk;

    // Stimulus
    initial begin
        errors = 0;
        errortime = 0;
        errors_out = 0;
        clocks = 0;
        for (int i = 0; i < 100; i++) begin
            {a,b,c,d,e} = $urandom;
            @(negedge clk);
        end
        #10 $finish;
    end

    // Reference module
    RefModule ref_mod(a, b, c, d, e, out_ref);

    // DUT
    TopModule dut(a, b, c, d, e, out_dut);

    // Check for mismatches
    always @(negedge clk) begin
        if (errors == 0 && (out_ref !== out_dut)) begin
            errors = errors + 1;
            errortime = $time;
        end else if (out_ref !== out_dut) begin
            errors = errors + 1;
        end
        clocks++;
    end

    // Simulation end and report
    final begin
        if (errors) begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", errors, errortime);
            $display("First Mismatch at time %0d: a=%b, b=%b, c=%b, d=%b, e=%b\nout_dut=%b (expected %b)", errortime, a, b, c, d, e, out_dut, out_ref);
        end else begin
            $display("SIMULATION PASSED");
        end
    end
endmodule

