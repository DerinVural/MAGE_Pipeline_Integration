module stimulus_gen (clk);
  input clk;
  output logic a, b, c;

  task wavedrom_start(); endtask
  task wavedrom_stop(); endtask

  initial begin
    {a,b,c} <= 3'b0;
    wavedrom_start();
    repeat(10) @(posedge clk) {a,b,c} <= $urandom % 8;
    wavedrom_stop();
    #1 $finish;
  end
endmodule

module tb();
  typedef struct packed {
    int errors;
    int errortime;
    int errors_out;
    int errortime_out;
    int clocks;
  } stats;
  stats stats1 = 0;
  logic clk = 0;
  initial forever #5 clk = ~clk;

  logic a, b, c;
  logic out_ref, out_dut;
  wire tb_match = (out_ref === out_dut);

  TopModule dut (.a(a), .b(b), .c(c), .out(out_dut));
  RefModule gm (.a(a), .b(b), .c(c), .out(out_ref));

  reg [2:0] input_queue [4:0]; reg [0:0] got_queue [4:0]; reg [0:0] exp_queue [4:0]; reg rst_queue [4:0];
  localparam MAX_QUEUE_SIZE = 5;
  integer queue_ptr;

  always @(posedge clk) begin
    if (tb_match === 0) begin
      if (stats1.errors == 0) begin
        $display("Simulation FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0t", stats1.errors + 1, $time);
        $display("First Mismatch at time %0t", stats1.errortime);
        $display("Cycle %0d: Inputs a=%b, b=%b, c=%b; Expected %b, Got %b", queue_ptr, a, b, c, exp_queue[queue_ptr], got_queue[queue_ptr]);
      end
      stats1.errors += 1;
      if (stats1.errors == 1) stats1.errortime = $time;
    end
    stats1.clocks += 1;
    // Queue management
    if (queue_ptr < MAX_QUEUE_SIZE - 1) queue_ptr += 1;
    input_queue[queue_ptr] = {a,b,c};
    got_queue[queue_ptr] = out_dut;
    exp_queue[queue_ptr] = out_ref;
  end

  initial begin
    $dumpfile("tb.vcd"); $dumpvars(1, tb);
    #1000000 $display("TIMEOUT"); $finish;
  end
endmodule
module RefModule (a, b, c, out);
  input a, b, c;
  output out;
  assign out = a | b | c;
endmodule

