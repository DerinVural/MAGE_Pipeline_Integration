module stimulus_gen (
    input clk,
    output reg a,
    output reg b,
    output reg c,
    output reg d
);
    task wavedrom_start(); endtask
    task wavedrom_stop(); endtask
    initial begin
        reg [3:0] count = 0;
        {a, b, c, d} <= 4'b0;
        wavedrom_start();
        repeat(16) @(posedge clk) {a, b, c, d} <= count++;
        @(negedge clk) wavedrom_stop();
        repeat(200) @(posedge clk, negedge clk) {d, c, b, a} <= $urandom;
        #1 $finish;
    end
endmodule

module tb();
    reg clk = 0;
    initial forever #5 clk = ~clk;
    logic a, b, c, d;
    wire out_ref, out_dut;
    wire tb_mismatch;
    stats stats1 = '(.errors(0), .errortime(0), .errors_out(0), .errortime_out(0), .clocks(0));
    reg [3:0] input_queue [0:9];
    reg [0:9] got_out_queue;
    reg [0:9] expected_out_queue;
    integer queue_size = 0;
    integer MAX_QUEUE_SIZE = 5;

    stimulus_gen stim1 (.clk(clk), .a(a), .b(b), .c(c), .d(d));
    RefModule good1 (.a(a), .b(b), .c(c), .d(d), .out(out_ref));
    TopModule top_module1 (.a(a), .b(b), .c(c), .d(d), .out(out_dut));
    assign tb_mismatch = (out_ref !== out_dut);

    always @(posedge clk, negedge clk) begin
        stats1.clocks <= (stats1.clocks == 0) ? 1 : stats1.clocks + 1;
        if (tb_mismatch) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors <= stats1.errors + 1;
            if (queue_size < MAX_QUEUE_SIZE) begin
                input_queue[queue_size] = {a, b, c, d};
                got_out_queue[queue_size] = out_dut;
                expected_out_queue[queue_size] = out_ref;
                queue_size <= queue_size + 1;
            end
        end
    end

    initial begin
        fork
            begin
                wait(stats1.clocks >= 1000000);
                $display("TIMEOUT");
                $finish;
            end
        join_none
    end

    final begin
        if (stats1.errors) begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
            $display("First mismatch inputs: %b %b %b %b", input_queue[0][3], input_queue[0][2], input_queue[0][1], input_queue[0][0]);
            $display("Got: %b Expected: %b", got_out_queue[0], expected_out_queue[0]);
        end else begin
            $display("SIMULATION PASSED");
        end
    end
endmodule

