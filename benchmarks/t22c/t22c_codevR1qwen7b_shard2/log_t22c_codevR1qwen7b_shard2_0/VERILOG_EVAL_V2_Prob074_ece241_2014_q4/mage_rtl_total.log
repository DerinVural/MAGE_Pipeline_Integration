module stimulus_gen (
    input clk,
    output logic x,
    output [511:0] wavedrom_title,
    output reg wavedrom_enable
);
    task wavedrom_start(); endtask
    task wavedrom_stop(); endtask
    initial begin
        x <= 0;
        #(5) x <= 0;
        #(5) x <= 0;
        #(5) x <= 0;
        #(5) x <= 0;
        #(5) x <= 1;
        #(5) x <= 1;
        #(5) x <= 1;
        #(5) x <= 1;
        #(5) wavedrom_stop();
        repeat(100) #(10) x <= $urandom;
        $finish;
    end
endmodule

module tb();
    typedef struct {
        int errors;
        int errortime;
        int errors_z;
        int errortime_z;
        int clocks;
    } stats;
    stats stats1 = '0;
    wire [511:0] wavedrom_title;
    reg wavedrom_enable;
    reg clk = 0;
    initial forever #(5) clk = ~clk;
    logic x, z_ref, z_dut;
    wire tb_match, tb_mismatch = ~tb_match;
    stimulus_gen stim1 (.clk(clk), .x(x), .wavedrom_title(wavedrom_title), .wavedrom_enable(wavedrom_enable));
    RefModule good1 (.clk(clk), .x(x), .z(z_ref));
    TopModule top_module1 (.clk(clk), .x(x), .z(z_dut));
    bit strobe = 0;
    task wait_for_timestep(); repeat(5) @(strobe = ~strobe); endtask
    // Queue variables for simulation mismatch display
    reg [511:0] input_queue [0:9]; // Wavedrom title is 512 bits
    reg x_queue [0:9];
    reg z_ref_queue [0:9];
    reg z_dut_queue [0:9];
    reg reset_queue [0:9]; // Assuming initial reset to 0 (but no reset in module spec)
    localparam MAX_QUEUE_SIZE = 10;
    // Simulation time tracking for queue management
    always @(posedge clk, negedge clk) begin
        if (input_queue[0] !== '0) begin // Circular buffer
            for (int i=0; i<MAX_QUEUE_SIZE-1; i++) begin
                input_queue[i] = input_queue[i+1];
                x_queue[i] = x_queue[i+1];
                z_ref_queue[i] = z_ref_queue[i+1];
                z_dut_queue[i] = z_dut_queue[i+1];
                reset_queue[i] = reset_queue[i+1];
            end
        end
        input_queue[MAX_QUEUE_SIZE-1] = wavedrom_title;
        x_queue[MAX_QUEUE_SIZE-1] = x;
        z_ref_queue[MAX_QUEUE_SIZE-1] = z_ref;
        z_dut_queue[MAX_QUEUE_SIZE-1] = z_dut;
        reset_queue[MAX_QUEUE_SIZE-1] = 0; // No reset in spec, but initializing to 0
        // Check mismatch
        if (tb_mismatch && stats1.errors == 0) begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
            for (int i=0; i<MAX_QUEUE_SIZE; i++) begin
                $display("Cycle %0d, reset %b, wavedrom_title %h, x %b, got z %b, exp z %b",
                    i, reset_queue[i], input_queue[i], x_queue[i], z_dut_queue[i], z_ref_queue[i]);
            end
            $display("SIMULATION PASSED"); // Adjust condition based on error detection
        end
    end
    // Error counting similar to original
    always @(posedge clk, negedge clk) begin
        stats1.clocks++;
        if (!tb_match) begin stats1.errors++; stats1.errortime = $time; end
        if (z_ref !== (z_ref ^ z_dut ^ z_ref)) begin stats1.errors_z++; stats1.errortime_z = $time; end
    end    // Timeout after 100K cycles
    initial #(100_000) begin $display("TIMEOUT"); $finish; end
    initial begin
        $dumpfile("wave.vcd");
        $dumpvars(0, tb);
    end
    // Final display
    final begin
        if (stats1.errors_z) $display("Output 'z' has %0d mismatches, first at %0d", stats1.errors_z, stats1.errortime_z);
        $display("Total %0d errors in %0d clocks", stats1.errors, stats1.clocks);
        $finish;
    end
endmodule
