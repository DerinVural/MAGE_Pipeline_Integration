        .b(b),
        .c(c),
        .d(d),
        .wavedrom_title(),
        .wavedrom_enable()
    );
    TopModule top_module1 (
        .a(a),
        .b(b),
        .c(c),
        .d(d),
        .out_sop(out_sop_dut),
        .out_pos(out_pos_dut)
    );
    RefModule good1 (
