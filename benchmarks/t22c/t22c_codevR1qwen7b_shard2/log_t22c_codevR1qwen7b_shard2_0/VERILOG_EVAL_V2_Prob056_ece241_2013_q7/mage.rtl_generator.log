[2026-05-14 11:52:12,149 - mage.rtl_generator - INFO] RTL code: module TopModule (input clk, input j, input k, output logic Q);

    // State parameters
    localparam Q0 = 0, Q1 = 1;
    logic next_Q;

    // Initialize Q to a known state
    initial begin
        Q = Q0;
    end

    // Sequential logic block for flip-flop behavior
    always @(posedge clk) begin
        case ({j, k})
            2'b00: Q <= Q; // Hold state
            2'b01: Q <= Q0; // Reset
            2'b10: Q <= Q1; // Set
            2'b11: Q <= ~Q; // Toggle
            default: Q <= Q; // Default case to prevent latches
        endcase
    end

endmodule;
