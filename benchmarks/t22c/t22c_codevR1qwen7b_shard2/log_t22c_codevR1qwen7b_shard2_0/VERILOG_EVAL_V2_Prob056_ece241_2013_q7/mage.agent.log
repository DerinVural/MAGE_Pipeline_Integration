[2026-05-14 11:51:29,214 - mage.agent - INFO] module TopModule (input clk, input j, input k, output logic Q);

    logic qold;

    initial Q = 0;
    initial qold = 0;

    always @(posedge clk) begin
        qold <= Q;
    end

    always @(posedge clk) begin
        case ({j,k})
            2'b00: Q <= qold;
            2'b01: Q <= 1'b0;
            2'b10: Q <= 1'b1;
            2'b11: Q <= ~qold;
        endcase
    end

