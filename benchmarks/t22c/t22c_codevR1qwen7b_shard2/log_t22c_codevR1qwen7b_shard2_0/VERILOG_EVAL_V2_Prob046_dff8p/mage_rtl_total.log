`timescale 1ps/1ps

module TopModule (clk, d, reset, q);
    input clk;
    input reset;
    input [7:0] d;
    output [7:0] q;

    // Implementation of 8 D flip-flops with active high sync reset to 0x34 on negedge clk
    reg [7:0] q_reg;
    always @(negedge clk) begin
        if (reset)
            q_reg <= 8'h34;
        else
            q_reg <= d;
    end
    assign q = q_reg;

endmodule

