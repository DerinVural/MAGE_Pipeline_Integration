timescale 1 ps/1 ps
`default_nettype none

module stimulus_gen (
    input logic clk,
    output logic [3:0] in
);
    logic [3:0] in_reg;
    initial in_reg = 0;
    // Placeholder tasks
    task nonedraw_start(input string msg); endtask
    task nonedraw_stop(); endtask
    // Simulation steps omitted for brevity
    always @(negedge clk) begin
        nonedraw_start("All combinations");
    end
    // Additional logic for in_reg updates
    always @(posedge clk) begin
        in_reg <= in_reg + 1;
    end
    assign in = in_reg;
endmodule

module tb();
    reg clk = 0;
    initial forever #5 clk = ~clk;
    logic [3:0] in;
    logic out_and_ref, out_and_dut;
    logic out_or_ref, out_or_dut;
    logic out_xor_ref, out_xor_dut;
    // Wavedrom ports but not connected
    wire [511:0] wavedrom_title;
    wire wavedrom_enable;
    int wavedrom_hide_after_time;
    // Instantiate modules
    stimulus_gen stim1 ( .clk(clk), .in(in) );
    TopModule top_module1 ( .in(in), .out_and(out_and_dut), .out_or(out_or_dut), .out_xor(out_xor_dut) );
    RefModule good1 ( .in(in), .out_and(out_and_ref), .out_or(out_or_ref), .out_xor(out_xor_ref) );
    // Error tracking variables
    integer errors = 0, errortime = 0;
    integer errors_out_and = 0, errortime_out_and = 0;
    integer errors_out_or = 0, errortime_out_or = 0;
    integer errors_out_xor = 0, errortime_out_xor = 0;
    integer clocks = 0;
    // Timeout handling
    initial begin #1000000; $display("TIMEOUT"); $finish(); end
    // Error checking process
    always @(posedge clk or negedge clk) begin
        clocks++;
        if ( (out_and_ref !== (out_and_ref ^ out_and_dut ^ out_and_ref)) ) begin
            if (errors == 0) errortime = $time;
            errors++;
            if (errors_out_and == 0) errortime_out_and = $time;
            errors_out_and++;
        end
        if ( (out_or_ref !== (out_or_ref ^ out_or_dut ^ out_or_ref)) ) begin
            if (errors_out_or == 0) errortime_out_or = $time;
            errors_out_or++;
        end
        if ( (out_xor_ref !== (out_xor_ref ^ out_xor_dut ^ out_xor_ref)) ) begin
            if (errors_out_xor == 0) errortime_out_xor = $time;
            errors_out_xor++;
        end
    end
    // Display final result
    final begin
        if (errors) begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", errors, errortime);
            $display("First mismatch: in=%b, out_and_ref=%b, out_and_dut=%b", in, out_and_ref, out_and_dut);
            $display("out_or_ref=%b, out_or_dut=%b", out_or_ref, out_or_dut);
            $display("out_xor_ref=%b, out_xor_dut=%b", out_xor_ref, out_xor_dut);
        end else begin
            $display("SIMULATION PASSED");
        end
    end
endmodule
