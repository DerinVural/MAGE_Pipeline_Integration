);

    task wavedrom_start(input[511:0] title = ""); endtask
    task wavedrom_stop; #1; endtask

    initial begin
        in <= 0;
        @(posedge clk);
        wavedrom_start();
        repeat(2) @(posedge clk);
        in <= 1;
        repeat(4) @(posedge clk);
        in <= 0;
        repeat(4) @(negedge clk);
        in <= 6;
        repeat(2) @(negedge clk);
        in <= 0;
        repeat(2) @(posedge clk);
        wavedrom_stop();

        repeat(200) @(posedge clk, negedge clk) in <= $random;
        $finish;
    end
endmodule

