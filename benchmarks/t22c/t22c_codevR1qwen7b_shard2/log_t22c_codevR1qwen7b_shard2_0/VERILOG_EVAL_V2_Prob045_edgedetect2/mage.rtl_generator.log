    input logic clk,
    input logic [7:0] in,
    output logic [7:0] anyedge
);

    // Registers to store previous input values
    logic [7:0] prev_in;

    // Update previous input on every clock edge
    always @(posedge clk) begin
        prev_in <= in;
    end

    // Combinational logic to detect edges: (current != previous) => anyedge = current ^ prev_in
    // Then register the edge detection for one cycle delay
    logic [7:0] edge_detect;

    // Detect changes: XOR between current and previous input
    assign edge_detect = in ^ prev_in;

    // Register the edge_detect to output on next cycle
    always @(posedge clk) begin
        anyedge <= edge_detect;
    end

endmodule
