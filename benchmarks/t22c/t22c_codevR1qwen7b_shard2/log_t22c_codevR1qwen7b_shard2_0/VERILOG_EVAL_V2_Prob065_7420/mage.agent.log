module TopModule (    input p1a, p1b, p1c, p1d,    input p2a, p2b, p2c, p2d,    output p1y, p2y);
// The actual implementation of the 7420's two 4-input NAND gates.
// Each output is the NAND of all four inputs.

assign p1y = ~(p1a & p1b & p1c & p1d);
assign p2y = ~(p2a & p2b & p2c & p2d);
endmodule

