    "testbench": "`timescale 1ps/1ps\n\nmodule TopModule (    input p1a, p1b, p1c, p1d,    input p2a, p2b, p2c, p2d,    output p1y, p2y);\n// The actual implementation of the 7420's two 4-input NAND gates.\n// Each output is the NAND of all four inputs.\n\nassign p1y = ~(p1a & p1b & p1c & p1d);\nassign p2y = ~(p2a & p2b & p2c & p2d);\nendmodule\n\nmodule stimulus_gen (    input clk,    output reg p1a, p1b, p1c, p1d,    output reg p2a, p2b, p2c, p2d); // Wavedrom ports not part of TopModule's interface\n    task wavedrom_start(input[511:0] title = \"\"); endtask\n    task wavedrom_stop; #1; endtask\n    initial begin        int count; count = 0;\n        {p1a,p1b,p1c,p1d} <= 4'h0;\n        {p2a,p2b,p2c,p2d} <= 4'h0;\n        wavedrom_start(\"Two NAND gates\");\n        repeat(20) @(posedge clk) begin\n            {p1a,p1b,p1c,p1d} <= count;\n            {p2a,p2b,p2c,p2d} <= count+1;\n            count = count + 1;\n        end\n        wavedrom_stop();\n        repeat(200) @(posedge clk, negedge clk) begin\n            {p1a,p1b,p1c,p1d,p2a,p2b,p2c,p2d} <= $random;\n        end\n        #1 $finish;\n    end\nendmodule\n\nmodule tb();    typedef struct {        int errors;        int errortime;        int errors_p1y;        int errortime_p1y;        int errors_p2y;        int errortime_p2y;        int clocks;    } stats;    stats stats1;    reg clk = 0;    initial forever #5 clk = ~clk;\n    // Instantiate the DUT and references    logic p1a, p1b, p1c, p1d, p2a, p2b, p2c, p2d;    logic p1y_ref, p1y_dut, p2y_ref, p2y_dut;\n    // Reference module (golden)    RefModule ref1(.p1a(p1a), .p1b(p1b), .p1c(p1c), .p1d(p1d), .p2a(p2a), .p2b(p2b), .p2c(p2c), .p2d(p2d), .p1y(p1y_ref), .p2y(p2y_ref));    // DUT    TopModule dut(.p1a(p1a), .p1b(p1b), .p1c(p1c), .p1d(p1d), .p2a(p2a), .p2b(p2b), .p2c(p2c), .p2d(p2d), .p1y(p1y_dut), .p2y(p2y_dut));    // Error tracking    bit strobe = 0;\n    task wait_for_stable; repeat(5) begin strobe <= ~strobe; @(strobe); end endtask\n    // Compar