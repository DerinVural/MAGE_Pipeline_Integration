    "interface": "module TopModule (  input p1a,  input p1b,  input p1c,  input p1d,  input p2a,  input p2b,  input p2c,  input p2d,  output p1y,  output p2y);  // Implementation of 7420 functionality endmodule",
    "testbench": "`timescale 1ps/1ps\n\nmodule TopModule (    input p1a, p1b, p1c, p1d,    input p2a, p2b, p2c, p2d,    output p1y, p2y);\n// The actual implementation of the 7420's two 4-input NAND gates.\n// Each output is the NAND of all four inputs.\n\nassign p1y = ~(p1a & p1b & p1c & p1d);\nassign p2y = ~(p2a & p2b & p2c & p2d);\nendmodule\n\nmodule stimulus_gen (    input clk,    output reg p1a, p1b, p1c, p1d,    output reg p2a, p2b, p2c, p2d); // Wavedrom ports not part of TopModule's interface\n    task wavedrom_start(input[511:0] title = \"\"); endtask\n    task wavedrom_stop; #1; endtask\n    initial begin        int count; count = 0;\n        {p1a,p1b,p1c,p1d} <= 4'h0;\n        {p2a,p2b,p2c,p2d} <= 4'h0;\n        wavedrom_start(\"Two NAND gates\");\n        repeat(20) @(posedge clk) begin\n            {p1a,p1b,p1c,p1d} <= count;\n            {p2a,p2b,p2c,p2d} <= count+1;\n            count = count + 1;\n        end\n        wavedrom_stop();\n        repeat(200) @(posedge clk, negedge clk) begin\n            {p1a,p1b,p1c,p1d,p2a,p2b,p2c,p2d} <= $random;\n        end\n        #1 $finish;\n    end\nendmodule\n\nmodule tb();    typedef struct {        int errors;        int errortime;        int errors_p1y;        int errortime_p1y;        int errors_p2y;        int errortime_p2y;        int clocks;    } stats;    stats stats1;    reg clk = 0;    initial forever #5 clk = ~clk;\n    // Instantiate the DUT and references    logic p1a, p1b, p1c, p1d, p2a, p2b, p2c, p2d;    logic p1y_ref, p1y_dut, p2y_ref, p2y_dut;\n    // Reference module (golden)    RefModule ref1(.p1a(p1a), .p1b(p1b), .p1c(p1c), .p1d(p1d), .p2a(p2a), .p2b(p2b), .p2c(p2c), .p2d(p2d), .p1y(p1y_ref), .p2y(p2y_ref));    // DUT    TopModule dut(.p1a(p1a), .p1b(p1b), .p1c(p1c), .p1d(p1d), .p2a(p2a), .p2b(p2b), .p2c(p2c), .p2d(p2d), .p1y(p1y_dut), .p2y(p2y_dut));    // Error tracking    bit strobe = 0;\n    task wait_for_stable; repeat(5) begin strobe <= ~strobe; @(strobe); end endtask\n    // Comparisons    always @(posedge clk, negedge clk) begin        stats1.clocks++;\n        // Compare outputs        if ( ( {p1y_ref, p2y_ref} !== { p1y_dut, p2y_dut } )) begin            if (stats1.errors == 0) stats1.errortime = $time;            stats1.errors++;\n            if (stats1.errors_p1y == 0 && p1y_ref !== p1y_dut) stats1.errortime_p1y = $time;            stats1.errors_p1y += (p1y_ref !== p1y_dut);\n            if (stats1.errors_p2y == 0 && p2y_ref !== p2y_dut) stats1.errortime_p2y = $time;            stats1.errors_p2y += (p2y_ref !== p2y_dut);\n        end        // Display first error        if (stats1.errors && !stats1.errortime) begin            stats1.errortime = $time;            $display(\"First MISMATCH AT TIME %0d: Inputs: p1a=%b, p1b=%b, p1c=%b, p1d=%b, p2a=%b, p2b=%b, p2c=%b, p2d=%b\", $time, p1a, p1b, p1c, p1d, p2a, p2b, p2c, p2d);            $display(\"Expected Outputs: p1y=%b, p2y=%b\", p1y_ref, p2y_ref);            $display(\"Actual Outputs: p1y=%b, p2y=%b\", p1y_dut, p2y_dut);\n        end    end    // Simulation control    initial begin        wait_for_stable();        #1000000 $display(\"TIMEOUT\"); $finish();    end    // Final results    final begin        if (stats1.errors) begin            $display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\", stats1.errors, stats1.errortime);\n        end else begin            $display(\"SIMULATION PASSED\");\n        end    endendmodule\n"
}
