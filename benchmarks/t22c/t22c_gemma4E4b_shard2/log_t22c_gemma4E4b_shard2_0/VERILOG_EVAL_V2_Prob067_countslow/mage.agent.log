module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_q;
		int errortime_q;

		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic slowena;
	logic reset;
	logic [3:0] q_ref;
	logic [3:0] q_dut;

	// --- Queue Definitions for Mismatch Checking ---
	reg [1:0] clk_q [$];
	reg [1:0] slowena_q [$];
	reg [1:0] reset_q [$];
	reg [3:0] q_ref_q [$];
	reg [3:0] q_dut_q [$];
	
	localparam MAX_QUEUE_SIZE = 10; // Set to 10 as per constraint
	
	// Tracking variables for first mismatch detection
	bit mismatch_detected = 0;
	int first_mismatch_time = 0;
	int total_mismatches = 0;
	int total_samples = 0;
	
	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,clk,slowena,reset,q_ref,q_dut );
	end


	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk,
		.* ,
		slowena,
		.reset );
	RefModule good1 (
		.clk,
		slowena,
		.reset,
		.q(q_ref) );
	
	TopModule top_module1 (
		.clk,
		slowena,
		.reset,
		.q(q_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		endtask	
	
	// Reset stats for final display
	initial begin
		stats1.errors = 0;
		stats1.errortime = 0;
		stats1.errors_q = 0;
		stats1.errortime_q = 0;
		stats1.clocks = 0;
	end

	// --- Clocked Logic for State Tracking and Mismatch Checking ---
	always @(posedge clk, negedge clk) begin
		if (!mismatch_detected) begin
			// 1. Store inputs and outputs
			clk_q.push_back(clk);
			slowena_q.push_back(slowena);
			reset_q.push_back(reset);
			q_ref_q.push_back(q_ref);
			q_dut_q.push_back(q_dut);

			// 2. Increment clock count
			stats1.clocks++;

			// 3. Check for mismatch (Original logic)
			if (!tb_match) begin
				if (stats1.errors == 0) stats1.errortime = $time;
				sT	stats1.errors++;
			end
			
			// 4. Check for queue mismatch (Required logic)
			if (q_ref !== ( q_ref ^ q_dut ^ q_ref )) // Original check logic
			begin 
				if (stats1.errors_q == 0) stats1.errortime_q = $time;
				sT	stats1.errors_q = stats1.errors_q+1'b1;
			end
			
			// 5. Check for *first* queue mismatch and trigger display
			if (!tb_match && mismatch_detected == 0) begin
				mismatch_detected = 1;
				first_mismatch_time = $time;
				end
			end
		end
		
		// Queue management (Maintain size limit)
		if (clk_q.size() >= MAX_QUEUE_SIZE) begin
			clk_q.delete(0);
			slowena_q.delete(0);
			reset_q.delete(0);
			q_ref_q.delete(0);
			q_dut_q.delete(0);
		end
	end

	// Display logic when first mismatch occurs (Synchronized with clock edge)
	always @(posedge clk, negedge clk) begin
		if (mismatch_detected && stats1.errors_q == 1 && stats1.errortime_q == $time) begin
			$display("\n========================================================================");
			$display("// Queue-based simulation mismatch display triggered at time %0d", $time);
			$display("// Last %0d cycles of simulation (MAX_QUEUE_SIZE=%0d):", q_ref_q.size());

			for (int i = 0; i < q_ref_q.size(); i++) begin
				if (q_dut_q[i] === q_ref_q[i]) begin
				$display("Got Match at cycle %0d", i);
				// Display format: Cycle, reset, input, got output, exp output
				$display("Cycle %0d, reset %b, slowena %b, got output %h (%b), exp output %h (%b)",
				i, reset_q[i], slowena_q[i], q_dut_q[i], q_dut_q[i], q_ref_q[i], q_ref_q[i]);
			end else begin
				$display("Got Mismatch at cycle %0d", i);
				// Display format: Cycle, reset, input, got output, exp output
				$display("Cycle %0d, reset %b, slowena %b, got output %h (%b), exp output %h (%b)",
				i, reset_q[i], slowena_q[i], q_dut_q[i], q_dut_q[i], q_ref_q[i], q_ref_q[i]);
			end
		end
		$display("========================================================================\n");
		end

	// add timeout after 100K cycles
	initial begin
		#1000000
		if (total_mismatches == 0) begin
			s$display("SIMULATION PASSED");
		end else begin
			s$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", total_mismatches, stats1.errortime);
		end
		$finish();
	end


	// Final reporting (Modified from original final block)
	initial begin
		// Original reporting kept for context/legacy if needed, but main report is handled by timeout block
		// if (stats1.errors_q) $display("Hint: Output '%s' has %0d mismatches. First mismatch occurred at time %0d.", "q", stats1.errors_q, stats1.errortime_q);
		// else $display("Hint: Output '%s' has no mismatches.", "q");

		// $display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		// $display("Simulation finished at %0d ps\n", $time);
		// $display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
	end

endmodule
