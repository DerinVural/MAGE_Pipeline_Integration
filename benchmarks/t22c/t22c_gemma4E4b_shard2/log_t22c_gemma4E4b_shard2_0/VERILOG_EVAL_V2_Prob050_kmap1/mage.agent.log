		mismatch_out_dut_hex = out_dut[7:0];
		mismatch_out_dut_bin = out_dut;
		end
		end
	
end

// add timeout after 100K cycles
initial begin
	#1000000
	$display("TIMEOUT");
	$finish();
end

endmodule
