	endtask	

	initial begin
		int count; count = 0;
		{a,b,c} <= 1'b0;
		wavedrom_start();
		repeat(10) @(posedge clk)
			{a,b,c} <= count++;
		wavedrom_stop();
		
		repeat(200) @(posedge clk, negedge clk)
