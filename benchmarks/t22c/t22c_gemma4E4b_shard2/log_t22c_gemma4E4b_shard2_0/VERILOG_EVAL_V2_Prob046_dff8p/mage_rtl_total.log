opModule top_module1 (\n\t\t.clk,\n\t\td,\n\t\t.reset,\n\t\t.q(q_dut) );\n\n\n\tbit strobe = 0;\n\t\ttask wait_for_end_of_timestep;\n\t\t\trepeat(5) begin\n\t\t\tstrobe <= !strobe;  // Try to delay until the very end of the time step.\n\t\t\t@(strobe);\n\t\t\tend\n\t\tendtask\t\n\n\t// --- Queue and Mismatch Detection Logic (Sequential Logic) ---\n\talways @(posedge clk, negedge clk) begin\n\t\t// 1. Queue Management (Maintain MAX_QUEUE_SIZE)\n\t\tif (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin\n\t\t\tinput_queue.delete(0);\n\t\t\tgot_output_queue.delete(0);\n\t\t\tgolden_queue.delete(0);\n\t\t\treset_queue.delete(0);\n\t\tend\n\n\t\t// 2. Store current cycle data\n\t\tinput_queue.push_back(d);\n\t\tgot_output_queue.push_back(q_dut);\n\t\tgolden_queue.push_back(q_ref);\n\t\treset_queue.push_back(reset);\n\n\t\t// 3. Update Stats\n\t\tstats1.clocks++;\n\t\t\n\t\t// Check for overall mismatch (Original functionality)\n\t\tif (!((q_ref === q_dut))) begin\n\t\t\tif (stats1.errors == 0) stats1.errortime = $time;\n\t\t\ts$display("--- OVERALL MISMATCH DETECTED AT TIME %0t ---", $time);\n\t\t\t$display("History leading to first overall mismatch (Last %0d cycles):", input_queue.size());\n\t\t\tfor (int i = 0; i < input_queue.size(); i++) begin\n\t\t\t\tif (got_output_queue[i] === golden_queue[i]) \n\t\t\t\t$display("Cycle %d, reset %b, input %h, got output %h, exp output %h -> MATCH");\n\t\t\telse \n\t\t\t\t$display("Cycle %d, reset %b, input %h, got output %h, exp output %h -> MISMATCH");\n\t\t\tend\n\t\t\tend\n\t\t\tstats1.errors++;\n\t\tend\n\n\t\t// Check for first queue-based mismatch (Requirement 1.1)\n\t\tif (q_ref !== q_dut) begin\n\t\t\tif (stats1.errors_q == 0) stats1.errortime_q = $time;\n\t\t\ts$display("\\n\\n======================================================================");\n\t\t\ts$display("// Queue-based simulation mismatch display triggered at time %0t", $time);\n\t\t\t$display("// Last %0d cycles of simulation history:", input_queue.size());\n\t