tep task as it is irrelevant for this combinational check\n\t\n\tfinal begin\n\t\tif (stats1.errors_min > 0) begin\n\t\t\t$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_min, stats1.errortime_min);\n\t\tend else begin\n\t\t\t$display("SIMULATION PASSED");\n\t\tend\n\t\t\n\t\t$display("Simulation finished at %0d ps", $time);\n\tend\n\t\n\t// Verification: Direct comparison for combinational logic\n\tassign tb_match = (min_ref === min_dut);\n\t\t\n\t// Clocked check to capture state at the end of the cycle where mismatch is detected\n\talways @(posedge clk, negedge clk) begin\n\t\tstats1.clocks++;\n\t\t\n\t\t// Error Counting Logic (Maintaining original error logic structure)\n\t\tif (!tb_match) begin\n\t\t\tif (stats1.errors == 0) stats1.errortime = $time;\n\t\t\tsstats1.errors++;\n\t\t\tend\n\t\tend\n\t\t\n\t\t// Tracking first error time (stats1.errors_min logic)\n\t\tif (min_ref !== min_dut) begin\n\t\t\tif (stats1.errors_min == 0) stats1.errortime_min = $time;\n\t\t\tsstats1.errors_min = stats1.errors_min + 1\'b1;\n\t\tend\n\t\tend\n\n   // Added logic to display details ONLY when the FIRST mismatch occurs\n   always @(posedge clk, negedge clk)\n   begin\n       if (stats1.errors_min == 1 && !tb_match)\n       begin\n           $display("\\n========================================================");\n           $display("FIRST MISMATCH DETECTED AT TIME %0d", $time);\n           $display("--------------------------------------------------------");\n           $display("Input Signals:");\n           $display("  a: %h (%b)", a, a);\n           $display("  b: %h (%b)", b, b);\n           $display("  c: %h (%b)", c, c);\n           $display("  d: %h (%b)", d, d);\n           $display("Expected Output (min_ref): %h (%b)", min_ref, min_ref);\n           $display("Actual Output (min_dut):   %h (%b)", min_dut, min_dut);\n           $display("========================================================\\n");\n       end\n   end\n\n   //