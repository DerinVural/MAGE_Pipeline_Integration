[2026-05-14 12:43:59,641 - mage.agent - INFO] `timescale 1 ps/1 ps
`define OK 12
`define INCORRECT 13


module stimulus_gen (
	input clk,
	output reg reset,
	output reg[511:0] wavedrom_title,
	output reg wavedrom_enable,
	input tb_match
);

	task reset_test(input async=0);
		bit arfail, srfail, datafail;
		
		@(posedge clk);
		@(posedge clk) reset <= 0;
		repeat(3) @(posedge clk);
		
		@(negedge clk) begin datafail = !tb_match ; reset <= 1; end
		@(posedge clk) arfail = !tb_match;
		@(posedge clk) begin
		srfail = !tb_match;
		reset <= 0;
		end
		if (srfail)
			$display("Hint: Your reset doesn't seem to be working.");
		else if (arfail && (async || !datafail))
			$display("Hint: Your reset should be %0s, but doesn't appear to be.", async ? "asynchronous" : "synchronous");
		// Don't warn about synchronous reset if the half-cycle before is already wrong. It's more likely
		// a functionality error than the reset being implemented asynchronously.
	endtask


// Add two ports to module stimulus_gen:
//    output [511:0] wavedrom_title
//    output reg wavedrom_enable

	task wavedrom_start(input[511:0] title = "");
	endtask
	
task wavedrom_stop;
		h#1;
	endtask
	
	
	
initial begin
		reset <= 1;
		wavedrom_start("Synchronous reset and counting");
		reset_test();
		repeat(12) @(posedge clk);
		wavedrom_stop();
		@(posedge clk);
		
		repeat(400) @(posedge clk, negedge clk) begin
		reset <= !($random & 31);
		end
		h#1 $finish;
	end

endmodule

module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_q;
		int errortime_q;

		int clocks;
	} stats;
	
	stats stats1;
	
	
wire[511:0] wavedrom_title;
wire wavedrom_enable;
int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		h#5 clk = ~clk;


logic reset;
logic [3:0] q_ref;
logic [3:0] q_dut;


// --- Queue-based Mismatch Detection Setup ---

// Since q is 4 bits, 2^4 = 16. We must cap at 10 as per instructions.
localparam MAX_QUEUE_SIZE = 10;

reg [3:0] input_reset_queue [$];
reg [3:0] got_output_queue [$];
reg [3:0] golden_queue [$];
reg [3:0] reset_queue [$];

// State tracking for final reporting
logic mismatch_detected = 0;


initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,clk,reset,q_ref,q_dut );
	end


wire tb_match;        // Verification
wire tb_mismatch = ~tb_match;
	
stimulus_gen stim1 (
		.clk, 
		.* , 
		.reset );
	RefModule good1 (
		.clk,
		.reset,
		.q(q_ref) );
	
TopModule top_module1 (
		.clk,
		.reset,
		.q(q_dut) );


	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		endtask
	

final begin
		if (stats1.errors_q) $display("Hint: Output 'q' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_q, stats1.errortime_q);
	else $display("SIMULATION PASSED");

	$display("Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
	$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
	$display("Simulation finished at %0d ps", $time);
	end
	
// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.
assign tb_match = ( { q_ref } === ( { q_ref } ^ { q_dut } ^ { q_ref } ) );

// --- Sequential Logic Queue and Check --- 
always @(posedge clk, negedge clk) begin
		
		stats1.clocks++;
		
		// Original Error Counting (MUST be maintained)
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
		end
		
		// Original Queue Error Counting (MUST be maintained)
		if (q_ref !== ( q_ref ^ q_dut ^ q_ref ))
		begin 
			if (stats1.errors_q == 0) stats1.errortime_q = $time;
			sstats1.errors_q = stats1.errors_q+1'b1; 
		end
		end

		// --- New Queue Mismatch Detection Logic ---
		if (!tb_match) begin
			mismatch_detected = 1;
		end

		// Manage queue size
		if (input_reset_queue.size() >= MAX_QUEUE_SIZE - 1) begin
			input_reset_queue.delete(0);
			got_output_queue.delete(0);
			golden_queue.delete(0);
			reset_queue.delete(0);
		end

		// Push current cycle data
		input_reset_queue.push_back(reset);
		got_output_queue.push_back(q_dut);
		golden_queue.push_back(q_ref);
		reset_queue.push_back(reset);

		// Check for first mismatch using the new queue logic
		if (!tb_match && got_output_queue.size() == 1) begin // Only check upon first mismatch detection
			$display("\n==============================================================");
			$display("Mismatch detected at time %0d", $time);
			$display("\nLast %0d cycles of simulation:", got_output_queue.size());
			
			for (int i = 0; i < got_output_queue.size(); i++) begin
				if (got_output_queue[i] === golden_queue[i]) begin
					$display("Got Match at Cycle %0d", i);
				end else begin
					$display("Got Mismatch at Cycle %0d", i);
				end
				// Display signals in HEX and BIN format (width <= 64 applies)
				$display("Cycle %0d, reset %b, input reset %h (%b), got output %h (%b), exp output %h (%b)",
				i,
				reset_queue[i],
				input_reset_queue[i],
				got_output_queue[i],
				golden_queue[i]
			);
			end
			$display("==============================================================\n");
		end
end

   // add timeout after 100K cycles
   initial begin
     #1000000
     if (!mismatch_detected)
         $display("SIMULATION PASSED (Timeout)");
     else
         $display("SIMULATION FAILED - x MISMATCHES DETECTED, FIRST AT TIME y (Timeout)\n");
     $finish();
   end

endmodule

