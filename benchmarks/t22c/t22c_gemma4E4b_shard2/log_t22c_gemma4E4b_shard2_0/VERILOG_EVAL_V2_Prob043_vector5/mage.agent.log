// --- Stimulus Generator (Kept from golden testbench) ---
module stimulus_gen (
	input clk,
	output logic a, b, c, d, e
);
		initial begin
			repeat(100) @(posedge clk, negedge clk)
				{a,b,c,d,e} <= $random;
			end
		$finish;
	endmodule


// --- Reference Module (Mocked/Kept from golden testbench) ---
// Assuming RefModule implements the correct golden comparison logic.
module RefModule (
	input a, b, c, d, e,
	output logic [24:0] out
);
	// For simulation purposes, we must implement a reference module.
	// Since the specification logic is based on pairwise comparison (X XNOR Y),
	// we implement that here as the expected reference.
	genvar i, j;
	generate
		for (i = 0; i < 5; i = i + 1)
		begin
			for (j = 0; j < 5; j = j + 1)
			begin
				// Map a, b, c, d, e to an array for easy indexing
				logic [4:0] inputs_arr = {a, b, c, d, e};
				// The comparison is (inputs_arr[i] XNOR inputs_arr[j])
				// XNOR is equivalent to ~(X ^ Y)
				assign out[i*5 + j] = ~(inputs_arr[i] ^ inputs_arr[j]);
			end
		end
	endgenerate
endmodule


// --- DUT Module Implementation (TopModule) ---
module TopModule (
	input a, input b, input c, input d, input e,
	output logic [24:0] out
);
		// Implementation based on: Output is 1 if the two bits being compared are equal (X XNOR Y).
		// Mapping: Indices 0-24 correspond to pairs (a,a), (a,b), ..., (e,e).
		// We map {a, b, c, d, e} to indices {0, 1, 2, 3, 4}
		logic [4:0] inputs_arr = {a, b, c, d, e};
		
		genvar i, j;
		generate
			for (i = 0; i < 5; i = i + 1)
			begin
				for (j = 0; j < 5; j = j + 1)
				begin
					// out[i*5 + j] = (inputs_arr[i] XNOR inputs_arr[j])
					assign out[i*5 + j] = ~(inputs_arr[i] ^ inputs_arr[j]);
				end
			end
		endgenerate
endmodule


