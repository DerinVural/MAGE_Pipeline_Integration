.push_back(w);\n\t\tinput_R_queue.push_back(R);\n\t\tinput_E_queue.push_back(E);\n\t\tinput_L_queue.push_back(L);\n\t\tgot_output_Q_queue.push_back(Q_dut);\n\t\tgolden_output_Q_queue.push_back(Q_ref);\n\n\t\t// Check for first mismatch for logging\n\t\tif (!tb_match && stats1.errors == 1) begin \n\t\t\t$display("==================================================================");\n\t\t\t$display("Queue-based simulation mismatch display started at time %t", $time);\n\t\t\t$display("First mismatch detected on the positive clock edge.");\n\t\t\t$display("Displaying last %d cycles of history:", input_w_queue.size());\n\t\t\t\n\t\t\tfor (int i = 0; i < input_w_queue.size(); i++) begin\n\t\t\t\t// Check if current cycle matches (This is tricky, we check the *history* vs expected)\n\t\t\t\t// Since we only log on mismatch, we display the state leading up to it.\n\t\t\t\t// We check if the logged state matches (which it should until the error)\n\t\t\t\t\n\t\t\t\tif (got_output_Q_queue[i] === golden_output_Q_queue[i]) begin\n\t\t\t\t\t$display("Cycle %d: Got Match (Q=%b)", i, got_output_Q_queue[i]);\n\t\t\t\tend else begin\n\t\t\t\t\t$display("Cycle %d: Got Mismatch (Q_dut=%b, Q_ref=%b) <- ERROR POINT", i, got_output_Q_queue[i], golden_output_Q_queue[i]);\n\t\t\t\tend\n\t\t\t\t$display("  Inputs: w=%b, R=%b, E=%b, L=%b | Outputs: Q_dut=%b, Q_ref=%b",\n\t\t\t\t    input_w_queue[i], input_R_queue[i], input_E_queue[i], input_L_queue[i],\n\t\t\t\t    got_output_Q_queue[i], golden_output_Q_queue[i]);\n\t\t\tend\n\t\t\t$display("==================================================================");\n\t\tend\n\tend\n\n\n// --- Initial Setup and Instantiations ---\n\tinitial begin \n\t\t$dumpfile("wave.vcd");\n\t\t$dumpvars(1, tb, clk,w,R,E,L,Q_ref,Q_dut );\n\tend\n\n\tstimulus_gen stim1 (\n\t\t.clk, \n\t\t.w, \n\t\tR, \n\t\t.E, \n\t\t.L );\n\tRefModule good1 (\n\t\t.clk, \n\t\t.w, \n\t\tR, \n\t\t.E, \n\t\t.L,\n\t\t.Q(Q_ref) );\n\tTopModule top_module1 (\n\t\t.clk, \n\t\tw, \n\t\tR, \n\t\t.E, \n\t\t.L, \n\t\t.Q(Q_dut) );\n\n\t\n\tbit strobe = 0;\n\ttask wait_for_end_of_timestep;\n\t\trepeat(5) begin\n\t\tstrobe <= !strobe;  // Try to delay until the very end of the time step.\n\t\t@(strobe);\n\t\tend\n\ttask\n\n\t// Add timeout after 100K cycles\n\tinitial begin\n\t\t#1000000\n\t\t$display("TIMEOUT");\n\t\t$finish();\n\tend\n\n\t// --- Final Reporting (Replacing original final block) ---\n\tinitial begin\n\t\t@(negedge clk);\n\t\t// Wait for simulation to run enough cycles to capture statistics\n\t\t#1000;\n\t\t\n\t\tif (stats1.errors == 0 && stats1.errors_Q == 0)\n\t\tbegin\n\t\t\t$display("SIMULATION PASSED");\n\t\tend\n\t\telse\n\t\tbegin\n\t\t\tint total_mismatches = stats1.errors;\n\t\t\tif (total_mismatches > 0)\n\t\t\t\t$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", total_mismatches, stats1.errortime);\n\t\t\telse\n\t\t\t\t// Fallback if errors count is zero but specific Q error occurred (shouldn\'t happen if logic is right)\n\t\t\t\t$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_Q, stats1.errortime_Q);\n\t\tend\n\t\t$finish;\n\tend\n\nendmodule\n</testbench>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nThe module interface is given below:\n<module_interface>\nmodule TopModule (\n    input clk,\n    input w,\n    input R,\n    input E,\n    input L,\n    output Q\n);\nendmodule\n</module_interface>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nYour response will be processed by a program, not human.\nSo, please STRICTLY FOLLOW the output format given as XML tag content below to generate a VALID JSON OBJECT:\n<output_format>\n{\n    "reasoning": "All reasoning steps and advices to avoid syntax error",\n    "module": "Pure SystemVerilog code, a complete module"\n}\n</output_format>\nDO NOT include any other information in you