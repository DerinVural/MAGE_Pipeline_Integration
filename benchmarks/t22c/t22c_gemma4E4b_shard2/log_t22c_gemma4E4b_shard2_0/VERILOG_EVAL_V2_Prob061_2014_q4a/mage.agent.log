					$display("Cycle %d: Got Mismatch (Q_dut=%b, Q_ref=%b) <- ERROR POINT", i, got_output_Q_queue[i], golden_output_Q_queue[i]);
				end
				$display("  Inputs: w=%b, R=%b, E=%b, L=%b | Outputs: Q_dut=%b, Q_ref=%b",
