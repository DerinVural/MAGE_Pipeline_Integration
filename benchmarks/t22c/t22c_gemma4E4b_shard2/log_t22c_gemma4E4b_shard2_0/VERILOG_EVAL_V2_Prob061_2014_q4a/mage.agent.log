	// Since Q is 1-bit, we track 1-bit values for outputs and input bundles.
	reg input_w_queue [$];
	reg input_R_queue [$];
	reg input_E_queue [$];
	reg input_L_queue [$];
	reg got_output_Q_queue [$];
	reg golden_output_Q_queue [$];
	
