	// We use the clock edge for queueing.
	
	localparam MAX_QUEUE_SIZE = 10;

	// --- Clocking and Mismatch Detection ---
	always @(posedge clk, negedge clk) begin
		// 1. Update Statistics (Original Logic)
		stats1.clocks++;
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
		end
		// Original specific Q mismatch check
		if (Q_ref !== ( Q_ref ^ Q_dut ^ Q_ref ))
		begin 
			if (stats1.errors_Q == 0) stats1.errortime_Q = $time;
			sstats1.errors_Q = stats1.errors_Q+1'b1; 
