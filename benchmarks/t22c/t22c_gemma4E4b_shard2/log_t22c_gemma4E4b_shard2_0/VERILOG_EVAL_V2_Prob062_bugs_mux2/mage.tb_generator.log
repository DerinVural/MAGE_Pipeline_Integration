ime of first error\n\t\t\t\ts\t\tstats1.errortime_out = $time; // Record time of first error for output\n\t\t\tend\n\t\tend\n\tend\n\n\t// The original testbench used a separate tb_match signal derived from XOR, which we simplify here.\n\t// The mismatch detection is now embedded in the always block above.\n\n\t\n\t// Finalization Block (Modified to meet new requirements)\n\tinitial begin\n\t\t// Wait until simulation is near completion or timeout\n\t\t@(negedge clk);\n\t\t#10;\n\t\t\n\t\t// Final Display Logic\n\t\tif (stats1.errors == 0) begin\n\t\t\t$display(\"SIMULATION PASSED\");\n\t\tend else begin\n\t\t\t$display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\", stats1.errors, stats1.errortime);\n\t\tend\n\t\t\n\t\t// Display detailed error information for the FIRST mismatch (Combinational Logic Rule 2)\n\t\tif (stats1.errors > 0 && first_error_clock != -1) begin\n\t\t\t$display(\"\\n--- FIRST MISMATCH DETAILS ---\");\n\t\t\t$display(\"Mismatch detected at time %0d\", stats1.errortime);\n\t\t\t$display(\"Cycle where first mismatch occurred: %0d\", first_error_clock);\n\t\t\t$display(\"Input signals at mismatch:\");\n\t\t\t$display(\"  sel: %b\", sel);\n\t\t\t$display(\"  a: %h (%b)\", a, a);\n\t\t\t$display(\"  b: %h (%b)\", b, b);\n\t\t\t$display(\"Output signals at mismatch:\");\n\t\t\t$display(\"  Golden Output (out_ref): %h (%b)\", out_ref, out_ref);\n\t\t\t$display(\"  DUT Output (out_dut): %h (%b)\", out_dut, out_dut);\n\t\t\tend\n\t\t$finish;\n\tend\n\n\n\t// add timeout after 100K cycles (Original logic maintained)\n\tinitial begin\n\t\t#1000000\n\t\t$display(\"TIMEOUT\");\n\t\t$finish();\n\tend\n\nendmodule"
