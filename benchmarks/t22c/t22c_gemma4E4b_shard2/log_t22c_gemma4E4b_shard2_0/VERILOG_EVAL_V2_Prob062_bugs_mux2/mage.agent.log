[2026-05-14 16:05:15,782 - mage.agent - INFO] // Corrected and improved testbench for TopModule
`timescale 1 ps/1 ps

// Define the module under test (DUT) based on the input spec
module TopModule (
    input        sel,
    input  [7:0] a,
    input  [7:0] b,
    output       out
);

    // Implementation (Fixing the 'bug' by using the specified correct logic)
    assign out = (~sel & a) | (sel & b);

endmodule

// Define the reference module used in the golden testbench
module RefModule (
    input        sel,
    input  [7:0] a,
    input  [7:0] b,
    output       out
);

    // Reference implementation matching TopModule logic
    assign out = (~sel & a) | (sel & b);

endmodule

// Stimulus Generator (Copied exactly from golden testbench)
module stimulus_gen (
	input clk,
	output logic sel,
	output logic [7:0] a, b,
	output reg[511:0] wavedrom_title,
	output reg wavedrom_enable
);


// Add two ports to module stimulus_gen:
//    output [511:0] wavedrom_title
//    output reg wavedrom_enable

	task wavedrom_start(input[511:0] title = "");
endtask
	task wavedrom_stop;
		#1;
	endtask

	initial begin
		{a, b, sel} <= '0;
		@(negedge clk) wavedrom_start("");
		@(posedge clk, negedge clk) {a,b,sel} <= {8'haa, 8'hbb, 1'b0};
		@(posedge clk, negedge clk) {a,b,sel} <= {8'haa, 8'hbb, 1'b0};
		@(posedge clk, negedge clk) {a,b,sel} <= {8'haa, 8'hbb, 1'b1};
		@(posedge clk, negedge clk) {a,b,sel} <= {8'haa, 8'hbb, 1'b0};
		@(posedge clk, negedge clk) {a,b,sel} <= {8'haa, 8'hbb, 1'b1};
		@(posedge clk, negedge clk) {a,b,sel} <= {8'haa, 8'hbb, 1'b1};
		
		@(posedge clk, negedge clk) {a, b} <= {8'hff, 8'h00}; sel <= 1'b0;
		@(posedge clk, negedge clk) sel <= 1'b0;
		@(posedge clk, negedge clk) sel <= 1'b1;
		@(posedge clk, negedge clk) sel <= 1'b0;
		@(posedge clk, negedge clk) sel <= 1'b1;
		@(posedge clk, negedge clk) sel <= 1'b1;
		wavedrom_stop();
		
		repeat(100) @(posedge clk, negedge clk)
			{a,b,sel} <= $urandom;
		$finish;
	end
	endmodule

// Testbench
module tb();

	// Stats structure (maintained from golden testbench)
	typedef struct packed {
		int errors;
		int errortime;
		int errors_out;
		int errortime_out;
		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic sel;
	logic [7:0] a;
	logic [7:0] b;
	logic [7:0] out_ref;
	logic [7:0] out_dut;

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,sel,a,b,out_ref,out_dut );
	end

	// tb_match will be derived from the comparison	
	logic tb_match;
	
	stimulus_gen stim1 (
		.clk,
		.sel,
		a,
		b,
		wavedrom_title,
		wavedrom_enable
	);
	RefModule good1 (
		.sel,
		a,
		b,
		out(out_ref) );
	
	TopModule top_module1 (
		.sel,
		a,
		b,
		out(out_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end
task

	// Error tracking variables
	int first_error_clock = -1;
	
	// Verification logic
	// For combinational logic, we check immediately after the clock edge transition where inputs settled.
	always @(posedge clk, negedge clk) begin
		
		stats1.clocks++;
		
		// Check for mismatch
		if (!(out_ref === out_dut)) begin
			
			// Update error counters
			stats1.errors++;
			// Original logic check (though redundant given the above check)
			if (!(out_ref === ( out_ref ^ out_dut ^ out_ref )))
					stats1.errors_out = stats1.errors_out + 1'b1;
			
			// Capture first error time and clock
			if (stats1.errors == 1) begin
				first_error_clock = stats1.clocks;
				stats1.errortime = $time; // Record time of first error
				s		stats1.errortime_out = $time; // Record time of first error for output
			end
		end
	end

	// The original testbench used a separate tb_match signal derived from XOR, which we simplify here.
	// The mismatch detection is now embedded in the always block above.

	
	// Finalization Block (Modified to meet new requirements)
	initial begin
		// Wait until simulation is near completion or timeout
		@(negedge clk);
		#10;
		
		// Final Display Logic
		if (stats1.errors == 0) begin
			$display("SIMULATION PASSED");
		end else begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
		end
		
		// Display detailed error information for the FIRST mismatch (Combinational Logic Rule 2)
		if (stats1.errors > 0 && first_error_clock != -1) begin
			$display("\n--- FIRST MISMATCH DETAILS ---");
			$display("Mismatch detected at time %0d", stats1.errortime);
			$display("Cycle where first mismatch occurred: %0d", first_error_clock);
			$display("Input signals at mismatch:");
			$display("  sel: %b", sel);
			$display("  a: %h (%b)", a, a);
			$display("  b: %h (%b)", b, b);
			$display("Output signals at mismatch:");
			$display("  Golden Output (out_ref): %h (%b)", out_ref, out_ref);
			$display("  DUT Output (out_dut): %h (%b)", out_dut, out_dut);
			end
		$finish;
	end


	// add timeout after 100K cycles (Original logic maintained)
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

endmodule
