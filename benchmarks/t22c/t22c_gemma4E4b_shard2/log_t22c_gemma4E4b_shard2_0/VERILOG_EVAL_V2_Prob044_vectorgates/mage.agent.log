// Instantiate RefModule (assuming it exists and matches interface)
module RefModule ( 
    input [2:0] a,
    input [2:0] b,
    output logic [2:0] out_or_bitwise,
    output logic out_or_logical,
    output logic [5:0] out_not
);
    // Implementation matching TopModule for reference
    assign out_or_bitwise = a | b;
    assign out_or_logical = (a | b) != 3'b0;
    assign out_not = {~b, ~a};
endmodule

// TopModule implementation based on specification
module TopModule(
    input logic [2:0] a,
    input logic [2:0] b,
    output logic [2:0] out_or_bitwise,
    output logic out_or_logical,
    output logic [5:0] out_not
);

    // 1. Bitwise OR of a and b
    assign out_or_bitwise = a | b;

    // 2. Logical OR of a and b (1 if any bit in a or b is 1)
    assign out_or_logical = (a | b) != 3'b0;

    // 3. Inverse (NOT) of a (lower half) and b (upper half)
    // ~b goes into the upper half [5:3]
    // ~a goes into the lower half [2:0]
    assign out_not[2:0] = ~a;
    assign out_not[5:3] = ~b;

endmodule
