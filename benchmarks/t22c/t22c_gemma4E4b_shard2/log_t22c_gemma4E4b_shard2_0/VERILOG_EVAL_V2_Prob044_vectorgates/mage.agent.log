		.a,
		.b,
		.out_or_bitwise(out_or_bitwise_dut),
		.out_or_logical(out_or_logical_dut),
		.out_not(out_not_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		endtask	
	
	// Improved Final Block to meet new reporting requirements
	final begin
		if (stats1.errors_out_or_bitwise) begin
			s$display("Mismatch detected for out_or_bitwise at time %0d", stats1.errortime_out_or_bitwise);
			$display("  Time %0d: a=%h, b=%h | Ref=%h, Dut=%h", stats1.errortime_out_or_bitwise, a, b, out_or_bitwise_ref, out_or_bitwise_dut);
			$display("  Ref Binary: %b, Dut Binary: %b", out_or_bitwise_ref, out_or_bitwise_dut);
			total_mismatches++;
			if (stats1.errortime_out_or_bitwise_first == -1) first_mismatch_time = stats1.errortime_out_or_bitwise;
		end
		if (stats1.errors_out_or_logical) begin
			s$display("Mismatch detected for out_or_logical at time %0d", stats1.errortime_out_or_logical);
			$display("  Time %0d: a=%h, b=%h | Ref=%b, Dut=%b", stats1.errortime_out_or_logical, a, b, out_or_logical_ref, out_or_logical_dut);
