endmodule

// The module under test (TopModule) - assumed to exist
module TopModule (
    input logic [2:0] a,
    input logic [2:0] b,
    output logic [2:0] out_or_bitwise,
    output logic out_or_logical,
    output logic [5:0] out_not
);
    // Placeholder implementation
endmodule

module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_out_or_bitwise;
		intime_out_or_bitwise;
		intime_out_or_bitwise_first;
		int errors_out_or_logical;
		intime_out_or_logical;
		intime_out_or_logical_first;
		int errors_out_not;
		intime_out_not;
		intime_out_not_first;
		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		h#5 clk = ~clk;

	logic [2:0] a;
	logic [2:0] b;
	logic [2:0] out_or_bitwise_ref;
	logic [2:0] out_or_bitwise_dut;
	logic out_or_logical_ref;
	logic out_or_logical_dut;
	logic [5:0] out_not_ref;
	logic [5:0] out_not_dut;

	// Tracking variables for the required final report
	integer total_mismatches = 0;
	integer first_mismatch_time = -1;

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,a,b,out_or_bitwise_ref,out_or_bitwise_dut,out_or_logical_ref,out_or_logical_dut,out_not_ref,out_not_dut );
	end

	
	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk, 
		.a, 
		.b, 
		.wavedrom_title, 
		.wavedrom_enable
	);
	RefModule good1 (
		.a, 
		.b,
		.out_or_bitwise(out_or_bitwise_ref),
		.out_or_logical(out_or_logical_ref),
		.out_not(out_not_ref) );
	
	TopModule top_module1 (
		.a,
		.b,
		.out_or_bitwise(out_or_bitwise_dut),
		.out_or_logical(out_or_logical_dut),
		.out_not(out_not_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		endtask	
	
	// Improved Final Block to meet new reporting requirements
	final begin
		if (stats1.errors_out_or_bitwise) begin
			s$display("Mismatch detected for out_or_bitwise at time %0d", stats1.errortime_out_or_bitwise);
			$display("  Time %0d: a=%h, b=%h | Ref=%h, Dut=%h", stats1.errortime_out_or_bitwise, a, b, out_or_bitwise_ref, out_or_bitwise_dut);
			$display("  Ref Binary: %b, Dut Binary: %b", out_or_bitwise_ref, out_or_bitwise_dut);
			total_mismatches++;
			if (stats1.errortime_out_or_bitwise_first == -1) first_mismatch_time = stats1.errortime_out_or_bitwise;
		end
		if (stats1.errors_out_or_logical) begin
			s$display("Mismatch detected for out_or_logical at time %0d", stats1.errortime_out_or_logical);
			$display("  Time %0d: a=%h, b=%h | Ref=%b, Dut=%b", stats1.errortime_out_or_logical, a, b, out_or_logical_ref, out_or_logical_dut);
			total_mismatches++;
			if (stats1.errortime_out_or_logical_first == -1) first_mismatch_time = stats1.errortime_out_or_logical;
		end
		if (stats1.errors_out_not) begin
			s$display("Mismatch detected for out_not at time %0d", stats1.errortime_out_not);
			$display("  Time %0d: a=%h, b=%h | Ref=%h, Dut=%h", stats1.errortime_out_not, a, b, out_not_ref, out_not_dut);
			$display("  Ref Binary: %b, Dut Binary: %b", out_not_ref, out_not_dut);
			total_mismatches++;
			if (stats1.errortime_out_not_first == -1) first_mismatch_time = stats1.errortime_out_not;
	end

	// Final required output based on total_mismatches and first_mismatch_time
	if (total_mismatches == 0)
		$display("SIMULATION PASSED");
	else
		$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", total_mismatches, first_mismatch_time);
	
	$display("Total mismatched samples counted by original logic: %1d out of %1d samples\n", stats1.errors, stats1.clocks);
	$display("Simulation finished at %0d ps", $time);
	end
	
	// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.
	assign tb_match = ( { out_or_bitwise_ref, out_or_logical_ref, out_not_ref } === ( { out_or_bitwise_ref, out_or_logical_ref, out_not_ref } ^ { out_or_bitwise_dut, out_or_logical_dut, out_not_dut } ^ { out_or_bitwise_ref, out_or_logical_ref, out_not_ref } ) );
	
	// Use explicit sensitivity list here.
	always @(posedge clk, negedge clk) begin

		stats1.clocks++;
		// Original error counting logic
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			sstats1.errors++;
		end
		
		// Output specific error counting logic (retaining original structure)
		if (out_or_bitwise_ref !== ( out_or_bitwise_ref ^ out_or_bitwise_dut ^ out_or_bitwise_ref ))
		begin 
			if (stats1.errors_out_or_bitwise == 0) stats1.errortime_out_or_bitwise = $time;
			sstats1.errors_out_or_bitwise = stats1.errors_out_or_bitwise+1'b1;
		end
		if (out_or_logical_ref !== ( out_or_logical_ref ^ out_or_logical_dut ^ out_or_logical_ref ))
		begin 
			if (stats1.errors_out_or_logical == 0) stats1.errortime_out_or_logical = $time;
			sstats1.errors_out_or_logical = stats1.errors_out_or_logical+1'b1;
		end
		if (out_not_ref !== ( out_not_ref ^ out_not_dut ^ out_not_ref ))
		begin 
			if (stats1.errors_out_not == 0) stats1.errortime_out_not = $time;
			sstats1.errors_out_not = stats1.errors_out_not+1'b1;
		end

	end

   // add timeout after 100K cycles
   initial begin
     #1000000
     $display("TIMEOUT");
     $finish();
   end

endmodule
