[2026-05-14 13:34:52,902 - mage.agent - INFO] `timescale 1 ps/1 ps
`define OK 12
`define INCORRECT 13

module stimulus_gen (
	input clk,
	output reg [2:0] a, b,
	output reg[511:0] wavedrom_title,
	output reg wavedrom_enable
);

	// Add two ports to module stimulus_gen:
	//    output [511:0] wavedrom_title
	//    output reg wavedrom_enable

	task wavedrom_start(input[511:0] title = "");
	endtask
	
	task wavedrom_stop;
		h#1;
	endtask	

	initial begin
		int count; count = 6'h38;
		{b, a} <= 6'b0;
		@(negedge clk);
		wavedrom_start();
		repeat(30) @(posedge clk)
			{b, a} <= count++;	
		wavedrom_stop();
		repeat(200) @(posedge clk, negedge clk)
			{b,a} <= $random;
		
		#1 $finish;
	end
	
endmodule

module TopModule (
    input  [2:0] a,
    input  [2:0] b,
    output [2:0] out_or_bitwise,
    output out_or_logical,
    output [5:0] out_not
);

    // 1. Bitwise OR
    assign out_or_bitwise = a | b;

    // 2. Logical OR of the two vectors (ORing all bits)
    assign out_or_logical = a[0] | b[0] | a[1] | b[1] | a[2] | b[2];

    // 3. Inverse (NOT) of a (lower half) and b (upper half)
    assign out_not[2:0] = ~a;
    assign out_not[5:3] = ~b;

endmodule

module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_out_or_bitwise;
		int errortime_out_or_bitwise;
		int errors_out_or_logical;
		int errortime_out_or_logical;
		int errors_out_not;
		int errortime_out_not;

		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		h#5 clk = ~clk;

	logic [2:0] a;
	logic [2:0] b;
	logic [2:0] out_or_bitwise_ref;
	logic [2:0] out_or_bitwise_dut;
	logic out_or_logical_ref;
	logic out_or_logical_dut;
	logic [5:0] out_not_ref;
	logic [5:0] out_not_dut;

	// Helper function for display formatting (HEX/BIN)
	task display_vector(string name, logic [63:0] val, int width);
	begin
		$write("%-20s: HEX = %h, BIN = ", name, val);
		if (width <= 64) begin
			$write(" %b\n", val);
			$else begin
				$write(" [Width > 64, displaying only HEX] %h\n", val);
			end
		end
	endtask

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stimulus_gen.clk, tb_mismatch ,a,b,out_or_bitwise_ref,out_or_bitwise_dut,out_or_logical_ref,out_or_logical_dut,out_not_ref,out_not_dut );
	end

	
	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk, 
		.* , 
		.a,
		.b );
	RefModule good1 (
		a,
		b,
		out_or_bitwise(out_or_bitwise_ref),
		out_or_logical(out_or_logical_ref),
		out_not(out_not_ref) );
	
	TopModule top_module1 (
		a,
		b,
		out_or_bitwise(out_or_bitwise_dut),
		out_or_logical(out_or_logical_dut),
		out_not(out_not_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end
	task
	
	initial begin
		// Initialize stats
		stats1 = '{errors: 0, errortime: 0, errors_out_or_bitwise: 0, errortime_out_or_bitwise: 0, errors_out_or_logical: 0, errortime_out_or_logical: 0, errors_out_not: 0, errortime_out_not: 0, clocks: 0};

		// Monitor the initial state before clocking starts
		@(posedge clk);
	end

	
	// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.
	assign tb_match = ( { out_or_bitwise_ref, out_or_logical_ref, out_not_ref } === ( { out_or_bitwise_ref, out_or_logical_ref, out_not_ref } ^ { out_or_bitwise_dut, out_or_logical_dut, out_not_dut } ^ { out_or_bitwise_ref, out_or_logical_ref, out_not_ref } ) );
	
	// Use explicit sensitivity list here. @(*) causes NetProc::nex_input() to be called when trying to compute
	// the sensitivity list of the @(strobe) process, which isn't implemented.
	always @(posedge clk, negedge clk) begin

		stats1.clocks++;
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			sstats1.errors++;
		end

		// Check out_or_bitwise
		if (out_or_bitwise_ref !== ( out_or_bitwise_ref ^ out_or_bitwise_dut ^ out_or_bitwise_ref ))
		begin 
			if (stats1.errors_out_or_bitwise == 0) stats1.errortime_out_or_bitwise = $time;
			sstats1.errors_out_or_bitwise = stats1.errors_out_or_bitwise+1'b1; 
		end

		// Check out_or_logical
		if (out_or_logical_ref !== ( out_or_logical_ref ^ out_or_logical_dut ^ out_or_logical_ref ))
		begin 
			if (stats1.errors_out_or_logical == 0) stats1.errortime_out_or_logical = $time;
			sstats1.errors_out_or_logical = stats1.errors_out_or_logical+1'b1; 
		end

		// Check out_not
		if (out_not_ref !== ( out_not_ref ^ out_not_dut ^ out_not_ref ))
		begin 
			if (stats1.errors_out_not == 0) stats1.errortime_out_not = $time;
			sstats1.errors_out_not = stats1.errors_out_not+1'b1; 
		end
	end


	// =================================================================================
	// NEW: Detailed Error Reporting Logic in Final Block
	// =================================================================================
	final begin
		$display("====================================================");
		$display("SIMULATION REPORT");
		$display("====================================================");

		if (stats1.errors_out_or_bitwise) begin
			$display("MISMATCH DETECTED: Output 'out_or_bitwise' (Bits: 3)");
			$display("  First mismatch occurred at time %0d ps.", stats1.errortime_out_or_bitwise);
			$display("  --- Signals at Mismatch Time ---");
			$display("  Inputs: a = %h (%b), b = %h (%b)", a, a, b, b);
			$display("  DUT Outputs: out_or_bitwise = %h (%b)", out_or_bitwise_dut, out_or_bitwise_dut);
			$display("  Reference Outputs: out_or_bitwise_ref = %h (%b)", out_or_bitwise_ref, out_or_bitwise_ref);
		end

		if (stats1.errors_out_or_logical) begin
			$display("MISMATCH DETECTED: Output 'out_or_logical' (Bit: 1)");
			$display("  First mismatch occurred at time %0d ps.", stats1.errortime_out_or_logical);
			$display("  --- Signals at Mismatch Time ---");
			$display("  Inputs: a = %h (%b), b = %h (%b)", a, a, b, b);
			$display("  DUT Outputs: out_or_logical = %b", out_or_logical_dut);
			$display("  Reference Outputs: out_or_logical_ref = %b", out_or_logical_ref);
		end

		if (stats1.errors_out_not) begin
			$display("MISMATCH DETECTED: Output 'out_not' (Bits: 6)");
			$display("  First mismatch occurred at time %0d ps.", stats1.errortime_out_not);
			$display("  --- Signals at Mismatch Time ---");
			$display("  Inputs: a = %h (%b), b = %h (%b)", a, a, b, b);
			$display("  DUT Outputs: out_not = %h (%b)", out_not_dut, out_not_dut);
			$display("  Reference Outputs: out_not_ref = %h (%b)", out_not_ref, out_not_ref);
		end

		$display("====================================================");
		if (stats1.errors == 0) begin
			$display("SIMULATION PASSED");
		end else begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
		end
		$display("Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
		$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
		$display("====================================================");
	end


	// add timeout after 100K cycles
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

endmodule
