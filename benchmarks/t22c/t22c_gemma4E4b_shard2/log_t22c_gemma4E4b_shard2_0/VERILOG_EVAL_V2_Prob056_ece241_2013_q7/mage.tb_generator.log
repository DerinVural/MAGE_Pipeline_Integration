    "testbench": "`timescale 1 ps/1 ps\n`define OK 12\n`define INCORRECT 13\n\n// Mock RefModule to satisfy compilation, matching the behavior of a JK FF\nmodule RefModule (\n    input clk,\n    input j,\n    input k,\n    output logic Q\n); \n    reg q_ref_reg = 0; // Initial state\n    always @(posedge clk)\n    begin\n        if (j == 1'b0 && k == 1'b0) begin\n            q_ref_reg <= q_ref_reg; // Hold\n        end else if (j == 1'b0 && k == 1'b1) begin\n            q_ref_reg <= 1'b0; // Reset\n        end else if (j == 1'b1 && k == 1'b0) begin\n            q_ref_reg <= 1'b1; // Set\n        end else if (j == 1'b1 && k == 1'b1) begin\n            q_ref_reg <= ~q_ref_reg; // Toggle\n        end\n    end\n    assign Q = q_ref_reg;\nendmodule\n\n// The DUT implementation based on the specification\nmodule TopModule (\n    input clk,\n    input j,\n    input k,\n    output Q\n); \n    reg q_dut_reg = 0; // Initial state\n    always @(posedge clk)\n    begin\n        if (j == 1'b0 && k == 1'b0) begin\n            q_dut_reg <= q_dut_reg; // Hold\n        end else if (j == 1'b0 && k == 1'b1) begin\n            q_dut_reg <= 1'b0; // Reset\n        end else if (j == 1'b1 && k == 1'b0) begin\n            q_dut_reg <= 1'b1; // Set\n        end else if (j == 1'b1 && k == 1'b1) begin\n            q_dut_reg <= ~q_dut_reg; // Toggle\n        end\n    end\n    assign Q = q_dut_reg;\nendmodule\n\n// Stimulus Generator (kept as is per requirement)\nmodule stimulus_gen (\n\tinput clk,\n\toutput logic j, k,\n\toutput reg[511:0] wavedrom_title,\n\toutput reg wavedrom_enable\n);\n\n\ttask wavedrom_start(input[511:0] title = \"\");\n\tendtask\n\t\n\ttask wavedrom_stop;\n\t\t#1;\n\tendtask\n\t\n\tinitial begin\n\t\tj,k <= 1;\n\t\t\n\t\t@(negedge clk) wavedrom_start();\n\t\t\t@(posedge clk) {j,k} <= 2'h1;\n\t\t\t@(posedge clk) {j,k} <= 2'h2;\n\t\t\t@(posedge clk) {j,k} <= 2'h3;\n\t\t\t@(posedge clk) {j,k} <= 2'h3;\n\t\t\t@(posedge clk) {j,k} <= 2'h3;\n\t\t\t@(posedge clk) {j,k} <= 2'h0;\n\t\t\t@(posedge clk) {j,k} <= 2'h0;\n\t\t\t@(posedge clk) {j,k} <= 2'h0;\n\t\t\t@(posedge clk) {j,k} <= 2'h2;\n\t\t\t@(posedge clk) {j,k} <= 2'h2;\n\t\t@(negedge clk) wavedrom_stop();\n\t\trepeat(400) @(posedge clk, negedge clk)\n\t\t\t{j,k} <= $random;\n\t\t$finish;\n\tend\n\tendmodule\n\nmodule tb();\n\n\ttypedef struct packed {\n\t\tint errors;\n\t\tint errortime;\n\t\tint errors_Q;\n\t\tint errortime_Q;\n\t\tint clocks;\n\t} stats;\n\t\n\tstats stats1;\n\t\n\t\n\twire[511:0] wavedrom_title;\n\twire wavedrom_enable;\n\tint wavedrom_hide_after_time;\n\t\n\treg clk=0;\n\tinitial forever\n\t\t#5 clk = ~clk;\n\n\tlogic j;\n\tlogic k;\n\tlogic Q_ref; // Expected output\n\tlogic Q_dut; // Actual output\n\n\t// --- Queue Definitions for Sequential Logic ---\n\tlocalparam MAX_QUEUE_SIZE = 5; // Sufficient for 1-bit signal, <= 10\n\treg [1:0] input_queue [$]; // Store J and K (2 bits)\n\treg [0:0] got_output_queue [$]; // Q_dut\n\treg [0:0] golden_queue [$]; // Q_ref\n\treg reset_queue [$]; // Placeholder for synchronization\n\n\t// --- Original Testbench Signals ---\n\twire tb_match;\n\twire tb_mismatch = ~tb_match;\n\t\n\t// --- Initialization and Dumping ---\n\tinitial begin \n\t\t$dumpfile(\"wave.vcd\");\n\t\t$dumpvars(1, stimulus_gen.clk, tb, clk, j, k, Q_ref, Q_dut, input_queue, got_output_queue, golden_queue);\n\tend\n\n\t// --- DUT Instantiations ---\n\tstimulus_gen stim1 (\n\t\t.clk, \n\t\t.j, \n\t\tk, \n\t\twavedrom_title, \n\t\twavedrom_enable\n\t);\n\t\t\n\tRefModule good1 (\n\t\t.clk,\n\t\tj,\n\t\tk,\n\t\t.Q(Q_ref) \n\t);\n\t\t\n\tTopModule top_module1 (\n\t\t.clk,\n\t\tj,\n\t\tk,\n\t\t.Q(Q_dut) \n\t);\n\n\t\n\t// --- Tasks (Kept as is) ---\n\tbit strobe = 0;\n\ttask wait_for_end_of_timestep;\n\t\trepeat(5) begin\n\t\tstrobe <= !strobe;  // Try to delay until the very end of the time step.\n\t\t@(strobe);\n\tendtask\n\n\t// --- Clocked Logic (Original Error Counting + Queue Management) ---\n\talways @(posedge clk, negedge clk) begin\n\t\tstats1.clocks++;\n\n\t\t// 1. Queue Management (FIFO behavior)\n\t\tif (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin\n\t\t\tinput_queue.delete(0);\n\t\t\tgot_output_queue.delete(0);\n\t\t\tgolden_queue.delete(0);\n\t\t\treset_queue.delete(0);\n\tend\n\n\t\t// Push current state\n\t\tinput_queue.push_back({j, k});\n\t\tgot_output_queue.push_back(Q_dut);\n\t\tgolden_queue.push_back(Q_ref);\n\t\treset_queue.push_back(1'b0); // Placeholder for synchronization\n\n\t\t// 2. Original Mismatch Detection (tb_match)\n\t\t// Original logic preservation:\n\t\tif (!tb_match) begin\n\t\t\tif (stats1.errors == 0) stats1.errortime = $time;\n\t\t\tstats1.errors++;\n\t\tend\n\n\t\t// Original Q error counting logic preservation:\n\t\tif (Q_ref !== ( Q_ref ^ Q_dut ^ Q_ref )) \n\t\tbegin \n\t\t\tif (stats1.errors_Q == 0) stats1.errortime_Q = $time;\n\t\t\tsstats1.errors_Q = stats1.errors_Q+1'b1; \n\tend\n\t\t\n\t\t// 3. Queue-based Mismatch Display (Checking Q_dut vs Q_ref)\n\t\tif (got_output_queue.size() > 0 && got_output_queue[got_output_queue.size()-1] !== golden_queue[golden_queue.size()-1]) begin\n\t\t\t// Mismatch detected on the current cycle\n\t\t\tif (stats1.errors == 0) stats1.errortime = $time; // Update time if this is the *first* mismatch found by the queue logic\n\t\t\t\n\t\t\t$display(\"\\n====================================================================\");\n\t\t\t$display(\"*** MISMATCH DETECTED (Queue Check) at time %0d ***",  
        "$time"
        :
        "$time"
        , "\"\");\n\t\t\t$display(\"\\nLast %0d cycles of simulation:\", input_queue.size());\n\n\t\t\tfor (int i = 0; i < input_queue.size(); i++) begin\n\t\t\t\tif (got_output_queue[i] === golden_queue[i]) begin\n\t\t\t\t$display(\"Match at cycle %0d\", i);\n\t\t\t\t// Display inputs (J, K) in HEX and BIN if <= 64 bits (here 2 bits)\n\t\t\t\t$display(\"  Cycle %0d, J/K: %b (%h), Q_dut: %b, Q_ref: %b\", \n\t\t\t\ti, input_queue[i], got_output_queue[i], golden_queue[i]);\n\t\t\tend else begin\n\t\t\t\t$display(\"*** MISMATCH at cycle %0d ***\", i);\n\t\t\t\t// Display inputs (J, K) in HEX and BIN\n\t\t\t\t$display(\"  Cycle %0d, J/K: %b (%h), Q_dut: %b, Q_ref: %b\", \n\t\t\t\ti, input_queue[i], got_output_queue[i], got_output_queue[i], golden_queue[i]);\n\t\t\tend\n\t\t\tend\n\t\t\t$display(\"====================================================================\\n\");\n\t\tend\n\tend\n\n\t// --- Timeout --- \n\tinitial begin\n\t\t#1000000\n\t\t$display(\"TIMEOUT\");\n\t\t$finish();\n\tend\n\n\t// --- Final Reporting --- \n\tfinal begin\n\t\t// Original hints\n\t\tif (stats1.errors_Q) $display(\"Hint: Output 'Q' has %0d mismatches. First mismatch occurred at time %0d.\", stats1.errors_Q, stats1.errortime_Q);\n\t\telse $display(\"Hint: Output 'Q' has no mismatches.\");\n\t\t\n\t\t// New Final Check based on requirements\n\t\tif (stats1.errors > 0) begin\n\t\t\ts$display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\", stats1.errors, stats1.errortime);\n\t\t\t$finish;\n\t\tend\n\t\t\n\t\t// If no errors detected\n\t\t$display(\"SIMULATION PASSED\");\n\t\t$finish;\n\tend\n\nendmodule"
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    

