havior)\n        if (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin\n            input_queue.delete(0);\n            got_output_queue.delete(0);\n            golden_queue.delete(0);\n            reset_queue.delete(0);\n        end\n\n        // Store current values\n        input_data = {d, r};\n        input_queue.push_back(input_data);\n        got_output_queue.push_back(q_dut);\n        golden_queue.push_back(q_ref);\n        reset_queue.push_back(r); // Using 'r' as the reset signal for the queue context\n\n        // 2. Error Counting (Maintained from Golden TB)\n        if (!tb_match) begin\n            if (stats1.errors == 0) stats1.errortime = $time;\n            stats1.errors++;\n        end\n        \n        // Note: The original gold testbench had an unusual check here: if (q_ref !== ( q_ref ^ q_dut ^ q_ref )) \n        // which simplifies to q_ref !== q_dut. We maintain the structure but use the derived mismatch.\n        if (q_ref !== q_dut) \n        begin \n            if (stats1.errors_q == 0) stats1.errortime_q = $time;\n            stats1.errors_q = stats1.errors_q + 1'b1; \n        end\n\n        // 3. Detailed Mismatch Logging (New Requirement)\n        if (!tb_match && !first_mismatch_logged) begin\n            $display(\"========================================================================\");\n            $display(\"*** FIRST MISMATCH DETECTED AT TIME %0t ***", 
