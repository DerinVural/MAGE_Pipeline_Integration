_ref_queue.delete(0);\n\t\treset_queue.delete(0);\n\tend\n\tendtask\n\n\t// Synchronous Queue Logging and Mismatch Detection\n\talways @(posedge clk, negedge clk) begin\n\t\tmanage_queue();\n\t\t\n\t\t// Store current state\n\t\tin_queue.push_back(in);\n\t\tanyedge_dut_queue.push_back(anyedge_dut);\n\t\tanyedge_ref_queue.push_back(anyedge_ref);\n\t\treset_queue.push_back(1'b0); // Placeholder\n\n\t\tstats1.clocks++;\n\t\t\n\t\t// Original Error Counting Logic Maintenance\n\t\tif (!tb_match) begin\n\t\t\tif (stats1.errors == 0) stats1.errortime = $time;\n\t\t\tstats1.errors++;\n\t\tend\n\t\tif (anyedge_ref !== anyedge_dut) \n\t\tbegin \n\t\t\tif (stats1.errors_anyedge == 0) stats1.errortime_anyedge = $time;\n\t\t\tsstats1.errors_anyedge = stats1.errors_anyedge+1'b1;\n\tend\n\t\tend\n\n\t\t// Queue-based Mismatch Display (Only on the very first mismatch)\n\t\tif (!tb_match && stats1.errors == 1 && first_mismatch_reported == 0) begin\n\t\t\t$display(\"==================================================================================\");\n\t\t\t$display(\"*** FIRST MISMATCH DETECTED AT TIME %0d ***",     
    
