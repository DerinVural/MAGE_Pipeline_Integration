    "testbench": "`timescale 1 ps/1 ps\n`define OK 12\n`define INCORRECT 13\n\n// --- Stimulus Generator (Copied from Golden TB) ---\nmodule stimulus_gen (\n\tinput clk,\n\tinput tb_match,\n\toutput reg [7:0] in,\n\toutput reg[511:0] wavedrom_title,\n\toutput reg wavedrom_enable\n);\n\n\t// Add two ports to module stimulus_gen:\n\t//    output [511:0] wavedrom_title\n\t//    output reg wavedrom_enable\n\n\ttask wavedrom_start(input[511:0] title = \"\");\n\tendtask\n\t\n\ttask wavedrom_stop;\n\t\th#1;\n\tendtask\t\n\n\tinitial begin\n\t\tin <= 8'h00;\n\t\t@(posedge clk);\n\t\t@(negedge clk) wavedrom_start(\"\");\n\t\trepeat(2) @(posedge clk);\n\t\tin <= 8'h01;\n\t\trepeat(4) @(posedge clk);\n\t\tin <= 8'h00;\n\t\trepeat(4) @(negedge clk);\n\t\tin <= 8'h06;\n\t\trepeat(2) @(negedge clk);\n\t\tin <= 8'h00;\n\t\trepeat(2) @(posedge clk);\n\t\t@(negedge clk) wavedrom_stop();\n\t\t\n\t\trepeat(200)\n\t\t\t@(posedge clk, negedge clk) in <= $random;\n\t\t$finish;\n\tend\n\nendmodule\n\n// --- Reference Model (Ground Truth) ---\nmodule RefModule (\n\tinput logic clk,\n\tinput logic [7:0] in,\n\toutput logic [7:0] anyedge\n);\n\n\tlogic [7:0] prev_in;\n\n\talways @(posedge clk)\n\tbegin\n\t\tprev_in <= in;\n\t\t// Edge detection: Transition occurs when in != prev_in\n\t\t// Since the DUT is designed to output 1 cycle *after* the transition, \n\t\t// the reference model should ideally mimic the DUT's 1-cycle delay for comparison.\n\t\t// However, to match the spirit of golden testing where RefModule defines ground truth,\n\t\t// we define the edge detection happening *immediately* on the clock edge for the reference.\n\t\tanyedge <= in ^ prev_in;\n\tend\n\nendmodule\n\n// --- DUT Implementation (TopModule) ---\nmodule TopModule (\n\tinput logic clk,\n\tinput logic [7:0] in,\n\toutput logic [7:0] anyedge\n);\n\n\t// State to hold the previous input value\n\tlogic [7:0] prev_in;\n\n\t// Internal register to capture the detected edge (0->1 or 1->0) in the current cycle\n\tlogic [7:0] next_anyedge_calc;\n\n\talways @(posedge clk)\n\tbegin\n\t\t// 1. Update state: Store current input as previous input for the next cycle\n\t\tprev_in <= in;\n\t\t\n\t\t// 2. Detect Edge: Calculate the transition based on the input received this cycle\n\t\tnext_anyedge_calc <= in ^ prev_in;\n\tend\n\n\t// 3. Output Delay: Register the calculated edge to meet the 1-cycle delay requirement\n\talways @(posedge clk)\n\tbegin\n\t\tanyedge <= next_anyedge_calc;\n\tend\n\nendmodule\n\n// --- Testbench (Improved Golden Testbench) ---\nmodule tb();\n\n\ttypedef struct packed {\n\t\tint errors;\n\t\tint errortime;\n\t\tint errors_anyedge;\n\t\tint errortime_anyedge;\n\t\tint clocks;\n\t} stats;\n\t\n\tstats stats1;\n\t\n\t// Queue definitions for sequential tracking\n\treg [7:0] in_queue [$];\n\treg [7:0] anyedge_dut_queue [$];\n\treg [7:0] anyedge_ref_queue [$];\n\treg reset_queue [$]; // Placeholder for structure compliance\n\n\tlocalparam MAX_QUEUE_SIZE = 10;\n\t\n\t// Signals\n\tlogic [7:0] in;\n\tlogic [7:0] anyedge_ref;\n\tlogic [7:0] anyedge_dut;\n\t\n\t// Control signals\n\twire tb_match;\n\twire tb_mismatch = ~tb_match;\n\t\n\t// Clock generation\t\n\treg clk=0;\n\tinitial forever\n\t\th#5 clk = ~clk;\n\n\t// Instantiate modules\n\tstimulus_gen stim1 (\n\t\t.clk, clk,\n\t\t.tb_match, tb_match,\n\t\tin, in,\n\t\twavedrom_title, wavedrom_title,\n\t\twavedrom_enable, wavedrom_enable\n\t);\n\n\tRefModule good1 (\n\t\t.clk, clk,\n\t\tin, in,\n\t\t.anyedge, anyedge_ref\n\t);\n\t\n\tTopModule top_module1 (\n\t\t.clk, clk,\n\t\tin, in,\n\t\t.anyedge, anyedge_dut\n\t);\n\n\t// Verification assignment: tb_match is true if DUT matches Reference\n\tassign tb_match = (anyedge_ref === anyedge_dut);\n\n\t// Flag to ensure detailed queue display only happens once\n\treg first_mismatch_reported = 0;\n\n\t// Task to manage queue size\n\ttask manage_queue;\n\t\tif (in_queue.size() >= MAX_QUEUE_SIZE - 1) begin\n\t\t\tin_queue.delete(0);\n\t\tanyedge_dut_queue.delete(0);\n\t\tanyedge