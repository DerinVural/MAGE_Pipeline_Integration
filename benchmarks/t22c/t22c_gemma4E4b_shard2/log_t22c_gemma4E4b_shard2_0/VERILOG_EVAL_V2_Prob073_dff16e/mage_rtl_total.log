// --- Stimulus Generator (Kept from Golden Testbench) ---
module stimulus_gen (
	input clk,
	output reg [15:0] d, output reg [1:0] byteena,
	output reg resetn,
	output reg[511:0] wavedrom_title,
	output reg wavedrom_enable,
	input tb_match
);
	reg reset;
	assign resetn = ~reset;

// Add two ports to module stimulus_gen:
//    output [511:0] wavedrom_title
//    output reg wavedrom_enable

	task wavedrom_start(input[511:0] title = "");
	endtask
	
	task wavedrom_stop;
		#1;
	endtask	

	task reset_test(input async=0);
		bit arfail, srfail, datafail;
		
		@(posedge clk);
		@(posedge clk) reset <= 0;
		repeat(3) @(posedge clk);
		
		@(negedge clk) begin datafail = !tb_match ; reset <= 1; end
		@(posedge clk) arfail = !tb_match;
		@(posedge clk) begin
		srfail = !tb_match;
		reset <= 0;
		end
		if (srfail)
			$display("Hint: Your reset doesn't seem to be working.");
		else if (arfail && (async || !datafail))
			$display("Hint: Your reset should be %0s, but doesn't appear to be.", async ? "asynchronous" : "synchronous");
		// Don't warn about synchronous reset if the half-cycle before is already wrong. It's more likely
		// a functionality error than the reset being implemented asynchronously.
		endtask

	
	initial begin
		reset <= 1;
		byteena <= 2'b11;
		d <= 16'habcd;
		@(posedge clk);
		wavedrom_start("Synchronous active-low reset");
		reset_test(0);
		repeat(2) @(posedge clk);
		wavedrom_stop();
		@(posedge clk);
		
		
		byteena <= 2'b11;
		d <= $random;
		@(posedge clk);
		@(negedge clk);
		wavedrom_start("DFF with byte enables");
		repeat(10) @(posedge clk) begin
		d <= $random;
		byteena <= byteena + 1;
		end
		wavedrom_stop();
		
		repeat(400) @(posedge clk, negedge clk) begin
		byteena[0] <= ($random & 3) != 0;
		byteena[1] <= ($random & 3) != 0;
		d <= $random;
		end
		#1 $finish;
	end
	endmodule

// --- Reference Module (Kept from Golden Testbench) ---
module RefModule (
	input logic clk,
	input logic resetn,
	input logic [1:0] byteena,
	input logic [15:0] d,
	output logic [15:0] q
);
	// Placeholder for reference implementation
	always @(posedge clk or negedge clk) begin
		if (!resetn) begin
			q <= 16'h0;
		end else begin
			// Simplified reference behavior for testing structural integrity
			if (byteena[1]) q[15:8] <= d[15:8];
			if (byteena[0]) q[7:0] <= d[7:0];
		end
	end
endmodule

// --- DUT Module (As per Input Spec) ---
module TopModule (
    input logic clk,
    input logic resetn,
    input logic [1:0] byteena,
    input logic [15:0] d,
    output logic [15:0] q
);
	reg [15:0] q_reg;
	
	// 16 D flip-flops. Reset is synchronous, active-low.
	always @(posedge clk)
	begin
		if (!resetn)
			q_reg <= 16'h0000; // Assuming reset sets all to zero
		else begin
			q_reg <= q_reg;
			// Update upper byte if enabled
			if (byteena[1]) begin
				q_reg[15:8] <= d[15:8];
			end
			// Update lower byte if enabled
			if (byteena[0]) begin
				q_reg[7:0] <= d[7:0];
			end
		end
	end
	
	assign q = q_reg;
	endmodule

// --- Testbench ---
module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_q;
		int errortime_q;
		// Clock count to track sample points
		int clocks;
	} stats;
	
	stats stats1;
	
	// Signals from Golden Testbench
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	// Clocking	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	// DUT Inputs
	logic resetn;
	logic [1:0] byteena;
	logic [15:0] d;
	
	// DUT Outputs & Reference
	logic [15:0] q_ref;
	logic [15:0] q_dut;

	// Verification Signals
	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	// --- Queue Storage Declarations (For Sequential Logic) ---
	// MAX_QUEUE_SIZE <= 10
	localparam MAX_QUEUE_SIZE = 10;
	
	// Store inputs: clk (1), resetn (1), byteena (2), d (16)
	logic [15:0] input_d_queue [$];
	logic [1:0] input_byteena_queue [$];
	logic input_resetn_queue [$];
	// We cannot easily queue 'clk' as it is continuous, so we queue its state at sample time
	
	// Store outputs: q_dut (16), q_ref (16)
	logic [15:0] got_output_queue [$];
	logic [15:0] golden_output_queue [$];
	
	// Store clock and time info
	logic clock_queue [$];
	
	// --- Initialization ---
	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stimulus_gen.clk, tb_mismatch ,clk,resetn,byteena,d,q_ref,q_dut );
		
		// Initialize stats
		stats1.errors = 0;
		stats1.errortime = 0;
		stats1.errors_q = 0;
		stats1.errortime_q = 0;
		stats1.clocks = 0;
	end

	// Instantiate Modules
	stimulus_gen stim1 (
		.clk, 
		.d, 
		.byteena, 
		.resetn, 
		.wavedrom_title, 
		.wavedrom_enable, 
		.tb_match
	);
	RefModule good1 (
		.clk, 
		.resetn, 
		.byteena, 
		d, 
		.q(q_ref) );
	TopModule top_module1 (
		.clk, 
		.resetn, 
		.byteena, 
		d, 
		.q(q_dut) );

	// Task to wait for timing stability (kept from golden testbench)
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		endtask	

	// Strobe signal for wait_for_end_of_timestep
	reg strobe = 0;

	// --- Queue Processing and Mismatch Detection (Sequential) ---
	always @(posedge clk, negedge clk) begin
		// 1. Queue management: Delete oldest if full
		if (input_d_queue.size() >= MAX_QUEUE_SIZE - 1) begin
			input_d_queue.delete(0);
			input_byteena_queue.delete(0);
			input_resetn_queue.delete(0);
			got_output_queue.delete(0);
			golden_output_queue.delete(0);
			clock_queue.delete(0);
		end

		// 2. Store current state (Input/Control Signals)
		input_d_queue.push_back(d);
		input_byteena_queue.push_back(byteena);
		input_resetn_queue.push_back(resetn);
		clock_queue.push_back(clk);
		
		// 3. Store Outputs
		got_output_queue.push_back(q_dut);
		golden_output_queue.push_back(q_ref);

		// 4. Update sample counter
		stats1.clocks++;

		// 5. Mismatch Detection (Primary tracking using the structure of the original testbench)
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
		end
		
		// 6. Queue Mismatch Tracking (For detailed display)
		if (q_dut !== q_ref) begin
			if (stats1.errors_q == 0) stats1.errortime_q = $time;
			stats1.errors_q = stats1.errors_q + 1'b1;
		end
	end

	// --- Verification Display Logic (Triggered on Mismatch) ---
	always @(posedge clk, negedge clk) begin
		if (!tb_match && stats1.errors > 0) begin
		$display("\n========================================================");
		$display("*** FIRST MISMATCH DETECTED AT TIME %0t ***", $time);
		$display("Displaying last %0d cycles of mismatch data (Queue based):
", input_d_queue.size());

		// Loop through the current contents of the queue
		for (int i = 0; i < input_d_queue.size(); i++) begin
			// Display format: Cycle index, resetn, input d, got q, exp q
			$display("Cycle %0d (Time %0t): Resetn=%b, Input D=%h (Bin: %b), Got Q=%h (Bin: %b), Exp Q=%h (Bin: %b)",
				 i,
				 $time - (input_d_queue.size() - 1 - i) * 10, // Approximate time stamp
				 input_resetn_queue[i],
				 input_d_queue[i],
				 input_d_queue[i], // Display input D in HEX
				 input_d_queue[i], // Display input D in BIN (since width <= 64)
				 got_output_queue[i],
				 got_output_queue[i], // Display got Q in HEX
				 got_output_queue[i], // Display got Q in BIN
				 golden_output_queue[i],
				 golden_output_queue[i], // Display exp Q in HEX
				 golden_output_queue[i]  // Display exp Q in BIN
			);
		end
		$display("========================================================\n");
		end

	// --- Timeout ---
	initial begin
		#1000000
		$display("TIMEOUT REACHED.");
		$finish();
	end

	// --- Final Reporting ---
	final begin
		// Final check based on the required output format
		if (stats1.errors == 0) begin
			$display("SIMULATION PASSED");
		end else begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
		end
		$display("Simulation finished at %0d ps", $time);
	end

endmodule
