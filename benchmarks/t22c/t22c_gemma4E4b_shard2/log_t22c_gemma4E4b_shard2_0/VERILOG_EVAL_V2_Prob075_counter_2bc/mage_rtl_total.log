`define OK 12
`define INCORRECT 13


module stimulus_gen(
	input clk,
	output logic areset,
	output logic train_valid,
	output logic train_taken,

	input tb_match,
	output reg[511:0] wavedrom_title,
	output reg wavedrom_enable,
	output int wavedrom_hide_after_time
);


// Add two ports to module stimulus_gen:
//    output [511:0] wavedrom_title
//    output reg wavedrom_enable

	task wavedrom_start(input[511:0] title = "");
	endtask
	
	task wavedrom_stop;
		#1;
	endtask	

	reg reset;
	task reset_test(input async=0);
		bit arfail, srfail, datafail;
		
		@(posedge clk);
		@(posedge clk) reset <= 0;
		repeat(3) @(posedge clk);
		
		@(negedge clk) begin datafail = !tb_match ; reset <= 1; end
		@(posedge clk) arfail = !tb_match;
		@(posedge clk) begin
		srfail = !tb_match;
		reset <= 0;
		end
		if (srfail)
			s$display("Hint: Your reset doesn't seem to be working.");
		else if (arfail && (async || !datafail))
			s$display("Hint: Your reset should be %0s, but doesn't appear to be.", async ? "asynchronous" : "synchronous");
		// Don't warn about synchronous reset if the half-cycle before is already wrong. It's more likely
		// a functionality error than the reset being implemented asynchronously.
	endtask

	
	assign areset = reset;
	logic train_taken_r;
	assign train_taken = train_valid ? train_taken_r : 1'bx;
	
	initial begin
		@(posedge clk);
		@(posedge clk) reset <= 1;
		@(posedge clk) reset <= 0;
		train_taken_r <= 1;
		train_valid <= 1;
		
		wavedrom_start("Asynchronous reset");
		reset_test(1); // Test for asynchronous reset
		wavedrom_stop();
		@(posedge clk) reset <= 1;
		train_taken_r <= 1;
		train_valid <= 0;
		@(posedge clk) reset <= 0;

		wavedrom_start("Count up, then down");
		train_taken_r <= 1;
			@(posedge clk) train_valid <= 1;
			@(posedge clk) train_valid <= 0;
			@(posedge clk) train_valid <= 1;
			@(posedge clk) train_valid <= 1;
			@(posedge clk) train_valid <= 1;
			@(posedge clk) train_valid <= 0;
			@(posedge clk) train_valid <= 1;
		train_taken_r <= 0;
			@(posedge clk) train_valid <= 1;
			@(posedge clk) train_valid <= 0;
			@(posedge clk) train_valid <= 1;
			@(posedge clk) train_valid <= 1;
			@(posedge clk) train_valid <= 1;
			@(posedge clk) train_valid <= 0;
			@(posedge clk) train_valid <= 1;		wavedrom_stop();

		repeat(1000) @(posedge clk,negedge clk) 
		{train_valid, train_taken_r} <= {$urandom} ; 

		#1 $finish;
	end
	

endmodule

module tb();

	// Structure to hold statistics (retaining original structure for compatibility)
	typedef struct packed {
		int errors;
		int errortime;
		int errors_state;
		int errortime_state;
		int clocks;
	} stats;
	
	stats stats1;
	
	// --- Queue Definitions for Robust Verification ---
	// state is 2 bits, so 2^2 = 4. Max size set to 10 as per requirement.
	localparam MAX_QUEUE_SIZE = 10;
	
	// Inputs to DUT: clk, areset, train_valid, train_taken
	reg clk_tb = 0;
	reg areset_tb = 1'b1;
	reg train_valid_tb = 1'b0;
	reg train_taken_tb = 1'b0;
	
	// Outputs from DUT: state[1:0]
	logic [1:0] state_dut_tb;
	logic [1:0] state_ref_tb;

	// Queue Storage
	reg [1:0] state_queue [$];
	reg [1:0] state_ref_queue [$];
	reg [1:0] state_dut_queue [$];
	reg reset_queue [$];
	reg [3:0] input_queue [$]; // Grouping inputs for simplicity in display

	// Control signals for queueing/checking	
	// --- Clock Generation ---
	initial forever
		#5 clk_tb = ~clk_tb;

	// --- Simulation Setup ---
	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, tb);
	end

	// --- DUT Instantiations (Maintaining Original Structure) ---
	// We need stimulus_gen and RefModule. Since the definition of RefModule is missing, 
	// we must assume it behaves correctly and only focus on TopModule and the TB structure.
	// We instantiate stimulus_gen as in the original TB.
	wire tb_match_wire;
	wire tb_mismatch = ~tb_match_wire;

	stimulus_gen stim1 (
		.clk, clk_tb,
		.areset, areset_tb,
		train_valid, train_valid_tb,
		train_taken, train_taken_tb,
		.tb_match, tb_match_wire,
		.wavedrom_title, wavedrom_title,
		.wavedrom_enable, wavedrom_enable,
		.wavedrom_hide_after_time, wavedrom_hide_after_time
	);

	// Mock RefModule instance based on original TB structure
	// Since RefModule definition is missing, we assume it provides the correct reference state.
	// In a real scenario, this would be the golden reference implementation.
	// For this exercise, we keep the instantiation structure.
	RefModule good1 (
		.clk, clk_tb,
		.areset, areset_tb,
		train_valid, train_valid_tb,
		train_taken, train_taken_tb,
		.state(state_ref_tb)
	);

	// TopModule DUT instantiation
	TopModule top_module1 (
		.clk, clk_tb,
		.areset, areset_tb,
		train_valid, train_valid_tb,
		train_taken, train_taken_tb,
		.state(state_dut_tb)
	);

	// --- Original TB tasks and logic preserved ---
	
task wait_for_end_of_timestep;
		repeat(5) begin
			// Original logic relies on strobe flip-flop timing
			strobe <= !strobe;
			@(strobe);
		end
	endtask	
	
	// Dummy variable required for wait_for_end_of_timestep
	reg strobe = 0;
	
	// --- Queueing and Mismatch Detection Logic (Replaces original 'always @(posedge clk, negedge clk)' block) ---
	always @(posedge clk_tb, negedge clk_tb) begin
		// 1. Input Handling (Capture inputs and reset)
		// Input data: {areset, train_valid, train_taken, state_ref_tb} (using state_ref as proxy for input context)
		input_queue.push_back({areset_tb, train_valid_tb, train_taken_tb, state_ref_tb});
		reset_queue.push_back(areset_tb);

		// 2. Output Capture
		state_ref_queue.push_back(state_ref_tb);
		state_dut_queue.push_back(state_dut_tb);

		// 3. Queue Management (Maintain MAX_QUEUE_SIZE)
		if (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin
			input_queue.delete(0);
			reset_queue.delete(0);
			state_ref_queue.delete(0);
			state_dut_queue.delete(0);
		end

		// 4. Check for Mismatch
		if (state_dut_tb !== state_ref_tb) begin
			// Mismatch detected. Check if this is the first one.
			if (stats1.errors == 0) begin
				s$display("Mismatch detected at time %0t", $time);
				s$display("\nLast %0d cycles of simulation:", input_queue.size());
				
				for (int i = 0; i < input_queue.size(); i++) begin
					if (state_dut_queue[i] === state_ref_queue[i]) begin
					$display("Got Match at Cycle %0d", i);
					// Displaying queue content for match case (though not strictly required by prompt, it helps debug)
				end else begin
					$display("Got Mismatch at Cycle %0d", i);
					// Displaying mismatched cycle data
					$display("Cycle %0d, reset %b, input {%h}, got output %h, exp output %h",
					i,
					reset_queue[i],
					input_queue[i], // Input representation
					state_dut_queue[i], // Got output
					state_ref_queue[i]  // Expected output
				);
				end
			end
			// Update stats only if it was the first error
			if (stats1.errors == 0) begin
				s$display("SIMULATION FAILED - 1 MISMATCHES DETECTED, FIRST AT TIME %0t", $time);
			end
		end
		// Update overall error count regardless of first detection
		stats1.errors = stats1.errors + 1;
		stats1.clocks++;
		end

	// --- Finalization --- 
	initial begin
		// Wait for simulation to naturally finish or timeout
		@(posedge clk_tb);
		// Wait a bit longer to ensure final states are captured
		#100;

		// Final Check using accumulated stats (errors field in stats1)
		if (stats1.errors == 0) begin
			s$display("SIMULATION PASSED");
		end else begin
			s$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
		end
		$display("Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
	end

	// add timeout after 100K cycles
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

	endmodule

