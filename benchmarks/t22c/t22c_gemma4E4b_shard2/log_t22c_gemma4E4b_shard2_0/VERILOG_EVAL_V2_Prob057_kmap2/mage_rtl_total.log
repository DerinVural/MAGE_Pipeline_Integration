    // ab=00, cd=11 -> 0
    // ab=00, cd=10 -> 1
    // ab=01, cd=00 -> 1
    // ab=01, cd=01 -> 0
    // ab=01, cd=11 -> 0
    // ab=01, cd=10 -> 1
    // ab=11, cd=00 -> 0
    // ab=11, cd=01 -> 1
    // ab=11, cd=11 -> 1
    // ab=11, cd=10 -> 1
    // ab=10, cd=00 -> 1
    // ab=10, cd=01 -> 1
    // ab=10, cd=11 -> 0
    // ab=10, cd=10 -> 0
    
