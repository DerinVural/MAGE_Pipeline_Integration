// --- Top Module Under Test (Implementation based on K-Map) ---
module TopModule (
    input a,
    input b,
    input c,
    input d,
    output out
);
    // K-Map: ab (row), cd (column)
    // 00 | 1 | 1 | 0 | 1 |
