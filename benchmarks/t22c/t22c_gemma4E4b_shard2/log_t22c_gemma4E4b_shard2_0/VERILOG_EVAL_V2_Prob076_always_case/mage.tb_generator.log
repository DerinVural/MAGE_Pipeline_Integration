        .data0, data0,\n        .data1, data1,\n        .data2, data2,\n        .data3, data3,\n        .data4, data4,\n        .data5, data5,\n        .out(out_ref) \n    );\n        \n    // Instantiate DUT\n    TopModule top_module1 (\n        .sel, sel,\n        .data0, data0,\n        .data1, data1,\n        .data2, data2,\n        .data3, data3,\n        .data4, data4,\n        .data5, data5,\n        .out(out_dut) \n    );\n\n    // Task to wait for a stable state (Kept original functionality)\n    bit strobe = 0;\n    task wait_for_end_of_timestep;\n        repeat(5) begin\n            strobe <= !strobe;  // Try to delay until the very end of the time step.\n            @(strobe);\n        end\n    endtask\n\n    // Verification Logic (Simplified from original complex XOR to direct comparison)\n    // tb_match is true if out_ref equals out_dut\n    assign tb_match = (out_ref === out_dut);\n\n    // Clocked always block to sample outputs and update stats\n    // Since the DUT is combinational, we sample on the clock edge to correlate with the expected reference output timing.\n    always @(posedge clk, negedge clk) begin\n\n        stats1.clocks++;\n\n        // 1. Tracking total mismatches (Error counting logic maintenance)\n        if (!tb_match) begin\n            if (stats1.errors == 0) stats1.errortime = $time;\n            stats1.errors++;\n        end\n\n        // 2. Tracking specific output mismatches (Error counting logic maintenance)\n        // The original logic was: if (out_ref !== ( out_ref ^ out_dut ^ out_ref ))\n        // This simplifies to: if (out_ref !== out_dut)\n        if (out_ref !== out_dut)\n        begin \n            if (stats1.errors_out == 0) stats1.errortime_out = $time;\n            stats1.errors_out = stats1.errors_out+1'b1; \n        end\n        \n        // 3. Combinational Mismatch Display (Improvement for combinational logic)\n        if (!tb_match && stats1.errors == 1 && stats1.errors_out == 1) begin\n            $display(\"\\n========================================================\");\n            $display(\"*** FIRST COMBINATIONAL MISMATCH DETECTED ***\");\n            $display(\"Time: %0t ps\", $time);\n            $display(\"--------------------------------------------------------\");\n            $display(\"Inputs: sel = %b, data0 = %h, data1 = %h, data2 = %h, data3 = %h, data4 = %h, data5 = %h\",\n                sel, data0, data1, data2, data3, data4, data5);\n            $display(\"Expected Output (Ref): %h (%b)\", out_ref, out_ref);\n            $display(\"Actual Output (DUT):   %h (%b)\", out_dut, out_dut);\n            $display(\"========================================================\\n\");\n        end\n    end\n\n    // Timeout\n   initial begin\n     #1000000\n     $display(\"\\nTIMEOUT REACHED.\");\n     $finish();\n   end\n\n    // Final Reporting Logic (Updated to required format)\n    final begin\n        if (stats1.errors_out == 0)\n        begin\n            $display(\"\\nSIMULATION PASSED\");\n        end\n        else begin\n            $display(\"\\nSIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\", stats1.errors_out, stats1.errortime_out);\n        end\n\n        $display(\"Total mismatched samples (overall count): %0d out of %0d samples\\n\", stats1.errors, stats1.clocks);\n        $display(\"Simulation finished at %0d ps\", $time);\n        $display(\"Final Summary: %0d total errors in %0d cycles.\", stats1.errors, stats1.clocks);\n    end\n\nendmodule\n"
