module tb();

    // Since the DUT is combinational, we track errors instantaneously upon mismatch detection.
    stats stats1;

    // Signal declarations based on testbench usage
    wire[511:0] wavedrom_title;
    wire wavedrom_enable;
    int wavedrom_hide_after_time;
    
    reg clk=0;
    initial forever
        #5 clk = ~clk;

    // Testbench inputs/outputs
    logic [2:0] sel;
    logic [3:0] data0;
    logic [3:0] data1;
    logic [3:0] data2;
    logic [3:0] data3;
    logic [3:0] data4;
    logic [3:0] data5;
    logic [3:0] out_ref;
    logic [3:0] out_dut;

    // Stats tracking
    stats1.errors = 0;
    stats1.errortime = 0;
    stats1.errors_out = 0;
    stats1.errortime_out = 0;
    stats1.clocks = 0;

    // Initial Dump Setup
    initial begin 
        $dumpfile("wave.vcd");
        // Note: stimulus_gen has extra ports, including them here.
        $dumpvars(1, stim1.clk, tb_mismatch, sel, data0, data1, data2, data3, data4, data5, out_ref, out_dut );
    end


    wire tb_match;
    wire tb_mismatch = ~tb_match;

    // Instantiate Stimulus Generator
    stimulus_gen stim1 (
        .clk, clk,
        .sel, sel,
        .data0, data0,
        .data1, data1,
        .data2, data2,
        .data3, data3,
        .data4, data4,
        .data5, data5,
        .wavedrom_title, wavedrom_title,
        .wavedrom_enable, wavedrom_enable 
    );

    // Instantiate Reference Module
    RefModule good1 (
        .sel, sel,
        .data0, data0,
        .data1, data1,
        .data2, data2,
        .data3, data3,
        .data4, data4,
        .data5, data5,
        .out(out_ref) 
    );
        
    // Instantiate DUT
    TopModule top_module1 (
        .sel, sel,
        .data0, data0,
        .data1, data1,
        .data2, data2,
        .data3, data3,
        .data4, data4,
        .data5, data5,
        .out(out_dut) 
    );

    // Task to wait for a stable state (Kept original functionality)
    bit strobe = 0;
    task wait_for_end_of_timestep;
        repeat(5) begin
            strobe <= !strobe;  // Try to delay until the very end of the time step.
            @(strobe);
        end
    endtask

    // Verification Logic (Simplified from original complex XOR to direct comparison)
    // tb_match is true if out_ref equals out_dut
    assign tb_match = (out_ref === out_dut);

    // Clocked always block to sample outputs and update stats
    // Since the DUT is combinational, we sample on the clock edge to correlate with the expected reference output timing.
    always @(posedge clk, negedge clk) begin

        stats1.clocks++;

        // 1. Tracking total mismatches (Error counting logic maintenance)
        if (!tb_match) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
        end

        // 2. Tracking specific output mismatches (Error counting logic maintenance)
        // The original logic was: if (out_ref !== ( out_ref ^ out_dut ^ out_ref ))
        // This simplifies to: if (out_ref !== out_dut)
        if (out_ref !== out_dut)
        begin 
            if (stats1.errors_out == 0) stats1.errortime_out = $time;
            stats1.errors_out = stats1.errors_out+1'b1; 
        end
        
        // 3. Combinational Mismatch Display (Improvement for combinational logic)
        if (!tb_match && stats1.errors == 1 && stats1.errors_out == 1) begin
            $display("\n========================================================");
            $display("*** FIRST COMBINATIONAL MISMATCH DETECTED ***");
            $display("Time: %0t ps", $time);
            $display("--------------------------------------------------------");
            $display("Inputs: sel = %b, data0 = %h, data1 = %h, data2 = %h, data3 = %h, data4 = %h, data5 = %h",
                sel, data0, data1, data2, data3, data4, data5);
            $display("Expected Output (Ref): %h (%b)", out_ref, out_ref);
            $display("Actual Output (DUT):   %h (%b)", out_dut, out_dut);
            $display("========================================================\n");
        end
    end

    // Timeout
   initial begin
     #1000000
     $display("\nTIMEOUT REACHED.");
     $finish();
   end

    // Final Reporting Logic (Updated to required format)
    final begin
        if (stats1.errors_out == 0)
        begin
            $display("\nSIMULATION PASSED");
        end
        else begin
            $display("\nSIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_out, stats1.errortime_out);
        end

        $display("Total mismatched samples (overall count): %0d out of %0d samples\n", stats1.errors, stats1.clocks);
        $display("Simulation finished at %0d ps", $time);
        $display("Final Summary: %0d total errors in %0d cycles.", stats1.errors, stats1.clocks);
    end

endmodule

