ut } ^ { q_ref } ) );\n\t\n\t// Use explicit sensitivity list here.\n\talways @(posedge clk, negedge clk) begin\n\t\t\n\t\tstats1.clocks++;\n\t\tif (!tb_match) begin\n\t\t\tif (stats1.errors == 0) begin\n\t\t\t\tsstats1.errortime = $time; // Fixed typo: sstats1 -> stats1\n\t\t\t\t// Capture current inputs and outputs upon first general mismatch\n\t\t\t\tdata_mismatch = data;\n\t\t\t\tshift_ena_mismatch = shift_ena;\n\t\t\t\tcount_ena_mismatch = count_ena;\n\t\t\t\tq_mismatch_ref = q_ref;\n\t\t\t\tq_mismatch_dut = q_dut;\n\t\t\t\tmismatch_time = $time;\n\t\t\tend\n\t\t\tsstats1.errors++;\n\t\tend\n\t\t\n\t\t// Specific check for output mismatch (q_ref != q_dut)\n\t\tif (q_ref !== q_dut) begin\n\t\t\tif (stats1.errors_q == 0) begin\n\t\t\t\tsstats1.errortime_q = $time; // Fixed typo: sstats1 -> stats1\n\t\t\t\t// Capture current inputs and outputs upon first output mismatch\n\t\t\t\tdata_mismatch = data;\n\t\t\t\tshift_ena_mismatch = shift_ena;\n\t\t\t\tcount_ena_mismatch = count_ena;\n\t\t\t\tq_mismatch_ref = q_ref;\n\t\t\t\tq_mismatch_dut = q_dut;\n\t\t\t\tmismatch_time = $time;\n\t\t\tend\n\t\t\tsstats1.errors_q = stats1.errors_q + 1'b1;\n\t\tend\n\tend\n\n\t// Add timeout after 100K cycles\n\tinitial begin\n\t\th#1000000\n\t\t$display(\"TIMEOUT\");\n\t\t$finish();\n\tend\n\nendmodule"
