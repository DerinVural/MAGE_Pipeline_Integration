	// Input signals to track: shift_ena, count_ena, data
	logic [1:0] input_ctrl_queue [$]; // {shift_ena, count_ena} -> 2 bits
	logic [3:0] input_data_queue [$];  // data
	logic [3:0] got_output_queue [$];  // q_dut
	logic [3:0] golden_queue [$];      // q_ref
	
	// MAX_QUEUE_SIZE: Output q is 4 bits (2^4 = 16 states). Setting to 11 to respect limit and provide context.
	localparam MAX_QUEUE_SIZE = 11;

	initial begin
		$dumpfile("wave.vcd");
		// Updated dumpvars to include relevant signals for tracking
		$dumpvars(1, stim1.clk, tb_mismatch, clk, shift_ena, count_ena, data, q_ref, q_dut);
	end

	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk,
		.shift_ena,
		.count_ena,
		.data,
		.wavedrom_title,
		.wavedrom_enable
	);
	
	RefModule good1 (
		.clk,
		.shift_ena,
		.count_ena,
		.data,
		.q(q_ref) 
	);
	
	TopModule top_module1 (
		.clk,
		.shift_ena,
		.count_ena,
		.data,
		.q(q_dut) 
	);

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end
	task

	// --- Queue Management and Mismatch Checking --- 
	always @(posedge clk, negedge clk) begin
		
		// 1. Queue Management (Shift/Trim oldest element if full)
		if (input_ctrl_queue.size() >= MAX_QUEUE_SIZE - 1) begin
			input_ctrl_queue.delete(0);
			input_data_queue.delete(0);
			got_output_queue.delete(0);
			golden_queue.delete(0);
		end

		// 2. Store current state
		input_ctrl_queue.push_back({shift_ena, count_ena});
		input_data_queue.push_back(data);
		got_output_queue.push_back(q_dut);
		golden_queue.push_back(q_ref);

		// 3. Check for first mismatch (Using q_dut vs q_ref)
		if (q_dut !== q_ref) begin
			// Update original error counters
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;

			// Update queue-based error counters (Requirement 1.1)
			if (stats1.errors_q == 0) stats1.errortime_q = $time;
			stats1.errors_q = stats1.errors_q + 1'b1;

			$display("\n========================================================");
			$display("QUEUE-BASED MISMATCH DETECTED AT TIME %0t", $time);
			$display("Last %0d cycles stored in queue.", input_ctrl_queue.size());
			$display("========================================================");

			for (int i = 0; i < input_ctrl_queue.size(); i++) begin
				// Check if this specific cycle was a mismatch
				if (got_output_queue[i] === golden_queue[i]) begin
					$display("Cycle %0d: Got Match.", i);
				end else begin
					$display("Cycle %0d: ***** GOT MISMATCH *****", i);
				end

				// Displaying data based on queue contents
				$display("  Time: %0t ps", $time - (input_ctrl_queue.size() - 1 - i) * 10);
				// Input signals (Shift_ena, Count_ena, Data)
				$display("  Inputs: {Shift_ena=%b, Count_ena=%b}, Data=%b", 
					input_ctrl_queue[i][0], input_ctrl_queue[i][1], input_data_queue[i]);
				// Outputs
				$display("  Outputs: Got Q = %h (%b), Exp Q = %h (%b)", 
					got_output_queue[i], got_output_queue[i], golden_queue[i], golden_queue[i]);
				// Note: We rely on the fact that if got_output_queue[i] != golden_queue[i], the mismatch occurred here.
			end
			end
		end
	end

	// Original synchronization for tb_match (kept for compatibility, though queue handles main logic)
	assign tb_match = ( { q_ref } === { q_dut } );

	// Original error tracking loop (retained) 
	always @(posedge clk, negedge clk) begin
		stats1.clocks++;
		// Original logic
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
		end
		// Original logic (redundant with queue tracking, but must be kept)
		if (q_ref !== ( q_ref ^ q_dut ^ q_ref ))
		begin if (stats1.errors_q == 0) stats1.errortime_q = $time;
			sstats1.errors_q = stats1.errors_q+1'b1; end
		end
	end

   // add timeout after 100K cycles
   initial begin
     #1000000
     $display("\nTIMEOUT REACHED.");
     $finish();
   end

   // Final Reporting (REPLACING original final block)
   initial begin
       @(negedge clk); // Wait for one clock cycle after simulation activity ceases or timeout
       
       if (stats1.errors == 0) begin
           $display("\n****************************************");
           $display("SIMULATION PASSED");
           $display("****************************************");
       end else begin
           $display("\n****************************************");
           $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", 
                    stats1.errors, stats1.errortime);
           $display("****************************************");
       end
       $finish;
   end
	endmodule
