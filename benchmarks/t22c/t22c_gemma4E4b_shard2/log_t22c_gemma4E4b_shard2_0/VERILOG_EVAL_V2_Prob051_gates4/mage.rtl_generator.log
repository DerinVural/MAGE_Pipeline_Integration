ats1.errors_out_xor == 0) stats1.errortime_out_xor = $time;\n\t\t\ts\n\t\t\ts\tstats1.errors_out_xor = stats1.errors_out_xor+1\'b1; \n\t\tend\n\t\tend\n\n   // Added display logic immediately after mismatch detection (for combinational logic requirement)\n   always @(posedge clk) begin\n       if (stats1.errors > 0 && stats1.errors_out_and == 1 && stats1.errors_out_or == 1 && stats1.errors_out_xor == 1) begin\n           // This is complex to trigger exactly once, using the first cycle of mismatch detection.\n           // We rely on the final display block to show the overall result, but we add a targeted display here.\n           if (stats1.errors == 1) begin\n               $display("\\n=============================================================================");\n               $display("!!! FIRST MISMATCH DETECTED AT TIME %0t !!!", $time);\n               $display("Inputs:  Binary=%h, Hex=%h", mismatch_in_val, mismatch_in_val);\n               $display("Expected Outputs: AND=%b, OR=%b, XOR=%b", out_and_ref, out_or_ref, out_xor_ref);\n               $display("Actual Outputs:   AND=%b, OR=%b, XOR=%b", out_and_dut, out_or_dut, out_xor_dut);\n               $display("=============================================================================");\n           end\n       end\n   end\n\n   // add timeout after 100K cycles\n   initial begin\n     #1000000\n     if (stats1.errors == 0) begin\n         $display("SIMULATION PASSED");\n     end else begin\n         $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);\n     end\n     $finish();\n   end\n\nendmodule\n\n// Mock RefModule needed for simulation to compile\nmodule RefModule (\n    input logic [3:0] in,\n    output logic out_and,\n    output logic out_or,\n    output logic out_xor\n);\n    assign out_and = in[0] & in[1] & in[2] & in[3];\n    assign out_or  = in[0] | in[1] | in[2] | in[3];\n    assign out_xor = in[0] ^ in[1] ^ in[2] ^ in[3];\nendmodule\n\