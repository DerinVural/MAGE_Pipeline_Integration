n,\n\t\tout_and(out_and_dut),\n\t\tout_or(out_or_dut),\n\t\tout_xor(out_xor_dut) );\n\n\t\n\tbit strobe = 0;\n\ttask wait_for_end_of_timestep;\n\t\trepeat(5) begin\n\t\tstrobe <= !strobe;  // Try to delay until the very end of the time step.\n\t\t@(strobe);\n\t\tendtask\t\n\n\tfinal begin\n\t\tif (stats1.errors_out_and) $display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d (out_and)\", stats1.errors_out_and, stats1.errortime_out_and);\n\t\telse $display(\"SIMULATION PASSED\");\n\t\tif (stats1.errors_out_or) $display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d (out_or)\", stats1.errors_out_or, stats1.errortime_out_or);\n\t\telse $display(\"SIMULATION PASSED\");\n\t\tif (stats1.errors_out_xor) $display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d (out_xor)\", stats1.errors_out_xor, stats1.errortime_out_xor);\n\t\telse $display(\"SIMULATION PASSED\");\n\n\t\t$display(\"\\nTotal mismatches across all outputs: %0d out of %0d samples.\", stats1.errors, stats1.clocks);\n\t\t$display(\"Simulation finished at %0d ps\", $time);\n\tend\n\t\n\t// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.\n\tassign tb_match = ( { out_and_ref, out_or_ref, out_xor_ref } === ( { out_and_ref, out_or_ref, out_xor_ref } ^ { out_and_dut, out_or_dut, out_xor_dut } ^ { out_and_ref, out_or_ref, out_xor_ref } ) );\n\t\n\t// Modified logic to capture mismatch state upon first error\n\talways @(posedge clk, negedge clk) begin\n\t\tstats1.clocks++;\n\t\t\n\t\tif (tb_mismatch) begin\n\t\t\tif (stats1.errors == 0) begin\n\t\t\tstats1.errortime = $time;\n\t\t\t// Capture state at first mismatch\n\t\t\tmismatch_in_val = in;\n\t\t\tmismatch_clk_val = in;\n\t\t\tend\n\t\t\t// Capture output states at first mismatch\n\t\t\tout_and_mismatch_val = out_and_dut;\n\t\t\tout_or_mismatch_val = out_or_dut;\n\t\t\tout_xor_mismatch_val = out_xor_dut;\n\t\t\tend\n\t\t\ts\n\t\t\tstats1.errors++;\n\t\t\tend\n\t\tend\n\t\t\n\t\t// Original per-output error tracking (Maintained functionality)\n\t\tif (out_and_ref !== ( out_and_ref ^ out_and_dut ^ out_and_ref ))\n\t\tbegin if (stats1.errors_out_and == 0) stats1.errortime_out_and = $time;\n\t\t\ts\n\t\t\ts\tstats1.errors_out_and = stats1.errors_out_and+1'b1; \n\t\tend\n\t\t\n\t\tif (out_or_ref !== ( out_or_ref ^ out_or_dut ^ out_or_ref ))\n\t\tbegin if (stats1.errors_out_or == 0) stats1.errortime_out_or = $time;\n\t\t\ts\n\t\t\ts\tstats1.errors_out_or = stats1.errors_out_or+1'b1; \n\t\tend\n\t\t\n\t\tif (out_xor_ref !== ( out_xor_ref ^ out_xor_dut ^ out_xor_ref ))\n\t\tbegin if (stats1.errors_out_xor == 0) stats1.errortime_out_xor = $time;\n\t\t\ts\n\t\t\ts\tstats1.errors_out_xor = stats1.errors_out_xor+1'b1; \n\t\tend\n\t\tend\n\n   // Added display logic immediately after mismatch detection (for combinational logic requirement)\n   always @(posedge clk) begin\n       if (stats1.errors > 0 && stats1.errors_out_and == 1 && stats1.errors_out_or == 1 && stats1.errors_out_xor == 1) begin\n           // This is complex to trigger exactly once, using the first cycle of mismatch detection.\n           // We rely on the final display block to show the overall result, but we add a targeted display here.\n           if (stats1.errors == 1) begin\n               $display(\"\\n=============================================================================\");\n               $display(\"!!! FIRST MISMATCH DETECTED AT TIME %0t !!!\", $time);\n               $display(\"Inputs:  Binary=%h, Hex=%h\", mismatch_in_val, mismatch_in_val);\n               $display(\"Expected Outputs: AND=%b, OR=%b, XOR=%b\", out_and_ref, out_or_ref, out_xor_ref);\n               $display(\"Actual Outputs:   AND=%b, OR=%b, XOR=%b\", out_and_dut, out_or_dut, out_xor_dut);\n               $display(\"=============================================================================\");\n           end\n       end\n   end\n\n   // add timeout after 100K cycles\n