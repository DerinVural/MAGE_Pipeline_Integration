\n53:  \xa0 \xa0 \xa0 @(posedge clk) {too_cold, too_hot, mode, fan_on} <= 4\'b1000;\n54:  \xa0 \xa0 \xa0 @(posedge clk) {too_cold, too_hot, mode, fan_on} <= 4\'b1100;\n55:  \xa0 \xa0 \xa0 @(posedge clk) {too_cold, too_hot, mode, fan_on} <= 4\'b1001;\n56:  \xa0 \xa0 \xa0 @(posedge clk) {too_cold, too_hot, mode, fan_on} <= 4\'b1101;\n57:  \xa0 \xa0 @(negedge clk) wavedrom_stop();\n58:  \xa0 \xa0 \n59:  \xa0 \xa0 repeat(200)\n60:  \xa0 \xa0 \xa0 @(posedge clk, negedge clk) {too_cold, too_hot, mode, fan_on} <= $random;\n61:  \xa0 \xa0 \n62:  \xa0 \xa0 #1 $finish;\n63:  \xa0 end\n64:  \xa0 \n65:  endmodule\n66:  \n67:  // =========================================================================\n68:  // Testbench (Improved for comprehensive display and error reporting)\n69:  // =========================================================================\n70:  module tb();\n71:  \n72:  \xa0 // Structure to hold statistics\n73:  \xa0 typedef struct packed {\n74:  \xa0 \xa0 int errors;\n75:  \xa0 \xa0 int errortime;\n76:  \xa0 \xa0 int errors_heater;\n77:  \xa0 \xa0 int errortime_heater;\n78:  \xa0 \xa0 int errors_aircon;\n79:  \xa0 \xa0 int errortime_aircon;\n80:  \xa0 \xa0 int errors_fan;\n81:  \xa0 \xa0 int errortime_fan;\n82:  \n83:  \xa0 \xa0 int clocks;\n84:  \xa0 } stats;\n85:  \xa0 \n86:  \xa0 stats stats1;\n87:  \xa0 \n88:  \xa0 // Signals from stimulus_gen\n89:  \xa0 wire[511:0] wavedrom_title;\n90:  \xa0 wire wavedrom_enable;\n91:  \xa0 \n92:  \xa0 // Clock generation\n93:  \xa0 reg clk=0;\n94:  \xa0 initial forever\n95:  \xa0 \xa0 #5 clk = ~clk;\n96:  \n97:  \xa0 // Testbench Control Signals\n98:  \xa0 logic mode;\n99:  \xa0 logic too_cold;\n100:  \xa0 logic too_hot;\n101:  \xa0 logic fan_on;\n102:  \xa0 logic heater_ref; // Expected\n103:  \xa0 logic heater_dut; // DUT\n104:  \xa0 logic aircon_ref; // Expected\n105:  \xa0 logic aircon_dut; // DUT\n106:  \xa0 logic fan_ref;   // Expected\n107:  \xa0 logic fan_dut;   // DUT\n108:  \n109:  \xa0 // Mismatch detection\