module RefModule (
    input mode,
    input too_cold,
    input too_hot,
    input fan_on,
    output heater,
    output aircon,
    output fan
);
    // Placeholder for the golden reference logic
    assign heater = too_cold & mode;
    assign aircon = too_hot & ~mode;
    assign fan = too_cold | too_hot | fan_on;
endmodule

// The module under test (DUT)
module TopModule (
    input mode,
    input too_cold,
    input too_hot,
    input fan_on,
    output heater,
    output aircon,
    output fan
);
    // Placeholder implementation matching the spec for simulation purposes
    // Logic: Heating mode (1) -> Heater on if too_cold. Cooling mode (0) -> AC on if too_hot.
    assign heater = (mode == 1) && too_cold;
    assign aircon = (mode == 0) && too_hot;
    assign fan = too_cold | too_hot | fan_on || heater | aircon; // Fan on if H/AC is on, or fan_on is asserted

endmodule

// Improved Testbench
module tb();

    // Statistics structure (retained from golden testbench)
    typedef struct packed {
        int errors;
        int errortime;
        int errors_heater;
        int errortime_heater;
        int errors_aircon;
        int errortime_aircon;
        int errors_fan;
        int errortime_fan;
        int clocks;
    } stats;
    
    stats stats1;
    
    // Waveform control signals (retained)
    wire[511:0] wavedrom_title;
    wire wavedrom_enable;
    int wavedrom_hide_after_time;
    
    // Clock definition (retained)
    reg clk=0;
    initial forever
        #5 clk = ~clk;

    // DUT/Reference signals
    logic mode;
    logic too_cold;
    logic too_hot;
    logic fan_on;
    logic heater_ref;
    logic heater_dut;
    logic aircon_ref;
    logic aircon_dut;
    logic fan_ref;
    logic fan_dut;
    
    // Mismatch tracking and queueing setup
    // Inputs are 4 bits, Outputs are 3 bits. We need to track inputs, got, golden, and reset.
    // MAX_QUEUE_SIZE must not be > 10.
    localparam MAX_QUEUE_SIZE = 8; // Sufficient for short sequences
    
    // Queue contents (Inputs: 4 bits; Outputs: 3 bits; Reset: 1 bit)
    logic [3:0] input_queue [$];
    logic [2:0] got_output_queue [$];
    logic [2:0] golden_queue [$];
    logic reset_queue [$];
    
    // State variables for tracking first error
    logic mismatch_detected_this_cycle = 0;
    integer total_mismatches = 0;
    int first_mismatch_time = -1;

    // Initial setup
    initial begin 
        $dumpfile("wave.vcd");
        // Dump variables matching the original setup
        $dumpvars(1, stimulus_gen::stim1, tb_mismatch, mode, too_cold, too_hot, fan_on, heater_ref, heater_dut, aircon_ref, aircon_dut, fan_ref, fan_dut );
    end

    // Wire connection from golden testbench
    wire tb_match;
    wire tb_mismatch = ~tb_match;
    
    // Stimulus Generator
    stimulus_gen stim1 (
        .clk, 
        .too_cold, .too_hot, .mode, .fan_on, 
        .wavedrom_title, .wavedrom_enable 
    );

    // Reference Model (Golden)
    RefModule good1 (
        .mode, .too_cold, .too_hot, .fan_on,
        .heater(heater_ref),
        .aircon(aircon_ref),
        .fan(fan_ref) 
    );
        
    // DUT Instantiation
    TopModule top_module1 (
        .mode,
        .too_cold,
        .too_hot,
        .fan_on,
        .heater(heater_dut),
        .aircon(aircon_dut),
        .fan(fan_dut) 
    );

    // Task to delay time step end (retained)
    bit strobe = 0;
    task wait_for_end_of_timestep;
        repeat(5) begin
            strobe <= !strobe;  // Try to delay until the very end of the time step.
            @(strobe);
        end
    endtask

    // Clocked logic block for state updates and mismatch detection (Sequential logic handling)
    always @(posedge clk, negedge clk) begin
        // Reset handling (assuming reset is deasserted initially)
        if (!clk) begin
            reset_queue.push_back(1'b0); // Reset asserted at falling edge (assuming clk=0 is reset state)
        end else begin
            reset_queue.push_back(1'b0); // Assuming no explicit reset signal for DUT
        end

        // 1. Manage Queue Size
        if (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin
            input_queue.delete(0);
            got_output_queue.delete(0);
            golden_queue.delete(0);
            reset_queue.delete(0);
        end

        // 2. Push current data into queue
        input_queue.push_back({too_cold, too_hot, mode, fan_on});
        got_output_queue.push_back({heater_dut, aircon_dut, fan_dut});
        golden_queue.push_back({heater_ref, aircon_ref, fan_ref});

        // 3. Mismatch Check
        // Compare DUT outputs against Reference outputs
        if (got_output_queue.size() > 0 && got_output_queue.size() == golden_queue.size() && got_output_queue.size() > 0) begin
            logic mismatch = (got_output_queue.size() > 0) && (got_output_queue.size() == golden_queue.size());
            if (mismatch && (got_output_queue[got_output_queue.size()-1] !== golden_queue[golden_queue.size()-1])) begin
                mismatch_detected_this_cycle = 1;
            end else begin
                mismatch_detected_this_cycle = 0;
            end
        end

        // 4. Update Error Counters/Timing
        if (mismatch_detected_this_cycle) begin
            if (first_mismatch_time == -1) begin
                first_mismatch_time = $time;
            end
            total_mismatches++;
        end
        
        // 5. Queue Display Logic (Triggered on mismatch)
        if (mismatch_detected_this_cycle) begin
            $display("Mismatch detected at time %0d", $time);
            $display("\nLast %0d cycles of simulation:", input_queue.size());

            for (int i = 0; i < input_queue.size(); i++) begin
                // Check if outputs match for this cycle in the queue
                if (got_output_queue[i] === golden_queue[i]) begin
                    $display("Cycle %0d, reset %b, input %h, got output %h, exp output %h",
                        i, reset_queue[i], input_queue[i], got_output_queue[i], golden_queue[i]);
                end else begin
                    $display("Cycle %0d, reset %b, input %h, got output %h, exp output %h [MISMATCH]",
                        i, reset_queue[i], input_queue[i], got_output_queue[i], golden_queue[i]);
                end
            end
        end

        stats1.clocks++;

    end

   // Timeout
   initial begin
     #1000000
     if (total_mismatches > 0) begin
         $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", total_mismatches, first_mismatch_time);
     end else begin
         $display("SIMULATION PASSED");
     end
     $finish();
   end

endmodule

