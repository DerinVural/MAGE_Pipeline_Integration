ch;\n    int first_mismatch_time = 0;\n\n    // Task to display signals clearly\n    task display_signals(string stage_name);\n        $display(\"====================================================================\");\n        $display(\"!!! FIRST MISMATCH DETECTED at time %0d ps during %s !!!\", $time, stage_name);\n        $display(\"--------------------------------------------------------------------\");\n        $display(\"INPUTS: mode=%b, too_cold=%b, too_hot=%b, fan_on=%b\", mode, too_cold, too_hot, fan_on);\n        $display(\"EXPECTED OUTPUTS: heater=%b, aircon=%b, fan=%b\", heater_ref, aircon_ref, fan_ref);\n        $display(\"ACTUAL OUTPUTS: heater=%b, aircon=%b, fan=%b\", heater_dut, aircon_dut, fan_dut);\n        $display(\"====================================================================\");\n    endtask\n\n\n    initial begin \n        $dumpfile(\"wave.vcd\");\n        // Note: The original dumpvars listed 'stim1.clk' which is incorrect as clk is in tb.\n        // We dump all necessary signals.\n        $dumpvars(0, tb);\n    end\n\n\n    // Stimulus Generator Instantiation\n    stimulus_gen stim1 (\n        .clk, \n        .mode, .too_cold, .too_hot, .fan_on,\n        .wavedrom_title, .wavedrom_enable \n    );\n\n    // Golden Reference Module Instantiation\n    RefModule good1 (\n        .mode, .too_cold, .too_hot, .fan_on,\n        .heater(heater_ref),\n        .aircon(aircon_ref),\n        .fan(fan_ref) \n    );\n        \n    // DUT Instantiation\n    TopModule top_module1 (\n        .mode, .too_cold, .too_hot, .fan_on,\n        .heater(heater_dut),\n        .aircon(aircon_dut),\n        .fan(fan_dut) \n    );\n\n    // --- Simulation Control and Verification --- \n\n    // Verification logic based on original golden_testbench structure\n    // The original assertion logic was: (A === (A ^ B ^ A)) which simplifies to (A === B).\n    // Therefore, the comparison is simply: {heater_ref, aircon_ref, fan_ref} === {heater_dut, aircon_dut, fan_dut}