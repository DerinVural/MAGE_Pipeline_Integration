		.x2,
		.x1,
		.f(f_ref) );
	
	// Instantiate DUT
	TopModule top_module1 (
		.x3,
		.x2,
		.x1,
		.f(f_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end
	task

	// --- Mismatch Tracking and Display Logic (Improved) ---
	
	// Storage for first mismatch details (Combinational logic tracking)
	reg first_mismatch_detected = 0;
	reg [2:0] first_mismatch_x_inputs; // Stores {x3, x2, x1}
	reg first_mismatch_f_ref; 
	reg first_mismatch_f_dut; 
	
	// Replicate original error counting logic
	always @(posedge clk, negedge clk) begin
		
		stats1.clocks++;
		
		// Update original error counters
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			sstats1.errors++;
		end
		if (f_ref !== ( f_ref ^ f_dut ^ f_ref ))
		begin 
			if (stats1.errors_f == 0) stats1.errortime_f = $time;
			sstats1.errors_f = stats1.errors_f+1'b1; 
		end
		end

		// NEW: Capture details ONLY on the FIRST mismatch detected
		if (!tb_match && !first_mismatch_detected) begin
			first_mismatch_detected = 1;
			// Capture inputs
			first_mismatch_x_inputs = {x3, x2, x1};
			// Capture outputs
			first_mismatch_f_ref = f_ref;
			first_mismatch_f_dut = f_dut;
		end
	end

	// Monitor for the first mismatch and display details (Rule 2 for Combinational Logic)
	always @(posedge clk, negedge clk)
		if (first_mismatch_detected && stats1.errors == 1) begin
			$display("=================================================================================");
			$display("--- FIRST MISMATCH DETECTED (Combinational Check) ---");
			$display("Time of First Mismatch: %0t ps", $time);
			$display("Inputs (x3 x2 x1): %b (%h)", first_mismatch_x_inputs, first_mismatch_x_inputs);
			$display("Expected Output (f_ref): %b (%h)", first_mismatch_f_ref, first_mismatch_f_ref);
			$display("DUT Output (f_dut):     %b (%h)", first_mismatch_f_dut, first_mismatch_f_dut);
			$display("=================================================================================");
		end


	// add timeout after 100K cycles	
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end


	// Final Status Reporting (Improved requirement fulfillment)
	initial begin
		@(negedge clk);
		// Wait a bit after simulation ends to ensure all logging finishes
		#10;
		
		if (stats1.errors == 0 && stats1.errors_f == 0) begin
			$display("SIMULATION PASSED");
		end else begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
		end
		end

endmodule

