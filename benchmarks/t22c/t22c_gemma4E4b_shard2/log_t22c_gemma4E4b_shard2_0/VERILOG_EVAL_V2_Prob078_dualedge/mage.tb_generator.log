    "testbench": "`timescale 1 ps/1 ps\n`define OK 12\n`define INCORRECT 13\n\n\n// Dummy modules required to keep the testbench structure intact, as they are not defined.\nmodule stimulus_gen (\n    input clk,\n    output reg d,\n    output reg[511:0] wavedrom_title,\n    output reg wavedrom_enable\n);\n\n    task wavedrom_start(input[511:0] title = \"\");\n        $display(\"--- Wavedrom Start ---\");\n    endtask\n    \n    task wavedrom_stop;\n        $display(\"--- Wavedrom Stop ---\");\n    endtask \n\n    initial begin\n        d <= 1'b0;\n        @(negedge clk) wavedrom_start();\n            repeat(20) @(posedge clk, negedge clk)\n                d <= $random>>2;\n        @(negedge clk) wavedrom_stop();\n        repeat(200) @(posedge clk, negedge clk) begin\n            d <= $random;\n        end\n        #1 $finish;\n    end\n    \nendmodule\n\nmodule RefModule (\n    input clk,\n    input d,\n    output q\n);\n    // Placeholder for the golden reference model\n    always @(posedge clk, negedge clk) begin\n        q <= d;\n    end\nendmodule\n\n// DUT Module Under Test (TopModule) - Assuming a simple FF for functional simulation purposes\n// A dual-edge triggered FF functionally is equivalent to sampling twice per clock cycle.\n// For simulation purposes in the testbench, we model the desired behavior.\nmodule TopModule (\n    input clk,\n    input d,\n    output q\n);\n    // Since we cannot implement true dual-edge triggering legally in Verilog/SystemVerilog\n    // without specialized constructs, we model the behavior based on the testbench's reference.\n    // If the golden testbench implies a simple synchronous FF for comparison, we use that.\n    // Assuming a standard positive edge FF behavior for comparison consistency:\n    logic internal_q;\n    always @(posedge clk) begin\n        internal_q <= d;\n    end\n    assign q = internal_q;\nendmodule\n\n\nmodule tb();\n\n    typedef struct packed {\n        int errors;\n        int errortime;\n        int errors_q;\n        int errortime_q;\n        int clocks;\n    } stats;\n    \n    stats stats1;\n    \n    \n    wire[511:0] wavedrom_title;\n    wire wavedrom_enable;\n    int wavedrom_hide_after_time;\n    \n    reg clk=0;\n    initial forever\n        #5 clk = ~clk;\n\n    logic d_tb;\n    logic q_ref;\n    logic q_dut;\n\n    // --- New Queue Definitions for Mismatch Tracking (Rule 1.1) ---\n    // Signal widths: d (1-bit), q_ref (1-bit), q_dut (1-bit), tb_match (1-bit)\n    logic d_queue [$];\n    logic q_dut_queue [$];\n    logic q_ref_queue [$];\n    logic match_queue [$];\n\n    localparam MAX_QUEUE_SIZE = 10; // Max 10 as per constraint\n    \n    // Original mismatch flag\n    wire tb_match;\n    wire tb_mismatch = ~tb_match;\n\n    initial begin \n        $dumpfile(\"wave.vcd\");\n        $dumpvars(1, stimulus_gen::stim1, tb);\n    end\n\n    // Instantiate Modules\n    stimulus_gen stim1 (\n        .clk, .d, .wavedrom_title, .wavedrom_enable \n    );\n\n    RefModule good1 (\n        .clk, .d, .q(q_ref) \n    );\n        \n    TopModule top_module1 (\n        .clk, .d, .q(q_dut) \n    );\n\n    \n    bit strobe = 0;\n    task wait_for_end_of_timestep;\n        repeat(5) begin\n            strobe <= !strobe;  // Try to delay until the very end of the time step.\n            @(strobe);\n        end\n    endtask\n\n    // Verification: Must maintain original functionality\n    assign tb_match = ( { q_ref } === ( { q_ref } ^ { q_dut } ^ { q_ref } ) );\n\n    // --- Clocked Block for Error Counting and Queueing (Rule 1.1 & 1.3) ---\n    always @(posedge clk, negedge clk) begin\n\n        stats1.clocks++;\n        \n        // 1. Queue Management\n        if (d_queue.size() >= MAX_QUEUE_SIZE - 1) begin\n            d_queue.delete(0);\n            q_dut_queue.delete(0);\n            q_ref_queue.delete(0);\n            match_queue.delete(0);\n        end\n\n        // 2. Push current values\n        d_queue.push_back(d_tb);\n        q_dut_queue.push_back(q_dut);\n        q_ref_queue.push_back(q_ref);\n        match_queue.push_back(tb_match);\n\n        // 3. Error Counting (Original Logic Maintained)\n        if (!tb_match) begin\n            if (stats1.errors == 0) stats1.errortime = $time;\n            stats1.errors++;\n        end\n        if (q_ref !== ( q_ref ^ q_dut ^ q_ref ))\n        begin if (stats1.errors_q == 0) stats1.errortime_q = $time;\n            stats1.errors_q = stats1.errors_q+1'b1; \n        end\n\n        // 4. Mismatch Detection and Queue Display (Rule 1.1)\n        if (!tb_match) begin\n            if (stats1.errors == 1) begin // Trigger display only upon the FIRST mismatch\n                $display(\"\\n==================================================================\");\n                $display(\"FIRST MISMATCH DETECTED AT TIME %0t\", $time);\n                $display(\"\\nLast %0d cycles of simulation (Showing data leading up to and including mismatch):\", d_queue.size());\n\n                for (int i = 0; i < d_queue.size(); i++) begin\n                    // Check if the data point *at this index* was a mismatch\n                    if (match_queue[i] !== 1'b1) begin\n                        $display(\"--- MISMATCH AT CYCLE %0d ---\", i);\n                        $display(\"Cycle %0d, Input d: %b (%h), Got q_dut: %b (%h), Expected q_ref: %b (%h)\",\n                            i, d_queue[i], d_queue[i], q_dut_queue[i], q_dut_queue[i], q_ref_queue[i], q_ref_queue[i]);\n                    end\n                end\n                $display(\"==================================================================\\n\");\n            end\n        end\n\n    end\n\n    // Add timeout after 100K cycles\n    initial begin\n     #1000000\n     $display(\"TIMEOUT REACHED\");\n     $finish();\n    end\n\n    // --- Final Reporting (Rule 4) ---\n    final begin\n        // Print the detailed log if mismatches occurred (retaining original hint structure)\n        if (stats1.errors_q) $display(\"Hint: Output 'q' has %0d mismatches. First mismatch occurred at time %0d.\", stats1.errors_q, stats1.errortime_q);\n        else $display(\"Hint: Output 'q' has no mismatches.\");\n\n        $display(\"Hint: Total mismatched samples is %1d out of %1d samples\\n\", stats1.errors, stats1.clocks);\n\n        // FINAL REQUIRED DISPLAY LOGIC\n        if (stats1.errors == 0) begin\n            $display(\"SIMULATION PASSED\");\n        end else begin\n            $display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\", stats1.errors, stats1.errortime);\n        end\n        $display(\"Simulation finished at %0d ps\", $time);\n    end\n\nendmodule"
