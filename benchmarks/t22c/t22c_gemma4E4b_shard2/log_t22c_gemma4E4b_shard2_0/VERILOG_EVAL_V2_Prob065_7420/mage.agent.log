module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_p1y;
		int errortime_p1y;
		int errors_p2y;
		int errortime_p2y;

		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic p1a;
	logic p1b;
	logic p1c;
	logic p1d;
	logic p2a;
	logic p2b;
	logic p2c;
	logic p2d;
	logic p1y_ref;
	logic p1y_dut;
	logic p2y_ref;
	logic p2y_dut;

	// Variables to store first mismatch state for combinational display
	logic [3:0] first_mismatch_input_p1a, first_mismatch_input_p1b, first_mismatch_input_p1c, first_mismatch_input_p1d;
	logic [3:0] first_mismatch_input_p2a, first_mismatch_input_p2b, first_mismatch_input_p2c, first_mismatch_input_p2d;
	logic [1:0] first_mismatch_input_packed;
	
	logic [1:0] first_mismatch_ref_output_packed;
	logic [1:0] first_mismatch_dut_output_packed;
	
	integer first_error_time = -1;

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,p1a,p1b,p1c,p1d,p2a,p2b,p2c,p2d,p1y_ref,p1y_dut,p2y_ref,p2y_dut );
	end


	wire tb_match; 	// Verification
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk,
		.* ,
		p1a,
		p1b,
		p1c,
		p1d,
		p2a,
		p2b,
		p2c,
		p2d );
	RefModule good1 (
		p1a,
		p1b,
		p1c,
		p1d,
		p2a,
		p2b,
		p2c,
		p2d,
		p1y(p1y_ref),
		p2y(p2y_ref) );
	
	TopModule top_module1 (
		p1a,
		p1b,
		p1c,
		p1d,
		p2a,
		p2b,
		p2c,
		p2d,
		p1y(p1y_dut),
		p2y(p2y_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		endtask	
	
	// State capture logic for combinational mismatch display
	always @(posedge clk, negedge clk) begin
		if (stats1.errors == 0 && !tb_match) begin
			first_error_time = $time;
			// Capture inputs
			first_mismatch_input_p1a = p1a; first_mismatch_input_p1b = p1b; first_mismatch_input_p1c = p1c; first_mismatch_input_p1d = p1d;
			first_mismatch_input_p2a = p2a; first_mismatch_input_p2b = p2b; first_mismatch_input_p2c = p2c; first_mismatch_input_p2d = p2d;
			first_mismatch_input_packed = {p1a, p1b, p1c, p1d, p2a, p2b, p2c, p2d};
			// Capture reference and DUT outputs
			first_mismatch_ref_output_packed = {p1y_ref, p2y_ref};
			first_mismatch_dut_output_packed = {p1y_dut, p2y_dut};
		end
	end

	final begin
		if (stats1.errors > 0) begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
			if (first_error_time != -1) begin
				$display("\n--- FIRST MISMATCH DETAILS (Time: %0d ps) ---", first_error_time);
				$display("Inputs: p1a=%b, p1b=%b, p1c=%b, p1d=%b, p2a=%b, p2b=%b, p2c=%b, p2d=%b (HEX: %h)",
					first_mismatch_input_p1a, first_mismatch_input_p1b, first_mismatch_input_p1c, first_mismatch_input_p1d,
					first_mismatch_input_p2a, first_mismatch_input_p2b, first_mismatch_input_p2c, first_mismatch_input_p2d, first_mismatch_input_packed);
				$display("Expected Outputs (Ref): %b (HEX: %h)", first_mismatch_ref_output_packed, first_mismatch_ref_output_packed);
				$display("Actual Outputs (DUT): %b (HEX: %h)", first_mismatch_dut_output_packed, first_mismatch_dut_output_packed);
			end
		
		// Detailed individual output mismatch reporting if they occurred
		if (stats1.errors_p1y > 0) begin
			$display("\nIndividual Output p1y Mismatch: %0d times. First mismatch at time %0d.", stats1.errors_p1y, stats1.errortime_p1y);
			$display("  Input State: %b (HEX: %h)", first_mismatch_input_packed, first_mismatch_input_packed);
			$display("  Expected: %b, Got: %b", first_mismatch_ref_output_packed[0], first_mismatch_dut_output_packed[0]);
		end
		if (stats1.errors_p2y > 0) begin
			$display("\nIndividual Output p2y Mismatch: %0d times. First mismatch at time %0d.", stats1.errors_p2y, stats1.errortime_p2y);
			$display("  Input State: %b (HEX: %h)", first_mismatch_input_packed, first_mismatch_input_packed);
			$display("  Expected: %b, Got: %b", first_mismatch_ref_output_packed[1], first_mismatch_dut_output_packed[1]);
		end
		
		$display("Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		if (stats1.errors == 0) begin
			$display("SIMULATION PASSED");
		end
		$display("Simulation finished at %0d ps", $time);
		$finish;
	end

	// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.
	assign tb_match = ( { p1y_ref, p2y_ref } === ( { p1y_ref, p2y_ref } ^ { p1y_dut, p2y_dut } ^ { p1y_ref, p2y_ref } ) );
	// Use explicit sensitivity list here. @(*) causes NetProc::nex_input() to be called when trying to compute
	// the sensitivity list of the @(strobe) process, which isn't implemented.
	always @(posedge clk, negedge clk) begin

		stats1.clocks++;
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			sstats1.errors++;
		end
		if (p1y_ref !== ( p1y_ref ^ p1y_dut ^ p1y_ref ))
		begin if (stats1.errors_p1y == 0) stats1.errortime_p1y = $time;
			sstats1.errors_p1y = stats1.errors_p1y+1'b1; end
		if (p2y_ref !== ( p2y_ref ^ p2y_dut ^ p2y_ref ))
		begin if (stats1.errors_p2y == 0) stats1.errortime_p2y = $time;
			sstats1.errors_p2y = stats1.errors_p2y+1'b1; end
		end

	// add timeout after 100K cycles
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

endmodule

