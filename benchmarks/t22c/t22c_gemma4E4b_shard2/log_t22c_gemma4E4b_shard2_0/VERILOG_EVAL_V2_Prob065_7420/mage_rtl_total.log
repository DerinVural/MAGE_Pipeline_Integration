		if (stats1.errors_p1y > 0) begin
			$display("\nIndividual Output p1y Mismatch: %0d times. First mismatch at time %0d.", stats1.errors_p1y, stats1.errortime_p1y);
			$display("  Input State: %b (HEX: %h)", first_mismatch_input_packed, first_mismatch_input_packed);
			$display("  Expected: %b, Got: %b", first_mismatch_ref_output_packed[0], first_mismatch_dut_output_packed[0]);
