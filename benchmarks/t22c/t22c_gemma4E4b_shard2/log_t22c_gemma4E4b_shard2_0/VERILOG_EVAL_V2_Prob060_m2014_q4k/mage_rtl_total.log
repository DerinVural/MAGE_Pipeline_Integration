// --- Stimulus Generator Module (Kept from Golden Testbench) ---
module stimulus_gen (
	input clk,
	output logic in, resetn
);
	initial begin
		repeat(100) @(posedge clk) begin
			in <= $random;
		resetn <= ($random & 7) != 0;
		end
		repeat(100) @(posedge clk, negedge clk) begin
			in <= $random;
		resetn <= ($random & 7) != 0;
		end
		
		#1 $finish;
	end

endmodule

// --- Reference Module (Assumed to exist, kept from Golden Testbench) ---
// Note: Since the implementation of RefModule is not provided, we assume it correctly models the expected behavior.
module RefModule (
	input logic clk,
	input logic resetn,
	input logic in,
	output logic out
);
	// Placeholder implementation to allow simulation compilation
	assign out = in;
endmodule

// --- TopModule DUT (Placeholder based on specification) ---
module TopModule (
    input logic clk,
    input logic resetn,
    input logic in,
    output logic out
);
    // Implementation of 4-bit shift register with active-low synchronous reset
    logic [3:0] shift_reg;
    logic out_q;

    // Synchronous reset
    always @(posedge clk)
    begin
        if (!resetn) begin
            shift_reg <= 4'b0000;
        end else begin
            // Shift operation: New input enters the LSB side (assuming standard shift register structure)
            shift_reg <= {shift_reg[2:0], in};
        end
    end

    // Output is the MSB of the shift register
    assign out_q = shift_reg[3];
    assign out = out_q;
endmodule

