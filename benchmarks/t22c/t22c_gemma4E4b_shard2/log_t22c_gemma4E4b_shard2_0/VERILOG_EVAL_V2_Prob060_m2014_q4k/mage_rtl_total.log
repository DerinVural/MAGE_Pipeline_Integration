        .resetn, 
        .in, 
        .out(out_dut) 
    );

    
    bit strobe = 0;
    task wait_for_end_of_timestep;
        repeat(5) begin
            strobe <= !strobe;  // Try to delay until the very end of the time step.
            @(strobe);
        end
    endtask


    // --- Queue Management and Detailed Mismatch Display (Sequential Logic) ---
    always @(posedge clk, negedge clk) begin
        // Reset queue/stats on reset if necessary, but maintaining original structure for now.
        
