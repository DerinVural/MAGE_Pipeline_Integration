.delete(0);\n            reset_queue.delete(0);\n        end\n\n        // Check for first mismatch (Original logic + Queue check)\n        if (!tb_match) begin\n            // Original Error Counting Logic\n            if (stats1.errors == 0) stats1.errortime = $time;\n            stats1.errors++;\n        \n            // Queue Display Trigger (Only display once on the first mismatch)\n            if (stats1.errors == 1) begin\n                $display(\"==================================================================\");\n                $display(\"!!! DETAILED MISMATCH REPORT TRIGGERED AT TIME %0t !!!\", $time);\n                $display(\"Queue Size: %0d (Max: %0d)\", input_queue.size(), MAX_QUEUE_SIZE);\n\n                for (int i = 0; i < input_queue.size(); i++) begin\n                    // Check mismatch between DUT and Golden for this cycle in the queue\n                    if (got_output_queue[i] !== golden_queue[i]) begin\n                        $display(\"\\n--- MISMATCH DETECTED AT CYCLE %0d ---\", i);\n                        $display(\"Time: %0t ps\", $time - (input_queue.size() - 1 - i) * 10); // Approximate time based on queue history\n                        $display(\"Reset: %b, Input: %b, Got Output: %b, Expected Output: %b\",\n                            reset_queue[i], input_queue[i], got_output_queue[i], golden_queue[i]);\n                    end\n                }\n                $display(\"==================================================================\");\n            end\n        end\n\n        // Original second error count check (kept for exact functionality preservation)\n        if (out_ref !== ( out_ref ^ out_dut ^ out_ref ))\n        begin \n            if (stats1.errors_out == 0) stats1.errortime_out = $time;\n            stats1.errors_out = stats1.errors_out+1'b1; \n        end\n    end\n\n    // Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.\n    assign 