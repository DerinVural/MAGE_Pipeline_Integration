module tb();

    typedef struct packed {
        int errors;
        int errortime;
        int errors_out;
        int errortime_out;

        int clocks;
    } stats;
    
    stats stats1;
    
    
    wire[511:0] wavedrom_title;
    wire wavedrom_enable;
    int wavedrom_hide_after_time;
    
    reg clk=0;
    initial forever
        #5 clk = ~clk;

    logic resetn;
    logic in;
    logic out_ref; // Golden Output
    logic out_dut; // DUT Output

    // Queue signals for detailed mismatch tracking
    reg input_queue [$];
    reg got_output_queue [$];
    reg golden_queue [$];
    reg reset_queue [$];

    localparam MAX_QUEUE_SIZE = 10; // Max 10 as per requirement

    initial begin 
        $dumpfile("wave.vcd");
        $dumpvars(1, stimulus_gen::stim1, tb);
    end


    wire tb_match;
    wire tb_mismatch = ~tb_match;
    
    // Instantiate stimulus generator
    stimulus_gen stim1 (
        .clk, // Not used by stimulus_gen, but matching original instantiation format
        .* , // Wildcard assignment from original testbench
        .resetn, 
        .in 
    );
    
    // Instantiate Reference Module
    RefModule good1 (
        .clk, 
        .resetn, 
        .in, 
        .out(out_ref) 
    );
        
    // Instantiate DUT
    TopModule top_module1 (
        .clk, 
        .resetn, 
        .in, 
        .out(out_dut) 
    );

    
    bit strobe = 0;
    task wait_for_end_of_timestep;
        repeat(5) begin
            strobe <= !strobe;  // Try to delay until the very end of the time step.
            @(strobe);
        end
    endtask


    // --- Queue Management and Detailed Mismatch Display (Sequential Logic) ---
    always @(posedge clk, negedge clk) begin
        // Reset queue/stats on reset if necessary, but maintaining original structure for now.
        
        stats1.clocks++;
        
        // Update Queue
        input_queue.push_back(in);
        got_output_queue.push_back(out_dut);
        golden_queue.push_back(out_ref);
        reset_queue.push_back(resetn);

        // Maintain queue size
        if (input_queue.size() >= MAX_QUEUE_SIZE) begin
            input_queue.delete(0);
            got_output_queue.delete(0);
            golden_queue.delete(0);
            reset_queue.delete(0);
        end

        // Check for first mismatch (Original logic + Queue check)
        if (!tb_match) begin
            // Original Error Counting Logic
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
        
            // Queue Display Trigger (Only display once on the first mismatch)
            if (stats1.errors == 1) begin
                $display("==================================================================");
                $display("!!! DETAILED MISMATCH REPORT TRIGGERED AT TIME %0t !!!", $time);
                $display("Queue Size: %0d (Max: %0d)", input_queue.size(), MAX_QUEUE_SIZE);

                for (int i = 0; i < input_queue.size(); i++) begin
                    // Check mismatch between DUT and Golden for this cycle in the queue
                    if (got_output_queue[i] !== golden_queue[i]) begin
                        $display("\n--- MISMATCH DETECTED AT CYCLE %0d ---", i);
                        $display("Time: %0t ps", $time - (input_queue.size() - 1 - i) * 10); // Approximate time based on queue history
                        $display("Reset: %b, Input: %b, Got Output: %b, Expected Output: %b",
                            reset_queue[i], input_queue[i], got_output_queue[i], golden_queue[i]);
                    end
                }
                $display("==================================================================");
            end
        end

        // Original second error count check (kept for exact functionality preservation)
        if (out_ref !== ( out_ref ^ out_dut ^ out_ref ))
        begin 
            if (stats1.errors_out == 0) stats1.errortime_out = $time;
            stats1.errors_out = stats1.errors_out+1'b1; 
        end
    end

    // Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.
    assign tb_match = ( { out_ref } === ( { out_ref } ^ { out_dut } ^ { out_ref } ) );

   // add timeout after 100K cycles
   initial begin
     #1000000
     $display("\n--- TIMEOUT REACHED ---\n");
     $finish();
   end


    // Final reporting block - Updated to meet final display requirements
    final begin
        $display("\n==================================================================");
        $display("SIMULATION SUMMARY");
        $display("Total Cycles Simulated: %0d", stats1.clocks);
        $display("Original Mismatches (stats1.errors): %0d", stats1.errors);
        $display("Original Mismatch Time (stats1.errortime): %0d", stats1.errortime);
        $display("Secondary Mismatches (stats1.errors_out): %0d", stats1.errors_out);
        $display("Secondary Mismatch Time (stats1.errortime_out): %0d", stats1.errortime_out);
        $display("==================================================================");

        if (stats1.errors == 0 && stats1.errors_out == 0) begin
            $display("SIMULATION PASSED");
        end else begin
            // Use stats1.errors and stats1.errortime as the primary error indicator
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
        end
    end

endmodule
