        // DFF 1: Q1 <= (x AND NOT Q1)
        q1 <= d1_next;
        
        // DFF 2: Q2 <= (x OR NOT Q2)
        q2 <= d2_next;
    end

    // --- 3. Combinational Logic Calculation ---
    always @* begin
        // Calculate complements
        q0_n = ~q0;
        q1_n = ~q1;
        q2_n = ~q2;

