_ref; // Golden Reference Output\n    logic z_dut; // DUT Output\n    logic reset_n = 1'b1; // Assuming active low reset based on FSM description\n\n    // Queue-based simulation mismatch display variables\n    reg [INPUT_WIDTH-1:0] input_queue [$];\n    reg [OUTPUT_WIDTH-1:0] got_output_queue [$];\n    reg [OUTPUT_WIDTH-1:0] golden_queue [$];\n    reg reset_queue [$];\n\n    // Counters\n    int errors = 0;\n    int first_error_time = 0;\n    int total_samples = 0;\n\n    // Task to handle signal formatting for display (HEX/BIN)\n    task display_signal(input logic signal, input string name);\n        $write(\"%-15s: \", name);\n        if (signal.get_byte_width() <= 64) begin\n            $write(\"BIN: %b, HEX: %h \", signal, signal);\n        end else begin\n            $write(\"HEX: %h \", signal);\n        end\n    endtask\n\n    // Task to print queue content upon first mismatch\n    task print_mismatch_queue;\n        $display(\"\\n========================================================================\");\n        $display(\"Mismatch detected at time %0t ps\", $time);\n        $display(\"\\nLast %0d cycles of simulation:\", input_queue.size());\n        $display(\"========================================================================\");\n\n        for (int i = 0; i < input_queue.size(); i++) begin\n            // Check if the mismatch occurred at this specific cycle i\n            if (got_output_queue[i] !== golden_queue[i]) begin\n                $display(\"\\n*** MISMATCH DETECTED AT CYCLE %0d (Time %0t ps) ***\", i, $time - (i * 10)); // Approximation of time\n                $display(\"\\nCycle %0d | Reset: %b | Input (x): %h | Got Output (z_dut): %h | Expected Output (z_ref): %h\",\n                    i, reset_queue[i], input_queue[i], got_output_queue[i], golden_queue[i]);\n            end else begin\n                $display(\"Cycle %0d | Reset: %b | Input (x): %h | Got Output (z_dut): %h | Expected Output (z_ref): %h (MATCH)\",\n                    i, reset_queue[i], input_queue[i], got_output_queue[i], golden_queue[i]);\n            end\n        end\n        $display(\"========================================================================\");\n    endtask\n\n    // --- Initialization and Dumping --- \n    initial begin \n        $dumpfile(\"wave.vcd\");\n        // Dumping all relevant signals\n        $dumpvars(1, tb);\n\n        // Initialize inputs\n        x = 0;\n        reset_n = 0; // Assert reset initially\n\n        // Initialize reference and DUT outputs\n        z_ref = 0;\n        z_dut = 0;\n\n        // Wait for initial reset to settle (e.g., 2 clock cycles)\n        @(posedge clk);\n        @(posedge clk);\n        \n        // Deassert reset\n        reset_n = 1;\n        $display(\"--- Simulation Started. Reset Deasserted at Time %0t ---\", $time);\n    end\n\n    // --- Instantiations --- \n    stimulus_gen stim1 (\n        .clk, .x, .wavedrom_title, .wavedrom_enable\n    );\n    RefModule good1 (\n        .clk, .x, .z(z_ref) \n    );\n    TopModule top_module1 (\n        .clk, .x, .z(z_dut) \n    );\n\n    // --- Wait Task (Copied from golden testbench) ---\n    bit strobe = 0;\n    task wait_for_end_of_timestep;\n        repeat(5) begin\n            strobe <= !strobe;  // Try to delay until the very end of the time step.\n            @(strobe);\n        end\n    endtask\n\n    // --- Verification Logic (Queueing and Mismatch Detection) ---\n    always @(posedge clk, negedge clk)\n    begin\n        if (!reset_n)\n        begin\n            // Hold queue/signals during reset if necessary, but for simplicity, we only push data when not resetting.\n        end else begin\n            // 1. Update statistics\n            total_samples++;\n\n            // 2. Push current state to queues (must happen before checking mismatch to include current cycle)\n            input_queue.push_back(x);\n            got_output_queue.push_back(z_dut);\n            golden_queue.push_back(z_ref);\n        