d\n        $display(\"========================================================================\");\n    end\n\n    // add timeout after 100K cycles (maintaining original functionality)\n    initial begin\n      #1000000\n      if (errors == 0)\n        $display(\"TIMEOUT REACHED. All samples matched until timeout.\");\n      else\n        $display(\"TIMEOUT REACHED. Mismatch count: %0d\", errors);\n      $finish();\n    end\n\nendmodule"
