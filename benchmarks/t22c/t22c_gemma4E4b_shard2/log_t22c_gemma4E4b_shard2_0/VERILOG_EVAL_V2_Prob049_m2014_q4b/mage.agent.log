	typedef struct packed {
		int errors;
		int errortime;
		int errors_q;
		int errortime_q;
		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic d;
	logic ar;
	logic q_ref;
	logic q_dut;

	// --- Queue Declarations for Improved Logging ---
	// Since signals are 1-bit, widths are 1
	reg input_queue [0:0] [$]; 
	reg got_output_queue [0:0] [$];
	reg golden_queue [0:0] [$];
	reg reset_queue [0:0] [$];

	localparam MAX_QUEUE_SIZE = 5;
	
	// Variables to track first mismatch for queue display
	reg mismatch_detected_in_queue = 0;

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch, clk, d, ar, q_ref, q_dut );
	end


	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk, 
		.d, 
		.ar );
		
	RefModule good1 (
		.clk,
		.d,
		.ar,
		.q(q_ref) );
		
	TopModule top_module1 (
		.clk,
		.d,
		.ar,
		.q(q_dut) );


	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
			strobe <= !strobe;  // Try to delay until the very end of the time step.
			@(strobe);
		end
	endtask

	// --- Queue Logging and Mismatch Check --- 
	always @(posedge clk, negedge clk) begin
		stats1.clocks++;

		// 1. Queue Management
		if (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin
			input_queue.delete(0);
			got_output_queue.delete(0);
			golden_queue.delete(0);
			reset_queue.delete(0);
		end

		// Store current state
		input_queue.push_back(d);
		reset_queue.push_back(ar);
		got_output_queue.push_back(q_dut);
		golden_queue.push_back(q_ref);

		// 2. Mismatch Detection (Original Logic)
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
		end

		// Second mismatch tracking (Original Logic)
		if (q_ref !== ( q_ref ^ q_dut ^ q_ref ))
		begin 
			if (stats1.errors_q == 0) stats1.errortime_q = $time;
			sstats1.errors_q = stats1.errors_q+1'b1; 
		end

		// 3. Queue-based mismatch detection and logging
		if (!tb_match && !mismatch_detected_in_queue) begin
			mismatch_detected_in_queue = 1;
			$display("\n========================================================================");
			$display("QUEUE-BASED MISMATCH DETECTED AT TIME %0t", $time);
			$display("\nLast %0d cycles of simulation (Up to MAX_QUEUE_SIZE):", input_queue.size());

			for (int i = 0; i < input_queue.size(); i++) begin
				if (got_output_queue[i] === golden_queue[i]) begin
				$display("Cycle %0d: Status: Match", i);
				$display("  Inputs: ar=%b, d=%b | Got Q: %b | Exp Q: %b", 
					reset_queue[i], input_queue[i], got_output_queue[i], golden_queue[i]);
				
				// Displaying in Hex/Bin if width <= 64 (All are 1-bit, so this is trivial)
				$display("  (Hex: Got=%h, Exp=%h)", got_output_queue[i], golden_queue[i]);
			end else begin
				$display("Cycle %0d: Status: MISMATCH", i);
				$display("  Inputs: ar=%b, d=%b | Got Q: %b | Exp Q: %b", 
					reset_queue[i], input_queue[i], got_output_queue[i], golden_queue[i]);
				$display("  (Hex: Got=%h, Exp=%h)", got_output_queue[i], golden_queue[i]);
			end
			end
			$display("========================================================================\n");
		end
		
	end


	// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.
	assign tb_match = ( { q_ref } === ( { q_ref } ^ { q_dut } ^ { q_ref } ) );


	// add timeout after 100K cycles
	initial begin
		#1000000
		$display("\n--- TIMEOUT REACHED ---");
		$finish();
	end

	// Final summary based on original error counters
	final begin
		if (stats1.errors_q) $display("Hint: Output 'q' has %0d mismatches (specific check). First mismatch occurred at time %0d.", stats1.errors_q, stats1.errortime_q);
	else $display("Hint: Output 'q' has no mismatches (specific check).");

	$display("\n=====================================================");
	$display("Final Summary: Total mismatched samples is %0d out of %0d samples.", stats1.errors, stats1.clocks);

	if (stats1.errors == 0) begin
		$display("SIMULATION PASSED");
	end else begin
		$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
	end
	$display("Simulation finished at %0d ps", $time);
	$display("=====================================================");
	
endmodule

