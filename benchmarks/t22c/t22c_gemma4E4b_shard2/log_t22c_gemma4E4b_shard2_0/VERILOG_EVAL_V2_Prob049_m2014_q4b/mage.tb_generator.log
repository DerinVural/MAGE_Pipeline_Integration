tate\n\t\tinput_queue.push_back(d);\n\t\treset_queue.push_back(ar);\n\t\tgot_output_queue.push_back(q_dut);\n\t\tgolden_queue.push_back(q_ref);\n\n\t\t// 2. Mismatch Detection (Original Logic)\n\t\tif (!tb_match) begin\n\t\t\tif (stats1.errors == 0) stats1.errortime = $time;\n\t\t\tstats1.errors++;\n\t\tend\n\n\t\t// Second mismatch tracking (Original Logic)\n\t\tif (q_ref !== ( q_ref ^ q_dut ^ q_ref ))\n\t\tbegin \n\t\t\tif (stats1.errors_q == 0) stats1.errortime_q = $time;\n\t\t\tsstats1.errors_q = stats1.errors_q+1'b1; \n\t\tend\n\n\t\t// 3. Queue-based mismatch detection and logging\n\t\tif (!tb_match && !mismatch_detected_in_queue) begin\n\t\t\tmismatch_detected_in_queue = 1;\n\t\t\t$display(\"\\n========================================================================\");\n\t\t\t$display(\"QUEUE-BASED MISMATCH DETECTED AT TIME %0t\", $time);\n\t\t\t$display(\"\\nLast %0d cycles of simulation (Up to MAX_QUEUE_SIZE):\", input_queue.size());\n\n\t\t\tfor (int i = 0; i < input_queue.size(); i++) begin\n\t\t\t\tif (got_output_queue[i] === golden_queue[i]) begin\n\t\t\t\t$display(\"Cycle %0d: Status: Match\", i);\n\t\t\t\t$display(\"  Inputs: ar=%b, d=%b | Got Q: %b | Exp Q: %b\", \n\t\t\t\t\treset_queue[i], input_queue[i], got_output_queue[i], golden_queue[i]);\n\t\t\t\t\n\t\t\t\t// Displaying in Hex/Bin if width <= 64 (All are 1-bit, so this is trivial)\n\t\t\t\t$display(\"  (Hex: Got=%h, Exp=%h)\", got_output_queue[i], golden_queue[i]);\n\t\t\tend else begin\n\t\t\t\t$display(\"Cycle %0d: Status: MISMATCH\", i);\n\t\t\t\t$display(\"  Inputs: ar=%b, d=%b | Got Q: %b | Exp Q: %b\", \n\t\t\t\t\treset_queue[i], input_queue[i], got_output_queue[i], golden_queue[i]);\n\t\t\t\t$display(\"  (Hex: Got=%h, Exp=%h)\", got_output_queue[i], golden_queue[i]);\n\t\t\tend\n\t\t\tend\n\t\t\t$display(\"========================================================================\\n\");\n\t\tend\n\t\t\n\tend\n\n\n\t// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.\n\tassign tb_match = ( { q_ref } === ( { q_ref } ^ { q_dut } ^ { q_ref } ) );\n\n\n\t// add timeout after 100K cycles\n\tinitial begin\n\t\t#1000000\n\t\t$display(\"\\n--- TIMEOUT REACHED ---\");\n\t\t$finish();\n\tend\n\n\t// Final summary based on original error counters\n\tfinal begin\n\t\tif (stats1.errors_q) $display(\"Hint: Output 'q' has %0d mismatches (specific check). First mismatch occurred at time %0d.\", stats1.errors_q, stats1.errortime_q);\n\telse $display(\"Hint: Output 'q' has no mismatches (specific check).\");\n\n\t$display(\"\\n=====================================================\");\n\t$display(\"Final Summary: Total mismatched samples is %0d out of %0d samples.\", stats1.errors, stats1.clocks);\n\n\tif (stats1.errors == 0) begin\n\t\t$display(\"SIMULATION PASSED\");\n\tend else begin\n\t\t$display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\", stats1.errors, stats1.errortime);\n\tend\n\t$display(\"Simulation finished at %0d ps\", $time);\n\t$display(\"=====================================================\");\n\t\nendmodule\n\n// Dummy RefModule definition required for compilation as it was in the golden TB\nmodule RefModule (input clk, input d, input ar, output logic q);\n\t// Simplified behavior for compilation, assuming it matches TopModule\n\talways @(posedge clk or negedge ar) begin\n\t\tif (!ar) q <= 1'b0;\n\t\telse q <= d;\n\tend\nendmodule\n"
