	end
	
endmodule

module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_q;
		int errortime_q;

		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		h#5 clk = ~clk;

	logic [7:0] d;
	logic reset;
	logic [7:0] q_ref;
	logic [7:0] q_dut;

	// --- Queue Implementation for Mismatch Logging ---
	// Since TopModule is sequential, we use queues for history.
	reg [7:0] d_queue [$];
	reg [7:0] q_dut_queue [$];
	reg [7:0] q_ref_queue [$];
	reg reset_queue [$];

	localparam MAX_QUEUE_SIZE = 9; // Max 10, chosen based on data width 8
	
	int error_count_q_flag = 0; // Flag to track if the first queue mismatch has been logged
	
	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stimulus_gen.stim1.clk, tb_mismatch ,clk,d,reset,q_ref,q_dut );
	end

	
	wire tb_match;        // Verification
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk, 
		.* , 
		d, 
		.reset );
	RefModule good1 (
		.clk,
		d,
		.reset,
		.q(q_ref) );
	
	TopModule top_module1 (
		.clk,
		d,
		.reset,
		.q(q_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		endtask	

	// --- Synchronous Mismatch Checking and Queue Management ---
	always @(posedge clk, negedge clk) begin

		stats1.clocks++;

		// 1. Push current cycle data to queues
		d_queue.push_back(d);
		q_dut_queue.push_back(q_dut);
		q_ref_queue.push_back(q_ref);
		reset_queue.push_back(reset);

		// 2. Manage Queue Size
		if (d_queue.size() >= MAX_QUEUE_SIZE) begin
		d_queue.delete(0);
		q_dut_queue.delete(0);
		q_ref_queue.delete(0);
		reset_queue.delete(0);
		end

		// 3. Check for Mismatches
		
		// Check 1: Overall verification mismatch (tb_mismatch)
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			sstats1.errors++;
			
			// Check if this is the first error encountered (for queue logging)
			if (error_count_q_flag == 0) begin
				error_count_q_flag = 1;
				stats1.errortime_q = $time;
				$display("======================================================================");
				$display("!!! FIRST MISMATCH DETECTED (Overall Verification) AT TIME %0t !!!", $time);
				$display("Logging last %0d cycles of simulation:", d_queue.size());

				for (int i = 0; i < d_queue.size(); i++) begin
					if (q_ref_queue[i] === q_dut_queue[i]) begin
					$display("Cycle %d: Got Match.", i);
					$display("Cycle %d, reset %b, input %h, got output %h, exp output %h",
					i, reset_queue[i], d_queue[i], q_dut_queue[i], q_ref_queue[i]);
				end else begin
					$display("Cycle %d: Got Mismatch.", i);
					$display("Cycle %d, reset %b, input %h, got output %h, exp output %h",
					i, reset_queue[i], d_queue[i], q_dut_queue[i], q_ref_queue[i]);
				end
				end
				$display("======================================================================");
				break; // Stop logging after the first error event is processed
				
			end
			end

		// Check 2: Specific output comparison mismatch
		if (q_ref !== ( q_ref ^ q_dut ^ q_ref )) 
		begin 
			if (stats1.errors_q == 0) stats1.errortime_q = $time;
			sstats1.errors_q = stats1.errors_q + 1'b1;
			
			// Only log if the overall error hasn't already triggered the comprehensive logging
			if (error_count_q_flag == 0) begin
				error_count_q_flag = 1;
				$display("======================================================================");
				$display("!!! FIRST MISMATCH DETECTED (Specific Output Check) AT TIME %0t !!!", $time);
				$display("Logging last %0d cycles of simulation:", d_queue.size());
				
				for (int i = 0; i < d_queue.size(); i++) begin
					if (q_ref_queue[i] === q_dut_queue[i]) begin
					$display("Cycle %d: Got Match.", i);
					$display("Cycle %d, reset %b, input %h, got output %h, exp output %h",
					i, reset_queue[i], d_queue[i], q_dut_queue[i], q_ref_queue[i]);
				end else begin
					$display("Cycle %d: Got Mismatch.", i);
					$display("Cycle %d, reset %b, input %h, got output %h, exp output %h",
					i, reset_queue[i], d_queue[i], q_dut_queue[i], q_ref_queue[i]);
				end
				end
				$display("======================================================================");
				break;
			end
		end


	// add timeout after 100K cycles
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

	// --- Final Status Check (Replaces original final block) ---
	initial begin
		@(negedge clk);
		#1;
		
		if (stats1.errors == 0 && stats1.errors_q == 0) begin
			$display("SIMULATION PASSED");
		end else begin
			int total_mismatches = stats1.errors + stats1.errors_q;
			int first_error_time = (stats1.errors == 0) ? stats1.errortime_q : stats1.errortime;

			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", total_mismatches, first_error_time);
		end
		$finish();
	end

endmodule
