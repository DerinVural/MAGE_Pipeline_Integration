module stimulus_gen:\\n\\t//    output [511:0] wavedrom_title\\n\\t//    output reg wavedrom_enable\\n\\n\\ttask wavedrom_start(input[511:0] title = \\"\\");\\n\\tendtask\\n\\t\\n\\ttask wavedrom_stop;\\n\\t\\th#1;\\n\\tendtask\\n\\t\\n\\tinitial begin\\n\\t\\t@(negedge clk) wavedrom_start(\\"Priority encoder\\");\\n\\t\\t@(posedge clk) in <= 8\'h1;\\n\\t\\trepeat(8) @(posedge clk) in <= in << 1;\\n\\t\\tin <= 8\'h10;\\n\\t\\trepeat(8) @(posedge clk) in <= in + 1;\\n\\t\\t@(negedge clk) wavedrom_stop();\\n\\n\\t\\trepeat(50) @(posedge clk, negedge clk) begin\\n\\t\\tin <= $urandom;\\n\\t\\tend\\n\\t\\trepeat(260) @(posedge clk, negedge clk) begin\\n\\t\\tin <= in + 1;\\n\\t\\tend\\n\\t\\t$finish;\\n\\tend\\n\\tendmodule\\n\\nmodule tb();\\n\\n\\ttypedef struct packed {\\n\\t\\tint errors;\\n\\t\\tint errortime;\\n\\t\\tint errors_pos;\\n\\t\\tint errortime_pos;\\n\\t\\tint clocks;\\n\\t\\tlogic [7:0] in_at_first_error;\\n\\t\\tlogic [2:0] pos_dut_at_first_error;\\n\\t\\tlogic [2:0] pos_ref_at_first_error;\\n\\t} stats;\\n\\t\\n\\tstats stats1;\\n\\t\\n\\t\\n\\twire[511:0] wavedrom_title;\\n\\twire wavedrom_enable;\\n\\tint wavedrom_hide_after_time;\\n\\t\\n\\treg clk=0;\\n\\tinitial forever\\n\\t\\th#5 clk = ~clk;\\n\\n\\tlogic [7:0] in;\\n\\tlogic [2:0] pos_ref;\\n\\tlogic [2:0] pos_dut;\\n\\n\\t// Variables to hold signals at first error\\n\\tlogic [7:0] in_snap;\\n\\tlogic [2:0] pos_dut_snap;\\n\\tlogic [2:0] pos_ref_snap;\\n\\n\\tinitial begin \\n\\t\\t$dumpfile(\\"wave.vcd\\");\\n\\t\\t$dumpvars(1, stimulus_gen.stim1.clk, tb_mismatch, in, pos_ref, pos_dut );\\n\\tend\\n\\n\\t\\n\\twire tb_match;        // Verification\\n\\twire tb_mismatch = ~tb_match;\\n\\t\\n\\tstimulus_gen stim1 (\\n\\t\\t.clk, \\n\\t\\t.in, \\n\\t\\t.wavedrom_title, \\n\\t\\t.wavedrom_enable\\n\\t);\\n\\tRefModule good1 (\\n\\t\\tin, \\n\\t\\t.pos(pos_ref) );\\n\\t\\n\\tTopModule top_module1 (\\n\\t\\tin, \\n\\t\\t.pos(pos_dut) );\\n\\n\\t\\n\\tbit strobe = 0;\\n\\ttask wait_for_end_of_timestep;\\n\\t\\trepeat(5) begin\\n\\t\\tstrobe <= !strobe;  // Try to delay until the very end of the time step.\\n\\t\\t@(strobe);\\n\\t\\tend\\ntask wait_for_end_of_timestep;\\n\\t\\tendtask\\n\\t\\n\\t\\n\\t// Helper task for detailed error display\\n\\ttask display_error_details;\\n\\t\\tinput integer time_val;\\n\\t\\tinput logic [7:0] in_val;\\n\\t\\tinput logic [2:0] pos_dut_val;\\n\\t\\tinput logic [2:0] pos_ref_val;\\n\\t\\t\\n\\t\\t$display(\\"\\\\n----------------------------------------------------------------------\\");\\n\\t\\t$display(\\"!!! FIRST MISMATCH DETECTED AT TIME: %0d ps !!!\\", time_val);\\n\\t\\t$display(\\"----------------------------------------------------------------------\\");\\n\\t\\t$display(\\"Input Signal (in):\\");\\n\\t\\t$display(\\"  HEX: %h\\", in_val);\\n\\t\\t$display(\\"  BIN: %b\\", in_val);\\n\\t\\t$display(\\"Expected Output (pos_ref):\\");\\n\\t\\t$display(\\"  HEX: %h\\", pos_ref_val);\\n\\t\\t$display(\\"  BIN: %b\\", pos_ref_val);\\n\\t\\t$display(\\"Actual Output (pos_dut):\\");\\n\\t\\t$display(\\"  HEX: %h\\", pos_dut_val);\\n\\t\\t$display(\\"  BIN: %b\\", pos_dut_val);\\n\\t\\t$display(\\"======================================================================", \n            "\\");\\n\\tendtask\\n\\t\\n\\t\\n\\tfinal begin\\n\\t\\tif (stats1.errors == 0) begin\\n\\t\\t\\t$display(\\"SIMULATION PASSED\\");\\n\\t\\tend else begin\\n\\t\\t\\t$display(\\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\\", stats1.errors, stats1.errortime);\\n\\t\\t\\t// Display detailed info for the first mismatch\\n\\t\\tdisplay_error_details(stats1.errortime, in_snap, pos_dut_snap, pos_ref_snap);\\n\\t\\tend\\n\\tend\\n\\t\\n\\t// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.\\n\\tassign tb_match = ( { pos_ref } === ( { pos_ref } ^ { pos_dut } ^ { pos_ref } ) );\\n\\t// Use explicit sensitivity list here.\\n\\talways @(posedge clk, negedge clk) begin\\n\\t\\t\\n\\t\\tstats1.clocks++;\\n\\t\\t\\n\\t\\t// --- General Mismatch Tracking ---\\n\\t\\tif (!tb_match) begin\\n\\t\\t\\tif (stats1.errors == 0) stats1.errortime = $time;\\n\\t\\t\\tsstats1.errors++;\\n\\t\\tend\\n\\t\\t// Snap signals only on the *first* mismatch\\n\\t\\tif (stats1.errors == 1) begin\\n\\t\\t\\tin_snap <= in;\\n\\t\\t\\tpos_dut_snap <= pos_dut;\\n\\t\\t\\tpos_ref_snap <= pos_ref;\\n\\t\\tend\\n\\t\\t\\n\\t\\t// --- POS Specific Mismatch Tracking ---\\n\\t\\tif (pos_ref !== ( pos_ref ^ pos_dut ^ pos_ref ))\\n\\t\\tbegin \\n\\t\\t\\tif (stats1.errors_pos == 0) stats1.errortime_pos = $time;\\n\\t\\t\\tsstats1.errors_pos = stats1.errors_pos+1\'b1;\\n\\t\\tend\\n\\t\\t// Snap signals only on the *first* pos mismatch\\n\\t\\tif (stats1.errors_pos == 1) begin\\n\\t\\t\\tin_snap <= in;\\n\\t\\t\\tpos_dut_snap <= pos_dut;\\n\\t\\t\\tpos_ref_snap <= pos_ref;\\n\\t\\tend\\n\\tend\\n\\n\\t// add timeout after 100K cycles\\n\\tinitial begin\\n\\t\\th#1000000\\n\\t\\t$display(\\"\\\\n--- TIMEOUT REACHED ---\\");\\n\\t\\tf$finish();\\n\\tend\\n\\nendmodule\\n"\n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n  \n 