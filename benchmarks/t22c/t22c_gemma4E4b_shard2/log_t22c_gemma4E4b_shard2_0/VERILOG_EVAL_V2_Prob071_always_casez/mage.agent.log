	typedef struct packed {
		int errors;
		int errortime;
		int errors_pos;
		int errortime_pos;

		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire [511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		h#5 clk = ~clk;

	logic [7:0] in;
	logic [2:0] pos_ref;
	logic [2:0] pos_dut;

	// Variables to store first mismatch data for combinational check
	logic [7:0] first_mismatch_in; 
	logic [2:0] first_mismatch_pos_dut; 
	logic [2:0] first_mismatch_pos_ref; 
	integer first_mismatch_detected = 0;

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,in,pos_ref,pos_dut );
	end


	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk,
		.* , 
		.in );
	RefModule good1 (
		.in,
		.pos(pos_ref) );
	
	TopModule top_module1 (
		.in,
		.pos(pos_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		endtask	

	// New logic to capture and display first mismatch for combinational DUT
	always @(posedge clk, negedge clk) begin
		if (!tb_match && first_mismatch_detected == 0) begin
			stats1.errortime = $time;
			stats1.errors = 1; // Mark as first error
			stats1.errortime_pos = $time;
			
			// Capture signals at mismatch time
			first_mismatch_in = in;
			first_mismatch_pos_dut = pos_dut;
			first_mismatch_pos_ref = pos_ref;
			first_mismatch_detected = 1;
		end

		stats1.clocks++;
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			sstats1.errors++;
		end

		if (pos_ref !== ( pos_ref ^ pos_dut ^ pos_ref ))
		begin 
			if (stats1.errors_pos == 0) stats1.errortime_pos = $time;
			sstats1.errors_pos = stats1.errors_pos+1'b1; 
		end
		end

	
	// Final check and display
	final begin
		if (stats1.errors_pos) begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d.", stats1.errors_pos, stats1.errortime_pos);
			$display("--- First Pos Mismatch Details ---");
			$display("Time of First Pos Mismatch: %0d ps", stats1.errortime_pos);
			$display("Input (in): %h (%b)", first_mismatch_in, first_mismatch_in);
			$display("Reference Output (pos_ref): %h (%b)", first_mismatch_pos_ref, first_mismatch_pos_ref);
			$display("DUT Output (pos_dut): %h (%b)", first_mismatch_pos_dut, first_mismatch_pos_dut);
		end
		if (stats1.errors > 0) begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d.", stats1.errors, stats1.errortime);
			$display("--- First General Mismatch Details (Last cycle recorded) ---");
			$display("Time of First General Mismatch: %0d ps", stats1.errortime);
			$display("Input (in): %h (%b)", in, in);
			$display("Reference Output (pos_ref): %h (%b)", pos_ref, pos_ref);
			$display("DUT Output (pos_dut): %h (%b)", pos_dut, pos_dut);
		end
		if (stats1.errors == 0 && stats1.errors_pos == 0) begin
			$display("SIMULATION PASSED");
		end
		$display("Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
		$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
	end

	// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.
	assign tb_match = ( { pos_ref } === ( { pos_ref } ^ { pos_dut } ^ { pos_ref } ) );

	// add timeout after 100K cycles
	initial begin
		h#1000000
		$display("TIMEOUT");
		$finish();
	end

endmodule

