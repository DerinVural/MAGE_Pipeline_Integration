			pos_dut_snap <= pos_dut;
			pos_ref_snap <= pos_ref;
	end
	end

	// add timeout after 100K cycles
	initial begin
		h#1000000
		$display("\n--- TIMEOUT REACHED ---");
		f$finish();
	end

endmodule

