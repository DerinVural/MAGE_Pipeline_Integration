// --- Testbench ---
module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_pedge;
		int errortime_pedge;
		int clocks;
	} stats;
	
	stats stats1;
	
	// Queue Definitions based on sequential logic requirements
	localparam MAX_QUEUE_SIZE = 10; // Max size constraint
	reg [7:0] input_queue [MAX_QUEUE_SIZE-1:0];
	reg [7:0] got_output_queue [MAX_QUEUE_SIZE-1:0];
	reg [7:0] golden_queue [MAX_QUEUE_SIZE-1:0];
	// Reset is not explicitly present in DUT interface, but keeping structure for robustness if needed later
	reg [7:0] reset_queue [MAX_QUEUE_SIZE-1:0];

	// Testbench Signals
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		h#5 clk = ~clk;

	logic [7:0] in;
	logic [7:0] pedge_ref;
	logic [7:0] pedge_dut;

	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	// Signals for queue tracking	
	// Queue pointers/indices
	integer queue_head = 0;
	integer queue_tail = 0;
	
	// Instantiate Modules
	stimulus_gen stim1 (
		.clk, 
		.tb_match, 
		.in, 
		.wavedrom_title, 
		.wavedrom_enable
	);
	RefModule good1 (
		.clk, 
		in, 
		pedge_ref
	);
	TopModule top_module1 (
		.clk, 
		in, 
		pedge_dut
	);

	// Wave dumping
	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch, clk, in, pedge_ref, pedge_dut );
	end

	// Task to maintain original timing/flow (Kept as is)
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		endtask

	// Verification Logic (Maintained original logic)
	// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.
	assign tb_match = ( { pedge_ref } === ( { pedge_ref } ^ { pedge_dut } ^ { pedge_ref } ) );

	// =======================================================================
	// SEQUENTIAL LOGIC MISMATCH DETECTION AND QUEUING (Improved) 
	// =======================================================================
	
	always @(posedge clk, negedge clk) begin
		// 1. Update Statistics
		stats1.clocks++;
		
		// 2. Queue Management (Circular Buffer Logic)
		if (queue_tail == MAX_QUEUE_SIZE) begin
			// Buffer is full, overwrite oldest element (Head advances)
			queue_head = (queue_head + 1) % MAX_QUEUE_SIZE;
			// Tail stays where it is, pointing to the next slot to overwrite
			// Since we are overwriting, we don't explicitly delete(0) like in the example, we just overwrite at queue_tail
		end else begin
			// Buffer not full, just advance tail
			queue_tail++;
		end

		// Store current data at the current tail position
		input_queue[queue_tail] = in;
		got_output_queue[queue_tail] = pedge_dut;
		golden_queue[queue_tail] = pedge_ref;
		reset_queue[queue_tail] = 0; // Placeholder

		// Advance tail for next cycle
		queue_tail = (queue_tail + 1) % MAX_QUEUE_SIZE;
		
		// 3. Mismatch Check
		if (!tb_match) begin
			// Update error counters
			if (stats1.errors == 0) stats1.errortime = $time;
			sstats1.errors++;
			end
		
			if (pedge_ref !== ( pedge_ref ^ pedge_dut ^ pedge_ref ))
		begin
			if (stats1.errors_pedge == 0) stats1.errortime_pedge = $time;
			sstats1.errors_pedge = stats1.errors_pedge+1'b1; 
		end
		end

		// 4. First Mismatch Display (Only display upon first error detected)
		if (stats1.errors == 1 && !tb_match) begin
			$display("\n==============================================================");
			$display("!!! FIRST MISMATCH DETECTED AT TIME %0t !!!", $time);
			$display("Queue content showing last %0d cycles:", queue_tail);
			$display("==============================================================");
			
			for (int i = 0; i < queue_tail; i++) begin
				// Check for mismatch at this stored cycle
				if (got_output_queue[i] !== golden_queue[i]) begin
					$display("\n--- Mismatch Found at Cycle %0d (Time %0t) ---", i, $time - (i * 10));
					$display("Input:  %h (Binary: %b)", input_queue[i], input_queue[i]);
					$display("Got Out: %h (Binary: %b)", got_output_queue[i], got_output_queue[i]);
					$display("Exp Out: %h (Binary: %b)", golden_queue[i], golden_queue[i]);
					s$display("------------------------------------------------------");
				end
			end
		end
	end

	// End of sequential logic block

	// Timeout logic (Kept as is)
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

	// Final Simulation Summary (Requirement 4)
	initial begin
		@(negedge clk);
		// Wait a bit to ensure all asynchronous operations settle if any
		#10;
		
		if (stats1.errors == 0 && stats1.errors_pedge == 0) begin
			$display("SIMULATION PASSED");
			$display("Simulation finished at %0d ps", $time);
			$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
		end else begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
			$display("Simulation finished at %0d ps", $time);
			end
	end

endmodule
