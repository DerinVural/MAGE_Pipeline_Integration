in\n\t\t\t$display("\\n==============================================================");\n\t\t\t$display("!!! FIRST MISMATCH DETECTED AT TIME %0t !!!", $time);\n\t\t\t$display("Queue content showing last %0d cycles:", queue_tail);\n\t\t\t$display("==============================================================");\n\t\t\t\n\t\t\tfor (int i = 0; i < queue_tail; i++) begin\n\t\t\t\t// Check for mismatch at this stored cycle\n\t\t\t\tif (got_output_queue[i] !== golden_queue[i]) begin\n\t\t\t\t\t$display("\\n--- Mismatch Found at Cycle %0d (Time %0t) ---", i, $time - (i * 10));\n\t\t\t\t\t$display("Input:  %h (Binary: %b)", input_queue[i], input_queue[i]);\n\t\t\t\t\t$display("Got Out: %h (Binary: %b)", got_output_queue[i], got_output_queue[i]);\n\t\t\t\t\t$display("Exp Out: %h (Binary: %b)", golden_queue[i], golden_queue[i]);\n\t\t\t\t\ts$display("------------------------------------------------------");\n\t\t\t\tend\n\t\t\tend\n\t\tend\n\tend\n\n\t// End of sequential logic block\n\n\t// Timeout logic (Kept as is)\n\tinitial begin\n\t\t#1000000\n\t\t$display("TIMEOUT");\n\t\t$finish();\n\tend\n\n\t// Final Simulation Summary (Requirement 4)\n\tinitial begin\n\t\t@(negedge clk);\n\t\t// Wait a bit to ensure all asynchronous operations settle if any\n\t\t#10;\n\t\t\n\t\tif (stats1.errors == 0 && stats1.errors_pedge == 0) begin\n\t\t\t$display("SIMULATION PASSED");\n\t\t\t$display("Simulation finished at %0d ps", $time);\n\t\t\t$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);\n\t\tend else begin\n\t\t\t$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);\n\t\t\t$display("Simulation finished at %0d ps", $time);\n\t\t\tend\n\tend\n\nendmodule\n</testbench>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nThe module interface is given below:\n<module_interface>\nmodule TopModule (\n    input  clk,\n    input  [7:0] in,\n    out