display("%s: HEX = %h, BIN = %b", signal_name, value, value);\n122: \t\tendtask\n123: \n124: \t\t// --- Error Capture Logic ---\n125: \t\talways @(posedge clk, negedge clk) begin\n126: \t\t\tstats1.clocks++;\n127: \t\t\n128: \t\t\t// Check tb_match error\n129: \t\t\tif (!tb_match) begin\n130: \t\t\t\tif (stats1.errors == 0) begin\n131: \t\t\t\tstats1.errortime = $time;\n132: \t\t\t\tin_at_first_error = in;\n133: \t\t\t\tpedge_ref_at_first_error = pedge_ref;\n134: \t\t\t\tpedge_dut_at_first_error = pedge_dut;\n135: \t\t\t\t$display("\\n!!! First Mismatch Detected (tb_match) at time %0d ps !!!", $time);\n136: \t\t\t\tdisplay_signal("Input (in)", in);\n137: \t\t\t\tdisplay_signal("Expected (pedge_ref)", pedge_ref);\n138: \t\t\t\tdisplay_signal("Actual (pedge_dut)", pedge_dut);\n139: \t\t\t\tstats1.errors++;\n140: \t\t\t\tstats1.errortime = $time;\n141: \t\t\tend\n142: \t\t\tend\n143: \t\t\telse begin\n144: \t\t\t\tstats1.errors++;\n145: \t\t\tend\n146: \t\t\tend\n147: \t\t\n148: \t\t\t// Check pedge_ref vs pedge_dut error\n149: \t\t\tif (pedge_ref !== pedge_dut) \n150: \t\t\tbegin \n151: \t\t\t\tif (stats1.errors_pedge == 0) begin\n152: \t\t\t\tstats1.errortime_pedge = $time;\n153: \t\t\t\t// Capture signals specific to this error type if it\'s the first of its kind\n154: \t\t\t\tend\n155: \t\t\t\t// We capture the state corresponding to the cycle where the error is detected\n156: \t\t\t\tin_at_first_error = in;\n157: \t\t\t\tpedge_ref_at_first_error = pedge_ref;\n158: \t\t\t\tpedge_dut_at_first_error = pedge_dut;\n159: \t\t\t\t$display("\\n!!! First Mismatch Detected (pedge) at time %0d ps !!!", $time);\n160: \t\t\t\tdisplay_signal("Input (in)", in);\n161: \t\t\t\tdisplay_signal("Expected (pedge_ref)", pedge_ref);\n162: \t\t\t\tdisplay_signal("Actual (pedge_dut)", pedge_dut);\n163: \t\t\t\tstats1.errors_pedge = stats1.errors_pedge + 1\'b1;\n164: \t\t\t\tstats1.errortime_pedge = $time;\n165: \t\t\tend\n166: \t\t\telse begin\n167: \t\t\t\tstats1.errors_pedge = stats1.errors_pedge + 1\'b1;\n168: \t\t\tend\n169: \t\t\tend\n170: \t\t\n171: \t\tend\n172: \n173: \t\t// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.\n174: \t\tassign tb_match = ( { pedge_ref } === ( { pedge_ref } ^ { pedge_dut } ^ { pedge_ref } ) );\n175: \n176: \t\t// add timeout after 100K cycles\n177: \t\tinitial begin\n178: \t\t\t#1000000\n179: \t\t\t$display("TIMEOUT");\n180: \t\t\t$finish();\n181: \t\tend\n182: \n183: \t\t// --- Final Report ---\n184: \t\tinitial begin\n185: \t\t\t// Wait long enough to allow simulation to run its course or timeout\n186: \t\t\t#10000000 \n187: \t\t\t\n188: \t\t\tif (stats1.errors == 0 && stats1.errors_pedge == 0)\n189: \t\t\t\t$display("\\n=======================================");\n190: \t\t\t\t$display("SIMULATION PASSED");\n191: \t\t\t\t$display("=======================================");\n192: \t\t\telse begin\n193: \t\t\t\tint total_errors = stats1.errors + stats1.errors_pedge;\n194: \t\t\t\tint first_error_time = 9999999999; // Initialize to a very large time\n195: \t\t\t\t\n196: \t\t\t\t// Determine the absolute first error time\n197: \t\t\t\tif (stats1.errors > 0) first_error_time = (stats1.errortime < first_error_time) ? stats1.errortime : first_error_time;\n198: \t\t\t\tif (stats1.errors_pedge > 0) first_error_time = (stats1.errortime_pedge < first_error_time) ? stats1.errortime_pedge : first_error_time;\n199: \t\t\t\t\n200: \t\t\t\t$display("\\n=======================================");\n201: \t\t\t\t$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", total_errors, first_error_time);\n202: \t\t\t\t$display("=======================================");\n203: \t\t\tend\n204: \t\t\t$finish;\n205: \t\tend\n206: \n207: endmodule\n\n</previous_tb>\n')]), ChatMessage(role=<MessageRole.ASSISTANT: 'assistant'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='{\n    "reasoning": "The main task is to generate an interface matchi