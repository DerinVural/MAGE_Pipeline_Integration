rom_title;\n\twire wavedrom_enable;\n\tint wavedrom_hide_after_time;\n\t\n\treg clk=0;\n\tinitial forever\n\t\t#5 clk = ~clk;\n\n\tlogic reset;\n\tlogic [31:0] in;\n\tlogic [31:0] out_ref; // Expected output\n\tlogic [31:0] out_dut; // DUT output\n\n\t// --- Queue Definitions for Mismatch Checking ---\n\treg [31:0] input_queue [$];\n\treg [31:0] got_output_queue [$];\n\treg [31:0] golden_queue [$];\n\treg reset_queue [$];\n\n\tlocalparam MAX_QUEUE_SIZE = 10;\n\t\n\t// Error tracking variables (retaining original logic intent)\n\tint total_errors = 0;\n\tint first_error_time = -1;\n\tint total_errors_out = 0;\n\tint first_error_time_out = -1;\n\n\tinitial begin \n\t\t$dumpfile(\"wave.vcd\");\n\t\t$dumpvars(1, stim1.clk, tb_mismatch ,clk,reset,in,out_ref,out_dut );\n\tend\n\n\n\twire tb_match;\n\twire tb_mismatch = ~tb_match;\n\t\n\tstimulus_gen stim1 (\n\t\t.clk, \n\t\t.tb_match, \n\t\t.in, \n\t\t.reset, \n\t\t.wavedrom_title, \n\t\t.wavedrom_enable\n\t);\n\t\n\t// Reference Model (Expected Value Calculation)\n\tmodule RefModule (input clk, input reset, input [31:0] in, output logic [31:0] out);\n\t\treg [31:0] out_reg;\n\t\treg [31:0] prev_in;\n\t\t\n\t\talways @(posedge clk)\n\t\tbegin\n\t\t\tif (reset) begin\n\t\t\t\tout_reg <= 32'h0;\n\t\t\tend\n\t\t\telse begin\n\t\t\t\t// Check for 1 -> 0 transition for each bit i\n\t\t\t\tlogic [31:0] captured_mask = 32'h0;\n\t\t\t\tfor (int i = 0; i < 32; i = i + 1) begin\n\t\t\t\t\tif (prev_in[i] == 1'b1 && in[i] == 1'b0) begin\n\t\t\t\t\tcaptured_mask[i] = 1'b1;\n\t\t\t\t\tend\n\t\t\t\tend\n\t\t\t\t\n\t\t\t\t// Capture means output remains 1 until reset (OR operation)\n\t\t\t\tout_reg <= out_reg | captured_mask;\n\t\tend\n\t\tend\n\t\t\n\t\talways @(posedge clk)\n\t\t\tprev_in <= in;\n\t\tendmodule\n\t\n\tRefModule good1 (\n\t\t.clk, \n\t\t.reset, \n\t\t.in, \n\t\t.out(out_ref) \n\t);\n\t\n\t// DUT Instantiation\n\tTopModule top_module1 (\n\t\t.clk, \n\t\t.reset, \n\t\tin, \n\t\tout_dut \n\t);\n\n\t\n\t// Task for time stepping delay (maintained from golden testbench)\n\ttask wait_for_end_of_timestep;\n\t\trepeat(5) begin\n\t\tstrobe <= !strobe;  // Try to delay until the very end of the time step.\n\t\t@(strobe);\n\t\tendtask\n\t\tendtask\n\n\t// Signal used for internal task timing delay\n\tlogic strobe = 0;\n\n\n\t// --- Verification Logic (Queue-based comparison) ---\n\talways @(posedge clk or negedge clk) begin\n\t\tif (!reset) begin\n\t\t\t// 1. Manage Queue Size\n\t\t\tif (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin\n\t\t\t\tinput_queue.delete(0);\n\t\t\t\tgot_output_queue.delete(0);\n\t\t\t\tgolden_queue.delete(0);\n\t\t\t\treset_queue.delete(0);\n\t\t\tend\n\t\t\t\n\t\t\t// 2. Store current cycle data\n\t\t\tinput_queue.push_back(in);\n\t\t\tgot_output_queue.push_back(out_dut);\n\t\t\tgolden_queue.push_back(out_ref);\n\t\t\treset_queue.push_back(reset);\n\t\t\t\n\t\t\t// 3. Check for mismatches (only check after initial loading phase)\n\t\t\tif (got_output_queue.size() > 1) begin \n\t\t\t\t\t\n\t\t\t\t// --- Update original error counters ---\n\t\t\t\t\tif (out_dut !== out_ref) begin\n\t\t\t\t\t\ttotal_errors++;\n\t\t\t\t\t\tif (total_errors == 1) begin\n\t\t\t\t\t\tfirst_error_time = $time;\n\t\t\t\t\tend\n\t\t\t\t\tend\n\t\t\t\t\t\n\t\t\t\t// Original error_out tracking logic (retained structure)\n\t\t\t\t\tif (out_dut !== out_ref) begin\n\t\t\t\t\t\tif (total_errors_out == 0) begin\n\t\t\t\t\t\tfirst_error_time_out = $time;\n\t\t\t\t\t\tend\n\t\t\t\t\t\ttotal_errors_out = 1;\n\t\t\t\t\tend\n\t\t\t\t\tend\n\t\t\t\t\tend\n\t\t\t\tend\n\t\t\t\tend\n\n\t\t\t// --- Mismatch Logging on First Error (Requirement 1.1) ---\n\t\t\tif (out_dut !== out_ref && total_errors == 1) begin\n\t\t\t\t$display(\"\\n============================================================================\");\n\t\t\t\t$display(\"*** FIRST MISMATCH DETECTED AT TIME %0t ***",  ";\n\t\t\t\t$display(\"\\nLast %d cycles of simulation (Mismatch occurs on current cycle):\", input_queue.size());\n\t\t\t\n\t\t\tfor (int i = 0; i < input_queue.size(); i++) begin\n\t\t\t\tif (got_output_queue[i] === golden_queue[i]) begin\n\t\t\t\t$display(\"Got Match at Cycle %d\", i);\n\t\t\t\tend else begin\n\t\t\t\t$display(\"Got Mismatch at Cycle %d\", i);\n\t\t\t\tend\n\t\t\t\t// Displaying required info\n\t\t\t\t$display(\"Cycle %0d, reset %b, input %h, got output %h, exp output %h\",\n\t\t\t\t\ti,\n\t\t\t\t\treset_queue[i],\n\t\t\t\t\tinput_queue[i],\n\t\t\t\t\tgot_output_queue[i],\n\t\t\t\t\tgolden_queue[i]);\n\t\t\tend\n\t\t\tend\n\t\t\tend\n\t\tend\n\t\tend\n\n\t// --- Finalization Logic (Requirement 4) ---\n\tfinal begin\n\t\t$display(\"============================================================================\");\n\t\t$display(\"Simulation finished at %0d ps\", $time);\n\t\t\n\t\tif (total_errors == 0) begin\n\t\t\t$display(\"SIMULATION PASSED\");\n\t\t\tend else begin\n\t\t\t// Format: \"SIMULATION FAILED - x MISMATCHES DETECTED, FIRST AT TIME y\"\n\t\t\t$display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\", total_errors, first_error_time);\n\t\tend\n\t\t$display(\"Mismatches (Original Logic Check): %1d in %1d samples\", stats1.errors, stats1.clocks);\n\tend\n\n\t// Original stats tracking logic (Maintained for strict functional preservation)\n\talways @(posedge clk, negedge clk) begin\n\t\tstats1.clocks++;\n\t\tif (!tb_match) begin\n\t\t\tif (stats1.errors == 0) stats1.errortime = $time;\n\t\t\tsstats1.errors++;\n\t\tend\n\t\t// Original secondary check\n\t\tif (out_ref !== ( out_ref ^ out_dut ^ out_ref ))\n\t\tbegin if (stats1.errors_out == 0) stats1.errortime_out = $time;\n\t\t\tsstats1.errors_out = stats1.errors_out+1'b1; end\n\t\tend\n\tend\n\n\t// add timeout after 100K cycles\n\tinitial begin\n\t\t#1000000\n\t\t$display(\"TIMEOUT\");\n\t\t$finish();\n\tend\n\nendmodule\n"
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
    
