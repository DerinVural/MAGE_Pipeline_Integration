    "testbench": "`timescale 1 ps/1 ps\n`define OK 12\n`define INCORRECT 13\n\nmodule stimulus_gen (\n\tinput clk,\n\toutput logic [7:0] in,\n\toutput logic reset\n);\n\n\tinitial begin\n\t\trepeat(200) @(negedge clk) begin\n\t\t\tin <= $random;\n\t\t\treset <= !($random & 31);\n\t\tend\n\n\t\t#1 $finish;\n\tend\n\nendmodule\n\nmodule tb();\n\n\ttypedef struct packed {\n\t\tint errors;\n\t\tint errortime;\n\t\tint errors_done;\n\t\tint errortime_done;\n\t\tint clocks;\n\t} stats;\n\t\n\tstats stats1;\n\t\n\t// Signal dumping setup (Maintained from golden TB)\n\twire[511:0] wavedrom_title;\n\twire wavedrom_enable;\n\tint wavedrom_hide_after_time;\n\t\n\treg clk=0;\n\tinitial forever\n\t\t#5 clk = ~clk;\n\n\t// Inputs/Outputs\n\tlogic [7:0] in_tb;\n\tlogic reset_tb;\n\tlogic done_ref;\n\tlogic done_dut;\n\n\t// Instantiate stimulus generator\n\tstimulus_gen stim1 (\n\t\t.clk, \n\t\t.in, \n\t\t.reset);\n\n\t// DUT Instantiation\n\t// RefModule is assumed to exist and function as the golden model\n\tRefModule good1 (\n\t\t.clk, \n\t\tin_tb, \n\t\t.reset, \n\t\t.done(done_ref) );\n\t\n\tTopModule top_module1 (\n\t\t.clk, \n\t\tin_tb, \n\t\t.reset, \n\t\t.done(done_dut) );\n\n\t// Signal connection from stimulus generator to DUT inputs\n\tassign in_tb = stim1.in;\n\tassign reset_tb = stim1.reset;\n\n\t// Dumping setup\n\tinitial begin \n\t\t$dumpfile(\"wave.vcd\");\n\t\t$dumpvars(1, stim1.clk, tb_mismatch ,clk,in_tb,reset_tb,done_ref,done_dut );\n\tend\n\n\t// Verification Signals\n\twire tb_match;\n\twire tb_mismatch = ~tb_match;\n\t\n\t// Verification Logic (Simplified comparison: done_ref === done_dut)\n\t// Original: assign tb_match = ( { done_ref } === ( { done_ref } ^ { done_dut } ^ { done_ref } ) );\n\t// Simplified: \n\tassign tb_match = (done_ref === done_dut);\n\n\t// --- Queue Based Mismatch Detection Setup ---\n\t\n\t// Data types for queues\n\ttypedef logic [7:0] byte_t;\n\t\n\t// Queue definitions\n\tbyte_t input_queue [$]; // Stores in_tb\t\n\tlogic reset_queue [$];  // Stores reset_tb\n\tlogic done_output_queue [$]; // Stores done_dut\n\tlogic done_golden_queue [$]; // Stores done_ref\n\t\n\tlocalparam MAX_QUEUE_SIZE = 10; // Constraint applied\n\t\n\t// Mismatch tracking variables (to maintain original error counting) \n\tint total_errors = 0;\n\tint first_error_time = 0;\n\tint total_clocks = 0;\n\tint first_done_mismatch_time = 0;\n\tint done_mismatches = 0;\n\t\n\t// Synchronous tracking and logging logic\n\talways @(posedge clk, negedge clk) begin\n\t\ttotal_clocks++;\n\t\t\n\t\t// 1. Manage Queue Size\n\t\tif (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin\n\t\t\tinput_queue.delete(0);\n\t\t\tdone_output_queue.delete(0);\n\t\t\tdone_golden_queue.delete(0);\n\t\t\treset_queue.delete(0);\n\t\tend\n\n\t\t// 2. Push current cycle data\n\t\tinput_queue.push_back(in_tb);\n\t\treset_queue.push_back(reset_tb);\n\t\tdone_output_queue.push_back(done_dut);\n\t\tdone_golden_queue.push_back(done_ref);\n\n\t\t// 3. Check for Mismatches and Log\n\t\tif (tb_mismatch) begin\n\t\t\t// Update total error count and first error time\n\t\t\tif (total_errors == 0) total_errors = 1;\n\t\t\tif (first_error_time == 0) first_error_time = $time;\n\t\t\ttotal_errors++;\n\t\t\tend\n\t\t\n\t\t// Check for done signal specific mismatch (to match original logic)\n\t\tif (done_ref !== done_dut) begin\n\t\t\tif (done_mismatches == 0) first_done_mismatch_time = $time;\n\t\t\tdone_mismatches++;\n\t\tend\n\tend\n\n\t// Display logic triggered when the first mismatch occurs\n\talways @(posedge clk, negedge clk) begin\n\t\tif (total_errors == 1 && first_error_time > 0) begin\n\t\t\t$display(\"======================================================================\");\n\t\t\t$display(\"!!! FIRST MISMATCH DETECTED AT TIME %0d ps !!!\", $time);\n\t\t\t$display(\"======================================================================\");\n\t\t\t$display(\"Last %0d cycles of simulation:\", input_queue.size());\n\t\t\t\n\t\t\tfor (int i = 0; i < input_queue.size(); i++) begin\n\t\t\t\t// Mismatch check must happen on the stored values\n\t\t\t\tif (done_output_queue[i] === done_golden_queue[i]) begin\n\t\t\t\t\t$display(\"Cycle %d: Got Match.\", i);\n\t\t\t\tend else begin\n\t\t\t\t\t$display(\"Cycle %d: Got MISMATCH.\", i);\n\t\t\t\tend\n\t\t\t\t\n\t\t\t\t// Display Format: Cycle, reset, in (HEX/BIN), got output (HEX/BIN), exp output (HEX/BIN)\n\t\t\t\t$display(\"  Cycle %d, Reset: %b, In: 0x%h (%b), Got Done: %b, Exp Done: %b\",\n\t\t\t\t\t i,\n\t\t\t\t\t reset_queue[i],\n\t\t\t\t\t input_queue[i],\n\t\t\t\t\t input_queue[i], // Reusing input_queue[i] for binary display if width<=64\n\t\t\t\t\t done_output_queue[i],\n\t\t\t\t\t done_golden_queue[i]);\n\t\t\tend\n\t\tend\n\tend\n\n\t// --- Test Completion Logic ---\n\tinitial begin\n\t\t// Wait for simulation duration or timeout\n\t\t#1000000; \n\t\tif ($time >= 1000000) begin\n\t\t\t$display(\"TIMEOUT REACHED.\");\n\t\t\t$finish();\n\t\tend\n\tend\n\n\t// Final reporting upon $finish\n\tinitial begin\n\t\t// Wait a bit longer to ensure all logs are flushed before finishing\n\t\t@(negedge clk);\n\t\t#1;\n\t\t\n\t\tif (total_errors == 0) begin\n\t\t\t$display(\"\\n=========================================\");\n\t\t\t$display(\"SIMULATION PASSED\");\n\t\t\t$display(\"=========================================\");\n\t\tend else begin\n\t\t\t$display(\"\\n=========================================\");\n\t\t\t$display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\", total_errors, first_error_time);\n\t\t\t$display(\"=========================================\");\n\t\tend\n\tend\n\n\tendmodule"
