module stimulus_gen (
	input clk,
	output logic [7:0] in,
	output logic reset
);

	initial begin
		repeat(200) @(negedge clk) begin
			in <= $random;
			reset <= !($random & 31);
		end

		#1 $finish;
	end

endmodule

module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_done;
		int errortime_done;
		int clocks;
	} stats;
	
	stats stats1;
	
	// Signal dumping setup (Maintained from golden TB)
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	// Inputs/Outputs
	logic [7:0] in_tb;
	logic reset_tb;
	logic done_ref;
	logic done_dut;

	// Instantiate stimulus generator
	stimulus_gen stim1 (
		.clk, 
		.in, 
		.reset);

	// DUT Instantiation
	// RefModule is assumed to exist and function as the golden model
	RefModule good1 (
		.clk, 
		in_tb, 
		.reset, 
		.done(done_ref) );
	
	TopModule top_module1 (
		.clk, 
		in_tb, 
		.reset, 
		.done(done_dut) );

	// Signal connection from stimulus generator to DUT inputs
	assign in_tb = stim1.in;
	assign reset_tb = stim1.reset;

	// Dumping setup
	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,clk,in_tb,reset_tb,done_ref,done_dut );
	end

	// Verification Signals
	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	// Verification Logic (Simplified comparison: done_ref === done_dut)
	// Original: assign tb_match = ( { done_ref } === ( { done_ref } ^ { done_dut } ^ { done_ref } ) );
	// Simplified: 
	assign tb_match = (done_ref === done_dut);

	// --- Queue Based Mismatch Detection Setup ---
	
	// Data types for queues
	typedef logic [7:0] byte_t;
	
	// Queue definitions
	byte_t input_queue [$]; // Stores in_tb	
	logic reset_queue [$];  // Stores reset_tb
	logic done_output_queue [$]; // Stores done_dut
	logic done_golden_queue [$]; // Stores done_ref
	
	localparam MAX_QUEUE_SIZE = 10; // Constraint applied
	
	// Mismatch tracking variables (to maintain original error counting) 
	int total_errors = 0;
	int first_error_time = 0;
	int total_clocks = 0;
	int first_done_mismatch_time = 0;
	int done_mismatches = 0;
	
	// Synchronous tracking and logging logic
	always @(posedge clk, negedge clk) begin
		total_clocks++;
		
		// 1. Manage Queue Size
		if (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin
			input_queue.delete(0);
			done_output_queue.delete(0);
			done_golden_queue.delete(0);
			reset_queue.delete(0);
		end

		// 2. Push current cycle data
		input_queue.push_back(in_tb);
		reset_queue.push_back(reset_tb);
		done_output_queue.push_back(done_dut);
		done_golden_queue.push_back(done_ref);

		// 3. Check for Mismatches and Log
		if (tb_mismatch) begin
			// Update total error count and first error time
			if (total_errors == 0) total_errors = 1;
			if (first_error_time == 0) first_error_time = $time;
			total_errors++;
			end
		
		// Check for done signal specific mismatch (to match original logic)
		if (done_ref !== done_dut) begin
			if (done_mismatches == 0) first_done_mismatch_time = $time;
			done_mismatches++;
		end
	end

	// Display logic triggered when the first mismatch occurs
	always @(posedge clk, negedge clk) begin
		if (total_errors == 1 && first_error_time > 0) begin
			$display("======================================================================");
			$display("!!! FIRST MISMATCH DETECTED AT TIME %0d ps !!!", $time);
			$display("======================================================================");
			$display("Last %0d cycles of simulation:", input_queue.size());
			
			for (int i = 0; i < input_queue.size(); i++) begin
				// Mismatch check must happen on the stored values
				if (done_output_queue[i] === done_golden_queue[i]) begin
					$display("Cycle %d: Got Match.", i);
				end else begin
					$display("Cycle %d: Got MISMATCH.", i);
				end
				
				// Display Format: Cycle, reset, in (HEX/BIN), got output (HEX/BIN), exp output (HEX/BIN)
				$display("  Cycle %d, Reset: %b, In: 0x%h (%b), Got Done: %b, Exp Done: %b",
					 i,
					 reset_queue[i],
					 input_queue[i],
					 input_queue[i], // Reusing input_queue[i] for binary display if width<=64
					 done_output_queue[i],
					 done_golden_queue[i]);
			end
		end
	end

	// --- Test Completion Logic ---
	initial begin
		// Wait for simulation duration or timeout
		#1000000; 
		if ($time >= 1000000) begin
			$display("TIMEOUT REACHED.");
			$finish();
		end
	end

	// Final reporting upon $finish
	initial begin
		// Wait a bit longer to ensure all logs are flushed before finishing
		@(negedge clk);
		#1;
		
		if (total_errors == 0) begin
			$display("\n=========================================");
			$display("SIMULATION PASSED");
			$display("=========================================");
		end else begin
			$display("\n=========================================");
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", total_errors, first_error_time);
			$display("=========================================");
		end
	end

	endmodule
