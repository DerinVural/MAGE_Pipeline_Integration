    "testbench": "`timescale 1 ps/1 ps\n`define OK 12\n`define INCORRECT 13\n\nmodule stimulus_gen (\n\tinput clk,\n\toutput logic reset,\n\toutput logic s, w,\n\tinput tb_match\n);\n\tbit spulse_fail = 0;\n\tbit failed = 0;\n\t\n\talways @(posedge clk, negedge clk)\n\t\tif (!tb_match) failed = 1;\n\t\t\t\t\n\tinitial begin\n\t\treset <= 1;\n\t\ts <= 0;\n\t\tw <= 0;\n\t\t@(posedge clk);\n\t\t@(posedge clk);\n\t\treset <= 0;\n\t\t@(posedge clk);\n\t\t@(posedge clk);\n\t\ts <= 1;\n\n\t\trepeat(200) @(posedge clk, negedge clk) begin\n\t\tw <= $random;\n\t\tend\n\n\t\treset <= 1;\n\t\t@(posedge clk);\n\t\treset <= 0;\n\t\t@(posedge clk);\n\t\t@(posedge clk);\n\n\t\trepeat(200) @(posedge clk, negedge clk) begin\n\t\tw <= $random;\n\t\tend\n\t\t\n\t\t@(posedge clk)\n\t\t\tspulse_fail <= failed;\n\t\t\n\t\trepeat(500) @(negedge clk) begin\n\t\treset <= !($random & 63);\n\t\ts <= !($random & 7);\n\t\tw <= $random;\n\t\tend\n\n\t\tif (failed && !spulse_fail) begin\n\t\t$display (\"Hint: Your state machine should ignore input 's' after the state A to B transition.\");\n\t\tend\n\t\t\n\t\t#1 $finish;\n\tend\n\t\nendmodule\n\nmodule tb();\n\n\t// --- Queue Based Verification Structures ---\n\t// MAX_QUEUE_SIZE must be >= (Pattern_Length + 1). Pattern length is 3 for 'w'. Setting to 9.\n\tlocalparam MAX_QUEUE_SIZE = 9;\n\t\n\t// Queue storage for sequential logic tracking\n\treg [1:0] clk_queue [$]; // Storing clock state (0 or 1)\n\treg [1:0] reset_queue [$];\n\treg [1:0] s_queue [$];\n\treg [1:0] w_queue [$];\n\treg [1:0] z_ref_queue [$];\n\treg [1:0] z_dut_queue [$];\n\t\n\t// Mismatch Counters\n\tint total_mismatches = 0;\n\tint first_mismatch_time = -1;\n\n\t// Constants for signal width (1 bit for all tracked signals)\n\tlocalparam INPUT_WIDTH = 1;\n\tlocalparam OUTPUT_WIDTH = 1;\n\n\t// Simulation Signals\n\treg clk=0;\n\tlogic reset;\n\tlogic s;\n\tlogic w;\n\tlogic z_ref;\n\tlogic z_dut;\n\n\twire tb_match;\n\twire tb_mismatch = ~tb_match;\n\t\n\t// Instantiate Stimulus