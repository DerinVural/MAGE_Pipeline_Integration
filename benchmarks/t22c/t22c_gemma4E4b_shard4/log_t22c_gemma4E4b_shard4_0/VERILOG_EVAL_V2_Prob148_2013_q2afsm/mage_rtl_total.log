	input logic clk;
	input logic resetn;
	input logic [2:0] r;
	output logic [2:0] g;
endmodule


top_module top_module_dummy;
	input logic clk;
	input logic resetn;
	input logic [2:0] r;
	output logic [2:0] g;
endmodule
