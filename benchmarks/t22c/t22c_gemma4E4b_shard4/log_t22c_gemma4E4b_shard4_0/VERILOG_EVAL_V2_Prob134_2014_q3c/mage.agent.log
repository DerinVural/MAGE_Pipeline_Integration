// Stimulus Generation Module (Copied from Golden TB)
module stimulus_gen (
	input clk,
	output logic x,
	output logic [2:0] y
);
	initial begin
		repeat(200) @(posedge clk, negedge clk) begin
			y <= $random;
			x <= $random;
		end
		
		#1 $finish;
	end
	endmodule

// Reference Model (Placeholder, Copied from Golden TB)
module RefModule (
	input clk,
	input x,
	input [2:0] y,
	output Y0,
	output z
);
	// Placeholder for the reference model
endmodule

// Testbench
module tb();


// --- Queue Definitions for Mismatch Tracking ---

// State space size is 3 bits, max queue size set to 10.
localparam MAX_QUEUE_SIZE = 10;

// Inputs Queue: clk (1-bit), x (1-bit), y (3-bits)
reg input_clk_queue [$];
reg input_x_queue [$];
reg input_y_queue [$];

// Outputs Queue: Y0_dut (1-bit), z_dut (1-bit)
reg got_Y0_queue [$];
reg got_z_queue [$];

// Golden/Reference Queue: Y0_ref (1-bit), z_ref (1-bit)
reg golden_Y0_queue [$];
reg golden_z_queue [$];

// Reset Queue (Placeholder)
reg reset_queue [$];

// Error Counters and Timestamps (Maintained functionality)
int errors = 0;
int errortime = 0;
int errors_Y0 = 0;
int errortime_Y0 = 0;
int errors_z = 0;
int errortime_z = 0;
int clocks = 0;


// --- Signals ---

reg clk=0;
initial forever
	#5 clk = ~clk;

logic x_sig;
logic [2:0] y_sig;
logic Y0_ref_sig;
logic Y0_dut_sig;
logic z_ref_sig;
logic z_dut_sig;

// Verification logic (Simplified from redundant XOR structure in original TB)
wire tb_match = ( { Y0_ref_sig, z_ref_sig } === { Y0_dut_sig, z_dut_sig } );

// --- Instantiations ---

stimulus_gen stim1 (
	.clk, 
	.x, 
	.y
);

RefModule good1 (
	.clk, 
	x_sig, 
	y_sig, 
	.Y0(Y0_ref_sig), 
	.z(z_ref_sig));

TopModule top_module1 (
	.clk, 
	x_sig, 
	y_sig, 
	.Y0(Y0_dut_sig), 
	.z(z_dut_sig));


// --- Task for Delaying Timestep (Copied from Golden TB) ---

bit strobe = 0;
task wait_for_end_of_timestep;
	repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
	end
task


// --- Waveform Dumping ---

initial begin 
	$dumpfile("wave.vcd");
	// Note: Updated dumping to include all relevant signals for debugging
	$dumpvars(0, tb, top_module1, stim1, good1);
end


// --- Mismatch Detection and Queue Management ---

// Flag to track if the first mismatch has already been logged
reg mismatch_logged = 0;

always @(posedge clk, negedge clk) begin
	// 1. Queue Management: Shift/Delete old samples if queue is full
	if (input_clk_queue.size() >= MAX_QUEUE_SIZE - 1) begin
		input_clk_queue.delete(0);
		input_x_queue.delete(0);
		input_y_queue.delete(0);
		got_Y0_queue.delete(0);
		got_z_queue.delete(0);
		golden_Y0_queue.delete(0);
		golden_z_queue.delete(0);
		reset_queue.delete(0);
	end

	// 2. Data Pushing (Current Cycle Data)
	input_clk_queue.push_back(clk);
	input_x_queue.push_back(x_sig);
	input_y_queue.push_back(y_sig);
	
	got_Y0_queue.push_back(Y0_dut_sig);
	got_z_queue.push_back(z_dut_sig);
	
	golden_Y0_queue.push_back(Y0_ref_sig);
	golden_z_queue.push_back(z_ref_sig);
	
	// Reset tracking (No change from original TB)
	reset_queue.push_back(1'b0); 

	// 3. Error Checking (Based on original TB's logic)
	
	// Total Mismatch Check
	if (!tb_match) begin
		if (errors == 0) errortime = $time;
		errors++;
		end
	
	// Y0 Mismatch Check (Original logic simplified: Y0_ref !== Y0_dut)
	if (Y0_ref_sig !== Y0_dut_sig) begin
		if (errors_Y0 == 0) errortime_Y0 = $time;
		errors_Y0 = errors_Y0 + 1'b1;
	end

	// z Mismatch Check (Original logic simplified: z_ref !== z_dut)
	if (z_ref_sig !== z_dut_sig) begin
		if (errors_z == 0) errortime_z = $time;
		errors_z = errors_z + 1'b1;
	end

	// 4. First Mismatch Logging (If not already logged)
	if (errors > 0 && !mismatch_logged) begin
		mismatch_logged = 1;
		$display("========================================================");
		$display("!!! FIRST MISMATCH DETECTED AT TIME %0d !!!", $time);
		$display("Logging last %0d cycles of simulation:", input_clk_queue.size());
		$display("========================================================");

		// Iterate through the current contents of the queue
		for (int i = 0; i < input_clk_queue.size(); i++) begin
			// Check overall match status for this historical point
			if (got_Y0_queue[i] === golden_Y0_queue[i] && got_z_queue[i] === golden_z_queue[i]) 
				$display("Cycle %0d: MATCH", i);
			else 
				$display("Cycle %0d: MISMATCH", i);

			// Display formatted data
			$display("  [Cycle %0d] Clk: %b, X: %b, Y: %h (%b) | Got Y0: %b, Got z: %b | Exp Y0: %b, Exp z: %b",
					 i,
					 input_clk_queue[i], 
					 input_x_queue[i], 
					 input_y_queue[i], input_y_queue[i], 
					 got_Y0_queue[i], got_z_queue[i], 
					 golden_Y0_queue[i], golden_z_queue[i]);
			end
		end

end


// --- Finalization ---
final begin
	// Print hints from original TB
	if (errors_Y0) $display("Hint: Output 'Y0' has %0d mismatches. First mismatch occurred at time %0d.", errors_Y0, errortime_Y0);
	else $display("Hint: Output 'Y0' has no mismatches.");
	if (errors_z) $display("Hint: Output 'z' has %0d mismatches. First mismatch occurred at time %0d.", errors_z, errortime_z);
	else $display("Hint: Output 'z' has no mismatches.");

	$display("Hint: Total mismatched samples is %0d out of %0d samples\n", errors, clocks);
	$display("Simulation finished at %0d ps", $time);

	// FINAL REQUIRED OUTPUT CHECK
	if (errors == 0) begin
		$display("SIMULATION PASSED");
		// Print original final summary for completeness
		$display("Mismatches: %0d in %0d samples", errors, clocks);
		$finish();
	end else begin
		$display("SIMULATION FAILED - x MISMATCHES DETECTED, FIRST AT TIME %0d", errortime);
		// Print original final summary for completeness
		$display("Mismatches: %0d in %0d samples", errors, clocks);
		$finish();
	end
end

// add timeout after 100K cycles (Copied from Golden TB)
initial begin
	#1000000
	$display("TIMEOUT");
	$finish();
end

endmodule
