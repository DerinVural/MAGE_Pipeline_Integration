g to track if the first mismatch has already been logged\nreg mismatch_logged = 0;\n\nalways @(posedge clk, negedge clk) begin\n\t// 1. Queue Management: Shift/Delete old samples if queue is full\n\tif (input_clk_queue.size() >= MAX_QUEUE_SIZE - 1) begin\n\t\tinput_clk_queue.delete(0);\n\t\tinput_x_queue.delete(0);\n\t\tinput_y_queue.delete(0);\n\t\tgot_Y0_queue.delete(0);\n\t\tgot_z_queue.delete(0);\n\t\tgolden_Y0_queue.delete(0);\n\t\tgolden_z_queue.delete(0);\n\t\treset_queue.delete(0);\n\tend\n\n\t// 2. Data Pushing (Current Cycle Data)\n\tinput_clk_queue.push_back(clk);\n\tinput_x_queue.push_back(x_sig);\n\tinput_y_queue.push_back(y_sig);\n\t\n\tgot_Y0_queue.push_back(Y0_dut_sig);\n\tgot_z_queue.push_back(z_dut_sig);\n\t\n\tgolden_Y0_queue.push_back(Y0_ref_sig);\n\tgolden_z_queue.push_back(z_ref_sig);\n\t\n\t// Reset tracking (No change from original TB)\n\treset_queue.push_back(1\'b0); \n\n\t// 3. Error Checking (Based on original TB\'s logic)\n\t\n\t// Total Mismatch Check\n\tif (!tb_match) begin\n\t\tif (errors == 0) errortime = $time;\n\t\terrors++;\n\t\tend\n\t\n\t// Y0 Mismatch Check (Original logic simplified: Y0_ref !== Y0_dut)\n\tif (Y0_ref_sig !== Y0_dut_sig) begin\n\t\tif (errors_Y0 == 0) errortime_Y0 = $time;\n\t\terrors_Y0 = errors_Y0 + 1\'b1;\n\tend\n\n\t// z Mismatch Check (Original logic simplified: z_ref !== z_dut)\n\tif (z_ref_sig !== z_dut_sig) begin\n\t\tif (errors_z == 0) errortime_z = $time;\n\t\terrors_z = errors_z + 1\'b1;\n\tend\n\n\t// 4. First Mismatch Logging (If not already logged)\n\tif (errors > 0 && !mismatch_logged) begin\n\t\tmismatch_logged = 1;\n\t\t$display("========================================================");\n\t\t$display("!!! FIRST MISMATCH DETECTED AT TIME %0d !!!", $time);\n\t\t$display("Logging last %0d cycles of simulation:", input_clk_queue.size());\n\t\t$display("========================================================");\n\n\t\t// Iterate through the current contents of the queue\n\t\tfor (int i = 0; i < input_clk_queue.size(); i++) begin\n\t\t\t// Check overall match status for this historical point\n\t\t\tif (got_Y0_queue[i] === golden_Y0_queue[i] && got_z_queue[i] === golden_z_queue[i]) \n\t\t\t\t$display("Cycle %0d: MATCH", i);\n\t\t\telse \n\t\t\t\t$display("Cycle %0d: MISMATCH", i);\n\n\t\t\t// Display formatted data\n\t\t\t$display("  [Cycle %0d] Clk: %b, X: %b, Y: %h (%b) | Got Y0: %b, Got z: %b | Exp Y0: %b, Exp z: %b",\n\t\t\t\t\t i,\n\t\t\t\t\t input_clk_queue[i], \n\t\t\t\t\t input_x_queue[i], \n\t\t\t\t\t input_y_queue[i], input_y_queue[i], \n\t\t\t\t\t got_Y0_queue[i], got_z_queue[i], \n\t\t\t\t\t golden_Y0_queue[i], golden_z_queue[i]);\n\t\t\tend\n\t\tend\n\nend\n\n\n// --- Finalization ---\nfinal begin\n\t// Print hints from original TB\n\tif (errors_Y0) $display("Hint: Output \'Y0\' has %0d mismatches. First mismatch occurred at time %0d.", errors_Y0, errortime_Y0);\n\telse $display("Hint: Output \'Y0\' has no mismatches.");\n\tif (errors_z) $display("Hint: Output \'z\' has %0d mismatches. First mismatch occurred at time %0d.", errors_z, errortime_z);\n\telse $display("Hint: Output \'z\' has no mismatches.");\n\n\t$display("Hint: Total mismatched samples is %0d out of %0d samples\\n", errors, clocks);\n\t$display("Simulation finished at %0d ps", $time);\n\n\t// FINAL REQUIRED OUTPUT CHECK\n\tif (errors == 0) begin\n\t\t$display("SIMULATION PASSED");\n\t\t// Print original final summary for completeness\n\t\t$display("Mismatches: %0d in %0d samples", errors, clocks);\n\t\t$finish();\n\tend else begin\n\t\t$display("SIMULATION FAILED - x MISMATCHES DETECTED, FIRST AT TIME %0d", errortime);\n\t\t// Print original final summary for completeness\n\t\t$display("Mismatches: %0d in %0d samples", errors, clocks);\n\t\t$finish();\n\tend\nend\n\n// add timeout after 100K cycles (Copied from Golden TB)\ninitial begin\n\t#1000000\n\t$display("TIMEOUT");\n\t$finish();\nend\n\nendmodule\n</testbench>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwar