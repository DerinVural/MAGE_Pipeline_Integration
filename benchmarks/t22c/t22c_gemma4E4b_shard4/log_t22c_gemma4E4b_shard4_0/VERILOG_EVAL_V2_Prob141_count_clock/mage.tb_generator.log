 hh_dut, mm_dut, ss_dut, pm_dut ? \"PM\": \"AM\");\n\t\t\treset_fail <= 1'b1;\n\t\tend\n\t\t\n\t\treset <= 1'b0;\n\t\t@(posedge clk);\n\t\t@(posedge clk);\n\t\tena <= 1'b0;\n\t\treset <= 1'b1;\n\t\t@(posedge clk);\n\t\t@(posedge clk)\n\t\tif (!tb_match && !reset_fail)\n\t\t\t$display(\"Hint: Reset has higher priority than enable and should occur even if not enabled.\");\n\t\t\n\t\t\n\t\trepeat(400) @(posedge clk, negedge clk) begin\n\t\t\treset <= !($random & 31);\n\t\t\tena <= !($random & 3);\n\t\tend\n\t\treset <= 1;\n\t\t@(posedge clk) begin\n\t\t\t{reset, ena} <= 2'b1;\n\t\tend\n\t\t\n\t\trepeat(55) @(posedge clk);\n\t\twavedrom_start(\"Minute roll-over\");\n\t\trepeat(10) @(posedge clk);\n\t\twavedrom_stop();\n\t\t\n\t\trepeat(3530) @(posedge clk);\n\t\twavedrom_start(\"Hour roll-over\");\n\t\trepeat(10) @(posedge clk);\n\t\twavedrom_stop();\n\t\t\n\t\trepeat(39590) @(posedge clk);\n\t\twavedrom_start(\"PM roll-over\");\n\t\trepeat(10) @(posedge clk);\n\t\twavedrom_stop();\n\t\t\n\t\trepeat(132745) @(posedge clk);\n\t\trepeat(50) @(posedge clk, negedge clk) begin\n\t\t\tena <= !($random & 7);\n\t\tend\n\t\treset <= 1'b1;\n\t\trepeat(5) @(posedge clk);\n\t\t\n\t\tif (bcd_fail)\n\t\t\t$display(\"Hint: Non-BCD values detected. Are you sure you're using two-digit BCD representation for hh, mm, and ss?\");\n\t\t\n\t\t#1 $finish;\n\tend\n\t\n\tendmodule\n\nmodule tb();\n\n\ttypedef struct packed {\n\t\tint errors;\n\t\tint errortime;\n\t\tint errors_pm;\n\t\tint errortime_pm;\n\t\tint errors_hh;\n\t\tint errortime_hh;\n\t\tint errors_mm;\n\t\tint errortime_mm;\n\t\tint errors_ss;\n\t\tint errortime_ss;\n\t\tint clocks;\n\t} stats;\n\t\n\tstats stats1;\n\t\n\t\n\twire[511:0] wavedrom_title;\n\twire wavedrom_enable;\n\tint wavedrom_hide_after_time;\n\t\n\treg clk=0;\n\tinitial forever\n\t\t#5 clk = ~clk;\n\n\tlogic reset;\n\tlogic ena;\n\tlogic pm_ref;\n\tlogic pm_dut;\n\tlogic [7:0] hh_ref;\n\tlogic [7:0] hh_dut;\n\tlogic [7:0] mm_ref;\n\tlogic [7:0] mm_dut;\n\tlogic [7:0] ss_ref;\n\tlogic [7:0] ss_dut;\n\n\t// --- Queueing Setup for Improved Testing ---\n\t// Max queue size set to 10 as per instructions for control.\n\tlocalparam MAX_QUEUE_SIZE = 10;\n\n\t// Inputs\n\treg clk_q_data; // Since clk is a clock, we track the state relevant to state change detection\n\treg reset_q_data;\n\treg ena_q_data;\n\t\n\t// Outputs (Dut & Ref)\n\treg pm_got_q_data;\n\treg [7:0] hh_got_q_data;\n\treg [7:0] mm_got_q_data;\n\treg [7:0] ss_got_q_data;\n\t\n\treg pm_exp_q_data;\n\treg [7:0] hh_exp_q_data;\n\treg [7:0] mm_exp_q_data;\n\treg [7:0] ss_exp_q_data;\n\n\t// Queues\n\treg clk_queue [$];\n\treg reset_queue [$];\n\treg ena_queue [$];\n\treg pm_got_queue [$];\n\treg [7:0] hh_got_queue [$];\n\treg [7:0] mm_got_queue [$];\treg [7:0] ss_got_queue [$];\n\treg pm_exp_queue [$];\n\treg [7:0] hh_exp_queue [$];\n\treg [7:0] mm_exp_queue [$];\treg [7:0] ss_exp_queue [$];\n\n\t// --- Signal Declarations --- \n\twire tb_match;\n\twire tb_mismatch = ~tb_match;\n\t\n\tinitial begin \n\t\t$dumpfile(\"wave.vcd\");\n\t\t$dumpvars(1, stim1.clk, tb_mismatch ,clk,reset,ena,pm_ref,pm_dut,hh_ref,hh_dut,mm_ref,mm_dut,ss_ref,ss_dut );\n\tend\n\n\t// Instantiate stimulus generator\n\tstimulus_gen stim1 (\n\t\t.clk, \n\t\t.reset, \n\t\tena, \n\t\thh_dut, mm_dut, ss_dut, \n\t\tpm_dut, \n\t\ttb_match,\n\t\twavedrom_title, \n\t\twavedrom_enable\n\t);\n\n\t// Reference Model\t\n\tRefModule good1 (\n\t\t.clk, \n\t\t.reset, \n\t\tena,\n\t\t.pm(pm_ref),\n\t\thh(hh_ref),\n\t\t.mm(mm_ref),\n\t\tss(ss_ref) );\n\t\n\t// DUT\t\n\tTopModule top_module1 (\n\t\t.clk, \n\t\t.reset, \n\t\tena,\n\t\t.pm(pm_dut),\n\t\thh(hh_dut),\n\t\t.mm(mm_dut),\n\t\tss(ss_dut) );\n\n\t\n\tbit strobe = 0;\n\ttask wait_for_end_of_timestep;\n\t\trepeat(5) begin\n\t\tstrobe <= !strobe;  // Try to delay until the very end of the time step.\n\t\t@(strobe);\n\t\tendtask\n\t\n\t// Verification logic (Original functionality maintained)\n\tassign tb_match = ( { pm_ref, hh_ref, mm_ref, ss_ref } === ( { pm_ref, hh_ref, mm_ref, ss_ref } ^ { pm_dut, hh_dut, mm_dut, ss_dut } ^ { pm_ref, hh_ref, mm_ref, ss_ref } ) );\n\n\t// --- Queueing and Mismatch Detection Logic ---\n\talways @(posedge clk, negedge clk) begin\n\t\t// 1. Maintain Queue Size\n\t\tif (reset_queue.size() >= MAX_QUEUE_SIZE - 1) begin\n\t\t\treset_queue.delete(0);\n\t\t\tena_queue.delete(0);\n\t\t\tpm_got_queue.delete(0);\n\t\t\thh_got_queue.delete(0);\n\t\t\tmm_got_queue.delete(0);\n\t\t\tss_got_queue.delete(0);\n\t\t\tpm_exp_queue.delete(0);\n\t\t\thh_exp_queue.delete(0);\n\t\t\tmm_exp_queue.delete(0);\n\t\t\tss_exp_queue.delete(0);\n\t\tend\n\n\t\t// 2. Push Current Data (Clock edge synchronized)\n\t\tclk_queue.push_back(clk);\n\t\treset_queue.push_back(reset);\n\t\tena_queue.push_back(ena);\n\t\tpm_got_queue.push_back(pm_dut);\n\t\thh_got_queue.push_back(hh_dut);\n\t\tmm_got_queue.push_back(mm_dut);\n\t\tss_got_queue.push_back(ss_dut);\n\t\tpm_exp_queue.push_back(pm_ref);\n\t\thh_exp_queue.push_back(hh_ref);\n\t\tmm_exp_queue.push_back(mm_ref);\n\t\tss_exp_queue.push_back(ss_ref);\n\n\t\t// 3. Update Stats (Original logic maintained)\n\t\tstats1.clocks++;\n\t\tif (!tb_match) begin\n\t\t\tif (stats1.errors == 0) stats1.errortime = $time;\n\t\t\tsstats1.errors++;\n\t\t\tend\n\t\tif (pm_ref !== ( pm_ref ^ pm_dut ^ pm_ref ))\n\t\t\tbegin if (stats1.errors_pm == 0) stats1.errortime_pm = $time;\n\t\t\tsstats1.errors_pm = stats1.errors_pm+1'b1; end\n\t\tif (hh_ref !== ( hh_ref ^ hh_dut ^ hh_ref ))\n\t\t\tbegin if (stats1.errors_hh == 0) stats1.errortime_hh = $time;\n\t\t\tsstats1.errors_hh = stats1.errors_hh+1'b1; end\n\t\tif (mm_ref !== ( mm_ref ^ mm_dut ^ mm_ref ))\n\t\t\tbegin if (stats1.errors_mm == 0) stats1.errortime_mm = $time;\n\t\t\tsstats1.errors_mm = stats1.errors_mm+1'b1; end\n\t\tif (ss_ref !== ( ss_ref ^ ss_dut ^ ss_ref ))\n\t\t\tbegin if (stats1.errors_ss == 0) stats1.errortime_ss = $time;\n\t\t\tsstats1.errors_ss = stats1.errors_ss+1'b1; end\n\tend\n\n\t// 4. Mismatch Detection & Queue Display (New implementation)\n\talways @(posedge clk, negedge clk)\n\tbegin\n\t\tif (!tb_match) begin\n\t\t\t$display(\"\\n============================================================\");\n\t\t\t$display(\"FIRST MISMATCH DETECTED AT TIME %0t\", $time);\n\t\t\t$display(\"============================================================\");\n\t\t\t$display(\"Displaying last %d cycles of simulation history:\", MAX_QUEUE_SIZE);\n\n\t\t\tfor (int i = 0; i < reset_queue.size(); i++) begin\n\t\t\t\t// Check match status for this cycle in the queue\n\t\t\t\tif (pm_got_queue[i] === pm_exp_queue[i] && hh_got_queue[i] === hh_exp_queue[i] && mm_got_queue[i] === mm_exp_queue[i] && ss_got_queue[i] === ss_exp_queue[i]) begin\n\t\t\t\t\t$display(\"Cycle %d: MATCHED\", i);\n\t\t\t\tend else begin\n\t\t\t\t\t$display(\"Cycle %d: MISMATCHED\", i);\n\t\t\t\tend\n\t\t\t\t// Display details\n\t\t\t\t$display(\"  Time: %0t | Reset: %b | Ena: %b\", $time - (reset_queue.size() - 1 - i)*5, reset_queue[i], ena_queue[i]);\n\t\t\t\t$display(\"  Inputs: clk=%b\", clk_queue[i]);\n\t\t\t\t$display(\"  Outputs: PM Got=%b, HH Got=%0h, MM Got=%0h, SS Got=%0h | PM Exp=%b, HH Exp=%0h, MM Exp=%0h, SS Exp=%0h\",\n\t\t\t\t\tpm_got_queue[i], hh_got_queue[i], mm_got_queue[i], ss_got_queue[i],\n\t\t\t\t\tpm_exp_queue[i], hh_exp_queue[i], mm_exp_queue[i], ss_exp_queue[i]);\n\t\t\t\t// Binary format for multi-bit signals <= 64 bits\n\t\t\t\t$display(\"  Outputs Binary: PM Got=%b, HH Got=%b, MM Got=%b, SS Got=%b\",\n\t\t\t\t\tpm_got_queue[i], hh_got_queue[i], mm_got_queue[i], ss_got_queue[i]);\n\t\t\t\t$display(\"  Expected Binary: PM Exp=%b, HH Exp=%b, MM Exp=%b, SS Exp=%b\\n\",\n\t\t\t\t\tpm_exp_queue[i], hh_exp_queue[i], mm_exp_queue[i], ss_exp_queue[i]);\n\t\t\tend\n\t\t\tend\n\t\t\t$display(\"============================================================\");\n\t\tend\n\tend\n\n\t// add timeout after 100K cycles\n\tinitial begin\n\t\t#1000000\n\t\t$display(\"\\nTIMEOUT REACHED.\");\n\t\t$finish();\n\tend\n\n\t// Final Simulation Conclusion (Replaces original hint reporting)\n\tinitial begin\n\t\t// Wait a bit for potential final queue updates\n\t\t#100;\n\t\t\n\t\tif (stats1.errors == 0)\n\t\t\t$display(\"\\n*************************************\");\n\t\t\t$display(\"SIMULATION PASSED\");\n\t\t\t$display(\"*************************************\");\n\t\telse\n\t\t\t$display(\"\\n*************************************\");\n\t\t\t$display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\", stats1.errors, stats1.errortime);\n\t\t\t$display(\"*************************************\");\n\t\tend\n\tendmodule"
