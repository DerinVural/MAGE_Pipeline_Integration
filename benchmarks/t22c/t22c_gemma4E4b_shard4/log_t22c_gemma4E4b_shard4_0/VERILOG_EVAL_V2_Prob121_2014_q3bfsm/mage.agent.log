module TopModule (
    input clk,
    input reset,
    input x,
    output z
);
    // FSM Implementation based on specification
    logic [2:0] state;
    logic [2:0] next_state;
    
    always @(posedge clk)
    begin
        if (reset) begin
            state <= 3'b000;
        end else begin
            state <= next_state;
        end
    end

    always @(*) begin
        next_state = state;
        z = 1'b0;

        case (state) 
            3'b000: begin
                if (x == 0) next_state = 3'b000;
                else next_state = 3'b001;
                z = 1'b0;
            end
            3'b001: begin
                if (x == 0) next_state = 3'b001;
                else next_state = 3'b100;
                z = 1'b0;
            end
            3'b010: begin
                if (x == 0) next_state = 3'b010;
                else next_state = 3'b001;
                z = 1'b0;
            end
            3'b011: begin
                if (x == 0) next_state = 3'b001;
                else next_state = 3'b010;
                z = 1'b1;
            end
            3'b100: begin
                if (x == 0) next_state = 3'b011;
                else next_state = 3'b100;
                z = 1'b1;
            end
            default: next_state = 3'b000; // Safety
        endcase
    end

endmodule


module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_z;
		int errortime_z;
		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic reset;
	logic x;
	logic z_ref;
	logic z_dut;

	// --- Queue Definitions for Mismatch Detection ---
	// State size is 3 bits, MAX_QUEUE_SIZE = 8
	localparam MAX_QUEUE_SIZE = 8;
	
	// Queue elements must match the width of the signals
	reg [1:0] x_queue [MAX_QUEUE_SIZE-1:0]; // x is 1 bit
	reg z_dut_queue [MAX_QUEUE_SIZE-1:0];   // z is 1 bit
	reg z_ref_queue [MAX_QUEUE_SIZE-1:0];   // z_ref is 1 bit
	reg reset_queue [MAX_QUEUE_SIZE-1:0];   // reset is 1 bit
	
	// Tracking first mismatch time for queue reporting
	reg mismatch_detected_flag = 0;
	reg [63:0] first_mismatch_time = 0;
	
	// --- Testbench Setup ---
	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,clk,reset,x,z_ref,z_dut );
	end

	wire tb_match; 
	// Original verification logic implies z_ref === z_dut
	assign tb_match = ( z_ref === z_dut );
	
	stimulus_gen stim1 (
		.clk, 
		.reset, // Note: The golden testbench uses .* here, but stimulus_gen only defines reset/x outputs, so we map explicitly.
		x, 
		.clk, // Required by stim1 definition, though redundant if map is used
		.reset, // Required by stim1 definition
		.x
	);
	RefModule good1 (
		.clk, 
		.reset, 
		x, 
		z_ref 
	);
	
	TopModule top_module1 (
		.clk, 
		.reset, 
		x, 
		z_dut 
	);

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end
task

	// Queueing and Verification Logic
	always @(posedge clk, negedge clk) begin
		stats1.clocks++;

		// 1. Queue Management: Shift data if full
		if (input_queue.size() >= MAX_QUEUE_SIZE) begin
			// Since we are using fixed arrays/FIFO logic conceptually, we shift all elements
			for (int i = 0; i < MAX_QUEUE_SIZE - 1; i++) begin
				x_queue[i] <= x_queue[i+1];
			z_dut_queue[i] <= z_dut_queue[i+1];
			z_ref_queue[i] <= z_ref_queue[i+1];
			reset_queue[i] <= reset_queue[i+1];
			end
		end

		// 2. Push current data to the last slot
		x_queue[MAX_QUEUE_SIZE-1] <= x;
		z_dut_queue[MAX_QUEUE_SIZE-1] <= z_dut;
		z_ref_queue[MAX_QUEUE_SIZE-1] <= z_ref;
		reset_queue[MAX_QUEUE_SIZE-1] <= reset;

		// 3. Check for mismatch and update error counts
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time; // Original logic
			stats1.errors++;
			end
		
		// Update Z error count (following original complex logic, although redundant with tb_match)
		if (z_ref !== ( z_ref ^ z_dut ^ z_ref ))
		begin 
			if (stats1.errors_z == 0) stats1.errortime_z = $time;
			sstats1.errors_z = stats1.errors_z+1'b1;
		end
		
		// 4. Queue Mismatch Detection (New Requirement)
		if (!mismatch_detected_flag && !tb_match) begin
			mismatch_detected_flag = 1;
			first_mismatch_time = $time;
			$display("\n=======================================================================");
			$display("QUEUE-BASED MISMATCH DETECTED AT TIME %0t", $time);
			$display("\nLast %0d cycles of simulation:", MAX_QUEUE_SIZE);

			// Display Queue Content
			for (int i = 0; i < MAX_QUEUE_SIZE; i++) begin
				// Check if the sample at index i was a match (This is complex to track perfectly, 
				// we display the values and note the mismatch occurred at the latest time step).
				// Since we only flag the *first* mismatch, we display all stored data up to this point.
				$display("Cycle %d, reset %b, input x=%b, got output z_dut=%b, exp output z_ref=%b",
				i,
				reset_queue[i],
				x_queue[i],
				z_dut_queue[i],
				z_ref_queue[i]
			);
			end
			$display("=======================================================================");
		end
		end

	// add timeout after 100K cycles
	initial begin
		#1000000
		if (!mismatch_detected_flag) begin
			$display("SIMULATION PASSED");
		end else begin
			$display("SIMULATION FAILED - x MISMATCHES DETECTED, FIRST AT TIME %0d", first_mismatch_time);
		end
		$finish();
	end

endmodule
