0)\n132: \t\t\t$display("SIMULATION PASSED");\n133: \t\telse\n134: \t\t\t$display("SIMULATION FAILED - x MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.first_mismatch_time);\n135: \t\t$display("========================================");\n136: \tend\n137: \n138: \t// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.\n139: \tassign tb_match = ( { z_ref } === ( { z_ref } ^ { z_dut } ^ { z_ref } ) );\n140: \n141: \t// Use explicit sensitivity list here.\n142: \talways @(posedge clk, negedge clk) begin\n143: \t\tstats1.clocks++;\n144: \n145: \t\t// --- General Mismatch Check ---\n146: \t\tif (!tb_match) begin\n147: \t\t\tif (stats1.errors == 0) begin\n148: \t\t\t\tstats1.errortime = $time;\n149: \t\t\t\tstats1.first_mismatch_time = $time;\n150: \t\t\t\tstats1.first_error_type = 0; // General mismatch\n151: \t\t\tend\n152: \t\t\tsstats1.errors++;\n153: \t\t\t\n154: \t\t\t// Display details on first mismatch\n155: \t\t\tif (stats1.errors == 1) begin\n156: \t\t\t\t$display("\\n!!! FIRST GENERAL MISMATCH DETECTED AT TIME %0d !!!", $time);\n157: \t\t\t\t$display("Inputs: clk=%b, reset=%b, x=%b", clk, reset, x);\n158: \t\t\t\t$display("Outputs: z_dut=%b (0x%h), z_ref=%b (0x%h)", z_dut, z_dut, z_ref, z_ref);\n159: \t\t\tend\n160: \t\tend\n161: \n162: \t\t// --- Z Output Mismatch Check ---\n163: \t\tif (z_ref !== ( z_ref ^ z_dut ^ z_ref ))\n164: \t\tbegin \n165: \t\t\tif (stats1.errors_z == 0) begin\n166: \t\t\t\tstats1.errortime_z = $time;\n167: \t\t\t\tstats1.first_mismatch_time = $time;\n168: \t\t\t\tstats1.first_error_type = 1; // Z output mismatch\n169: \t\t\tend\n170: \t\t\tsstats1.errors_z = stats1.errors_z+1\'b1;\n171: \t\t\t\n172: \t\t\t// Display details on first Z output mismatch\n173: \t\t\tif (stats1.errors_z == 1) begin\n174: \t\t\t\t$display("\\n!!! FIRST Z OUTPUT MISMATCH DETECTED AT TIME %0d !!!", $time);\n175: \t\t\t\t$display("Inputs: clk=%b, reset=%b, x=%b", clk, reset, x);\n176: \t\t\t\t$displ