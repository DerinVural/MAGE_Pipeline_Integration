`define INCORRECT 13

// =====================================================================
// Stimulus Generator (Kept from original golden testbench)
// =====================================================================
module stimulus_gen (
	input clk,
	output logic [7:0] in,
	output logic reset
);
	initial begin
		$display("--- Stimulus Generator Starting ---");
		repeat(200) @(negedge clk) begin
			in <= $random;
			reset <= !($random & 31);
		end
		reset <= 1'b0;
		in <= '0;
		repeat(10) @(posedge clk);
		
		$display("--- Starting Randomized Test Sequence ---");
		repeat(200) begin
			in <= $random;
			in[3] <= 1'b1;
		@(posedge clk);
			in <= $random;
		@(posedge clk);
			in <= $random;
		@(posedge clk);
		end
		#1 $finish;
	end
	endmodule

// =====================================================================
// Top Level Testbench (Improved) 
// =====================================================================
module tb();

	// --- Statistics Structure (Maintained) ---
	typedef struct packed {
		int errors;
		int errortime;
		int errors_out_bytes;
		int errortime_out_bytes;
		int errors_done;
		int errortime_done;
		int clocks;
	} stats;
	
	stats stats1;
	
	// --- Waveform Dumping Setup (Maintained) ---
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	// --- Clock Generation ---
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	// --- Signals ---
	logic [7:0] in;
	logic reset;
	logic [23:0] out_bytes_ref; // Golden reference output
	logic [23:0] out_bytes_dut; // DUT output
	logic done_ref;
	logic done_dut;

	// --- Mismatch Detection ---
	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	// --- Queue Definitions for Detailed Logging ---
	// State is sequential, MAX_QUEUE_SIZE = 10
	localparam MAX_QUEUE_SIZE = 10;

	reg [7:0] input_data_q [$];
	reg [23:0] got_output_q [$];
	reg [23:0] golden_output_q [$];
	reg reset_q [$];
	reg [7:0] input_in_q [$]; // Storing 'in' as 8-bit
	reg [23:0] out_bytes_dut_q [$];
	reg [23:0] out_bytes_ref_q [$];
	reg done_dut_q [$];
	reg done_ref_q [$];
	
	// Variables to track first mismatch time from queue mechanism
	reg first_mismatch_time_q = 0;
	reg detailed_log_triggered = 0;

	// --- Initialization & Dumping ---
	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch, clk, in, reset, out_bytes_ref, out_bytes_dut, done_ref, done_dut );
		end

	// --- Instantiations ---
	stimulus_gen stim1 (
		.clk, 
		in, 
		.reset );
	
	// Golden Reference Module (Assuming RefModule exists and matches TopModule interface)
	RefModule good1 (
		.clk,
		in,
		.reset,
		.out_bytes(out_bytes_ref),
		.done(done_ref) );
	
	// Device Under Test (DUT)
	TopModule top_module1 (
		.clk,
		in,
		.reset,
		.out_bytes(out_bytes_dut),
		.done(done_dut) );

	// --- Helper Task (Maintained) ---
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end
task

	// --- Mismatch Logic (Combined tracking and queue logging) ---
	// Reset logic for tracking errors
	initial begin
		stats1.errors = 0;
		stats1.errors_out_bytes = 0;
		stats1.errors_done = 0;
		stats1.errortime = 0;
		stats1.errortime_out_bytes = 0;
		stats1.errortime_done = 0;
		stats1.clocks = 0;
		detailed_log_triggered = 0;
	end

	// Synchronous update and mismatch detection
	always @(posedge clk, negedge clk) begin
		if (reset) begin
			// Reset queues and flags
			input_data_q.delete();
			got_output_q.delete();
			golden_output_q.delete();
			reset_q.delete();
			input_in_q.delete();
			out_bytes_dut_q.delete();
			out_bytes_ref_q.delete();
			done_dut_q.delete();
			done_ref_q.delete();
			detailed_log_triggered = 0;
		end
		else begin
			// 1. Update Statistics
			stats1.clocks++;
			
			// 2. Store data into queues
			input_data_q.push_back(in);
			got_output_q.push_back(out_bytes_dut);
			golden_output_q.push_back(out_bytes_ref);
			reset_q.push_back(reset);
			input_in_q.push_back(in);
			out_bytes_dut_q.push_back(out_bytes_dut);
			out_bytes_ref_q.push_back(out_bytes_ref);
			done_dut_q.push_back(done_dut);
			done_ref_q.push_back(done_ref);
		
			// 3. Check for mismatch
			tb_match = ( { out_bytes_ref, done_ref } === ( { out_bytes_dut, done_dut } ));

			if (!tb_match) begin
				// Update general error count
				if (stats1.errors == 0) stats1.errortime = $time;
				stats1.errors++;

				// Check for specific signal mismatches and update error counters
				if (out_bytes_ref !== out_bytes_dut) begin
					if (stats1.errors_out_bytes == 0) stats1.errortime_out_bytes = $time;
				stats1.errors_out_bytes = stats1.errors_out_bytes + 1'b1;
				end
				if (done_ref !== done_dut) begin
				if (stats1.errors_done == 0) stats1.errortime_done = $time;
				stats1.errors_done = stats1.errors_done + 1'b1;
				end
				
				// 4. Trigger detailed log if not already triggered
				if (detailed_log_triggered == 0) begin
					detailed_log_triggered = 1;
					first_mismatch_time_q = $time;
					$display("========================================================================");
					$display("*** DETAILED MISMATCH LOG TRIGGERED AT TIME %0t ***", $time);
					$display("Last %0d cycles of simulation leading to mismatch:", MAX_QUEUE_SIZE);
					
					for (int i = 0; i < input_data_q.size(); i++) begin
						// Determine match status based on the current comparison
						if (out_bytes_ref_q[i] === out_bytes_dut_q[i] && done_ref_q[i] === done_dut_q[i]) begin
							$display("Cycle %0d: Match", i);
						end else begin
							$display("Cycle %0d: *** MISMATCH ***", i);
						end
						$display("  Cycle %0d, Reset: %b, In: %h, Ref Out: %h, DUT Out: %h, Ref Done: %b, DUT Done: %b",
						i,
						reset_q[i],
						input_in_q[i],
						out_bytes_ref_q[i],
						out_bytes_dut_q[i],
						done_ref_q[i],
						done_dut_q[i]);
					end
					$display("========================================================================");
				end
			end
		end
	end

	// --- Finalization ---
	initial begin
		@(negedge clk);
		#10; // Wait for one last cycle to ensure all logging is done
		
		$display("\n============================================================");
		$display("Final Simulation Summary:");
		
		if (stats1.errors == 0) begin
			$display("SIMULATION PASSED");
		end else begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0t", stats1.errors, stats1.errortime);
		end
		
		// Maintain original hints for backward compatibility/debugging
		if (stats1.errors_out_bytes) $display("Hint: Output 'out_bytes' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_out_bytes, stats1.errortime_out_bytes);
		else $display("Hint: Output 'out_bytes' has no mismatches.");
		if (stats1.errors_done) $display("Hint: Output 'done' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_done, stats1.errortime_done);
		else $display("Hint: Output 'done' has no mismatches.");
		$display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
		$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
		end

	// Add timeout after 100K cycles (Maintained)
	initial begin
		#1000000
		$display("TIMEOUT REACHED");
		$finish();
	end

endmodule

