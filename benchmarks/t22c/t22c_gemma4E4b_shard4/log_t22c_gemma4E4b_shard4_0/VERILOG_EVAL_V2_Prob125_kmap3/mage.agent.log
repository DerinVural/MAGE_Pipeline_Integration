            // cd=10 (Row 4) -> ab=01(0), 00(1), 10(1), 11(1)
            4'b0110: out = 1'b0; // 0 (ab=01, cd=10)
            4'b0010: out = 1'b1; // 1 (ab=00, cd=10)
            4'b1010: out = 1'b1; // 1 (ab=10, cd=10)
            4'b1110: out = 1'b1; // 1 (ab=11, cd=10)

            default: out = 1'b0;
        endcase
