splay(\"!!! FIRST MISMATCH DETECTED !!! at time %0t\", $time);\n\t\t\t$display(\"=====================================================================\");\n\t\t\t$display(\"Time: %0t ps\", $time);\n\t\t\t$display(\"Input X: %b (Hex: %h)\", x, x);\n\t\t\t$display(\"Input Y: %b (Hex: %h)\", y, y);\n\t\t\t$display(\"Got Output Z_DUT: %b (Hex: %h)\", z_dut, z_dut);\n\t\t\t$display(\"Expected Output Z_REF: %b (Hex: %h)\", z_ref, z_ref);\n\t\t\tend\n\tend\n\n\n\t// Final simulation completion block\n\tinitial begin\n\t\t// Wait for the stimulus generator to finish its sequence\n\t\twait (stim1.done);\n\t\t// Ensure a few more cycles pass to settle any latches before final check\n\t\t@(posedge clk);\n\t\t@(posedge clk);\n\n\t\tif (stats1.errors == 0) begin\n\t\t\t$display(\"SIMULATION PASSED\");\n\t\tend else begin\n\t\t\t$display(\"SIMULATION FAILED - x MISMATCHES DETECTED, FIRST AT TIME %0d\", stats1.first_mismatch_time);\n\t\tend\n\t\t$finish;\n\tend\n\n\n\t// add timeout after 100K cycles (Maintaining original functionality)\n\tinitial begin\n\t\t#1000000\n\t\t$display(\"TIMEOUT\");\n\t\t$finish();\n\tend\n\nendmodule\n"
