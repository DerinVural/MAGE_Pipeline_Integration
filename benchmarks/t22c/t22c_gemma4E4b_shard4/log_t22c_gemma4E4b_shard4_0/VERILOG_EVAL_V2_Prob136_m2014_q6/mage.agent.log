module tb();

    // --- Structure Definitions and Constants ---
    typedef struct packed {
        int errors;
        int errortime;
        int errors_z;
        int errortime_z;
        int clocks;
    } stats;
    
    stats stats1;
    
    // State definition for queue sizing (6 states -> need >= 6, capped at 10)
    localparam MAX_QUEUE_SIZE = 10;

    // --- Signal Declarations ---
    wire[511:0] wavedrom_title; // Unused in logic but kept for fidelity
    wire wavedrom_enable;       // Unused in logic but kept for fidelity
    int wavedrom_hide_after_time; // Unused in logic but kept for fidelity
    
    reg clk=0;
    initial forever
        #5 clk = ~clk;

    logic reset;
    logic w;
    logic z_ref;
    logic z_dut;

    wire tb_match;
    wire tb_mismatch = ~tb_match;

    // --- Queue Declarations for Queue-based Verification ---
    // Inputs: clk, reset, w (1-bit signals, but queue stores vectors for consistency)
    reg input_clk_q [$];
    reg input_reset_q [$];
    reg input_w_q [$];
    
    // Outputs
    reg got_output_z_q [$];
    reg golden_output_z_q [$];
    
    // Error tracking related state
    reg error_primary_q [$]; // Tracks if tb_match failed
    reg error_secondary_q [$]; // Tracks if z_ref !== ( z_ref ^ z_dut ^ z_ref ) failed
    
    // --- Initialization and Dumping ---
    initial begin 
        $dumpfile("wave.vcd");
        // Note: Original dumpvars used stim1.clk, tb_mismatch, tb_match, clk, reset, w, z_ref, z_dut.
        // We stick to the original dumpvars structure as much as possible.
        $dumpvars(1, stim1.clk, tb_mismatch, clk, reset, w, z_ref, z_dut);
    end

    // --- Instantiations ---
    stimulus_gen stim1 (
        .clk, 
        .reset, 
        .w 
    );

    RefModule good1 (
        .clk, 
        .reset, 
        .w,
        .z(z_ref) 
    );
        
    TopModule top_module1 (
        .clk,
        .reset,
        .w,
        .z(z_dut) 
    );

    // --- Tasks ---
    bit strobe = 0;
    task wait_for_end_of_timestep;
        repeat(5) begin
            strobe <= !strobe;  // Try to delay until the very end of the time step.
            @(strobe);
        end
    endtask

    // --- Verification Logic (Replacing old always block) ---
    // Keep the original assignment logic for tb_match as per golden testbench structure
    assign tb_match = ( { z_ref } === ( { z_ref } ^ { z_dut } ^ { z_ref } ) );

    // --- Queue Management and Mismatch Checking (Replacing old error counting) ---
    always @(posedge clk, negedge clk) begin
        // 1. Queue Management: Shift and Push
        if (input_clk_q.size() >= MAX_QUEUE_SIZE - 1) begin
            input_clk_q.delete(0);
            input_reset_q.delete(0);
            input_w_q.delete(0);
            got_output_z_q.delete(0);
            golden_output_z_q.delete(0);
            error_primary_q.delete(0);
            error_secondary_q.delete(0);
        end

        // Push current state data
        input_clk_q.push_back(clk);
        input_reset_q.push_back(reset);
        input_w_q.push_back(w);
        got_output_z_q.push_back(z_dut);
        golden_output_z_q.push_back(z_ref);
        
        // Track error conditions based on original logic
        error_primary_q.push_back(tb_mismatch);
        error_secondary_q.push_back((z_ref !== ( z_ref ^ z_dut ^ z_ref )));
        
        // 2. Check for First Mismatch (Primary Error: tb_mismatch)
        if (tb_mismatch && error_primary_q.size() == 1) begin // Check only on the first occurrence
            $display("Mismatch detected at time %0t", $time);
            $display("\nLast %0d cycles of simulation (Primary Mismatch Triggered):", input_clk_q.size());
            
            for (int i = 0; i < input_clk_q.size(); i++) begin
                // We are comparing the state that *caused* the mismatch to the state *before* it, 
                // but per prompt, we display the queue content up to the error.
                if (!error_primary_q[i]) begin
                    $display("Got Match at Cycle %0d", i);
                end else begin
                    $display("Got Mismatch at Cycle %0d", i);
                end
                
                // Displaying the required signals
                $display("Cycle %0d, reset %b, input w %b, got output z %b, exp output z %b",
                    i, 
                    input_reset_q[i], 
                    input_w_q[i], 
                    got_output_z_q[i], 
                    golden_output_z_q[i]
                );
            end
            // Stop further error logging upon first primary mismatch if desired, though we let the loop run for comprehensive logging.
        end
        
        // 3. Secondary Error Tracking (Corresponds to stats1.errors_z)
        // We track the count separately using the queue size for consistency with the prompt's structure.
        if (error_secondary_q[error_secondary_q.size()-1] && stats1.errors_z == 0) begin
             stats1.errortime_z = $time;
        end
        if (error_secondary_q[error_secondary_q.size()-1]) begin
             stats1.errors_z = stats1.errors_z + 1'
        end

        // 4. Primary Error Counting (Corresponds to stats1.errors)
        if (tb_mismatch) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors = stats1.errors + 1'
        end
    end

    // --- Test Sequence Execution ---
    initial begin 
        $display("--- Starting Simulation ---");
        // Run the stimulus generator for 200 cycles (as in original golden testbench)
        @(posedge clk);
        repeat(200) @(posedge clk);
        
        // Wait for the time step task to potentially stabilize signals before finishing
        wait_for_end_of_timestep(); 
        #1 $finish; 
    end

    // --- Timeout ---
    initial begin
     #1000000
     $display("TIMEOUT");
     $finish();
   end

    // --- Final Report (Replaced old final block) ---
    initial begin
        @(negedge clk);
        // Wait until simulation is clearly done or reaches the end signal
        @(posedge clk);

        $display("\n========================================");
        
        if (stats1.errors == 0 && stats1.errors_z == 0) begin
            $display("SIMULATION PASSED");
        end else begin
            int total_mismatches = stats1.errors + stats1.errors_z;
            int first_mismatch_time = (stats1.errors == 0) ? stats1.errortime_z : stats1.errortime;
            
            // Determine the earliest time a mismatch occurred
            int earliest_time = (stats1.errors > 0 && stats1.errors_z > 0) ? (stats1.errortime < stats1.errortime_z ? stats1.errortime : stats1.errortime_z) : 
                                (stats1.errors > 0 ? stats1.errortime : stats1.errortime_z);

            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", total_mismatches, earliest_time);
        end
        $display("========================================");
    end

endmodule

