n_mispredicted,\n\t\ttrain_taken,\n\t\ttrain_history,\n\t\t.predict_history(predict_history_ref) );\n\t\nTopModule top_module1 (\n\t\t.clk,\n\t\tareset,\n\t\t.predict_valid,\n\t\t.predict_taken,\n\t\ttrain_mispredicted,\n\t\ttrain_taken,\n\t\ttrain_history,\n\t\t.predict_history(predict_history_dut) );\n\t\n\n\tbit strobe = 0;\n\ttask wait_for_end_of_timestep;\n\t\trepeat(5) begin\n\t\tstrobe <= !strobe;  // Try to delay until the very end of the time step.\n\t\t@(strobe);\n\t\tendtask\t\n\n\t// Variables to capture state at first mismatch\n\tlogic [31:0] captured_inputs_hist;\n\tlogic [31:0] captured_outputs_hist;\n\tlogic [31:0] captured_expected_hist;\n\t\n\t// Flag to ensure state capture only happens once per type of error\n\t\n\tfinal begin\n\t\t// --- Detailed Mismatch Display for predict_history ---\n\t\tif (stats1.errors_predict_history > 0) begin\n\t\t\t$display(\"\n========================================================\");\n\t\t\t$display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\", stats1.errors_predict_history, stats1.errortime_predict_history);\n\t\t\t$display(\"\n--- FIRST MISMATCH DETAILS (predict_history) ---\");\n\t\t\t$display(\"Time: %0d ps\", stats1.errortime_predict_history);\n\t\t\t$display(\"Inputs at mismatch time:\");\n\t\t\t$display(\"  predict_valid: %b\", predict_valid);\n\t\t\t$display(\"  predict_taken: %b\", predict_taken);\n\t\t\t$display(\"  train_mispredicted: %b\", train_mispredicted);\n\t\t\t$display(\"  train_taken: %b\", train_taken);\n\t\t\t$display(\"  train_history: HEX=%h / BIN=%b\", train_history, train_history);\n\t\t\t$display(\"Outputs at mismatch time:\");\n\t\t\t$display(\"  predict_history_DUT: HEX=%h / BIN=%b\", predict_history_dut, predict_history_dut);\n\t\t\t$display(\"Expected Output (Ref): HEX=%h / BIN=%b\", predict_history_ref, predict_history_ref);\n\t\t\t$display(\"========================================================\n\");\n\t\tend\n\t\t\n\t\t// --- Overall Error Display ---\n\t\