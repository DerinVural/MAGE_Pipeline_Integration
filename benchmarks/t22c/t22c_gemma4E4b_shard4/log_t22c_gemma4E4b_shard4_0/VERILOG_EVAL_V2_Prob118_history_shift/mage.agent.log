			if (predict_history_ref !== ( predict_history_ref ^ predict_history_dut ^ predict_history_ref ))
			begin 
				if (stats1.errors_predict_history == 0) stats1.errortime_predict_history = $time;
			stats1.errors_predict_history++;
			end
			end
		
			// add timeout after 100K cycles
			initial begin
				#1000000
				$display("TIMEOUT");
				$finish();
			end
		end

endmodule
