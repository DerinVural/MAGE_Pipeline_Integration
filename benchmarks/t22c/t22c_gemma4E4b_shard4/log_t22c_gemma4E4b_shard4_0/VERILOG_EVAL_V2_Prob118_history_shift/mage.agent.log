module tb();

	// --- Statistics and Queue Setup ---
	typedef struct packed {
		int errors;
		int errortime;
		int errors_predict_history;
		int errortime_predict_history;

		int clocks;
	} stats;
	
	stats stats1;
	
	// Queue-based simulation mismatch display setup
	reg [31:0] input_queue [$];
	reg [31:0] got_output_queue [$];
	reg [31:0] golden_queue [$];
	reg reset_queue [$];
	
	localparam MAX_QUEUE_SIZE = 10; // Max size set to 10 as per requirement

	// Output signal widths
	localparam PREDICT_HISTORY_WIDTH = 32;
	
	// --- Waveform Control Signals ---
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	// --- Clock Generation ---
	reg clk=0;
	initial forever
		h#5 clk = ~clk;

	// --- DUT Interface Signals ---
	logic areset;
	logic predict_valid;
	logic predict_taken;
	logic train_mispredicted;
	logic train_taken;
	logic [31:0] train_history;
	logic [31:0] predict_history_ref; // Golden Reference
	logic [31:0] predict_history_dut; // DUT Output

	// --- Initial Dump Setup ---
	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stimulus_gen.clk, tb_mismatch ,clk,areset,predict_valid,predict_taken,train_mispredicted,train_taken,train_history,predict_history_ref,predict_history_dut );
	end

	wire tb_match; 
	wire tb_mismatch = ~tb_match;
	
	// --- Module Instantiations ---
	stimulus_gen stim1 (
		.clk, 
		areset, 
		.predict_valid, 
		.predict_taken, 
		train_mispredicted, 
		train_taken, 
		train_history, 
		.tb_match, // Connected to tb_match wire
		.wavedrom_title, 
		.wavedrom_enable, 
		.wavedrom_hide_after_time 
	);
	
	RefModule good1 (
		.clk, 
		areset, 
		.predict_valid, 
		.predict_taken, 
		train_mispredicted, 
		train_taken, 
		train_history, 
		.predict_history(predict_history_ref) 
	);
	
	TopModule top_module1 (
		.clk, 
		areset, 
		.predict_valid, 
		.predict_taken, 
		train_mispredicted, 
		train_taken, 
		train_history, 
		.predict_history(predict_history_dut) 
	);

	
	// --- Helper Task ---
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end
task;

	// --- Verification Assignment ---
	// Original assignment logic for tb_match
	assign tb_match = ( { predict_history_ref } === ( { predict_history_ref } ^ { predict_history_dut } ^ { predict_history_ref } ) );

	// --- Core Verification and Logging Block (Sequential) ---
	always @(posedge clk, negedge clk) begin
		
		// 1. Queue Management (Shift) - Only push data when clock edge occurs
		if (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin
			input_queue.delete(0);
			got_output_queue.delete(0);
			golden_queue.delete(0);
			reset_queue.delete(0);
		end

		// 2. Store current state
		input_queue.push_back({predict_valid, predict_taken, train_mispredicted, train_taken, train_history});
		got_output_queue.push_back(predict_history_dut);
		golden_queue.push_back(predict_history_ref);
		reset_queue.push_back(areset);
		
		// 3. Check for first mismatch (Tracking Errors)
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			sstats1.errors++;
		end

		// 4. Check for first mismatch (Predict History Specific Tracking)
		if (predict_history_ref !== predict_history_dut) begin
			if (stats1.errors_predict_history == 0) stats1.errortime_predict_history = $time;
			sstats1.errors_predict_history++;
		end

		// 5. Queue Display Logic (If mismatch detected on this cycle)
		if (!tb_match) begin
			$display("\n========================================================================");
			$display("MISMATCH DETECTED AT TIME %0d", $time);
			$display("--- Showing Last %0d Cycles of Simulation (Mismatch Detected) ---", input_queue.size());
			
			for (int i = 0; i < input_queue.size(); i++) begin
				// Check if this specific cycle resulted in a mismatch
				if (i == input_queue.size() - 1 && !tb_match) begin
					s$display("*** ERROR LOCATION *** Cycle %d: Got Output Mismatch!
", i);
				end
				
				// Display cycle data
				$display("Cycle %d, Reset %b, Input: V=%b, PT=%b, TM=%b, T_Taken=%b, T_Hist=%h | Got Hist: %h | Exp Hist: %h",
				i,
				reset_queue[i],
				input_queue[i][31:0], // Train History is 32 bits, but we only push the tuple
				input_queue[i][31:31], // Assuming only relevant bits are packed for display brevity if needed, but let's show the tuple
				predict_valid_from_tuple(i), // Helper to extract tuple bits
				predict_taken_from_tuple(i),
				train_mispredicted_from_tuple(i),
				train_taken_from_tuple(i),
				input_queue[i][31:0], // Displaying the combined input tuple (not clean, but follows queue structure)
				got_output_queue[i], // Got Predict History
				golden_queue[i]  // Expected Predict History
			);
			}
		end
	end

	// Helper functions to extract inputs from the packed tuple stored in input_queue (which is 32 bits wide)
	function automatic bit predict_valid_from_tuple(int i); return input_queue[i][31]; endfunction
	function automatic bit predict_taken_from_tuple(int i); return input_queue[i][30]; endfunction
	function automatic bit train_mispredicted_from_tuple(int i); return input_queue[i][29]; endfunction
	function automatic bit train_taken_from_tuple(int i); return input_queue[i][28]; endfunction

	// --- Clock/Reset Initialization ---
	initial begin
		areset = 1;
		@(posedge clk);
		areset = 0;
	end

	// --- Finalization ---
	initial begin
		@(negedge clk);
		#1000000 // Wait for simulation end condition
		
		// Final check and required display format
		if (stats1.errors == 0 && stats1.errors_predict_history == 0)
			s$display("SIMULATION PASSED");
		else begin
			s$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
		end
		$finish();
	end

endmodule

