al forever\n\t\th#5 clk = ~clk;\n\n\tlogic areset;\n\tlogic bump_left;\n\tlogic bump_right;\n\tlogic ground;\n\tlogic dig;\n\tlogic walk_left_ref;\n\tlogic walk_left_dut;\n\tlogic walk_right_ref;\n\tlogic walk_right_dut;\n\tlogic aaah_ref;\n\tlogic aaah_dut;\n\tlogic digging_ref;\n\tlogic digging_dut;\n\n\t// Signals for queue tracking\n\tlogic [1:0] input_data;\n\tlogic [3:0] output_data;\n\tlogic [3:0] golden_output_data;\n\tlogic [1:0] reset_data;\n\n\t// Queue definitions\n\treg [1:0] input_queue [$];\n\treg [3:0] got_output_queue [$];\n\treg [3:0] golden_queue [$];\t\n\tlocalparam MAX_QUEUE_SIZE = 10;\n\n\tinitial begin \n\t\t$dumpfile("wave.vcd");\n\t\t$dumpvars(1, stim1.clk, tb_mismatch ,clk,areset,bump_left,bump_right,ground,dig,walk_left_ref,walk_left_dut,walk_right_ref,walk_right_dut,aaah_ref,aaah_dut,digging_ref,digging_dut );\n\tend\n\n\t// Define reference outputs as 4-bit vectors for easy queue comparison\n\tassign golden_output_data = {walk_left_ref, walk_right_ref, aaah_ref, digging_ref};\n\tassign output_data = {walk_left_dut, walk_right_dut, aaah_dut, digging_dut};\n\n\t//tb_match logic is complex in the original, we simplify it to check if DUT matches REF\n\twire tb_mismatch = (golden_output_data !== output_data);\n\t\n\t// --- Queue Management and Mismatch Detection (Synchronous) ---\n\talways @(posedge clk, negedge clk) begin\n\t\tif (!areset) begin\n\t\t\t// Reset handling for queues\n\t\t\tinput_queue.delete();\n\t\t\tgot_output_queue.delete();\n\t\t\tgolden_queue.delete();\n\t\tend\n\n\t\t// Store current state data\n\t\tinput_queue.push_back({bump_left, bump_right}); // Simplified input tracking based on used bits\n\t\tgot_output_queue.push_back(output_data);\n\t\tgolden_queue.push_back(golden_output_data);\n\t\t// Reset tracking is implicit in the queue logic\n\n\t\t// Maintain queue size\n\t\tif (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin\n\t\t\tinput_queue.delete(0);\n\t\t\tgot_output_queue.delete(0);\n\t\t\tgolden_queue.delete(0);\n\t\tend\n\n\t\t// Check for first mismatch\n\t\tif (tb_mismatch && stats1.errors == 0) begin\n\t\t\t// First mismatch detected\n\t\t\t$display("Mismatch detected at time %0t", $time);\n\t\t\t$display("\\nLast %0d cycles of simulation:", input_queue.size());\n\n\t\t\tfor (int i = 0; i < input_queue.size(); i++) begin\n\t\t\t\t// Since we are tracking the state leading up to the mismatch, we check the stored values\n\t\t\t\t$display("Cycle %d, input %b, got output %h, exp output %h",\n\t\t\t\ti,\n\t\t\t\tinput_queue[i],\n\t\t\t\tgot_output_queue[i],\n\t\t\t\tgolden_queue[i]);\n\t\t\tend\n\t\t\t// Set error flag to prevent further reporting in the final block\n\t\t\tstats1.errors = 1;\n\t\tend\n\tend\n\n\t// --- Original Testbench Structure --- \n\t\n\tstimulus_gen stim1 (\n\t\t.clk, \n\t\t.areset, \n\t\t.bump_left, \n\t\t.bump_right, \n\t\t.ground, \n\t\t.dig, \n\t\t.wavedrom_title, \n\t\t.wavedrom_enable, \n\t\t.tb_match \n\t);\n\tRefModule good1 (\n\t\t.clk, \n\t\t.areset, \n\t\t.bump_left, \n\t\t.bump_right, \n\t\t.ground, \n\t\t.dig,\n\t\t.walk_left(walk_left_ref),\n\t\t.walk_right(walk_right_ref),\n\t\t.aaah(aaah_ref),\n\t\tdigging(digging_ref) );\n\t\n\tTopModule top_module1 (\n\t\t.clk,\n\t\tareset,\n\t\tbump_left,\n\t\tbump_right,\n\t\t.ground,\n\t\tdig,\n\t\t.walk_left(walk_left_dut),\n\t\t.walk_right(walk_right_dut),\n\t\taaah(aaah_dut),\n\t\tdigging(digging_dut) );\n\n\t\n\tbit strobe = 0;\n\ttask wait_for_end_of_timestep;\n\t\trepeat(5) begin\n\t\tstrobe <= !strobe;  // Try to delay until the very end of the time step.\n\t\t@(strobe);\n\t\tend\n\ttask\n\n\t\n\tfinal begin\n\t\tif (stats1.errors == 0) begin\n\t\t$display("SIMULATION PASSED");\n\t\t// Display specific success messages if necessary, maintaining original intent\n\t\t$display("Hint: All outputs matched reference.");\n\t\tend\n\t\telse begin\n\t\t// Find the first error time, which was recorded in the queue check logic above.\n\t\t// Since the queue logic stops reporting on the first error, we use the stored errortime if it was populated,\n\t\t// otherwise, we default to the time the error was detected (which is complex to extract perfectly here without modifying the queue block further).\n\t\t// Relying on the queue block to have set stats1.errors=1 and printing the data.\n\t\t$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);\n\t\tend\n\tend\n\n\t// Original error counting logic is deprecated/replaced by queue mechanism for the final check.\n\t// Keeping original logic structure for stats counting placeholder if needed for debugging, but the final output relies on queue detection.\n\talways @(posedge clk, negedge clk) begin\n\t\tstats1.clocks++;\n\t\t// Simplified error counting based on the queue mechanism result\n\t\tif (tb_mismatch) begin\n\t\t\tif (stats1.errors == 0) stats1.errortime = $time;\n\t\t\ts$display("Internal error count incremented.");\n\t\tend\n\tend\n\n\t// add timeout after 100K cycles\n\tinitial begin\n\t\t#1000000\n\t\t$display("TIMEOUT");\n\t\t$finish();\n\tend\n\nendmodule\n\n</testbench>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nThe module interface is given below:\n<module_interface>\nmodule TopModule (\n    input  clk,\n    input  areset,\n    input  bump_left,\n    input  bump_right,\n    input  ground,\n    input  dig,\n    output walk_left,\n    output walk_right,\n    output aaah,\n    output digging\n);\nendmodule\n\n</module_interface>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nYour response will be processed by a program, not human.\nSo, please STRICTLY FOLLOW the output format given as XML tag content below to generate a VALID JSON OBJECT:\n<output_format>\n{\n    "reasoning": "All reasoning steps and advices to avoid syntax error",\n    "module": "Pure SystemVerilog code, a complete module"\n}\n</output_format>\n