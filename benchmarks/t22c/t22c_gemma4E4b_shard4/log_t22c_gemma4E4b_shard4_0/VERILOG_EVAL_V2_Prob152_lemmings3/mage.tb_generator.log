e = S_WALK_R;\n102:                 end\n103:                 S_DIG_L, S_DIG_R: begin\n104:                     // If digging stops (dig=0) while on ground, resume walking in the direction of the last active dig state\n105:                     if (current_state == S_DIG_L) next_state = S_WALK_L;\n106:                     else next_state = S_WALK_R;\n107:                 end\n108:                 default: next_state = S_WALK_L; // Should not happen\n109:             endcase\n110:         end\n111:     end\n112: \n113:     // Moore Output Logic (Outputs depend only on current_state)\n114:     always @(*)\n115:     begin\n116:         // Default outputs\n117:         walk_left = 1\'b0;\n118:         walk_right = 1\'b0;\n119:         aaah = 1\'b0;\n120:         digging = 1\'b0;\n121: \n122:         case (current_state)\n123:             S_WALK_L: begin\n124:                 walk_left = 1\'b1;\n125:             end\n126:             S_WALK_R: begin\n127:                 walk_right = 1\'b1;\n128:             end\n129:             S_FALL: begin\n130:                 aaah = 1\'b1;\n131:             end\n132:             S_DIG_L: begin\n133:                 digging = 1\'b1;\n134:             end\n135:             S_DIG_R: begin\n136:                 digging = 1\'b1;\n137:             end\n138:         endcase\n139:     end\n140: \n141: endmodule\n\n</previous_code>\n<previous_tb>\n1: `timescale 1 ps/1 ps\n2: `define OK 12\n3: `define INCORRECT 13\n4: \n5: \n6: module stimulus_gen (\n7: \t\tinput clk,\n8: \t\toutput logic areset,\n9: \t\toutput logic bump_left,\n10: \t\toutput logic bump_right,\n11: \t\toutput logic dig,\n12: \t\toutput logic ground,\n13: \t\toutput reg[511:0] wavedrom_title,\n14: \t\toutput reg wavedrom_enable,\n15: \t\tinput tb_match\n16: );\n17: \t\treg reset;\n18: \t\tassign areset = reset;\n19: \n20: \t\ttask reset_test(input async=0);\n21: \t\t\tbit arfail, srfail, datafail;\n22: \t\t\t\n23: \t\t\t@(posedge clk);\n24: \t\t\t@(posedge clk) reset <= 0;\n2