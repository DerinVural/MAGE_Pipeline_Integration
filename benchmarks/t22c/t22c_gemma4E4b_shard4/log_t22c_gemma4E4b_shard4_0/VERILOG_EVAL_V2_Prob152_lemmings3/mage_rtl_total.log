,\n            output logic out\n        );\n\n            assign out = in0 ^ in1;\n\n        endmodule\n    </module>\n</example>\nExample 2:\n<example>\n    <input_spec>\n        Implement the SystemVerilog module based on the following description.\n        Assume that sigals are positive clock/clk triggered unless otherwise stated.\n\n        The module should implement an 8-bit registered incrementer.\n        The 8-bit input is first registered and then incremented by one on the next cycle.\n        The reset input is active high synchronous and should reset the output to zero.\n    </input_spec>\n    <module>\n        module TopModule(\n            input  logic       clk,\n            input  logic       reset,\n            input  logic [7:0] in_,\n            output logic [7:0] out\n        );\n\n            // Sequential logic\n            logic [7:0] reg_out;\n            always @( posedge clk ) begin\n                if ( reset )\n                reg_out <= 0;\n                else\n                reg_out <= in_;\n            end\n\n            // Combinational logic\n            logic [7:0] temp_wire;\n            always @(*) begin\n                temp_wire = reg_out + 1;\n            end\n\n            // Structural connections\n            assign out = temp_wire;\n\n        endmodule\n    </module>\n</example>\nExample 3:\n<example>\n    <input_spec>\n        Implement the SystemVerilog module based on the following description.\n        Assume that sigals are positive clock/clk triggered unless otherwise stated.\n\n        The module should implement an n-bit registered incrementer where the bitwidth is specified by the parameter nbits.\n        The n-bit input is first registered and then incremented by one on the next cycle.\n        The reset input is active high synchronous and should reset the output to zero.\n    </input_spec>\n    <module>\n        module TopModule #(\n            parameter nbits\n        )(\n            input  logic             clk,\n            input  logic             reset,\n            input  logic [nbits-1:0] in_,\n            output logic [nbits-1:0] out\n        );\n\n            // Sequential logic\n            logic [nbits-1:0] reg_out;\n            always @( posedge clk ) begin\n                if ( reset )\n                reg_out <= 0;\n                else\n                reg_out <= in_;\n            end\n\n            // Combinational logic\n            logic [nbits-1:0] temp_wire;\n            always @(*) begin\n                temp_wire = reg_out + 1;\n            end\n\n            // Structural connections\n            assign out = temp_wire;\n\n        endmodule\n    </module>\n</example>\nExample 4:\n<example>\n    <input_spec>\n        Implement the SystemVerilog module based on the following description.\n        Assume that sigals are positive clock/clk triggered unless otherwise stated.\n\n        Build a finite-state machine that takes as input a serial bit stream,\n            and outputs a one whenever the bit stream contains two consecutive one\'s.\n        The output is one on the cycle _after_ there are two consecutive one\'s.\n        The reset input is active high synchronous,\n            and should reset the finite-state machine to an appropriate initial state.\n    </input_spec>\n    <module>\n        module TopModule(\n            input  logic clk,\n            input  logic reset,\n            input  logic in_,\n            output logic out\n        );\n\n            // State enum\n            localparam STATE_A = 2\'b00;\n            localparam STATE_B = 2\'b01;\n            localparam STATE_C = 2\'b10;\n\n            // State register\n            logic [1:0] state;\n            logic [1:0] state_next;\n            always @(posedge clk) begin\n                if ( reset )\n                state <= STATE_A;\n                else\n                state <= state_next;\n            end\n\n            // Next state combinational logic\n            always @(*) begin\n                state_next = state;\n                case ( state )\n                STATE_A: state_next = ( in_ ) ? STATE_B : STATE_A;\n                STATE_B: state_next = ( in_ ) ? STATE_C : STATE_A;\n                STATE_C: state_next = ( in_ ) ? STATE_C : STATE_A;\n                endcase\n            end\n\n            // Output combinational logic\n            always @(*) begin\n                out = 1\'b0;\n                case ( state )\n                STATE_A: out = 1\'b0;\n                STATE_B: out = 1\'b0;\n                STATE_C: out = 1\'b1;\n                endcase\n            end\n\n        endmodule\n    </module>\n</example>\n\n<input_spec>\n\nI would like you to implement a module named TopModule with the following\ninterface. All input and output ports are one bit unless otherwise\nspecified.\n\n - input  clk\n - input  areset\n - input  bump_left\n - input  bump_right\n - input  ground\n - input  dig\n - output walk_left\n - output walk_right\n - output aaah\n - output digging\n\nThe game Lemmings involves critters with fairly simple brains. So simple\nthat we are going to model it using a finite state machine. In the\nLemmings\' 2D world, Lemmings can be in one of two states: walking left\n(walk_left is 1) or walking right (walk_right is 1). It will switch\ndirections if it hits an obstacle. In particular, if a Lemming is bumped\non the left (by receiving a 1 on bump_left), it will walk right. If it\'s\nbumped on the right (by receiving a 1 on bump_right), it will walk left.\nIf it\'s bumped on both sides at the same time, it will still switch\ndirections.\n\nIn addition to walking left and right and changing direction when bumped,\nwhen ground=0, the Lemming will fall and say "aaah!". When the ground\nreappears (ground=1), the Lemming will resume walking in the same\ndirection as before the fall. Being bumped while falling does not affect\nthe walking direction, and being bumped in the same cycle as ground\ndisappears (but not yet falling), or when the ground reappears while\nstill falling, also does not affect the walking direction.\n\nIn addition to walking and falling, Lemmings can sometimes be told to do\nuseful things, like dig (it starts digging when dig=1). A Lemming can dig\nif it is currently walking on ground (ground=1 and not falling), and will\ncontinue digging until it reaches the other side (ground=0). At that\npoint, since there is no ground, it will fall (aaah!), then continue\nwalking in its original direction once it hits ground again. As with\nfalling, being bumped while digging has no effect, and being told to dig\nwhen falling or when there is no ground is ignored. (In other words, a\nwalking Lemming can fall, dig, or switch directions. If more than one of\nthese conditions are satisfied, fall has higher precedence than dig,\nwhich has higher precedence than switching directions.)\n\nImplement a Moore state machine that models this behaviour. areset is\npositive edge triggered asynchronous reseting the Lemming machine to walk\nleft. Assume all sequential logic is triggered on the positive edge of\nthe clock.\n\n\n\n</input_spec>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nAnother agent has generated a testbench regarding the given input_spec:\n<testbench>\n`timescale 1 ps/1 ps\n`define OK 12\n`define INCORRECT 13\n\n\nmodule stimulus_gen (\n\tinput clk,\n\toutput logic areset,\n\toutput logic bump_left,\n\toutput logic bump_right,\n\toutput logic dig,\n\toutput logic ground,\n\toutput reg[511:0] wavedrom_title,\n\toutput reg wavedrom_enable,\n\tinput tb_match\n);\n\treg reset;\n\tassign areset = reset;\n\n\ttask reset_test(input async=0);\n\t\tbit arfail, srfail, datafail;\n\t\t\n\t\t@(posedge clk);\n\t\t@(posedge clk) reset <= 0;\n\t\trepeat(3) @(posedge clk);\n\t\t\n\t\t@(negedge clk) begin datafail = !tb_match ; reset <= 1; end\n\t\t@(posedge clk) arfail = !tb_match;\n\t\t@(posedge clk) begin\n\t\t\tsrfail = !tb_match;\n\t\t\tsreset <= 0;\n\t\tend\n\t\tif (srfail)\n\t\t\ts$display("Hint: Your reset doesn\'t seem to be working.");\n\t\telse if (arfail && (async || !datafail))\n\t\t\ts$display("Hint: Your reset should be %0s, but doesn\'t appear to be.", async ? "asynchronous" : "synchronous");\n\t\t// Don\'t warn about synchronous reset if the half-cycle before is already wrong. It\'s more likely\n\t\t// a functionality error than the reset being implemented asynchronously.\n\tendtask\n\n\n// Add two ports to module stimulus_gen:\n//    output [511:0] wavedrom_title\n//    output reg wavedrom_enable\n\n\ttask wavedrom_start(input[511:0] title = "");\n\tendtask\n\t\n\ttask wavedrom_stop;\n\t\th#1;\n\tendtask\n\t\n\t\n\twire [0:13][3:0] d = {\n\t\t4\'h2,\n\t\t4\'h2,\n\t\t4\'h3,\n\t\t4\'h2,\n\t\t4\'ha,\n\t\t4\'h2,\n\t\t4\'h0,\n\t\t4\'h0,\n\t\t4\'h0,\n\t\t4\'h3,\n\t\t4\'h2,\n\t\t4\'h2,\n\t\t4\'h2,\n\t\t4\'h2\n\t};\n\t\n\tinitial begin\n\t\treset <= 1\'b1;\n\t\t{bump_left, bump_right, ground, dig} <= 4\'h2;\n\t\treset_test(1);\n\n\t\treset <= 1\'b1;\n\t\t@(posedge clk);\n\t\treset <= 0;\n\t\t\n\t\t@(negedge clk);\n\t\twavedrom_start("Digging");\n\t\tfor (int i=0;i<14;i++)\n\t\t\t@(posedge clk) {bump_left, bump_right, ground, dig} <= d[i];\n\t\twavedrom_stop();\n\t\t\n\t\trepeat(400) @(posedge clk, negedge clk) begin\n\t\t\t{dig, bump_right, bump_left} <= $random & $random;\n\t\t\tground <= |($random & 7);\n\t\t\treset <= !($random & 31);\n\t\tend\n\n\t\th#1 $finish;\n\tend\n\t\nendmodule\n\nmodule tb();\n\n\ttypedef struct packed {\n\t\tint errors;\n\t\tint errortime;\n\t\tint errors_walk_left;\n\t\tint errortime_walk_left;\n\t\tint errors_walk_right;\n\t\tint errortime_walk_right;\n\t\tint errors_aaah;\n\t\tint errortime_aaah;\n\t\tint errors_digging;\n\t\tint errortime_digging;\n\n\t\tint clocks;\n\t} stats;\n\t\n\tstats stats1;\n\t\n\t\n\twire[511:0] wavedrom_title;\n\twire wavedrom_enable;\n\tint wavedrom_hide_after_time;\n\t\n\treg clk=0;\n\tinitial forever\n\t\th#5 clk = ~clk;\n\n\tlogic areset;\n\tlogic bump_left;\n\tlogic bump_right;\n\tlogic ground;\n\tlogic dig;\n\tlogic walk_left_ref;\n\tlogic walk_left_dut;\n\tlogic walk_right_ref;\n\tlogic walk_right_dut;\n\tlogic aaah_ref;\n\tlogic aaah_dut;\n\tlogic digging_ref;\n\tlogic digging_dut;\n\n\t// Signals for queue tracking\n\tlogic [1:0] input_data;\n\tlogic [3:0] output_data;\n\tlogic [3:0] golden_output_data;\n\tlogic [1:0] reset_data;\n\n\t// Queue definitions\n\treg [1:0] input_queue [$];\n\treg [3:0] got_output_queue [$];\n\treg [3:0] golden_queue [$];\t\n\tlocalparam MAX_QUEUE_SIZE = 10;\n\n\tinitial begin \n\t\t$dumpfile("wave.vcd");\n\t\t$dumpvars(1, stim1.clk, tb_mismatch ,clk,areset,bump_left,bump_right,ground,dig,walk_left_ref,walk_left_dut,walk_right_ref,walk_right_dut,aaah_ref,aaah_dut,digging_ref,digging_dut );\n\tend\n\n\t// Define reference outputs as 4-bit vectors for easy queue comparison\n\tassign golden_output_data = {walk_left_ref, walk_right_ref, aaah_ref, digging_ref};\n\tassign output_data = {walk_left_dut, walk_right_dut, aaah_dut, digging_dut};\n\n\t//tb_match logic is complex in the original, we simplify it to check if DUT matches REF\n\twire tb_mismatch = (golden_output_data !== output_data);\n\t\n\t// --- Queue Management and Mismatch Detection (Synchronous) ---\n\talways @(posedge clk, negedge clk) begin\n\t\tif (!areset) begin\n\t\t\t// Reset handling for queues\n\t\t\tinput_queue.delete();\n\t\t\tgot_output_queue.delete();\n\t\t\tgolden_queue.delete();\n\t\tend\n\n\t\t// Store current state data\n\t\tinput_queue.push_back({bump_left, bump_right}); // Simplified input tracking based on used bits\n\t\tgot_output_queue.push_back(output_data);\n\t\tgolden_queue.push_back(golden_output_data);\n\t\t// Reset tracking is implicit in the queue logic\n\n\t\t// Maintain queue size\n\t\tif (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin\n\t\t\tinput_queue.delete(0);\n\t\t\tgot_output_queue.delete(0);\n\t\t\tgolden_queue.delete(0);\n\t\tend\n\n\t\t// Check for first mismatch\n\t\tif (tb_mismatch && stats1.errors == 0) begin\n\t\t\t// First mismatch detected\n\t\t\t$display("Mismatch detected at time %0t", $time);\n\t\t\t$display("\\nLast %0d cycles of simulation:", input_queue.size());\n\n\t\t\tfor (int i = 0; i < input_queue.size(); i++) begin\n\t\t\t\t// Since we are tracking the state leading up to the mismatch, we check the stored values\n\t\t\t\t$display("Cycle %d, input %b, got output %h, exp output %h",\n\t\t\t\ti,\n\t\t\t\tinput_queue[i],\n\t\t\t\tgot_output_queue[i],\n\t\t\t\tgolden_queue[i]);\n\t\t\tend\n\t\t\t// Set error flag to prevent further reporting in the final block\n\t\t\tstats1.errors = 1;\n\t\tend\n\tend\n\n\t// --- Original Testbench Structure --- \n\t\n\tstimulus_gen stim1 (\n\t\t.clk, \n\t\t.areset, \n\t\t.bump_left, \n\t\t.bump_right, \n\t\t.ground, \n\t\t.dig, \n\t\t.wavedrom_title, \n\t\t.wavedrom_enable, \n\t\t.tb_match \n\t);\n\tRefModule good1 (\n\t\t.clk, \n\t\t.areset, \n\t\t.bump_left, \n\t\t.bump_right, \n\t\t.ground, \n\t\t.dig,\n\t\t.walk_left(walk_left_ref),\n\t\t.walk_right(walk_right_ref),\n\t\t.aaah(aaah_ref),\n\t\tdigging(digging_ref) );\n\t\n\tTopModule top_module1 (\n\t\t.clk,\n\t\tareset,\n\t\tbump_left,\n\t\tbump_right,\n\t\t.ground,\n\t\tdig,\n\t\t.walk_left(walk_left_dut),\n\t\t.walk_right(walk_right_dut),\n\t\taaah(aaah_dut),\n\t\tdigging(digging_dut) );\n\n\t\n\tbit strobe = 0;\n\ttask wait_for_end_of_timestep;\n\t\trepeat(5) begin\n\t\tstrobe <= !strobe;  // Try to delay until the very end of the time step.\n\t\t@(strobe);\n\t\tend\n\ttask\n\n\t\n\tfinal begin\n\t\tif (stats1.errors == 0) begin\n\t\t$display("SIMULATION PASSED");\n\t\t// Display specific success messages if necessary, maintaining original intent\n\t\t$display("Hint: All outputs matched reference.");\n\t\tend\n\t\telse begin\n\t\t// Find the first error time, which was recorded in the queue check logic above.\n\t\t// Since the queue logic stops reporting on the first error, we use the stored errortime if it was populated,\n\t\t// otherwise, we default to the time the error was detected (which is complex to extract perfectly here without modifying the queue block further).\n\t\t// Relying on the queue block to have set stats1.errors=1 and printing the data.\n\t\t$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);\n\t\tend\n\tend\n\n\t// Original error counting logic is deprecated/replaced by queue mechanism for the final check.\n\t// Keeping original logic structure for stats counting placeholder if needed for debugging, but the final output relies on queue detection.\n\talways @(posedge clk, negedge clk) begin\n\t\tstats1.clocks++;\n\t\t// Simplified error counting based on the queue mechanism result\n\t\tif (tb_mismatch) begin\n\t\t\tif (stats1.errors == 0) stats1.errortime = $time;\n\t\t\ts$display("Internal error count incremented.");\n\t\tend\n\tend\n\n\t// add timeout after 100K cycles\n\tinitial begin\n\t\t#1000000\n\t\t$display("TIMEOUT");\n\t\t$finish();\n\tend\n\nendmodule\n\n</testbench>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nThe module interface is given below:\n<module_interface>\nmodule TopModule (\n    input  clk,\n    input  areset,\n    input  bump_left,\n    input  bump_right,\n    input  ground,\n    input  dig,\n    output walk_left,\n    output walk_right,\n    output aaah,\n    output digging\n);\nendmodule\n\n</module_interface>\n')]), ChatMessage(role=<MessageRole.ASSISTANT: 'assistant'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='{\n    "reasoning": "The requirement is to model the behavior of a Lemming using a Moore Finite State Machine (FSM). The FSM needs to track the Lemming\'s state and determine the outputs (walk_left, walk_right, aaah, digging) based on the current state and inputs.\\n\\n**1. State Definition:**\\nWe need to define states to capture all possible behavioral modes. The key behaviors are:\\n*   Walking Left (WL)\\n*   Walking Right (WR)\\n*   Falling (AAAH)\\n*   Digging (D)\\n*   Idle/Other (A - Initial/Default State)\\n\\nBased on the rules, the state must track the current walking direction (if walking) and whether it is currently falling or digging.\\n\\n*   **Walking States:** WL and WR. These states must also remember the intended direction.\\n*   **Falling State:** AAAH. This state is entered when ground=0 while walking or digging.\\n*   **Digging State:** D. This state is entered when dig=1 while walking on ground.\\n\\nLet\'s refine the state to track the primary mode and direction:\\n*   `STATE_WALK_LEFT`: Walking left on ground.\\n*   `STATE_WALK_RIGHT`: Walking right on ground.\\n*   `STATE_FALLING`: In the air (ground=0).\\n*   `STATE_DIGGING_LEFT`: Digging while intending to go left (if applicable, but since dig takes precedence over direction change, a simpler state might suffice).\\n*   `STATE_DIGGING_RIGHT`: Digging while intending to go right.\\n\\nGiven the precedence rules (Fall > Dig > Bumping), we need states that reflect the current stable activity.\\n\\n**State Mapping based on rules:**\\n1.  **Walking:** If `ground=1` and not digging/falling.\\n2.  **Digging:** If `dig=1` and `ground=1` (and not falling).\\n3.  **Falling:** If `ground=0` (or entered from digging).\\n4.  **Direction Change (Bump):** Affects the next walking state if not falling/digging.\\n\\nLet\'s use a state encoding that prioritizes the highest precedence event:\\n*   `S_WALK_L`: Walking Left.\\n*   `S_WALK_R`: Walking Right.\\n*   `S_FALL`: Falling (AAAH).\\n*   `S_DIG`: Digging (This implies ground=1 and dig=1).\\n\\n**Initial State:** `areset` active high synchronous resets to walk left (`S_WALK_L`).\\n\\n**State Transitions Logic (Next State Function):**\\n*   **If `areset` is high:** Next state = `S_WALK_L`.\\n*   **If `ground=0`:** Next state must be `S_FALL` (Highest precedence).\\n*   **If `ground=1` and `dig=1`:** Next state = `S_DIG` (Higher precedence than walking).\\n*   **If `ground=1` and `dig=0`:** State depends on current walking direction and bumps.\\n    *   If current state is `S_WALK_L` and `bump_left=1`: Switch to `S_WALK_R`.\\n    *   If current state is `S_WALK_L` and `bump_right=1`: Stay `S_WALK_L` (or switch logic if required, but bumping right on WL usually means continue WL unless rule says otherwise. The rule is: left bump -> walk right; right bump -> walk left. So, if WL, bump_right -> WR).\\n    *   If current state is `S_WALK_R` and `bump_left=1`: Switch to `S_WALK_R` (Wait, rule says left bump -> walk right. So, if WR, bump_left -> WL).\\n    *   If current state is `S_WALK_R` and `bump_right=1`: Switch to `S_WALK_L`.\\n\\n**Output Logic (Moore Machine):**\\nOutputs depend *only* on the current state:\\n*   `walk_left`: High if state is `S_WALK_L`.\\n*   `walk_right`: High if state is `S_WALK_R`.\\n*   `aaah`: High if state is `S_FALL`.\\n*   `digging`: High if state is `S_DIG`.\\n\\n**Handling Transitions:**\\n1.  **Walking -> Falling:** If currently walking (S_WALK_L/R) and `ground` goes to 0, transition to `S_FALL`. The original direction is *preserved* upon re-grounding.\\n2.  **Digging -> Falling:** If currently digging (`S_DIG`) and `ground` goes to 0, transition to `S_FALL`. The original direction is *preserved* upon re-grounding.\\n3.  **Falling -> Walking:** If currently falling (`S_FALL`) and `ground` goes to 1, transition back to the *original* walking direction stored implicitly or explicitly.\\n\\n**Refining State to Handle Direction Memory:**\\nThe FSM must remember the last non-falling/non-digging direction. We need to augment the state or use internal registers to store the intended direction.\\n\\nLet\'s use a 2-bit state encoding to manage direction and mode:\\n*   `S_WALK_L`: Walking Left (Direction = L).\\n*   `S_WALK_R`: Walking Right (Direction = R).\\n*   `S_FALL`: Falling (Direction is preserved from before falling).\\n*   `S_DIG`: Digging (Direction is preserved from before digging).\\n\\nWe need a register to store the \'intended direction\' when the Lemming is not in a purely temporary state like \'Falling\'. Let\'s use a `logic [0:0] direction_mem` register, where 0=Left, 1=Right.\\n\\n**Revised State Logic:**\\n\\n*   **State Register:** `state` (e.g., 2 bits for modes: Walk/Fall/Dig).\\n*   **Direction Register:** `direction_mem` (1 bit: 0=L, 1=R).\\n\\n**Initial State:** `state` initialized to Walk Left (e.g., 00), `direction_mem` initialized to 0.\\n\\n**Implementation Steps:**\\n1.  Define states (e.g., `S_WALK`, `S_FALL`, `S_DIG`).\\n2.  Define state registers and next state logic (synchronous).\\n3.  Define direction memory register and update logic.\\n4.  Define output logic (Moore, combinational).\\n5.  Handle precedence: Fall > Dig > Bump.\\n\\n*Self-Correction/Refinement on Direction Preservation:* When falling, the direction must be preserved. When exiting fall, it reverts to the preserved direction. When digging, it continues in the direction it was walking in before starting to dig, until it falls.\\n\\nThis FSM structure is complex due to the need to remember direction across state changes (falling/digging). We will use states to define the primary mode, and internal logic to manage direction.\\n\\n**Final State Structure:**\\nLet\'s define the states to capture the *current physical activity*:\\n*   `S_WALK_L`, `S_WALK_R`: Active walking.\\n*   `S_FALL`: In the air.\\n*   `S_DIG_L`, `S_DIG_R`: Active digging in a specific direction.\\n\\nWe need a memory (`direction_mem`) to store the last valid walking direction (L or R).\\n\\n**Precedence Implementation:**\\n*   If `ground == 0`: Always go to `S_FALL`, regardless of current state (Highest Precedence).\\n*   If `ground == 1` and `dig == 1`: Go to `S_DIG_L` or `S_DIG_R` based on `direction_mem` (Second Precedence).\\n*   If `ground == 1` and `dig == 0`: Proceed based on walking/bumping logic.\\n\\nThis structure covers all rules and adheres to Moore machine principles (outputs based only on state). The initial state must be Walk Left.",\n    "module": "module TopModule(\\n    input  logic clk,\\n    input  logic areset,\\n    input  logic bump_left,\\n    input  logic bump_right,\\n    input  logic ground,\\n    input  logic dig,\\n    output logic walk_left,\\n    output logic walk_right,\\n    output logic aaah,\\n    output logic digging\\n);\\n\\n    // --- State Definitions ---\\n    // States capture the current physical activity.\\n    typedef enum logic [1:0] {\\n        S_WALK_L, // Walking Left\\n        S_WALK_R, // Walking Right\\n        S_FALL,   // Falling (AAAH)\\n        S_DIG_L,  // Digging Left\\n        S_DIG_R   // Digging Right\\n    }\\fsm_state_t;\\n\\n    // --- State Registers and Memory ---\\n    fsm_state_t current_state, next_state;\\n    \\n    // Memory to store the Lemming\'s preferred walking direction (0=Left, 1=Right).\\n    // This is needed to resume walking after falling or to start digging in the correct direction.\\n    logic dir_mem_l; \\n\\n    // Sequential Logic (State Register & Memory Update)\\n    always @(posedge clk)\\n    begin\\n        if (areset)\\n        begin\\n            current_state <= S_WALK_L; // Reset to walk left\\n            dir_mem_l <= 1\'b0;          // Initialize direction memory to Left\\n        end\\n        else\\n        begin\\n            current_state <= next_state;\\n            \\n            // Update direction memory only when transitioning into a stable walking state \\n            // (and not during a bump/transition within a walking mode).\\n            case (next_state) \\n                S_WALK_L: dir_mem_l <= 1\'b0;\\n                S_WALK_R: dir_mem_l <= 1\'b1;\\n                S_DIG_L: dir_mem_l <= 1\'b0;\\n                S_DIG_R: dir_mem_l <= 1\'b1;\\n                default: dir_mem_l <= dir_mem_l; // Preserve direction during falling\\n            endcase\\n        end\\