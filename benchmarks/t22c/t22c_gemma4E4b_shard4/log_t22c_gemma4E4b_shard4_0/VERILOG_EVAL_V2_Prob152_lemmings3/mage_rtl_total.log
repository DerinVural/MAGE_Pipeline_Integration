 TopModule(\n2:     input  logic clk,\n3:     input  logic areset,\n4:     input  logic bump_left,\n5:     input  logic bump_right,\n6:     input  logic ground,\n7:     input  logic dig,\n8:     output logic walk_left,\n9:     output logic walk_right,\n10:     output logic aaah,\n11:     output logic digging\n12: );\n13: \n14:     // State Encoding (5 states require 3 bits: 000 to 100)\n15:     localparam S_WALK_L = 3\'b000;\n16:     localparam S_WALK_R = 3\'b001;\n17:     localparam S_FALL   = 3\'b010;\n18:     localparam S_DIG_L  = 3\'b011;\n19:     localparam S_DIG_R  = 3\'b100;\n20: \n21:     // --- State Registers and Memory ---\n22:     logic [2:0] current_state, next_state;\n23:     \n24:     // Memory to store the Lemming\'s preferred walking direction (0=Left, 1=Right).\n25:     logic dir_mem_l;\n26: \n27:     // Initialization Block (Requirement #3)\n28:     initial begin\n29:         current_state = S_WALK_L;\n30:         dir_mem_l = 1\'b0;\n31:     end\n32: \n33:     // Sequential Logic (State Register & Memory Update)\n34:     always @(posedge clk)\n35:     begin\n36:         if (areset)\n37:         begin\n38:             current_state <= S_WALK_L; // Reset to walk left\n39:             dir_mem_l <= 1\'b0;          // Initialize direction memory to Left\n40:         end\n41:         else\n42:         begin\n43:             current_state <= next_state;\n44:             \n45:             // Update direction memory only when transitioning into a stable walking state \n46:             case (next_state) \n47:                 S_WALK_L: dir_mem_l <= 1\'b0;\n48:                 S_WALK_R: dir_mem_l <= 1\'b1;\n49:                 S_DIG_L: dir_mem_l <= 1\'b0;\n50:                 S_DIG_R: dir_mem_l <= 1\'b1;\n51:                 default: dir_mem_l <= dir_mem_l; // Preserve direction during falling or unknown state\n52:             endcase\n53:         end\n54:     end\n55: \n56:     // Next State Combinational Logic\n57:     always @(*)\n58:     begin\n59:         next_state = current_state;\n60: \n61:         // 1. HIGHEST PRECEDENCE: FALLING (ground=0)\n62:         if (ground == 0) begin\n63:             next_state = S_FALL; // Always fall if ground disappears\n64:         end\n65: \n66:         // 2. SECOND PRECEDENCE: DIGGING (ground=1 and dig=1)\n67:         else if (ground == 1 && dig == 1) begin\n68:             // Digging continues in the previous direction memory\n69:             if (dir_mem_l == 1\'b0) begin\n70:                 next_state = S_DIG_L;\n71:             end else begin\n72:                 next_state = S_DIG_R;\n73:             end\n74:         end\n75: \n76:         // 3. LOWEST PRECEDENCE: WALKING / BUMPING (ground=1 and dig=0)\n77:         else if (ground == 1 && dig == 0) begin\n78:             case (current_state) \n79:                 S_WALK_L:\n80:                 begin\n81:                     // Bump Left -> Switch to Right\n82:                     if (bump_left) next_state = S_WALK_R;\n83:                     // Bump Right -> Switch to Left\n84:                     else if (bump_right) next_state = S_WALK_L;\n85:                     // No bump -> Stay\n86:                     else next_state = S_WALK_L;\n87:                 end\n88:                 S_WALK_R:\n89:                 begin\n90:                     // Bump Left -> Switch to Left\n91:                     if (bump_left) next_state = S_WALK_L;\n92:                     // Bump Right -> Switch to Right\n93:                     else if (bump_right) next_state = S_WALK_R;\n94:                     // No bump -> Stay\n95:                     else next_state = S_WALK_R;\n96:                 end\n97:                 // If in a non-walking state but ground reappears (e.g., falling back to ground), resume walking\n98:                 S_FALL: begin\n99:                     // Resume walking in the direction remembered before falling\n100:                     if (dir_mem_l == 1\'b0) next_state = S_WALK_L;\n101:                     else next_stat