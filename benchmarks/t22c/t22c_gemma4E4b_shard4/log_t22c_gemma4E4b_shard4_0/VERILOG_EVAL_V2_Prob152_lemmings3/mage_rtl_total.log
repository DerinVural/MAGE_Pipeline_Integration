urrent_state)\n123:             S_WALK_L: begin\n124:                 walk_left = 1\'b1;\n125:             end\n126:             S_WALK_R: begin\n127:                 walk_right = 1\'b1;\n128:             end\n129:             S_FALL: begin\n130:                 aaah = 1\'b1;\n131:             end\n132:             S_DIG_L: begin\n133:                 digging = 1\'b1;\n134:             end\n135:             S_DIG_R: begin\n136:                 digging = 1\'b1;\n137:             end\n138:         endcase\n139:     end\n140: \n141: endmodule\n\n</failed_rtl>\n<failed_testbench>\n1: `timescale 1 ps/1 ps\n2: `define OK 12\n3: `define INCORRECT 13\n4: \n5: \n6: module stimulus_gen (\n7: \tinput clk,\n8: \toutput logic areset,\n9: \toutput logic bump_left,\n10: \toutput logic bump_right,\n11: \toutput logic dig,\n12: \toutput logic ground,\n13: \toutput reg[511:0] wavedrom_title,\n14: \toutput reg wavedrom_enable,\n15: \tinput tb_match\n16: );\n17: \treg reset;\n18: \tassign areset = reset;\n19: \n20: \ttask reset_test(input async=0);\n21: \t\tbit arfail, srfail, datafail;\n22: \t\t\n23: \t\t@(posedge clk);\n24: \t\t@(posedge clk) reset <= 0;\n25: \t\trepeat(3) @(posedge clk);\n26: \t\t\n27: \t\t@(negedge clk) begin datafail = !tb_match ; reset <= 1; end\n28: \t\t@(posedge clk) arfail = !tb_match;\n29: \t\t@(posedge clk) begin\n30: \t\t\tsrfail = !tb_match;\n31: \t\t\tsreset <= 0;\n32: \t\tend\n33: \t\tif (srfail)\n34: \t\t\ts$display("Hint: Your reset doesn\'t seem to be working.");\n35: \t\telse if (arfail && (async || !datafail))\n36: \t\t\ts$display("Hint: Your reset should be %0s, but doesn\'t appear to be.", async ? "asynchronous" : "synchronous");\n37: \t\t// Don\'t warn about synchronous reset if the half-cycle before is already wrong. It\'s more likely\n38: \t\t// a functionality error than the reset being implemented asynchronously.\n39: \tendtask\n40: \n41: \n42: // Add two ports to module stimulus_gen:\n43: //    output [511:0] wavedrom_title\n44: //    output