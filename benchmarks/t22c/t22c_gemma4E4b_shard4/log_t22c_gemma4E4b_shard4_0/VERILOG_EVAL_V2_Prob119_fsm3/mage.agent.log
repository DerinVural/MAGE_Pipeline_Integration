        $dumpfile("wave.vcd");
        $dumpvars(1, stim1.clk, tb_mismatch, clk, in, areset, out_ref, out_dut, capture_in_sig, capture_areset_sig, capture_out_ref_sig, capture_out_dut_sig );
    end


    wire tb_match;
    wire tb_mismatch = ~tb_match;
    
