			@(posedge clk) in <= 0;
			@(posedge clk) in <= 1;
			@(posedge clk) in <= 0;
			@(posedge clk) in <= 1;
			@(posedge clk) in <= 1;
			@(posedge clk) in <= 1;
		@(negedge clk);
		wavedrom_stop();
		repeat(200) @(posedge clk, negedge clk) begin
		in <= $random;
		reset <= !($random & 31);
		end

		#1 $finish;
	end
	endmodule

module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_out;
		int errortime_out;

		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic in;
	logic areset;
	logic out_ref;
	logic out_dut;

	// Queue storage for sequential logic checking
	// Storing 1-bit values as logic type to simplify storage, although the queue definition uses reg.
	reg input_queue [$]; 
	reg got_output_queue [$]; 
	reg golden_queue [$]; 
	reg reset_queue [$]; 

	localparam MAX_QUEUE_SIZE = 10;
	reg mismatch_detected_flag = 0;

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stimulus_gen.clk, tb_mismatch, clk, in, areset, out_ref, out_dut );
	end

	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk, 
		.in, 
		.areset, 
		.tb_match
);
	RefModule good1 (
		.clk, 
		.in, 
		.areset, 
		.out(out_ref) );
	
	TopModule top_module1 (
		.clk, 
		.areset, 
		in, 
		out(out_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		endtask

	// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.
	assign tb_match = ( { out_ref } === ( { out_ref } ^ { out_dut } ^ { out_ref } ) );
	
	// Queue-based simulation mismatch display
	always @(posedge clk, negedge clk) begin
		
		// Store data in queue (storing 1-bit values as reg[0:0] for consistency)
		input_queue.push_back({in});
		got_output_queue.push_back({out_dut});
		golden_queue.push_back({out_ref});
		reset_queue.push_back({areset});

		// Manage queue size
		if (input_queue.size() >= MAX_QUEUE_SIZE) begin
			input_queue.delete(0);
			got_output_queue.delete(0);
			golden_queue.delete(0);
			reset_queue.delete(0);
		end
		
		// Check for first mismatch
		if (!tb_match && mismatch_detected_flag == 0) begin
			mismatch_detected_flag = 1;
			$display("\n==================================================================");
			$display("*** FIRST MISMATCH DETECTED AT TIME %0t ***", $time);
			$display("\nLast %0d cycles of simulation:", input_queue.size());

			for (int i = 0; i < input_queue.size(); i++) begin
				if (got_output_queue[i] === golden_queue[i]) begin
				$display("Cycle %0d: Got Match.", i);
				$display("  Cycle %0d, reset %b, input %b, got output %b, exp output %b",
				i, reset_queue[i], input_queue[i], got_output_queue[i], golden_queue[i]);
				$display("--------------------------------------------------");
			end else begin
				$display("Cycle %0d: Got Mismatch.", i);
				$display("  Cycle %0d, reset %b, input %b, got output %b, exp output %b",
				i, reset_queue[i], input_queue[i], got_output_queue[i], golden_queue[i]);
				end
			end
		$display("==================================================================\n");
		end

	// Original logic from golden testbench
	if (out_ref !== ( out_ref ^ out_dut ^ out_ref ))
	begin if (stats1.errors_out == 0) stats1.errortime_out = $time;
		s$display("Original Check Mismatch detected at time %0t", $time);
		sstats1.errors_out = stats1.errors_out+1'b1; 
	end
	end

	// Original logic for tb_match tracking (maintaining original error counting)
	if (!tb_match) begin
		if (stats1.errors == 0) stats1.errortime = $time;
		sstats1.errors++;
	end

	// add timeout after 100K cycles
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

	// Final check and display
	initial begin
		@(negedge clk);
		wait (mismatch_detected_flag || $time > 1000000);
		
		if (mismatch_detected_flag == 0) begin
			$display("SIMULATION PASSED");
			$display("Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
			$display("Simulation finished at %0d ps", $time);
			$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
		end else begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
			$display("Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
			$display("Simulation finished at %0d ps", $time);
			$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
		end
		$finish;
	end

endmodule
