module TopModule (
    input clk,
    input areset,
    input in,
    output out
);
    // State definitions and FSM logic go here (Implementation derived from spec)
    typedef enum logic [1:0] {STATE_A, STATE_B, STATE_C, STATE_D} state_t;
    state_t current_state, next_state;
    logic fsm_output;

    // State Register (Sequential Logic)
    always @(posedge clk or posedge areset) begin
        if (areset) begin
            current_state <= STATE_A; // Asynchronous reset to A
        end else begin
            current_state <= next_state;
        end
    end

    // Next State Logic (Combinational)
    always_comb begin
        next_state = current_state;
        case (current_state) 
            STATE_A:
                next_state = in ? STATE_B : STATE_A;
            STATE_B:
                next_state = in ? STATE_B : STATE_C;
            STATE_C:
                next_state = in ? STATE_D : STATE_A;
            STATE_D:
                next_state = in ? STATE_B : STATE_C;
            default: next_state = STATE_A;
        endcase
    end

    // Output Logic (Moore - Combinational)
    always_comb begin
        case (current_state) 
            STATE_A: fsm_output = 1'b0;
            STATE_B: fsm_output = 1'b0;
            STATE_C: fsm_output = 1'b0;
            STATE_D: fsm_output = 1'b1;
            default: fsm_output = 1'b0;
        endcase
    end

    assign out = fsm_output;
endmodule


