// Dummy modules needed to keep the testbench structure intact, as they are not defined in the prompt.
module RefModule (input clk, input in, input areset, output logic out); 
    // Placeholder implementation
    assign out = in;
endmodule

module TopModule (input clk, input areset, input in, output out);
    // FSM implementation based on specification
    typedef enum logic [1:0] { A, B, C, D } state_t;
    state_t current_state, next_state;
    logic [1:0] state_reg;

    // State Register Logic (Positive edge triggered)
    always @(posedge clk or posedge areset) begin
        if (areset) begin
            state_reg <= 2'b00; // State A
        end else begin
            state_reg <= next_state;
        end
    end

    always_comb begin
        current_state = state_reg;
        case (current_state) 
            A: begin
                next_state = in ? B : A;
                out = 1'b0;
            end
            B: begin
                next_state = in ? C : B;
                out = 1'b0;
            end
            C: begin
                next_state = in ? D : A;
                out = 1'b0;
            end
            D: begin
                next_state = in ? C : B;
                out = 1'b1;
            end
            default: next_state = A;
        endcase
    end

    assign state_reg = next_state;
endmodule

module stimulus_gen (
	input clk,
	output logic in,
	output logic areset,
	output reg[511:0] wavedrom_title,
	output reg wavedrom_enable,
