// Assuming stimulus_gen and RefModule are defined or available

module stimulus_gen (
	input clk,
	output reg reset,
	output reg data, done_counting, ack,
	input tb_match
);
	bit failed = 0;
	
	always @(posedge clk, negedge clk)
		if (!tb_match) 
			failed <= 1;
	
	initial begin

		@(posedge clk);
		failed <= 0;
		reset <= 1;
		data <= 0;
		done_counting <= 1'bx;
		ack <= 1'bx;
		@(posedge clk) 
			data <= 1;
			reset <= 0;
		@(posedge clk) data <= 0;
		@(posedge clk) data <= 0;
		@(posedge clk) data <= 1;
		@(posedge clk) data <= 1;
		@(posedge clk) data <= 0;
		@(posedge clk) data <= 1;
		@(posedge clk);
			data <= 1'bx;
		repeat(4) @(posedge clk);
			done_counting <= 1'b0;
		repeat(4) @(posedge clk);
			done_counting <= 1'b1;
		@(posedge clk);
			done_counting <= 1'bx;
		ack <= 1'b0;
		repeat(3) @(posedge clk);
			ack <= 1'b1;
		@(posedge clk);
			ack <= 1'b0;
			data <= 1'b1;
		@(posedge clk);
			ack <= 1'bx;
			data <= 1'b1;
		@(posedge clk);
			data <= 1'b0;
		@(posedge clk);
			data <= 1'b1;
		@(posedge clk);
			data <= 1'bx;
		repeat(4) @(posedge clk);
			done_counting <= 1'b0;
		repeat(4) @(posedge clk);
			done_counting <= 1'b1;
		@(posedge clk);

		if (failed)
			$display("Hint: Your FSM didn't pass the sample timing diagram posted with the problem statement. Perhaps try debugging that?");
		
		
		repeat(5000) @(posedge clk, negedge clk) begin
			reset <= !($random & 255);
			data <= $random;
			done_counting <= !($random & 31);
			ack <= !($random & 31);
		end

		#1 $finish;
	end
	
endmodule

module tb();

	// --- Statistics Structure ---
	typedef struct packed {
		int errors;
		int errortime;
		int errors_shift_ena;
		int errortime_shift_ena;
		int errors_counting;
		int errortime_counting;
		int errors_done;
		int errortime_done;
		int clocks;
} stats;
	
	stats stats1;
	
	// --- Waveform Configuration ---
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	// --- Clock Generation ---
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	// --- DUT Signals ---
	logic reset;
	logic data;
	logic done_counting;
	logic ack;
	logic shift_ena_ref;
	logic shift_ena_dut;
	logic counting_ref;
	logic counting_dut;
	logic done_ref;
	logic done_dut;

	// --- Verification Signals ---
	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	// --- Queue Definitions (For sequential logic logging) ---
	localparam MAX_QUEUE_SIZE = 10;
	
	reg [1:0] input_data_q [$]; // data (1 bit) + other small signals if needed, using 2 bits for simplicity if we only track data
	reg [1:0] input_done_counting_q [$];
	reg [1:0] input_ack_q [$];
	reg input_reset_q [$]; // Reset is single bit
	
	reg [1:0] got_shift_ena_q [$];
	reg [1:0] golden_shift_ena_q [$];
	
	reg [1:0] got_counting_q [$];
	reg [1:0] golden_counting_q [$];
	
	reg [1:0] got_done_q [$];
	reg [1:0] golden_done_q [$];

	// Helper to represent 1-bit signals in the queue structure, padding to 2 bits for consistency


	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stimulus_gen::clk, tb_mismatch, clk, reset, data, done_counting, ack, shift_ena_ref, shift_ena_dut, counting_ref, counting_dut, done_ref, done_dut );
	end

	// Instantiate Stimulus Generator (Input Driver)
	stimulus_gen stim1 (
		.clk, 
		.reset, 
		.data, 
		done_counting, 
		.ack, 
		.tb_match
	);

	// Instantiate Reference Model (Golden) -- Requires RefModule definition
	RefModule good1 (
		.clk,
		.reset,
		.data,
		done_counting,
		.ack,
		.shift_ena(shift_ena_ref),
		.counting(counting_ref),
		.done(done_ref) );
	
	// Instantiate DUT
	TopModule top_module1 (
		.clk,
		.reset,
		.data,
		done_counting,
		.ack,
		.shift_ena(shift_ena_dut),
		.counting(counting_dut),
		.done(done_dut) );

	// --- Task Definition (Kept from original, though its function is timing sensitive) ---
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end
	task

	// Initialize signals needed for the task		reg strobe = 0;

	// --- Synchronization and Verification Logic ---
	// This block replaces the simple XOR assignment and implements queue logging
	always @(posedge clk, negedge clk) begin
		// 1. Update Stats
		stats1.clocks++;
		
		// 2. Push data to queues (Padded to 2 bits for uniform queue structure)
		input_reset_q.push_back({reset});
		input_data_q.push_back({data});
		input_done_counting_q.push_back({done_counting});
		input_ack_q.push_back({ack});

		// Output queues
		got_shift_ena_q.push_back({shift_ena_dut});
		golden_shift_ena_q.push_back({shift_ena_ref});
		
		got_counting_q.push_back({counting_dut});
		golden_counting_q.push_back({counting_ref});
		
		got_done_q.push_back({done_dut});
		golden_done_q.push_back({done_ref});
		
		// 3. Manage Queue Size (FIFO)
		if (input_data_q.size() >= MAX_QUEUE_SIZE) begin
			input_data_q.delete(0);
			input_done_counting_q.delete(0);
			input_ack_q.delete(0);
			input_reset_q.delete(0);
			got_shift_ena_q.delete(0);
			golden_shift_ena_q.delete(0);
			got_counting_q.delete(0);
			golden_counting_q.delete(0);
			got_done_q.delete(0);
			golden_done_q.delete(0);
		end

		// 4. Check for Mismatches and Update Errors
		// Check shift_ena
		if (shift_ena_dut !== shift_ena_ref) begin
			if (stats1.errors_shift_ena == 0) stats1.errortime_shift_ena = $time;
			sats1.errors_shift_ena = stats1.errors_shift_ena+1'b1;
		end
		// Check counting
		if (counting_dut !== counting_ref) begin
			if (stats1.errors_counting == 0) stats1.errortime_counting = $time;
			sats1.errors_counting = stats1.errors_counting+1'b1;
		end
		// Check done
		if (done_dut !== done_ref) begin
			if (stats1.errors_done == 0) stats1.errortime_done = $time;
			sats1.errors_done = stats1.errors_done+1'b1;
		end
		
		// Total Mismatch Check (If any single output mismatched, count it against total errors)
		if (shift_ena_dut !== shift_ena_ref || counting_dut !== counting_ref || done_dut !== done_ref) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			sats1.errors = stats1.errors+1'b1;
		end
		
		// 5. Display detailed error information upon FIRST mismatch (if errors > 0 and previous error count was 0)
		if (stats1.errors > 0 && stats1.errors == 1 && stats1.errortime == $time) begin
			$display("\n=======================================================================");
			$display("!! FIRST MISMATCH DETECTED AT TIME %0d ps !!", $time);
			$display("=======================================================================");
			$display("Queue-based simulation mismatch display (Last %0d cycles):", MAX_QUEUE_SIZE);

			for (int i = 0; i < input_data_q.size(); i++) begin
				// Note: We display all signals available in the queue structure
				$display("Cycle %d, Reset: %b, Data: %b, DoneCnt: %b, Ack: %b | Ref: %b, Got: %b",
				i,
				input_reset_q[i], 
				input_data_q[i], 
				input_done_counting_q[i], 
				input_ack_q[i], 
				golden_shift_ena_q[i], 
				got_shift_ena_q[i]);
				
				$display("\t-> Expected shift_ena: %b, Actual shift_ena: %b", golden_shift_ena_q[i], got_shift_ena_q[i]);
				$display("\t-> Expected counting: %b, Actual counting: %b", golden_counting_q[i], got_counting_q[i]);
				$display("\t-> Expected done: %b, Actual done: %b", golden_done_q[i], got_done_q[i]);
			end
			$display("=======================================================================\n");
		end
	end

	// --- Finalization ---
	initial begin
		// Wait for simulation to run long enough to capture steady state or timeout
		@(negedge clk);
		#1000000 // Allow enough time for the randomized phase
		$finish();
	end

	final begin
		// Original Hint style output is replaced by required final summary
		
		if (stats1.errors == 0) begin
			$display("SIMULATION PASSED");
		end else begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
		end
	end

endmodule

