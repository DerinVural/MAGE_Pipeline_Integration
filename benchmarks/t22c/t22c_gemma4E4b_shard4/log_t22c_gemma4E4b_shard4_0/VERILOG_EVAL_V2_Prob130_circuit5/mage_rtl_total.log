            $display("SIMULATION PASSED");
            $display("=======================================================================================");
        end
        
        $display("\nTotal mismatched samples is %0d out of %0d samples", stats1.errors, stats1.clocks);
        $display("Simulation finished at %0d ps", $time);
    end
    
