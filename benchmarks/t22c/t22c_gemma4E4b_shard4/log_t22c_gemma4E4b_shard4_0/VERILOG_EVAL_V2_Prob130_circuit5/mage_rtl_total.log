    wire tb_match;
    wire tb_mismatch = ~tb_match;
    
    stimulus_gen stim1 (
        .clk,
        .* ,
        .a, 
        .b,
        .c,
        .d,
        .e );
    RefModule good1 (
        .a,
        .b,
        .c,
        .d,
        .e,
