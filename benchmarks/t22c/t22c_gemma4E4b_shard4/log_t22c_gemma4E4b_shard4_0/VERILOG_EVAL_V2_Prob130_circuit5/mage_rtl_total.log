module tb();

	// Stats tracking for the required output format
	int errors_total = 0;
	int first_mismatch_time = -1;
	
	// Control signals
	logic tb_match = 1'b1;
	logic tb_mismatch = ~tb_match;

	// Signals from stimulus_gen
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	
	// DUT and Reference Signals
	logic [3:0] a;
	logic [3:0] b;
	logic [3:0] c;
	logic [3:0] d;
	logic [3:0] e;
