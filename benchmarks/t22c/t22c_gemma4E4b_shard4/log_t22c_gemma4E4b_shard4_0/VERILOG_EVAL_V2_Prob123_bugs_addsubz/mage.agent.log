// --- Corrected Module Under Test ---
module TopModule_Fixed ( 
    input do_sub,
    input [7:0] a,
    input [7:0] b,
    output logic [7:0] out,
    output logic result_is_zero
);

    // Fix: Check if out is all zeros (out == 8'b0) instead of bitwise NOT (~out)
    always @(*) begin
        case (do_sub)
            0: out = a + b;
            1: out = a - b;
        endcase

        // Fixed condition for zero flag
        if (out == 8'b0)
            result_is_zero = 1;
        else
            result_is_zero = 0;
    end

endmodule


