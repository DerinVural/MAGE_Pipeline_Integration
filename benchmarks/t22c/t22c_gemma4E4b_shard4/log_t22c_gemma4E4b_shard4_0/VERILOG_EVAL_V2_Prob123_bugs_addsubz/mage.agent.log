module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_out;
		int errortime_out;
		int errors_result_is_zero;
		int errortime_result_is_zero;

		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic do_sub;
	logic [7:0] a;
	logic [7:0] b;
	logic [7:0] out_ref;
	logic [7:0] out_dut;
	logic result_is_zero_ref;
	logic result_is_zero_dut;

	// Variables to capture state at first mismatch
	logic [7:0] first_mismatch_a = 8'hXX;
	logic [7:0] first_mismatch_b = 8'hXX;
	logic first_mismatch_do_sub = 0;
	logic [7:0] first_mismatch_out_ref = 8'hXX;
	logic [7:0] first_mismatch_out_dut = 8'hXX;
	logic first_mismatch_rz_ref = 0;
	logic first_mismatch_rz_dut = 0;
	integer first_mismatch_time = 0;

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stimulus_gen.clk, tb_mismatch ,do_sub,a,b,out_ref,out_dut,result_is_zero_ref,result_is_zero_dut );
	end

	
	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk,
		.* ,
		do_sub,
		a,
		b );
	RefModule good1 (
		do_sub,
		a,
		b,
		out(out_ref),
		.result_is_zero(result_is_zero_ref) );
	
	TopModule top_module1 (
		do_sub,
		a,
		b,
		out(out_dut),
		.result_is_zero(result_is_zero_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		endtask
	
	
	final begin
		$display("====================================================");
		if (stats1.errors_out == 0 && stats1.errors_result_is_zero == 0) begin
			$display("SIMULATION PASSED");
		end else begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
		end
		$display("====================================================");
		
		if (stats1.errors_out) 
			$display("Hint: Output 'out' has %0d mismatches. First mismatch occurred at time %0d. State: A=%h, B=%h, DoSub=%b, RefOut=%h, DUTOut=%h", 
			s, stats1.errors_out, stats1.errortime_out, first_mismatch_a, first_mismatch_b, first_mismatch_do_sub, first_mismatch_out_ref, first_mismatch_out_dut);
		else
			$display("Hint: Output 'out' has no mismatches.");
		if (stats1.errors_result_is_zero) 
			$display("Hint: Output 'result_is_zero' has %0d mismatches. First mismatch occurred at time %0d. State: A=%h, B=%h, DoSub=%b, RefRZ=%b, DUTRZ=%b", 
			s, stats1.errors_result_is_zero, stats1.errortime_result_is_zero, first_mismatch_a, first_mismatch_b, first_mismatch_do_sub, first_mismatch_rz_ref, first_mismatch_rz_dut);
		else
			$display("Hint: Output 'result_is_zero' has no mismatches.");

		$display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
		$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
	end
	
	// Verification: Simplified logic: tb_match is true if outputs match.
	// Since this is combinational, we check if the outputs change from the expected value.
	assign tb_match = ( { out_ref, result_is_zero_ref } === { out_dut, result_is_zero_dut } );
	
	// Logic to capture state upon first mismatch
	always @(posedge clk, negedge clk) begin
		// 1. Update counters and clock count
		stats1.clocks++;

		// 2. Update error counters (Original functionality maintained)
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			sstats1.errors++;
		end

		// Out Mismatch Check
		if (out_ref !== out_dut) begin
			if (stats1.errors_out == 0) stats1.errortime_out = $time;
			sstats1.errors_out = stats1.errors_out+1'b1;
			// Capture state on first mismatch for 'out'
			if (stats1.errors_out == 1) begin
				first_mismatch_time = $time;
				first_mismatch_a = a;
				first_mismatch_b = b;
				first_mismatch_do_sub = do_sub;
				first_mismatch_out_ref = out_ref;
				first_mismatch_out_dut = out_dut;
			end
		end

		// Result_is_zero Mismatch Check
		if (result_is_zero_ref !== result_is_zero_dut) begin
			if (stats1.errors_result_is_zero == 0) stats1.errortime_result_is_zero = $time;
			sstats1.errors_result_is_zero = stats1.errors_result_is_zero+1'b1;
			// Capture state on first mismatch for 'result_is_zero'
			if (stats1.errors_result_is_zero == 1) begin
				first_mismatch_time = $time;
				first_mismatch_a = a;
				first_mismatch_b = b;
				first_mismatch_do_sub = do_sub;
				first_mismatch_rz_ref = result_is_zero_ref;
				first_mismatch_rz_dut = result_is_zero_dut;
			end
		end
	end

	// add timeout after 100K cycles
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

	endmodule
