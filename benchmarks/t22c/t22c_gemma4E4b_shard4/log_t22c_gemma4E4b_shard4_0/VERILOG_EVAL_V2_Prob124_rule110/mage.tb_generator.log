    "testbench": "`timescale 1 ps/1 ps\n`define OK 12\n`define INCORRECT 13\n\n// Define the required interface for TopModule for instantiation\nmodule TopModule_if;\n    input logic clk;\n    input logic load;\n    input logic [511:0] data;\n    output logic [511:0] q;\nendmodule\n\n\nmodule stimulus_gen (\n\tinput clk,\n\toutput reg load,\n\toutput reg[511:0] data,\n\toutput reg[511:0] wavedrom_title,\n\toutput reg wavedrom_enable\n);\n\n\n// Add two ports to module stimulus_gen:\n//    output [511:0] wavedrom_title\n//    output reg wavedrom_enable\n\n\ttask wavedrom_start(input[511:0] title = \"\");\n\tendtask\n\t\n\ttask wavedrom_stop;\n\t\t#1;\n\tendtask\n\n\n\tinitial begin\n\t\tdata <= 0;\n\t\tdata[0] <= 1'b1;\n\t\tload <= 1;\n\t\t@(posedge clk); wavedrom_start(\"Load q[511:0] = 1: See Hint.\");\n\t\t@(posedge clk);\n\t\t@(posedge clk);\n\t\tload <= 0;\n\t\trepeat(10) @(posedge clk);\t\n\t\twavedrom_stop();\n\t\t\n\t\tdata <= 0;\n\t\tdata[256] <= 1'b1;\n\t\tload <= 1;\n\t\t@(posedge clk);\n\t\t@(posedge clk);\n\t\t@(posedge clk);\n\t\tload <= 0;\n\t\trepeat(1000) @(posedge clk) begin\n\t\tend\n\t\tdata <= 512'h4df;\n\t\tload <= 1;\n\t\t@(posedge clk);\n\t\tload <= 0;\n\t\trepeat(1000) @(posedge clk) begin\n\t\tend\n\t\tdata <= $random;\n\t\tload <= 1;\n\t\t@(posedge clk);\n\t\tload <= 0;\n\t\trepeat(1000) @(posedge clk) begin\n\t\tend\n\n\t\tdata <= 0;\n\t\tload <= 1;\n\t\trepeat (20) @(posedge clk);\n\t\t@(posedge clk) data <= 2;\n\t\t@(posedge clk) data <= 4;\n\t\t@(posedge clk) begin\n\t\t\tdata <= 9;\n\t\t\tload <= 0;\n\t\tend\n\t\t@(posedge clk) data <= 12;\n\t\trepeat(100) @(posedge clk);\n\n\t\t#1 $finish;\n\tend\n\t\nendmodule\n\nmodule tb();\n\n    typedef struct packed {\n        int errors;\n        int errortime;\n        int errors_q;\n        int errortime_q;\n\n        int clocks;\n    } stats;\n    \n    stats stats1;\n    \n    \n    wire[511:0] wavedrom_title;\n    wire wavedrom_enable;\n    int wavedrom_hide_after_time;\n    \n    reg clk=0;\n    initial forever\n        #5 clk = ~clk;\n\n    logic load;\n    logic [511:0] data;\n    logic [511:0] q_ref;\n    logic [511:0] q_dut;\n\n    // Queue setup for mismatch detection (Sequential Logic)\n    // MAX_QUEUE_SIZE <= 10\n    localparam MAX_QUEUE_SIZE = 10;\n    logic [511:0] input_load_queue [$];\n    logic [511:0] input_data_queue [$];\n    logic [511:0] got_output_queue [$];\n    logic [511:0] golden_queue [$];\n    logic reset_queue [$]; // Placeholder, though no explicit reset is used in the original testbench\n\n    initial begin \n        $dumpfile(\"wave.vcd\");\n        $dumpvars(1, stimulus_gen.clk, tb_mismatch ,clk,load,data,q_ref,q_dut );\n    end\n\n\n    wire tb_match;\n    wire tb_mismatch = ~tb_match;\n    \n    stimulus_gen stim1 (\n        .clk,\n        .load,\n        .data );\n    \n    // Assume RefModule and TopModule are defined elsewhere or are placeholders for the golden reference.\n    // Since their definition is not provided, we must assume they exist and match the interface.\n    RefModule good1 (\n        .clk,\n        .load,\n        .data,\n        .q(q_ref) );\n        \n    TopModule_if top_module1 (\n        .clk,\n        .load,\n        .data,\n        .q(q_dut) );\n\n    \n    bit strobe = 0;\n    task wait_for_end_of_timestep;\n        repeat(5) begin\n            strobe <= !strobe;  // Try to delay until the very end of the time step.\n            @(strobe);\n        end\n    endtask\n\n    // --- Queueing and Mismatch Detection Logic ---\n    always @(posedge clk, negedge clk) begin\n        // 1. Manage Queue Size\n        if (input_load_queue.size() >= MAX_QUEUE_SIZE - 1) begin\n            input_load_queue.delete(0);\n            input_data_queue.delete(0);\n            got_output_queue.delete(0);\n            golden_queue.delete(0);\n            reset_queue.delete(0);\n        end\n\n        // 2. Store current state (Inputs & Outputs)\n        input_load_queue.push_back(load);\n        input_data_queue.push_back(data);\n        got_output_queue.push_back(q_dut);\n        golden_queue.push_back(q_ref);\n        reset_queue.push_back(1'b0); // Assuming no explicit reset is active\n\n        // 3. Check for First Mismatch (Queue Detection)\n        if (stats1.errors_q == 0 && (q_dut !== q_ref)) begin\n            $display(\"\\n============================================================================\");\n            $display(\"!! MISMATCH DETECTED VIA QUEUE LOGIC AT TIME %0t !!\", $time);\n            $display(\"============================================================================\");\n            $display(\"Displaying last %0d cycles of simulation history before mismatch:\", input_load_queue.size());\n\n            for (int i = 0; i < input_load_queue.size(); i++) begin\n                $display(\"Cycle %d | Load: %b | Data: %h | Got Q: %h | Exp Q: %h\",\n                    i, \n                    input_load_queue[i], \n                    input_data_queue[i], \n                    got_output_queue[i], \n                    golden_queue[i]);\n            end\n            $display(\"============================================================================\");\n        end\n\n        // 4. Original Error Counting Logic (Must be maintained)\n        stats1.clocks++;\n        if (!tb_match) begin\n            if (stats1.errors == 0) stats1.errortime = $time;\n            stats1.errors++;\n        end\n        // The redundant check from golden_testbench is maintained:\n        if (q_ref !== ( q_ref ^ q_dut ^ q_ref ))\n        begin if (stats1.errors_q == 0) stats1.errortime_q = $time;\n            stats1.errors_q = stats1.errors_q+1'b1; end\n        end\n    end\n\n    // Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.\n    assign tb_match = ( { q_ref } === ( { q_ref } ^ { q_dut } ^ { q_ref } ) );\n\n   // add timeout after 100K cycles\n   initial begin\n     #1000000\n     $display(\"TIMEOUT REACHED.\");\n     $finish();\n   end\n\n    // Final Reporting Logic (Replacing original final block)\n    initial begin\n        @(negedge clk); // Wait a moment after simulation starts\n        wait (sim_done);\n\n        if (stats1.errors == 0) begin\n            $display(\"\\n============================================================================\");\n            $display(\"SIMULATION PASSED\");\n            $display(\"============================================================================\");\n        end else begin\n            $display(\"\\n============================================================================\");\n            $display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\", stats1.errors, stats1.errortime);\n            $display(\"============================================================================\");\n        end\n\n        $display(\"Total mismatched samples counted by original logic: %1d out of %1d samples\\n\", stats1.errors, stats1.clocks);\n        $display(\"Simulation finished at %0d ps\", $time);\n        $finish;\n    end\n    \n    // Signal to gracefully end the final reporting block\n    logic sim_done = 0;\n    always @(posedge clk) begin\n        if (stats1.clocks >= 1000000) begin\n            sim_done <= 1;\n        end\n    end\n\nendmodule"
