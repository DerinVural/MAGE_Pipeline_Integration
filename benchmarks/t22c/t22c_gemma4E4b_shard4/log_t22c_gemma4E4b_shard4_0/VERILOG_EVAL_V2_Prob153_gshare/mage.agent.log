        .clk, .areset, 
        .predict_valid, .predict_pc, 
        .train_valid, .train_taken, .train_mispredicted, .train_history, .train_pc, 
        .predict_taken(predict_taken_dut), 
        .predict_history(predict_history_dut) 
    );

    
    bit strobe = 0;
    task wait_for_end_of_timestep;
        repeat(5) begin
            strobe <= !strobe;  // Try to delay until the very end of the time step.
            @(strobe);
        end
    endtask	


    // --- Queue Management and Mismatch Detection (Sequential Logic) ---
    always @(posedge clk, negedge clk) begin
        // 1. Queue Management: Dequeue if full
        if (input_predict_pc_q.size() >= MAX_QUEUE_SIZE - 1) begin
            input_predict_pc_q.delete(0);
            input_train_history_q.delete(0);
            input_train_pc_q.delete(0);
            got_predict_history_q.delete(0);
            got_predict_taken_q.delete(0);
            golden_predict_history_q.delete(0);
            golden_predict_taken_q.delete(0);
            reset_q.delete(0);
        end

        // 2. Data Capture (Capture inputs/state for the cycle being evaluated)
        // Inputs that define the current state/request
        reset_q.push_back(areset);
        input_predict_pc_q.push_back(predict_pc);
        input_train_history_q.push_back(train_history);
        input_train_pc_q.push_back(train_pc);
        
        // Outputs that result from the current cycle's inputs (DUT outputs)
        got_predict_history_q.push_back(predict_history_dut);
        got_predict_taken_q.push_back(predict_taken_dut);
        // Golden reference outputs
        golden_predict_history_q.push_back(predict_history_ref);
        golden_predict_taken_q.push_back(predict_taken_ref);

        // 3. Mismatch Detection and Tracking
        if (tb_mismatch) begin
            total_errors++;
            if (total_errors == 1) begin
                first_error_time = $time;
            end
        end

        // 4. Queue Display Logic: Only display when a mismatch occurs
        if (tb_mismatch) begin
            $display("\n====================================================");
            $display("!!! MISMATCH DETECTED AT TIME %0t !!!", $time);
            $display("Showing last %0d cycles of history (Queue Size: %0d):", MAX_QUEUE_SIZE, input_predict_pc_q.size());

            for (int i = 0; i < input_predict_pc_q.size(); i++) begin
                $display("----------------------------------------------------");
                $display("Queue Index: %0d | Clock Cycle Start: %0t", i, $time - (input_predict_pc_q.size() - i) * 10);
                
                // Inputs
                $display("  RESET: %b", reset_q[i]);
                $display("  INPUT PC: %h (%b)", input_predict_pc_q[i], input_predict_pc_q[i]);
                $display("  INPUT HIST: %h (%b)", input_train_history_q[i], input_train_history_q[i]);
                $display("  INPUT TRAIN PC: %h (%b)", input_train_pc_q[i], input_train_pc_q[i]);
                
                // Outputs
                $display("  GOT OUT HIST: %h (%b)", got_predict_history_q[i], got_predict_history_q[i]);
                $display("  GOLDEN OUT HIST: %h (%b)", golden_predict_history_q[i], golden_predict_history_q[i]);
                $display("  GOT OUT TAKEN: %b | GOLDEN OUT TAKEN: %b", got_predict_taken_q[i], golden_predict_taken_q[i]);
                
                // Check for mismatch at this specific index for detailed reporting
                if (got_predict_taken_q[i] !== golden_predict_taken_q[i] || got_predict_history_q[i] !== golden_predict_history_q[i]) begin
                     $display("  *** MISMATCH CONFIRMED AT THIS RECORDED STEP ***");
                end
            end
        end
    end

   // add timeout after 100K cycles
   initial begin
     #1000000
     if (total_errors > 0) begin
         $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", total_errors, first_error_time);
     end else begin
         $display("SIMULATION PASSED");
     end
     $finish();
   end

endmodule
