			// 2. Store DUT Outputs
			got_output_queue.push_back({B3_next_dut, S_next_dut, S1_next_dut, Count_next_dut, Wait_next_dut, done_dut, counting_dut, shift_ena_dut});
			
			// 3. Store Reference Outputs
