.state,\n\t\t.B3_next(B3_next_ref),\n\t\t.S_next(S_next_ref),\n\t\t.S1_next(S1_next_ref),\n\t\t.Count_next(Count_next_ref),\n\t\t.Wait_next(Wait_next_ref),\n\t\tdone(done_ref),\n\t\t.counting(counting_ref),\n\t\t.shift_ena(shift_ena_ref) );\n\t\n\tTopModule top_module1 (\n\t\td.d,\n\t\tdone_counting,\n\t\tack,\n\t\t.state,\n\t\t.B3_next(B3_next_dut),\n\t\t.S_next(S_next_dut),\n\t\t.S1_next(S1_next_dut),\n\t\t.Count_next(Count_next_dut),\n\t\t.Wait_next(Wait_next_dut),\n\t\tdone(done_dut),\n\t\t.counting(counting_dut),\n\t\t.shift_ena(shift_ena_dut) );\n\n\t\n\t// --- Task Definitions ---\n\ttask wait_for_end_of_timestep;\n\t\trepeat(5) begin\n\t\tstrobe <= !strobe;  // Try to delay until the very end of the time step.\n\t\t@(strobe);\n\t\tendtask\n\n\t// Helper function to display queued data upon first error\n\ntask display_mismatch_info;\n\tbegin\n\t\t$display("========================================================================================");\n\t\t$display("!!! FIRST MISMATCH DETECTED AT TIME %0t !!!", $time);\n\t\t$display("Total mismatches counted so far: %0d", stats1.errors);\n\t\t$display("Displaying the last %0d cycles stored in the queue.", input_data_queue.size());\n\t\t$display("========================================================================================");\n\t\t\n\t\tfor (int i = 0; i < input_data_queue.size(); i++) begin\n\t\t\t// Extract relevant signals from the packed queue element\n\t\t\treg [2:0] q_d_ack_done = input_data_queue[i][2:0];\n\t\t\treg [9:0] q_state = input_data_queue[i][12:3];\n\t\t\treg [7:0] q_got_out = got_output_queue[i];\n\t\t\treg [7:0] q_golden_out = golden_output_queue[i];\n\t\t\t\n\t\t\t$display("\\n--- CYCLE %0d (Time: %0t ps) ---", i, $time);\n\t\t\t// Display Inputs\n\t\t\t$display("Inputs: d=%b, done_counting=%b, ack=%b, state=0x%0h (%0d)", q_d_ack_done[0], q_d_ack_done[1], q_d_ack_done[2], q_state, q_state);\n\t\t\t// Display Reference Outputs (Golden)\n\t\t\t$display("Golden Outputs (Ref): 0x%0h (%b)", q_golden_out, q_golden_out);\n\t\t\t// Display DUT Outputs (Got)\n\t\t\t$display("DUT Outputs (Got): 0x%0h (%b)", q_got_out, q_got_out);\n\t\t\t\n\t\t\t// Detailed signal check for the current cycle (optional, but helpful for first error)\n\t\t\t$display("Detailed Signal Check (Bit-by-Bit): ");\n\t\t\t$display("  B3_next: Ref=%b, Got=%b", q_golden_out[0], q_got_out[0]);\n\t\t\t$display("  S_next: Ref=%b, Got=%b", q_golden_out[1], q_got_out[1]);\n\t\t\t$display("  S1_next: Ref=%b, Got=%b", q_golden_out[2], q_got_out[2]);\n\t\t\t$display("  Count_next: Ref=%b, Got=%b", q_golden_out[3], q_got_out[3]);\n\t\t\t$display("  Wait_next: Ref=%b, Got=%b", q_golden_out[4], q_got_out[4]);\n\t\t\t$display("  done: Ref=%b, Got=%b", q_golden_out[5], q_got_out[5]);\n\t\t\t$display("  counting: Ref=%b, Got=%b", q_golden_out[6], q_got_out[6]);\n\t\t\t$display("  shift_ena: Ref=%b, Got=%b", q_golden_out[7], q_got_out[7]);\n\t\t\t\n\t\tend\n\tendtask\n\n\t// --- Simulation Logic ---\n\t\n\t// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.\n\tassign tb_match = ( { B3_next_ref, S_next_ref, S1_next_ref, Count_next_ref, Wait_next_ref, done_ref, counting_ref, shift_ena_ref } === ( { B3_next_ref, S_next_ref, S1_next_ref, Count_next_ref, Wait_next_ref, done_ref, counting_ref, shift_ena_ref } ^ { B3_next_dut, S_next_dut, S1_next_dut, Count_next_dut, Wait_next_dut, done_dut, counting_dut, shift_ena_dut } ^ { B3_next_ref, S_next_ref, S1_next_ref, Count_next_ref, Wait_next_ref, done_ref, counting_ref, shift_ena_ref } ) );\n\t\n\t// Sequential logic processing, Queue management, and Error Checking\n\talways @(posedge clk, negedge clk) begin\n\t\tif (!mismatch_detected) begin\n\t\t\t// 1. Store Inputs\n\t\t\t// d, done_counting, ack (3 bits) | state (10 bits)\n\t\t\tinput_data_queue.push_back({state, done_counting, ack, d});\n\t\t\t\n\t\t\t// 2. Store DUT Outputs\n\t\t\tgot_output_queue.push_back({B3_next_dut, S_next_dut, S1_next_dut, Count_next_dut, Wait_next_dut, done_dut, counting_dut, shift_ena_dut});\n\t\t\t\n\t\t\t// 3. Store Reference Outputs\n\t\t\tgolden_output_queue.push_back({B3_next_ref, S_next_ref, S1_next_ref, Count_next_ref, Wait_next_ref, done_ref, counting_ref, shift_ena_ref});\n\t\t\t\n\t\t\t// 4. Check Mismatch\n\t\t\tif (!tb_match) begin\n\t\t\t\tstats1.errors++;\n\t\t\t\tif (stats1.errors == 1) begin\n\t\t\t\t\tmismatch_detected = 1;\n\t\t\t\t\tdisplay_mismatch_info();\n\t\t\t\tend\n\t\t\tend\n\t\tend\n\t\t\n\t\t// 5. Manage Queue Size\n\t\t\tif (input_data_queue.size() >= MAX_QUEUE_SIZE) begin\n\t\t\tinput_data_queue.delete(0);\n\t\t\tgot_output_queue.delete(0);\n\t\t\tgolden_output_queue.delete(0);\n\t\t\tend\n\t\tend\n\t\tend\n\n\t// Original Error Counting (Kept for total error tally, though detailed info is in queue display)\n\talways @(posedge clk, negedge clk) begin\n\t\tstats1.clocks++;\n\t\tif (!tb_match) begin\n\t\t\tif (stats1.errors == 1) stats1.errortime = $time;\n\t\tend\n\t\t\n\t\t// Checking individual signals for stats1 counters\n\t\tif (B3_next_ref !== ( B3_next_ref ^ B3_next_dut ^ B3_next_ref ))\n\t\tbegin if (stats1.errors_B3_next == 0) stats1.errortime_B3_next = $time;\n\t\t\tsstats1.errors_B3_next = stats1.errors_B3_next+1\'b1; end\n\t\tend\n\t\tif (S_next_ref !== ( S_next_ref ^ S_next_dut ^ S_next_ref ))\n\t\tbegin if (stats1.errors_S_next == 0) stats1.errortime_S_next = $time;\n\t\t\tsstats1.errors_S_next = stats1.errors_S_next+1\'b1; end\n\t\tend\n\t\tif (S1_next_ref !== ( S1_next_ref ^ S1_next_dut ^ S1_next_ref ))\n\t\tbegin if (stats1.errors_S1_next == 0) stats1.errortime_S1_next = $time;\n\t\t\tsstats1.errors_S1_next = stats1.errors_S1_next+1\'b1; end\n\t\tend\n\t\tif (Count_next_ref !== ( Count_next_ref ^ Count_next_dut ^ Count_next_ref ))\n\t\tbegin if (stats1.errors_Count_next == 0) stats1.errortime_Count_next = $time;\n\t\t\tsstats1.errors_Count_next = stats1.errors_Count_next+1\'b1; end\n\t\tend\n\t\tif (Wait_next_ref !== ( Wait_next_ref ^