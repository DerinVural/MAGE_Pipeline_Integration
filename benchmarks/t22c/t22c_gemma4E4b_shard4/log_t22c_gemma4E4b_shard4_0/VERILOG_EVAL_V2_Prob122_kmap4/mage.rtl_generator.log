    "module": "module TopModule (\n    input  logic a,\n    input  logic b,\n    input  logic c,\n    input  logic d,\n    output logic out\n);\n\n    // Combinational logic implementation based on K-map truth table.\n    // The index I is derived from the K-map layout: I = 4 * (2*a + b) + (2*c + d)\n    logic [3:0] input_index;\n\n    // Calculate the unique index corresponding to the K-map cell\n    assign input_index = {2*a + b, 2*c + d};\n\n    always @(*) begin\n        // Default to 0 (since most entries are 0 or the default is safe)\n        out = 1'b0;\n        \n        case (input_index)\n            4'b0000: out = 1'b0; // ab=00, cd=00\n            4'b0001: out = 1'b1; // ab=00, cd=01\n            4'b0011: out = 1'b0; // ab=00, cd=11\n            4'b0010: out = 1'b1; // ab=00, cd=10\n            4'b0100: out = 1'b1; // ab=01, cd=00\n            4'b0101: out = 1'b0; // ab=01, cd=01\n            4'b0111: out = 1'b1; // ab=01, cd=11\n            4'b0110: out = 1'b0; // ab=01, cd=10\n            4'b1000: out = 1'b0; // ab=11, cd=00\n            4'b1001: out = 1'b1; // ab=11, cd=01\n            4'b1011: out = 1'b0; // ab=11, cd=11\n            4'b1010: out = 1'b1; // ab=11, cd=10\n            4'b1100: out = 1'b1; // ab=10, cd=00\n            4'b1101: out = 1'b0; // ab=10, cd=01\n            4'b1111: out = 1'b1; // ab=10, cd=11\n            4'b1110: out = 1'b0; // ab=10, cd=10\n            default: out = 1'b0;\n        endcase\n    end\n\nendmodule"
