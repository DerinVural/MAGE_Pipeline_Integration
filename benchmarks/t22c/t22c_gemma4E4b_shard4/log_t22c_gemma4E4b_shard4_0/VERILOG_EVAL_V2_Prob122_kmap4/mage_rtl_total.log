module stimulus_gen (
	input logic clk,
	output logic a, b, c, d,
	output logic[511:0] wavedrom_title,
	output logic wavedrom_enable
);

	// Add two ports to module stimulus_gen:
	//    output [511:0] wavedrom_title
	//    output reg wavedrom_enable

	task wavedrom_start(input[511:0] title = "");
	endtask
	
	task wavedrom_stop;
		h#1;
	endtask	

	initial begin
		int count; count = 0;
		{a,b,c,d} <= 4'b0;
		wavedrom_start();
		repeat(16) @(posedge clk)
			{a,b,c,d} <= count++;
		@(negedge clk) wavedrom_stop();
		
		repeat(200) @(posedge clk, negedge clk)
			{d,c,b,a} <= $urandom;
		
		#1 $finish;
	end
	endmodule

module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_out;
		int errortime_out;

		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic a;
	logic b;
	logic c;
	logic d;
	logic out_ref;
	logic out_dut;

	// State variables for mismatch tracking
	int total_mismatches = 0;
	int first_mismatch_time = -1;
	
	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stimulus_gen.clk, tb_mismatch, a, b, c, d, out_ref, out_dut );
	end

	
	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk, // Must match golden testbench port order usage
		.a, 
		.b, 
		.c, 
		.d, 
		.wavedrom_title, 
		.wavedrom_enable
	);

	// Assuming RefModule exists and connects correctly as per golden testbench
	RefModule good1 (
		.a, 
		.b, 
		.c, 
		.d, 
		.out(out_ref) 
	);
	
	TopModule top_module1 (
		.a, 
		.b, 
		.c, 
		.d, 
		.out(out_dut) 
	);

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end
task
	
	// Combinational Logic Mismatch Check
	always @(posedge clk, negedge clk) begin
		stats1.clocks++;
		
		// Original functionality check
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
		end

		// Check for mismatch in 'out' signal
		if (out_ref !== out_dut) begin
			if (stats1.errors_out == 0) stats1.errortime_out = $time;
			stats1.errors_out = stats1.errors_out + 1'b1; 
			
			// --- COMBINATIONAL MISMATCH REPORTING --- 
			if (first_mismatch_time == -1) begin
				$display("\n========================================================================");
				$display("!!! FIRST MISMATCH DETECTED !!!");
				$display("Time: %0d ps", $time);
				$display("Inputs: a=%b, b=%b, c=%b, d=%b", a, b, c, d);
				$display("Reference Output (Expected): out_ref = %b", out_ref);
				$display("DUT Output (Got): out_dut = %b", out_dut);
				$display("========================================================================\n");
				first_mismatch_time = $time;
			end
		end
	end

	// --- FINAL STATUS REPORTING --- 
	final begin
		if (stats1.errors_out == 0) begin
			$display("SIMULATION PASSED");
		end else begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_out, stats1.errortime_out);
		end

		$display("Hint: Output 'out' has %0d mismatches.", stats1.errors_out);
		$display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
		$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
	end

	// add timeout after 100K cycles
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

endmodule

