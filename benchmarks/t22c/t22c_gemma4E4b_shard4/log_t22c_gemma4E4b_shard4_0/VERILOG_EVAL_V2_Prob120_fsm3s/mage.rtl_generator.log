   int errors_out;\n        int errortime_out;\n        int clocks;\n    } stats;\n    \n    stats stats1;\n    \n    // Queue declarations for detailed logging\n    logic [511:0] input_queue [$];\n    logic [511:0] got_output_queue [$];\n    logic [511:0] golden_queue [$];\n    logic reset_queue [$];\n\n    // Signal wires and registers\n    wire[511:0] wavedrom_title;\n    wire wavedrom_enable;\n    int wavedrom_hide_after_time;\n    \n    reg clk=0;\n    initial forever\n        #5 clk = ~clk;\n\n    logic in;\n    logic reset;\n    logic out_ref;\n    logic out_dut;\n\n    wire tb_match;\n    wire tb_mismatch = ~tb_match;\n\n    // Queue Constants\n    localparam MAX_QUEUE_SIZE = 8; // State width is 2 bits (4 states), 2^2 = 4. Max 10.\n    \n    // Initialization\n    initial begin \n        $dumpfile("wave.vcd");\n        $dumpvars(1, stim1.clk, tb_mismatch ,clk,in,reset,out_ref,out_dut );\n        \n        stats1.errors = 0;\n        stats1.errortime = 0;\n        stats1.errors_out = 0;\n        stats1.errortime_out = 0;\n        stats1.clocks = 0;\n    end\n\n\n    // Instantiate Modules\n    stimulus_gen stim1 (\n        .clk, .in, .reset, .wavedrom_title, .wavedrom_enable, .tb_match \n    );\n    RefModule good1 (\n        .clk, .in, .reset,\n        .out(out_ref) \n    );\n        \n    TopModule top_module1 (\n        .clk,\n        .in,\n        .reset,\n        .out(out_dut) \n    );\n\n\n    bit strobe = 0;\n    task wait_for_end_of_timestep;\n        repeat(5) begin\n            strobe <= !strobe;  // Try to delay until the very end of the time step.\n            @(strobe);\n        end\n    endtask\n\n    // --- Mismatch Detection and Queueing Logic ---\n    always @(posedge clk, negedge clk) begin\n        // 1. Update statistics\n        stats1.clocks++;\n        \n        // 2. Push data to queues\n        input_queue.push_back(in);\n        got_output_queue.push_back(out_dut);\n        golden_queue.push_back(out_ref);\n        reset_queue.push_