// --- DUT Interface and Wrapper (For Simulation Context) ---
// Note: The original golden testbench used 'RefModule' and 'TopModule'.
// We define a minimal wrapper for TopModule to satisfy the constraints.
module RefModule (
    input clk,
    input in,
    input reset,
    output logic out
);
    // Placeholder for the expected behavior (Golden Model)
    // Since the actual golden model logic is not provided, we simulate a pass for RefModule
    assign out = in;
endmodule

module TopModule (
    input clk,
    input reset,
    input in,
    output out
);
    // FSM Implementation based on input_spec
    typedef enum logic [1:0] { A, B, C, D } state_t;
    state_t current_state, next_state;
    logic out_reg;

    // State Register Logic
    always @(posedge clk or negedge reset)
    begin
        if (!reset) begin
            current_state <= A;
        end else begin
            current_state <= next_state;
        end
    end

    // Next State Logic
    always_comb
    begin
        next_state = current_state;
        case (current_state)
            A: next_state = in ? B : A;
            B: next_state = in ? C : B;
            C: next_state = in ? D : A;
            D: next_state = in ? C : B;
            default: next_state = A;
        endcase
    end

    // Output Logic (Moore)
    always_comb
    begin
        case (current_state)
            A: out_reg = 0;
            B: out_reg = 0;
            C: out_reg = 0;
            D: out_reg = 1;
        endcase
    end

    // Output Register
    assign out = out_reg;
endmodule

// --- Stimulus Generator (Copied from Golden TB) ---
module stimulus_gen (
    input clk,
    output logic in,
    output logic reset,
    output reg[511:0] wavedrom_title,
    output reg wavedrom_enable,
    input tb_match
);
    task reset_test(input async=0);
        bit arfail, srfail, datafail;
    
        @(posedge clk);
        @(posedge clk) reset <= 0;
        repeat(3) @(posedge clk);
    
        @(negedge clk) begin datafail = !tb_match ; reset <= 1; end
        @(posedge clk) arfail = !tb_match;
        @(posedge clk) begin
            srfail = !tb_match;
            reset <= 0;
        end
        if (srfail)
            $display("Hint: Your reset doesn't seem to be working.");
        else if (arfail && (async || !datafail))
            $display("Hint: Your reset should be %0s, but doesn't appear to be.", async ? "asynchronous" : "synchronous");
        // Don't warn about synchronous reset if the half-cycle before is already wrong. It's more likely
        // a functionality error than the reset being implemented asynchronously.
    
    endtask

    task wavedrom_start(input[511:0] title = "");
    endtask
    
    task wavedrom_stop;
        #1;
    endtask

    initial begin
        reset <= 1;
        in <= 0;
        @(posedge clk) reset <= 0; in <= 1;
        @(posedge clk) in <= 0;
        @(posedge clk) in <= 1;
        wavedrom_start();
            @(posedge clk) in <= 0;
            @(posedge clk) in <= 1;
            @(posedge clk);
            @(negedge clk) reset <= 1;
            @(posedge clk) reset <= 0;
            @(posedge clk) in <= 1;
            @(posedge clk) in <= 1;
            @(posedge clk) in <= 0;
            @(posedge clk) in <= 1;
            @(posedge clk) in <= 0;
            @(posedge clk) in <= 1;
            @(posedge clk) in <= 1;
            @(posedge clk) in <= 1;
        @(negedge clk);
        wavedrom_stop();
        repeat(200) @(posedge clk, negedge clk) begin
            in <= $random;
            reset <= !($random & 31);
        end

        #1 $finish;
    end
    
endmodule

// --- Testbench Module ---
module tb();

    // Helper function for displaying multi-bit signals in HEX/BIN
    task display_signal(string name, logic [511:0] signal);
        if (signal.size() > 64) begin
            $display("%-20s: %h (Too wide to show binary)", name, signal);
        end else begin
            $display("%-20s: %h (%b)", name, signal, signal);
        end
    endtask

    typedef struct packed {
        int errors;
        int errortime;
        int errors_out;
        int errortime_out;
        int clocks;
    } stats;
    
    stats stats1;
    
    // Queue declarations for detailed logging
    logic [511:0] input_queue [$];
    logic [511:0] got_output_queue [$];
    logic [511:0] golden_queue [$];
    logic reset_queue [$];

    // Signal wires and registers
    wire[511:0] wavedrom_title;
    wire wavedrom_enable;
    int wavedrom_hide_after_time;
    
    reg clk=0;
    initial forever
        #5 clk = ~clk;

    logic in;
    logic reset;
    logic out_ref;
    logic out_dut;

    wire tb_match;
    wire tb_mismatch = ~tb_match;

    // Queue Constants
    localparam MAX_QUEUE_SIZE = 8; // State width is 2 bits (4 states), 2^2 = 4. Max 10.
    
    // Initialization
    initial begin 
        $dumpfile("wave.vcd");
        $dumpvars(1, stim1.clk, tb_mismatch ,clk,in,reset,out_ref,out_dut );
        
        stats1.errors = 0;
        stats1.errortime = 0;
        stats1.errors_out = 0;
        stats1.errortime_out = 0;
        stats1.clocks = 0;
    end


    // Instantiate Modules
    stimulus_gen stim1 (
        .clk, .in, .reset, .wavedrom_title, .wavedrom_enable, .tb_match 
    );
    RefModule good1 (
        .clk, .in, .reset,
        .out(out_ref) 
    );
        
    TopModule top_module1 (
        .clk,
        .in,
        .reset,
        .out(out_dut) 
    );


    bit strobe = 0;
    task wait_for_end_of_timestep;
        repeat(5) begin
            strobe <= !strobe;  // Try to delay until the very end of the time step.
            @(strobe);
        end
    endtask

    // --- Mismatch Detection and Queueing Logic ---
    always @(posedge clk, negedge clk) begin
        // 1. Update statistics
        stats1.clocks++;
        
        // 2. Push data to queues
        input_queue.push_back(in);
        got_output_queue.push_back(out_dut);
        golden_queue.push_back(out_ref);
        reset_queue.push_back(reset);
        
        // 3. Manage queue size
        if (input_queue.size() >= MAX_QUEUE_SIZE) begin
            input_queue.delete(0);
            got_output_queue.delete(0);
            golden_queue.delete(0);
            reset_queue.delete(0);
        end

        // 4. Check for mismatches (Main logic preserved)
        if (!tb_match) begin
            // Update original error counters
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
        end
        
        if (out_ref !== ( out_ref ^ out_dut ^ out_ref )) // Equivalent to out_ref !== out_dut
        begin 
            if (stats1.errors_out == 0) stats1.errortime_out = $time;
            stats1.errors_out = stats1.errors_out+1'b1; 
        end

        // 5. Check for FIRST mismatch using the newly pushed data
        if (stats1.errors == 1 && !tb_match) begin 
            $display("========================================================");
            $display("*** DETAILED MISMATCH LOG STARTING AT TIME %0d ***", $time);
            $display("First mismatch detected at cycle %0d.", stats1.clocks);
            
            // Display queue content
            $display("\n--- Last %0d cycles of simulation (Including current cycle) ---", input_queue.size());
            
            for (int i = 0; i < input_queue.size(); i++) begin
                logic [511:0] current_in = input_queue[i];
                logic [511:0] current_got = got_output_queue[i];
                logic [511:0] current_golden = golden_queue[i];
                logic current_reset = reset_queue[i];
                
                $display("Cycle %0d, Reset: %b, Input: %h, Got Out: %h, Exp Out: %h",
                    i, current_reset, current_in, current_got, current_golden);
            end
            $display("*** DETAILED MISMATCH LOG END ***");
            $display("========================================================");
        end
    end


    // Final Summary Logic (Replaced original final block)
    final begin
        // Check if any mismatches occurred
        if (stats1.errors > 0 || stats1.errors_out > 0) begin
            // Use stats1.errortime if available, otherwise use errortime_out (though they should align)
            int first_error_time = (stats1.errors > 0) ? stats1.errortime : stats1.errortime_out;
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors + stats1.errors_out, first_error_time);
        end else begin
            $display("SIMULATION PASSED");
        end

        $display("Simulation finished at %0d ps", $time);
        $display("Total mismatched samples (General): %1d in %1d samples", stats1.errors, stats1.clocks);
    end
    
    // add timeout after 100K cycles
    initial begin
      #1000000
      if ($finish == 0) begin
        $display("TIMEOUT");
        $finish();
      end
    end

endmodule

