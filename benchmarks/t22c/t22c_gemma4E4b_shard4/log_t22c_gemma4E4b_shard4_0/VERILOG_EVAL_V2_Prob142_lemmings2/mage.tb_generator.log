rrent_aaah_dut !== current_aaah_ref) begin\n\t\t\t\tif (stats1.errors_aaah == 0) stats1.errortime_aaah = $time;\n\t\t\t\tstats1.errors_aaah = stats1.errors_aaah + 1'b1;\n\t\t\tend\n\t\tend\n\t\t\n\t\t// Global error count update\n\t\tif (current_walk_left_dut !== current_walk_left_ref || \n\t\t    current_walk_right_dut !== current_walk_right_ref || \n\t\t    current_aaah_dut !== current_aaah_ref) begin\n\t\t\tstats1.errors = stats1.errors + 1'b1;\n\t\tend\n\t\tstats1.clocks++;\n\tend\n\n\n\t// --- Simulation Control --- \n\tinitial begin \n\t\t// Initialization\n\t\tstats1 = '{errors:0, errortime:0, errors_walk_left:0, errortime_walk_left:0, errors_walk_right:0, errortime_walk_right:0, errors_aaah:0, errortime_aaah:0, clocks:0};\n\t\t\n\t\t// Initial state setting for simulation start\n\t\t@(posedge clk);\n\t\t// Wait for reset sequence defined in stimulus_gen\n\t\tend\n\n\t\t// Timeout mechanism (Kept from original) \n\t\t#1000000\n\t\t$display(\"\\n!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!\");\n\t\t$display(\"TIMEOUT REACHED - Forcing finish.\");\n\t\t$display(\"!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!\");\n\t\t$finish();\n\tend\n\n\t// --- Final Results Display ---\n\tfinal begin\n\t\t$display(\"\\n========================================================\");\n\t\t$display(\"Simulation Summary:\");\n\t\t\n\t\t// Check specific output errors\n\t\tif (stats1.errors_walk_left) $display(\"-> Output 'walk_left' has %0d mismatches. First mismatch occurred at time %0d.\", stats1.errors_walk_left, stats1.errortime_walk_left);\n\t\telse $display(\"-> Output 'walk_left' has no mismatches.\");\n\t\t\n\t\tif (stats1.errors_walk_right) $display(\"-> Output 'walk_right' has %0d mismatches. First mismatch occurred at time %0d.\", stats1.errors_walk_right, stats1.errortime_walk_right);\n\t\telse $display(\"-> Output 'walk_right' has no mismatches.\");\n\t\t\n\t\tif (stats1.errors_aaah) $display(\"-> Output 'aaah' has %0d mismatches. First mismatch occurred at time %0d.\", stats1.errors_aaah, stats1.errortime_aaah);\n\t\telse $display(\"-> Output 'aaah' has no mismatches.\");\n\t\t\n\t\t$display(\"Total mismatched samples: %1d out of %1d samples.\", stats1.errors, stats1.clocks);\n\t\t$display(\"========================================================\");\n\n\t\t// FINAL REQUIRED DISPLAY LOGIC\n\t\tif (stats1.errors == 0) begin\n\t\t\t$display(\"SIMULATION PASSED\");\n\t\tend else begin\n\t\t\t$display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\", stats1.errors, stats1.errortime);\n\t\tend\n\tend\n\nendmodule"
