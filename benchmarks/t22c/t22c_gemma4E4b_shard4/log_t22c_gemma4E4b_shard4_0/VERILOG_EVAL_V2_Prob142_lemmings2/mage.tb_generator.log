t -> switch to right\n64:                         next_state = STATE_R_WALK;\n65:                     end else if (bump_right) begin\n66:                         // Bump right -> switch to left\n67:                         next_state = STATE_L_WALK;\n68:                     end else begin\n69:                         // Continue walking right\n70:                         next_state = STATE_R_WALK;\n71:                     end\n72:                 end\n73: \n74:             STATE_L_FALL:\n75:                 if (ground == 1\'b1) begin\n76:                     // Ground reappears, resume previous direction (Left)\n77:                     next_state = STATE_L_WALK;\n78:                 end else begin\n79:                     // Still falling, maintain state\n80:                     next_state = STATE_L_FALL;\n81:                 end\n82: \n83:             STATE_R_FALL:\n84:                 if (ground == 1\'b1) begin\n85:                     // Ground reappears, resume previous direction (Right)\n86:                     next_state = STATE_R_WALK;\n87:                 end else begin\n88:                     // Still falling, maintain state\n89:                     next_state = STATE_R_FALL;\n90:                 end\n91: \n92:             default: begin\n93:                 // Safety/Unreachable state handling\n94:                 next_state = STATE_L_WALK;\n95:             end\n96:         endcase\n97:     end\n98: \n99:     // --- Combinational Logic (Output Decoder - Moore Machine) ---\n100:     always @* begin\n101:         // Default assignments to ensure no latches\n102:         walk_left = 1\'b0;\n103:         walk_right = 1\'b0;\n104:         aaah = 1\'b0;\n105: \n106:         case (current_state) \n107:             STATE_L_WALK:\n108:                 walk_left = 1\'b1;\n109: \n110:             STATE_R_WALK:\n111:                 walk_right = 1\'b1;\n112: \n113:             STATE_L_FALL:\n114:                 aaah = 1\'b1;\n115: \n116:             STATE_R_FALL:\n1