dual error counters (Maintaining original logic structure)\n\t\t\tif (current_walk_left_dut !== current_walk_left_ref) begin\n\t\t\t\tif (stats1.errors_walk_left == 0) stats1.errortime_walk_left = $time;\n\t\t\t\tstats1.errors_walk_left = stats1.errors_walk_left + 1\'b1;\n\t\t\tend\n\t\t\tif (current_walk_right_dut !== current_walk_right_ref) begin\n\t\t\t\tif (stats1.errors_walk_right == 0) stats1.errortime_walk_right = $time;\n\t\t\t\tstats1.errors_walk_right = stats1.errors_walk_right + 1\'b1;\n\t\t\tend\n\t\t\tif (current_aaah_dut !== current_aaah_ref) begin\n\t\t\t\tif (stats1.errors_aaah == 0) stats1.errortime_aaah = $time;\n\t\t\t\tstats1.errors_aaah = stats1.errors_aaah + 1\'b1;\n\t\t\tend\n\t\tend\n\t\t\n\t\t// Global error count update\n\t\tif (current_walk_left_dut !== current_walk_left_ref || \n\t\t    current_walk_right_dut !== current_walk_right_ref || \n\t\t    current_aaah_dut !== current_aaah_ref) begin\n\t\t\tstats1.errors = stats1.errors + 1\'b1;\n\t\tend\n\t\tstats1.clocks++;\n\tend\n\n\n\t// --- Simulation Control --- \n\tinitial begin \n\t\t// Initialization\n\t\tstats1 = \'{errors:0, errortime:0, errors_walk_left:0, errortime_walk_left:0, errors_walk_right:0, errortime_walk_right:0, errors_aaah:0, errortime_aaah:0, clocks:0};\n\t\t\n\t\t// Initial state setting for simulation start\n\t\t@(posedge clk);\n\t\t// Wait for reset sequence defined in stimulus_gen\n\t\tend\n\n\t\t// Timeout mechanism (Kept from original) \n\t\t#1000000\n\t\t$display("\\n!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!");\n\t\t$display("TIMEOUT REACHED - Forcing finish.");\n\t\t$display("!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!");\n\t\t$finish();\n\tend\n\n\t// --- Final Results Display ---\n\tfinal begin\n\t\t$display("\\n========================================================");\n\t\t$display("Simulation Summary:");\n\t\t\n\t\t// Check specific output errors\n\t\tif (stats1.errors_walk_left) $display("-> Output \'walk_left\' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_walk_left, stats1.errortime_walk_left);\n\t\telse $display("-> Output \'walk_left\' has no mismatches.");\n\t\t\n\t\tif (stats1.errors_walk_right) $display("-> Output \'walk_right\' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_walk_right, stats1.errortime_walk_right);\n\t\telse $display("-> Output \'walk_right\' has no mismatches.");\n\t\t\n\t\tif (stats1.errors_aaah) $display("-> Output \'aaah\' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_aaah, stats1.errortime_aaah);\n\t\telse $display("-> Output \'aaah\' has no mismatches.");\n\t\t\n\t\t$display("Total mismatched samples: %1d out of %1d samples.", stats1.errors, stats1.clocks);\n\t\t$display("========================================================");\n\n\t\t// FINAL REQUIRED DISPLAY LOGIC\n\t\tif (stats1.errors == 0) begin\n\t\t\t$display("SIMULATION PASSED");\n\t\tend else begin\n\t\t\t$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);\n\t\tend\n\tend\n\nendmodule\n</testbench>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nThe module interface is given below:\n<module_interface>\nmodule TopModule (\n    input logic clk,\n    input logic areset,\n    input logic bump_left,\n    input logic bump_right,\n    input logic ground,\n    output logic walk_left,\n    output logic walk_right,\n    output logic aaah\n);\nendmodule\n</module_interface>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nYour response will be processed by a program, not human.\nSo, please STRICTLY FOLLOW the output format given as XML tag content below to generate a VALID JSON OBJECT:\n<output_format>\n{\n    "reasoning": "All reasoning steps and advices to avoid syntax error",\n    "module": "Pure SystemVerilog code, a complete module"\n}\n</output_format>\nDO NOT include any other information in your response, like \'json\', \'reasoning\' or \'<output_format>\'.\n\nOther requirements:\n1. Don\'t use state_t to define the parameter. Use `localparam` or Use \'reg\' or \'logic\' for signals as registers or Flip-Flops.\n2. Declare all ports and signals as logic.\n3. Not all the sequential logic need to be reset to 0 when reset is asserted,\n    but these without-reset logic should be initialized to a known value with an initial block instead of being X.\n4. For combinational logic with an always block do not explicitly specify the sensitivity list; instead use always @(*).\n5. NEVER USE \'inside\' operator in RTL code. Code like \'state inside {STATE_B, STATE_C, STATE_D}\' should NOT be used.\n6. Never USE \'unique\' or \'unique0\' keywords in RTL code. Code like \'unique case\' should NOT be used.\n')])]
