n\n\t\t\t\tsnap_clk = clk;\n\t\t\t\tsnap_a = a;\n\t\t\t\tsnap_b = b;\n\t\t\t\tsnap_q_ref = q_ref;\n\t\t\t\tsnap_q_dut = q_dut;\n\t\t\t\tsnap_state_ref = state_ref;\n\t\t\t\tsnap_state_dut = state_dut;\n\t\t\tend\n\t\tend\n\n\t\t\n\t\tfinal begin\n\t\t\t$display(\"\n====================================================\");\n\t\t\t$display(\"SIMULATION SUMMARY\");\n\t\t\t$display(\"====================================================\");\n\t\t\t\n\t\t\tif (stats1.errors > 0) begin\n\t\t\t\t$display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\", stats1.errors, stats1.errortime);\n\t\t\t\t$display(\"----------------------------------------------------\");\n\t\t\t\t$display(\"--- Signals Snapshot at Time %0d ps ---\", snap_errortime);\n\t\t\t\t$display(\"Inputs: A=%b, B=%b\", snap_a, snap_b);\n\t\t\t\t$display(\"Reference Outputs: Q_ref=%b, State_ref=%b\", snap_q_ref, snap_state_ref);\n\t\t\t\t$display(\"DUT Outputs: Q_dut=%b, State_dut=%b\", snap_q_dut, snap_state_dut);\n\t\t\t\t$display(\"----------------------------------------------------\");\n\t\t\t\t// Detailed per-output failure reporting (if errors exist)\n\t\t\t\tif (stats1.errors_q > 0) begin\n\t\t\t\t\ts$display(\"Output 'q' has %0d mismatches. First mismatch occurred at time %0d.\", stats1.errors_q, stats1.errortime_q);\n\t\t\t\t\ts$display(\"  Snapshot at q failure: Q_ref=%b, Q_dut=%b\", snap_q_ref, snap_q_dut);\n\t\t\t\tend\n\t\t\t\tif (stats1.errors_state > 0) begin\n\t\t\t\t\ts$display(\"Output 'state' has %0d mismatches. First mismatch occurred at time %0d.\", stats1.errors_state, stats1.errortime_state);\n\t\t\t\t\ts$display(\"  Snapshot at state failure: State_ref=%b, State_dut=%b\", snap_state_ref, snap_state_dut);\n\t\t\t\tend\n\t\t\tend\n\t\t\tif (stats1.errors == 0) begin\n\t\t\t\t$display(\"SIMULATION PASSED\");\n\t\t\tend\n\t\t\t$display(\"====================================================\");\n\t\t\t$display(\"Simulation finished at %0d ps\", $time);\n\t\t\t$display(\"Total