	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		endtask	

	// --- Queue-based Mismatch Tracking and Display Logic ---

always @(posedge clk, negedge clk) begin
		// Queue Management: Maintain MAX_QUEUE_SIZE
		if (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin
			input_queue.delete(0);
			got_output_queue.delete(0);
			golden_queue.delete(0);
		end

		// Store current inputs and outputs (Synchronized to clock edge)
		input_queue.push_back({a, b});
		got_output_queue.push_back({q_dut, state_dut});
		golden_queue.push_back({q_ref, state_ref});

