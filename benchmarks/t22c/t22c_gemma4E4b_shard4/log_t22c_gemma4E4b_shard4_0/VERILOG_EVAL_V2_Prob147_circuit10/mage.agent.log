		if (!( {q_ref, state_ref} === {q_dut, state_dut} )) begin
			// 1. Update Error Counters (Original Logic)
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
			if (stats1.errors_q == 0) stats1.errortime_q = $time;
			stats1.errors_q = stats1.errors_q + 1'b1;
			if (stats1.errors_state == 0) stats1.errortime_state = $time;
			stats1.errors_state = stats1.errors_state + 1'b1;
			
			// 2. Queue Logging (First Mismatch Detection)
			if (stats1.errors == 1) begin // Only log detailed history on the very first error detected
				$display("======================================================================================");
				$display("Mismatch detected at time %0t (First error cycle)", $time);
				$display("Logging last %0d cycles of simulation history.", input_queue.size());
				$display("======================================================================================");
				
				for (int i = 0; i < input_queue.size(); i++) begin
					// Check if current sample i matches
					if (golden_queue[i] === got_output_queue[i]) begin
						$display("Cycle %0d: Got Match.", i);
					end else begin
						$display("Cycle %0d: *** GOT MISMATCH ***", i);
					end
					
					$display("--------------------------------------------------------------------------------------");
					$display("Cycle %0d | Input [A,B] = %h | Got Out [Q,S] = %h | Exp Out [Q,S] = %h",
					i, input_queue[i], got_output_queue[i], golden_queue[i]);
				end
				$display("======================================================================================");
			endif
		end
	end

	// --- Original Timing and Statistics Update --- 

always @(posedge clk, negedge clk) begin
		stats1.clocks++;
	end

	// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.
	assign tb_match = ( { q_ref, state_ref } === { q_dut, state_dut } );

	// add timeout after 100K cycles
	initial begin
		h#1000000
		$display("TIMEOUT");
		$finish();
	end

	// Final Reporting (REPLACING OLD FINAL BLOCK)
	initial begin
		// Wait a bit longer to ensure all logging finishes, though $finish() should handle it.
		#100;
		
		if (stats1.errors == 0) begin
			$display("SIMULATION PASSED");
		end else begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0t", stats1.errors, stats1.errortime);
		end
		$finish;
	end
	endmodule

