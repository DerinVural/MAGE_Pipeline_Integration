	// Inputs: a, b (2 bits)
	// Got Outputs: q_dut, state_dut (2 bits)
	// Golden Outputs: q_ref, state_ref (2 bits)
	reg [1:0] input_queue [$];
	reg [1:0] got_output_queue [$];
	reg [1:0] golden_queue [$];
	
	localparam MAX_QUEUE_SIZE = 10;

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,clk,a,b,q_ref,q_dut,state_ref,state_dut );
	end

	// Mismatch detection
	wire tb_match;
	wire tb_mismatch = ~tb_match;

