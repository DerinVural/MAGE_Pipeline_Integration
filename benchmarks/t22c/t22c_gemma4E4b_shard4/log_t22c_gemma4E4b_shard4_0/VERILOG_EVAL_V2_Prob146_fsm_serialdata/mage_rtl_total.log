				stats1.first_mismatch_out_byte = capture_out_byte_ref;
				stats1.first_mismatch_done = capture_done_ref;
				s
				// For byte mismatch, we track this separately, but capture the state
				stats1.first_mismatch_out_byte = capture_out_byte_ref;
				stats1.first_mismatch_done = capture_done_ref;
				
