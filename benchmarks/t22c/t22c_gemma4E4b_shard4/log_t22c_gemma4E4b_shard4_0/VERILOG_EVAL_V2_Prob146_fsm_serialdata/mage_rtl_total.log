b000;\n55:                     // Store the byte value on success\n56:                     out_byte_r <= rx_byte;\n57:                 end else begin\n58:                     // Failure: Stop bit was 0, reset counter to start checking from next bit\n59:                     bit_count <= 3\'b000;\n60:                 end\n61:             end else if (state == S_ERROR_WAIT && in == 1\'b1) begin\n62:                 // Recovery found (saw a 1), reset counter to look for start bit\n63:                 bit_count <= 3\'b000;\n64:             end else begin\n65:                 // Hold count otherwise (e.g., staying in S_DATA or S_ERROR_WAIT)\n66:                 bit_count <= bit_count;\n67:             end\n68: \n69:             // Done pulse assertion (Asserted only on the cycle AFTER successful stop check)\n70:             if (state == S_STOP_CHECK && in == 1\'b1 && state_next == S_IDLE)\n71:             begin\n72:                 done_r <= 1\'b1;\n73:             end\n74:             else\n75:             begin\n76:                 done_r <= 1\'b0;\n77:             end\n78:         end\n79:     end\n80: \n81:     // --- Combinational Logic (Next State and Outputs) ---\n82:     always @(*)\n83:     begin\n84:         state_next = state;\n85:         // Default assignments for outputs (driven by registers)\n86:         out_byte = out_byte_r;\n87:         done = done_r;\n88: \n89:         case (state)\n90:             S_IDLE:\n91:                 // Idle: Wait for Start Bit (0). Protocol idle is 1.\n92:                 if (in == 1\'b0) begin\n93:                     state_next = S_START;\n94:                 end\n95:                 else begin\n96:                     state_next = S_IDLE;\n97:                 end\n98: \n99:             S_START:\n100:                 // Start bit (0) received. Move to first data bit (bit_count starts at 0).\n101:                 state_next = S_DATA;\n102: \n103:             S_DATA:\n104:                 // Check if 8 bits have been received