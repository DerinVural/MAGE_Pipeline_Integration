    localparam [1:0] S_IDLE = 2'b00;
    localparam [1:0] S_DATA = 2'b01;
    localparam [1:0] S_WAIT_STOP = 2'b10;
    localparam [1:0] S_WAIT_INVALID_STOP = 2'b11;

    // State Registers and Logic
    logic [1:0] current_state;
    logic [1:0] next_state;
    logic [3:0] bit_count;

