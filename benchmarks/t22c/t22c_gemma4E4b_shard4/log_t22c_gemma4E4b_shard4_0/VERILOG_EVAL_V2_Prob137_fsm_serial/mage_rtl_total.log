inational Logic (Next State Determination)\n    always @(*)\n    begin\n        next_state = current_state;\n        \n        case (current_state)\n            S_IDLE:\n            begin\n                // Idle state expects input=1. Detect start bit (0).\n                if (in == 1'b0) begin\n                    next_state = S_DATA; // Start data reception (bit count starts at 1 in sequential block)\n                end\n                // If in == 1, stay in S_IDLE (default assignment handles this)\n            end\n\n            S_DATA:\n            begin\n                // Data bits are received sequentially up to 8 bits\n                if (bit_count < 4'd8) begin\n                    // Move to next data bit\n                    next_state = S_DATA;\n                end else begin\n                    // 8 data bits received, check stop bit\n                    if (in == 1'b1) begin\n                        next_state = S_WAIT_STOP; // Potential success\n                    end else begin\n                        next_state = S_WAIT_INVALID_STOP; // Stop bit failed (is 0)\n                    end\n                end\n            end\n\n            S_WAIT_STOP:\n            begin\n                // Must see stop bit (1) to confirm success\n                if (in == 1'b1) begin\n                    next_state = S_IDLE; // Success! Go back to idle\n                end else begin\n                    // Stop bit was 0. Protocol violation. Wait for next valid stop bit.\n                    next_state = S_WAIT_INVALID_STOP;\n                end\n            end\n\n            S_WAIT_INVALID_STOP:\n            begin\n                // Protocol violation occurred (Stop bit was 0). Wait until a stop bit (1) is seen\n                if (in == 1'b1) begin\n                    next_state = S_IDLE; // Found a stop bit, sequence reset, go idle\n                end else begin\n                    // Still waiting for the stop bit (1)\n                    next_state = 