				$display("Cycle %0d: reset=%b, in=%b, clk=%b, DUT_OUT=%b, GOLDEN_OUT=%b",
				i,
				reset_queue[i],
				in_queue[i],
				clk_queue[i],
				done_dut_queue[i],
				done_ref_queue[i]);
			end
