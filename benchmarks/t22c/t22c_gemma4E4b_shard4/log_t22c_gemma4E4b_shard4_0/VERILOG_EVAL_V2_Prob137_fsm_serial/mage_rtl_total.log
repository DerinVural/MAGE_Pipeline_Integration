24:         current_state = S_IDLE;\n25:         bit_count = 4\'d0;\n26:         done_pulse = 1\'b0;\n27:     end\n28: \n29:     // Sequential Logic (State and Counter Registers)\n30:     always @(posedge clk)\n31:     begin\n32:         if (reset)\n33:         begin\n34:             current_state <= S_IDLE;\n35:             bit_count <= 4\'d0;\n36:             done_pulse <= 1\'b0;\n37:         end\n38:         else\n39:         begin\n40:             current_state <= next_state;\n41:             \n42:             // Counter logic\n43:             if (next_state == S_DATA && current_state == S_DATA) begin\n44:                 // Increment only if we are still within the 8 data bits\n45:                 if (bit_count < 4\'d8) begin\n46:                     bit_count <= bit_count + 1;\n47:                 end\n48:             end else if (next_state == S_DATA && current_state == S_IDLE && in == 1\'b0) begin\n49:                 // Transition from IDLE to DATA means we received the start bit (0), count starts at 1\n50:                 bit_count <= 4\'d1;\n51:             end else begin\n52:                 // Reset counter if we transition out of the S_DATA phase\n53:                 if (next_state != S_DATA) begin\n54:                     bit_count <= 4\'d0;\n55:                 end\n56:             end\n57:             \n58:             // Done pulse logic: Assert high only on the cycle the transition from WAIT_STOP to IDLE occurs\n59:             if (current_state == S_WAIT_STOP && in == 1\'b1 && next_state == S_IDLE)\n60:             begin\n61:                 done_pulse <= 1\'b1; // Pulse done high for one cycle\n62:             end else begin\n63:                 done_pulse <= 1\'b0;\n64:             end\n65:         end\n66:     end\n67: \n68:     // Combinational Logic (Next State Determination)\n69:     always @(*)\n70:     begin\n71:         next_state = current_state;\n72:         \n73:         case (current_state)\n74:             S_IDLE:\n75:             b