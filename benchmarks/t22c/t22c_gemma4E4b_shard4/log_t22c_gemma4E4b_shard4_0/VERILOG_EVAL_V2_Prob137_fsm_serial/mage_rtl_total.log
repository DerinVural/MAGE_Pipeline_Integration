		.clk, clk,
		in, in,
		.reset, reset
	);
	RefModule good1 (
		.clk, clk,
		in, in,
		.reset, reset,
		done(done_ref) 
	);
	TopModule top_module1 (
		.clk, clk,
		in, in,
		.reset, reset,
		done(done_dut) 
	);

