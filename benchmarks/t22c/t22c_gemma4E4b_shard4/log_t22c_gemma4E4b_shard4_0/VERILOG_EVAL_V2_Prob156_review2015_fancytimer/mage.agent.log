// --- Stimulus Generator (Original - Kept for functionality) ---
module stimulus_gen (
	input wire clk,
	output reg reset,
	output reg data, 
	output reg ack,
	input wire tb_match, // Added for completeness, though not strictly necessary for queue TB
	input wire counting_dut // Added for completeness
);
	bit failed = 0;
	int counting_cycles = 0;
	
	always @(posedge clk, negedge clk)
		if (!tb_match) 
			failed <= 1;
			
	always @(posedge clk)
		if (counting_dut)
			counting_cycles++;
	
	initial begin

		@(posedge clk);
		failed <= 0;
		reset <= 1;
		data <= 0;
		ack <= 1'bx;
		@(posedge clk) 
			data <= 1;
			reset <= 0;
		@(posedge clk) data <= 0;
		@(posedge clk) data <= 0;
		@(posedge clk) data <= 1;
		@(posedge clk) data <= 1;
		@(posedge clk) data <= 0;
		@(posedge clk) data <= 1;
		@(posedge clk) data <= 0;
		@(posedge clk) data <= 0;
		@(posedge clk) data <= 0;
		@(posedge clk) data <= 1;
		@(posedge clk);
			data <= 1'bx;
		repeat(2000) @(posedge clk);
			ack <= 1'b0;
		repeat(3) @(posedge clk);
			ack <= 1'b1;
		@(posedge clk);
			ack <= 1'b0;
			data <= 1'b1;
		if (counting_cycles != 2000)
			$display("Hint: The first test case should count for 2000 cycles. Your circuit counted %0d", counting_cycles);
		counting_cycles <= 0;
		@(posedge clk);
			ack <= 1'bx;
			data <= 1'b1;
		@(posedge clk);
			data <= 1'b0;
		@(posedge clk);
			data <= 1'b1;
		@(posedge clk);	data <= 1'b1;
		@(posedge clk);	data <= 1'b1;
		@(posedge clk);	data <= 1'b1;
		@(posedge clk);	data <= 1'b0;
		repeat(14800) @(posedge clk);
			ack <= 1'b0;
		repeat(400) @(posedge clk);

		if (counting_cycles != 15000)
			$display("Hint: The second test case should count for 15000 cycles. Your circuit counted %0d", counting_cycles);
		counting_cycles <= 0;

		if (failed)
			$display("Hint: Your FSM didn't pass the sample timing diagram posted with the problem statement. Perhaps try debugging that?");
		
		
		repeat(1000) @(posedge clk, negedge clk) begin
			reset <= !($random & 8191);
			data <= $random;
			act <= !($random & 31);
		end
		repeat(100000) @(posedge clk) begin
			reset <= !($random & 8191);
			data <= $random;
			act <= !($random & 31);
		end

		#1 $finish;
	end

endmodule

// --- Testbench (Improved with Queue Tracking) ---
module tb();

    // Queue-based simulation mismatch tracking structures
    // Pattern detection length is 4 bits (1101). Max size set to 10.
    localparam MAX_QUEUE_SIZE = 10;

    // Input Signals Queue
    reg reset_queue [MAX_QUEUE_SIZE-1:0];
    reg data_queue [MAX_QUEUE_SIZE-1:0];
    reg ack_queue [MAX_QUEUE_SIZE-1:0];
    
    // DUT Output Signals Queue
    reg [3:0] count_dut_queue [MAX_QUEUE_SIZE-1:0];
    reg counting_dut_queue [MAX_QUEUE_SIZE-1:0];
    reg done_dut_queue [MAX_QUEUE_SIZE-1:0];

    // Reference/Golden Signals Queue
    reg [3:0] count_ref_queue [MAX_QUEUE_SIZE-1:0];
    reg counting_ref_queue [MAX_QUEUE_SIZE-1:0];
    reg done_ref_queue [MAX_QUEUE_SIZE-1:0];
    
    // Control/Status Queue
    reg reset_queue_control [MAX_QUEUE_SIZE-1:0]; // Stores the state of the system reset

    // Tracking variables
    int mismatch_count = 0;
    int first_mismatch_time = 0;
    
    // Clock and Signals
    reg clk = 0;
    initial forever
        #5 clk = ~clk;

    logic reset;
    logic data;
    logic ack;
    logic [3:0] count_ref;
    logic [3:0] count_dut;
    logic counting_ref;
    logic counting_dut;
    logic done_ref;
    logic done_dut;
    
    // Testbench Match Signal (Used by stimulus_gen)
    wire tb_match;
    wire tb_mismatch = ~tb_match;

    // Initial Signal Setup
    initial begin 
        $dumpfile("wave.vcd");
        $dumpvars(1, tb);

        // Initial State Setup
        reset = 1;
        data = 0;
        ack = 0;
        count_ref = 4'b0;
        count_dut = 4'b0;
        counting_ref = 1'b0;
        counting_dut = 1'b0;
        done_ref = 1'b0;
        done_dut = 1'b0;

        @(posedge clk);
        reset <= 0;
    end

    // --- Module Instantiations ---
    // RefModule (Golden Reference) - Assuming RefModule exists and matches TopModule interface
    RefModule good1 (
        .clk, 
        .reset, 
        .data, 
        .ack, 
        .count(count_ref),
        .counting(counting_ref),
        .done(done_ref) 
    );
        
    // DUT Module
    TopModule top_module1 (
        .clk, 
        .reset, 
        .data, 
        .ack, 
        .count(count_dut),
        .counting(counting_dut),
        .done(done_dut) 
    );
    
    // Stimulus Generator
    stimulus_gen stim1 (
        .clk, 
        .reset, 
        .data, 
        .ack, 
        .tb_match, 
        .counting_dut
    );

    // Verification Logic
    // tb_match is true if all compared signals match.
    assign tb_match = ( { count_ref, counting_ref, done_ref } == { count_dut, counting_dut, done_dut } );

    // --- Queue Management and Mismatch Detection ---
    always @(posedge clk, negedge clk) begin
        
        // 1. Manage Queue Size
        if (data_queue.size() >= MAX_QUEUE_SIZE - 1) begin
            // Shift elements (delete 0)
            for (int i = 0; i < MAX_QUEUE_SIZE - 1; i++) begin
                reset_queue[i] = reset_queue[i+1];
                data_queue[i] = data_queue[i+1];
                ack_queue[i] = ack_queue[i+1];
                count_dut_queue[i] = count_dut_queue[i+1];
                counting_dut_queue[i] = counting_dut_queue[i+1];
                done_dut_queue[i] = done_dut_queue[i+1];
                count_ref_queue[i] = count_ref_queue[i+1];
                counting_ref_queue[i] = counting_ref_queue[i+1];
                done_ref_queue[i] = done_ref_queue[i+1];
                reset_queue_control[i] = reset_queue_control[i+1];
            end
        end

        // 2. Push Current Values
        reset_queue[MAX_QUEUE_SIZE-1] = reset;
        data_queue[MAX_QUEUE_SIZE-1] = data;
        ack_queue[MAX_QUEUE_SIZE-1] = ack;

        count_dut_queue[MAX_QUEUE_SIZE-1] = count_dut;
        counting_dut_queue[MAX_QUEUE_SIZE-1] = counting_dut;
        done_dut_queue[MAX_QUEUE_SIZE-1] = done_dut;

        count_ref_queue[MAX_QUEUE_SIZE-1] = count_ref;
        counting_ref_queue[MAX_QUEUE_SIZE-1] = counting_ref;
        done_ref_queue[MAX_QUEUE_SIZE-1] = done_ref;
        reset_queue_control[MAX_QUEUE_SIZE-1] = reset;

        // 3. Check for Mismatch
        if (!tb_match) begin
            if (mismatch_count == 0) begin
                first_mismatch_time = $time;
            end
            mismatch_count = mismatch_count + 1;

            $display("\n====================================================================");
            $display("!!! MISMATCH DETECTED AT TIME %0t !!!", $time);
            $display("Last %0d cycles of simulation (Max Queue Size: %0d):
", count_dut_queue.size(), MAX_QUEUE_SIZE);

            for (int i = 0; i < count_dut_queue.size(); i++) begin
                
                // Check if current entry is the mismatch point
                if (i == MAX_QUEUE_SIZE - 1) begin
                    $display("--- MISMATCH POINT (Cycle %0d) ---", i);
                end else if (i == MAX_QUEUE_SIZE - 2) begin
                    $display("--- PREVIOUS CYCLE (Cycle %0d) ---", i);
                end
                
                // Formatting helper function for display
                function string format_hex_bin(logic [3:0] val);
                    return $sformatf("HEX:%h, BIN:%b", val, val);
                endfunction
                
                $display("Cycle %0d | Reset:%b | Data:%b | Ack:%b | ", 
                    i, 
                    reset_queue_control[i], 
                    data_queue[i], 
                    ack_queue[i]);

                $display("  | Ref: C=%s, Count=%b, Done=%b | Got: C=%s, Count=%b, Done=%b", 
                    format_hex_bin(count_ref_queue[i]), 
                    counting_ref_queue[i], 
                    done_ref_queue[i], 
                    format_hex_bin(count_dut_queue[i]), 
                    counting_dut_queue[i], 
                    done_dut_queue[i]);
            end
            $display("====================================================================\n");
        end
    end

    // --- Timeout and Final Check ---
    initial begin
        // Run the specific test cases first (from original TB)
        // These sections are handled by stimulus_gen, we just let it run.

        // Monitor for timeout (100K cycles)
        #1000000
        $display("\n--- TIMEOUT REACHED ---");
        $finish();

        // Wait for simulation to naturally end if no timeout is hit during randomized phase
        @(posedge clk);
        if (mismatch_count > 0) begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", mismatch_count, first_mismatch_time);
        end else begin
            $display("SIMULATION PASSED");
        end
        $finish;
    end

endmodule
