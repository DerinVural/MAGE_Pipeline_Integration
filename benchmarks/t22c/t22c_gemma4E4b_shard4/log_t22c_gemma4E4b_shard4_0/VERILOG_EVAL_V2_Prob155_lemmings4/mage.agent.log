	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	
	// --- Stimulus Generation Instantiation ---
	stimulus_gen stim1 (
		.clk, clk_tb,
		.areset, areset,
		.bump_left, bump_left,
		.bump_right, bump_right,
		.dig, dig,
		.ground, ground,
		.wavedrom_title, wavedrom_title,
		.wavedrom_enable, wavedrom_enable,
		.tb_match, tb_match
	);

	// --- DUT and Reference Instantiations ---
	RefModule good1 (
		.clk, clk_tb,
		areset, areset,
		bump_left, bump_left,
		bump_right, bump_right,
		.ground, ground,
		dig, dig,
		.walk_left(walk_left_ref),
		.walk_right(walk_right_ref),
		aah(aaah_ref),
		digging(digging_ref)
	);
	
	TopModule top_module1 (
		.clk, clk_tb,
		areset, areset,
		bump_left, bump_left,
		bump_right, bump_right,
		.ground, ground,
		dig, dig,
		.walk_left(walk_left_dut),
		.walk_right(walk_right_dut),
		aah(aaah_dut),
		digging(digging_dut)
	);

	// --- Control & Verification Logic ---
	
	// Calculate tb_match based on the difference between DUT and Reference
	// Note: The original XOR logic is equivalent to simple inequality (A != B).
	assign tb_match = (walk_left_ref === walk_left_dut) &&
	                  (walk_right_ref === walk_right_dut) &&
	                  (aaah_ref === aaah_dut) &&
	                  (digging_ref === digging_dut);

		// Control inputs driving the DUT/Reference
		initial begin
			// Initialize to known safe state (assuming initial reset is high/1)
			areset = 1'b1;
			bump_left = 1'b0;
			bump_right = 1'b0;
			ground = 1'b1;
			dig = 1'b0;
		end

		// Task to synchronize inputs/outputs to clock edges if necessary for setup/hold, 
		// but for this structured testbench, we rely on stimulus_gen driving inputs.
		end

	// Final reporting block
	initial begin
		// Wait for simulation to finish (or timeout)
		@(negedge clk_tb);
		// Wait a little longer to ensure all queued data is processed
		#10;

		if (input_queue.size() == 0) begin
			$display("SIMULATION PASSED");
		end else begin
			// If the queue is not empty, it means at least one mismatch occurred.
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", 
				// Since we only track the first detected mismatch at the time it enters the queue, 
				// we approximate the first error time from the queue history.
				// For simplicity, we report the time of the first queued error based on queue history.
				$time // A precise time requires tracking the first mismatch event separately from queue size
			);
			end
	end

	// Timeout mechanism
	initial begin
		#1000000
		$display("TIMEOUT REACHED");
		$finish();
	end

endmodule
