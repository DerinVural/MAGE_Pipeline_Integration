module tb();

	// Define structure for statistics	
type stats_t;
stats_t stats1;

// Define queue types based on signal widths
// Inputs: clk(1), areset(1), bump_left(1), bump_right(1), ground(1), dig(1) -> 6 bits total for input vector
// Outputs: walk_left(1), walk_right(1), aaah(1), digging(1) -> 4 bits total for output vector

	// Queue for Input Signals (Clock cycle + 6 primary inputs)
reg [5:0] input_data_vec;
reg [1:0] input_control_vec; // Placeholder for clk/reset cycle info if needed, but we use clocking logic
reg input_queue [$];
	// Queue for Got Outputs
reg [3:0] got_output_vec;
reg got_output_queue [$];
	// Queue for Golden Outputs
reg [3:0] golden_output_vec;
reg golden_output_queue [$];
	// Queue for Reset Signals
reg reset_queue [$];

	localparam MAX_QUEUE_SIZE = 10;

	// Verification Signals
	wire tb_match;
	wire tb_mismatch = ~tb_match;

	// DUT/Reference Wires
	logic walk_left_ref, walk_right_ref, aaah_ref, digging_ref;
	logic walk_left_dut, walk_right_dut, aaah_dut, digging_dut;
	logic clk_tb;
	
	// Testbench Clock
	initial begin
		clk_tb = 0;
		forever #5 clk_tb = ~clk_tb;
		end

	// Clocking for Queueing and Mismatch Detection
	always @(posedge clk_tb, negedge clk_tb) begin
		if (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin
			input_queue.delete(0);
			got_output_queue.delete(0);
			golden_output_queue.delete(0);
			reset_queue.delete(0);
		end

		// Capture Current State/Inputs
		// Input vector: {bump_left, bump_right, ground, dig, areset} (5 bits for primary inputs + 1 for reset capture)
		input_data_vec = {bump_left, bump_right, ground, dig, areset}; 
		input_queue.push_back(input_data_vec);
		
		// Capture Outputs
		got_output_vec = {walk_left_dut, walk_right_dut, aaah_dut, digging_dut};
		golden_output_vec = {walk_left_ref, walk_right_ref, aaah_ref, digging_ref};
		
		// Capture Reset State (Assuming areset tracks the reset signal state on the clock edge)
		reset_queue.push_back(areset);

		// Check for Mismatch
		if (got_output_vec !== golden_output_vec) begin
			// Mismatch detected. Display history.
			$display("Mismatch detected at time %0t", $time);
			$display("\nLast %0d cycles of simulation (MAX_QUEUE_SIZE=%0d):", input_queue.size(), MAX_QUEUE_SIZE);
			
			for (int i = 0; i < input_queue.size(); i++) begin
				if (got_output_queue[i] === golden_output_queue[i]) begin
				$display("Match at Cycle %0d", i);
				// Display details for matched cycles if required, but primarily focus on the mismatch context.
			end else begin
				$display("*** MISMATCH AT CYCLE %0d ***", i);
				$display("Cycle %0d, Reset %b, Input Vector %b (h=%h), Got Output %b (h=%h), Expected Output %b (h=%h)",
				i, 
				reset_queue[i], 
				input_queue[i], 
				got_output_queue[i], 
				golden_output_queue[i]);
			end
			end
		end
	end

	// Signals for DUT/Reference Instantiation
	logic bump_left, bump_right, ground, dig;
	logic areset;
	logic walk_left_dut, walk_right_dut, aaah_dut, digging_dut;
	logic walk_left_ref, walk_right_ref, aaah_ref, digging_ref;
	
