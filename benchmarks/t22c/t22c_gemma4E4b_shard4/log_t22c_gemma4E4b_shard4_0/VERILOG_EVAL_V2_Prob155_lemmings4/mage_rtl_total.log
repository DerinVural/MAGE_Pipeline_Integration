ndtask\n49: \t\n50: task wavedrom_stop;\n51: \t#1;\n52: \tendtask\n53: \n54: \n55: \tinitial begin\n56: \treset <= 1\'b1;\n57: \t@(posedge clk);\n58: \treset <= 0;\n59: \t{bump_left, bump_right, ground, dig} <= 2;\n60: \trepeat(2) @(posedge clk);\n61: \t{bump_left, bump_right, ground, dig} <= 3;\n62: \t@(posedge clk);\n63: \t{bump_left, bump_right, ground, dig} <= 2;\n64: \t@(posedge clk);\n65: \t{bump_left, bump_right, ground, dig} <= 10;\n66: \t@(posedge clk);\n67: \t{bump_left, bump_right, ground, dig} <= 2;\n68: \t@(posedge clk);\n69: \t{bump_left, bump_right, ground, dig} <= 0;\n70: \trepeat(3) @(posedge clk);\n71: \t{bump_left, bump_right, ground, dig} <= 3;\n72: \t@(posedge clk);\n73: \t{bump_left, bump_right, ground, dig} <= 2;\n74: \trepeat(4) @(posedge clk);\n75: \t\n76: \t{bump_left, bump_right, ground, dig} <= 0;\t// Fall\n77: \trepeat(20) @(posedge clk);\n78: \t{bump_left, bump_right, ground, dig} <= 2;\t// Survive\n79: \trepeat(1) @(posedge clk);\n80: \n81: \t{bump_left, bump_right, ground, dig} <= 0;\t// Fall\n82: \trepeat(21) @(posedge clk);\n83: \t{bump_left, bump_right, ground, dig} <= 2;\t// Splat after falling left\n84: \trepeat(20) @(posedge clk) begin\n85: \t\t{dig, bump_right, bump_left} <= $random & $random;\t// See if it\'s handled correctly.\n86: \t\tground <= |($random & 7);\n87: \tend\n88: \t\n89: \treset <= 1;\n90: \t{bump_left, bump_right, ground, dig} <= 2;\t// Normal\n91: \t@(posedge clk)\n92: \treset <= 0;\t// Resurrect.\n93: \tbump_left <= 1;\n94: \trepeat(5) @(posedge clk);\n95: \t{bump_left, bump_right, ground, dig} <= 0;\t// Fall\n96: \trepeat(21) @(posedge clk);\n97: \t{bump_left, bump_right, ground, dig} <= 2;\t// Splat after falling right\n98: \trepeat(20) @(posedge clk) begin\n99: \t\t{dig, bump_right, bump_left} <= $random & $random;\t// See if it\'s handled correctly.\n100: \t\tground <= |($random & 7);\n101: \tend\n102: \n103: \treset <= 1;\n104: \t@(posedge clk)\n105: \treset <= 0;\t// Resurrect.\n106: \t{bump_left, bump_