ft\n95:                 end else if (bump_left) begin\n96:                     state_next = S_WL;\n97:                 // Precedence 3: Falling (Ground disappears)\n98:                 end else if (!ground) begin\n99:                     state_next = S_FR; // Falling maintains current direction (Right)\n100:                 end\n101:                 // Otherwise, stay S_WR\n102:                 end\n103: \n104:             S_FL: begin // Falling\n105:                 // Precedence 1: Splatter Check\n106:                 if (fall_counter >= 20) begin\n107:                     state_next = S_SP;\n108:                 // Precedence 2: Ground Reappears\n109:                 end else if (ground) begin\n110:                     // Resume walking in the direction stored when entering fall\n111:                     if (current_direction == 0) state_next = S_WL;\n112:                     else state_next = S_WR;\n113:                 // Otherwise, continue falling\n114:                 end\n115:             end\n116: \n117:             S_FR: begin // Falling\n118:                 // Precedence 1: Splatter Check\n119:                 if (fall_counter >= 20) begin\n120:                     state_next = S_SP;\n121:                 // Precedence 2: Ground Reappears\n122:                 end else if (ground) begin\n123:                     // Resume walking in the direction stored when entering fall\n124:                     if (current_direction == 0) state_next = S_WL;\n125:                     else state_next = S_WR;\n126:                 // Otherwise, continue falling\n127:                 end\n128:             end\n129: \n130:             S_DL: begin // Digging Left\n131:                 // Precedence 1: Ground disappears (Fall)\n132:                 if (!ground) begin\n133:                     // Direction stored when entering dig (which originated from a walk state)\n134:                     if (current_direction == 0) state_next = S_FL; \n135:                     else stat