put_vec = {walk_left_dut, walk_right_dut, aaah_dut, digging_dut};\n\t\tgolden_output_vec = {walk_left_ref, walk_right_ref, aaah_ref, digging_ref};\n\t\t\n\t\t// Capture Reset State (Assuming areset tracks the reset signal state on the clock edge)\n\t\treset_queue.push_back(areset);\n\n\t\t// Check for Mismatch\n\t\tif (got_output_vec !== golden_output_vec) begin\n\t\t\t// Mismatch detected. Display history.\n\t\t\t$display(\"Mismatch detected at time %0t\", $time);\n\t\t\t$display(\"\\nLast %0d cycles of simulation (MAX_QUEUE_SIZE=%0d):\", input_queue.size(), MAX_QUEUE_SIZE);\n\t\t\t\n\t\t\tfor (int i = 0; i < input_queue.size(); i++) begin\n\t\t\t\tif (got_output_queue[i] === golden_output_queue[i]) begin\n\t\t\t\t$display(\"Match at Cycle %0d\", i);\n\t\t\t\t// Display details for matched cycles if required, but primarily focus on the mismatch context.\n\t\t\tend else begin\n\t\t\t\t$display(\"*** MISMATCH AT CYCLE %0d ***\", i);\n\t\t\t\t$display(\"Cycle %0d, Reset %b, Input Vector %b (h=%h), Got Output %b (h=%h), Expected Output %b (h=%h)\",\n\t\t\t\ti, \n\t\t\t\treset_queue[i], \n\t\t\t\tinput_queue[i], \n\t\t\t\tgot_output_queue[i], \n\t\t\t\tgolden_output_queue[i]);\n\t\t\tend\n\t\t\tend\n\t\tend\n\tend\n\n\t// Signals for DUT/Reference Instantiation\n\tlogic bump_left, bump_right, ground, dig;\n\tlogic areset;\n\tlogic walk_left_dut, walk_right_dut, aaah_dut, digging_dut;\n\tlogic walk_left_ref, walk_right_ref, aaah_ref, digging_ref;\n\t\n\t// Wavedrom signals (Required by stimulus_gen)\n\twire[511:0] wavedrom_title;\n\twire wavedrom_enable;\n\t\n\t// --- Stimulus Generation Instantiation ---\n\tstimulus_gen stim1 (\n\t\t.clk, clk_tb,\n\t\t.areset, areset,\n\t\t.bump_left, bump_left,\n\t\t.bump_right, bump_right,\n\t\t.dig, dig,\n\t\t.ground, ground,\n\t\t.wavedrom_title, wavedrom_title,\n\t\t.wavedrom_enable, wavedrom_enable,\n\t\t.tb_match, tb_match\n\t);\n\n\t// --- DUT and Reference Instantiations ---\n\tRefModule good1 (\n\t\t.clk, clk_tb,\n\t\tareset, areset,\n\t\tbump_left, bump_left,\n\t\tbump_right, bump_right,\n\t\t.ground, ground,\n\t\tdig, dig,\n\t\t.walk_left(walk_left_ref),\n\t\t.walk_right(walk_right_ref),\n\t\taah(aaah_ref),\n\t\tdigging(digging_ref)\n\t);\n\t\n\tTopModule top_module1 (\n\t\t.clk, clk_tb,\n\t\tareset, areset,\n\t\tbump_left, bump_left,\n\t\tbump_right, bump_right,\n\t\t.ground, ground,\n\t\tdig, dig,\n\t\t.walk_left(walk_left_dut),\n\t\t.walk_right(walk_right_dut),\n\t\taah(aaah_dut),\n\t\tdigging(digging_dut)\n\t);\n\n\t// --- Control & Verification Logic ---\n\t\n\t// Calculate tb_match based on the difference between DUT and Reference\n\t// Note: The original XOR logic is equivalent to simple inequality (A != B).\n\tassign tb_match = (walk_left_ref === walk_left_dut) &&\n\t                  (walk_right_ref === walk_right_dut) &&\n\t                  (aaah_ref === aaah_dut) &&\n\t                  (digging_ref === digging_dut);\n\n\t\t// Control inputs driving the DUT/Reference\n\t\tinitial begin\n\t\t\t// Initialize to known safe state (assuming initial reset is high/1)\n\t\t\tareset = 1'b1;\n\t\t\tbump_left = 1'b0;\n\t\t\tbump_right = 1'b0;\n\t\t\tground = 1'b1;\n\t\t\tdig = 1'b0;\n\t\tend\n\n\t\t// Task to synchronize inputs/outputs to clock edges if necessary for setup/hold, \n\t\t// but for this structured testbench, we rely on stimulus_gen driving inputs.\n\t\tend\n\n\t// Final reporting block\n\tinitial begin\n\t\t// Wait for simulation to finish (or timeout)\n\t\t@(negedge clk_tb);\n\t\t// Wait a little longer to ensure all queued data is processed\n\t\t#10;\n\n\t\tif (input_queue.size() == 0) begin\n\t\t\t$display(\"SIMULATION PASSED\");\n\t\tend else begin\n\t\t\t// If the queue is not empty, it means at least one mismatch occurred.\n\t\t\t$display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\", \n\t\t\t\t// Since we only track the first detected mismatch at the time it enters the queue, \n\t\t\t\t// we approximate the first error time from the queue history.\n\t\t\t\t// For simplicity, we report the time of the first queued error based on queue history.\n\t\t\t\t$time // A precise time requires tracking the first mismatch event separately from queue size\n\t\t\t);\n\t\t\tend\n\tend\n\n\t// Timeout mechanism\n\tinitial begin\n\t\t#1000000\n\t\t$display(\"TIMEOUT REACHED\");\n\t\t$finish();\n\tend\n\nendmodule"
