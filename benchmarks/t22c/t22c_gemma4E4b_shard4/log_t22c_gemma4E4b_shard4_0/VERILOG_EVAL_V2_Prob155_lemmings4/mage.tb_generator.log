c\n44:             if (state == S_FL || state == S_FR) begin\n45:                 if (ground) begin\n46:                     fall_counter <= 0; // Reset counter upon hitting ground\n47:                 end else begin\n48:                     fall_counter <= fall_counter + 1;\n49:                 end\n50:             end\n51: \n52:             // Update direction tracking ONLY when transitioning into a WALKING state\n53:             if (state_next == S_WL) current_direction <= 0;\n54:             else if (state_next == S_WR) current_direction <= 1;\n55:         end\n56:     end\n57: \n58:     // Initialization block for non-reset path to prevent X values\n59:     initial begin\n60:         state = S_INIT;\n61:         fall_counter = 0;\n62:         current_direction = 0;\n63:     end\n64: \n65:     // --- Next State Logic (Combinational) ---\n66:     always @(*)\n67:     begin\n68:         state_next = state;\n69: \n70:         case (state) \n71:             S_INIT: begin\n72:                 // Initial state defaults to walking left upon exiting reset\n73:                 state_next = S_WL;\n74:             end\n75: \n76:             S_WL: begin // Walking Left\n77:                 // Precedence 1: Digging\n78:                 if (dig && ground) begin\n79:                     state_next = S_DL;\n80:                 // Precedence 2: Bumping Right\n81:                 end else if (bump_right) begin\n82:                     state_next = S_WR;\n83:                 // Precedence 3: Falling (Ground disappears)\n84:                 end else if (!ground) begin\n85:                     state_next = S_FL; // Falling maintains current direction (Left)\n86:                 end\n87:                 // Otherwise, stay S_WL\n88:                 end\n89: \n90:             S_WR: begin // Walking Right\n91:                 // Precedence 1: Digging\n92:                 if (dig && ground) begin\n93:                     state_next = S_DR;\n94:                 // Precedence 2: Bumping Left\n95:                 end else if (bump_left) begin\n96:                     state_next = S_WL;\n97:                 // Precedence 3: Falling (Ground disappears)\n98:                 end else if (!ground) begin\n99:                     state_next = S_FR; // Falling maintains current direction (Right)\n100:                 end\n101:                 // Otherwise, stay S_WR\n102:                 end\n103: \n104:             S_FL: begin // Falling\n105:                 // Precedence 1: Splatter Check\n106:                 if (fall_counter >= 20) begin\n107:                     state_next = S_SP;\n108:                 // Precedence 2: Ground Reappears\n109:                 end else if (ground) begin\n110:                     // Resume walking in the direction stored when entering fall\n111:                     if (current_direction == 0) state_next = S_WL;\n112:                     else state_next = S_WR;\n113:                 // Otherwise, continue falling\n114:                 end\n115:             end\n116: \n117:             S_FR: begin // Falling\n118:                 // Precedence 1: Splatter Check\n119:                 if (fall_counter >= 20) begin\n120:                     state_next = S_SP;\n121:                 // Precedence 2: Ground Reappears\n122:                 end else if (ground) begin\n123:                     // Resume walking in the direction stored when entering fall\n124:                     if (current_direction == 0) state_next = S_WL;\n125:                     else state_next = S_WR;\n126:                 // Otherwise, continue falling\n127:                 end\n128:             end\n129: \n130:             S_DL: begin // Digging Left\n131:                 // Precedence 1: Ground disappears (Fall)\n132:                 if (!ground) begin\n133:                     // Direction stored when entering dig (which originated from a walk state)\n134:                     if (current_direction == 0) state_next = S_FL; \n135:                     else state_next = S_FR;\n136:                 // Precedence 2: Digging stops\n137:                 end else if (!dig) begin\n138:                     // If dig input goes low while grounded, revert to walking in the same direction\n139:                     if (current_direction == 0) state_next = S_WL;\n140:                     else state_next = S_WR;\n141:                 // Otherwise, continue digging\n142:                 end\n143:             end\n144: \n145:             S_DR: begin // Digging Right\n146:                 // Precedence 1: Ground disappears (Fall)\n147:                 if (!ground) begin\n148:                     // Direction stored when entering dig\n149:                     if (current_direction == 0) state_next = S_FL; \n150:                     else state_next = S_FR;\n151:                 // Precedence 2: Digging stops\n152:                 end else if (!dig) begin\n153:                     if (current_direction == 0) state_next = S_WL;\n154:                     else state_next = S_WR;\n155:                 // Otherwise, continue digging\n156:                 end\n157:             end\n158: \n159:             S_SP: begin // Splattered - remains here until reset\n160:                 state_next = S_SP;\n161:             end\n162:         endcase\n163:     end\n164: \n165:     // --- Output Logic (Moore Machine) ---\n166:     always @(*)\n167:     begin\n168:         // Default outputs are 0\n169:         walk_left = 1\'b0;\n170:         walk_right = 1\'b0;\n171:         aaah = 1\'b0;\n172:         digging = 1\'b0;\n173: \n174:         case (state) \n175:             S_WL: begin\n176:                 walk_left = 1\'b1;\n177:                 digging = 1\'b1;\n178:             end\n179:             S_WR: begin\n180:                 walk_right = 1\'b1;\n181:                 digging = 1\'b1;\n182:             end\n183:             S_FL: begin\n184:                 aaah = 1\'b1;\n185:             end\n186:             S_FR: begin\n187:                 aaah =