[2026-05-14 15:46:54,755 - mage.agent - INFO] Revised tb:
[2026-05-14 15:46:54,755 - mage.agent - INFO] `timescale 1 ps/1 ps
`define OK 12
`define INCORRECT 13

module stimulus_gen (
	input clk,
	output logic in,
	output logic [9:0] state,
	input tb_match,
	input [9:0] next_state_ref,
	input [9:0] next_state_dut,
	output reg[511:0] wavedrom_title,
	output reg wavedrom_enable
);

	// Add two ports to module stimulus_gen:
	//    output [511:0] wavedrom_title
	//    output reg wavedrom_enable

	task wavedrom_start(input[511:0] title = "");
	endtask
	
	task wavedrom_stop;
		h#1;
	endtask
	
	reg [9:0] state_error = 10'h0;
	
	initial begin
		repeat(2) @(posedge clk);
		forever @(posedge clk, negedge clk)
			state_error <= state_error | (next_state_ref^next_state_dut);
		end
		
	initial begin
		state <= 0;
		
		@(negedge clk) wavedrom_start();
		for (int i=0;i<10;i++) begin
			@(negedge clk, posedge clk);
			state <= 1<< i;
			in <= 0;
		end
		for (int i=0;i<10;i++) begin
			@(negedge clk, posedge clk);
			state <= 1<< i;
			in <= 1;
		end	
		@(negedge clk) wavedrom_stop();
		
		// Test the one-hot cases first.
		repeat(200) @(posedge clk, negedge clk) begin
			state <= 1<< ($unsigned($random) % 10);
			in <= $random;
		end
		
		for (int i=0;i<$bits(state_error);i++) 
			$display("Hint: next_state[%0d] is %s.", i, (state_error[i] === 1'b0) ? "correct" : "incorrect");
		
		h#1 $finish;
	end
	
endmodule

module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_next_state;
		int errortime_next_state;
		int errors_out1;
		int errortime_out1;
		int errors_out2;
		int errortime_out2;
		int clocks;
		// Captured values for first error reporting
		logic in_err;
		logic [9:0] state_err;
		logic [9:0] next_state_ref_err;
		logic [9:0] next_state_dut_err;
		logic out1_ref_err;
		logic out1_dut_err;
		logic out2_ref_err;
		logic out2_dut_err;
	} stats;
	
	stats stats1;
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		h#5 clk = ~clk;

	logic in;
	logic [9:0] state;
	logic [9:0] next_state_ref;
	logic [9:0] next_state_dut;
	logic out1_ref;
	logic out1_dut;
	logic out2_ref;
	logic out2_dut;

	// Variables to capture first error details
	logic error_captured = 0;

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,in,state,next_state_ref,next_state_dut,out1_ref,out1_dut,out2_ref,out2_dut );
	end

	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk,
		in,
		.state,
		.tb_match,
		.next_state_ref,
		.next_state_dut,
		.wavedrom_title,
		.wavedrom_enable 
	);
	RefModule good1 (
		in,
		.state,
		.next_state(next_state_ref),
		out1(out1_ref),
		out2(out2_ref) );
	
	TopModule top_module1 (
		in,
		.state,
		.next_state(next_state_dut),
		out1(out1_dut),
		out2(out2_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		endtask
	
	
	// Logic to capture error details upon first mismatch
	always @(posedge clk, negedge clk) begin
		stats1.clocks++;
		
		if (!tb_match && !error_captured) begin
			// Record state at the first error time
			stats1.errortime = $time;
			stats1.in_err = in;
			stats1.state_err = state;
			stats1.next_state_ref_err = next_state_ref;
			stats1.next_state_dut_err = next_state_dut;
			stats1.out1_ref_err = out1_ref;
			stats1.out1_dut_err = out1_dut;
			stats1.out2_ref_err = out2_ref;
			stats1.out2_dut_err = out2_dut;
			error_captured = 1;
		end
		
		// Original error counting logic
		if (!tb_match) begin
			stats1.errors++;
		end
		
		// Next State Errors
		if (next_state_ref !== next_state_dut)
			begin 
				if (stats1.errors_next_state == 0) stats1.errortime_next_state = $time;
				stats1.errors_next_state = stats1.errors_next_state + 1'b1;
			end
		
		// Out1 Errors
		if (out1_ref !== out1_dut)
			begin 
			if (stats1.errors_out1 == 0) stats1.errortime_out1 = $time;
				stats1.errors_out1 = stats1.errors_out1 + 1'b1;
			end
		
		// Out2 Errors
		if (out2_ref !== out2_dut)
			begin 
			if (stats1.errors_out2 == 0) stats1.errortime_out2 = $time;
				stats1.errors_out2 = stats1.errors_out2 + 1'b1;
			end
		
	end

	// Display logic for required format (First Mismatch Details)
	always @(posedge clk, negedge clk)
	begin
		if (!tb_match && stats1.errors == 1 && error_captured == 1) begin
			// First mismatch detected. Display detailed information.
			$display("\n=============================================================");
			$display("!!! FIRST MISMATCH DETECTED AT TIME %0t ps !!!", $time);
			$display("-------------------------------------------------------------");
			$display("Inputs:");
			$display("  in:  %b (0x%h)", stats1.in_err, stats1.in_err);
			$display("  state: %b (0x%h)", stats1.state_err, stats1.state_err);
			$display("\nReference (Good) Outputs:");
			$display("  next_state: %b (0x%h)", stats1.next_state_ref_err, stats1.next_state_ref_err);
			$display("  out1: %b", stats1.out1_ref_err);
			$display("  out2: %b", stats1.out2_ref_err);
			$display("\nDUT Outputs:");
			$display("  next_state: %b (0x%h)", stats1.next_state_dut_err, stats1.next_state_dut_err);
			$display("  out1: %b", stats1.out1_dut_err);
			$display("  out2: %b", stats1.out2_dut_err);
			$display("=============================================================\n");
		end

	final begin
		// Check for errors and report using the required final message format
		if (stats1.errors_next_state > 0) begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_next_state, stats1.errortime_next_state);
		end
		if (stats1.errors_out1 > 0) begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_out1, stats1.errortime_out1);
		end
		if (stats1.errors_out2 > 0) begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_out2, stats1.errortime_out2);
		end
		
		if (stats1.errors == 0) begin
			$display("SIMULATION PASSED");
		end else begin
			// Report total errors if the specific field checks pass but total mismatch occurred
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
		end
		
		$display("Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
		$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
	end

	// add timeout after 100K cycles
	initial begin
		h#1000000
		$display("TIMEOUT");
		f$finish();
	end

endmodule

// Placeholder modules required by the golden testbench structure
