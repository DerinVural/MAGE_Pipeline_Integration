ail_reset = reset;\n118:                 fail_w = w;\n119:                 fail_z_dut = z_dut;\n120:                 fail_z_ref = z_ref;\n121:             end\n122:         end\n123:         \n124:         // Z Output Mismatch Check\n125:         if (z_ref !== ( z_ref ^ z_dut ^ z_ref ))\n126:         begin \n127:             if (stats1.errors_z == 0) stats1.errortime_z = $time;\n128:             stats1.errors_z = stats1.errors_z+1\'b1;\n129:             // Capture state at first Z mismatch (if it\'s the overall first mismatch)\n130:             if (stats1.errors_z == 1 && first_mismatch_time == -1) begin\n131:                 first_mismatch_time = $time;\n132:                 fail_clk = clk;\n133:                 fail_reset = reset;\n134:                 fail_w = w;\n135:                 fail_z_dut = z_dut;\n136:                 fail_z_ref = z_ref;\n137:             end\n138:         end\n139:     end\n140: \n141:     // Timeout\n142:     initial begin\n143:         #1000000\n144:         $display("TIMEOUT");\n145:         $finish();\n146:     end\n147: \n148:     // Final reporting block (Enhanced to meet strict requirements)\n149:     final begin\n150:         if (stats1.errors == 0 && stats1.errors_z == 0) begin\n151:             $display("\\n========================================")\n152:             $display("SIMULATION PASSED")\n153:             $display("========================================")\n154:         end else begin\n155:             int total_mismatches = stats1.errors + stats1.errors_z;\n156:             string failure_message = "SIMULATION FAILED - " + \n157:                 string(total_mismatches) + " MISMATCHES DETECTED, FIRST AT TIME " + \n158:                 string(first_mismatch_time);\n159:             $display("\\n========================================")\n160:             $display("%s", failure_message)\n161:             $display("========================================")\n162:             \n163:             // Detailed signal display