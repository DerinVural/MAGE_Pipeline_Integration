  \n53:     reg clk=0;\n54:     initial forever\n55:         #5 clk = ~clk;\n56: \n57:     logic reset;\n58:     logic w;\n59:     logic z_ref;\n60:     logic z_dut;\n61: \n62:     // DUT Instantiation\n63:     TopModule top_module1 (\n64:         .clk(clk),\n65:         .reset(reset),\n66:         .w(w),\n67:         .z(z_dut)\n68:     );\n69: \n70:     // Reference Instantiation\n71:     RefModule good1 (\n72:         .clk(clk),\n73:         .reset(reset),\n74:         .w(w),\n75:         .z(z_ref)\n76:     );\n77:         \n78:     // Stimulus Generation Instantiation\n79:     stimulus_gen stim1 (\n80:         .clk(clk),\n81:         .reset(reset),\n82:         .w(w)\n83:     );\n84: \n85:     // Dump waves\n86:     initial begin \n87:         $dumpfile("wave.vcd");\n88:         $dumpvars(1, stim1.clk, tb_mismatch ,clk,reset,w,z_ref,z_dut );\n89:     end\n90: \n91:     wire tb_match;\n92:     wire tb_mismatch = ~tb_match;\n93:     \n94:     // Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.\n95:     assign tb_match = ( { z_ref } === ( { z_ref } ^ { z_dut } ^ { z_ref } ) );\n96: \n97:     bit strobe = 0;\n98:     task wait_for_end_of_timestep;\n99:         repeat(5) begin\n100:             strobe <= !strobe;  // Try to delay until the very end of the time step.\n101:             @(strobe);\n102:         end\n103:     endtask\n104: \n105:     // Clocked verification and error counting\n106:     always @(posedge clk, negedge clk) begin\n107:         stats1.clocks++;\n108:         \n109:         // General Mismatch Check\n110:         if (!tb_match) begin\n111:             if (stats1.errors == 0) stats1.errortime = $time;\n112:             stats1.errors++;\n113:             // Capture state at first general mismatch\n114:             if (stats1.errors == 1 && first_mismatch_time == -1) begin\n115:                 first_mismatch_time = $time;\n116:                 fail_clk = clk;\n117:                 fail_reset = reset;\n118:                 fail_w = w;\n119:                 fail_z_dut = z_dut;\n120:                 fail_z_ref = z_ref;\n121:             end\n122:         end\n123:         \n124:         // Z Output Mismatch Check\n125:         if (z_ref !== ( z_ref ^ z_dut ^ z_ref ))\n126:         begin \n127:             if (stats1.errors_z == 0) stats1.errortime_z = $time;\n128:             stats1.errors_z = stats1.errors_z+1\'b1;\n129:             // Capture state at first Z mismatch (if it\'s the overall first mismatch)\n130:             if (stats1.errors_z == 1 && first_mismatch_time == -1) begin\n131:                 first_mismatch_time = $time;\n132:                 fail_clk = clk;\n133:                 fail_reset = reset;\n134:                 fail_w = w;\n135:                 fail_z_dut = z_dut;\n136:                 fail_z_ref = z_ref;\n137:             end\n138:         end\n139:     end\n140: \n141:     // Timeout\n142:     initial begin\n143:         #1000000\n144:         $display("TIMEOUT");\n145:         $finish();\n146:     end\n147: \n148:     // Final reporting block (Enhanced to meet strict requirements)\n149:     final begin\n150:         if (stats1.errors == 0 && stats1.errors_z == 0) begin\n151:             $display("\\n========================================")\n152:             $display("SIMULATION PASSED")\n153:             $display("========================================")\n154:         end else begin\n155:             int total_mismatches = stats1.errors + stats1.errors_z;\n156:             string failure_message = "SIMULATION FAILED - " + \n157:                 string(total_mismatches) + " MISMATCHES DETECTED, FIRST AT TIME " + \n158:                 string(first_mismatch_time);\n159:             $display("\\n========================================")\n160:             $display("%s", failure_message)\n161:             $display("========================================")\n162:             \n163:             // Detailed signal display