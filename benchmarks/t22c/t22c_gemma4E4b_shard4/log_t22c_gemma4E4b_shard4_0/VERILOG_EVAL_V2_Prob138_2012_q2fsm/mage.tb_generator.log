\n    );\n\n    RefModule good1 (\n        .clk(clk),\n        .reset(reset),\n        .w(w),\n        .z(z_ref)\n    );\n\n    TopModule top_module1 (\n        .clk(clk),\n        .reset(reset),\n        .w(w),\n        .z(z_dut)\n    );\n\n    // --- Verification Signals ---\n    wire tb_match;\n    // Original logic: assign tb_match = ( { z_ref } === ( { z_ref } ^ { z_dut } ^ { z_ref } ) );\n    // Simplified based on 1-bit nature: (z_ref == z_ref ^ z_dut ^ z_ref) simplifies to (z_ref == z_dut)\n    assign tb_match = ( z_ref === z_dut );\n\n    // --- Statistics Tracking ---\n    int total_clocks = 0;\n    int mismatch_count = 0;\n    int first_mismatch_time = 0;\n\n    // --- Initialization and Dumping ---\n    initial begin \n        $dumpfile(\"wave.vcd\");\n        // Dump all relevant signals\n        $dumpvars(0, tb);\n        \n        // Initialize inputs for the first cycle\n        reset = 1'b1; \n        w = 1'b0;\n\n        // Wait for initial stabilization before starting clocking sequence\n        @(posedge clk);\n        reset = 1'b0;\n    end\n\n    // --- Queue Management and Mismatch Detection (Synchronous) ---\n    always @(posedge clk)\n    begin\n        total_clocks++;\n\n        // 1. Queue Management: Delete oldest if size limit reached\n        if (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin\n            input_queue.delete(0);\n            got_output_queue.delete(0);\n            golden_queue.delete(0);\n            reset_queue.delete(0);\n        end\n\n        // 2. Push current data\n        // Input data: {w, reset}\n        input_queue.push_back({w, reset});\n        // Outputs\n        got_output_queue.push_back(z_dut);\n        golden_queue.push_back(z_ref);\n        reset_queue.push_back(reset);\n\n        // 3. Check for first mismatch (Using the reference comparison as the primary trigger)\n        if (z_dut !== z_ref) begin\n            if (mismatch_count == 0) begin\n                first_mismatch_time = $time;\n            end\n            mismatch_count = mismatch_count + 1;\n\n            // Display queue content upon first mismatch detection\n            if (mismatch_count == 1) begin\n                $display(\"==================================================================\");\n                $display(\"!!! MISMATCH DETECTED AT TIME %0d !!!\", $time);\n                $display(\"\\nLast %0d cycles of simulation (Max Queue Size = %0d):\", input_queue.size(), MAX_QUEUE_SIZE);\n\n                // Display queue contents\n                for (int i = 0; i < input_queue.size(); i++) begin\n                    // Display input (w, reset), got output (z_dut), exp output (z_ref)\n                    $display(\"Cycle %0d | Reset: %b | Input W: %b | Got Z: %b | Exp Z: %b\",\n                        i, \n                        reset_queue[i], \n                        input_queue[i][0], // w\n                        got_output_queue[i], \n                        golden_queue[i]\n                    );\n                end\n                $display(\"==================================================================\");\n            end\n        end\n\n    end\n\n    // add timeout after 100K cycles\n    initial begin\n     #1000000\n     $display(\"\\n--- TIMEOUT REACHED ---\");\n     $finish();\n   end\n\n    // --- Final Results Display ---\n    initial begin\n        @(posedge clk);\n        // Wait for simulation to naturally finish via $finish in stimulus_gen, or run until timeout\n        wait (total_clocks >= 1);\n\n        if (mismatch_count == 0) begin\n            $display(\"\\n****************************************\");\n            $display(\"SIMULATION PASSED\");\n            $display(\"****************************************\");\n        end else begin\n            $display(\"\\n****************************************\");\n            $display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\", mismatch_count, first_mismatch_time);\n            $display(\"****************************************\");\n        end\n        \n        #10; // Give time for final messages to print\n        $finish;\n    end\n\nendmodule"
