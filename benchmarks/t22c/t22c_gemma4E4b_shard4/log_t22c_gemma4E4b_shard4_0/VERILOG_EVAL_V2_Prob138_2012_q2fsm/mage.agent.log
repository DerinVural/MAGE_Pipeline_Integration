`define OK 12
`define INCORRECT 13

// Stimulus Generator (Kept exactly as in golden testbench)
module stimulus_gen (
	input clk,
	output logic reset,
	output logic w
);
	initial begin
		repeat(200) @(negedge clk) begin
			reset <= ($random & 'h1f) == 0;
			w <= $random;
		end
		
		#1 $finish;
	end
	endmodule

// Reference Module (Kept exactly as in golden testbench)
module RefModule (
	input clk,
	input reset,
	input w,
	output logic z
);
    // Placeholder for golden reference implementation
