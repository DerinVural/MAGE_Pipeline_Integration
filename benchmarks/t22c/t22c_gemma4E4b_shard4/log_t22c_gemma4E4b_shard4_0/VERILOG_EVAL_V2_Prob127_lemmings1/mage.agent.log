// --- TopModule Implementation (Based on Specification) ---
module TopModule (
    input clk,
    input areset,
    input bump_left,
    input bump_right,
    output reg walk_left,
    output reg walk_right
);

    // State encoding: 0 = Walk Left, 1 = Walk Right
    typedef enum logic [0:0] {LEFT, RIGHT} state_t;
    state_t current_state, next_state;

    // Moore FSM: Outputs depend only on current_state
    always_comb begin
        if (current_state == LEFT) begin
            walk_left = 1'b1;
            walk_right = 1'b0;
        end else begin // current_state == RIGHT
            walk_left = 1'b0;
            walk_right = 1'b1;
        end
    end

    // State Register Logic (Sequential Block)
    always @(posedge clk or posedge areset)
    begin
        if (areset) begin
            // Asynchronous reset to walk left
            current_state <= LEFT;
        end else begin
            current_state <= next_state;
        end
    end

    // Next State Logic (Combinational Block)
    always_comb begin
        next_state = current_state;
        
        // If bumped on the left, switch to walk right
        if (bump_left == 1'b1) begin
            next_state = RIGHT;
        end
        // If bumped on the right, switch to walk left. 
        // Note: If both are 1, the 'bump_left' condition above takes precedence in this simple logic flow, resulting in RIGHT.
        // If the intention is that *any* bump causes a switch, and simultaneous bumps cause a switch, 
        // we prioritize bump_right if bump_left didn't trigger, or handle the OR condition.
        // Re-evaluating specification: "If it's bumped on both sides at the same time, it will still switch directions."
        // Let's define the transition: 
        // Current LEFT:
        //   bump_right=1 -> RIGHT
        //   bump_left=1 -> RIGHT
        //   Both=1 -> RIGHT (based on bump_left rule)
        // Current RIGHT:
        //   bump_left=1 -> RIGHT
        //   bump_right=1 -> LEFT
        //   Both=1 -> LEFT (based on bump_right rule, since bump_left already set it to RIGHT)
        
        // Simpler implementation based on direct state change: 
        // Bump Left forces RIGHT. Bump Right forces LEFT.
        if (bump_left == 1'b1) begin
            next_state = RIGHT;
        end else if (bump_right == 1'b1) begin
            next_state = LEFT;
        end
    end

endmodule

