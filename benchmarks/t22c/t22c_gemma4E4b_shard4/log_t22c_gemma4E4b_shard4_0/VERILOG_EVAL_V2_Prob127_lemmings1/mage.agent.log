		#5 clk = ~clk;

	logic areset;
	logic bump_left;
	logic bump_right;
	logic walk_left_ref;
	logic walk_left_dut;
	logic walk_right_ref;
	logic walk_right_dut;

	// --- Queue Declarations for New Requirement ---
	
	// Inputs driving the DUT state (excluding clock/reset handled by queue logic context)
	reg input_queue [7:0]; 
	// Outputs from DUT
	reg output_dut_queue [7:0]; 
	// Golden Reference Outputs
	reg output_golden_queue [7:0]; 
	// Reset signals (using areset for simplicity in this context)
	reg reset_queue [7:0]; 
	
	localparam MAX_QUEUE_SIZE = 8; // State machine has 2 states, 8 is sufficient, <= 10 enforced
	
	// Counters for tracking error state	
	reg error_count = 0;
	reg first_error_time = 0;
	
	// --- Clocking and Queue Logic ---
	always @(posedge clk, negedge clk) begin
		
		// 1. Queue Management: Shift contents if full
		if (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin
			input_queue.delete(0);
			output_dut_queue.delete(0);
			output_golden_queue.delete(0);
			reset_queue.delete(0);
		end

		// 2. Store current values
		// Inputs: {areset, bump_left, bump_right}
		input_queue.push_back({areset, bump_left, bump_right});
		// Outputs: {walk_left_dut, walk_right_dut}
		output_dut_queue.push_back({walk_left_dut, walk_right_dut});
		// Golden: {walk_left_ref, walk_right_ref}
		output_golden_queue.push_back({walk_left_ref, walk_right_ref});
		// Reset
		reset_queue.push_back(areset);

		// 3. Check for first mismatch
		if (error_count == 0) begin
			// Compare the newly added elements (the last element pushed)
			if ((walk_left_dut !== walk_left_ref) || (walk_right_dut !== walk_right_ref)) begin
				error_count = 1;
				first_error_time = $time;
				$display("\n// Queue-based simulation mismatch display //");
				$display("Mismatch detected at time %t", $time);
				$display("\nLast %d cycles of simulation:", input_queue.size());

				for (int i = 0; i < input_queue.size(); i++) begin
					// Extract values for display
					logic [2:0] current_input = input_queue[i];
					logic [1:0] current_dut_output = output_dut_queue[i];
					logic [1:0] current_golden_output = output_golden_queue[i];
					logic current_reset = reset_queue[i];

					if (current_dut_output === current_golden_output) begin
						sdisplay("Got Match at cycle %d", i);
					end else begin
						sdisplay("Got Mismatch at cycle %d", i);
					end
					// Displaying signals. Since they are 1-bit, we use %b.
					$display("Cycle %d, reset %b, input %b, got output %b, exp output %b",
					i,
					current_reset,
					current_input,
					current_dut_output,
					current_golden_output);
				end
			end
		end
	end


	// --- Original Testbench Structure (Modified for new error tracking) ---
	
	// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.
	assign tb_match = ( { walk_left_ref, walk_right_ref } === ( { walk_left_ref, walk_right_ref } ^ { walk_left_dut, walk_right_dut } ^ { walk_left_ref, walk_right_ref } ) );
	
	// Original clocking/stats update logic (modified to not double count errors, relying on queue for detailed first error)
	always @(posedge clk, negedge clk) begin
		stats1.clocks++;
		
		// Original logic for stats counting (retained)
		if (!tb_match) begin
			// Only increment error count if the queue hasn't registered the first error yet, or if this is a subsequent error.
			if (error_count == 0) begin
				// First error already handled by queue display
				end
			stats1.errors++;
			end
		end
		
		// Original detailed output tracking (retained)
		if (walk_left_ref !== ( walk_left_ref ^ walk_left_dut ^ walk_left_ref ))
		begin if (stats1.errors_walk_left == 0) stats1.errortime_walk_left = $time;
			sstats1.errors_walk_left = stats1.errors_walk_left+1'b1; end
		end
		if (walk_right_ref !== ( walk_right_ref ^ walk_right_dut ^ walk_right_ref ))
		begin if (stats1.errors_walk_right == 0) stats1.errortime_walk_right = $time;
			sstats1.errors_walk_right = stats1.errors_walk_right+1'b1; end
		end
	end

   // Add timeout after 100K cycles	
   initial begin
     #1000000
     $display("\nTIMEOUT REACHED.");
     $finish();
   end

	// --- Initial Block & Final Reporting --- 
	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stimulus_gen::stim1, clk, areset, bump_left, bump_right, walk_left_ref, walk_left_dut, walk_right_ref, walk_right_dut );
		
		// Initialize stats and queues
		stats1.errors = 0;
		stats1.clocks = 0;
		// Queues are automatically initialized to empty

		// Reset sequence start
		reset <= 1'b1;
		{bump_right, bump_left} <= 3'h3;
		stim1.wavedrom_start("Asynchronous reset");
		stim1.reset_test(1);
		repeat(3) @(posedge clk);
		{bump_right, bump_left} <= 2;
		repeat(2) @(posedge clk);
		{bump_right, bump_left} <= 1;
		repeat(2) @(posedge clk);
		stim1.wavedrom_stop();
		
		@(posedge clk);
		repeat(200) @(posedge clk, negedge clk) begin
			{bump_right, bump_left} <= $random & $random;
			reset <= !($random & 31);
		end
		
		// Wait until all stimulus is done and finish simulation
		#1 $finish;
	end

	// Final reporting block, updated to the required format
	always @(finish) begin
		// Print detailed status from original golden testbench (retained)
		if (stats1.errors_walk_left) $display("Hint: Output 'walk_left' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_walk_left, stats1.errortime_walk_left);
		else $display("Hint: Output 'walk_left' has no mismatches.");
		if (stats1.errors_walk_right) $display("Hint: Output 'walk_right' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_walk_right, stats1.errortime_walk_right);
		else $display("Hint: Output 'walk_right' has no mismatches.");
		
		$display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
		$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);

		// Final required output format
		if (stats1.errors == 0)
			sdisplay("SIMULATION PASSED");
		else begin
			// Use the time recorded in the queue check for the first error
			sdisplay("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, first_error_time);
		end
	end
