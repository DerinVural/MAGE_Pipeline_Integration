d\n\n    // 3. Combinational Logic: Output Generation (Moore Machine)\n    // Output depends ONLY on the current state\n    always @(*)\n    begin\n        walk_left = 1'b0;\n        walk_right = 1'b0;\n\n        case (current_state)\n            STATE_LEFT:\n                walk_left = 1'b1;\n            STATE_RIGHT:\n                walk_right = 1'b1;\n        endcase\n    end\n\nendmodule"
