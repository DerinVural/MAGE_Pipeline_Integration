atch anything, but X in dut_vector will only match X.\n\tassign tb_match = ( { walk_left_ref, walk_right_ref } === ( { walk_left_ref, walk_right_ref } ^ { walk_left_dut, walk_right_dut } ^ { walk_left_ref, walk_right_ref } ) );\n\t\n\t// Original clocking/stats update logic (modified to not double count errors, relying on queue for detailed first error)\n\talways @(posedge clk, negedge clk) begin\n\t\tstats1.clocks++;\n\t\t\n\t\t// Original logic for stats counting (retained)\n\t\tif (!tb_match) begin\n\t\t\t// Only increment error count if the queue hasn\'t registered the first error yet, or if this is a subsequent error.\n\t\t\tif (error_count == 0) begin\n\t\t\t\t// First error already handled by queue display\n\t\t\t\tend\n\t\t\tstats1.errors++;\n\t\t\tend\n\t\tend\n\t\t\n\t\t// Original detailed output tracking (retained)\n\t\tif (walk_left_ref !== ( walk_left_ref ^ walk_left_dut ^ walk_left_ref ))\n\t\tbegin if (stats1.errors_walk_left == 0) stats1.errortime_walk_left = $time;\n\t\t\tsstats1.errors_walk_left = stats1.errors_walk_left+1\'b1; end\n\t\tend\n\t\tif (walk_right_ref !== ( walk_right_ref ^ walk_right_dut ^ walk_right_ref ))\n\t\tbegin if (stats1.errors_walk_right == 0) stats1.errortime_walk_right = $time;\n\t\t\tsstats1.errors_walk_right = stats1.errors_walk_right+1\'b1; end\n\t\tend\n\tend\n\n   // Add timeout after 100K cycles\t\n   initial begin\n     #1000000\n     $display("\\nTIMEOUT REACHED.");\n     $finish();\n   end\n\n\t// --- Initial Block & Final Reporting --- \n\tinitial begin \n\t\t$dumpfile("wave.vcd");\n\t\t$dumpvars(1, stimulus_gen::stim1, clk, areset, bump_left, bump_right, walk_left_ref, walk_left_dut, walk_right_ref, walk_right_dut );\n\t\t\n\t\t// Initialize stats and queues\n\t\tstats1.errors = 0;\n\t\tstats1.clocks = 0;\n\t\t// Queues are automatically initialized to empty\n\n\t\t// Reset sequence start\n\t\treset <= 1\'b1;\n\t\t{bump_right, bump_left} <= 3\'h3;\n\t\tstim1.wavedrom_start("Asynchronous reset");\n\t\tstim1.reset