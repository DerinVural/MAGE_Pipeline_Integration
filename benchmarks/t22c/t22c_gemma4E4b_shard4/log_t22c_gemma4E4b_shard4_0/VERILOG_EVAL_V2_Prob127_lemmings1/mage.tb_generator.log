put bump_left,\n    input bump_right,\n    output reg walk_left,\n    output reg walk_right\n);\n\n    // State encoding: 0 = Walk Left, 1 = Walk Right\n    typedef enum logic [0:0] {LEFT, RIGHT} state_t;\n    state_t current_state, next_state;\n\n    // Moore FSM: Outputs depend only on current_state\n    always_comb begin\n        if (current_state == LEFT) begin\n            walk_left = 1'b1;\n            walk_right = 1'b0;\n        end else begin // current_state == RIGHT\n            walk_left = 1'b0;\n            walk_right = 1'b1;\n        end\n    end\n\n    // State Register Logic (Sequential Block)\n    always @(posedge clk or posedge areset)\n    begin\n        if (areset) begin\n            // Asynchronous reset to walk left\n            current_state <= LEFT;\n        end else begin\n            current_state <= next_state;\n        end\n    end\n\n    // Next State Logic (Combinational Block)\n    always_comb begin\n        next_state = current_state;\n        \n        // If bumped on the left, switch to walk right\n        if (bump_left == 1'b1) begin\n            next_state = RIGHT;\n        end\n        // If bumped on the right, switch to walk left. \n        // Note: If both are 1, the 'bump_left' condition above takes precedence in this simple logic flow, resulting in RIGHT.\n        // If the intention is that *any* bump causes a switch, and simultaneous bumps cause a switch, \n        // we prioritize bump_right if bump_left didn't trigger, or handle the OR condition.\n        // Re-evaluating specification: \"If it's bumped on both sides at the same time, it will still switch directions.\"\n        // Let's define the transition: \n        // Current LEFT:\n        //   bump_right=1 -> RIGHT\n        //   bump_left=1 -> RIGHT\n        //   Both=1 -> RIGHT (based on bump_left rule)\n        // Current RIGHT:\n        //   bump_left=1 -> RIGHT\n        //   bump_right=1 -> LEFT\n        //   Both=1 -> LEFT (based on bump_right rule, since bump_