    "testbench": "`timescale 1 ps/1 ps\n`define OK 12\n`define INCORRECT 13\n\n// --- DUT Interface and Reference Model (RefModule) ---\nmodule stimulus_gen (\n\tinput clk,\n\toutput logic [2:0] a,\n\toutput reg[511:0] wavedrom_title,\n\toutput reg wavedrom_enable\n);\n\n\ttask wavedrom_start(input[511:0] title = \"\");\n\tendtask\n\t\ntask wavedrom_stop;\n\t\th#1;\n\tendtask\n\n\tinitial begin\n\t\t@(negedge clk) wavedrom_start(\"Unknown circuit\");\n\t\t@(posedge clk) {a} <= 3'b0;\n\t\trepeat(10) @(posedge clk,negedge clk) a <= a + 1;\n\t\twavedrom_stop();\n\n\t\trepeat(100) @(posedge clk, negedge clk)\n\t\ta <= $urandom;\n\t\t$finish;\n\tend\n\ndendmodule\n\nmodule RefModule (\n\tinput [2:0] a,\n\toutput logic [15:0] q\n);\n\n\t// Logic derived from the provided sample waveform\n\talways_comb begin\n\t\tcase (a)\n\t\t\t3'b0: q = 16'h1232;\n\t\t\t3'b1: q = 16'haee0;\n\t\t\t3'b2: q = 16'h27d4;\n\t\t\t3'b3: q = 16'h5a0e;\n\t\t\t3'b4: q = 16'h2066;\n\t\t\t3'b5: q = 16'h64ce;\n\t\t\t3'b6: q = 16'hc526;\n\t\t\t3'b7: q = 16'h2f19;\n\t\t\tdefault: q = 16'hx;\n\t\tendcase\n\tend\n\ndendmodule\n\nmodule tb();\n\n\ttypedef struct packed {\n\t\tint errors;\n\t\tint errortime;\n\t\tint errors_q;\n\t\tint errortime_q;\n\t\tint clocks;\n\t} stats;\n\t\n\tstats stats1;\n\t\n\t\n\twire[511:0] wavedrom_title;\n\twire wavedrom_enable;\n\tint wavedrom_hide_after_time;\n\t\n\treg clk=0;\n\tinitial forever\n\t\th#5 clk = ~clk;\n\n\tlogic [2:0] a;\n\tlogic [15:0] q_ref;\n\tlogic [15:0] q_dut;\n\n\t// Variables for improved mismatch reporting\n\tlogic first_mismatch_detected = 0;\n\tlogic [2:0] a_at_first_mismatch;\n\tlogic [15:0] q_dut_at_first_mismatch;\n\tlogic [15:0] q_ref_at_first_mismatch;\n\n\tinitial begin \n\t\t$dumpfile(\"wave.vcd\");\n\t\t$dumpvars(1, stim1.clk, tb_mismatch ,a,q_ref,q_dut );\n\tend\n\n\t\n\twire tb_match;\n\twire tb_mismatch = ~tb_match;\n\t\n\tstimulus_gen stim1 (\n\t\t.clk,\n\t\t.*,\n\t\t.a );\n\tRefModule good1 (\n\t\t.a,\n\t\t.q(q_ref) );\n\t\n\tTopModule top_module1 (\n\t\t.a,\n\t\t.q(q_dut) );\n\n\t\n\tbit strobe = 0;\n\ttask wait_for_end_of_timestep;\n\t\trepeat(5) begin\n\t\tstrobe <= !strobe;  // Try to delay until the very end of the time step.\n\t\t@(strobe);\n\t\tend\ntask\n\t\n\t// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.\n\t// Simplified comparison for combinational logic: tb_match is true if q_ref == q_dut\n\tassign tb_match = (q_ref === q_dut);\n\n\t// Clocked block for stats tracking (as per golden testbench structure)\n\talways @(posedge clk, negedge clk) begin\n\t\tstats1.clocks++;\n\t\t\n\t\t// Original error counting logic\n\t\tif (!tb_match) begin\n\t\t\tif (stats1.errors == 0) stats1.errortime = $time;\n\t\t\tsstats1.errors++;\n\t\tend\n\t\tif (q_ref !== q_dut)\n\t\tbegin \n\t\t\tif (stats1.errors_q == 0) stats1.errortime_q = $time;\n\t\t\tsstats1.errors_q = stats1.errors_q + 1'b1; \n\t\tend\n\tend\n\n\t// Combinational Mismatch Capture (First Mismatch Display Requirement)\n\talways @(*) begin\n\t\tif (q_ref !== q_dut) begin\n\t\t\tif (!first_mismatch_detected) begin\n\t\t\t// Capture state at first mismatch\n\t\t\ta_at_first_mismatch = a;\n\t\t\tq_dut_at_first_mismatch = q_dut;\n\t\t\tq_ref_at_first_mismatch = q_ref;\n\t\t\tfirst_mismatch_detected = 1;\n\t\t\tend\n\t\tend\n\t\tend\n\tend\n\n\t// Final check and display logic\n\tinitial begin\n\t\t@(negedge clk);\n\t\t// Wait a bit to ensure all stimulus cycles have run\n\t\t#100;\n\n\t\tif (stats1.errors == 0) begin\n\t\t\t$display(\"SIMULATION PASSED\");\n\t\tend else begin\n\t\t\t$display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\", stats1.errors, stats1.errortime);\n\t\t\tend\n\t\t\n\t\t// Display detailed first mismatch information if it occurred\n\t\tif (first_mismatch_detected) begin\n\t\t\t$display(\"\\n--- FIRST MISMATCH DETAILS ---\");\n\t\t\t$display(\"Mismatch detected at time %0t\", $time);\n\t\t\t$display(\"Input (a): Binary = %b, Hex = %h