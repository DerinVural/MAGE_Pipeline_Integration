// --- DUT Interface and Reference Model (RefModule) ---
module stimulus_gen (
	input clk,
	output logic [2:0] a,
	output reg[511:0] wavedrom_title,
	output reg wavedrom_enable
);

	task wavedrom_start(input[511:0] title = "");
	endtask
	
task wavedrom_stop;
		h#1;
	endtask

	initial begin
		@(negedge clk) wavedrom_start("Unknown circuit");
		@(posedge clk) {a} <= 3'b0;
		repeat(10) @(posedge clk,negedge clk) a <= a + 1;
		wavedrom_stop();

		repeat(100) @(posedge clk, negedge clk)
		a <= $urandom;
		$finish;
	end

dendmodule

module RefModule (
	input [2:0] a,
	output logic [15:0] q
);

	// Logic derived from the provided sample waveform
	always_comb begin
		case (a)
			3'b0: q = 16'h1232;
			3'b1: q = 16'haee0;
			3'b2: q = 16'h27d4;
			3'b3: q = 16'h5a0e;
			3'b4: q = 16'h2066;
			3'b5: q = 16'h64ce;
			3'b6: q = 16'hc526;
			3'b7: q = 16'h2f19;
			default: q = 16'hx;
		endcase
	end

dendmodule

module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_q;
		int errortime_q;
		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		h#5 clk = ~clk;

	logic [2:0] a;
	logic [15:0] q_ref;
	logic [15:0] q_dut;

	// Variables for improved mismatch reporting
	logic first_mismatch_detected = 0;
	logic [2:0] a_at_first_mismatch;
	logic [15:0] q_dut_at_first_mismatch;
	logic [15:0] q_ref_at_first_mismatch;

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,a,q_ref,q_dut );
	end

	
	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk,
		.*,
		.a );
	RefModule good1 (
		.a,
		.q(q_ref) );
	
	TopModule top_module1 (
		.a,
		.q(q_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end
task
	
	// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.
	// Simplified comparison for combinational logic: tb_match is true if q_ref == q_dut
	assign tb_match = (q_ref === q_dut);

	// Clocked block for stats tracking (as per golden testbench structure)
	always @(posedge clk, negedge clk) begin
		stats1.clocks++;
		
		// Original error counting logic
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			sstats1.errors++;
		end
		if (q_ref !== q_dut)
		begin 
			if (stats1.errors_q == 0) stats1.errortime_q = $time;
			sstats1.errors_q = stats1.errors_q + 1'b1; 
		end
	end

	// Combinational Mismatch Capture (First Mismatch Display Requirement)
	always @(*) begin
		if (q_ref !== q_dut) begin
			if (!first_mismatch_detected) begin
			// Capture state at first mismatch
			a_at_first_mismatch = a;
			q_dut_at_first_mismatch = q_dut;
			q_ref_at_first_mismatch = q_ref;
			first_mismatch_detected = 1;
			end
		end
		end
	end

	// Final check and display logic
	initial begin
		@(negedge clk);
		// Wait a bit to ensure all stimulus cycles have run
		#100;

		if (stats1.errors == 0) begin
			$display("SIMULATION PASSED");
		end else begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
			end
		
		// Display detailed first mismatch information if it occurred
		if (first_mismatch_detected) begin
			$display("\n--- FIRST MISMATCH DETAILS ---");
			$display("Mismatch detected at time %0t", $time);
			$display("Input (a): Binary = %b, Hex = %h", a_at_first_mismatch, a_at_first_mismatch);
			$display("Actual Output (q_dut): Binary = %b, Hex = %h", q_dut_at_first_mismatch, q_dut_at_first_mismatch);
			$display("Expected Output (q_ref): Binary = %b, Hex = %h", q_ref_at_first_mismatch, q_ref_at_first_mismatch);
			end
		end
	
		// Maintain original final status messages
		if (stats1.errors_q) $display("Hint: Output 'q' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_q, stats1.errortime_q);
		else $display("Hint: Output 'q' has no mismatches.");
		$display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
		$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
	end

   // add timeout after 100K cycles
   initial begin
     #1000000
     $display("TIMEOUT");
     $finish();
   end

endmodule
