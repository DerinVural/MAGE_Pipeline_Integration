		.clk,
		.d,
		.r,
		.q(q_ref) );
		
	TopModule top_module1 (
		.clk,
		.d,
		.r,
		.q(q_dut) );


	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
			strobe <= !strobe;  
			@(strobe);
		end
	endtask

