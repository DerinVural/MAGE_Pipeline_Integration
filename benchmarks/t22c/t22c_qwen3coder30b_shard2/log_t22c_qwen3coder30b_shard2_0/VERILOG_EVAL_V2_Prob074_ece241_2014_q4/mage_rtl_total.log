task wavedrom_start(input[511:0] title = "");
	endtask

task wavedrom_stop;
	#1;
endtask	


initial begin
	x <= 0;
	@(negedge clk) wavedrom_start();
		@(posedge clk) x <= 2'h0;
		@(posedge clk) x <= 2'h0;
		@(posedge clk) x <= 2'h0;
		@(posedge clk) x <= 2'h0;
		@(posedge clk) x <= 2'h1;
		@(posedge clk) x <= 2'h1;
