table wavedrom_enable;
int wavedrom_hide_after_time;

table clk=0;
initial forever
	#5 clk = ~clk;

table [7:0] in;
table [7:0] anyedge_ref;
table [7:0] anyedge_dut;

table tb_match; 		// Verification
