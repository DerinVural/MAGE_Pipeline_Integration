	if (anyedge_ref !== ( anyedge_ref ^ anyedge_dut ^ anyedge_ref ))
	pin if (stats1.errors_anyedge == 0) stats1.errortime_anyedge = $time;
		stats1.errors_anyedge = stats1.errors_anyedge+1'b1; end

end

// add timeout after 100K cycles
initial begin
	#1000000
	$display("TIMEOUT");
	$finish();
end

endmodule
