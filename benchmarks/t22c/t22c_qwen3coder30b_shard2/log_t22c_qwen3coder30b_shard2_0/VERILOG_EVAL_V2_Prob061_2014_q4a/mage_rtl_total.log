	.clk,
	.w,
	.R,
	.E,
	.L,
	.Q(Q_ref) );
	
TopModule top_module1 (
	.clk,
	.w,
	.R,
	.E,
	.L,
	.Q(Q_dut) );

bit strobe = 0;
task wait_for_end_of_timestep;
	repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
	end
endtask	


// Queue-based simulation mismatch display
reg w_queue [$];
reg R_queue [$];
reg E_queue [$];
reg L_queue [$];
reg Q_ref_queue [$];
reg Q_dut_queue [$];

localparam MAX_QUEUE_SIZE = 10;

always @(posedge clk, negedge clk) begin
	if (w_queue.size() >= MAX_QUEUE_SIZE - 1) begin
		w_queue.delete(0);
		R_queue.delete(0);
		E_queue.delete(0);
		L_queue.delete(0);
		Q_ref_queue.delete(0);
		Q_dut_queue.delete(0);
	end

	w_queue.push_back(w);
	R_queue.push_back(R);
	E_queue.push_back(E);
	L_queue.push_back(L);
	Q_ref_queue.push_back(Q_ref);
	Q_dut_queue.push_back(Q_dut);

	// Check for first mismatch
	if (!tb_match) begin
		if (stats1.errors == 0) stats1.errortime = $time;
		stats1.errors++;
		
