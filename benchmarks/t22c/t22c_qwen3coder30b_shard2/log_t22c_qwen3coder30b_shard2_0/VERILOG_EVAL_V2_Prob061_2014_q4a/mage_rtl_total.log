		repeat(200) @(posedge clk, negedge clk) begin
			{w,R,E,L} <= $random;
		en
		#1 $finish;
	end

endmodule

module tb();

typedef struct packed {
	int errors;
	int errortime;
	int errors_Q;
	int errortime_Q;

	int clocks;
} stats;

stats stats1;


wire[511:0] wavedrom_title;
wire wavedrom_enable;
int wavedrom_hide_after_time;

reg clk=0;
initial forever
	#5 clk = ~clk;

logic w;
logic R;
logic E;
logic L;
logic Q_ref;
logic Q_dut;

initial begin 
	$dumpfile("wave.vcd");
	$dumpvars(1, stim1.clk, tb_mismatch ,clk,w,R,E,L,Q_ref,Q_dut );
end


