task wavedrom_start(input[511:0] title = "");
	endtask
	
ntask wavedrom_stop;
	#1;
endtask	



initial begin
	int count; count = 0;
	{a,b,c,d} <= 4'b0;
	wavedrom_start();
	repeat(16) @(posedge clk)
		{a,b,c,d} <= count++;		
	@(negedge clk) wavedrom_stop();
	
	repeat(200) @(posedge clk, negedge clk)
		{d,c,b,a} <= $urandom;
		
	#1 $finish;
end

