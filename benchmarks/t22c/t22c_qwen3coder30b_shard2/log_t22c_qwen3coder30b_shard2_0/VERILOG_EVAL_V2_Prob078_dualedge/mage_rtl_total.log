[2026-05-14 15:04:42,930 - mage.rtl_generator - INFO] RTL code: module TopModule(
    input clk,
    input d,
    output q
);

    // Internal signals to store values sampled on both edges
    logic d_rising;
    logic d_falling;
    
    // Register to hold previous clock state for edge detection
    logic clk_prev;
    
    // Sample on rising edge
    always @(posedge clk) begin
        d_rising <= d;
    end
    
    // Sample on falling edge
    always @(negedge clk) begin
        d_falling <= d;
    end
    
    // Determine which value to output based on current clock edge
    always @(*) begin
        if (clk && !clk_prev)
            q = d_rising;
        else
            q = d_falling;
    end
    
    // Update previous clock value
    always @(posedge clk or negedge clk) begin
        clk_prev <= clk;
    end

endmodule
