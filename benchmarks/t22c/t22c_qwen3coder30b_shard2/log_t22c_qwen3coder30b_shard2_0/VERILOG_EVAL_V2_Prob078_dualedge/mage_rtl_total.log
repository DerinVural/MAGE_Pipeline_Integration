    input clk,
    input d,
    output q
);

    logic d_pos;
    logic d_neg;
    logic clk_edge;

    // Sample data on positive edge
    always @(posedge clk) begin
        d_pos <= d;
    end

    // Sample data on negative edge
    always @(negedge clk) begin
        d_neg <= d;
    end

