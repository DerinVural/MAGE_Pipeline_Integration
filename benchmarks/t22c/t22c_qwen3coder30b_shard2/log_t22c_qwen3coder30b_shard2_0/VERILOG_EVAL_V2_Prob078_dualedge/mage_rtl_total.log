[2026-05-14 15:05:02,010 - mage.rtl_generator - INFO] RTL code: module TopModule (
    input clk,
    input d,
    output q
);

    logic d_ff_pos;
    logic d_ff_neg;
    logic prev_clk;
    
    // Register to store previous clock value
    always @(posedge clk or negedge clk) begin
        prev_clk <= clk;
    end
    
    // Positive edge triggered flip-flop
    always @(posedge clk) begin
        d_ff_pos <= d;
    end
    
    // Negative edge triggered flip-flop
    always @(negedge clk) begin
        d_ff_neg <= d;
    end
    
    // Multiplexer to select between positive and negative edge outputs
    always @(*) begin
        if (prev_clk == 1'b0 && clk == 1'b1) begin
            q = d_ff_pos;
        end else begin
            q = d_ff_neg;
        end
    end
    
endmodule
