[2026-05-14 15:06:01,458 - mage.rtl_generator - INFO] RTL code: module TopModule (
    input clk,
    input d,
    output q
);

    logic d_posedge;
    logic d_negedge;
    logic prev_clk;
    
    // Register to hold the previous clock level
    always @(posedge clk or negedge clk) begin
        prev_clk <= clk;
    end
    
    // Sample d on positive edge
    always @(posedge clk) begin
        d_posedge <= d;
    end
    
    // Sample d on negative edge
    always @(negedge clk) begin
        d_negedge <= d;
    end
    
    // Select the appropriate value based on the current clock edge
    always @(*) begin
        if (prev_clk) begin
            // Previous edge was positive, so we want the value from the negative edge
            q = d_negedge;
        end else begin
            // Previous edge was negative, so we want the value from the positive edge
            q = d_posedge;
        end
    end

endmodule
