    input clk,
    input d,
    output logic q
);

    logic d_posedge;
    logic d_negedge;
    logic prev_clk;
    
    // Register to store previous clock value
    always @(posedge clk or negedge clk) begin
        prev_clk <= clk;
    end
    
    // Flip-flop triggered on positive edge
    always @(posedge clk) begin
        d_posedge <= d;
    end
    
    // Flip-flop triggered on negative edge
    always @(negedge clk) begin
        d_negedge <= d;
    end
    
    // Multiplexer to select output based on clock edge
    always @(*) begin
        if (prev_clk == 1'b0 && clk == 1'b1)
            q = d_posedge;
        else
            q = d_negedge;
    end
    
    // Initialize to known value
    initial begin
        q <= 1'b0;
        d_posedge <= 1'b0;
        d_negedge <= 1'b0;
        prev_clk <= 1'b0;
    end
    
