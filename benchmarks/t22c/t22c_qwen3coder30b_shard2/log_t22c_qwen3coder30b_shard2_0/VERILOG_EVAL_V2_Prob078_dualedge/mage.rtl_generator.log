[2026-05-14 15:05:42,178 - mage.rtl_generator - INFO] RTL code: module TopModule (
    input clk,
    input d,
    output logic q
);

    logic prev_clk;
    logic q_pos;
    logic q_neg;
    
    // Initialize previous clock value
    initial begin
        prev_clk = 1'b0;
    end
    
    // Positive edge triggered flip-flop
    always @(posedge clk) begin
        q_pos <= d;
    end
    
    // Negative edge triggered flip-flop
    always @(negedge clk) begin
        q_neg <= d;
    end
    
    // Determine output based on current clock edge
    always @(*) begin
        if (clk && !prev_clk)
            q = q_pos;
        else if (!clk && prev_clk)
            q = q_neg;
        else
            q = q;
    end
    
    // Update previous clock value
    always @(posedge clk or negedge clk) begin
        prev_clk <= clk;
    end
    
endmodule
