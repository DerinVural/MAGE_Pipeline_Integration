[2026-05-14 15:05:52,888 - mage.rtl_generator - INFO] RTL code: module TopModule (
    input clk,
    input d,
    output q
);

    logic d_pos;
    logic d_neg;
    logic clk_edge;

    // Sample data on positive edge
    always @(posedge clk) begin
        d_pos <= d;
    end

    // Sample data on negative edge
    always @(negedge clk) begin
        d_neg <= d;
    end

    // Determine which edge we're currently at
    always @(posedge clk or negedge clk) begin
        clk_edge <= clk;
    end

    // Select output based on clock edge
    always @(*) begin
        if (clk_edge)
            q = d_pos;
        else
            q = d_neg;
    end

endmodule
