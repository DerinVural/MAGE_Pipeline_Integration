tn;\n\tlogic [1:0] byteena;\n\tlogic [15:0] d;\n\tlogic [15:0] q_ref;\n\tlogic [15:0] q_dut;\n\n\tinitial begin \n\t\t$dumpfile("wave.vcd");\n\t\t$dumpvars(1, stim1.clk, tb_mismatch ,clk,resetn,byteena,d,q_ref,q_dut );\n\tend\n\n\n\twire tb_match; \t\t// Verification\n\twire tb_mismatch = ~tb_match;\n\t\n\tstimulus_gen stim1 (\n\t\t.clk,\n\t\t.* ,\n\t\t.resetn,\n\t\t.byteena,\n\t\t.d );\n\tRefModule good1 (\n\t\t.clk,\n\t\t.resetn,\n\t\t.byteena,\n\t\t.d,\n\t\t.q(q_ref) );\n\t\t\n\tTopModule top_module1 (\n\t\t.clk,\n\t\t.resetn,\n\t\t.byteena,\n\t\t.d,\n\t\t.q(q_dut) );\n\n\tbit strobe = 0;\n\ttask wait_for_end_of_timestep;\n\t\trepeat(5) begin\n\t\t\tstrobe <= !strobe;  // Try to delay until the very end of the time step.\n\t\t\t@(strobe);\n\t\te nd\n\tendtask\n\n\t// Queue-based simulation mismatch display\n\treg [15:0] input_queue [$];\n\treg [15:0] got_output_queue [$];\n\treg [15:0] golden_queue [$];\n\treg [1:0] byteena_queue [$];\n\treg reset_queue [$];\n\n\tlocalparam MAX_QUEUE_SIZE = 10;\n\n\talways @(posedge clk, negedge clk) begin\n\t\tif (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin\n\t\t\tinput_queue.delete(0);\n\t\t\tgot_output_queue.delete(0);\n\t\t\tgolden_queue.delete(0);\n\t\t\tbyteena_queue.delete(0);\n\t\t\treset_queue.delete(0);\n\t\te nd\n\n\t\tinput_queue.push_back(d);\n\t\tgot_output_queue.push_back(q_dut);\n\t\tgolden_queue.push_back(q_ref);\n\t\tbyteena_queue.push_back(byteena);\n\t\treset_queue.push_back(~resetn);\n\n\t\t// Check for first mismatch\n\t\tif (q_dut !== q_ref) begin\n\t\t\t$display("Mismatch detected at time %t", $time);\n\t\t\t$display("\\nLast %d cycles of simulation:");\n\t\t\t\n\t\t\tfor (int i = 0; i < input_queue.size(); i++) begin\n\t\t\t\tif (got_output_queue[i] === golden_queue[i]) begin\n\t\t\t\t\t$display("Got Match at");\n\t\t\t\te nd else begin\n\t\t\t\t\t$display("Got Mismatch at");\n\t\t\t\te nd\n\t\t\t\t$display("Cycle %d, reset %b, byteena %b, input %h (%b), got output %h (%b), exp output %h (%b)",\n\t\t\