    // Input combinations where output = 0: 0, 1, 4, 5, 6, 9, 10, 13, 14
    // Don't care combinations: 3, 8, 11, 12

    // For SOP (Sum of Products):
    // Minterms where output = 1: a'b'c'd, a'b'cd', ab'c'd, abc'd', abcd
