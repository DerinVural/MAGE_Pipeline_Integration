    // Maxterms where output = 0: a+b+c+d, a+b+c'+d, a+b'+c+d, a+b'+c'+d, a'+b+c+d, a'+b+c'+d, a'+b'+c+d, a'+b'+c'+d, a'+b'+c'+d'
    // Simplifying the POS form gives:
    // out_pos = (a'+b)(a'+c)(b'+d')(c'+d')
    
    assign out_sop = (a & ~b & ~c & d) | (~a & ~b & c & ~d) | (~a & b & ~c & d) | (a & b & ~c & d) | (a & b & c & d);
    assign out_pos = (~a | ~b) & (~a | ~c) & (b | ~d) & (c | ~d);

