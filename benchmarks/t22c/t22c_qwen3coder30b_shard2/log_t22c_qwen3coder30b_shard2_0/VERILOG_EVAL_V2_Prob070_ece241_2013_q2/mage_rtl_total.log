    // Truth table analysis:
    // Input combinations (a,b,c,d): 
    // 0000 -> 0 -> out_sop=0, out_pos=1
    // 0001 -> 1 -> out_sop=0, out_pos=1
    // 0010 -> 2 -> out_sop=1, out_pos=1
    // 0011 -> 3 -> out_sop=?, out_pos=?
    // 0100 -> 4 -> out_sop=0, out_pos=1
    // 0101 -> 5 -> out_sop=0, out_pos=1
    // 0110 -> 6 -> out_sop=0, out_pos=1
    // 0111 -> 7 -> out_sop=1, out_pos=1
    // 1000 -> 8 -> out_sop=?, out_pos=?
    // 1001 -> 9 -> out_sop=0, out_pos=1
    // 1010 -> 10 -> out_sop=0, out_pos=1
    // 1011 -> 11 -> out_sop=?, out_pos=?
    // 1100 -> 12 -> out_sop=?, out_pos=?
    // 1101 -> 13 -> out_sop=0, out_pos=1
    // 1110 -> 14 -> out_sop=0, out_pos=1
    // 1111 -> 15 -> out_sop=1, out_pos=1
    
    // From the truth table, we see that out_sop = 1 for inputs 2,7,15
    // We can derive the SOP expression for out_sop as:
    // m2 = a'b'c'd
    // m7 = a'b'cd'
    // m15 = abcd
    // So, out_sop = m2 + m7 + m15 = a'b'c'd + a'b'cd' + abcd
    
    // Simplifying using Karnaugh map:
    // out_sop = b'd' + acd
    
    // For out_pos, since we want 1 for 0,1,4,5,6,9,10,13,14 and 0 for 2,7,15
    // out_pos = 0 for 2,7,15 (i.e. m2,m7,m15)
    // So out_pos = !(m2 + m7 + m15)
    // Using De Morgan's law: out_pos = !m2 * !m7 * !m15
    // !m2 = a+b+c+d
    // !m7 = a+b+c'+d
    // !m15 = a'+b'+c'+d'
    // So out_pos = (a+b+c+d) * (a+b+c'+d) * (a'+b'+c'+d')
    // Simplifying this using Karnaugh map:
    // out_pos = (a+b+c+d) * (a+b+c'+d) * (a'+b'+c'+d')
    // = (a+b+d) * (a'+b'+c'+d')
    
    assign out_sop = (~b & ~d) | (a & c & d);
    assign out_pos = (a | b | d) & (~a | ~b | ~c | ~d);

endmodule
