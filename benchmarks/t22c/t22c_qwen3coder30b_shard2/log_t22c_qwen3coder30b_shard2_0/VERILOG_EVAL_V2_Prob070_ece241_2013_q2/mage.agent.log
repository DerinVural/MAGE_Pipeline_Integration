[2026-05-14 14:27:06,288 - mage.agent - INFO] module TopModule (
    input a,
    input b,
    input c,
    input d,
    output out_sop,
    output out_pos
);

    // For SOP: out_sop = 1 for minterms 2, 7, 15
    // For POS: out_pos = 0 for minterms 0, 1, 4, 5, 6, 9, 10, 13, 14
    
    // Simplified SOP: out_sop = a'd + bc'd' + ab'c'd
    assign out_sop = (~a & d) | (b & c & ~d) | (a & ~b & c & ~d);

    // Simplified POS: out_pos = (a + b + c + d)(a + b + c' + d')(a + b' + c + d')
    // Note: The POS expression is derived from the maxterms that make out_pos = 0.
    // Maxterms = 0, 1, 4, 5, 6, 9, 10, 13, 14
    assign out_pos = (a | b | c | d) & (a | b | ~c | ~d) & (a | ~b | c | ~d);

endmodule
