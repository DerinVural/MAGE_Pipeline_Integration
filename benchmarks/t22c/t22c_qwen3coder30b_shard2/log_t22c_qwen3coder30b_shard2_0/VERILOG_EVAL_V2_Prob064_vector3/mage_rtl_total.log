	$dumpvars(1, stim1.clk, tb_mismatch ,a,b,c,d,e,f,w_ref,w_dut,x_ref,x_dut,y_ref,y_dut,z_ref,z_dut );
end


wire tb_match;    	// Verification
wire tb_mismatch = ~tb_match;

