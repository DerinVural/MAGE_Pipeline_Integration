[2026-05-14 16:52:24,205 - mage.agent - INFO] module TopModule (
    input clk,
    input reset,
    input data,
    input done_counting,
    input ack,
    output reg shift_ena,
    output reg counting,
    output reg done
);

    // Define states
    localparam ST_SEARCH      = 3'd0;
    localparam ST_SHIFT       = 3'd1;
    localparam ST_WAIT_COUNT  = 3'd2;
    localparam ST_DONE        = 3'd3;
    localparam ST_ACK         = 3'd4;

    // State register
    logic [2:0] state;
    logic [2:0] state_next;

    // Internal signals
    logic [3:0] shift_reg;
    logic pattern_detected;

    // Combinational logic for next state
    always @(*) begin
        case (state)
            ST_SEARCH: begin
                if (pattern_detected)
                    state_next = ST_SHIFT;
                else
                    state_next = ST_SEARCH;
            end
            ST_SHIFT: begin
                if (shift_reg[3] == 1'b1)
                    state_next = ST_WAIT_COUNT;
                else
                    state_next = ST_SHIFT;
            end
            ST_WAIT_COUNT: begin
                if (done_counting)
                    state_next = ST_DONE;
                else
                    state_next = ST_WAIT_COUNT;
            end
            ST_DONE: begin
                if (ack)
                    state_next = ST_SEARCH;
                else
                    state_next = ST_DONE;
            end
            ST_ACK: begin
                if (ack)
                    state_next = ST_SEARCH;
                else
                    state_next = ST_ACK;
            end
            default: state_next = ST_SEARCH;
        endcase
    end

    // Sequential logic for state transition
    always @(posedge clk) begin
        if (reset)
            state <= ST_SEARCH;
        else
            state <= state_next;
    end

    // Combinational logic for outputs
    always @(*) begin
        shift_ena = 1'b0;
        counting = 1'b0;
        done = 1'b0;

        case (state)
            ST_SEARCH:;
            ST_SHIFT: shift_ena = 1'b1;
            ST_WAIT_COUNT: counting = 1'b1;
            ST_DONE: done = 1'b1;
            ST_ACK: done = 1'b1;
        endcase
    end

    // Shift register logic
    always @(posedge clk) begin
        if (reset) begin
            shift_reg <= 4'b0000;
        end else begin
            case (state)
                ST_SHIFT: begin
                    shift_reg <= {shift_reg[2:0], data};
                end
                default:;
            endcase
        end
    end

    // Pattern detection logic
    always @(*) begin
        pattern_detected = 1'b0;
        if (state == ST_SEARCH && shift_reg == 4'b1101)
            pattern_detected = 1'b1;
    end

endmodule
