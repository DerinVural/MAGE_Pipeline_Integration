    always @(*) begin
        case (current_state)
            S_IDLE: begin
                if (shift_reg == 4'b1101)
                    next_state = S_DETECT;
                else
                    next_state = S_IDLE;
            end
            S_DETECT: begin
                next_state = S_SHIFT;
            end
            S_SHIFT: begin
                next_state = S_COUNTING;
            end
            S_COUNTING: begin
                if (done_counting)
                    next_state = S_DONE;
                else
                    next_state = S_COUNTING;
            end
            S_DONE: begin
                if (ack)
