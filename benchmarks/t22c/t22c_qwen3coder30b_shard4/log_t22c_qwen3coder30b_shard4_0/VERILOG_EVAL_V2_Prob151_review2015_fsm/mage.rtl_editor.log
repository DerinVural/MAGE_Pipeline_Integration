hift_reg[1], shift_reg[0]} == 4'b1101) begin\n                    next_state = SHIFT;\n                end\n            end\n\n            SHIFT: begin\n                // Assert shift_ena for 4 cycles\n                shift_ena = 1'b1;\n                next_state = COUNTING;\n            end\n\n            COUNTING: begin\n                // Assert counting\n                counting = 1'b1;\n                // Wait for done_counting\n                if (done_counting)\n                    next_state = DONE;\n            end\n\n            DONE: begin\n                // Assert done\n                done = 1'b1;\n                // Wait for ack\n                if (ack)\n                    next_state = IDLE;\n            end\n        endcase\n    end"}
