            end
            
            ST_DONE: begin
                if (ack)
                    next_state = ST_IDLE;
                else
                    next_state = ST_DONE;
            end
            
            default: next_state = ST_IDLE;
        endcase
    end

    // Combinational logic for outputs
    always @(*) begin
        shift_ena = 1'b0;
        counting = 1'b0;
        done = 1'b0;
        
        case (state)
