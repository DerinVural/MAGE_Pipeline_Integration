[2026-05-14 16:56:12,563 - mage.rtl_generator - INFO] RTL code: module TopModule (
    input clk,
    input reset,
    input data,
    input done_counting,
    input ack,
    output reg shift_ena,
    output reg counting,
    output reg done
);

    // State definitions
    localparam ST_IDLE         = 3'd0;
    localparam ST_PATTERN1     = 3'd1;
    localparam ST_PATTERN2     = 3'd2;
    localparam ST_PATTERN3     = 3'd3;
    localparam ST_PATTERN4     = 3'd4;
    localparam ST_SHIFTING     = 3'd5;
    localparam ST_COUNTING     = 3'd6;
    localparam ST_DONE         = 3'd7;

    // Current and next state
    logic [2:0] state, next_state;

    // Register to hold the received data
    logic [3:0] shift_reg;
    
    // Sequential logic for state
    always @(posedge clk) begin
        if (reset)
            state <= ST_IDLE;
        else
            state <= next_state;
    end

    // Combinational logic for next state
    always @(*) begin
        case (state)
            ST_IDLE: begin
                if (data == 1'b1)
                    next_state = ST_PATTERN1;
                else
                    next_state = ST_IDLE;
            end
            
            ST_PATTERN1: begin
                if (data == 1'b1)
                    next_state = ST_PATTERN2;
                else
                    next_state = ST_IDLE;
            end
            
            ST_PATTERN2: begin
                if (data == 1'b0)
                    next_state = ST_PATTERN3;
                else
                    next_state = ST_IDLE;
            end
            
            ST_PATTERN3: begin
                if (data == 1'b1)
                    next_state = ST_SHIFTING;
                else
                    next_state = ST_IDLE;
            end
            
            ST_SHIFTING: begin
                next_state = ST_COUNTING;
            end
            
            ST_COUNTING: begin
                if (done_counting)
                    next_state = ST_DONE;
                else
                    next_state = ST_COUNTING;
            end
            
            ST_DONE: begin
                if (ack)
                    next_state = ST_IDLE;
                else
                    next_state = ST_DONE;
            end
            
            default: next_state = ST_IDLE;
        endcase
    end

    // Combinational logic for outputs
    always @(*) begin
        shift_ena = 1'b0;
        counting = 1'b0;
        done = 1'b0;
        
        case (state)
            ST_SHIFTING:
                shift_ena = 1'b1;
            
            ST_COUNTING:
                counting = 1'b1;
            
            ST_DONE:
                done = 1'b1;
        endcase
    end

endmodule
