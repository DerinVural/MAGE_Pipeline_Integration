[2026-05-14 16:58:37,113 - mage.rtl_editor - INFO] module TopModule (
    input clk,
    input reset,
    input data,
    input done_counting,
    input ack,
    output reg shift_ena,
    output reg counting,
    output reg done
);

    // Define states
    localparam IDLE       = 3'd0;
    localparam SHIFT      = 3'd1;
    localparam COUNTING   = 3'd2;
    localparam DONE       = 3'd3;

    // Current and next state
    logic [2:0] state, next_state;

    // Shift register to hold last 4 bits
    logic [3:0] shift_reg;

    // Initialize registers to known values
    initial begin
        shift_reg = 4'b0000;
        state     = IDLE;
    end

    // Sequential logic - state register
    always @(posedge clk) begin
        if (reset)
            state <= IDLE;
        else
            state <= next_state;
    end

    // Combinational logic - next state and outputs
    always @(*) begin
        // Default assignments - clear all outputs
        next_state = state;
        shift_ena = 1'b0;
        counting = 1'b0;
        done = 1'b0;

        case (state)
            IDLE: begin
                // Check for pattern 1101 in shift_reg
                if ({shift_reg[3], shift_reg[2], shift_reg[1], shift_reg[0]} == 4'b1101) begin
                    next_state = SHIFT;
                end
            end

            SHIFT: begin
                // Assert shift_ena for 4 cycles
                shift_ena = 1'b1;
                next_state = COUNTING;
            end

            COUNTING: begin
                // Assert counting
                counting = 1'b1;
                // Wait for done_counting
                if (done_counting)
                    next_state = DONE;
            end

            DONE: begin
                // Assert done
                done = 1'b1;
                // Wait for ack
                if (ack)
                    next_state = IDLE;
            end
        endcase
    end

    // Update shift register
    always @(posedge clk) begin
        if (reset) begin
            shift_reg <= 4'b0000;
        end else begin
            shift_reg <= {shift_reg[2:0], data};
        end
    end

endmodule
