                    state_next = ST_WAIT_COUNT;
            end
            ST_DONE: begin
                if (ack)
                    state_next = ST_SEARCH;
                else
                    state_next = ST_DONE;
            end
            ST_ACK: begin
                if (ack)
                    state_next = ST_SEARCH;
                else
                    state_next = ST_ACK;
            end
            default: state_next = ST_SEARCH;
        endcase
    end

    // Sequential logic for state transition
    always @(posedge clk) begin
        if (reset)
            state <= ST_SEARCH;
        else
            state <= state_next;
    end

    // Combinational logic for outputs
    always @(*) begin
        shift_ena = 1'b0;
        counting = 1'b0;
        done = 1'b0;

        case (state)
            ST_SEARCH:;
            ST_SHIFT: shift_ena = 1'b1;
            ST_WAIT_COUNT: counting = 1'b1;
            ST_DONE: done = 1'b1;
            ST_ACK: done = 1'b1;
        endcase
    end

    // Shift register logic
    always @(posedge clk) begin
        if (reset) begin
            shift_reg <= 4'b0000;
        end else begin
            case (state)
                ST_SHIFT: begin
                    shift_reg <= {shift_reg[2:0], data};
                end
                default:;
            endcase
        end
    end

    // Pattern detection logic
    always @(*) begin
        pattern_detected = 1'b0;
        if (state == ST_SEARCH && shift_reg == 4'b1101)
            pattern_detected = 1'b1;
    end

endmodule
