[2026-05-14 14:57:18,693 - mage.rtl_generator - INFO] RTL code: module TopModule (
    input clk,
    input reset,
    input in,
    output reg disc,
    output reg flag,
    output reg err
);

    // Define states
    localparam S_IDLE    = 3'b000;
    localparam S_01      = 3'b001;
    localparam S_011     = 3'b010;
    localparam S_0111    = 3'b011;
    localparam S_01111   = 3'b100;
    localparam S_011111  = 3'b101;
    localparam S_0111111 = 3'b110;
    localparam S_01111111 = 3'b111;

    // Current and next state
    logic [2:0] state, next_state;

    // Register to hold last 6 bits
    logic [5:0] shift_reg;

    // Initialize shift register to 0
    initial begin
        shift_reg = 6'b0;
    end

    // State transition logic
    always @(*) begin
        case (state)
            S_IDLE: begin
                if (in == 1'b0) next_state = S_01;
                else next_state = S_011;
            end
            
            S_01: begin
                if (in == 1'b1) next_state = S_011;
                else next_state = S_IDLE;
            end
            
            S_011: begin
                if (in == 1'b1) next_state = S_0111;
                else next_state = S_IDLE;
            end
            
            S_0111: begin
                if (in == 1'b1) next_state = S_01111;
                else next_state = S_IDLE;
            end
            
            S_01111: begin
                if (in == 1'b1) next_state = S_011111;
                else next_state = S_IDLE;
            end
            
            S_011111: begin
                if (in == 1'b1) next_state = S_0111111;
                else next_state = S_IDLE;
            end
            
            S_0111111: begin
                if (in == 1'b1) next_state = S_01111111;
                else next_state = S_IDLE;
            end
            
            S_01111111: begin
                if (in == 1'b1) next_state = S_01111111;
                else next_state = S_IDLE;
            end
            
            default: next_state = S_IDLE;
        endcase
    end

    // Sequential logic
    always @(posedge clk) begin
        if (reset) begin
            state <= S_IDLE;
            shift_reg <= 6'b0;
        end else begin
            state <= next_state;
            shift_reg <= {shift_reg[4:0], in};
        end
    end

    // Output logic
    always @(*) begin
        // Default values
        disc = 1'b0;
        flag = 1'b0;
        err = 1'b0;
        
        case (state)
            S_011111: begin
                // Check if the pattern 0111110 matches
                if ({shift_reg[5:1], in} == 6'b0111110) disc = 1'b1;
                // Check if the pattern 01111110 matches
                else if ({shift_reg[5:0], in} == 7'b01111110) flag = 1'b1;
            end
            S_0111111: begin
                // Check if the pattern 01111111 matches
                if ({shift_reg[5:0], in} == 7'b01111111) err = 1'b1;
            end
            S_01111111: begin
                err = 1'b1;
            end
            default: ;
        endcase
    end

endmodule
