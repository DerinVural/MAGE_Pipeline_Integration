                else
                    next_state = S0;
            end
            
            S7: begin
                if (in)
                    next_state = S7;
                else
                    next_state = S0;
            end
        endcase
        
        // Handle outputs after state determination
        // Check for special patterns based on previous state
        if (state == S5 && in == 1'b1) begin
            // If we were at S5 and now see 1, go to S6
            // In the next cycle, if we receive 0, it's 0111110 (disc)
            // If we receive 1, it's 0111111 (err)
            // But we need to signal these in the next state
            // Actually, we just want to know what will happen on the next cycle
            // So we need to set the outputs based on the expected transition
            // If in the next cycle, we see 0, it's a flag
            // If in the next cycle, we see 1, it's an error
        end
        else if (state == S6 && in == 1'b0) begin
            // We are in S6 and received 0, forming 01111110 (flag)
            flag = 1'b1;
        end
        else if (state == S6 && in == 1'b1) begin
            // We are in S6 and received 1, forming 0111111 (error)
            err = 1'b1;
        end
        else if (state == S7 && in == 1'b0) begin
            // We are in S7 and received 0, forming 011111110... (error)
            err = 1'b1;
        end
    end

endmodule
