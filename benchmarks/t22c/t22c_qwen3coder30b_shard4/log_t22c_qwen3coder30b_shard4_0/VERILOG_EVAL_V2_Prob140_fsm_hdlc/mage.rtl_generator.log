            end
            
            S_01111111: begin
                if (in == 1'b1) next_state = S_01111111;
                else next_state = S_IDLE;
            end
            
            default: next_state = S_IDLE;
        endcase
    end

    // Sequential logic
    always @(posedge clk) begin
        if (reset) begin
            state <= S_IDLE;
            shift_reg <= 6'b000000;
        end else begin
            state <= next_state;
            shift_reg <= {shift_reg[4:0], in};
        end
