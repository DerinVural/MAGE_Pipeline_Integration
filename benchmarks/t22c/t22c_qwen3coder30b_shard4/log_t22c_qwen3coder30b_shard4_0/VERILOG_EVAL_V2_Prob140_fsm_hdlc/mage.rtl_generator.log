    end

    // Sequential logic
    always @(posedge clk) begin
        if (reset) begin
            state <= S_IDLE;
            shift_reg <= 6'b0;
        end else begin
            state <= next_state;
            shift_reg <= {shift_reg[4:0], in};
        end
    end

    // Output logic
    always @(*) begin
        // Default values
        disc = 1'b0;
        flag = 1'b0;
        err = 1'b0;
        
        case (state)
