                if (in)
                    next_state = S_111;
                else
                    next_state = S_0;
            end
            
            S_111: begin
                if (in)
                    next_state = S_1111;
                else
                    next_state = S_0;
            end
            
            S_1111: begin
                if (in)
                    next_state = S_11111;
                else
