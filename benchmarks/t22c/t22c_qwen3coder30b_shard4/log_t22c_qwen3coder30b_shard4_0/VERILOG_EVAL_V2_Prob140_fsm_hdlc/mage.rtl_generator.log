    // Define states for the FSM
    localparam IDLE = 3'd0;
    localparam S1   = 3'd1;
    localparam S2   = 3'd2;
    localparam S3   = 3'd3;

    // Shift register to hold last 7 bits
    logic [6:0] shift_reg;
    logic [2:0] state;
    logic [2:0] next_state;

    // Initialize shift register to 0
    initial begin
        shift_reg = 7'b0000000;
    end

    // Sequential logic for state and shift register
    always @(posedge clk) begin
        if (reset) begin
            state <= IDLE;
            shift_reg <= 7'b0000000;
        end else begin
            state <= next_state;
            shift_reg <= {shift_reg[5:0], in};
        end
    end

    // Combinational logic for next state and outputs
    always @(*) begin
        // Default assignments
        next_state = state;
        disc = 1'b0;
        flag = 1'b0;
        err = 1'b0;

        case (state)
