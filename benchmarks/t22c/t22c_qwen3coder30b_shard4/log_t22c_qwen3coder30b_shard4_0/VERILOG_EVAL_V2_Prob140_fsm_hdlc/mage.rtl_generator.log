            end
            
            S_11111: begin
                if (in)
                    next_state = S_111111;
                else
                    next_state = S_0;
            end
            
            S_111111: begin
                if (in)
                    next_state = S_111111; // Stay in this state for error detection
                else
                    next_state = S_0;
            end
            
            default: next_state = S_IDLE;
        endcase
