                if (in == 1'b1)
                    next_state = ST_S4;
                else
                    next_state = ST_IDLE;
            end

            ST_S4: begin
                if (in == 1'b1)
                    next_state = ST_S5;
                else
                    next_state = ST_IDLE;
            end

            ST_S5: begin
                if (in == 1'b1) begin
                    next_state = ST_S6;
                end else begin
                    next_state = ST_IDLE;
                end
            end

            ST_S6: begin
                if (in == 1'b1) begin
                    next_state = ST_S7;
                end else begin
                    next_state = ST_IDLE;
                end
            end

            ST_S7: begin
                if (in == 1'b1) begin
                    // 7 or more consecutive 1s - error
                    err = 1'b1;
                    next_state = ST_S7;
                end else begin
                    // Found 0 after 6 1s -> flag
                    flag = 1'b1;
                    next_state = ST_IDLE;
                end
            end

            default: next_state = ST_IDLE;
        endcase
    end

endmodule
