                    next_state = ST_S7;
                end else begin
                    // Found 0 after 6 1s -> flag
                    flag = 1'b1;
                    next_state = ST_IDLE;
                end
            end

            default: next_state = ST_IDLE;
        endcase
    end

endmodule
