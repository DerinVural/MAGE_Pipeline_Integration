                end else begin
                    // Found 0 after 5 1s -> discard
                    disc = 1'b1;
                    next_state = ST_IDLE;
                end
            end

            ST_S6: begin
                if (in == 1'b1) begin
                    next_state = ST_S7;
                end else begin
                    // Found 0 after 5 1s -> discard
                    disc = 1'b1;
                    next_state = ST_IDLE;
                end
            end

            ST_S7: begin
                if (in == 1'b1) begin
                    // 7 or more consecutive 1s - error
                    err = 1'b1;
                    next_state = ST_S7;
                end else begin
                    // Found 0 after 6 1s -> flag
                    flag = 1'b1;
                    next_state = ST_IDLE;
                end
            end

            default: next_state = ST_IDLE;
        endcase
    end

endmodule
