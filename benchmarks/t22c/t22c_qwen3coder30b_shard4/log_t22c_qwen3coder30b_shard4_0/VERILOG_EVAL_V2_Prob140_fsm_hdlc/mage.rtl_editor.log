                    next_state = ST_S6;
                end else begin
                    next_state = ST_IDLE;
                end
            end

            ST_S6: begin
                if (in == 1'b1) begin
                    next_state = ST_S7;
                end else begin
                    next_state = ST_IDLE;
                end
            end

