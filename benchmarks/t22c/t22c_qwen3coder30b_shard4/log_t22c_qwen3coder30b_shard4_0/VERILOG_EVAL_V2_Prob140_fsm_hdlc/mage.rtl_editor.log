\'d2;\n    localparam ST_S3     = 3\'d3;\n    localparam ST_S4     = 3\'d4;\n    localparam ST_S5     = 3\'d5;\n    localparam ST_S6     = 3\'d6;\n    localparam ST_S7     = 3\'d7;\n\n    // State register\n    logic [2:0] state;\n    logic [2:0] next_state;\n\n    // Initialize signals\n    initial begin\n        disc = 1\'b0;\n        flag = 1\'b0;\n        err = 1\'b0;\n    end\n\n    // Sequential logic for state transition\n    always @(posedge clk) begin\n        if (reset)\n            state <= ST_IDLE;\n        else\n            state <= next_state;\n    end\n\n    // Combinational logic for next state and outputs\n    always @(*) begin\n        // Default assignments\n        next_state = state;\n        disc = 1\'b0;\n        flag = 1\'b0;\n        err = 1\'b0;\n\n        case (state)\n            ST_IDLE: begin\n                if (in == 1\'b1)\n                    next_state = ST_S1;\n                else\n                    next_state = ST_IDLE;\n            end\n\n            ST_S1: begin\n                if (in == 1\'b1)\n                    next_state = ST_S2;\n                else\n                    next_state = ST_IDLE;\n            end\n\n            ST_S2: begin\n                if (in == 1\'b1)\n                    next_state = ST_S3;\n                else\n                    next_state = ST_IDLE;\n            end\n\n            ST_S3: begin\n                if (in == 1\'b1)\n                    next_state = ST_S4;\n                else\n                    next_state = ST_IDLE;\n            end\n\n            ST_S4: begin\n                if (in == 1\'b1)\n                    next_state = ST_S5;\n                else\n                    next_state = ST_IDLE;\n            end\n\n            ST_S5: begin\n                if (in == 1\'b1) begin\n                    next_state = ST_S6;\n                end else begin\n                    next_state = ST_IDLE;\n                end\n            end\n\n            ST_S6: begin\n                if