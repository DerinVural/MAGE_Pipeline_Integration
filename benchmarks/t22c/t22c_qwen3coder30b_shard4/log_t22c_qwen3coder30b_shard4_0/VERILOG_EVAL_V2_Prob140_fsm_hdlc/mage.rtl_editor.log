[2026-05-14 15:08:39,849 - mage.rtl_editor - INFO] module TopModule (
    input clk,
    input reset,
    input in,
    output reg disc,
    output reg flag,
    output reg err
);

    // Define states
    localparam ST_IDLE   = 3'd0;
    localparam ST_S1     = 3'd1;
    localparam ST_S2     = 3'd2;
    localparam ST_S3     = 3'd3;
    localparam ST_S4     = 3'd4;
    localparam ST_S5     = 3'd5;
    localparam ST_S6     = 3'd6;
    localparam ST_S7     = 3'd7;

    // State register
    logic [2:0] state;
    logic [2:0] next_state;

    // Sequential logic for state transition
    always @(posedge clk) begin
        if (reset)
            state <= ST_IDLE;
        else
            state <= next_state;
    end

    // Combinational logic for next state and outputs
    always @(*) begin
        // Default assignments
        next_state = state;
        disc = 1'b0;
        flag = 1'b0;
        err = 1'b0;

        case (state)
            ST_IDLE: begin
                if (in == 1'b1)
                    next_state = ST_S1;
                else
                    next_state = ST_IDLE;
            end

            ST_S1: begin
                if (in == 1'b1)
                    next_state = ST_S2;
                else
                    next_state = ST_IDLE;
            end

            ST_S2: begin
                if (in == 1'b1)
                    next_state = ST_S3;
                else
                    next_state = ST_IDLE;
            end

            ST_S3: begin
                if (in == 1'b1)
                    next_state = ST_S4;
                else
                    next_state = ST_IDLE;
            end

            ST_S4: begin
                if (in == 1'b1)
                    next_state = ST_S5;
                else
                    next_state = ST_IDLE;
            end

            ST_S5: begin
                if (in == 1'b1) begin
                    next_state = ST_S6;
                end else begin
                    next_state = ST_IDLE;
                end
            end

            ST_S6: begin
                if (in == 1'b1) begin
                    next_state = ST_S7;
                end else begin
                    next_state = ST_IDLE;
                end
            end

            ST_S7: begin
                if (in == 1'b1) begin
                    // 7 or more consecutive 1s - error
                    err = 1'b1;
                    next_state = ST_S7;
                end else begin
                    // Found 0 after 6 1s -> flag
                    flag = 1'b1;
                    next_state = ST_IDLE;
                end
            end

            default: next_state = ST_IDLE;
        endcase
    end

endmodule
