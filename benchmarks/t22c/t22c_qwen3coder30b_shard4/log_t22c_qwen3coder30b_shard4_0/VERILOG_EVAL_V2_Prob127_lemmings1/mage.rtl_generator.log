    localparam STATE_WALK_LEFT = 1'b0;
    localparam STATE_WALK_RIGHT = 1'b1;

    // State register
    logic current_state;
    logic next_state;

    // Sequential logic for state transitions
    always @(posedge clk or posedge areset) begin
        if (areset)
            current_state <= STATE_WALK_LEFT;
        else
