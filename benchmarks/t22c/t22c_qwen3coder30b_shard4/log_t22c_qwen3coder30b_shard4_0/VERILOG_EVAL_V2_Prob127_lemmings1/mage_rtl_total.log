    // Define states
    localparam WALK_LEFT = 1'b0;
    localparam WALK_RIGHT = 1'b1;

    // Current and next state
    logic state, state_next;

    // Sequential logic for state register
    always @(posedge clk or posedge areset) begin
        if (areset)
            state <= WALK_LEFT;
        else
            state <= state_next;
    end

    // Next state logic
    always @(*) begin
        case (state)
