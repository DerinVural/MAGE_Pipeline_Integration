[2026-05-14 13:52:18,028 - mage.rtl_generator - INFO] RTL code: module TopModule (
    input clk,
    input areset,
    input bump_left,
    input bump_right,
    output walk_left,
    output walk_right
);

    // Define states
    localparam WALK_LEFT = 1'b0;
    localparam WALK_RIGHT = 1'b1;

    // State register
    logic current_state;
    
    // Next state logic
    logic next_state;
    
    // Sequential logic
    always @(posedge clk or posedge areset) begin
        if (areset)
            current_state <= WALK_LEFT;
        else
            current_state <= next_state;
    end

    // Combinational logic to determine next state
    always @(*) begin
        if (bump_left || bump_right) begin
            // Toggle direction upon bump
            next_state = ~current_state;
        end else begin
            // No change in direction
            next_state = current_state;
        end
    end

    // Output logic
    always @(*) begin
        if (current_state == WALK_LEFT) begin
            walk_left = 1'b1;
            walk_right = 1'b0;
        end else begin
            walk_left = 1'b0;
            walk_right = 1'b1;
        end
    end

endmodule
