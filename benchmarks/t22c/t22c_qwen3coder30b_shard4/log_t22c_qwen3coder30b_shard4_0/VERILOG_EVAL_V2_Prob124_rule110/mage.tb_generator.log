        .clk,\n        .load,\n        .data,\n        .q(q_ref) );\n        \n    TopModule top_module1 (\n        .clk,\n        .load,\n        .data,\n        .q(q_dut) );\n\n    \n    bit strobe = 0;\n    task wait_for_end_of_timestep;\n        repeat(5) begin\n            strobe <= !strobe;  // Try to delay until the very end of the time step.\n            @(strobe);\n        end\n    endtask    \n    \n    // Queue-based simulation mismatch display\n    reg [511:0] data_queue [$];\n    reg load_queue [$];\n    reg [511:0] got_output_queue [$];\n    reg [511:0] golden_queue [$];\n    \n    localparam MAX_QUEUE_SIZE = 10;\n    \n    always @(posedge clk, negedge clk) begin\n        if (data_queue.size() >= MAX_QUEUE_SIZE - 1) begin\n            data_queue.delete(0);\n            load_queue.delete(0);\n            got_output_queue.delete(0);\n            golden_queue.delete(0);\n        end\n\n        data_queue.push_back(data);\n        load_queue.push_back(load);\n        got_output_queue.push_back(q_dut);\n        golden_queue.push_back(q_ref);\n\n        // Check for first mismatch\n        if (got_output_queue[$] !== golden_queue[$]) begin\n            $display(\"Mismatch detected at time %t\", $time);\n            $display(\"\\nLast %d cycles of simulation:\", data_queue.size());\n\n\n            for (int i = 0; i < data_queue.size(); i++) begin\n                if (got_output_queue[i] === golden_queue[i]) begin\n                    $display(\"Got Match at\");\n                end else begin\n                    $display(\"Got Mismatch at\");\n                end\n                $display(\"Cycle %d, load %b, data %h (%b), got output %h (%b), exp output %h (%b)\",\n                    i,\n                    load_queue[i],\n                    data_queue[i], data_queue[i],\n                    got_output_queue[i], got_output_queue[i],\n                    golden_queue[i], golden_queue[i]\n                );\n            end\n        end\n    end\n    \n   