[2026-05-14 15:56:48,301 - mage.agent - INFO] module TopModule (
    input clk,
    input resetn,
    input [2:0] r,
    output [2:0] g
);

    // State definitions
    localparam ST_A = 2'b00;
    localparam ST_B = 2'b01;
    localparam ST_C = 2'b10;
    localparam ST_D = 2'b11;

    // Current and next state
    logic [1:0] state, next_state;

    // Next state logic
    always @(*) begin
        case (state)
            ST_A: begin
                if (r[0])
                    next_state = ST_B;
                else if (r[1])
                    next_state = ST_C;
                else if (r[2])
                    next_state = ST_D;
                else
                    next_state = ST_A;
            end
            
            ST_B: begin
                if (r[0])
                    next_state = ST_B;
                else
                    next_state = ST_A;
            end
            
            ST_C: begin
                if (r[1])
                    next_state = ST_C;
                else
                    next_state = ST_A;
            end
            
            ST_D: begin
                next_state = ST_D;
            end
            
            default: next_state = ST_A;
        endcase
    end

    // State flip-flop
    always @(posedge clk) begin
        if (!resetn)
            state <= ST_A;
        else
            state <= next_state;
    end

    // Output logic
    assign g = (state == ST_A) ? 3'b000 :
              (state == ST_B) ? 3'b001 :
              (state == ST_C) ? 3'b010 :
              (state == ST_D) ? 3'b100 :
                               3'b000;

endmodule
