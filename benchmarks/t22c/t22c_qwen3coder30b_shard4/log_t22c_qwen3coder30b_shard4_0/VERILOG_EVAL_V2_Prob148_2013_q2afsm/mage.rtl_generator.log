                if (r[1])
                    next_state = ST_C;
                else
                    next_state = ST_A;
            end
            
            ST_D: begin
                next_state = ST_A;
            end
        endcase
    end

    // State flip-flop
    always @(posedge clk or negedge resetn) begin
        if (!resetn)
            state <= ST_A;
        else
            state <= next_state;
