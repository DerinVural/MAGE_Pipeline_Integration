);

    // State definitions
    localparam ST_A = 2'b00;
    localparam ST_B = 2'b01;
    localparam ST_C = 2'b10;
    localparam ST_D = 2'b11;

    // Current and next state registers
    logic [1:0] state;
    logic [1:0] state_next;

    // Sequential logic for state flip-flops
    always @(posedge clk) begin
        if (!resetn)
            state <= ST_A;
        else
            state <= state_next;
    end

