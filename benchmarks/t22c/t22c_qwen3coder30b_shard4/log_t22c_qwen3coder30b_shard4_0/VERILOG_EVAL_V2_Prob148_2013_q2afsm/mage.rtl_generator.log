                    state_next = ST_B;
                else
                    state_next = ST_A;
            end
            
            ST_C: begin
                if (r[1])
                    state_next = ST_C;
                else
                    state_next = ST_A;
            end
            
            ST_D: begin
                state_next = ST_A;
            end
        endcase
    end

