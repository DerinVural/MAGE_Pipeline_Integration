    output [2:0] g
);

    // Define states
    localparam ST_A = 2'b00;
    localparam ST_B = 2'b01;
    localparam ST_C = 2'b10;
    localparam ST_D = 2'b11;

    // Current and next state signals
    logic [1:0] state, state_next;

    // Internal signal for output logic
    logic [2:0] g_int;

    // Sequential logic for state flip-flops
    always @(posedge clk) begin
        if (resetn == 0)
            state <= ST_A;
        else
            state <= state_next;
    end

    // Next state logic
    always @(*) begin
        case (state)
            ST_A: begin
                if (r[0])
                    state_next = ST_B;
                else if (r[1])
                    state_next = ST_C;
                else if (r[2])
                    state_next = ST_D;
                else
                    state_next = ST_A;
            end
            
            ST_B: begin
                if (r[0])
                    state_next = ST_B;
                else
                    state_next = ST_A;
            end
            
            ST_C: begin
                if (r[1])
                    state_next = ST_C;
                else
                    state_next = ST_A;
            end
            
            ST_D: begin
                state_next = ST_A;
            end
        endcase
    end

    // Output logic
    always @(*) begin
        g_int = 3'b000;
        case (state)
            ST_A: begin
                if (r[0]) g_int[0] = 1'b1;
                else if (r[1]) g_int[1] = 1'b1;
                else if (r[2]) g_int[2] = 1'b1;
            end
            
            ST_B: g_int[0] = 1'b1;
            
            ST_C: g_int[1] = 1'b1;
            
            ST_D: g_int[2] = 1'b1;
        endcase
    end

    // Assign internal signal to output port
    assign g = g_int;

endmodule
