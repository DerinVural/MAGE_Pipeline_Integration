                if (r[1])
                    state_next = ST_C;
                else
                    state_next = ST_A;
            end
            ST_D: begin
                if (r[2])
                    state_next = ST_D;
                else
                    state_next = ST_A;
            end
            default: state_next = ST_A;
        endcase
    end

    // State register update
    always @(posedge clk or negedge resetn) begin
        if (!resetn)
            state <= ST_A;
        else
            state <= state_next;
    end

    // Output logic for g
    always @(*) begin
        case (state)
