            ST_B: begin
                if (r[0])
                    state_next = ST_B;
                else
                    state_next = ST_A;
            end
            ST_C: begin
                if (r[1])
                    state_next = ST_C;
                else
                    state_next = ST_A;
            end
            ST_D: begin
                state_next = ST_D;
            end
        endcase
    end

    // Output logic for grant signals using continuous assignment
    assign g[0] = (state == ST_B);
    assign g[1] = (state == ST_C);
    assign g[2] = (state == ST_D);

endmodule
