[2026-05-14 16:00:22,351 - mage.rtl_generator - INFO] RTL code: module TopModule (
    input clk,
    input resetn,
    input [2:0] r,
    output [2:0] g
);

    // State definitions
    localparam ST_A = 2'b00;
    localparam ST_B = 2'b01;
    localparam ST_C = 2'b10;
    localparam ST_D = 2'b11;

    // Internal signals
    logic [1:0] state, next_state;
    
    // State register
    always @(posedge clk or negedge resetn) begin
        if (!resetn)
            state <= ST_A;
        else
            state <= next_state;
    end

    // Next state logic
    always @(*) begin
        case (state)
            ST_A: begin
                if (r[0])
                    next_state = ST_B;
                else if (r[1])
                    next_state = ST_C;
                else if (r[2])
                    next_state = ST_D;
                else
                    next_state = ST_A;
            end
            
            ST_B: begin
                if (r[0])
                    next_state = ST_B;
                else
                    next_state = ST_A;
            end
            
            ST_C: begin
                if (r[1])
                    next_state = ST_C;
                else
                    next_state = ST_A;
            end
            
            ST_D: begin
                next_state = ST_A;
            end
            
            default:
                next_state = ST_A;
        endcase
    end

    // Output logic
    assign g[0] = (state == ST_B);
    assign g[1] = (state == ST_C);
    assign g[2] = 1'b0; // No specific output for g[2]

endmodule
