                    next_state = ST_B;
                else
                    next_state = ST_A;
            
            ST_C:
                if (r[1])
                    next_state = ST_C;
                else
                    next_state = ST_A;
            
            ST_D:
                if (r[2])
                    next_state = ST_D;
                else
                    next_state = ST_A;
        endcase
    end

    // State flip-flops
    always @(posedge clk or negedge resetn) begin
        if (!resetn)
            state <= ST_A;
        else
            state <= next_state;
    end

    // Output logic
    always @(*) begin
