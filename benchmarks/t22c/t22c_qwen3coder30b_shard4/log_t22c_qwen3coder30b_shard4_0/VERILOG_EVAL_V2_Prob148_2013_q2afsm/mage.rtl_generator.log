    // State definitions
    localparam ST_A = 2'b00;
    localparam ST_B = 2'b01;
    localparam ST_C = 2'b10;
    localparam ST_D = 2'b11;

    // State register
    logic [1:0] state;
    logic [1:0] state_next;

    // State transition logic
    always @(posedge clk or negedge resetn) begin
        if (!resetn)
            state <= ST_A;
        else
            state <= state_next;
    end

    // Next state logic
    always @(*) begin
        case (state)
            ST_A: begin
                if (r[0])
                    state_next = ST_B;
                else if (r[1])
                    state_next = ST_C;
                else if (r[2])
                    state_next = ST_D;
                else
                    state_next = ST_A;
            end
            
            ST_B: begin
                if (r[0])
                    state_next = ST_B;
                else
                    state_next = ST_A;
            end
            
            ST_C: begin
                if (r[1])
                    state_next = ST_C;
                else
                    state_next = ST_A;
            end
            
            ST_D: begin
                state_next = ST_D; // Stay in D until reset
            end
            
            default: state_next = ST_A;
        endcase
    end

    // Output logic using continuous assignment
    assign g[0] = (state == ST_B);  // g[0] = 1 if in state B
    assign g[1] = (state == ST_C);  // g[1] = 1 if in state C
    assign g[2] = (state == ST_D);  // g[2] = 1 if in state D

endmodule
