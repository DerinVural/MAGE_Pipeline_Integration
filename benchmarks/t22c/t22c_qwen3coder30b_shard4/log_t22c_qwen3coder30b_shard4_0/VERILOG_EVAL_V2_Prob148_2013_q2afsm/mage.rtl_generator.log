[2026-05-14 16:04:12,642 - mage.rtl_generator - INFO] RTL code: module TopModule (
    input clk,
    input resetn,
    input [2:0] r,
    output [2:0] g
);

    // Define states
    localparam ST_A = 2'b00;
    localparam ST_B = 2'b01;
    localparam ST_C = 2'b10;
    localparam ST_D = 2'b11;

    // State register
    logic [1:0] state;
    logic [1:0] state_next;

    // Initialize state to ST_A
    initial begin
        state = ST_A;
    end

    // State transition logic
    always @(*) begin
        case (state)
            ST_A: begin
                if (r[0])
                    state_next = ST_B;
                else if (r[1])
                    state_next = ST_C;
                else if (r[2])
                    state_next = ST_D;
                else
                    state_next = ST_A;
            end
            ST_B: begin
                if (r[0])
                    state_next = ST_B;
                else
                    state_next = ST_A;
            end
            ST_C: begin
                if (r[1])
                    state_next = ST_C;
                else
                    state_next = ST_A;
            end
            ST_D: begin
                if (r[2])
                    state_next = ST_D;
                else
                    state_next = ST_A;
            end
            default: state_next = ST_A;
        endcase
    end

    // State register update
    always @(posedge clk or negedge resetn) begin
        if (!resetn)
            state <= ST_A;
        else
            state <= state_next;
    end

    // Output logic for g using assign
    assign g = (state == ST_A) ? 3'b000 :
               (state == ST_B) ? 3'b001 :
               (state == ST_C) ? 3'b010 :
               3'b100;

endmodule
