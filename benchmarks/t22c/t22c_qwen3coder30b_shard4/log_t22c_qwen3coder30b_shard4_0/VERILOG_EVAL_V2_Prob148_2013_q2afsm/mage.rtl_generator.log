[2026-05-14 16:01:43,754 - mage.rtl_generator - INFO] RTL code: module TopModule (
    input clk,
    input resetn,
    input [2:0] r,
    output [2:0] g
);

    // State encoding
    localparam ST_A = 2'b00;
    localparam ST_B = 2'b01;
    localparam ST_C = 2'b10;
    localparam ST_D = 2'b11;

    // State registers
    logic [1:0] state, next_state;

    // Next state logic
    always @(*) begin
        case (state)
            ST_A:
                if (r[0])
                    next_state = ST_B;
                else if (r[1])
                    next_state = ST_C;
                else if (r[2])
                    next_state = ST_D;
                else
                    next_state = ST_A;
            
            ST_B:
                if (r[0])
                    next_state = ST_B;
                else
                    next_state = ST_A;
            
            ST_C:
                if (r[1])
                    next_state = ST_C;
                else
                    next_state = ST_A;
            
            ST_D:
                if (r[2])
                    next_state = ST_D;
                else
                    next_state = ST_A;
        endcase
    end

    // State flip-flops
    always @(posedge clk or negedge resetn) begin
        if (!resetn)
            state <= ST_A;
        else
            state <= next_state;
    end

    // Output logic
    always @(*) begin
        g[0] = 1'b0;
        g[1] = 1'b0;
        g[2] = 1'b0;
        case (state)
            ST_A:;
            ST_B: g[0] = 1'b1;
            ST_C: g[1] = 1'b1;
            ST_D: g[2] = 1'b1;
        endcase
    end

endmodule
