 half-cycle before is already wrong. It\'s more likely\n37: \t\t// a functionality error than the reset being implemented asynchronously.\n38: \t\n39: \tendtask\n40: \n41: \n42: // Add two ports to module stimulus_gen:\n43: //    output [511:0] wavedrom_title\n44: //    output reg wavedrom_enable\n45: \n46: \ttask wavedrom_start(input[511:0] title = "");\n47: \tendtask\n48: \n49: \ttask wavedrom_stop;\n50: \t\t#1;\n51: \tendtask\t\n52: \n53: \n54: \twire [0:13][3:0] d = {\n55: \t\t4\'h2,\n56: \t\t4\'h2,\n57: \t\t4\'h3,\n58: \t\t4\'h2,\n59: \t\t4\'ha,\n60: \t\t4\'h2,\n61: \t\t4\'h0,\n62: \t\t4\'h0,\n63: \t\t4\'h0,\n64: \t\t4\'h3,\n65: \t\t4\'h2,\n66: \t\t4\'h2,\n67: \t\t4\'h2,\n68: \t\t4\'h2\n69: \t};\n70: \n71: \tinitial begin\n72: \t\treset <= 1\'b1;\n73: \t\t{bump_left, bump_right, ground, dig} <= 4\'h2;\n74: \t\treset_test(1);\n75: \n76: \t\treset <= 1\'b1;\n77: \t\t@(posedge clk);\n78: \t\treset <= 0;\n79: \t\t\n80: \t\t@(negedge clk);\n81: \t\twavedrom_start("Digging");\n82: \t\tfor (int i=0;i<14;i++)\n83: \t\t\t@(posedge clk) {bump_left, bump_right, ground, dig} <= d[i];\n84: \t\twavedrom_stop();\n85: \t\t\n86: \t\trepeat(400) @(posedge clk, negedge clk) begin\n87: \t\t\t{dig, bump_right, bump_left} <= $random & $random;\n88: \t\t\tground <= |($random & 7);\n89: \t\t\treset <= !($random & 31);\n90: \t\ten d\n91: \n92: \t\t#1 $finish;\n93: \tend\n94: \t\n95: endmodule\n96: \n97: module tb();\n98: \n99: \ttypedef struct packed {\n100: \t\tint errors;\n101: \t\tint errortime;\n102: \t\tint errors_walk_left;\n103: \t\tint errortime_walk_left;\n104: \t\tint errors_walk_right;\n105: \t\tint errortime_walk_right;\n106: \t\tint errors_aaah;\n107: \t\tint errortime_aaah;\n108: \t\tint errors_digging;\n109: \t\tint errortime_digging;\n110: \n111: \t\tint clocks;\n112: \t} stats;\n113: \t\n114: \tstats stats1;\n115: \t\n116: \t\n117: \twire[511:0] wavedrom_title;\n118: \twire wavedrom_enable;\n119: \tint wavedrom_hide_after_time;\n120: \t\n121: \treg clk=0;\n122: \tiniti