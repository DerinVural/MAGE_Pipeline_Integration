 \'%s\' has no mismatches.", "walk_left");\n193: \t\tif (stats1.errors_walk_right) $display("Hint: Output \'%s\' has %0d mismatches. First mismatch occurred at time %0d.", "walk_right", stats1.errors_walk_right, stats1.errortime_walk_right);\n194: \t\telse $display("Hint: Output \'%s\' has no mismatches.", "walk_right");\n195: \t\tif (stats1.errors_aaah) $display("Hint: Output \'%s\' has %0d mismatches. First mismatch occurred at time %0d.", "aaah", stats1.errors_aaah, stats1.errortime_aaah);\n196: \t\telse $display("Hint: Output \'%s\' has no mismatches.", "aaah");\n197: \t\tif (stats1.errors_digging) $display("Hint: Output \'%s\' has %0d mismatches. First mismatch occurred at time %0d.", "digging", stats1.errors_digging, stats1.errortime_digging);\n198: \t\telse $display("Hint: Output \'%s\' has no mismatches.", "digging");\n199: \n200: \t\t$display("Hint: Total mismatched samples is %1d out of %1d samples\\n", stats1.errors, stats1.clocks);\n201: \t\t$display("Simulation finished at %0d ps", $time);\n202: \t\t$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);\n203: \n204: \t\tif (stats1.errors == 0) begin\n205: \t\t\t$display("SIMULATION PASSED");\n206: \t\tend else begin\n207: \t\t\t$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);\n208: \t\tend\n209: \tend\n210: \t\n211: \t// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.\n212: \tassign tb_match = ( { walk_left_ref, walk_right_ref, aaah_ref, digging_ref } === ( { walk_left_ref, walk_right_ref, aaah_ref, digging_ref } ^ { walk_left_dut, walk_right_dut, aaah_dut, digging_dut } ^ { walk_left_ref, walk_right_ref, aaah_ref, digging_ref } ) );\n213: \t// Use explicit sensitivity list here. @(*) causes NetProc::nex_input() to be called when trying to compute\n214: \t// the sensitivity list of the @(strobe) process, which isn\'t implemented.\n215: \talways @(posedge clk, negedge clk) begin\n216: \n217: \t\tstats1.clocks++;\n218: \t\tif (!tb_match) begin\n219: \t\t\tif (stats1.errors == 0) stats1.errortime = $time;\n220: \t\t\tstats1.errors++;\n221: \t\t\t// Display inputs and outputs at first mismatch\n222: \t\t\tif (stats1.errors == 1) begin\n223: \t\t\t\t$display("FIRST MISMATCH DETECTED AT TIME %0d:", $time);\n224: \t\t\t\t$display("Input signals:\\tclk=%b, areset=%b, bump_left=%b, bump_right=%b, ground=%b, dig=%b",\n225: \t\t\t\t\tclk, areset, bump_left, bump_right, ground, dig);\n226: \t\t\t\t$display("Expected outputs:\\twalk_left=%b, walk_right=%b, aaah=%b, digging=%b",\n227: \t\t\t\t\twalk_left_ref, walk_right_ref, aaah_ref, digging_ref);\n228: \t\t\t\t$display("Actual outputs:\\twalk_left=%b, walk_right=%b, aaah=%b, digging=%b",\n229: \t\t\t\t\twalk_left_dut, walk_right_dut, aaah_dut, digging_dut);\n230: \t\t\tend\n231: \t\tend\n232: \t\tif (walk_left_ref !== ( walk_left_ref ^ walk_left_dut ^ walk_left_ref ))\n233: \t\tbegin if (stats1.errors_walk_left == 0) stats1.errortime_walk_left = $time;\n234: \t\t\tstats1.errors_walk_left = stats1.errors_walk_left+1\'b1; end\n235: \t\tif (walk_right_ref !== ( walk_right_ref ^ walk_right_dut ^ walk_right_ref ))\n236: \t\tbegin if (stats1.errors_walk_right == 0) stats1.errortime_walk_right = $time;\n237: \t\t\tstats1.errors_walk_right = stats1.errors_walk_right+1\'b1; end\n238: \t\tif (aaah_ref !== ( aaah_ref ^ aaah_dut ^ aaah_ref ))\n239: \t\tbegin if (stats1.errors_aaah == 0) stats1.errortime_aaah = $time;\n240: \t\t\tstats1.errors_aaah = stats1.errors_aaah+1\'b1; end\n241: \t\tif (digging_ref !== ( digging_ref ^ digging_dut ^ digging_ref ))\n242: \t\tbegin if (stats1.errors_digging == 0) stats1.errortime_digging = $time;\n243: \t\t\tstats1.errors_digging = stats1.errors_digging+1\'b1; end\n244: \n245: \tend\n246: \n247: \t// add timeout after 100K cycles\n248: \tinitial begin\n249: \t\t#1000000\n250: \t\t$display("TIMEOUT");\n251: \t\t$finish();\n252: \tend\n253: \n254: endmodule\n\n