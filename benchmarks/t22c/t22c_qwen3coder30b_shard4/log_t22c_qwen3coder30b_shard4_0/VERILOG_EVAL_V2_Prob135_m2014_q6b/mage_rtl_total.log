	reg [2:0] y_queue [$];
	reg w_queue [$];
	reg Y1_dut_queue [$];
	reg Y1_ref_queue [$];
	localparam MAX_QUEUE_SIZE = 8;
	
	always @(posedge clk, negedge clk) begin
		if (y_queue.size() >= MAX_QUEUE_SIZE - 1) begin
			y_queue.delete(0);
			w_queue.delete(0);
			Y1_dut_queue.delete(0);
			Y1_ref_queue.delete(0);
		end

		y_queue.push_back(y);
		w_queue.push_back(w);
		Y1_dut_queue.push_back(Y1_dut);
