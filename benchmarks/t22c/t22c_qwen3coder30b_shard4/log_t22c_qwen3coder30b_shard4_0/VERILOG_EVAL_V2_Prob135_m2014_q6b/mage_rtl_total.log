            $display("  w = %b", w);
            $display("  Y1_ref = %b", Y1_ref);
            $display("  Y1_dut = %b", Y1_dut);
        end
    end
    if (Y1_ref !== ( Y1_ref ^ Y1_dut ^ Y1_ref ))
    begin 
        if (stats1.errors_Y1 == 0) stats1.errortime_Y1 = $time;
        stats1.errors_Y1 = stats1.errors_Y1+1'b1; 
    end

end

// add timeout after 100K cycles
initial begin
    #1000000
    $display("TIMEOUT");
    $finish();
end

endmodule
