always @(posedge clk, negedge clk) begin

	stats1.clocks++;
	if (!tb_match) begin
		if (stats1.errors == 0) stats1.errortime = $time;
		stats1.errors++;
		
		// Display first mismatch
		if (stats1.errors == 1) begin
			$display("FIRST MISMATCH AT TIME %0d:", $time);
			$display("predict_valid=%b predict_pc=0x%0h (%b) train_valid=%b train_taken=%b train_mispredicted=%b train_history=0x%0h (%b) train_pc=0x%0h (%b)",
				predict_valid, predict_pc, predict_pc,
				train_valid, train_taken, train_mispredicted,
				train_history, train_history,
				train_pc, train_pc);
			$display("predict_taken_ref=%b predict_taken_dut=%b predict_history_ref=0x%0h (%b) predict_history_dut=0x%0h (%b)",
				predict_taken_ref, predict_taken_dut,
				predict_history_ref, predict_history_ref,
				predict_history_dut, predict_history_dut);
		end
	end
	if (predict_taken_ref !== ( predict_taken_ref ^ predict_taken_dut ^ predict_taken_ref ))
	begin if (stats1.errors_predict_taken == 0) stats1.errortime_predict_taken = $time;
