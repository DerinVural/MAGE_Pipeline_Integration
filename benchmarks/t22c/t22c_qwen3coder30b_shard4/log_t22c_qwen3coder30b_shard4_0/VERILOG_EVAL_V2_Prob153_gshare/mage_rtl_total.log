    "interface": "module TopModule (\n    input clk,\n    input areset,\n\n    input predict_valid,\n    input [6:0] predict_pc,\n    output predict_taken,\n    output [6:0] predict_history,\n\n    input train_valid,\n    input train_taken,\n    input train_mispredicted,\n    input [6:0] train_history,\n    input [6:0] train_pc\n);",
