		if (stats1.errors == 1) begin
			$display("FIRST MISMATCH AT TIME %0d:", $time);
			$display("predict_valid=%b predict_pc=0x%0h (%b) train_valid=%b train_taken=%b train_mispredicted=%b train_history=0x%0h (%b) train_pc=0x%0h (%b)",
