            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
            // Display mismatch details
            $display("Mismatch detected at time %t", $time);
            $display("Input x = %b, y = %b, Got z_dut = %b, Expected z_ref = %b", x, y, z_dut, z_ref);
        end
        if (z_ref !== ( z_ref ^ z_dut ^ z_ref ))
        begin 
            if (stats1.errors_z == 0) stats1.errortime_z = $time;
            stats1.errors_z = stats1.errors_z+1'b1; 
        end

    end

