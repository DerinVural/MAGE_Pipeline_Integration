endmodule


module B (
    input  logic x,
    input  logic y,
    output logic z
);

    // Given waveform
    // time  x  y  z
    // 0ns   0  0  1
    // 5ns   0  0  1
    // 10ns  0  0  1
    // 15ns  0  0  1
    // 20ns  0  0  1
