            S011: begin
                if (x == 1'b0)
                    state_next = 3'b001;
                else
                    state_next = 3'b010;
                z_temp = 1'b1;
            end
            S100: begin
                if (x == 1'b0)
                    state_next = 3'b011;
                else
                    state_next = 3'b100;
                z_temp = 1'b1;
            end
            default: begin
                state_next = S000;
                z_temp = 1'b0;
            end
        endcase
    end

    // Assign the temporary output z to the actual output
    assign z = z_temp;

    // Output Y0 is the least significant bit of the next state
    assign Y0 = state_next[0];

