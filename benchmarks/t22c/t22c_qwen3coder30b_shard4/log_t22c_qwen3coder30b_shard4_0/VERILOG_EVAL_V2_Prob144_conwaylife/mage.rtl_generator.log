] count_neighbors (input [3:0] row, input [3:0] col);\\n        logic [255:0] temp_q;\\n        temp_q = q_reg;\\n        \\n        logic sum;\\n        sum = 0;\\n        \\n        // Loop through all 8 neighbors\\n        for (integer i = -1; i <= 1; i++) begin\\n            for (integer j = -1; j <= 1; j++) begin\\n                if (!(i == 0 && j == 0)) begin\\n                    integer neighbor_row;\\n                    integer neighbor_col;\\n                    integer neighbor_idx;\\n                    \\n                    neighbor_row = get_row_index(row + i);\\n                    neighbor_col = get_col_index(col + j);\\n                    neighbor_idx = neighbor_row * 16 + neighbor_col;\\n                    \\n                    sum = sum + temp_q[neighbor_idx];\\n                end\\n            end\\n        end\\n        \\n        return sum;\\n    endfunction\\n\\n    // Generate next state\\n    always @(*) begin\\n        q_next = 0;\\n        for (integer i = 0; i < 256; i++) begin\\n            integer row;\\n            integer col;\\n            integer neighbors;\\n            \\n            row = i / 16;\\n            col = i % 16;\\n            neighbors = count_neighbors(row, col);\\n            \\n            // Apply Game of Life rules\\n            if (q_reg[i]) begin\\n                // Cell is alive\\n                if (neighbors < 2 || neighbors > 3)\\n                    q_next[i] = 0;\\n                else\\n                    q_next[i] = 1;\\n            end else begin\\n                // Cell is dead\\n                if (neighbors == 3)\\n                    q_next[i] = 1;\\n                else\\n                    q_next[i] = 0;\\n            end\\n        end\\n    end\\n\\n    // Sequential logic\\n    always @(posedge clk) begin\\n        if (load)\\n            q_reg <= data;\\n        else\\n            q_reg <= q_next;\\n    end\\n\\n    // Output assignment\\n    assign q = q_reg;\\n\\nendmodule"\n}')]