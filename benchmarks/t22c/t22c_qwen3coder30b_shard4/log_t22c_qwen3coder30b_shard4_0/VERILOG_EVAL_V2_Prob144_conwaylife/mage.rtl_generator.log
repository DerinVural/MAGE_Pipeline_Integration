[2026-05-14 15:31:43,688 - mage.rtl_generator - INFO] {
    "reasoning": "To implement Conway's Game of Life on a 16x16 toroidal grid using SystemVerilog, I must design a module that advances the state by one generation on each clock cycle. The key aspects to consider are: 1) Representing the 16x16 grid as a 256-bit vector with rows stored consecutively, 2) Calculating neighbor counts for each cell while handling wraparound for toroidal boundaries, 3) Applying the Game of Life rules correctly, 4) Handling the load signal to initialize the grid, 5) Ensuring proper sequential behavior with clock synchronization. I will break the implementation into steps: 1) Define the logic for counting neighbors with toroidal wrapping, 2) Apply the transition rules, 3) Implement the sequential update mechanism, 4) Handle the load functionality. For neighbor counting, I will calculate the index of each neighbor considering toroidal boundaries. To avoid syntax errors, I'll ensure bit selection uses correct indices (e.g., q[15:0] for row 0), use proper concatenation for multi-bit selections, and declare all signals as logic.",
    "module": "module TopModule (\n    input clk,\n    input load,\n    input [255:0] data,\n    output [255:0] q\n);\n\n    logic [255:0] q_reg;\n    logic [255:0] q_next;\n\n    // Helper function to get neighbor indices with toroidal wrapping\n    function automatic [3:0] get_row_index (input [3:0] row);\n        return (row + 16) % 16;\n    endfunction\n\n    function automatic [3:0] get_col_index (input [3:0] col);\n        return (col + 16) % 16;\n    endfunction\n\n    // Function to get the neighbor count for a specific cell\n    function automatic [3:0] count_neighbors (input [3:0] row, input [3:0] col);\n        logic [255:0] temp_q;\n        temp_q = q_reg;\n        \n        logic sum;\n        sum = 0;\n        \n        // Loop through all 8 neighbors\n        for (integer i = -1; i <= 1; i++) begin\n            for (integer j = -1; j <= 1; j++) begin\n                if (!(i == 0 && j == 0)) begin\n                    integer neighbor_row;\n                    integer neighbor_col;\n                    integer neighbor_idx;\n                    \n                    neighbor_row = get_row_index(row + i);\n                    neighbor_col = get_col_index(col + j);\n                    neighbor_idx = neighbor_row * 16 + neighbor_col;\n                    \n                    sum = sum + temp_q[neighbor_idx];\n                end\n            end\n        end\n        \n        return sum;\n    endfunction\n\n    // Generate next state\n    always @(*) begin\n        q_next = 0;\n        for (integer i = 0; i < 256; i++) begin\n            integer row;\n            integer col;\n            integer neighbors;\n            \n            row = i / 16;\n            col = i % 16;\n            neighbors = count_neighbors(row, col);\n            \n            // Apply Game of Life rules\n            if (q_reg[i]) begin\n                // Cell is alive\n                if (neighbors < 2 || neighbors > 3)\n                    q_next[i] = 0;\n                else\n                    q_next[i] = 1;\n            end else begin\n                // Cell is dead\n                if (neighbors == 3)\n                    q_next[i] = 1;\n                else\n                    q_next[i] = 0;\n            end\n        end\n    end\n\n    // Sequential logic\n    always @(posedge clk) begin\n        if (load)\n            q_reg <= data;\n        else\n            q_reg <= q_next;\n    end\n\n    // Output assignment\n    assign q = q_reg;\n\nendmodule"
}
