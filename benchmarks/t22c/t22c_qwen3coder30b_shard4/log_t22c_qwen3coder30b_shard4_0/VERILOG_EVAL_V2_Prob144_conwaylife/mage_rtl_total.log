se\n                    q_next[i] = 1;\n            end else begin\n                // Cell is dead\n                if (neighbors == 3)\n                    q_next[i] = 1;\n                else\n                    q_next[i] = 0;\n            end\n        end\n    end\n\n    // Sequential logic\n    always @(posedge clk) begin\n        if (load)\n            q_reg <= data;\n        else\n            q_reg <= q_next;\n    end\n\n    // Output assignment\n    assign q = q_reg;\n\nendmodule"
