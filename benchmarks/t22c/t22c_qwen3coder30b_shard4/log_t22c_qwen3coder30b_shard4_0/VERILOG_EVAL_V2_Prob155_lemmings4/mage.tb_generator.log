edge clk);\n113: \t\t{bump_left, bump_right, ground, dig} <= 2; \t\t// Splat? (24-cycles)\n114: \t\trepeat(2) @(posedge clk);\n115: \t\twavedrom_stop();\n116: \t\t\n117: \t\treset <= 1;\n118: \t\t@(posedge clk)\n119: \t\treset <= 0; \t\t// Resurrect.\n120: \t\t{bump_left, bump_right, ground, dig} <= 2; \t\t// Normal\n121: \t\t@(posedge clk);\n122: \t\t@(posedge clk);\n123: \t\t{bump_left, bump_right, ground, dig} <= 0; \t\t// Fall\n124: \t\trepeat(35) @(posedge clk);\n125: \t\t{bump_left, bump_right, ground, dig} <= 2; \t\t// Splat? (Test for 5-bit non-saturating counter)\n126: \t\trepeat(2) @(posedge clk);\n127: \t\trepeat(20) @(posedge clk) begin\n128: \t\t\t{dig, bump_right, bump_left} <= $random & $random; \t\t// See if it\'s handled correctly.\n129: \t\t\tground <= |($random & 7);\n130: \t\tend\t\n131: \n132: \t\treset <= 1;\n133: \t\t{bump_left, bump_right, ground, dig} <= 2; \t\t// Normal\n134: \t\t@(posedge clk)\n135: \t\treset <= 0; \t\t// Resurrect.\n136: \t\t@(posedge clk);\n137: \t\t{bump_left, bump_right, ground, dig} <= 0; \t\t// Fall\n138: \t\trepeat(67) @(posedge clk);\n139: \t\t{bump_left, bump_right, ground, dig} <= 2; \t\t// Splat? (Test for 6-bit non-saturating counter)\n140: \t\trepeat(20) @(posedge clk) begin\n141: \t\t\t{dig, bump_right, bump_left} <= $random & $random; \t\t// See if it\'s handled correctly.\n142: \t\t\tground <= |($random & 7);\n143: \t\tend\n144: \t\t\n145: \t\treset <= 1;\n146: \t\t{bump_left, bump_right, ground, dig} <= 2; \t\t// Normal\n147: \t\t@(posedge clk)\n148: \t\treset <= 0; \t\t// Resurrect.\n149: \t\t\n150: \t\t\n151: \t\trepeat(400) @(posedge clk, negedge clk) begin\n152: \t\t\t{dig, bump_right, bump_left} <= $random & $random;\n153: \t\t\tground <= |($random & 7);\n154: \t\t\treset <= !($random & 31);\n155: \t\tend\n156: \n157: \t\t#1 $finish;\n158: \tend\n159: \n160: endmodule\n161: \n162: module tb();\n163: \n164: typedef struct packed {\n165: \tint errors;\n166: \tint errortime;\n167: \tint errors_walk_left;