   endcase\n142:     end\n143: \n144: endmodule\n\n</previous_code>\n<previous_tb>\n1: `timescale 1 ps/1 ps\n2: `define OK 12\n3: `define INCORRECT 13\n4: \n5: module stimulus_gen (\n6: \tinput clk,\n7: \toverride output logic areset,\n8: \toverride output logic bump_left,\n9: \toverride output logic bump_right,\n10: \toverride output logic dig,\n11: \toverride output logic ground,\n12: \toverride output reg[511:0] wavedrom_title,\n13: \toverride output reg wavedrom_enable,\n14: \tinput tb_match\n15: );\n16: \n17: \treg reset;\n18: \tassign areset = reset;\n19: \n20: \ttask reset_test(input async=0);\n21: \t\tbit arfail, srfail, datafail;\n22: \t\n23: \t\t@(posedge clk);\n24: \t\t@(posedge clk) reset <= 0;\n25: \t\trepeat(3) @(posedge clk);\n26: \t\n27: \t\t@(negedge clk) begin datafail = !tb_match ; reset <= 1; end\n28: \t\t@(posedge clk) arfail = !tb_match;\n29: \t\t@(posedge clk) begin\n30: \t\t\tsrfail = !tb_match;\n31: \t\t\treset <= 0;\n32: \t\tend\n33: \t\tif (srfail)\n34: \t\t\t$display("Hint: Your reset doesn\'t seem to be working.");\n35: \t\telse if (arfail && (async || !datafail))\n36: \t\t\t$display("Hint: Your reset should be %0s, but doesn\'t appear to be.", async ? "asynchronous" : "synchronous");\n37: \t\t// Don\'t warn about synchronous reset if the half-cycle before is already wrong. It\'s more likely\n38: \t\t// a functionality error than the reset being implemented asynchronously.\n39: \t\n40: \tendtask\n41: \n42: \n43: \t// Add two ports to module stimulus_gen:\n44: \t//    output [511:0] wavedrom_title\n45: \t//    output reg wavedrom_enable\n46: \n47: \ttask wavedrom_start(input[511:0] title = "");\n48: \tendtask\n49: \n50: \ttask wavedrom_stop;\n51: \t\t#1;\n52: \tendtask\t\n53: \n54: \n55: \n56: \tinitial begin\n57: \t\treset <= 1\'b1;\n58: \t\t@(posedge clk);\n59: \t\treset <= 0;\n60: \t\t{bump_left, bump_right, ground, dig} <= 2;\n61: \t\trepeat(2) @(posedge clk);\n62: \t\t{bump_left, bump_right, ground, dig} <= 3;\n63: \t\t@(posedge clk)