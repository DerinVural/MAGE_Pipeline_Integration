 \t.dig );\n256: RefModule good1 (\n257: \t.clk,\n258: \t.areset,\n259: \t.bump_left,\n260: \t.bump_right,\n261: \t.ground,\n262: \t.dig,\n263: \t.walk_left(walk_left_ref),\n264: \t.walk_right(walk_right_ref),\n265: \t.aaah(aaah_ref),\n266: \t.digging(digging_ref) );\n267: \t\n268: TopModule top_module1 (\n269: \t.clk,\n270: \t.areset,\n271: \t.bump_left,\n272: \t.bump_right,\n273: \t.ground,\n274: \t.dig,\n275: \t.walk_left(walk_left_dut),\n276: \t.walk_right(walk_right_dut),\n277: \t.aaah(aaah_dut),\n278: \t.digging(digging_dut) );\n279: \n280: \n281: bit strobe = 0;\n282: task wait_for_end_of_timestep;\n283: \trepeat(5) begin\n284: \t\tstrobe <= !strobe;  // Try to delay until the very end of the time step.\n285: \t\t@(strobe);\n286: \tend\n287: endtask\t\n288: \n289: \n290: final begin\n291: \tif (stats1.errors_walk_left) $display("Hint: Output \'%s\' has %0d mismatches. First mismatch occurred at time %0d.", "walk_left", stats1.errors_walk_left, stats1.errortime_walk_left);\n292: \telse $display("Hint: Output \'%s\' has no mismatches.", "walk_left");\n293: \tif (stats1.errors_walk_right) $display("Hint: Output \'%s\' has %0d mismatches. First mismatch occurred at time %0d.", "walk_right", stats1.errors_walk_right, stats1.errortime_walk_right);\n294: \telse $display("Hint: Output \'%s\' has no mismatches.", "walk_right");\n295: \tif (stats1.errors_aaah) $display("Hint: Output \'%s\' has %0d mismatches. First mismatch occurred at time %0d.", "aaah", stats1.errors_aaah, stats1.errortime_aaah);\n296: \telse $display("Hint: Output \'%s\' has no mismatches.", "aaah");\n297: \tif (stats1.errors_digging) $display("Hint: Output \'%s\' has %0d mismatches. First mismatch occurred at time %0d.", "digging", stats1.errors_digging, stats1.errortime_digging);\n298: \telse $display("Hint: Output \'%s\' has no mismatches.", "digging");\n299: \n300: \t$display("Hint: Total mismatched samples is %1d out of %1d samples\\n", stats1.errors, stats1.clocks);\n301: \t$display("Simulatio