    input clk,
    input aresetn,
    input x,
    output z
);

    // Define states
    localparam STATE_IDLE = 2'b00;
    localparam STATE_SEEN_1 = 2'b01;
    localparam STATE_SEEN_10 = 2'b10;

    // State registers
    logic [1:0] current_state, next_state;

    // Next state and output logic
    always @(*) begin
        case (current_state)
            STATE_IDLE: begin
                if (x)
                    next_state = STATE_SEEN_1;
                else
                    next_state = STATE_IDLE;
            end
            STATE_SEEN_1: begin
                if (x)
                    next_state = STATE_SEEN_1;
                else
                    next_state = STATE_SEEN_10;
            end
            STATE_SEEN_10: begin
                if (x)
                    next_state = STATE_SEEN_10;
                else
                    next_state = STATE_IDLE;
            end
            default: next_state = STATE_IDLE;
        endcase
    end

    // Output logic
    always @(*) begin
        case (current_state)
            STATE_IDLE: z = 0;
            STATE_SEEN_1: z = 0;
            STATE_SEEN_10: z = x; // Output z is 1 only when x is 1
            default: z = 0;
        endcase
    end

    // Sequential logic for state register
    always @(posedge clk or negedge aresetn) begin
        if (!aresetn)
            current_state <= STATE_IDLE;
        else
            current_state <= next_state;
    end

