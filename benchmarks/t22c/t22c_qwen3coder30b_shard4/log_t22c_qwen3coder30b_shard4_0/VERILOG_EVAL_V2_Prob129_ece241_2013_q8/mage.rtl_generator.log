                if (x)
                    state_next = S1;
                else
                    state_next = S2;
            end
            S2: begin
                if (x)
                    state_next = S1;
                else
                    state_next = S0;
            end
            default: state_next = S0;
        endcase
    end

    // Output logic (Mealy machine)
    always @(*) begin
        case (state)
            S0: z = 1'b0;
            S1: z = 1'b0;
            S2: z = x;
            default: z = 1'b0;
        endcase
    end

endmodule
