end\n        else if (state[9]) begin // Wait state\n            if (ack)\n                S_next = 1'b1;\n            else\n                Wait_next = 1'b1;\n        end\n    end\n\n    // Output logic (Moore machine)\n    always @(*) begin\n        done = 1'b0;\n        counting = 1'b0;\n        shift_ena = 1'b0;\n\n        if (state[4] || state[5] || state[6] || state[7]) // B0, B1, B2, B3 states\n            shift_ena = 1'b1;\n        else if (state[8]) // Count state\n            counting = 1'b1;\n        else if (state[9]) // Wait state\n            done = 1'b1;\n    end\n\nendmodule"
