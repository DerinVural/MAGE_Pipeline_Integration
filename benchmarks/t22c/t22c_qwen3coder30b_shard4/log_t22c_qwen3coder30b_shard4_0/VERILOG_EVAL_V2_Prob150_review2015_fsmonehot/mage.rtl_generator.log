    output logic Wait_next,
    output logic done,
    output logic counting,
    output logic shift_ena
);

    // Next state logic
    always @(*) begin
        B3_next = 1'b0;
        S_next = 1'b0;
        S1_next = 1'b0;
        Count_next = 1'b0;
        Wait_next = 1'b0;

        if (state[0]) begin // S state
            if (d)
                S1_next = 1'b1;
            else
                S_next = 1'b1;
        end
        else if (state[1]) begin // S1 state
            if (d)
                S1_next = 1'b1;
            else
                S_next = 1'b1;
        end
        else if (state[2]) begin // S11 state
            if (d)
                S1_next = 1'b1; // This was previously S11_next, but S1 is the correct target for d=1
            else
                S_next = 1'b1; // This was previously S110_next, but S is the correct target for d=0
        end
        else if (state[3]) begin // S110 state
            if (d)
                S_next = 1'b1; // Correctly transition to S for d=1
            else
                S_next = 1'b1; // Correctly transition to S for d=0
        end
        else if (state[4]) begin // B0 state
            B1_next = 1'b1;
        end
        else if (state[5]) begin // B1 state
            B2_next = 1'b1;
        end
        else if (state[6]) begin // B2 state
            B3_next = 1'b1;
        end
        else if (state[7]) begin // B3 state
            Count_next = 1'b1;
        end
        else if (state[8]) begin // Count state
            if (done_counting)
                Wait_next = 1'b1;
            else
                Count_next = 1'b1;
        end
        else if (state[9]) begin // Wait state
            if (ack)
                S_next = 1'b1;
            else
                Wait_next = 1'b1;
        end
    end

    // Output logic
    always @(*) begin
        done = 1'b0;
        counting = 1'b0;
        shift_ena = 1'b0;

        if (state[4]) begin // B0
            shift_ena = 1'b1;
        end
        else if (state[5]) begin // B1
            shift_ena = 1'b1;
        end
        else if (state[6]) begin // B2
            shift_ena = 1'b1;
        end
        else if (state[7]) begin // B3
            shift_ena = 1'b1;
        end
        else if (state[8]) begin // Count
            counting = 1'b1;
        end
        else if (state[9]) begin // Wait
            done = 1'b1;
        end
    end

endmodule
