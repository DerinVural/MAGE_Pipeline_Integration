                    S11_next_logic = 1'b1;
                else
                    S110_next_logic = 1'b1;
            end

            S110: begin
                if (d == 1'b1)
                    B0_next_logic = 1'b1;
                else
                    S_next_logic = 1'b1;
            end

            B0: begin
                B1_next_logic = 1'b1;
            end

            B1: begin
                B2_next_logic = 1'b1;
            end

            B2: begin
                B3_next_logic = 1'b1;
            end

            B3: begin
                Count_next_logic = 1'b1;
            end

            Count: begin
                if (done_counting == 1'b1)
                    Wait_next_logic = 1'b1;
                else
                    Count_next_logic = 1'b1;
            end

            Wait: begin
                if (ack == 1'b1)
                    S_next_logic = 1'b1;
                else
                    Wait_next_logic = 1'b1;
            end

            default: begin
                S_next_logic = 1'b1;
            end
        endcase
    end

    // Assign outputs for next states
    assign S_next      = S_next_logic;
    assign S1_next     = S1_next_logic;
    assign S11_next    = S11_next_logic;
    assign S110_next   = S110_next_logic;
    assign B0_next     = B0_next_logic;
    assign B1_next     = B1_next_logic;
    assign B2_next     = B2_next_logic;
    assign B3_next     = B3_next_logic;
    assign Count_next  = Count_next_logic;
    assign Wait_next   = Wait_next_logic;

    // Combinational logic for outputs
    always @(*) begin
        done_logic      = 1'b0;
        counting_logic  = 1'b0;
        shift_ena_logic = 1'b0;

        case (state)
            B0:
                shift_ena_logic = 1'b1;

            B1:
                shift_ena_logic = 1'b1;

            B2:
                shift_ena_logic = 1'b1;

            B3:
                shift_ena_logic = 1'b1;

            Count:
                counting_logic = 1'b1;

            Wait:
                done_logic = 1'b1;

            default:;
        endcase
    end

    // Assign outputs
    assign done      = done_logic;
    assign counting  = counting_logic;
    assign shift_ena = shift_ena_logic;

endmodule
