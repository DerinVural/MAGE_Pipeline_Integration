        B3_next_logic = 1'b0;
        S_next_logic = 1'b0;
        S1_next_logic = 1'b0;
        Count_next_logic = 1'b0;
        Wait_next_logic = 1'b0;

        // Determine next state based on current state and inputs
        if (state == S) begin
            if (d == 1)
                S1_next_logic = 1'b1;
            else
                S_next_logic = 1'b1;
        end
        else if (state == S1) begin
            if (d == 1)
                S1_next_logic = 1'b1;
            else
                S_next_logic = 1'b1;
        end
        else if (state == S11) begin
            if (d == 1)
                S11_next_logic = 1'b1;
            else
                S110_next_logic = 1'b1;
        end
        else if (state == S110) begin
            if (d == 1)
                B0_next_logic = 1'b1;
            else
                S_next_logic = 1'b1;
        end
        else if (state == B0) begin
            B1_next_logic = 1'b1;
        end
        else if (state == B1) begin
            B2_next_logic = 1'b1;
        end
        else if (state == B2) begin
            B3_next_logic = 1'b1;
        end
        else if (state == B3) begin
            Count_next_logic = 1'b1;
        end
        else if (state == Count) begin
            if (done_counting == 1)
                Wait_next_logic = 1'b1;
            else
                Count_next_logic = 1'b1;
        end
        else if (state == Wait) begin
