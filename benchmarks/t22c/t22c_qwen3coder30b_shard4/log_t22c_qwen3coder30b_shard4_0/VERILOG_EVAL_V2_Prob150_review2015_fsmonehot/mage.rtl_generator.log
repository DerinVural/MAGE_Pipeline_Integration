                else
                    Wait_next_logic = 1'b1;
            end

            default: begin
                S_next_logic = 1'b1;
            end
        endcase
    end

    // Assign outputs for next states
    assign S_next      = S_next_logic;
    assign S1_next     = S1_next_logic;
