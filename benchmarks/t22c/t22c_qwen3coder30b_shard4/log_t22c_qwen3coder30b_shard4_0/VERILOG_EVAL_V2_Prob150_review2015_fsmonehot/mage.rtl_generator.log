    output shift_ena
);

    // Define state encodings
    localparam S      = 10'b0000000001;
    localparam S1     = 10'b0000000010;
    localparam S11    = 10'b0000000100;
    localparam S110   = 10'b0000001000;
    localparam B0     = 10'b0000010000;
    localparam B1     = 10'b0000100000;
    localparam B2     = 10'b0001000000;
    localparam B3     = 10'b0010000000;
    localparam Count  = 10'b0100000000;
    localparam Wait   = 10'b1000000000;

    // Next state signals
    logic B3_next_reg;
    logic S_next_reg;
    logic S1_next_reg;
    logic Count_next_reg;
    logic Wait_next_reg;

    // Output signals
    logic done_reg;
    logic counting_reg;
    logic shift_ena_reg;

    // Next state logic
    always @(*) begin
        B3_next_reg = 1'b0;
        S_next_reg = 1'b0;
        S1_next_reg = 1'b0;
        Count_next_reg = 1'b0;
        Wait_next_reg = 1'b0;

        case (state)
            S: begin
                if (d == 1'b1)
                    S1_next_reg = 1'b1;
                else
                    S_next_reg = 1'b1;
            end
            S1: begin
                if (d == 1'b1)
                    S1_next_reg = 1'b1;
                else
                    S_next_reg = 1'b1;
            end
            S11: begin
                if (d == 1'b1)
                    S11_next_reg = 1'b1;
                else
                    S110_next_reg = 1'b1;
            end
            S110: begin
                if (d == 1'b1)
                    B0_next_reg = 1'b1;
                else
                    S_next_reg = 1'b1;
            end
            B0: begin
                B1_next_reg = 1'b1;
            end
            B1: begin
                B2_next_reg = 1'b1;
            end
            B2: begin
                B3_next_reg = 1'b1;
            end
            B3: begin
                Count_next_reg = 1'b1;
            end
            Count: begin
                if (done_counting == 1'b1)
                    Wait_next_reg = 1'b1;
                else
                    Count_next_reg = 1'b1;
            end
            Wait: begin
                if (ack == 1'b1)
                    S_next_reg = 1'b1;
                else
                    Wait_next_reg = 1'b1;
            end
            default: begin
                S_next_reg = 1'b1;
            end
        endcase
    end

    // Output logic
    always @(*) begin
        done_reg = 1'b0;
        counting_reg = 1'b0;
        shift_ena_reg = 1'b0;

        case (state)
            B0:
                shift_ena_reg = 1'b1;
            B1:
                shift_ena_reg = 1'b1;
            B2:
                shift_ena_reg = 1'b1;
            B3:
                shift_ena_reg = 1'b1;
            Count:
                counting_reg = 1'b1;
            Wait:
                done_reg = 1'b1;
            default:
                ;
        endcase
    end

    // Assign outputs
    assign B3_next = B3_next_reg;
    assign S_next = S_next_reg;
    assign S1_next = S1_next_reg;
    assign Count_next = Count_next_reg;
    assign Wait_next = Wait_next_reg;
    assign done = done_reg;
    assign counting = counting_reg;
    assign shift_ena = shift_ena_reg;

endmodule
