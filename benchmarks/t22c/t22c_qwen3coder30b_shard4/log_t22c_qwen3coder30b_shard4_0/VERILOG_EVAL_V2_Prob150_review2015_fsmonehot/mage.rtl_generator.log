        end
        else if (state[3]) begin
            // Current state is S110
            if (d)
                B3_next = 1'b1;
            else
                S_next = 1'b1;
        end
        else if (state[4]) begin
            // Current state is B0
            B1_next = 1'b1;
        end
        else if (state[5]) begin
            // Current state is B1
            B2_next = 1'b1;
        end
        else if (state[6]) begin
            // Current state is B2
            B3_next = 1'b1;
        end
        else if (state[7]) begin
            // Current state is B3
            Count_next = 1'b1;
        end
        else if (state[8]) begin
            // Current state is Count
            if (done_counting)
                Wait_next = 1'b1;
            else
                Count_next = 1'b1;
        end
        else if (state[9]) begin
            // Current state is Wait
            if (ack)
                S_next = 1'b1;
            else
                Wait_next = 1'b1;
        end
    end

    // Output logic
    always @(*) begin
        done = 1'b0;
        counting = 1'b0;
        shift_ena = 1'b0;

        if (state[4] || state[5] || state[6] || state[7]) begin
            shift_ena = 1'b1;
        end
        else if (state[8]) begin
            counting = 1'b1;
        end
