                S11_next = 1'b1;
        end
        else if (state == S110) begin
            if (d == 0)
                S_next = 1'b1;
            else
                B0_next = 1'b1;
        end
        else if (state == B0) begin
            B1_next = 1'b1;
        end
        else if (state == B1) begin
            B2_next = 1'b1;
        end
        else if (state == B2) begin
            B3_next = 1'b1;
        end
        else if (state == B3) begin
            Count_next = 1'b1;
        end
        else if (state == Count) begin
            if (done_counting == 0)
                Count_next = 1'b1;
            else
                Wait_next = 1'b1;
        end
        else if (state == Wait) begin
            if (ack == 0)
                Wait_next = 1'b1;
            else
                S_next = 1'b1;
        end
    end

    // Output logic
    always @(*) begin
        done = 1'b0;
        counting = 1'b0;
        shift_ena = 1'b0;

        if (state == B0 || state == B1 || state == B2 || state == B3)
            shift_ena = 1'b1;
        else if (state == Count)
            counting = 1'b1;
        else if (state == Wait)
            done = 1'b1;
    end

endmodule
