                    B0_next_logic = 1'b1;
                end
            end
            B0: begin
                B1_next_logic = 1'b1;
            end
            B1: begin
                B2_next_logic = 1'b1;
            end
            B2: begin
                B3_next_logic = 1'b1;
            end
            B3: begin
                Count_next_logic = 1'b1;
            end
            Count: begin
