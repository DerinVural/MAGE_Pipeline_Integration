            B0: B1_next = 1'b1;
            B1: B2_next = 1'b1;
            B2: B3_next = 1'b1;
            B3: Count_next = 1'b1;
            Count: begin
                if (done_counting) Wait_next = 1'b1;
                else Count_next = 1'b1;
            end
            Wait: begin
                if (ack) S_next = 1'b1;
                else Wait_next = 1'b1;
            end
            default: begin
                // Default case
                S_next = 1'b1; // Default to S state
            end
        endcase
    end

    // Output logic
    always @(*) begin
        done = 1'b0;
        counting = 1'b0;
        shift_ena = 1'b0;

        case (state)
            B0: shift_ena = 1'b1;
            B1: shift_ena = 1'b1;
            B2: shift_ena = 1'b1;
            B3: shift_ena = 1'b1;
            Count: counting = 1'b1;
            Wait: done = 1'b1;
