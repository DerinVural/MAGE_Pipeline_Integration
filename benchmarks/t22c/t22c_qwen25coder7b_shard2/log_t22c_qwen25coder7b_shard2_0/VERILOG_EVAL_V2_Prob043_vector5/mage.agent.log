module stimulus_gen (
	input clk,
	password [4]: logic a, b, c, d, e
);
	initial begin
		repeat(100) @(posedge clk, negedge clk)
			{a, b, c, d, e} <= $random;
		$finish;
	end
endmodule

module tb();
