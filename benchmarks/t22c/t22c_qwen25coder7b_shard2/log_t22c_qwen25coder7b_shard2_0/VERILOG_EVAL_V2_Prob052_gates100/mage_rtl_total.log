    input string title;
    wavedrom_title <= title;
    wavedrom_enable <= 1;
endtask

task wavedrom_stop;
    @(posedge clk);
    wavedrom_enable <= 0;
endtask

initial begin
    reg logic [3:0] count; count = 0;
    in <= 100'h0;

    @(negedge clk) wavedrom_start("Test AND gate");
    @(posedge clk, negedge clk) in <= 100'h0;
    @(posedge clk, negedge clk); in <= ~100'h0;
    @(posedge clk, negedge clk); in <= 100'h3ffff;
    @(posedge clk, negedge clk); in <= ~100'h3ffff;
    @(posedge clk, negedge clk); in <= 100'h80;
    @(posedge clk, negedge clk); in <= ~100'h80;
