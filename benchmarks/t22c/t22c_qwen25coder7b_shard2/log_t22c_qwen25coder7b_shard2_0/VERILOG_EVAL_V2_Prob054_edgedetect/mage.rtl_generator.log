    input  logic clk,
    input  logic [7:0] in,
    output logic [7:0] pedge
);

    // Internal storage for the previous input
    logic [7:0] prev_in;

    // Assign the previous input on each rising edge of the clock
    always @(posedge clk) begin
        prev_in <= in;
    end

    // Combinational logic to detect positive edge transitions
    always @(*) begin
