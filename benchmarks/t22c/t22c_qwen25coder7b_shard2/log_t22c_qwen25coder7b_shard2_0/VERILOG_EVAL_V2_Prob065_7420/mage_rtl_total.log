endtask	

task wavedrom_stop;
  #1;
endtask	


initial begin
  int count; count = 0;
  {p1a,p1b,p1c,p1d} <= 4'h0; 		// Initialize inputs
  {p2a,p2b,p2c,p2d} <= 4'h0; 		// Initialize inputs
  wavedrom_start("Two NAND gates");
  repeat(20) @(posedge clk) begin
    {p1a,p1b,p1c,p1d} <= count; 		// Sequentially set inputs
    {p2a,p2b,p2c,p2d} <= count+1; 		// Sequentially set inputs
    count = count + 1;
  end
  wavedrom_stop();

  repeat(200) @(posedge clk,negedge clk) begin
    {p1a,p1b,p1c,p1d,p2a,p2b,p2c,p2d} <= $random; 		// Randomize inputs
  end
  
  #1 $finish;
end

endmodule

