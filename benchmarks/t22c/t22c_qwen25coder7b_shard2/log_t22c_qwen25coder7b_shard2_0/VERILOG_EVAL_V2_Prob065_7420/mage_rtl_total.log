module stimulus_gen (
	input clk,
	output reg p1a,
	output reg p1b,
	output reg p1c,
	output reg p1d,
	output reg p2a,
	output reg p2b,
	output reg p2c,
	output reg p2d,
	output reg[511:0] wavedrom_title,
	output reg wavedrom_enable
);

task wavedrom_start(input[511:0] title = "");
	$display("WaveDrom Title: \"%s\"
", title);
	wavedrom_title = title;
endtask

function void wavedrom_stop;
	$display("WaveDrom stop
");
	wavedrom_enable = 0;
	wavedrom_title = 512'b0;
endfunction

initial begin
	integer count = 0;
	{p1a, p1b, p1c, p1d} = 4'b0;
	{p2a, p2b, p2c, p2d} = 4'b0;
	wavedrom_start("Two NAND gates");
	repeat(20) @(posedge clk) begin
		{p1a, p1b, p1c, p1d} = count;
		{p2a, p2b, p2c, p2d} = count + 1;
		count = count + 1;
	end
	wavedrom_stop();

	repeat(200) @(posedge clk, negedge clk) begin
		{p1a, p1b, p1c, p1d, p2a, p2b, p2c, p2d} = $random;
		wavedrom_enable = 1;
		wavedrom_title = 512'b0;
	end

	#1 $finish;
end

