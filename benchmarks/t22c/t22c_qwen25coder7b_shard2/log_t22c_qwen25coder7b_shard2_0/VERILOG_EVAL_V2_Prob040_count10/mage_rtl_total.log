    // Define states using localparams
    localparam IDLE = 4'b0000;
    localparam COUNT_0 = 4'b0001;
    localparam COUNT_1 = 4'b0010;
    localparam COUNT_2 = 4'b0011;
    localparam COUNT_3 = 4'b0100;
    localparam COUNT_4 = 4'b0101;
    localparam COUNT_5 = 4'b0110;
    localparam COUNT_6 = 4'b0111;
    localparam COUNT_7 = 4'b1000;
    localparam COUNT_8 = 4'b1001;
    localparam COUNT_9 = 4'b1010;

    // State Register
    logic [3:0] current_state, next_state;

    // Sequential Logic
    always_ff @(posedge clk or posedge reset) begin
        if (reset)
            current_state <= IDLE;
        else
            current_state <= next_state;
    end

    // Next State Determination
    always @(*) begin
        next_state = current_state;
        case (current_state)
            IDLE: next_state = COUNT_0;
            COUNT_0: next_state = COUNT_1;
            COUNT_1: next_state = COUNT_2;
            COUNT_2: next_state = COUNT_3;
            COUNT_3: next_state = COUNT_4;
            COUNT_4: next_state = COUNT_5;
            COUNT_5: next_state = COUNT_6;
            COUNT_6: next_state = COUNT_7;
            COUNT_7: next_state = COUNT_8;
            COUNT_8: next_state = COUNT_9;
            COUNT_9: next_state = COUNT_0;
            default: next_state = IDLE;
        endcase
    end

    // Combinational Logic
    always @(*) begin
        q = 4'b0000;
        case (current_state)
            COUNT_0: q = 4'b0000;
            COUNT_1: q = 4'b0001;
            COUNT_2: q = 4'b0010;
            COUNT_3: q = 4'b0011;
            COUNT_4: q = 4'b0100;
            COUNT_5: q = 4'b0101;
            COUNT_6: q = 4'b0110;
            COUNT_7: q = 4'b0111;
            COUNT_8: q = 4'b1000;
            COUNT_9: q = 4'b1001;
        endcase
    end

endmodule
