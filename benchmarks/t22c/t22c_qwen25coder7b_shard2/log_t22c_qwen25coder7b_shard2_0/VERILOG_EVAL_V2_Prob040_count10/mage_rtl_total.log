[2026-05-14 11:01:45,409 - mage.rtl_editor - INFO] module TopModule (
    input  logic clk,
    input  logic reset,
    output logic [3:0] q
);

    logic [3:0] count;

    always_ff @(posedge clk or posedge reset) begin
