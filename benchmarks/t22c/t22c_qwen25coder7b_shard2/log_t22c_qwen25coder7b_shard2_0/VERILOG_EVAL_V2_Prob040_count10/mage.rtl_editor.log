[2026-05-14 11:01:41,276 - mage.rtl_editor - INFO] module TopModule(
    input logic clk,
    input logic reset,
    output logic [3:0] q
);

    localparam COUNT_MAX = 10;

    logic [3:0] counter;

    always @(posedge clk) begin
        if (reset)
            counter <= 4'b0000;
        else begin
            if (counter == COUNT_MAX - 1)
                counter <= 4'b0000;
            else
                counter <= counter + 1;
        end
    end

    assign q = counter;

endmodule
