[2026-05-14 11:01:10,869 - mage.rtl_generator - INFO] RTL code: module TopModule (
	logic clk,
	logic reset,
	logic [3:0] q
);

	localparam MAX_COUNT = 4'd9;
	localparam RESET_VALUE = 4'd0;

	logic [3:0] counter;

	initial begin
		counter = RESET_VALUE;
	end

	// Sequential logic
	always_ff @(posedge clk or posedge reset) begin
		if (reset)
			counter <= RESET_VALUE;
		else if (counter == MAX_COUNT)
			counter <= RESET_VALUE;
		else
			counter <= counter + 1;
	end

	// Assign output
	assign q = counter;

endmodule
