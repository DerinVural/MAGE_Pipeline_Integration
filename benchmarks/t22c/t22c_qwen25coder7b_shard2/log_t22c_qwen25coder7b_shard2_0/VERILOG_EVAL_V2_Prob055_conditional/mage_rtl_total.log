logic [7:0] min_dut;

initial begin 
	$dumpfile("wave.vcd");
	$dumpvars(1, stim1.clk, tb_mismatch ,a,b,c,d,min_ref,min_dut );
end

wire tb_match;	wire tb_mismatch = ~tb_match;

stimulus_gen stim1 (
	.clk,
	.*,
	.a,
	.b,
	.c,
	.d);
RefModule good1 (
	.a,
	.b,
	.c,
	.d,
	.min(min_ref));

TopModule top_module1 (
	.a,
	.b,
	.c,
	.d,
	.min(min_dut));

bit strobe = 0;
task wait_for_end_of_timestep;
	repeat(5) begin
		strobe <= !strobe;
		@(strobe);
	end
endtask

final begin
	if (stats1.errors_min) $display("Hint: Output 'min' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_min, stats1.errortime_min);
	else $display("Hint: Output 'min' has no mismatches.");

