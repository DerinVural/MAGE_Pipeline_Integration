class bist_top;
parameter CLK_PERIOD = 10;
parameter RST_HOLD_TIME = 3;
parameter WAVEFORM_TIMEOUT = 1000000;
parameter ERR_MSG_MAX_LEN = 2048;
parameter ERR_MSG_FORMAT = "%s";
parameter ERR_MSG_FORMAT_STATE = "%%s";
parameter ERR_MSG_FORMAT_STATS = "Total mismatched samples is %%1d out of %%1d samples\n";
parameter ERR_MSG_FORMAT_FINISH = "Simulation finished at %%0d ps"
parameter ERR_MSG_FORMAT_MISSES = "Mismatches: %%1d in %%1d samples"
parameter ERR_MSG_FORMAT_ERRORTIME = "First mismatch occurred at time %%0d"
parameter ERR_MSG_FORMAT_FIRSTERROR = "Got Mismatch at Cycle %%d, reset %b, input %h, got output %h, exp output %h"
parameter ERR_MSG_FORMAT_NOMATCH = "Got No Match at Cycle %%d, reset %b, input %h, got output %h, exp output %h"
parameter ERR_MSG_FORMAT_RESETCHECK = "Hint: Your reset doesn't seem to be working."
parameter ERR_MSG_FORMAT_RESETTYPE = "Hint: Your reset should be %0s, but doesn't appear to be."
parameter ERR_MSG_FORMAT_RESETSYNC = "Don't warn about synchronous reset if the half-cycle before is already wrong. It's more likely a functionality error than the reset being implemented asynchronously."
reg clk;
reg reset;
logic train_valid;
logic train_taken;
logic [1:0] state_ref;
logic [1:0] state_dut;
wire tb_match;
wire tb_mismatch = ~tb_match;
parameter ERR_MSG_NOERR = "SIMULATION PASSED"
parameter ERR_MSG_ERR = "SIMULATION FAILED - %%d MISMATCHES DETECTED, FIRST AT TIME %%d"
parameter ERR_MSG_MAXQUEUE = 10
reg [ERR_MSG_MAXQUEUE-1:0] input_queue;
reg [ERR_MSG_MAXQUEUE-1:0] got_output_queue;
reg [ERR_MSG_MAXQUEUE-1:0] golden_queue;
reg [ERR_MSG_MAXQUEUE-1:0] reset_queue;
integer err_count;
integer err_time;
integer max_err;
parameter ERR_MSG_NOERR = "SIMULATION PASSED"
parameter ERR_MSG_ERR = "SIMULATION FAILED - %%d MISMATCHES DETECTED, FIRST AT TIME %%d"
integer current_clock;
task wavedrom_start(input[511:0] title = "");
endtask
task wavedrom_stop;
	#1;
endtask	
reg rst;
task reset_test(input async=0);
	bit arfail, srfail, datafail;
	@(+posedge clk);
	@(posedge clk) rst <= 0;
	repeat(RST_HOLD_TIME) @(posedge clk);
	@(negedge clk) begin datafail = !tb_match ; rst <= 1; end
	@(posedge clk) arfail = !tb_match;
	@(posedge clk) begin
		srfail = !tb_match;
		rst <= 0;
	end
	if (srfail)
		$display(ERR_MSG_RESETCHECK);
	else if (arfail && (async || !datafail))
		$display(ERR_MSG_RESETTYPE, async ? "asynchronous" : "synchronous");
endtask
assign train_taken = train_valid ? train_taken_r : 1'bx;
assign train_taken_r = train_taken;
integer max_wait;
task run_bist;
	max_wait = WAVEFORM_TIMEOUT / CLK_PERIOD;
	for (current_clock = 0; current_clock < max_wait; current_clock++) begin
		if (current_clock == 0) begin
			train_taken_r <= 1;
			train_valid <= 1;
		end
		if (current_clock == 1) begin
			wavedrom_start("Asynchronous reset");
			reset_test(1); // Test for asynchronous reset
			wavedrom_stop();
		end
		if (current_clock == 2) begin
			train_taken_r <= 1;
			train_valid <= 0;
			@(+posedge clk);
			train_taken_r <= 0;
		end
		if (current_clock == 3) begin
			wavedrom_start("Count up, then down");
			train_taken_r <= 1;
			@(posedge clk) train_valid <= 1;
			@(posedge clk) train_valid <= 0;
			@(posedge clk) train_valid <= 1;
			@(posedge clk) train_valid <= 1;
			@(posedge clk) train_valid <= 1;
			@(posedge clk) train_valid <= 0;
			@(posedge clk) train_valid <= 1;
			train_taken_r <= 0;
			@(posedge clk) train_valid <= 1;
			@(posedge clk) train_valid <= 0;
			@(posedge clk) train_valid <= 1;
			@(posedge clk) train_valid <= 1;
			@(posedge clk) train_valid <= 1;
			@(posedge clk) train_valid <= 0;
			@(posedge clk) train_valid <= 1;
			wavedrom_stop();
		end
		if (current_clock >= 4) begin
			repeat(1000) @(posedge clk,negedge clk) {train_valid, train_taken_r} <= {$urandom};
			if (current_clock == 4) train_taken_r <= 1;
			if (current_clock == 5) begin
				wavedrom_start("Synchronous reset");
				reset_test(0); // Test for synchronous reset
				wavedrom_stop();
			end
		end
	end
endtask
task check_results;
	for (current_clock = 0; current_clock < max_wait; current_clock++) begin
		if (got_output_queue[current_clock] !== golden_queue[current_clock]) begin
			$display(ERR_MSG_FIRSTERROR, current_clock, reset_queue[current_clock], input_queue[current_clock], got_output_queue[current_clock], golden_queue[current_clock]);
			err_count++;
			if (err_count == 1) err_time = $time;
		end else begin
			$display(ERR_MSG_NOMATCH, current_clock, reset_queue[current_clock], input_queue[current_clock], got_output_queue[current_clock], golden_queue[current_clock]);
		end
	end
endtask
task start;
	clk = 0;
	reset = 1;
	@(+posedge clk);
	reset = 0;
	run_bist();
	check_results();
	if (err_count > 0)
		$display(ERR_MSG_ERR, err_count, err_time);
	else
		$display(ERR_MSG_NOERR);
endtask
endclass
