parameter ERR_MSG_NOERR = "SIMULATION PASSED"
parameter ERR_MSG_ERR = "SIMULATION FAILED - %%d MISMATCHES DETECTED, FIRST AT TIME %%d"
integer current_clock;
task wavedrom_start(input[511:0] title = "");
endtask
task wavedrom_stop;
	#1;
endtask	
reg rst;
task reset_test(input async=0);
	bit arfail, srfail, datafail;
	@(+posedge clk);
	@(posedge clk) rst <= 0;
	repeat(RST_HOLD_TIME) @(posedge clk);
	@(negedge clk) begin datafail = !tb_match ; rst <= 1; end
	@(posedge clk) arfail = !tb_match;
	@(posedge clk) begin
		srfail = !tb_match;
		rst <= 0;
	end
	if (srfail)
		$display(ERR_MSG_RESETCHECK);
	else if (arfail && (async || !datafail))
		$display(ERR_MSG_RESETTYPE, async ? "asynchronous" : "synchronous");
endtask
assign train_taken = train_valid ? train_taken_r : 1'bx;
assign train_taken_r = train_taken;
integer max_wait;
task run_bist;
	max_wait = WAVEFORM_TIMEOUT / CLK_PERIOD;
	for (current_clock = 0; current_clock < max_wait; current_clock++) begin
		if (current_clock == 0) begin
			train_taken_r <= 1;
			train_valid <= 1;
		end
		if (current_clock == 1) begin
			wavedrom_start("Asynchronous reset");
			reset_test(1); // Test for asynchronous reset
			wavedrom_stop();
		end
		if (current_clock == 2) begin
			train_taken_r <= 1;
			train_valid <= 0;
			@(+posedge clk);
