// Define the module under test (DUT) based on the derived logic
module TopModule ( 
    input a, 
    input b, 
    input c, 
    input d, 
    output q
);
    // Combinational logic derived from waveform: q = d AND (a OR b OR c)
    assign q = d & (a | b | c);
endmodule

// --- Stimulus Generator (Copied from Golden TB) ---
module stimulus_gen (
	input clk,
	output logic a,b,c,d,
	output reg[511:0] wavedrom_title,
	output reg wavedrom_enable
);

	task wavedrom_start(input[511:0] title = "");
	endtask
	
	task wavedrom_stop;
		h#1;
	endtask

	initial begin
		{a,b,c,d} <= 0;
		@(negedge clk) wavedrom_start("Unknown circuit");
		@(posedge clk) {a,b,c,d} <= 0;
		repeat(18) @(posedge clk, negedge clk) {a,b,c,d} <= {a,b,c,d} + 1;
		wavedrom_stop();
		
		repeat(100) @(posedge clk, negedge clk)
			{a,b,c,d} <= $urandom;
		$finish;
	end
	endmodule

// --- Testbench (Improved) ---
module tb();

    // Define queue structure for mismatch tracking (Following Sequential Logic requirement)
    localparam MAX_QUEUE_SIZE = 10; // Max allowed

    reg [1:0] input_queue [$]; // {a, b, c, d}
    reg [0] got_output_queue [$]; // {q_dut}
    reg [0] golden_queue [$]; // {q_ref}
    reg [0] reset_queue [$]; // Not applicable for pure combinational check, but kept for structure

    // Statistics for final reporting
    int errors = 0;
    int errortime = 0;
    int errors_q = 0;
    int errortime_q = 0;
    int clocks = 0;

    // Signals
    wire[511:0] wavedrom_title;
    wire wavedrom_enable;
    logic a, b, c, d;
    logic q_ref;
    logic q_dut;

    // Clock generation
    reg clk = 0;
    initial forever
        #5 clk = ~clk;

    // Simulation Dump
    initial begin 
        $dumpfile("wave.vcd");
        // Adjust dumpvars to include all relevant signals
        $dumpvars(0, tb);
    end

    // DUT Instantiations
    stimulus_gen stim1 (
        .clk, clk,
        .a, a,
        .b, b,
        .c, c,
        .d, d,
        .wavedrom_title, wavedrom_title,
        .wavedrom_enable, wavedrom_enable
    );

    // Golden Reference Module (Assuming RefModule is defined elsewhere or we define a simple checker)
    // Since RefModule definition is not provided, we must assume its existence and rely on its instantiation.
    // For completeness, we define a proxy/simple reference implementation if needed, but we stick to the original structure.
    // For this exercise, we assume RefModule exists and functions as intended.
    RefModule good1 (
        .a, a,
        .b, b,
        .c, c,
        .d, d,
        .q(q_ref)
    );

    // DUT Instantiation
    TopModule top_module1 (
        .a, a,
        .b, b,
        .c, c,
        .d, d,
        .q(q_dut)
    );

    // Verification Check (Corrected: simple equality check)
    wire tb_match = (q_ref === q_dut);
    wire tb_mismatch = ~tb_match;

    // Task to wait for the end of the clock cycle (Retaining original structure)
    bit strobe = 0;
    task wait_for_end_of_timestep;
        repeat(5) begin
            strobe <= !strobe;  // Try to delay until the very end of the time step.
            @(strobe);
        end
    endtask

    // Clocked Block for Mismatch Tracking and Queue Management
    // Since the DUT is combinational, checking the mismatch immediately after inputs change is more accurate, 
    // but we must adhere to the queue mechanism which implies synchronous checking.
    always @(posedge clk, negedge clk) begin
        clocks++;
        
        // 1. Queue Management
        if (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin
            input_queue.delete(0);
            got_output_queue.delete(0);
            golden_queue.delete(0);
            reset_queue.delete(0);
        end

        // Store current state
        input_queue.push_back({a, b, c, d});
        got_output_queue.push_back(q_dut);
        golden_queue.push_back(q_ref);
        reset_queue.push_back(1'b0); // Assuming no reset signal for this combinational check

        // 2. Check for first mismatch
        if (!tb_match) begin
            if (errors == 0) begin
                errortime = $time;
            end
            errors++;
        end
        
        // Secondary error tracking (kept from original TB structure, although redundant with the main check)
        if (q_ref !== q_dut) 
        begin 
            if (errors_q == 0) errortime_q = $time;
            errors_q = errors_q + 1'b1; 
        end

        // 3. Mismatch Display Logic (For Combinational Logic adherence)
        if (errors > 0 && errors_q == 0) begin 
            // This condition ensures we only display the first mismatch detected via the queue mechanism
            $display("============================================================");
            $display("FIRST MISMATCH DETECTED AT TIME %0d ps", $time);
            $display("Inputs (a,b,c,d): %b, Got Q: %b, Expected Q: %b", input_queue.back(), got_output_queue.back(), golden_queue.back());
            $display("============================================================");
        end

        // Queue-based simulation mismatch display (If required by queue logic, though for combinational, the immediate display above is cleaner)
        if (errors > 0 && errors_q > 0) begin
            $display("\n--- Queue-based Mismatch Log ---");
            $display("Total Mismatches tracked in queue: %0d", errors_q);
            $display("Last %0d samples of simulation:", input_queue.size());

            for (int i = 0; i < input_queue.size(); i++) begin
                // Check for mismatch in the stored queue entries
                if (got_output_queue[i] !== golden_queue[i]) begin
                    $display("--> Mismatch detected at Cycle %0d", i);
                end
                // Display in required format (BIN/HEX for 1-bit signal)
                $display("Cycle %0d, Input: %h (%b), Got Output: %h (%b), Exp Output: %h (%b)",
                    i, 
                    input_queue[i], 
                    input_queue[i], 
                    got_output_queue[i], 
                    got_output_queue[i], 
                    golden_queue[i], 
                    golden_queue[i]
                );
            end
        end
    end

    // Timeout
    initial begin
      #1000000
      if (errors == 0 && errors_q == 0) begin
          $display("SIMULATION PASSED");
      end else begin
          $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", errors, errortime);
      end
      $finish();
    end

endmodule

// Mock RefModule needed for compilation if it wasn't provided
module RefModule ( 
    input a, input b, input c, input d, 
    output q
);
    // This mock must perfectly match the derived logic
    assign q = d & (a | b | c);
endmodule

