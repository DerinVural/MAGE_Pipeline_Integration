	RefModule good1 (
		.a, 
		.b, 
		.c, 
		.d,
		.q(q_ref) );
	
	// Instantiate Device Under Test (DUT)
	TopModule top_module1 (
		.a, 
		.b, 
		.c, 
		.d,
		.q(q_dut) );

	// Clock event observer for verification
	// Since the DUT is combinational, we check the mismatch immediately after inputs change, 
	// which often aligns closely with the clock edge in this type of testbench structure.
