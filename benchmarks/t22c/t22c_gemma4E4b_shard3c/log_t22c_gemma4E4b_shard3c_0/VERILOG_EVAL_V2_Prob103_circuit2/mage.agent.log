                (a==0 && b==0 && c==1 && d==1) || 
                (a==0 && b==1 && c==0 && d==1) || 
                (a==0 && b==1 && c==1 && d==0) || 
                (a==1 && b==0 && c==0 && d==1) || 
                (a==1 && b==0 && c==1 && d==0) || 
                (a==1 && b==1 && c==0 && d==0) || 
                (a==1 && b==1 && c==1 && d==1);
endmodule

