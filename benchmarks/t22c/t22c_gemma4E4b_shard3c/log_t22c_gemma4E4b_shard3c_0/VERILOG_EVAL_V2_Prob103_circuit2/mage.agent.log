		@(negedge clk);
		
		if (total_mismatches == 0) begin
			$display("SIMULATION PASSED");
			$display("Simulation finished at %0d ps", $time);
			$display("Mismatches: 0 in %1d samples", stats1.clocks);
		end else begin
