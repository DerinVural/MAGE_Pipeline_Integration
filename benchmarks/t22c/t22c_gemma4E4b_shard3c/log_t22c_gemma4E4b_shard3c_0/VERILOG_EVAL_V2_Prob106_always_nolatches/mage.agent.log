		end
		if (up_ref !== up_dut) 
		begin if (stats1.errors_up == 0) stats1.errortime_up = $time;
			stats1.errors_up = stats1.errors_up+1'b1; 
		end
	end

	// Add timeout after 100K cycles
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

	// FINAL REPORTING - MODIFIED TO MEET NEW SPECIFICATION
	initial begin
		// Wait for simulation to naturally finish or timeout
		@(negedge clk);
		#1;
		
		int total_mismatches = stats1.errors;
		int first_error_time = stats1.errortime;
		
		if (total_mismatches == 0)
		begin
			$display("SIMULATION PASSED");
		end
		else
		begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", total_mismatches, first_error_time);
		end
	end
	endmodule
