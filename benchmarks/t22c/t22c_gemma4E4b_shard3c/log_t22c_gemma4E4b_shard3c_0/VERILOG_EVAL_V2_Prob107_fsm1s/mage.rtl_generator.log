ue [$];\n\treg [0:0] got_output_queue [$];\n\treg [0:0] golden_queue [$];\n\treg reset_queue [$];\n\t\n\t// Mismatch tracking\n\tint total_mismatches = 0;\n\tint first_mismatch_time = 0;\n\t\n\t// --- Simulation Control and Dumping ---\n\tinitial begin \n\t\t\t$dumpfile("wave.vcd");\n\t\t\t$dumpvars(1, stim1.clk, tb_mismatch, clk, in, reset, out_ref, out_dut );\n\t\tend\n\n\t\n\twire tb_match; // Used by stimulus_gen, but we will use our own clock-edge driven check\n\t// Assigning tb_match to prevent compilation errors if it\'s used, but its value is overridden by the clocked logic.\n\tassign tb_match = 1\'b1; \n\t\n\t// --- DUT Instantiations ---\n\tstimulus_gen stim1 (\n\t\t.clk, \n\t\t.in, \n\t\t.reset, \n\t\t.wavedrom_title, \n\t\t.wavedrom_enable, \n\t\t.tb_match\n);\n\tRefModule good1 (\n\t\t.clk, \n\t\t.in, \n\t\t.reset,\n\t\t.out(out_ref) );\n\tTopModule top_module1 (\n\t\t.clk, \n\t\t.in, \n\t\t.reset, \n\t\t.out(out_dut) );\n\n\t\n\tbit strobe = 0;\n\ttask wait_for_end_of_timestep;\n\t\trepeat(5) begin\n\t\t\tstrobe <= !strobe;  // Try to delay until the very end of the time step.\n\t\t\t@(strobe);\n\t\tend\ttask\n\n\t// --- Clocked Verification Logic (Queue Management & Mismatch Detection) ---\n\talways @(posedge clk, negedge clk) begin\n\t\t\tstats1.clocks++;\n\n\t\t\t// 1. Store current cycle data\n\t\t\tinput_queue.push_back(in);\n\t\t\tgot_output_queue.push_back(out_dut);\n\t\t\tgolden_queue.push_back(out_ref);\n\t\t\treset_queue.push_back(reset);\n\n\t\t\t// 2. Manage queue size\n\t\t\tif (input_queue.size() >= MAX_QUEUE_SIZE) begin\n\t\t\t\tinput_queue.delete(0);\n\t\t\t\tgot_output_queue.delete(0);\n\t\t\t\tgolden_queue.delete(0);\n\t\t\t\treset_queue.delete(0);\n\t\t\tend\n\n\t\t\t// 3. Check for mismatch (This check happens *after* storing the current values)\n\t\t\tif (out_ref !== out_dut) begin\n\t\t\t\t// Mismatch detected! Record time and increment error count\n\t\t\t\tif (total_mismatches == 0) begin\n\t\t\t\t\tfirst_mismatch_time = $time;\n\t\t\t\tend\n\t\t\t\ttotal_mismatches++;\n\t\t\t\t\n\t\t\t\t// Update stats1 structure (maintaining original error counting logic)\n\t\t\t\tstats1.errors++;\n\t\t\t\tif (stats1.errors_out == 0) stats1.errortime_out = $time;\n\t\t\t\tstats1.errors_out = stats1.errors_out+1\'b1;\n\n\t\t\t\t// Display queue content upon first mismatch (Requirement 1.1)\n\t\t\t\tif (total_mismatches == 1) begin\n\t\t\t\t\t$display("==================================================================");\n\t\t\t\t\t$display("!!! MISMATCH DETECTED AT TIME %0t !!!", $time);\n\t\t\t\t\t$display("Last %0d cycles of simulation (Queue Size):", input_queue.size());\n\t\t\t\t\t$display("==================================================================");\n\t\t\t\t\t\n\t\t\t\t\tfor (int i = 0; i < input_queue.size(); i++) begin\n\t\t\t\t\t\t// Check if this specific cycle was the mismatch cycle\n\t\t\t\t\t\tif (got_output_queue[i] !== golden_queue[i]) begin\n\t\t\t\t\t\t\t$display("--> MISMATCH CYCLE: Cycle %0d, reset %b, input %b, got output %b, exp output %b",\n\t\t\t\t\t\t\ti,\n\t\t\t\t\t\t\treset_queue[i],\n\t\t\t\t\t\t\tin_queue[i],\n\t\t\t\t\t\t\tgot_output_queue[i],\n\t\t\t\t\t\t\tgolden_queue[i]);\n\t\t\t\t\t\tend else begin\n\t\t\t\t\t\t\t$display("Match at: Cycle %0d, reset %b, input %b, got output %b, exp output %b",\n\t\t\t\t\t\t\ti,\n\t\t\t\t\t\t\treset_queue[i],\n\t\t\t\t\t\t\tin_queue[i],\n\t\t\t\t\t\t\tgot_output_queue[i],\n\t\t\t\t\t\t\tgolden_queue[i]);\n\t\t\t\t\t\tend\n\t\t\t\t\tend\n\t\t\t\t\t$display("==================================================================");\n\t\t\t\tend\n\t\t\tend\n\t\tend\n\n\t// --- Final Status Reporting ---\n\tfinal begin\n\t\tif (total_mismatches > 0) begin\n\t\t\t$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", total_mismatches, first_mismatch_time);\n\t\t\t// Maintain original hint style output if possible, otherwise use new detailed format\n\t\t\tif (stats1.errors_out > 0) begin\n\t\t\t\ts$display("Hint: Output \'