al begin\n\t\trepeat(100) @(posedge clk, negedge clk) begin\n\t\t\tin <= $random;\n\t\tstate <= $random;\n\t\tend\n\t\t#1 $finish;\n\tend\n\tendmodule\n\nmodule tb();\n\n\ttypedef struct packed {\n\t\tint errors;\n\t\tint errortime;\n\t\tint errors_next_state;\n\t\tint errortime_next_state;\n\t\tint errors_out;\n\t\tint errortime_out;\n\t\tint clocks;\n\t} stats;\n\t\n\tstats stats1;\n\t\n\t// --- Queue Definitions for Mismatch Tracking ---\n\t// State width is 2 bits. Max queue size set to 10 as per constraints.\n\t\t// Queue elements track: in, state, next_state_dut, out_dut, next_state_ref, out_ref\n\t\treg [1:0] input_state_queue [$]; // Tracks current state input\n\t\treg [1:0] input_data_queue [$];  // Tracks input 'in'\n\t\treg [1:0] got_next_state_queue [$];\n\t\treg [1:0] got_out_queue [$];\n\t\treg [1:0] golden_next_state_queue [$];\n\t\treg [1:0] golden_out_queue [$];\n\t\t\n\tlocalparam MAX_QUEUE_SIZE = 10;\n\n\t// --- Clocking and Signals ---\n\treg clk=0;\n\tinitial forever\n\t\t#5 clk = ~clk;\n\n\tlogic in;\n\tlogic [1:0] state;\n\tlogic [1:0] next_state_ref;\n\tlogic [1:0] next_state_dut;\n\tlogic out_ref;\n\tlogic out_dut;\n\n\t// Wave dumping setup\n\tinitial begin \n\t\t$dumpfile(\"wave.vcd\");\n\t\t$dumpvars(1, tb);\n\tend\n\n\twire tb_match;\n\twire tb_mismatch = ~tb_match;\n\t\n\t// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.\n\tassign tb_match = ( { next_state_ref, out_ref } === ( { next_state_dut, out_dut } ) );\n\n\t// --- Module Instantiations ---\n\tstimulus_gen stim1 (\n\t\t.clk, \n\t\t.in, \n\t\t.state \n\t);\n\t\t\n\tRefModule good1 (\n\t\t.in, \n\t\t.state,\n\t\t.next_state(next_state_ref),\n\t\t.out(out_ref) \n\t);\n\t\t\n\tTopModule top_module1 (\n\t\t.in,\n\t\t.state,\n\t\t.next_state(next_state_dut),\n\t\t.out(out_dut) \n\t);\n\n\tbit strobe = 0;\n\ttask wait_for_end_of_timestep;\n\tbegin\n\t\trepeat(5) begin\n\t\tstrobe <= !strobe;  // Try to delay until the very end of the time step.\n\t\t@(strobe);\n\t\tend\n\tendtask\n\n\t// State tracking and Mismatch detection logic\n\talways @(posedge clk, negedge clk) begin\n\t\tstats1.clocks++;\n\t\t\n\t\t// --- Queue Management: Dequeue oldest elements if full ---\n\t\tif (input_state_queue.size() >= MAX_QUEUE_SIZE) begin\n\t\t\tinput_state_queue.delete(0);\n\t\t\tinput_data_queue.delete(0);\n\t\t\tgot_next_state_queue.delete(0);\n\t\t\tgot_out_queue.delete(0);\n\t\t\tgolden_next_state_queue.delete(0);\n\t\t\tgolden_out_queue.delete(0);\n\t\t\tend\n\t\t\n\t\t// --- Push current cycle data ---\n\t\tinput_state_queue.push_back(state);\n\t\tinput_data_queue.push_back(in);\n\t\tgot_next_state_queue.push_back(next_state_dut);\n\t\tgot_out_queue.push_back(out_dut);\n\t\tgolden_next_state_queue.push_back(next_state_ref);\n\t\tgolden_out_queue.push_back(out_ref);\n\n\t\t// --- Mismatch Detection and First Error Logging ---\n\t\tif (!tb_match) begin\n\t\t\tif (stats1.errors == 0) begin\n\t\t\t\tstats1.errortime = $time;\n\t\t\t\t$display(\"\\n======================================================================\");\n\t\t\t\t$display(\"!!! FIRST MISMATCH DETECTED AT TIME %0t !!!\", $time);\n\t\t\t\t$display(\"\\nLast %d cycles of simulation before/at mismatch:\", input_state_queue.size());\n\t\t\t\n\t\t\t\tfor (int i = 0; i < input_state_queue.size(); i++) begin\n\t\t\t\t\t// Check if this specific cycle is the mismatch cycle (i == input_state_queue.size() - 1)\n\t\t\t\t\t// We display the full history up to the mismatch point.\n\t\t\t\t\t\n\t\t\t\t\t$display(\"Cycle %d (Time %0t): \", i, $time - (input_state_queue.size() - 1) * 10);\n\t\t\t\t\t$display(\"  State: %h | Input: %b\", input_state_queue[i], input_data_queue[i]);\n\t\t\t\t\t$display(\"  DUT Output: NextState=%h, Out=%b\", got_next_state_queue[i], got_out_queue[i]);\n\t\t\t\t\t$display(\"  GOLDEN Output: NextState=%h, Out=%b\", golden_next_state_queue[i], golden_out_queue[i]);\n\t\t\t\t\t\n\t\t\t\t\t// Detailed mismatch status for the cycle\n\t\t\t\t\tif (got_next_state_queue[i] !== golden_next_state_queue[i] || got_out_queue[i] !== golden_out_queue[i]) begin\n\t\t\t\t\t\t$display(\"  *** MISMATCH DETECTED IN THIS CYCLE ***\");\n\t\t\t\t\tend\n\t\t\t\t}\n\t\t\t\t$display(\"======================================================================\\n\");\n\t\t\tend\n\t\t\t\n\t\t\tstats1.errors++;\n\t\tend\n\t\t\n\t\t// Original error counting logic preserved for backward compatibility\n\t\tif (next_state_ref !== next_state_dut) begin \n\t\t\tif (stats1.errors_next_state == 0) stats1.errortime_next_state = $time; \n\t\t\tstats1.errors_next_state = stats1.errors_next_state + 1'b1; \n\t\tend\n\t\tif (out_ref !== out_dut) begin \n\t\t\tif (stats1.errors_out == 0) stats1.errortime_out = $time; \n\t\t\tstats1.errors_out = stats1.errors_out + 1'b1; \n\t\tend\n\tend\n\n   // add timeout after 100K cycles\n   initial begin\n     #1000000\n     if (stats1.errors == 0) begin\n        $display(\"SIMULATION PASSED\");\n     end else begin\n        $display(\"SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d\", stats1.errors, stats1.errortime);\n     end\n     $finish();\n   end\n\nendmodule"
