// --- TOP MODULE IMPLEMENTATION (DUT) --- 
module TopModule (
    input logic in,
    input logic [1:0] state,
    output logic [1:0] next_state,
    output logic out
);
	
	// State Definitions (A=00, B=01, C=10, D=11)
	localparam [1:0] STATE_A = 2'b00;
	localparam [1:0] STATE_B = 2'b01;
	localparam [1:0] STATE_C = 2'b10;
	localparam [1:0] STATE_D = 2'b11;

	// Combinational Logic Implementation
	always_comb begin
		// Default assignments to prevent latches
		next_state = state;
		out = 0;

		case (state) 
			STATE_A:
			if (in == 1'b0) begin
				next_state = STATE_A;
				out = 0;
			end else begin // in == 1'b1
				next_state = STATE_B;
				out = 0;
			end
			
			STATE_B:
			if (in == 1'b0) begin
				next_state = STATE_C;
				out = 0;
			end else begin // in == 1'b1
				next_state = STATE_B;
			out = 0;
			end
			
			STATE_C:
			if (in == 1'b0) begin
				next_state = STATE_A;
				out = 0;
			end else begin // in == 1'b1
				next_state = STATE_D;
			out = 0;
			end
			
			STATE_D:
			if (in == 1'b0) begin
				next_state = STATE_C;
				out = 1;
			end else begin // in == 1'b1
				next_state = STATE_B;
			out = 1;
			end
			
			default: begin
				next_state = STATE_A;
				out = 0;
			end
			
			endcase
	end
	endmodule
