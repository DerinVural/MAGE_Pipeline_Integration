module stimulus_gen (
	input clk,
	output reg load,
	output reg[511:0] data,
	output reg[511:0] wavedrom_title,
	output reg wavedrom_enable
);

	// Add two ports to module stimulus_gen:
	//    output [511:0] wavedrom_title
	//    output reg wavedrom_enable

	task wavedrom_start(input[511:0] title = "");
	endtask
	
	task wavedrom_stop;
		#1;
	endtask	

	initial begin
		data <= 0;
		data[0] <= 1'b1;
		load <= 1;
		@(posedge clk); wavedrom_start("Sierpi&#324;ski triangle: See Hint.");
		@(posedge clk);
		@(posedge clk);
		load <= 0;
		repeat(10) @(posedge clk);	
		wavedrom_stop();

		data <= 0;
		data[256] <= 1'b1;
		load <= 1;
		@(posedge clk);
		@(posedge clk);
		@(posedge clk);
		load <= 0;
		repeat(1000) @(posedge clk) begin
		end
		data <= 512'h1000000000000001;
		load <= 1;
		@(posedge clk);
		load <= 0;
		repeat(1000) @(posedge clk) begin
		end

		data <= $random;
		load <= 1;
		@(posedge clk);
		load <= 0;
		repeat(1000) @(posedge clk) begin
		end

		data <= 0;
		load <= 1;
		repeat(20) @(posedge clk);
		repeat(2) @(posedge clk) data <= data + 2;
		@(posedge clk) begin 
			load <= 0;
			data <= data + 1;
		end
		repeat(20) @(posedge clk) data <= data + 1;
		repeat(500) @(posedge clk) begin
		end

		#1 $finish;
	end
	
endmodule

module tb();

	// Queue-based simulation mismatch display setup
	reg [511:0] input_queue [$];
	reg [511:0] got_output_queue [$];
	reg [511:0] golden_queue [$];
	reg reset_queue [$]; // Reusing queue for control/state tracking if needed

	localparam MAX_QUEUE_SIZE = 10; // Controlled size as per requirement

	// Statistics tracking (retaining original structure while enhancing reporting)
	typedef struct packed {
		int errors;
		int errortime;
		int errors_q; // Tracks errors based on the specific comparison in the original TB
		int errortime_q;
		int clocks;
	} stats;
	
	stats stats1;
	
	// Waveform dumping signals
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic load;
	logic [511:0] data;
	logic [511:0] q_ref;
	logic [511:0] q_dut;

	wire tb_match;
	wire tb_mismatch = ~tb_match;

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,clk,load,data,q_ref,q_dut );
	end

	// Instantiate stimulus generator
	stimulus_gen stim1 (
		.clk, 
		.load, 
		.data, 
		.wavedrom_title, 
		.wavedrom_enable
	);

	// Instantiate Reference Module	
	RefModule good1 (
		.clk, 
		.load, 
		.data, 
		.q(q_ref) );
	
	// Instantiate DUT
	TopModule top_module1 (
		.clk, 
		.load, 
		.data, 
		.q(q_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end
	endtask	

	// --- Mismatch Detection and Queueing Logic ---
	always @(posedge clk, negedge clk) begin
		// 1. Advance queues
		if (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin
			input_queue.delete(0);
			got_output_queue.delete(0);
			golden_queue.delete(0);
			reset_queue.delete(0);
		end

		// Store current values (using tb_mismatch as the error indicator)
		input_queue.push_back(data);
		got_output_queue.push_back(q_dut);
		golden_queue.push_back(q_ref);
		reset_queue.push_back(load); // Using load as a proxy for control/reset state

		// 2. Check for first mismatch
		if (tb_mismatch) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
			end
		
		// Logic from original TB to track errors_q
		if (q_ref !== ( q_ref ^ q_dut ^ q_ref ))
		begin 
			if (stats1.errors_q == 0) stats1.errortime_q = $time;
			stats1.errors_q = stats1.errors_q+1'b1; 
		end
		
		// Display queue content upon first mismatch (using tb_mismatch as trigger)
		if (stats1.errors == 1) begin
			s$display("============================================================");
			s$display("Mismatch detected at time %0t (First failure based on tb_mismatch)", $time);
			s$display("\nLast %0d cycles of simulation (Capturing context around first error):
", input_queue.size());

			for (int i = 0; i < input_queue.size(); i++) begin
				// Check if the *current* state in the queue matches
				if (got_output_queue[i] === golden_queue[i]) begin
					s$display("Cycle %0d: Match OK.", i);
				end else begin
					s$display("Cycle %0d: *** MISMATCH DETECTED ***", i);
				end
				
				// Display signals in HEX and BINARY if <= 64 bits
				$display("Cycle %0d, Control/Load: %b, Input Data: %h (%b), Got Q: %h (%b), Exp Q: %h (%b)",
				i,
				reset_queue[i],
				input_queue[i],
				input_queue[i].size() <= 64 ? input_queue[i] : "",
				got_output_queue[i],
				got_output_queue[i].size() <= 64 ? got_output_queue[i] : "",
				golden_queue[i],
				golden_queue[i].size() <= 64 ? golden_queue[i] : "");
			end
			end
			$display("============================================================");
			end
		
		// Keep original error counters updated for final summary
		stats1.clocks++;
		
		// The original TB logic for errors_q is maintained here:
		if (q_ref !== ( q_ref ^ q_dut ^ q_ref ))
		begin if (stats1.errors_q == 0) stats1.errortime_q = $time;
			s$display("Queue check mismatch at %0t", $time);
			sstats1.errors_q = stats1.errors_q+1'b1; 
		end
		
	end

	// Timeout
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

	// Final Summary Block (Replaced original final block)
	initial begin
		@(negedge clk); // Wait for a stable point after simulation runs
		#10; // Small delay to ensure last events finish

		int total_mismatches = stats1.errors;
		int total_samples = stats1.clocks;
		int first_mismatch_time = stats1.errortime;

		if (total_mismatches == 0) begin
			s$display("SIMULATION PASSED");
		end else begin
			s$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", total_mismatches, first_mismatch_time);
		end
		$finish();
	end

endmodule

