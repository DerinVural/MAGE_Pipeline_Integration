        $display("  load: %b", load_val);
        $display("  data (HEX): %h", data_val);
        $display("  data (BIN - First 64 bits): %b", data_val[63:0]);
        $display("---------------------------------------------------------------");
        $display("OUTPUTS:");
        $display("  Expected q_ref (HEX): %h", q_ref_val);
        $display("  DUT q_dut (HEX): %h", q_dut_val);
