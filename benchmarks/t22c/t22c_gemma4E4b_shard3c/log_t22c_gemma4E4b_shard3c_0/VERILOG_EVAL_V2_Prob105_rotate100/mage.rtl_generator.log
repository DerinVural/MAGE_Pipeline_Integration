oad, .ena, .data, .q(q_dut) );\n\n\t\t// Task wait_for_end_of_timestep (Kept from original)\n\t\tbit strobe = 0;\n\t\ttask wait_for_end_oftimestep;\n\t\t\trepeat(5) begin\n\t\t\tstrobe <= !strobe;  // Try to delay until the very end of the time step.\n\t\t\t@(strobe);\n\t\t\tend\n\t\tendtask\n\n\t\t// Synchronous Verification and Queue Management\n\t\talways @(posedge clk, negedge clk) begin\n\t\t\tstats1.clocks++;\n\n\t\t\t// 1. Queue Management (FIFO behavior)\n\t\t\tif (input_data_q.size() >= MAX_QUEUE_SIZE - 1) begin\n\t\t\t\tinput_data_q.delete(0);\n\t\t\t\tgot_output_q.delete(0);\n\t\t\t\tgolden_output_q.delete(0);\n\t\t\t\tena_q.delete(0);\n\t\t\t\tload_q.delete(0);\n\t\t\t\tdata_q.delete(0);\n\t\t\tend\n\n\t\t\t// 2. Push current values into queues (Snapshot at posedge clk)\n\t\t\tinput_data_q.push_back(data);\n\t\t\tena_q.push_back(ena);\n\t\t\tload_q.push_back(load);\n\t\t\tdata_q.push_back(data);\n\t\t\tgot_output_q.push_back(q_dut);\n\t\t\tgolden_output_q.push_back(q_ref);\n\n\t\t\t// 3. Check for first mismatch and log (Requirement 1.1, 1.3)\n\t\t\tif (!tb_match) begin\n\t\t\t\tif (stats1.errors == 0) stats1.errortime = $time;\n\t\t\t\tstats1.errors++;\n\t\t\t\t\n\t\t\t\t$display("========================================================");\n\t\t\t\t$display("!!! FIRST MISMATCH DETECTED AT TIME %0t !!!", $time);\n\t\t\t\t$display("Last %0d cycles of simulation recorded:", input_data_q.size());\n\t\t\t\t\n\t\t\t\tfor (int i = 0; i < input_data_q.size(); i++) begin\n\t\t\t\t\t// Check mismatch status for this logged cycle\n\t\t\t\t\tif (golden_output_q[i] === got_output_q[i]) begin\n\t\t\t\t\t\t$display("Cycle %0d: Got Match.", i);\n\t\t\t\t\t\tend\n\t\t\t\t\telse begin\n\t\t\t\t\t\t$display("Cycle %0d: Got Mismatch.", i);\n\t\t\t\t\t\tend\n\t\t\t\t\tend\n\t\t\t\t\t// Display data as required (HEX only for 100 bits)\n\t\t\t\t\t$display("  Cycle %0d | Load: %b | ENA: %b | Data: %h | Got Q: %h | Exp Q: %h",\n\t\t\t\t\ti, \n\t\t\t\t\tload_q[i], ena_q[i], data_q[i], got_output_q[i], golden_output_q[i]);\n\t\t\t\tend\n\t\t\t\tend\n\t\t\tend\n\t\tend\n\n\t\t// Timeout mechanism (Kept from original)\n\t\tinitial begin\n\t\t\t#1000000\n\t\t\t$display("TIMEOUT");\n\t\t\tend\n\n\t\t// Final Reporting (Replaced original final block based on new requirements)\n\t\tinitial begin\n\t\t\t@(posedge clk);\n\t\t\t@(posedge clk);\n\t\t\t@(posedge clk);\n\t\t\t// Wait a bit longer to ensure all sampling is complete before final report\n\t\t\t#10000; \n\t\t\t\n\t\t\tif (stats1.errors == 0)\n\t\t\t\t$display("========================================================");\n\t\t\t\t$display("SIMULATION PASSED");\n\t\t\t\t$display("========================================================");\n\t\t\telse\n\t\t\t\t$display("========================================================");\n\t\t\t\t$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0t", stats1.errors, stats1.errortime);\n\t\t\t\t$display("========================================================");\n\t\t\tend\n\n\tendmodule\n</testbench>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nThe module interface is given below:\n<module_interface>\nmodule TopModule(\n    input clk,\n    input load,\n    input [1:0] ena,\n    input [99:0] data,\n    output [99:0] q\n);\nendmodule\n</module_interface>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nYour response will be processed by a program, not human.\nSo, please STRICTLY FOLLOW the output format given as XML tag content below to generate a VALID JSON OBJECT:\n<output_format>\n{\n    "reasoning": "All reasoning steps and advices to avoid syntax error",\n    "module": "Pure SystemVerilog code, a complete module"\n}\n</output_format>\nDO NOT include any other information in your response, like \'json\', \'reasoning\' or \'<output_format>\'.\n\nOther requirements:\n1. Don\'t use state_t to