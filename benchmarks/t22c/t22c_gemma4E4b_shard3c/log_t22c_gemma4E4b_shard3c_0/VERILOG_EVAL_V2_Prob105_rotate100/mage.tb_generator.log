from original)\n\t\tRefModule good1 (\n\t\t\t.clk, .load, .ena, .data, .q(q_ref) );\n\t\t\n\t\tTopModule top_module1 (\n\t\t\t.clk, .load, .ena, .data, .q(q_dut) );\n\n\t\t// Task wait_for_end_of_timestep (Kept from original)\n\t\tbit strobe = 0;\n\t\ttask wait_for_end_oftimestep;\n\t\t\trepeat(5) begin\n\t\t\tstrobe <= !strobe;  // Try to delay until the very end of the time step.\n\t\t\t@(strobe);\n\t\t\tend\n\t\tendtask\n\n\t\t// Synchronous Verification and Queue Management\n\t\talways @(posedge clk, negedge clk) begin\n\t\t\tstats1.clocks++;\n\n\t\t\t// 1. Queue Management (FIFO behavior)\n\t\t\tif (input_data_q.size() >= MAX_QUEUE_SIZE - 1) begin\n\t\t\t\tinput_data_q.delete(0);\n\t\t\t\tgot_output_q.delete(0);\n\t\t\t\tgolden_output_q.delete(0);\n\t\t\t\tena_q.delete(0);\n\t\t\t\tload_q.delete(0);\n\t\t\t\tdata_q.delete(0);\n\t\t\tend\n\n\t\t\t// 2. Push current values into queues\n\t\t\tinput_data_q.push_back(data);\n\t\t\tena_q.push_back(ena);\n\t\t\tload_q.push_back(load);\n\t\t\tdata_q.push_back(data);\n\t\t\tgot_output_q.push_back(q_dut);\n\t\t\tgolden_output_q.push_back(q_ref);\n\n\t\t\t// 3. Check for first mismatch and log (Requirement 1.1, 1.3)\n\t\t\tif (!tb_match) begin\n\t\t\t\tif (stats1.errors == 0) stats1.errortime = $time;\n\t\t\t\tstats1.errors++;\n\t\t\t\t\n\t\t\t\t$display(\"========================================================\");\n\t\t\t\t$display(\"!!! FIRST MISMATCH DETECTED AT TIME %0t !!!\", $time);\n\t\t\t\t$display(\"Last %0d cycles of simulation recorded:\", input_data_q.size());\n\t\t\t\t\n\t\t\t\tfor (int i = 0; i < input_data_q.size(); i++) begin\n\t\t\t\t\t// Check mismatch status for this logged cycle\n\t\t\t\t\t// Note: We re-evaluate the match status for logging clarity.\n\t\t\t\t\t// Since the mismatch happened on the current clock edge, the state i-1 was correct, and i is incorrect.\n\t\t\t\t\tif (golden_output_q[i] === got_output_q[i]) begin\n\t\t\t\t\t\t$display(\"Cycle %0d: Match Confirmed.\", i);\n\t\t\t\t\t\t// Sin