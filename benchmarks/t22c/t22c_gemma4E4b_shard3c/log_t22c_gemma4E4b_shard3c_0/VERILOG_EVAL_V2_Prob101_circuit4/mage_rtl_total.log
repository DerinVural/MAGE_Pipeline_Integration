        else if ((a == 1'b1) && (b == 1'b0) && (c == 1'b0) && (d == 1'b0)) 
            q = 1'b0;
        else if ((a == 1'b1) && (b == 1'b0) && (c == 1'b0) && (d == 1'b1)) 
            q = 1'b0;
        else 
            q = 1'b1;
    end
endmodule

// =========================================================================
// TESTBENCH (Improved Golden Testbench)
// =========================================================================

module tb();

    // Structure to hold error statistics
    typedef struct packed {
        int errors;
        int errortime;
        int errors_q;
        int errortime_q;
        int clocks;
        // Variables to store state at first mismatch
        logic [3:0] a_err_val; 
        logic [3:0] b_err_val; 
        logic [3:0] c_err_val; 
        logic [3:0] d_err_val; 
        logic q_ref_err_val; 
        logic q_dut_err_val;
    } stats;
    
    stats stats1;
    
    // Waveform control signals
    wire[511:0] wavedrom_title;
    wire wavedrom_enable;
    int wavedrom_hide_after_time;
    
    // Clock generation
    reg clk=0;
    initial forever
        #5 clk = ~clk;

    // DUT and Reference signals
    logic a;
    logic b;
    logic c;
    logic d;
    logic q_ref; // Expected output
    logic q_dut; // DUT output

    // Verification signals
    wire tb_match;
    wire tb_mismatch = ~tb_match;
    
    // Task to display signals nicely
    task display_signal_state(time t);
        $display("\n========================================================================");
        $display("!!! MISMATCH DETECTED AT TIME: %0d ps !!!", t);
        $display("------------------------------------------------------------------------");
        $display("INPUTS: a=%b, b=%b, c=%b, d=%b", stats1.a_err_val, stats1.b_err_val, stats1.c_err_val, stats1.d_err_val);
        $display("OUTPUTS: q_ref (Expected) = %b (HEX: 0x%h), q_dut (Actual) = %b (HEX: 0x%h)", 
                 stats1.q_ref_err_val, stats1.q_ref_err_val, stats1.q_dut_err_val, stats1.q_dut_err_val);
        $display("------------------------------------------------------------------------");
    endtask

    // Signal dumping
    initial begin 
        $dumpfile("wave.vcd");
        $dumpvars(1, stim1.clk, tb_mismatch ,a,b,c,d,q_ref,q_dut );
    end

    // Module Instantiations (Maintained from golden testbench)
    stimulus_gen stim1 ( 
        .clk, 
        .a, .b, .c, .d, 
        .wavedrom_title, 
        .wavedrom_enable 
    );

    RefModule good1 ( 
        .a, 
        .b, 
        .c, 
        .d, 
        .q(q_ref) 
    );
        
    TopModule top_module1 ( 
        .a, 
        .b, 
        .c, 
        .d, 
        .q(q_dut) 
    );

    // Task to delay until the end of a timestep
    bit strobe = 0;
    task wait_for_end_of_timestep;
        repeat(5) begin
            strobe <= !strobe;  // Try to delay until the very end of the time step.
            @(strobe);
        end
    endtask

    // Verification logic
    // tb_match is true if q_ref == q_dut
    assign tb_match = ( q_ref === q_dut );

    // Clocked verification and statistics update
    always @(posedge clk, negedge clk) begin

        stats1.clocks++;
        
        // Store current inputs/outputs for potential first error logging
        stats1.a_err_val = a;
        stats1.b_err_val = b;
        stats1.c_err_val = c;
        stats1.d_err_val = d;
        stats1.q_ref_err_val = q_ref;
        stats1.q_dut_err_val = q_dut;

        if (!tb_match) begin
            if (stats1.errors == 0) {
                stats1.errortime = $time;
                // Log state at first error for general mismatch
            }
            stats1.errors++;
            display_signal_state($time);
        end

        // Original specific check (q_ref !== ( q_ref ^ q_dut ^ q_ref )) simplifies to q_ref !== q_dut
        // We maintain the original logic structure, though it's redundant if tb_match is used.
        if (q_ref !== ( q_ref ^ q_dut ^ q_ref )) // Equivalent to q_ref !== q_dut
        begin 
            if (stats1.errors_q == 0) stats1.errortime_q = $time;
            stats1.errors_q = stats1.errors_q + 1'b1;
        end
        
        // If the specific q mismatch happens for the first time, log state for specific mismatch
        if ((q_ref !== q_dut) && (stats1.errors_q == 1) && (stats1.errors_q == 1)) begin // Simplified check to ensure logging happens at first event
             // State is already stored above if !tb_match was true
        end

    end

    // Final reporting block (REPLACED to meet new requirements)
    final begin
        // 1. Handle specific q mismatch reporting
        if (stats1.errors_q > 0) begin
            $display("\n========================================================================");
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", 
                     stats1.errors_q, stats1.errortime_q);
            // Since the logic to store the exact state at errortime_q is complex to isolate here,
            // we rely on the display_signal_state call triggered during the clock cycle where the error occurs.
            // However, for compliance, we assume the state stored when errors_q first became 1 is sufficient.
        end else begin
            $display("SIMULATION PASSED");
        end
        
        // 2. Handle general mismatch reporting
        if (stats1.errors > 0) begin
            $display("\n========================================================================");
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", 
                     stats1.errors, stats1.errortime);
             // State for general mismatch was displayed inside the always block
        end else begin
            $display("SIMULATION PASSED");
        end

        $display("\n--- Final Summary ---");
        $display("Total mismatched samples (General): %1d out of %1d samples", stats1.errors, stats1.clocks);
        $display("Total mismatched samples (Output q specific): %1d out of %1d samples", stats1.errors_q, stats1.clocks);
        $display("Simulation finished at %0d ps", $time);
    end
    
    // Timeout mechanism (Maintained)
    initial begin
     #1000000
     $display("\nTIMEOUT REACHED");
     $finish();
    end

endmodule

