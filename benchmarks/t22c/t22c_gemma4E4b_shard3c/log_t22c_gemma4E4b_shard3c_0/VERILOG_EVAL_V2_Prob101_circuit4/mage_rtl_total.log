module TopModule (
    input a,
    input b,
    input c,
    input d,
    output q
);
    // Truth table derived from simulation: q=0 if (0000, 0001, 1000, 1001), else q=1
    always_comb begin
        if ((a == 1'b0) && (b == 1'b0) && (c == 1'b0) && (d == 1'b0)) 
            q = 1'b0;
        else if ((a == 1'b0) && (b == 1'b0) && (c == 1'b0) && (d == 1'b1)) 
