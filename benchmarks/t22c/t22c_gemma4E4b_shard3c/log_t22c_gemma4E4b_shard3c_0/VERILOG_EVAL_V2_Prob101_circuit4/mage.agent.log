        if ((a == 1'b0) && (b == 1'b0) && (c == 1'b0) && (d == 1'b0)) 
            q = 1'b0;
        else if ((a == 1'b0) && (b == 1'b0) && (c == 1'b0) && (d == 1'b1)) 
            q = 1'b0;
        else if ((a == 1'b1) && (b == 1'b0) && (c == 1'b0) && (d == 1'b0)) 
            q = 1'b0;
        else if ((a == 1'b1) && (b == 1'b0) && (c == 1'b0) && (d == 1'b1)) 
            q = 1'b0;
        else 
            q = 1'b1;
    end
