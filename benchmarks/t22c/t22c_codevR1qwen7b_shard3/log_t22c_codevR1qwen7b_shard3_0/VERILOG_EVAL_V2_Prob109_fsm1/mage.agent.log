module tb;
  reg clk = 0;
  reg areset;
  reg in;
  wire out;

  // Queue variables
  localparam MAX_QUEUE_SIZE = 8;
  reg [0:0] input_queue [0:MAX_QUEUE_SIZE-1]; // Assuming 1-bit inputs
  reg [0:0] got_output_queue [0:MAX_QUEUE_SIZE-1];
  reg [0:0] golden_queue [0:MAX_QUEUE_SIZE-1];
  reg reset_queue [0:MAX_QUEUE_SIZE-1];
  integer queue_ptr = 0;

  // Instantiate DUT
  TopModule dut (.clk(clk), .areset(areset), .in(in), .out(out));

  // Reference signals
  reg golden_out;
  // ... (reference model logic omitted for brevity)

  // Clock generation
  always #5 clk = ~clk;

  // Stimulus
  initial begin
    areset = 1;
    in = 0;
    #10 areset = 0;
    // ... Stimulus sequence
  end

  // Mismatch detection
  always @(posedge clk, negedge clk) begin
    // Push to queue
    input_queue[queue_ptr] = in;
    reset_queue[queue_ptr] = areset;
    golden_queue[queue_ptr] = golden_out;
    got_output_queue[queue_ptr] = out;

    if (out !== golden_out) begin
      if (stats1.errors == 0) begin
        $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors + 1, $time);
        display_queue();
      end
      stats1.errors = stats1.errors + 1;
    end
  end

  // Display function
  task display_queue;
  begin
    $display("%0t: Simulation failed", $time);
    for (int i = 0; i < queue_ptr; i++) begin
      $display("Cycle %0d: reset=%b, in=%b, got=%b, exp=%b", i, reset_queue[i], input_queue[i], got_output_queue[i], golden_queue[i]);
    end
  end
  endtask

  // Simulation end
  always begin
    #100000 $display("SIMULATION PASSED");
    #10 $finish;
  end
endmodule
