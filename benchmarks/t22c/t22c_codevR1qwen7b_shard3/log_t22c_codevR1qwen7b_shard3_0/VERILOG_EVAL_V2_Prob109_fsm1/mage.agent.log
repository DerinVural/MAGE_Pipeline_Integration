    end
    initial begin
        #1000000;
        $display((stats1.errors_out > 0) ? "SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d" : "SIMULATION PASSED", stats1.errors_out, stats1.errortime_out);
        $finish;
    end
endmodule
