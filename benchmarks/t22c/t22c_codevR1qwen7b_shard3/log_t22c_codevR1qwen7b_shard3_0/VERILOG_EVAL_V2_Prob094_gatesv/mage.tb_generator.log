rors ? 0 : 2;\n\t\tdisplay_error = errors;\n\t\tif (errors_both) begin\n\t\t\t$display(\"SIMULATION FAILED - %0d MISMATCHES IN out_both AT %0d\", errors_both, errors_both);\n\t\t\t$display(\"First error at time %0d\", errors_both);\n\t\t\t$display(\"Input: %h %h %h %h\", in[3], in[2], in[1], in[0]);\n\t\t\t$display(\"out_both_ref: %h, out_both_dut: %h\", out_both_ref, out_both_dut);\n\t\tend else if (errors_any) begin\n\t\t\t$display(\"SIMULATION FAILED - %0d MISMATCHES IN out_any AT %0d\", errors_any, errors_any);\n\t\t\t$display(\"First error at time %0d\", errors_any);\n\t\t\t$display(\"Input: %h %h %h %h\", in[3], in[2], in[1], in[0]);\n\t\t\t$display(\"out_any_ref: %h, out_any_dut: %h\", out_any_ref, out_any_dut);\n\t\tend else if (errors_diff) begin\n\t\t\t$display(\"SIMULATION FAILED - %0d MISMATCHES IN out_different AT %0d\", errors_diff, errors_diff);\n\t\t\t$display(\"First error at time %0d\", errors_diff);\n\t\t\t$display(\"Input: %h %h %h %h\", in[3], in[2], in[1], in[0]);\n\t\t\t$display(\"out_different_ref: %h, out_different_dut: %h\", out_different_ref, out_different_dut);\n\t\tend else begin\n\t\t\t$display(\"SIMULATION PASSED\");\n\t\tend\n\tend\nendmodule"
