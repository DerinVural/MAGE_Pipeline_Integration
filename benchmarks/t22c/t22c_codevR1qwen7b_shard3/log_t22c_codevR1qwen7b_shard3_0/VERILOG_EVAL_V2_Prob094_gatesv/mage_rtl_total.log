[2026-05-14 11:41:22,929 - mage.agent - INFO] `timescale 1ps/1ps
module tb();
	display_error = 0;
	time_of_error = -1;
	time_of_first = -1;
	score = 0;

	reg clk = 0;
	initial begin
		forever #(5) clk = ~clk;
	end

	logic [3:0] in;
	logic [3:0] out_both_ref;
	logic [3:0] out_both_dut;
	logic [3:0] out_any_ref;
	logic [3:0] out_any_dut;
	logic [3:0] out_different_ref;
	logic [3:0] out_different_dut;

	RefModule gm(
		.in(in),
		.out_both(out_both_ref),
		.out_any(out_any_ref),
		.out_different(out_different_ref)
	);

	TopModule dut(
		.in(in),
		.out_both(out_both_dut),
		.out_any(out_any_dut),
		.out_different(out_different_dut)
	);

	// Stimulus
	initial begin
		in = 4'h3;
		s@(negedge clk);
		in = 3;
		s@(posedge clk);
		in = 6;
		s@(posedge clk);
		in = 12;
		s@(posedge clk);
		in = 9;
		s@(posedge clk);
		in = 5;
		s@(negedge clk);
		in = $random;
		repeat(100) begin
			s@(negedge clk);
			in = $random;
			s@(posedge clk);
			in = $random;
		end
		#1 $finish;
	end

	// Check correctness
	int errors = 0;
	int errors_both = 0;
	int errors_any = 0;
	int errors_diff = 0;
	int clocks = 0;

	always @(posedge clk, negedge clk) begin
		clocks++;
		if (out_both_dut !== out_both_ref) begin
			if (errors_both == 0) errors_both = $time;
			errors_both++;
			if (errors == 0) errors = $time;
			errors++;
		end
		if (out_any_dut !== out_any_ref) begin
			if (errors_any == 0) errors_any = $time;
			errors_any++;
			if (errors == 0) errors = $time;
			errors++;
		end
		if (out_different_dut !== out_different_ref) begin
			if (errors_diff == 0) errors_diff = $time;
			errors_diff++;
			if (errors == 0) errors = $time;
			errors++;
		end
	end

	// Timeout handling
	initial begin
		#1000000 $display("TIMEOUT"); $finish;
	end

	// Final report
	final begin
		score = errors ? 0 : 2;
		display_error = errors;
		if (errors_both) begin
			$display("SIMULATION FAILED - %0d MISMATCHES IN out_both AT %0d", errors_both, errors_both);
			$display("First error at time %0d", errors_both);
			$display("Input: %h %h %h %h", in[3], in[2], in[1], in[0]);
			$display("out_both_ref: %h, out_both_dut: %h", out_both_ref, out_both_dut);
		end else if (errors_any) begin
			$display("SIMULATION FAILED - %0d MISMATCHES IN out_any AT %0d", errors_any, errors_any);
			$display("First error at time %0d", errors_any);
			$display("Input: %h %h %h %h", in[3], in[2], in[1], in[0]);
			$display("out_any_ref: %h, out_any_dut: %h", out_any_ref, out_any_dut);
		end else if (errors_diff) begin
			$display("SIMULATION FAILED - %0d MISMATCHES IN out_different AT %0d", errors_diff, errors_diff);
			$display("First error at time %0d", errors_diff);
			$display("Input: %h %h %h %h", in[3], in[2], in[1], in[0]);
			$display("out_different_ref: %h, out_different_dut: %h", out_different_ref, out_different_dut);
		end else begin
			$display("SIMULATION PASSED");
		end
	end
endmodule
