	randomize(); 
	reg clk = 0; 
	initial forever #5 clk = ~clk; 
	wire [3:0] in; 
	wire [3:0] out_both; 
	wire [3:0] out_any; 
	wire [3:0] out_different; 
	reg [3:0] in_dut; 
	wire [3:0] golden_out_both; 
	wire [3:0] golden_out_any; 
	wire [3:0] golden_out_different; 
	TopModule dut ( .in(in_dut), .out_both(out_both), .out_any(out_any), .out_different(out_different) ); 
	RefModule golden ( .in(in_dut), .out_both(golden_out_both), .out_any(golden_out_any), .out_different(golden_out_different) ); 
	logic tb_match; 
	logic tb_mismatch; 
	stats stats1; 
	always @(posedge clk, negedge clk) begin 
		stats1.clocks++; 
		if (!(out_both === golden_out_both && out_any === golden_out_any && out_different === golden_out_different)) begin 
			if (stats1.errors == 0) stats1.errortime = $time; 
			stats1.errors++; 
			if (out_both !== golden_out_both) stats1.errors_out_both++; 
			if (out_any !== golden_out_any) stats1.errors_out_any++; 
			if (out_different !== golden_out_different) stats1.errors_out_different++; 
		end 
	end 
	initial begin 
		$dumpfile("wave.vcd"); 
		$dumpvars(0, tb); 
		in_dut = 4'h3; 
		s@(negedge clk); 
		in_dut = 3; 
		s@(posedge clk); 
		in_dut = 6; 
		s@(posedge clk); 
		in_dut = 12; 
		s@(posedge clk); 
		in_dut = 9; 
		s@(posedge clk); 
		in_dut = 5; 
		s@(negedge clk); 
		repeat(100) begin 
			s@(negedge clk); 
			in_dut = $urandom; 
			s@(posedge clk); 
			in_dut = $urandom; 
		end 
		#1 $finish; 
	end 
	initial begin 
		wait(stats1.clocks > 1000000); 
		$display("TIMEOUT"); 
		$finish; 
	end 
	final begin 
		if (stats1.errors_out_both) $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_out_both, stats1.errortime_out_both); 
		else if (stats1.errors_out_any) $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_out_any, stats1.errortime_out_any); 
		else if (stats1.errors_out_different) $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_out_different, stats1.errortime_out_different); 
		else $display("SIMULATION PASSED"); 
	end 
endmodule 

