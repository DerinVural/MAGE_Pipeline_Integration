    wire wavedrom_enable;
    int wavedrom_hide_after_time;
    reg clk = 0;
    initial forever #5 clk = ~clk;

    logic j, k, areset;
    logic out_ref, out_dut;
    wire tb_match = ~({out_ref} === ({out_ref} ^ {out_dut} ^ {out_ref}));
    assign tb_match = ( { out_ref } === ( { out_ref } ^ { out_dut } ^ { out_ref } ) ) ? 1 : 0;

    refmodule good1 (clk, j, k, areset, out_ref);
    TopModule top_module1 (clk, j, k, areset, out_dut);
    wire tb_mismatch = ~tb_match;

    stimulus_gen stim1 (clk, j, k, areset);

    task wait_for_end_of_timestep; repeat(5) begin strobe <= !strobe; @(strobe); end endtask

    initial begin $dumpfile("wave.vcd"); $dumpvars(1, stim1.clk, tb_mismatch, clk, j, k, areset, out_ref, out_dut); end

    always @(posedge clk, negedge clk) begin
        stats1.clocks++;
        if (!tb_match) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
        end
        if (out_ref !== (out_ref ^ out_dut ^ out_ref)) begin
            if (stats1.errors_out == 0) stats1.errortime_out = $time;
            stats1.errors_out++;
        end
    end

    initial begin #1000000 $display("TIMEOUT"); $finish(); end
    final begin
