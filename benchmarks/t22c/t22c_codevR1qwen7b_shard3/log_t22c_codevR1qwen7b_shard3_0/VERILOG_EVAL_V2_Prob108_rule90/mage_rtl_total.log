module tb();
    typedef struct packed { int errors; int errortime; int errors_q; int errortime_q; int clocks; } stats;
    stats stats1 = 0;
    reg clk = 0; always #5 clk = ~clk;
    logic load; logic [511:0] data; logic [511:0] q_ref; logic [511:0] q_dut; logic [511:0] wavedrom_title; logic wavedrom_enable;
    wire tb_match = ( { q_ref } === ( { q_ref } ^ { q_dut } ^ { q_ref } ) );
    assign tb_mismatch = ~tb_match;
    stimulus_gen stim1 ( .clk(clk), .load(load), .data(data), .wavedrom_title(wavedrom_title), .wavedrom_enable(wavedrom_enable) );
    RefModule good1 ( .clk(clk), .load(load), .data(data), .q(q_ref) );
    TopModule top_module1 ( .clk(clk), .load(load), .data(data), .q(q_dut) );
    initial begin $dumpfile("wave.vcd"); $dumpvars(1, stim1.clk, tb_mismatch, clk, load, data, q_ref, q_dut); end
    wire tb_mismatch;
    task display_mismatch;
        begin
            $display("Time %0d: Input load=%b data= %h (binary %b) Expected q_ref= %h (binary %b) DUT q_dut= %h (binary %b)", $time, load, data, data, q_ref, q_ref, q_dut, q_dut);
        end
    endtask
    reg match_reg;
    always @(posedge clk) begin stats1.clocks++; end
    always @(posedge clk) begin
        if (!tb_match) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
            if (stats1.errors == 1) display_mismatch();
        end
        if (q_ref !== ( q_ref ^ q_dut ^ q_ref )) begin
            if (stats1.errors_q == 0) stats1.errortime_q = $time;
            stats1.errors_q++;
        end
    end
    initial begin #1000000 $display("TIMEOUT"); $finish; end
    initial begin
        wait(stim1.stopped); // Wait for simulation to finish naturally
        if (stats1.errors) $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
        else $display("SIMULATION PASSED");
        $finish;
    end
endmodule

