[2026-05-14 12:15:25,950 - mage.agent - INFO] `timescale 1ps/1ps
`define OK 12
`define INCORRECT 13

module stimulus_gen (
    input clk,
    output reg load,
    output reg [511:0] data,
    output reg [511:0] wavedrom_title,
    output reg wavedrom_enable
);

    task wavedrom_start(input [511:0] title = ""); endtask
    task wavedrom_stop; #1; endtask

    initial begin
        data <= 0;
        data[0] <= 1'b1;
        load <= 1;
        @(posedge clk); wavedrom_start("Sierpi\u0144ski triangle: See Hint.");
        @(posedge clk);
        @(posedge clk);
        load <= 0;
        repeat(10) @(posedge clk);
        wavedrom_stop();

        data <= 0;
        data[256] <= 1'b1;
        load <= 1;
        @(posedge clk);
        @(posedge clk);
        @(posedge clk);
        load <= 0;
        repeat(1000) @(posedge clk);

        data <= 512'h1000000000000001;
        load <= 1;
        @(posedge clk);
        load <= 0;
        repeat(1000) @(posedge clk);

        data <= $random;
        load <= 1;
        @(posedge clk);
        load <= 0;
        repeat(1000) @(posedge clk);

        data <= 0;
        load <= 1;
        repeat(20) @(posedge clk);
        repeat(2) @(posedge clk) data <= data + 2;
        @(posedge clk) begin load <= 0; data <= data + 1; end
        repeat(20) @(posedge clk) data <= data + 1;
        repeat(500) @(posedge clk);

        #1 $finish;
    end
endmodule

module tb();
    typedef struct packed {
        int errors;
        int errortime;
        int errors_q;
        int errortime_q;
        int clocks;
    } stats;
    stats stats1 = '{errors:0, errortime:0, errors_q:0, errortime_q:0, clocks:0};

    wire [511:0] q;
    logic load;
    logic [511:0] data;
    logic clk;
    reg [511:0] q_ref;
    reg [511:0] q_dut;
    wire tb_match;

    reg [511:0] input_queue [0:9];
    reg [511:0] got_output_queue [0:9];
    reg [511:0] golden_queue [0:9];
    reg reset_queue [0:9];
    integer queue_size;
    localparam MAX_QUEUE_SIZE = 10;

    initial begin clk = 0; forever #5 clk = ~clk; end

    stimulus_gen stim1 (.clk(clk), .load(load), .data(data), .wavedrom_title(), .wavedrom_enable());
    RefModule good1 (.clk(clk), .load(load), .data(data), .q(q_ref));
    TopModule top_module1 (.clk(clk), .load(load), .data(data), .q(q_dut));

    always @(posedge clk, negedge clk) begin
        if (queue_size >= MAX_QUEUE_SIZE-1) begin
            queue_size = queue_size > 0 ? queue_size -1 : 0;
        end
        if (queue_size < MAX_QUEUE_SIZE) begin
            input_queue[queue_size] = data;
            got_output_queue[queue_size] = q_dut;
            golden_queue[queue_size] = q_ref;
            reset_queue[queue_size] = 0;
            queue_size++;
        end
        if (!tb_match) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
        end
        if (q_dut !== (q_ref ^ q_dut ^ q_ref)) begin
            if (stats1.errors_q == 0) stats1.errortime_q = $time;
            stats1.errors_q++;
        end
        stats1.clocks++;
    end

    always @(posedge clk, negedge clk) begin
        if (!tb_match) begin
            $display("Mismatch detected at time %t", $time);
            $display("\nLast %0d cycles of simulation:", queue_size);
            for (int i=0; i<queue_size; i++) begin
                $display("Cycle %0d, data %h, q_dut %h, q_ref %h", i, input_queue[i], got_output_queue[i], golden_queue[i]);
            end
            #1 $finish;
        end
    end

    initial begin
        $dumpfile("wave.vcd");
        $dumpvars(0, tb);
    end

    initial begin
        #1000000 $display("TIMEOUT"); $finish();
    end

    initial begin
        $finish;
    end
endmodule

// Additional displays
always @(posedge clk, negedge clk) begin
    if (stats1.errors > 0) begin
        $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0t", stats1.errors, stats1.errortime);
    end else begin
        $display("SIMULATION PASSED");
    end
end
