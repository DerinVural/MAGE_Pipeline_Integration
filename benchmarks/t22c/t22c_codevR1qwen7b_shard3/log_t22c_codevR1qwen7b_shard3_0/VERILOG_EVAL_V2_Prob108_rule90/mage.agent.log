module stimulus_gen (input clk, output reg load, output reg [511:0] data, output reg [511:0] wavedrom_title, output reg wavedrom_enable);
    initial begin
        load = 0;
        data = 512'b0;
        wavedrom_title = 512'b0;
        wavedrom_enable = 0;
    end
    initial begin
        data[0] = 1'b1;
        load = 1;
        @(posedge clk);
        @(posedge clk);
        load = 0;
        @(posedge clk);
        @(posedge clk);
    end
endmodule

module RefModule (input clk, input load, input [511:0] data, output [511:0] q);
    // Reference implementation
    reg [511:0] q_reg;
    assign q = q_reg;
    always @(posedge clk) begin
        if (load) begin
            q_reg <= data;
        end else begin
            // Rule 90 logic
            for (int i=0; i<512; i++) begin
                if (i == 0) begin
                    q_reg[i] <= 0 ^ data[i+1];
                end else if (i == 511) begin
                    q_reg[i] <= data[i-1] ^ 0;
                end else begin
                    q_reg[i] <= data[i-1] ^ data[i+1];
                end
            end
        end
    end
endmodule

module TopModule (input clk, input load, input [511:0] data, output [511:0] q);
    reg [511:0] q_reg;
    assign q = q_reg;
    always @(posedge clk) begin
        if (load) begin
            q_reg <= data;
        end else begin
            // Rule 90 logic with boundaries 0
            q_reg[0] <= q_reg[1]; // Next state depends on left (0), current, right (q_reg[1])? Wait original Rule90 is XOR of left and right. Original Rule: XOR of left and right neighbors. The left boundary is 0, current cell's left (which is 0), current cell's right (next cell's left). So each cell's next state is XOR of left and right neighbor. For cell i: left (i-1 if exists, else 0), center (current), right (i+1 if exists, else 0). But the original description says boundaries are 0, so each cell's left and right can be considered. For i=0: left is 0, right is i+1. For i=511: right is 0, left is i-1.
            for (int i=0; i<512; i++) begin
                if (i == 0) begin
                    q_reg[i] <= 0 ^ q_reg[i+1];
                end else if (i == 511) begin
                    q_reg[i] <= q_reg[i-1] ^ 0;
                end else begin
                    q_reg[i] <= q_reg[i-1] ^ q_reg[i+1];
                end
            end
        end
    end
endmodule

