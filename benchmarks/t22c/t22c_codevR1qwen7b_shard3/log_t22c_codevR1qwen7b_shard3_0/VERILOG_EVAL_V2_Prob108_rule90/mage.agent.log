    stats stats1 = '{errors:0, errortime:0, errors_q:0, errortime_q:0, clocks:0};

    wire [511:0] q;
    logic load;
    logic [511:0] data;
    logic clk;
    reg [511:0] q_ref;
    reg [511:0] q_dut;
    wire tb_match;

    reg [511:0] input_queue [0:9];
    reg [511:0] got_output_queue [0:9];
    reg [511:0] golden_queue [0:9];
    reg reset_queue [0:9];
    integer queue_size;
    localparam MAX_QUEUE_SIZE = 10;

    initial begin clk = 0; forever #5 clk = ~clk; end

    stimulus_gen stim1 (.clk(clk), .load(load), .data(data), .wavedrom_title(), .wavedrom_enable());
    RefModule good1 (.clk(clk), .load(load), .data(data), .q(q_ref));
    TopModule top_module1 (.clk(clk), .load(load), .data(data), .q(q_dut));

    always @(posedge clk, negedge clk) begin
        if (queue_size >= MAX_QUEUE_SIZE-1) begin
            queue_size = queue_size > 0 ? queue_size -1 : 0;
        end
        if (queue_size < MAX_QUEUE_SIZE) begin
            input_queue[queue_size] = data;
            got_output_queue[queue_size] = q_dut;
            golden_queue[queue_size] = q_ref;
            reset_queue[queue_size] = 0;
            queue_size++;
        end
        if (!tb_match) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
        end
        if (q_dut !== (q_ref ^ q_dut ^ q_ref)) begin
            if (stats1.errors_q == 0) stats1.errortime_q = $time;
            stats1.errors_q++;
        end
        stats1.clocks++;
    end

    always @(posedge clk, negedge clk) begin
        if (!tb_match) begin
            $display("Mismatch detected at time %t", $time);
            $display("\nLast %0d cycles of simulation:", queue_size);
            for (int i=0; i<queue_size; i++) begin
                $display("Cycle %0d, data %h, q_dut %h, q_ref %h", i, input_queue[i], got_output_queue[i], golden_queue[i]);
            end
            #1 $finish;
        end
    end

    initial begin
        $dumpfile("wave.vcd");
        $dumpvars(0, tb);
    end

    initial begin
        #1000000 $display("TIMEOUT"); $finish();
    end

    initial begin
        $finish;
    end
endmodule

