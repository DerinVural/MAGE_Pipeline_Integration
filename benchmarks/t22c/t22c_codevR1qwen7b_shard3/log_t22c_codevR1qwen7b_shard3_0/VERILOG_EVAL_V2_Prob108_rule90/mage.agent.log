        @(posedge clk);
        @(posedge clk);
        load <= 0;
        repeat(1000) @(posedge clk);

        data <= 512'h1000000000000001;
        load <= 1;
        @(posedge clk);
        load <= 0;
        repeat(1000) @(posedge clk);

        data <= $random;
        load <= 1;
        @(posedge clk);
        load <= 0;
        repeat(1000) @(posedge clk);

        data <= 0;
        load <= 1;
        repeat(20) @(posedge clk);
