e [0:9];\n    reg reset_queue [0:9];\n    integer queue_size;\n    localparam MAX_QUEUE_SIZE = 10;\n\n    initial begin clk = 0; forever #5 clk = ~clk; end\n\n    stimulus_gen stim1 (.clk(clk), .load(load), .data(data), .wavedrom_title(), .wavedrom_enable());\n    RefModule good1 (.clk(clk), .load(load), .data(data), .q(q_ref));\n    TopModule top_module1 (.clk(clk), .load(load), .data(data), .q(q_dut));\n\n    always @(posedge clk, negedge clk) begin\n        if (queue_size >= MAX_QUEUE_SIZE-1) begin\n            queue_size = queue_size > 0 ? queue_size -1 : 0;\n        end\n        if (queue_size < MAX_QUEUE_SIZE) begin\n            input_queue[queue_size] = data;\n            got_output_queue[queue_size] = q_dut;\n            golden_queue[queue_size] = q_ref;\n            reset_queue[queue_size] = 0;\n            queue_size++;\n        end\n        if (!tb_match) begin\n            if (stats1.errors == 0) stats1.errortime = $time;\n            stats1.errors++;\n        end\n        if (q_dut !== (q_ref ^ q_dut ^ q_ref)) begin\n            if (stats1.errors_q == 0) stats1.errortime_q = $time;\n            stats1.errors_q++;\n        end\n        stats1.clocks++;\n    end\n\n    always @(posedge clk, negedge clk) begin\n        if (!tb_match) begin\n            $display("Mismatch detected at time %t", $time);\n            $display("\\nLast %0d cycles of simulation:", queue_size);\n            for (int i=0; i<queue_size; i++) begin\n                $display("Cycle %0d, data %h, q_dut %h, q_ref %h", i, input_queue[i], got_output_queue[i], golden_queue[i]);\n            end\n            #1 $finish;\n        end\n    end\n\n    initial begin\n        $dumpfile("wave.vcd");\n        $dumpvars(0, tb);\n    end\n\n    initial begin\n        #1000000 $display("TIMEOUT"); $finish();\n    end\n\n    initial begin\n        $finish;\n    end\nendmodule\n\n// Additional displays\nalways @(posedge clk, negedge clk) begin\n    if (stats1.errors > 0) begin\n        $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0t", stats1.errors, stats1.errortime);\n    end else begin\n        $display("SIMULATION PASSED");\n    end\nend\n</testbench>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nThe module interface is given below:\n<module_interface>\nmodule stimulus_gen (\n    input clk,\n    output reg load,\n    output reg [511:0] data,\n    output reg [511:0] wavedrom_title,\n    output reg wavedrom_enable\n);\nendmodule\n\nmodule tb();\n    // ... internal signals and instantiations\nendmodule\n</module_interface>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nYour response will be processed by a program, not human.\nSo, please STRICTLY FOLLOW the output format given as XML tag content below to generate a VALID JSON OBJECT:\n<output_format>\n{\n    "reasoning": "All reasoning steps and advices to avoid syntax error",\n    "module": "Pure SystemVerilog code, a complete module"\n}\n</output_format>\nDO NOT include any other information in your response, like \'json\', \'reasoning\' or \'<output_format>\'.\n\nOther requirements:\n1. Don\'t use state_t to define the parameter. Use `localparam` or Use \'reg\' or \'logic\' for signals as registers or Flip-Flops.\n2. Declare all ports and signals as logic.\n3. Not all the sequential logic need to be reset to 0 when reset is asserted,\n    but these without-reset logic should be initialized to a known value with an initial block instead of being X.\n4. For combinational logic with an always block do not explicitly specify the sensitivity list; instead use always @(*).\n5. NEVER USE \'inside\' operator in RTL code. Code like \'state inside {STATE_B, STATE_C, STATE_D}\' should NOT be used.\n6. Never USE \'unique\' or \'unique0\' keywords in RTL code. Code like \'unique case\' should NOT be used.\n')])]
