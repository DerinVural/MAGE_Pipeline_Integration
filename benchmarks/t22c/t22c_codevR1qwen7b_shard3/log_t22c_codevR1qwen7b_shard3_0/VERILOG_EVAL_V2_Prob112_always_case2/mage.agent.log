    } stats;
    stats stats1 = '{errors:0, errortime:0, errors_pos:0, errortime_pos:0, clocks:0};

    wire [511:0] wavedrom_title;
    wire wavedrom_enable;
    reg clk = 0;
    initial forever #5 clk = ~clk;

    logic [3:0] in;
    logic [1:0] pos_ref;
    logic [1:0] pos_dut;

    initial begin
        $dumpfile("wave.vcd");
        $dumpvars(1, stim1.clk, tb_mismatch, in, pos_ref, pos_dut);
    end

    wire tb_match;
    wire tb_mismatch = ~tb_match;

    stimulus_gen stim1 (
        .clk(clk),
        .in(in),
        .wavedrom_title(wavedrom_title),
        .wavedrom_enable(wavedrom_enable)
    );

    RefModule good1 (
        .in(in),
        .pos(pos_ref)
    );

    TopModule top_module1 (
        .in(in),
        .pos(pos_dut)
    );

    bit strobe = 0;
    task wait_for_end_of_timestep;
        repeat(5) begin
            strobe <= !strobe;
            @(strobe);
        end
