(posedge clk) in <= in << 1;\n        in <= 0;\n        repeat(16) @(posedge clk) in <= in + 1;\n        @(negedge clk); wavedrom_stop();\n        repeat(50) @(posedge clk, negedge clk) in <= $urandom;\n        $finish;\n    end\nendmodule\n\nmodule tb();\n    typedef struct { int errors; int errortime; int errors_pos; int errortime_pos; int clocks; } stats;\n    stats stats1 = {0, 0, 0, 0, 0};\n    reg clk = 0; initial forever #5 clk = ~clk;\n    logic [3:0] in;\n    logic [1:0] pos_ref, pos_dut;\n    wire tb_match = ({pos_ref} === ({pos_ref} ^ {pos_dut} ^ {pos_ref}));\n\n    stimulus_gen stim1 (clk, in, wavedrom_title, wavedrom_enable);\n    RefModule good1 (in, .pos(pos_ref));\n    TopModule top_module1 (in, pos_dut);\n\n    // Queue for mismatches\n    reg [3:0] in_queue [0:4]; reg [1:0] got_pos [0:4]; reg [1:0] golden_pos [0:4]; reg rst_queue [0:4];\n    localparam MAX_QUEUE_SIZE = 5;\n\n    always @(posedge clk, negedge clk) begin\n        // Manage queue depth\n        if ($size(in_queue) >= MAX_QUEUE_SIZE) begin\n            for (int i=0; i < MAX_QUEUE_SIZE-1; i++) begin\n                in_queue[i] = in_queue[i+1];\n                got_pos[i] = got_pos[i+1];\n                golden_pos[i] = golden_pos[i+1];\n                rst_queue[i] = rst_queue[i+1];\n            end\n        end\n        in_queue[$size(in_queue)] = in;\n        got_pos[$size(got_pos)] = pos_dut;\n        golden_pos[$size(golden_pos)] = pos_ref;\n        rst_queue[$size(rst_queue)] = 0; // Assuming no reset in this testbench\n\n        // Check for first mismatch\n        if (tb_match === 0 && stats1.errors == 0) begin\n            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0t", stats1.errors+1, $time);\n            $display("Last %0d cycles of simulation:", $size(in_queue));\n            for (int i=0; i < $size(in_queue); i++) begin\n                if (got_pos[i] === golden_pos[i])\n                    $display("Got Match at");\n                else\n                    $display("Got Mismatch at");\n                $display("Cycle %0d, reset %b, input %h, got output %h, exp output %h", i, rst_queue[i], in_queue[i], got_pos[i], golden_pos[i]);\n            end\n            $finish;\n        end else if (!tb_match) begin\n            stats1.errors++;\n            if (stats1.errors == 1) stats1.errortime = $time;\n        end\n        stats1.clocks++;\n    end\n    // Timeout\n    initial #1000000 $finish;\nendmodule\n</testbench>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nThe module interface is given below:\n<module_interface>\nmodule stimulus_gen (input clk, output logic [3:0] in, output logic [511:0] wavedrom_title, output logic wavedrom_enable);\nmodule tb(); // ... other signals\n// Instantiate TopModule and RefModule here\nendmodule\n</module_interface>\n')]), ChatMessage(role=<MessageRole.USER: 'user'>, additional_kwargs={}, blocks=[TextBlock(block_type='text', text='\nYour response will be processed by a program, not human.\nSo, please STRICTLY FOLLOW the output format given as XML tag content below to generate a VALID JSON OBJECT:\n<output_format>\n{\n    "reasoning": "All reasoning steps and advices to avoid syntax error",\n    "module": "Pure SystemVerilog code, a complete module"\n}\n</output_format>\nDO NOT include any other information in your response, like \'json\', \'reasoning\' or \'<output_format>\'.\n\nOther requirements:\n1. Don\'t use state_t to define the parameter. Use `localparam` or Use \'reg\' or \'logic\' for signals as registers or Flip-Flops.\n2. Declare all ports and signals as logic.\n3. Not all the sequential logic need to be reset to 0 when reset is asserted,\n    but these without-reset logic should be initialized to a known value with an initial block instead of being X.\n4. For combinational logic with an always block do not explicitly specify the sensitivity list; instead use always @(*).\n5. NEVER USE \'insi