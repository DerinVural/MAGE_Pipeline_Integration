`define OK 12
`define INCORRECT 13

module stimulus_gen (
    input clk,
    output reg [6:1] y,
    output reg w,
    input tb_match
);

    initial begin
        repeat(200) @(posedge clk, negedge clk) begin
            y <= 1 << ($random % 6);
            w <= $random;
        end
        #1 $finish;
    end

endmodule

module tb();
    typedef struct {
        int errors;
        int errortime;
        int errors_Y2;
        int errortime_Y2;
        int errors_Y4;
        int errortime_Y4;
        int clocks;
    } stats;
    stats stats1;
    reg clk = 0;
    initial forever #5 clk = ~clk;

    reg [6:1] y;
    reg w;
    logic Y2_ref, Y4_ref, Y2_dut, Y4_dut;
    wire tb_match = ~tb_match_reg;
    reg tb_match_reg;
    wire tb_mismatch = ~tb_match;

    stimulus_gen stim1 (clk, y, w, tb_match_reg);
    RefModule ref_inst (y, w, Y2_ref, Y4_ref);
    TopModule dut (y, w, Y2_dut, Y4_dut);

    bit strobe = 0;
    task wait_for_timestep; repeat(5) begin strobe <= !strobe; @(strobe); end endtask

    initial begin
        $dumpfile("wave.vcd");
        $dumpvars(1, tb, clk, y, w, Y2_ref, Y2_dut, Y4_ref, Y4_dut);
    end

    // First mismatch tracking
    reg [6:1] input_queue [0:5];
    reg [1:0] got_Y2 [0:5], got_Y4 [0:5];
    reg [1:0] expected_Y2 [0:5], expected_Y4 [0:5];
    reg [6:1] reset_queue [0:5];
    localparam MAX_QUEUE_SIZE = 6;

    always @(posedge clk, negedge clk) begin
        if (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin
            input_queue.delete(0);
            // ... adjust arrays on size reduction
        end
        input_queue.push_back({y, w});
        expected_Y2.push_back(Y2_ref);
        expected_Y4.push_back(Y4_ref);
        reset_queue.push_back(1'b0); // Assuming reset is tied low, adjust if needed

        if (tb_mismatch) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
            if (Y2_ref !== (Y2_ref ^ Y2_dut ^ Y2_ref)) begin
                if (stats1.errors_Y2 == 0) stats1.errortime_Y2 = $time;
                stats1.errors_Y2++;
            end
            if (Y4_ref !== (Y4_ref ^ Y4_dut ^ Y4_ref)) begin
                if (stats1.errors_Y4 == 0) stats1.errortime_Y4 = $time;
                stats1.errors_Y4++;
            end
        end
    end

    // Simulation end with timeout
    initial begin #1e6 $display("TIMEOUT"); $finish; end
    initial begin stats1.clocks = 0; end

    final begin
        $display("Sim passed");
        if (stats1.errors) $display("FAILED %d mismatches first at %0t", stats1.errors, stats1.errortime);
        else $display("PASSED");
    end
endmodule
