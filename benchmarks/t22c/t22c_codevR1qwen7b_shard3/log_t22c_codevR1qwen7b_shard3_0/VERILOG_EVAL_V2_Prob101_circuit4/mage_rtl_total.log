        #15; // Time 15ns: same
        #20; d = 1; // Time 20ns
        #5; // 25ns: a=0, b=1, c=1, d=0 (q=1)
        #5; // 30ns: b=1, c=1, d=1 (q=1)
        #5; // 35ns: b=1
