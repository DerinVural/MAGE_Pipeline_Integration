    RefModule ref_inst (.a(a), .b(b), .c(c), .d(d), .q(q_ref));
    TopModule dut_inst (.a(a), .b(b), .c(c), .d(d), .q(q_dut));
    // Stimulus generation
    initial begin
        a = 0; b = 0; c = 0; d = 0;
        #0;
        #5; // Time 5ns: values same
