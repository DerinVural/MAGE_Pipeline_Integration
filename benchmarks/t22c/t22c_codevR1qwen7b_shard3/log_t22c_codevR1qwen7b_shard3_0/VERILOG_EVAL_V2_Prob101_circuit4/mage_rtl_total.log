        #5; // 80ns: d=1 (q=1)
        #5; // 85ns: c=1 (q=1)
        #5; // 90ns: d=1 (q=1)
        #500; // Timeout after 100ns*5=500ns
        $finish;
    end
    // Error detection logic
    integer errors=0, errortime, clocks=0;
    always @(posedge d or negedge d) begin
