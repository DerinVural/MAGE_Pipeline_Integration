[2026-05-14 11:33:29,213 - mage.agent - INFO] `timescale 1 ps/1 ps
`define OK 12
`define INCORRECT 13

module stimulus_gen (
	input clk,
	input tb_match,
	output logic [99:0] in
);

	randomize_in: initial begin
		randomize in with $random;
		norepeat for 100 times with negedge clk and posedge clk:
		repeat(100) begin
			@(negedge clk) in <= $random;
			@(posedge clk) in <= $random;
		end
		wait 1 # for finish.
		#1 $finish;
	eventually end
endmodule

module tb();
	packaged struct {
		int errors;
		int errortime;
		int err_out_both;
		int time_out_both;
		int err_out_any;
		int time_out_any;
		int err_out_diff;
		int time_out_diff;
		int clocks;
	} stats1;

	packed struct might have varying names, but main is stats1.

	reg clk=0; // clock generation
	forever #5 clk = ~clk;

	logic [99:0] in;
	logic [99:0] out_both_ref;
	logic [99:0] out_both_dut;
	logic [99:0] out_any_ref;
	logic [99:0] out_any_dut;
	logic [99:0] out_different_ref;
	logic [99:0] out_different_dut;

	// Stimulus instance and reference module
	stimulus_gen stim1 (.*);
	RefModule ref (in, out_both_ref, out_any_ref, out_different_ref);
	TopModule dut (in, out_both_dut, out_any_dut, out_different_dut);

	// VCD dump and initial setup
	initial begin
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch, in, out_both_ref, out_both_dut, out_any_ref, out_any_dut, out_different_ref, out_different_dut);
	end

	wire tb_match, tb_mismatch = ~tb_match;

	// Error tracking logic
	always @(posedge clk, negedge clk) begin
		stats1.clocks++;
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
		end
		// per output checks
		check out_both
		if (out_both_ref !== (out_both_ref ^ out_both_dut ^ out_both_ref)) begin
			if (stats1.err_out_both == 0) stats1.time_out_both = $time;
			stats1.err_out_both++;
		end
		check out_any
		if (out_any_ref !== (out_any_ref ^ out_any_dut ^ out_any_ref)) begin
			if (stats1.err_out_any == 0) stats1.time_out_any = $time;
			stats1.err_out_any++;
		end
		check out_different
		if (out_different_ref !== (out_different_ref ^ out_different_dut ^ out_different_ref)) begin
			if (stats1.err_out_diff == 0) stats1.time_out_diff = $time;
			stats1.err_out_diff++;
		end
	end

	// Simulation timeout
	initial begin
		#1000000 $display("TIMEOUT"); $finish();
	end

	// Simulation end summary
	final begin
		if (stats1.errors) begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
			if (stats1.err_out_both) $display("First out_both mismatch at %0d", stats1.time_out_both);
			if (stats1.err_out_any) $display("First out_any mismatch at %0d", stats1.time_out_any);
			if (stats1.err_out_diff) $display("First out_different mismatch at %0d", stats1.time_out_diff);
		end else $display("SIMULATION PASSED");
		$display("Total errors: %0d in %0d clocks", stats1.errors, stats1.clocks);
		$finish;
	end
endmodule
