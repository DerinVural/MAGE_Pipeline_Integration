[2026-05-14 11:33:46,839 - mage.agent - INFO] `timescale 1ps/1ps

module stimulus_gen (
    input clk,
    input tb_match,
    output logic [99:0] in
);
    initial begin
        in = $random;
        repeat(100) begin
            @(negedge clk);
            in = $random;
            @(posedge clk);
            in = $random;
        end
        #1 $finish;
    end
endmodule

module tb();
    typedef struct packed {
        int errors;
        int errortime;
        int err_out_both;
        int errortime_out_both;
        int err_out_any;
        int errortime_out_any;
        int err_out_different;
        int errortime_out_different;
        int clocks;
    } stats_t;
    stats_t stats1 = '{errors:0, err_out_both:0, err_out_any:0, err_out_different:0, clocks:0};

    reg clk = 0;
    initial forever #5 clk = ~clk;

    logic [99:0] in;
    logic [99:0] out_both_ref, out_both_dut;
    logic [99:0] out_any_ref, out_any_dut;
    logic [99:0] out_different_ref, out_different_dut;

    // Clock generator and stimulus
    stimulus_gen stim_gen (.clk(clk), .tb_match(tb_match), .in(in));

    // Reference module
    RefModule ref_mod (
        .in(in),
        .out_both(out_both_ref),
        .out_any(out_any_ref),
        .out_different(out_different_ref)
    );

    // Device Under Test
    TopModule dut (
        .in(in),
        .out_both(out_both_dut),
        .out_any(out_any_dut),
        .out_different(out_different_dut)
    );

    // Verification Logic
    wire tb_match = ~tb_match_dummy;
    reg tb_match_dummy;
    always @(posedge clk, negedge clk) begin
        stats1.clocks++;
        if (stats1.errors == 0) begin
            if (!( {out_both_ref, out_any_ref, out_different_ref} === ( {out_both_ref, out_any_ref, out_different_ref} ^ {out_both_dut, out_any_dut, out_different_dut} ^ {out_both_ref, out_any_ref, out_different_ref} ) )) begin
                stats1.errors++;
                if (stats1.errortime == 0) stats1.errortime = $time;
            end
        end
        if ( {out_both_ref, out_any_ref, out_different_ref} === ( {out_both_ref, out_any_ref, out_different_ref} ^ {out_both_dut, out_any_dut, out_different_dut} ^ {out_both_ref, out_any_ref, out_different_ref} ) ) {
            // No error
        } else begin
            // out_both check
            if (stats1.err_out_both == 0 && out_both_ref[i] !== (out_both_ref[i] ^ out_both_dut[i] ^ out_both_ref[i])) begin
                stats1.err_out_both++;
                if (stats1.errortime_out_both == 0) stats1.errortime_out_both = $time;
            end
            // out_any check
            if (stats1.err_out_any == 0 && out_any_ref[i] !== (out_any_ref[i] ^ out_any_dut[i] ^ out_any_ref[i])) begin
                stats1.err_out_any++;
                if (stats1.errortime_out_any == 0) stats1.errortime_out_any = $time;
            end
            // out_different check
            if (stats1.err_out_different == 0 && out_different_ref[i] !== (out_different_ref[i] ^ out_different_dut[i] ^ out_different_ref[i])) begin
                stats1.err_out_different++;
                if (stats1.errortime_out_different == 0) stats1.errortime_out_different = $time;
            end
        end
    end

    initial begin tb_match_dummy = 0; end
    always @(negedge clk) tb_match_dummy = !tb_match_dummy;

    initial begin
        #1000000 $finish;
    end

    final begin
        $display((stats1.errors == 0) ? "SIMULATION PASSED" : "SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
        if (stats1.err_out_both) $display("First out_both mismatch at time: %0d", stats1.errortime_out_both);
        if (stats1.err_out_any) $display("First out_any mismatch at time: %0d", stats1.errortime_out_any);
        if (stats1.err_out_different) $display("First out_different mismatch at time: %0d", stats1.errortime_out_different);
        $display("Total errors: %0d in %0d clocks", stats1.errors, stats1.clocks);
    end
endmodule
