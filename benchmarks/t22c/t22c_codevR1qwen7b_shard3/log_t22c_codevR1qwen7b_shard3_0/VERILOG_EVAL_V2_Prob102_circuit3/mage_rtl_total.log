    TopModule top_module1 (.a(a), .b(b), .c(c), .d(d), .q(q_dut));
    reg [3:0] input_queue [0:9];
    reg [0:9] got_q [0:9];
    reg [0:9] expected_q [0:9];
    localparam MAX_QUEUE_SIZE = 10;
    task display_first_mismatch();
        begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0t", stats1.errors, stats1.errortime);
        end
    endtask
    reg [3:0] current_input;
    reg current_q;
    reg expected_q_reg;
    always @(posedge clk, negedge clk) begin
        stats1.clocks <= stats1.clocks + 1;
        if (tb_mismatch) begin
            if (stats1.errors == 0) stats1.errortime <= $time;
            stats1.errors <= stats1.errors + 1;
        end
        // Queue management
