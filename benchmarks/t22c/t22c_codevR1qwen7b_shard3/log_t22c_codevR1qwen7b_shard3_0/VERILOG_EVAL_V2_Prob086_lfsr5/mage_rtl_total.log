    endtask
    task wavedrom_start(input [511:0] title = ";"); endtask
    task wavedrom_stop; #1; endtask
    initial begin
        reset <= 1;
        @(negedge clk);
        wavedrom_start();
        reset_test();
        repeat(8) @(posedge clk);
        @(negedge clk);
        wavedrom_stop();
        repeat(400) @(posedge clk, negedge clk) begin
            reset <= !($random & 31);
        end
        @(posedge clk) reset <= 1'b0;
        repeat(2000) @(posedge clk);
        reset <= 1'b1;
        repeat(5) @(posedge clk);
        #1 $finish;
    end
endmodule

