        #(1) sel = 4'h2;
        #(1) sel = 4'h3;
        #(1) sel = 4'h4;
        #(1) sel = 4'h7;
        #(1) sel = 4'h8;
        #(1) sel = 4'h9;
        #(1) sel = 4'ha;
        #(1) sel = 4'hb;
        // Random after
        repeat(200) begin
            {a,b,c,d,e,f,g,h,i} <= {$random, $random, $random, $random, $random};
            sel <= $random;
            @(negedge clk);
        end
        $finish;
    end
endmodule

module tb();
    reg clk = 0;
    initial forever #5 clk = ~clk;
    // Stimulus and Dut signals
    logic [15:0] a,b,c,d,e,f,g,h,i;
    logic [3:0] sel;
    logic [15:0] out_dut, out_ref;
    TopModule dut (.a(a), .b(b), .c(c), .d(d), .e(e), .f(f), .g(g), .h(h), .i(i), .sel(sel), .out(out_dut));
    RefModule ref (.a(a), .b(b), .c(c), .d(d), .e(e), .f(f), .g(g), .h(h), .i(i), .sel(sel), .out(out_ref));
    // Error tracking
    reg [4:0] errors = 0;
    reg [31:0] err_time;
    // Queue for first error display
    localparam MAX_QUEUE = 5;
    reg [15:0] a_q [0:MAX_QUEUE-1];
    reg [15:0] b_q [0:MAX_QUEUE-1];
    reg [15:0] c_q [0:MAX_QUEUE-1];
    reg [15:0] d_q [0:MAX_QUEUE-1];
    reg [15:0] e_q [0:MAX_QUEUE-1];
    reg [15:0] f_q [0:MAX_QUEUE-1];
    reg [15:0] g_q [0:MAX_QUEUE-1];
    reg [15:0] h_q [0:MAX_QUEUE-1];
    reg [15:0] i_q [0:MAX_QUEUE-1];
    reg [3:0] sel_q [0:MAX_QUEUE-1];
    reg [15:0] out_ref_q [0:MAX_QUEUE-1];
    reg [15:0] out_dut_q [0:MAX_QUEUE-1];
    reg error_q [0:MAX_QUEUE-1];
    integer q_ptr = 0;
    integer i;
    // Check on clock edges
    always @(posedge clk, negedge clk) begin
        if (q_ptr >= MAX_QUEUE-1) begin
            for (i=0; i < MAX_QUEUE-1; i=i+1) begin
                a_q[i] <= a_q[i+1];
                b_q[i] <= b_q[i+1];
                c_q[i] <= c_q[i+1];
                d_q[i] <= d_q[i+1];
                e_q[i] <= e_q[i+1];
                f_q[i] <= f_q[i+1];
                g_q[i] <= g_q[i+1];
                h_q[i] <= h_q[i+1];
                i_q[i] <= i_q[i+1];
                sel_q[i] <= sel_q[i+1];
                out_ref_q[i] <= out_ref_q[i+1];
                out_dut_q[i] <= out_dut_q[i+1];
                error_q[i] <= error_q[i+1];
            end
            q_ptr <= q_ptr -1;
        end
        a_q[q_ptr] <= a;
        b_q[q_ptr] <= b;
        c_q[q_ptr] <= c;
        d_q[q_ptr] <= d;
        e_q[q_ptr] <= e;
        f_q[q_ptr] <= f;
        g_q[q_ptr] <= g;
        h_q[q_ptr] <= h;
        i_q[q_ptr] <= i;
        sel_q[q_ptr] <= sel;
        out_ref_q[q_ptr] <= out_ref;
        out_dut_q[q_ptr] <= out_dut;
        error_q[q_ptr] <= (out_dut != out_ref);
        q_ptr <= q_ptr +1;
        if (out_dut != out_ref) begin
            if (errors == 0) err_time = $time;
            errors <= errors +1;
            if (error_q[q_ptr]) begin
                $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", errors+1, err_time);
                $display("Cycle %0d, sel %h, inputs %h, %h, %h, %h, %h, %h, %h, %h, %h", q_ptr, sel_q[q_ptr], a_q[q_ptr], b_q[q_ptr], c_q[q_ptr], d_q[q_ptr], e_q[q_ptr], f_q[q_ptr], g_q[q_ptr], h_q[q_ptr], i_q[q_ptr], sel_q[q_ptr]);
                $display("Got output: %h, Expected: %h", out_dut_q[q_ptr], out_ref_q[q_ptr]);
                $finish;
            end
        end
    end
    // Timeout after 1M cycles
    initial begin
        #1000000 $display("TIMEOUT"); $finish;
    end
    // Simulation end display
    initial begin
        wait(errors == 0);
        $display("SIMULATION PASSED");
    end
endmodule
