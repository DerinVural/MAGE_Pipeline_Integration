        .p2a(p2a), .p2b(p2b), .p2c(p2c), .p2d(p2d),
        .p1y(p1y_dut), .p2y(p2y_dut)
    );
    RefModule ref_mod (
        .p1a(p1a), .p1b(p1b), .p1c(p1c), .p1d(p1d), .p1e(p1e), .p1f(p1f),
