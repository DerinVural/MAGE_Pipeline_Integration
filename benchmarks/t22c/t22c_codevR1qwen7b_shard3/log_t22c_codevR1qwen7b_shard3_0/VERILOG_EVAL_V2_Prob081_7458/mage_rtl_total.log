module stimulus_gen (
    input clk,
    output logic p1a, p1b, p1c, p1d, p1e, p1f,
    output logic p2a, p2b, p2c, p2d
);
    task wavedrom_start;
        input [511:0] title;
    endtask
    task wavedrom_stop;
        #1;
    endtask
    int count = 0;
    initial begin
        {p1a,p1b,p1c,p1d,p1e,p1f} = 0;
