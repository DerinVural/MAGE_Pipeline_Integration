`define OK 12
`define INCORRECT 13

module stimulus_gen(clk, enable, S, A, B, C);
    input clk;
    output logic enable;
    output logic S;
    output logic A;
    output logic B;
    output logic C;
    
    task wavedrom_start(input[511:0] title = ""); endtask
    task wavedrom_stop; #1; endtask
    
    initial begin
        enable <= 0;
        {A,B,C} <= 0;
        S <= 1'bx;
        @(negedge clk) wavedrom_start("A 3-input AND gate");
        @(posedge clk);
        @(posedge clk) enable <= 1; S <= 1;
        @(posedge clk) S <= 0;
        repeat(6) @(posedge clk);
        enable <= 0; S <= 1'bx;
        {A,B,C} <= 5;
        repeat(500) @(posedge clk, negedge clk) begin
            {A,B,C,S} <= $random;
            enable <= ($random & 3) == 0;
        end
        @(negedge clk) wavedrom_stop();
        $finish;
    end
endmodule

module tb();
    typedef struct packed { int errors; int errortime; int errors_Z; int errortime_Z; int clocks; } stats_t;
    stats_t stats1 = 0;
    
    reg clk = 0;
    initial forever #5 clk = ~clk;
    
    logic enable;
    logic S;
    logic A,B,C;
    logic Z_ref;
    logic Z_dut;
    
    initial begin
        $dumpfile("wave.vcd");
        $dumpvars(1, tb, clk, enable, S, A, B, C, Z_ref, Z_dut);
    end
    
    wire tb_match, tb_mismatch = ~tb_match;
    
    stimulus_gen stim1(
        .clk(clk),
        .enable(enable),
        .S(S),
        .A(A),
        .B(B),
        .C(C)
    );
    
    RefModule good1(
        .clk(clk),
        .enable(enable),
        .S(S),
        .A(A),
        .B(B),
        .C(C),
        .Z(Z_ref)
    );
    
    TopModule top_module1(
        .clk(clk),
        .enable(enable),
        .S(S),
        .A(A),
        .B(B),
        .C(C),
        .Z(Z_dut)
    );
    
    task wait_for_end_of_timestep;
        repeat(5) begin
            strobe <= !strobe;
            @(strobe);
        end
    endtask
    reg strobe = 0;
    
    always @(*) begin
        if (Z_ref !== Z_dut) begin
            if (stats1.errors == 0) stats1.errortime = $time;
            stats1.errors++;
        end
        if (Z_dut !== (Z_ref & (A & B & C))) begin // Adjust logic based on original spec
            if (stats1.errors_Z == 0) stats1.errortime_Z = $time;
            stats1.errors_Z++;
        end
    end
    
    initial begin
        #1000000;
        $display("TIMEOUT");
        $finish;
    end
    
    final begin
        if (stats1.errors_Z) begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors_Z, stats1.errortime_Z);
        end else begin
            $display("SIMULATION PASSED");
        end
        $display("Total mismatched samples: %0d out of %0d", stats1.errors, stats1.clocks);
        $display("Simulation finished at %0d ps", $time);
    end
endmodule
