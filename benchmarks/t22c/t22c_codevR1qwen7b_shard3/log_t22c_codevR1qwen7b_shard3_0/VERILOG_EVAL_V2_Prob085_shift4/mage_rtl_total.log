module stimulus_gen (
    input clk,
    output areset,
    output reg load,
    output reg ena,
    output reg [3:0] data
);
    reg reset;
    assign areset = reset;

    task reset_test(input async=0);
        bit arfail, srfail, datafail;
        @(posedge clk);
        @(posedge clk) reset <= 0;
        repeat(3) @(posedge clk);
        @(negedge clk) begin datafail = !tb_match; reset <= 1; end
        @(posedge clk) arfail = !tb_match;
        @(posedge clk) begin
            srfail = !tb_match;
            reset <= 0;
        end
        if (srfail)
            $display("Hint: Your reset doesn't seem to be working.");
        else if (arfail && (async || !datafail))
            $display("Hint: Your reset should be %0s, but doesn't appear to be.", async ? "asynchronous" : "synchronous");
    endtask

    reg [3:0] q_ref, q_dut;
    reg tb_match;
    reg [3:0] q_ref_queue [0:8];
    reg [3:0] q_dut_queue [0:8];
    reg reset_queue [0:8];
    reg [3:0] load_queue [0:8];
    reg [3:0] ena_queue [0:8];
    reg [3:0] data_queue [0:8];
    integer error_count = 0, error_time, error_time_q;
    integer error_q_count = 0;

    initial begin
        {load, ena, reset, data} = 7'h40;
        @(posedge clk) {load, ena, reset, data} = 7'h4F;
        @(posedge clk) {load, ena, reset, data} = 7'h0X;
        @(posedge clk) {load, ena, reset, data} = 7'h2X;
        @(posedge clk) {load, ena, reset, data} = 7'h2X;
        @(posedge clk) {load, ena, reset, data} = 7'h0X;
        reset_test(1);
        @(posedge clk);
        @(posedge clk);
        repeat(400) @(posedge clk, negedge clk);
        $finish;
    end
endmodule

module tb();
    reg clk = 0;
    initial forever #5 clk = ~clk;

    logic areset;
    logic load, ena;
    logic [3:0] data, q_dut, q_ref;
    wire tb_match = (q_ref === (q_ref ^ q_dut ^ q_ref));

    TopModule dut (.clk(clk), .areset(areset), .load(load), .ena(ena), .data(data), .q(q_dut));
    RefModule ref_mod (.clk(clk), .areset(areset), .load(load), .ena(ena), .data(data), .q(q_ref));

    always @(posedge clk, negedge clk) begin
        if (!tb_match && error_count == 0) begin
            error_count = 1;
            error_time = $time;
        end
        if (q_dut !== q_ref && error_q_count == 0) begin
            error_q_count = 1;
            error_time_q = $time;
        end
    end

    always @(posedge clk) begin
        if (error_count > 0)
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", error_count, error_time);
        else if (error_q_count == 0)
            $display("SIMULATION PASSED");
    end
endmodule
