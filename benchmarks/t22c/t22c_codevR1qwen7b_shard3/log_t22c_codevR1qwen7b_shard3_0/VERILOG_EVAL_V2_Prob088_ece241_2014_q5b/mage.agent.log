[2026-05-14 11:21:11,299 - mage.agent - INFO] module TopModule (clk, areset, x, z);
  input logic clk;
  input logic areset;
  input logic x;
  output logic z;

  // State encoding: A=2'b10, B=2'b01
  logic [1:0] state, next_state;

  // Asynchronous reset with one-hot encoding
  always_ff @(posedge clk or posedge areset) begin
    if (areset) begin
      state <= 2'b10; // State A after reset
    end else begin
      state <= next_state;
    end
  end

  // Combinational next state logic (Mealy output)
  always_comb begin
    case (state)
      2'b10: begin // State A
        next_state = x ? 2'b01 : 2'b10;
      end
      2'b01: begin // State B
        next_state = 2'b01; // Stays in B regardless of x
      end
      default: next_state = 2'b10; // Handle undefined states
    endcase
  end

  // Mealy output logic: z depends on state and x
  always_comb begin
    case (state)
      2'b10: z = x ? 1'b1 : 1'b0;
      2'b01: z = x ? 1'b0 : 1'b1;
      default: z = 1'b0;
    endcase
  end
endmodule
