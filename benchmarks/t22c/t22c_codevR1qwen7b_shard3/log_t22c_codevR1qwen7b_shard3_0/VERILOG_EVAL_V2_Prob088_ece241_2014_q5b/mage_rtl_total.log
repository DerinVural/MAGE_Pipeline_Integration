    // One-hot states
    localparam [1:0] A = 2'b10, B = 2'b01;

    logic [1:0] state, next_state;
    // Asynchronous reset
    always @(posedge clk or posedge areset) begin
        if (areset) state <= A;
        else state <= next_state;
    end

