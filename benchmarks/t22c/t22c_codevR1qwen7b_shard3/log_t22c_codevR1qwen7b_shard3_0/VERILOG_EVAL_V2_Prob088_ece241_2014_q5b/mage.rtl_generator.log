    // One-hot states
    localparam [1:0] A = 2'b10, B = 2'b01;

    logic [1:0] state, next_state;
    // Asynchronous reset
    always @(posedge clk or posedge areset) begin
        if (areset) state <= A;
        else state <= next_state;
    end

    // Next state combinational logic
    always @(*) begin
        case (state)
            A: next_state = x ? B : A;
            B: next_state = x ? B : B;
            default: next_state = A;
        endcase
    end

    // Output logic (Mealy)
    assign z = (state == A) ? x : ~x;
endmodule
