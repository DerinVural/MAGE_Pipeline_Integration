    input clk;
    input areset;
    input x;
    output logic z;

    // One-hot state encoding
    logic [1:0] state;
    localparam STATE_A = 2'b10, STATE_B = 2'b01;
    logic [1:0] next_state;

    // Asynchronous reset, initial to STATE_A
    initial begin
        state = STATE_A;
    end
    always @(posedge clk or posedge areset) begin
        if (areset) begin
            state <= STATE_A;
        end else begin
            state <= next_state;
        end
    end

    // Combinational next state and output logic
    always @(*) begin
        case (state)
            STATE_A: begin
                next_state = x ? STATE_B : STATE_A;
                z = x;
            end
            STATE_B: begin
                next_state = x ? STATE_A : STATE_B;
                z = ~x;
            end
            default: begin
                next_state = STATE_A;
                z = 1'b0;
            end
        endcase
    end

endmodule
