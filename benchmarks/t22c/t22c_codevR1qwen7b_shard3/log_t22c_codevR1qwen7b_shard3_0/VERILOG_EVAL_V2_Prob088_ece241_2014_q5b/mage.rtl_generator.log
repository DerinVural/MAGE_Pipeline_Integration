[2026-05-14 11:21:54,329 - mage.rtl_generator - INFO] RTL code: module TopModule (clk, areset, x, z);
  input clk;
  input areset;
  input x;
  output logic z;

  // State definitions
  localparam [1:0] STATE_A = 2'b10,
                   STATE_B = 2'b01;

  // State registers
  logic [1:0] state, next_state;

  // Initialize state on reset or asynchronously
  always @(posedge clk or posedge areset) begin
    if (areset) begin
      state <= STATE_A;
    end else begin
      state <= next_state;
    end
  end

  // Next state logic
  always @(*) begin
    case (state)
      STATE_A: begin
        if (x) next_state = STATE_B;
        else next_state = STATE_A;
      end
      STATE_B: begin
        if (x) next_state = STATE_B;
        else next_state = STATE_B;
      end
      default: next_state = STATE_A;
    endcase
  end

  // Mealy output logic
  always @(*) begin
    case (state)
      STATE_A: z = (x) ? 1'b1 : 1'b0;
      STATE_B: z = (x) ? 1'b0 : 1'b1;
      default: z = 1'b0;
    endcase
  end

endmodule
