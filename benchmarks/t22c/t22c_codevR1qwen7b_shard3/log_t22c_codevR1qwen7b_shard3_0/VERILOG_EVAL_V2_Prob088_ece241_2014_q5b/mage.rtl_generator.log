    input clk;
    input areset;
    input x;
    output logic z;

    // State encoding
    localparam [1:0] STATE_A = 2'b10,
                     STATE_B = 2'b01;

    logic [1:0] current_state, next_state;

    // State register with async reset
    always @(posedge clk or posedge areset) begin
        if (areset) current_state <= STATE_A;
        else        current_state <= next_state;
    end

    // Next state logic and output (combinational)
    always @(*) begin
        case (current_state)
            STATE_A: begin
                if (x) begin
                    next_state = STATE_B;
                    z = 1;
                end else begin
                    next_state = STATE_A;
                    z = 0;
                end
            end
            STATE_B: begin
                if (x) begin
                    next_state = STATE_B;
                    z = 0;
                end else begin
                    next_state = STATE_B;
                    z = 1;
                end
            end
            default: begin
                next_state = STATE_A;
                z = 0;
            end
        endcase
    end

    // Initialization
    initial begin
        current_state = STATE_A;
        next_state = STATE_A;
    end
endmodule
