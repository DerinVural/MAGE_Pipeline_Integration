egin next_state = 2'b00; out = 0; end\n        endcase\n    end\nendmodule\n\nmodule TopModule (input logic in, input logic [1:0] state, output logic [1:0] next_state, output logic out);\n    always @(*) begin\n        case (state)\n            2'b00: next_state = in ? 2'b01 : 2'b00;\n            2'b01: next_state = in ? 2'b10 : 2'b01;\n            2'b10: next_state = in ? 2'b11 : 2'b00;\n            2'b11: next_state = in ? 2'b01 : 2'b10;\n            default: next_state = 2'b00;\n        endcase\n    end\n    always @(*) begin\n        case (state)\n            2'b00: out = 0;\n            2'b01: out = 0;\n            2'b10: out = 0;\n            2'b11: out = 1;\n            default: out = 0;\n        endcase\n    end\nendmodule\n\nstruct packed stats { int errors, errortime, errors_next_state, errortime_next_state, errors_out, errortime_out, clocks; };"
