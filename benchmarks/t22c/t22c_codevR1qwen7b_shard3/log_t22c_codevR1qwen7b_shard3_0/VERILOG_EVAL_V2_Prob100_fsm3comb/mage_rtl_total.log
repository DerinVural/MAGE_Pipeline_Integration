module stimulus_gen (input logic clk, output logic in, output logic [1:0] state);
    int i;
    initial repeat(100) @(posedge clk, negedge clk) begin
        in = $urandom;
        state = $urandom;
    end
    #1 $finish;
endmodule

module RefModule (input logic in, input logic [1:0] state, output logic [1:0] next_state, output logic out);
    logic [1:0] next_state;
    logic out;
    always @(*) begin
        case (state)
            2'b00: begin next_state = in ? 2'b01 : 2'b00; out = 0; end
            2'b01: begin next_state = in ? 2'b10 : 2'b01; out = 0; end
            2'b10: begin next_state = in ? 2'b11 : 2'b00; out = 0; end
            2'b11: begin next_state = in ? 2'b01 : 2'b10; out = 1; end
            default: begin next_state = 2'b00; out = 0; end
        endcase
    end
endmodule

module TopModule (input logic in, input logic [1:0] state, output logic [1:0] next_state, output logic out);
    always @(*) begin
        case (state)
            2'b00: next_state = in ? 2'b01 : 2'b00;
            2'b01: next_state = in ? 2'b10 : 2'b01;
            2'b10: next_state = in ? 2'b11 : 2'b00;
            2'b11: next_state = in ? 2'b01 : 2'b10;
            default: next_state = 2'b00;
        endcase
    end
    always @(*) begin
        case (state)
            2'b00: out = 0;
            2'b01: out = 0;
            2'b10: out = 0;
            2'b11: out = 1;
            default: out = 0;
        endcase
    end
