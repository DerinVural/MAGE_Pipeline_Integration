[2026-05-14 11:46:28,422 - mage.agent - INFO] module tb();
    reg clk = 0;
    logic in;
    logic [1:0] state;
    logic [1:0] next_state_ref, next_state_dut;
    logic out_ref, out_dut;
    initial begin
        clk = 0;
        forever #5 clk = ~clk;
    end
    stimulus_gen stim1(.clk(clk), .in(in), .state(state));
    RefModule ref1(.in(in), .state(state), .next_state(next_state_ref), .out(out_ref));
    TopModule top1(.in(in), .state(state), .next_state(next_state_dut), .out(out_dut));
    integer errors = 0, errortime = 0, clocks = 0;
    always @(posedge clk, negedge clk) begin
        clocks++;
        if (next_state_ref !== next_state_dut) begin
            errors++;
            if (errors == 1) errortime = $time;
        end
        if (out_ref !== out_dut) begin
            errors++;
            if (errors == 1) errortime = $time;
        end
    end
    initial begin
        #1000000;
        if (errors == 0) $display("SIMULATION PASSED");
        else $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", errors, errortime);
        $finish;
    end
endmodule

module stimulus_gen(input clk, output logic in, output logic [1:0] state);
    integer i;
    initial begin
        repeat(100) @(posedge clk, negedge clk) begin
            in = $random;
            state = $random;
        end
        #1 $finish;
    end
endmodule

module RefModule(input logic in, input logic [1:0] state, output logic [1:0] next_state, output logic out);
    localparam [1:0] A = 2'b00, B = 2'b01, C = 2'b10, D = 2'b11;
    always @(*) begin
        case (state)
            A: out = 0;
            B: out = 0;
            C: out = 0;
            D: out = 1;
        endcase
    end
    always @(*) begin
        case (state)
            A: next_state = in ? B : A;
            B: next_state = in ? C : B;
            C: next_state = in ? D : A;
            D: next_state = in ? B : C;
            default: next_state = A;
        endcase
    end
endmodule

module TopModule(input logic in, input logic [1:0] state, output logic [1:0] next_state, output logic out);
    localparam [1:0] A = 2'b00, B = 2'b01, C = 2'b10, D = 2'b11;
    always @(*) begin
        case (state)
            A: next_state = in ? B : A;
            B: next_state = in ? C : B;
            C: next_state = in ? D : A;
            D: next_state = in ? B : C;
            default: next_state = A;
        endcase
    end
    always @(*) begin
        if (state == A) out = 0;
        else if (state == B) out = 0;
        else if (state == C) out = 0;
        else if (state == D) out = 1;
        else out = 0;
    end
endmodule
