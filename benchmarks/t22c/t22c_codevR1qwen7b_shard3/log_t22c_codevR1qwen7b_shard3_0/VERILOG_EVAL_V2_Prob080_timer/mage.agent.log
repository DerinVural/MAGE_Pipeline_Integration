module RefModule (
    input clk,
    input load,
    input [9:0] data,
    output reg tc
);
    reg [9:0] counter;
    always @(posedge clk) begin
        if (load) begin
            counter <= data;
        end else if (counter != 0) begin
            counter <= counter - 1;
        end
    end
    assign tc = (counter == 0);
endmodule

