        end
        #1 $finish;
    end
endmodule

module tb();
    typedef struct packed {
        int errors;
        int errortime;
        int errors_tc;
        int errortime_tc;
        int clocks;
    } stats;
    stats stats1 = 0;
    wire [511:0] wavedrom_title;
    wire wavedrom_enable;
    int wavedrom_hide_after_time;
    reg clk = 0;
    initial forever #5 clk = ~clk;
    logic load;
    logic [9:0] data;
    logic tc_ref;
    logic tc_dut;
    wire tb_match;
    wire tb_mismatch = ~tb_match;
    stimulus_gen stim1 (
        .clk(clk),
        .load(load),
        .data(data),
        .tb_match(tb_match),
        .wavedrom_title(wavedrom_title),
        .wavedrom_enable(wavedrom_enable),
        .wavedrom_hide_after_time(wavedrom_hide_after_time)
    );
    RefModule good1 (
        .clk(clk),
        .load(load),
        .data(data),
        .tc(tc_ref)
    );
    TopModule top_module1 (
        .clk(clk),
        .load(load),
        .data(data),
        .tc(tc_dut)
    );
    bit strobe = 0;
    task wait_for_end_of_timestep; repeat(5) strobe <= !strobe; @(strobe); endtask
    initial begin
        $dumpfile("wave.vcd");
        $dumpvars(1, stim1.clk, tb_mismatch, clk, load, data, tc_ref, tc_dut);
    end
    assign tb_match = (tc_ref === (tc_ref ^ tc_dut ^ tc_ref));
    reg [1:0] input_queue [0:4];
    reg [0:4] got_output_queue;
    reg [0:4] golden_queue;
    reg [0:4] reset_queue;
    localparam MAX_QUEUE_SIZE = 5;
    integer i;
    always @(posedge clk, negedge clk) begin
        if (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin
            input_queue.delete(0);
            got_output_queue.delete(0);
            golden_queue.delete(0);
            reset_queue.delete(0);
        end
        input_queue.push_back({clk, load, data});
        got_output_queue.push_back(tc_dut);
        golden_queue.push_back(tc_ref);
        reset_queue.push_back(0);
        if (input_queue.size() == MAX_QUEUE_SIZE) begin
            if (got_output_queue[MAX_QUEUE_SIZE - 1] !== golden_queue[MAX_QUEUE_SIZE - 1]) begin
                $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0t", input_queue.size(), $time);
                for (i = 0; i < MAX_QUEUE_SIZE; i++) begin
                    if (i > 0 && got_output_queue[i] === golden_queue[i])
                        $display("Got Match at");
                    else
                        $display("Got Mismatch at");
                    $display("Cycle %0d, clk %b, load %b, data %h, got output %b, exp output %b",
                        i, input_queue[i][2], input_queue[i][1], input_queue[i][0], got_output_queue[i], golden_queue[i]);
                end
                $finish;
            end
        end
    end
    initial begin
        stats1.clocks = 0;
        stats1.errors = 0;
        stats1.errortime = 0;
        stats1.errors_tc = 0;
        stats1.errortime_tc = 0;
        @(posedge clk);
        while (stats1.clocks < 100_000) begin
            if (!tb_match) begin
                if (stats1.errors == 0) stats1.errortime = $time;
                stats1.errors++;
            end
            if (tc_ref !== tc_dut) begin
                if (stats1.errors_tc == 0) stats1.errortime_tc = $time;
                stats1.errors_tc++;
            end
            stats1.clocks++;
            @(posedge clk);
        end
        if (stats1.errors_tc) begin
            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0t", stats1.errors_tc, stats1.errortime_tc);
            for (i = 0; i < MAX_QUEUE_SIZE; i++) begin
                if (i > 0 && got_output_queue[i] === golden_queue[i])
                    $display("Got Match at");
                else
                    $display("Got Mismatch at");
                $display("Cycle %0d, clk %b, load %b, data %h, got output %b, exp output %b",
                    i, input_queue[i][2], input_queue[i][1], input_queue[i][0], got_output_queue[i], golden_queue[i]);
            end
        end else begin
            $display("SIMULATION PASSED");
        end
        $finish;
    end
endmodule

module RefModule (
    input clk,
    input load,
    input [9:0] data,
    output reg tc
);
    reg [9:0] counter;
    always @(posedge clk) begin
        if (load) begin
            counter <= data;
        end else if (counter != 0) begin
            counter <= counter - 1;
        end
    end
    assign tc = (counter == 0);
endmodule

