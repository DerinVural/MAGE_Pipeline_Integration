     .data(data),\n        .tb_match(tb_match),\n        .wavedrom_title(wavedrom_title),\n        .wavedrom_enable(wavedrom_enable),\n        .wavedrom_hide_after_time(wavedrom_hide_after_time)\n    );\n    RefModule good1 (\n        .clk(clk),\n        .load(load),\n        .data(data),\n        .tc(tc_ref)\n    );\n    TopModule top_module1 (\n        .clk(clk),\n        .load(load),\n        .data(data),\n        .tc(tc_dut)\n    );\n    bit strobe = 0;\n    task wait_for_end_of_timestep; repeat(5) strobe <= !strobe; @(strobe); endtask\n    initial begin\n        $dumpfile("wave.vcd");\n        $dumpvars(1, stim1.clk, tb_mismatch, clk, load, data, tc_ref, tc_dut);\n    end\n    assign tb_match = (tc_ref === (tc_ref ^ tc_dut ^ tc_ref));\n    reg [1:0] input_queue [0:4];\n    reg [0:4] got_output_queue;\n    reg [0:4] golden_queue;\n    reg [0:4] reset_queue;\n    localparam MAX_QUEUE_SIZE = 5;\n    integer i;\n    always @(posedge clk, negedge clk) begin\n        if (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin\n            input_queue.delete(0);\n            got_output_queue.delete(0);\n            golden_queue.delete(0);\n            reset_queue.delete(0);\n        end\n        input_queue.push_back({clk, load, data});\n        got_output_queue.push_back(tc_dut);\n        golden_queue.push_back(tc_ref);\n        reset_queue.push_back(0);\n        if (input_queue.size() == MAX_QUEUE_SIZE) begin\n            if (got_output_queue[MAX_QUEUE_SIZE - 1] !== golden_queue[MAX_QUEUE_SIZE - 1]) begin\n                $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0t", input_queue.size(), $time);\n                for (i = 0; i < MAX_QUEUE_SIZE; i++) begin\n                    if (i > 0 && got_output_queue[i] === golden_queue[i])\n                        $display("Got Match at");\n                    else\n                        $display("Got Mismatch at");\n                    $display("Cycle %0d, clk %b, load %b, data %h, got output %b, exp output %b",\n                        i, input_queue[i][2], input_queue[i][1], input_queue[i][0], got_output_queue[i], golden_queue[i]);\n                end\n                $finish;\n            end\n        end\n    end\n    initial begin\n        stats1.clocks = 0;\n        stats1.errors = 0;\n        stats1.errortime = 0;\n        stats1.errors_tc = 0;\n        stats1.errortime_tc = 0;\n        @(posedge clk);\n        while (stats1.clocks < 100_000) begin\n            if (!tb_match) begin\n                if (stats1.errors == 0) stats1.errortime = $time;\n                stats1.errors++;\n            end\n            if (tc_ref !== tc_dut) begin\n                if (stats1.errors_tc == 0) stats1.errortime_tc = $time;\n                stats1.errors_tc++;\n            end\n            stats1.clocks++;\n            @(posedge clk);\n        end\n        if (stats1.errors_tc) begin\n            $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0t", stats1.errors_tc, stats1.errortime_tc);\n            for (i = 0; i < MAX_QUEUE_SIZE; i++) begin\n                if (i > 0 && got_output_queue[i] === golden_queue[i])\n                    $display("Got Match at");\n                else\n                    $display("Got Mismatch at");\n                $display("Cycle %0d, clk %b, load %b, data %h, got output %b, exp output %b",\n                    i, input_queue[i][2], input_queue[i][1], input_queue[i][0], got_output_queue[i], golden_queue[i]);\n            end\n        end else begin\n            $display("SIMULATION PASSED");\n        end\n        $finish;\n    end\nendmodule\n\nmodule RefModule (\n    input clk,\n    input load,\n    input [9:0] data,\n    output reg tc\n);\n    reg [9:0] counter;\n    always @(posedge clk) begin\n        if (load) begin\n            counter <= data;\n        end else if (counter != 0) begin\n            counter <= counter - 1;\n        end\n    end\n    assign tc = (counter == 0);\nendmodule\n\n</testbench>\n')]), Cha