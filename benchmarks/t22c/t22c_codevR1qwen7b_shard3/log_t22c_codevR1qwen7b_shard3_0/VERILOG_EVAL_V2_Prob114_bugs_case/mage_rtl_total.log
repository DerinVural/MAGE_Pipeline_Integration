	initial forever #5 clk = ~clk;

	logic [7:0] code;
	logic [3:0] out_ref, out_dut;
	logic valid_ref, valid_dut;

	// Instantiate the module to test
	TopModule top_module (
		.code(code),
		.out(out_dut),
		.valid(valid_dut)
	);

	// Reference model
	RefModule ref_module (
		.code(code),
		.out(out_ref),
		.valid(valid_ref)
	);

	// Mismatch detection
	wire tb_match = ( {out_ref, valid_ref} === ( {out_ref, valid_ref} ^ {out_dut, valid_dut} ^ {out_ref, valid_ref} ) );
	reg [31:0] errors = 0, first_error_time;
	reg [31:0] errors_out = 0, errors_valid = 0;

	// Simulation time limit
	initial #1000000 $finish;

	// Error counting
	always @(posedge clk, negedge clk) begin
		if (!tb_match) begin
			if (errors == 0) first_error_time = $time;
			errors = errors + 1;
		end
		if (out_ref !== (out_ref ^ out_dut ^ out_ref)) begin
			if (errors_out == 0) errors_out = $time;
			errors_out = errors_out + 1;
		end
