`define OK 12
`define INCORRECT 13

module stimulus_gen (
	xinput clk,
	xoutput reg reset
);

	xinitial begin
		repeat(100) @(negedge clk) begin
			reset <= !($random & 31);
		end
		#1 $finish;
	xend

endmodule

module tb();
	xtypedef struct packed {
		xint errors;
		xint errortime;
		xint errors_shift_ena;
		xint errortime_shift_ena;
		xint clocks;
	} stats;

	stats stats1;
	xwire[511:0] wavedrom_title;
	xwire wavedrom_enable;
	xint wavedrom_hide_after_time;
	xreg clk=0;
	xinitial forever
		xrepeat(5) begin
			clk <= ~clk;
			x@(negedge clk);
		xend

	xlogic reset;
	xlogic shift_ena_ref;
	xlogic shift_ena_dut;
	xwire tb_match;
	xwire tb_mismatch = ~tb_match;

	stimulus_gen stim1 (
		.clk(clk),
		.* ,
		.reset(reset) );

	RefModule good1 (
		.clk(clk),
		.reset(reset),
		.shift_ena(shift_ena_ref) );

	TopModule top_module1 (
		.clk(clk),
		.reset(reset),
		.shift_ena(shift_ena_dut) );

	xbit strobe = 0;
	xtask wait_for_end_of_timestep;
		xrepeat(5) begin
			strobe <= !strobe;
			x@(strobe);
		xend
	xendtask

	xfinal begin
		if (stats1.errors_shift_ena) $display("Hint: Output 'shift_ena' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_shift_ena, stats1.errortime_shift_ena);
		xelse $display("Hint: Output 'shift_ena' has no mismatches.");

		$display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
		$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
		xif (stats1.errors == 0) $display("SIMULATION PASSED");
		xelse $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
	xend

	xassign tb_match = ( { shift_ena_ref } === ( { shift_ena_ref } ^ { shift_ena_dut } ^ { shift_ena_ref } ) );

	xalways @(posedge clk, negedge clk) begin
		stats1.clocks++;
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
		end
		if (shift_ena_ref !== ( shift_ena_ref ^ shift_ena_dut ^ shift_ena_ref )) begin
			if (stats1.errors_shift_ena == 0) stats1.errortime_shift_ena = $time;
			stats1.errors_shift_ena += 1;
		end
	end

	xinitial begin
		#1000000;
		$display("TIMEOUT");
		$finish();
	xend

endmodule
