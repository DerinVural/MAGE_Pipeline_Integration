                $display("First mismatch at time %0d: a=%b, b=%b, q_ref=%b, q_dut=%b", $time, a, b, q_ref, q_dut);
        end
        if (q_dut !== q_ref) begin
            errors_q++;
            if (errors_q == 1)
                $display("First q mismatch at time %0d: a=%b, b=%b, q_ref=%b, q_dut=%b", $time, a, b, q_ref, q_dut);
        end
        clocks++;
    end

    // Simulation timeout after 100ns
    initial begin
        #100 $display("TIMEOUT\nSIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", errors, errortime);
        $finish;
    end

    // Simulation completion
    initial begin
        wait(clocks >= 18); // Assuming 90ns /5 steps = 18 clocks
        if (!errors && !errors_q)
            $display("SIMULATION PASSED\nNo mismatches detected");
        $finish;
    end
endmodule

