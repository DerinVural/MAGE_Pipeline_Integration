`define OK 12
`define INCORRECT 13

module stimulus_gen (
    input clk,
    output logic a,
    output logic b
);

    task wavedrom_start(input[511:0] title = ""); endtask
    task wavedrom_stop; #1; endtask

    initial begin
        {a, b} <= 0;
        @(negedge clk); wavedrom_start("Unknown circuit");
        @(posedge clk) {a, b} <= 0;
        repeat(8) @(posedge clk) {a, b} <= {a, b} + 1;
        @(negedge clk); wavedrom_stop();
        repeat(100) @(posedge clk, negedge clk) {a, b} <= $urandom;
        $finish;
    end
endmodule

