    initial forever #5 clk = ~clk;

    logic a;
    logic b;
    logic q_ref;
    logic q_dut;

    wire tb_match = ( {q_ref} === ( {q_ref} ^ {q_dut} ^ {q_ref} ) );

    // Queue variables for mismatch display
    reg [1:0] input_queue [0:4]; // Assuming a and b are 1 bit each
    reg [0:4] got_output_queue;
    reg [0:4] golden_queue;
