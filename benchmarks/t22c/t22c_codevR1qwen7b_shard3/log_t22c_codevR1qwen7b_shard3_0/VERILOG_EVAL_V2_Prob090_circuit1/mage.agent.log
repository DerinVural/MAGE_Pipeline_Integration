                golden_queue[i] = golden_queue[i+1];
                reset_queue[i] = reset_queue[i+1];
            end
            queue_ptr = MAX_QUEUE_SIZE-1;
        end else begin
            queue_ptr = queue_ptr + 1;
        end
        input_queue[queue_ptr] = {a, b};
        got_output_queue[queue_ptr] = q_dut;
        golden_queue[queue_ptr] = q_ref;
        reset_queue[queue_ptr] = clk; // Assuming clk as reset signal here

        // Check for mismatch
        if (q_dut !== q_ref) begin
