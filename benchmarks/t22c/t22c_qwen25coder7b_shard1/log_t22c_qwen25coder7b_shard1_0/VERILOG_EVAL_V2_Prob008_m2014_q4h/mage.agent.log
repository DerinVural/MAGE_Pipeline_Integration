// Display first mismatch
reg [INPUT_WIDTH-1:0] input_queue [$];
reg [OUTPUT_WIDTH-1:0] got_output_queue [$];
reg [OUTPUT_WIDTH-1:0] golden_queue [$];

localparam INPUT_WIDTH = 1;
localparam OUTPUT_WIDTH = 1;
localparam MAX_QUEUE_SIZE = 2;

always @(posedge clk, negedge clk) begin
    if (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin
        input_queue.delete(0);
        got_output_queue.delete(0);
        golden_queue.delete(0);
    end

    input_queue.push_back(in);
    got_output_queue.push_back(out_dut);
    golden_queue.push_back(out_ref);

    // Check for first mismatch
    if (out_dut !== out_ref) begin
        $display("Mismatch detected at time %t", $time);
        $display("First mismatch detected at cycle %d with input %h, got output %h, exp output %h",
            input_queue.size() - 1,
            input_queue[input_queue.size() - 1],
            got_output_queue[got_output_queue.size() - 1],
            golden_queue[golden_queue.size() - 1]
        );
    end

end

endmodule

