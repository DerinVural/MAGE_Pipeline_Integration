wire[511:0] wavedrom_title;
wire wavedrom_enable;
int wavedrom_hide_after_time;

reg clk = 0;
initial forever
    #5 clk = ~clk;

logic a;
logic b;
logic sum_ref;
logic sum_dut;
logic cout_ref;
logic cout_dut;

initial begin 
    $dumpfile("wave.vcd");
    $dumpvars(1, stim1.clk, tb_mismatch, a, b, sum_ref, sum_dut, cout_ref, cout_dut);
end

