`define OK 12
`define INCORRECT 13

interface TopModule_if (
    logic a,
    logic b,
    logic sum,
    logic cout
);

module stimulus_gen (
    input clk,
    output logic a,
    output logic b
);

    always @(posedge clk, negedge clk)
        {a, b} <= $random;

    initial begin
        repeat(100) @(negedge clk);
        $finish;
    end

endmodule

topmodule_tb tb ();

typedef struct packed {
    int errors;
    int errortime;
    int errors_sum;
    int errortime_sum;
    int errors_cout;
    int errortime_cout;

    int clocks;
} stats;

