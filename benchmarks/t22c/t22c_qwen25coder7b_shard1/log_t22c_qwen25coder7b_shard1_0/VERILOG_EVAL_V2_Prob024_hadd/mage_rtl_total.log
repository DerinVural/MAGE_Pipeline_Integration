    if (cout_ref !== ( cout_ref ^ cout_dut ^ cout_ref ))
    begin if (stats1.errors_cout == 0) stats1.errortime_cout = $time;
        stats1.errors_cout = stats1.errors_cout+1'b1; end

end

   // add timeout after 100K cycles
   initial begin
     #1000000
     $display("TIMEOUT");
     $finish();
   end

