module tb;
	parameter CLK_PERIOD = 10;
	parameter MAX_QUEUE_SIZE = 8;

typedef struct packed {
		int errors;
		int errortime;
		int errors_q;
		int errortime_q;
		int clocks;
} stats;

stats stats1;

wire [511:0] wavedrom_title;
wire wavedrom_enable;
integer wavedrom_hide_after_time;

reg clk = 0;
initial forever
	#CLK_PERIOD/2 clk = ~clk;

logic reset;
logic [3:0] q_ref;
logic [3:0] q_dut;

reg [CLK_PERIOD*MAX_QUEUE_SIZE-1:0] input_queue;
reg [CLK_PERIOD*MAX_QUEUE_SIZE-1:0] got_output_queue;
reg [CLK_PERIOD*MAX_QUEUE_SIZE-1:0] golden_queue;
reg [CLK_PERIOD*MAX_QUEUE_SIZE-1:0] reset_queue;

reg [$clog2(MAX_QUEUE_SIZE)-1:0] input_index = 0;
reg [$clog2(MAX_QUEUE_SIZE)-1:0] output_index = 0;

wire tb_match;
wire tb_mismatch = ~tb_match;

stimulus_gen stim1 (
	.clk(clk),
	.*,
	.reset(reset)
);

RefModule good1 (
	.clk(clk),
	.reset(reset),
	.q(q_ref)
);

TopModule top_module1 (
	.clk(clk),
	.reset(reset),
	.q(q_dut)
);

bit strobe = 0;
task wait_for_end_of_timestep;
	repeat(5) begin
		strobe <= !strobe;
		@(strobe);
	end
endtask

final begin
	if (stats1.errors_q) begin
		$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0t", stats1.errors_q, stats1.errortime_q);
	end else begin
		$display("SIMULATION PASSED");
	end
end

assign tb_match = ( { q_ref } === ( { q_ref } ^ { q_dut } ^ { q_ref } ) );
always @(posedge clk, negedge clk) begin
	if (input_index < CLK_PERIOD*MAX_QUEUE_SIZE) begin
		input_queue[input_index] = {clk, reset};
		reset_queue[input_index] = reset;
		input_index <= input_index + 1;
	end
	if (output_index < CLK_PERIOD*MAX_QUEUE_SIZE) begin
		got_output_queue[output_index] = {clk, q_dut};
		golden_queue[output_index] = {clk, q_ref};
		output_index <= output_index + 1;
	end
	stats1.clocks++;
	if (!tb_match) begin
		if (stats1.errors == 0) stats1.errortime = $time;
		stats1.errors++;
	end
	if (q_ref !== ( q_ref ^ q_dut ^ q_ref )) begin
		if (stats1.errors_q == 0) stats1.errortime_q = $time;
		stats1.errors_q = stats1.errors_q + 1;
	end
end

initial begin
	#1000000 $finish;
end
endmodule

