	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	reg clk=0;
	initial forever
		#5 clk = ~clk;
	logic reset;
	logic [3:0] q_ref;
	logic [3:0] q_dut;
	initial begin
		$dumpfile("wave.vcd");
