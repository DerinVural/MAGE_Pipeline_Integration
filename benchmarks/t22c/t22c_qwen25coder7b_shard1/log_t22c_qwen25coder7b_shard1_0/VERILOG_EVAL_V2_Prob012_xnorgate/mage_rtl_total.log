	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	reg clk=0;
	initial forever #5 clk = ~clk;
	logic a;
	logic b;
	logic out_ref;
	logic out_dut;
	wire tb_match;
	wire tb_mismatch;
