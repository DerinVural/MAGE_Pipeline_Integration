[2026-05-14 11:12:08,889 - mage.agent - INFO] `timescale 1ps/1ps

parameter INPUT_WIDTH = 4;
parameter OUTPUT_WIDTH = 5;
parameter MAX_QUEUE_SIZE = 8;

logic clk=0;
initial forever
	#5 clk = ~clk;

logic [3:0] x;
logic [3:0] y;
logic [4:0] sum_ref;
logic [4:0] sum_dut;
logic tb_match;

reg [INPUT_WIDTH-1:0] input_queue [$];
reg [OUTPUT_WIDTH-1:0] got_output_queue [$];
reg [OUTPUT_WIDTH-1:0] golden_queue [$];

always @(posedge clk, negedge clk) begin
	if (input_queue.size() >= MAX_QUEUE_SIZE - 1) begin
		input_queue.delete(0);
		got_output_queue.delete(0);
		golden_queue.delete(0);
	end
	
	input_queue.push_back(x);
	got_output_queue.push_back(sum_dut);
	golden_queue.push_back(sum_ref);
	
	// Check for first mismatch
	if (sum_dut !== sum_ref) begin
		$display("Mismatch detected at time %t", $time);
		$display("\nLast %d cycles of simulation:", input_queue.size());
		for (int i = 0; i < input_queue.size(); i++) begin
			$display("Cycle %d, input %h, got output %h, exp output %h",
				i,
				x,
				sum_dut,
				sum_ref
			);
		end
		$finish;
	end
	
end

stimulus_gen stim1 (
	.clk(clk),
	.x(x),
	.y(y)
);

RefModule good1 (
	.x(x),
	.y(y),
	.sum(sum_ref)
);

final begin
	if (input_queue.size()) $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %t", input_queue.size(), $time);
	else $display("SIMULATION PASSED");
end

