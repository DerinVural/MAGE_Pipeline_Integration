[2026-05-14 11:07:11,613 - mage.agent - INFO] module stimulus_gen (
	input clk,
	output logic x,
	output logic y
);

	always @(posedge clk)
		{ x, y } <= $random % 2;

	initial begin
		repeat(101) @(negedge clk);
		#1 $finish;
	end

endmodule

module tb();
	logic clk;
	logic x;
	logic y;
	logic z_ref;
	logic z_dut;

	stimulus_gen stim1 (
		.clk(clk),
		.x(x),
		.y(y)
	);

