		.x(x),
		.y(y),
		.z(z_ref)
	);

	TopModule top_module1 (
		.x(x),
		.y(y),
		.z(z_dut)
	);

	final begin
		if (z_dut != z_ref) $display("SIMULATION FAILED - x MISMATCHES DETECTED, FIRST AT TIME %t", $time);
		else $display("SIMULATION PASSED");
	end

endmodule
