	endtask
	
	final begin
		if (stats1.errors_cout) $display("Hint: Output '"%s"' has %0d mismatches. First mismatch occurred at time %0d.", "cout", stats1.errors_cout, stats1.errortime_cout);
		else $display("Hint: Output '"%s"' has no mismatches.", "cout");
