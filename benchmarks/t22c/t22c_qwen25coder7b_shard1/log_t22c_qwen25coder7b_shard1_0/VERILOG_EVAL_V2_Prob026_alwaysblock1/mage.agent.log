module RefModule(
	.input a,
	.input b,
	.output out_assign,
	.output out_alwaysblock
);
assign out_assign = a & b;
always @(*)
out_alwaysblock = a & b;
endmodule

module TopModule(
	.input a,
	.input b,
	.output out_assign,
	.output out_alwaysblock
);
assign out_assign = a & b;
always @(*)
out_alwaysblock = a & b;
endmodule
