				$display("Input Signals (in): Hex=%h, Binary=%b", in, in);
				$display("DUT Output (pos_dut): Hex=%h, Binary=%b", pos_dut, pos_dut);
				$display("Expected Output (pos_ref): Hex=%h, Binary=%b", pos_ref, pos_ref);
				$display("========================================================\n");
				
			stats1.errors++;
				
