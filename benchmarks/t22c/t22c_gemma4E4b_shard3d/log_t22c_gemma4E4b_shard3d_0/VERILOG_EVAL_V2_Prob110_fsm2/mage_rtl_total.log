	logic first_areset_at_error = 0;
	logic first_out_ref_at_error = 0;
	logic first_out_dut_at_error = 0;
	
	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,clk,j,k,areset,out_ref,out_dut );
