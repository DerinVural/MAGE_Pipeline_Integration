	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk,
		.* ,
		j,
		k,
		areset );
	RefModule good1 (
		.clk,
		j,
		k,
		areset,
		out(out_ref) );
	
