				first_j_k_at_error = {j, k};
				first_areset_at_error = areset;
				// Capture outputs
				first_out_ref_at_error = out_ref;
				first_out_dut_at_error = out_dut;
			end
			end
		end

		// add timeout after 100K cycles
		initial begin
			#1000000
			$display("TIMEOUT");
			$finish();
		end

endmodule
