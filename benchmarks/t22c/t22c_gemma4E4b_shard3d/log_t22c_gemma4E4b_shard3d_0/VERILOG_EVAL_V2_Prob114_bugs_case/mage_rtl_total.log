] wavedrom_title;\n\t\twire wavedrom_enable;\n\t\tint wavedrom_hide_after_time;\n\t\t\n\t\treg clk=0;\n\t\tinitial forever\n\t\t\th#5 clk = ~clk;\n\tend\n\n\t\tlogic [7:0] code;\n\t\tlogic [3:0] out_ref;\n\t\tlogic [3:0] out_dut;\n\t\tlogic valid_ref;\n\t\tlogic valid_dut;\n\n\t\tinitial begin \n\t\t\t$dumpfile(\"wave.vcd\");\n\t\t\t$dumpvars(1, stimulus_gen.clk, tb_mismatch ,code,out_ref,out_dut,valid_ref,valid_dut );\n\t\tend\n\n\t\t\n\t\twire tb_match;        // Verification\n\t\twire tb_mismatch = ~tb_match;\n\t\t\n\t\tstimulus_gen stim1 (\n\t\t\t.clk,\n\t\t\t.* ,\n\t\t\t.code );\n\t\tRefModule good1 (\n\t\t\t.code,\n\t\t\tout(out_ref),\n\t\t\t.valid(valid_ref) );\n\t\t\n\t\tTopModule top_module1 (\n\t\t\t.code,\n\t\t\tout(out_dut),\n\t\t\t.valid(valid_dut) );\n\n\t\t\n\t\tbit strobe = 0;\n\t\ttask wait_for_end_of_timestep;\n\t\t\trepeat(5) begin\n\t\t\tstrobe <= !strobe;  // Try to delay until the very end of the time step.\n\t\t\t@(strobe);\n\t\t\tend\n\t\tendtask\n\t\t\n\n\t\t// Initialize snapshot variables\n\t\tinitial begin\n\t\t\tcode_snapshot = 8'h00;\n\t\t\tout_ref_snapshot = 4'h0;\n\t\t\tout_dut_snapshot = 4'h0;\n\t\t\tvalid_ref_snapshot = 1'b0;\n\t\t\tvalid_dut_snapshot = 1'b0;\n\t\tend\n\n\t\t\n\t\t// Monitor for the FIRST mismatch and capture snapshots\n\t\tinitial begin\n\t\t\t// Wait for the first mismatch to occur\n\t\t\t@(posedge clk);\n\t\t\twhile(1) begin\n\t\t\t\t@(posedge clk);\n\t\t\t\tif (!tb_match && stats1.errors == 0) begin\n\t\t\t\t\t// Capture state AT the time of first mismatch detection\n\t\t\t\t\tcode_snapshot = code;\n\t\t\t\t\tout_ref_snapshot = out_ref;\n\t\t\t\t\tout_dut_snapshot = out_dut;\n\t\t\t\t\tvalid_ref_snapshot = valid_ref;\n\t\t\t\t\tvalid_dut_snapshot = valid_dut;\n\t\t\t\t\t\n\t\t\t\t\t$display(\"\n============================================================\");\n\t\t\t\t\t$display(\"*** FIRST MISMATCH DETECTED AT TIME %0d ps ***\", $time);\n\t\t\t\t\t$display(\"============================================================\");\n\t\t\t\t\t$display(\"Input Signals (code): HEX = %h, BIN = %b\", code, code);\n\t\t\t\t\t$display(\"Expected Output Signals (ref): HEX = %h, BIN = %b\", out_ref, out_ref);\n\t\t\t\t\t$display(\"DUT Output Signals: HEX = %h, BIN = %b\", out_dut, out_dut);\n\t\t\t\t\t$display(\"Expected Valid: %b | DUT Valid: %b\", valid_ref, valid_dut);\n\t\t\t\tend\n\t\t\t\t// Stop monitoring after first mismatch is reported\n\t\t\tend\n\t\tend\n\n\t\t// Continuous update of snapshots for final reporting accuracy\n\t\talways @(posedge clk) begin\n\t\t\tcode_snapshot = code;\n\t\t\tout_ref_snapshot = out_ref;\n\t\t\tout_dut_snapshot = out_dut;\n\t\t\tvalid_ref_snapshot = valid_ref;\n\t\t\tvalid_dut_snapshot = valid_dut;\n\t\tend\n\n\t\t\n\t\t// Verification assignment: {out_ref, valid_ref} must equal {out_dut, valid_dut}\n\t\tassign tb_match = ({ out_ref, valid_ref } === { out_dut, valid_dut });\n\n\t\t// Error counting logic\n\t\talways @(posedge clk, negedge clk) begin\n\t\t\tstats1.clocks++;\n\t\t\t\n\t\t\tif (!tb_match) begin\n\t\t\t\tif (stats1.errors == 0) stats1.errortime = $time;\n\t\t\t\tsstats1.errors++;\n\t\t\tend\n\t\t\t\n\t\t\t// Check 'out' mismatch\n\t\t\tif (out_ref !== out_dut)\n\t\t\tbegin \n\t\t\t\tif (stats1.errors_out == 0) stats1.errortime_out = $time;\n\t\t\t\tsstats1.errors_out = stats1.errors_out+1'b1;\n\t\t\tend\n\t\t\t\n\t\t\t// Check 'valid' mismatch\n\t\t\tif (valid_ref !== valid_dut)\n\t\t\tbegin \n\t\t\t\tif (stats1.errors_valid == 0) stats1.errortime_valid = $time;\n\t\t\t\tsstats1.errors_valid = stats1.errors_valid+1'b1;\n\t\t\tend\n\t\t\tend\n\t\tend\n\n\t\t\n\t\t// add timeout after 100K cycles\n\t\tinitial begin\n\t\t\th#1000000\n\t\t\t$display(\"\\n*** TIMEOUT REACHED ***\");\n\t\t\t$finish();\n\t\tend\n\n\t\t// Final Reporting\n\t\tfinal begin\n\t\t\tif (stats1.errors == 0) begin\n\t\t\t\t$display(\"\\n*****************************************\");\n\t\t\t\t$display(\"SIMULATION PASSED\");\n\t\t\t\t$display(\"*****************************************\");\n\t\t\tend else begin\n\t\t\t$display(\"\\n============================================================"
