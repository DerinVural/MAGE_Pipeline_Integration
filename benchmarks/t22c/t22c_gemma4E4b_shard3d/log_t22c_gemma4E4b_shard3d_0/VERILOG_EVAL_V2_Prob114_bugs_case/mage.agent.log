module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_out;
		int errortime_out;
		int errors_valid;
		int errortime_valid;
		
		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		h#5 clk = ~clk;

	logic [7:0] code;
	logic [3:0] out_ref; // Assuming 4-bit output based on spec
	logic [3:0] out_dut;
	logic valid_ref;
	logic valid_dut;

	// Variables to track first mismatch for new display logic
	logic first_mismatch_detected = 0;
	integer first_mismatch_time = 0;
	logic [7:0] mismatch_code = 0;
	logic [3:0] mismatch_out_dut = 0;
	logic [3:0] mismatch_out_ref = 0;
	logic mismatch_valid_dut = 0;
	logic mismatch_valid_ref = 0;

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,code,out_ref,out_dut,valid_ref,valid_dut );
	end

	
	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk,
		.*,
		.code );
		RefModule good1 (
			.code,
			out(out_ref),
			.valid(valid_ref) );
		
		TopModule top_module1 (
			.code,
			out(out_dut),
			.valid(valid_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end
	task
	
	
	// Removed original final block and replaced with new logic
	
	// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.
	assign tb_match = ( { out_ref, valid_ref } === ( { out_ref, valid_ref } ^ { out_dut, valid_dut } ^ { out_ref, valid_ref } ) );

	// Main verification loop synchronized to clock edge
always @(posedge clk, negedge clk) begin

		stats1.clocks++;
		
		// Check total mismatch
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			sstats1.errors++;
			end
		
		// Check 'out' mismatch
		if (out_ref !== ( out_ref ^ out_dut ^ out_ref ))
		begin 
			if (stats1.errors_out == 0) stats1.errortime_out = $time;
			sstats1.errors_out = stats1.errors_out+1'b1; 
		end
		
		// Check 'valid' mismatch
		if (valid_ref !== ( valid_ref ^ valid_dut ^ valid_ref ))
		begin 
			if (stats1.errors_valid == 0) stats1.errortime_valid = $time;
			sstats1.errors_valid = stats1.errors_valid+1'b1; 
		end
		end

	// Logic to capture state at the FIRST detected mismatch (Combinational requirement)
	always @(posedge clk, negedge clk)
	begin
		if (stats1.errors == 1 && first_mismatch_detected == 0)
		begin
			first_mismatch_detected = 1;
			first_mismatch_time = $time;
			// Capture current state at the point of first mismatch
			mismatch_code = code;
			mismatch_out_dut = out_dut;
			mismatch_out_ref = out_ref;
			mismatch_valid_dut = valid_dut;
			mismatch_valid_ref = valid_ref;
			end
		end

	// Add timeout after 100K cycles
	initial begin
		h#1000000
		$display("\n====================================================");
		$display("TIMEOUT REACHED.");
		$display("====================================================");
		$finish();
	end

	// Final simulation summary based on new requirements
	initial begin
		@(negedge clk);
		#1;
		$display("\n====================================================");
		if (stats1.errors == 0 && stats1.errors_out == 0 && stats1.errors_valid == 0)
			$display("SIMULATION PASSED");
		else begin
			int total_errors = stats1.errors + stats1.errors_out + stats1.errors_valid;
			int first_time = (stats1.errortime != 0) ? stats1.errortime : (stats1.errortime_out != 0 ? stats1.errortime_out : stats1.errortime_valid);
			if (first_time == 0) first_time = $time; // Fallback if no errors were flagged in specific counters but total > 0
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", total_errors, first_time);
			
			// Detailed display on first mismatch (Combinational rule)
			if (first_mismatch_detected == 1)
				$display("\n--- DETAILED MISMATCH REPORT (FIRST ERROR AT %0d) ---", first_mismatch_time);
				$display("Input Code: %h (Binary: %b)", mismatch_code, mismatch_code);
				$display("DUT Output: %h (Binary: %b), Valid: %b", mismatch_out_dut, mismatch_out_dut, mismatch_valid_dut);
				$display("Reference Output: %h (Binary: %b), Valid: %b", mismatch_out_ref, mismatch_out_ref, mismatch_valid_ref);
				$display("---------------------------------------------------");
		end
		$display("Total Samples Checked: %0d\n", stats1.clocks);
	end

endmodule

