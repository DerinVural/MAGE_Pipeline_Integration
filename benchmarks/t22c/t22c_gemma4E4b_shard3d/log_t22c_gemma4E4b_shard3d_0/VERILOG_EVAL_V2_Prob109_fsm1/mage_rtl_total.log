module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_out;
		int errortime_out;

		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic in;
	logic areset;
	logic out_ref;
	logic out_dut;

	// --- Queue Setup for Sequential Logic Check ---
	// FSM has 2 states (A, B). Max queue size must be >= 2^2 = 4. Max allowed is 10.
	localparam MAX_QUEUE_SIZE = 10;

	reg [1:0] input_queue [MAX_QUEUE_SIZE-1:0];
	reg [1:0] got_output_queue [MAX_QUEUE_SIZE-1:0];
	reg [1:0] golden_queue [MAX_QUEUE_SIZE-1:0];
	reg reset_queue [MAX_QUEUE_SIZE-1:0];
	
	int queue_head = 0;
	int queue_tail = 0;
	
	// --- Mismatch Tracking --- 
	reg mismatch_detected = 0;
	
	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,clk,in,areset,out_ref,out_dut );
	end

	
	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk,
		.* , // Uses wavedrom_title, wavedrom_enable
		in,
		areset );
	RefModule good1 (
		.clk,
		in,
		areset,
		out(out_ref) );
	
	TopModule top_module1 (
		.clk,
		in,
		areset,
		out(out_dut) );


	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end	ask
	
	
	// --- Queue Update and Mismatch Checking Logic ---
	always @(posedge clk, negedge clk) begin
		
		// 1. Update Queue (Circular Buffer Logic)
		queue_tail = (queue_tail + 1) % MAX_QUEUE_SIZE;
		
		// Shift existing data (simple approach for small queue or use pointers)
		// For simplicity and following the example structure, we use a fixed-size array and wrap.
		// Since the example used push_back/delete(0), we simulate that behavior using wrap around.
		
		input_queue[queue_tail] = in;
		got_output_queue[queue_tail] = out_dut;
		golden_queue[queue_tail] = out_ref;
		reset_queue[queue_tail] = areset;

		// 2. Check for Mismatch
		if (!tb_match) begin
			if (mismatch_detected == 0) begin
				// First mismatch detected, record time
				stats1.errortime = $time;
				mismatch_detected = 1;
			end
			stats1.errors++;
			
			// Check output specific mismatch (original logic)
			if (out_ref !== ( out_ref ^ out_dut ^ out_ref ))
			begin 
				if (stats1.errors_out == 0) stats1.errortime_out = $time;
				sstats1.errors_out = stats1.errors_out+1'b1; 
			end
			
			// 3. Display Queue Content ONLY ON FIRST MISMATCH
			if (mismatch_detected == 1 && stats1.errors == 1) begin
				s$display("Mismatch detected at time %t", $time);
				s$display("\nLast %0d cycles of simulation:", MAX_QUEUE_SIZE);
			
				// Iterate through the queue contents (assuming queue_tail points to the latest, and we display MAX_QUEUE_SIZE elements backwards/cyclically)
				for (int i = 0; i < MAX_QUEUE_SIZE; i++) begin
					// Calculate index for the i-th element back from the latest (queue_tail)
					int idx = (queue_tail - i + MAX_QUEUE_SIZE) % MAX_QUEUE_SIZE;
					
					// Check match/mismatch for this specific cycle in the queue
					if (got_output_queue[idx] === golden_queue[idx]) begin
						s$display("Got Match at Index %d", i);
					end else begin
						s$display("Got Mismatch at Index %d", i);
					end
						s$display("Cycle %d, reset %b, input %b, got output %b, exp output %b",
					i,
					reset_queue[idx],
					input_queue[idx],
					got_output_queue[idx],
					golden_queue[idx]);
				end
			end
			
			// Ensure mismatch_detected remains 1 after first error for logging purposes
			// We don't reset mismatch_detected until simulation ends.
			
			
			end
		end
		
		// 4. Update Stats (Original Logic)
		stats1.clocks++;
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			sstats1.errors++;
		end
		if (out_ref !== ( out_ref ^ out_dut ^ out_ref ))
		begin 
			if (stats1.errors_out == 0) stats1.errortime_out = $time;
			sstats1.errors_out = stats1.errors_out+1'b1; 
		end
		
	end


	final begin
		if (stats1.errors_out) $display("Hint: Output 'out' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_out, stats1.errortime_out);
		else $display("Hint: Output 'out' has no mismatches.");

		// New required final display logic
		if (stats1.errors == 0 && stats1.errors_out == 0) begin
			s$display("SIMULATION PASSED");
		end else begin
			s$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
		end

		$display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
		$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
	end
	

	// add timeout after 100K cycles
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

endmodule
