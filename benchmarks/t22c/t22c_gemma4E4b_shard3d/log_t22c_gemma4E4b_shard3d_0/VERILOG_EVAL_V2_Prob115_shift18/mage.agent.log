// TESTBENCH WITH IMPROVED QUEUE-BASED VERIFICATION
// =======================================================================
module tb();

	// Queue-based simulation mismatch display setup
	reg [63:0] input_data_q [$];
	reg [63:0] got_output_q [$];
	reg [63:0] golden_queue [$];
	reg [1:0] amount_q [$];
	reg clk_q [$];

	localparam MAX_QUEUE_SIZE = 10;
	
	// Simulation statistics
	int errors = 0;
	int errortime = -1;
	int errors_q = 0;
	int errortime_q = -1;
	int clocks = 0;

	// Clock generation
	reg clk=0;

	initial forever
		h#5 clk = ~clk;

	// DUT Signals
	logic load;
	logic ena;
	logic [1:0] amount;
	logic [63:0] data;
	logic [63:0] q_dut;
	logic [63:0] q_ref;

	// Verification signals
	wire tb_match;
	wire tb_mismatch = ~tb_match;

	// Instantiate Stimulus Generator	
	stimulus_gen stim1 (
		.clk, clk,
		.load, load,
		ena, ena,
		.amount, amount,
		.data, data,
		.wavedrom_title, wavedrom_title,
		.wavedrom_enable, wavedrom_enable
	);

	// Instantiate Reference Model (Golden)	
	RefModule good1 (
		.clk, clk,
		.load, load,
		ena, ena,
		.amount, amount,
		.data, data,
		.q(q_ref)
	);

	// Instantiate DUT
	TopModule top_module1 (
		.clk, clk,
		.load, load,
		ena, ena,
		.amount, amount,
		.data, data,
		.q(q_dut)
	);

	// Initial setup and dumping
	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, tb);
		// Initialize signals
		load = 0;
		ena = 0;
		data = 64'h0;
		amount = 2'b00;
		$display("--- Starting Simulation ---");
	end

	// Task to display queue contents for mismatch
	task display_mismatch_queue;
		$display("\n==================================================================");
		$display("!!! MISMATCH DETECTED AT TIME %0t !!!", $time);
		$display("\nLast %0d cycles of simulation (MAX_QUEUE_SIZE=%0d):", input_data_q.size(), MAX_QUEUE_SIZE);
		$display("------------------------------------------------------------------");

		for (int i = 0; i < input_data_q.size(); i++) begin
			$display("Cycle %0d (Time %0t):", i, $time - (i * 10));
			$display("  Inputs: clk=%b, load=%b, ena=%b, amount=%b, data=%h (%b)", 
				clk_q[i], load, ena, amount_q[i], input_data_q[i], input_data_q[i]);
			$display("  Got Output (DUT): q=%h (%b)", got_output_q[i], got_output_q[i]);
			$display("  Expected Output (Ref): q=%h (%b)", golden_queue[i], golden_queue[i]);
			$display("------------------------------------------------------------------");
		end
		$display("==================================================================");
	endtask

	// Mismatch Detection and Queue Filling Logic
	always @(posedge clk, negedge clk) begin
			clocks++;

			// 1. Queue Management (FIFO logic)
			if (input_data_q.size() >= MAX_QUEUE_SIZE - 1) begin
				input_data_q.delete(0);
				got_output_q.delete(0);
				golden_queue.delete(0);
				amount_q.delete(0);
				clk_q.delete(0);
			end

			// 2. Store current values
			clk_q.push_back(clk);
			input_data_q.push_back(data);
			amount_q.push_back(amount);
			got_output_q.push_back(q_dut);
			golden_queue.push_back(q_ref);

			// 3. Check for first mismatch (Overall verification)
			if (q_ref !== ( q_ref ^ q_dut ^ q_ref )) begin // Logic from golden TB
				if (errors == 0) begin
					errortime = $time;
				errors_q = 1;
				end
				errors++;
			end
				
			// Check for first mismatch based on original TB logic (q_ref !== ( q_ref ^ q_dut ^ q_ref ))
			// Note: The original TB used two separate error counts. We merge them based on the requirement to follow original logic.
			if (q_ref !== ( q_ref ^ q_dut ^ q_ref )) begin
				if (errors_q == 0) begin
					errortime_q = $time;
				errors_q = 1;
				end
				end
			end
			
			// Check overall match (based on tb_match logic)
			if (!tb_match) begin
				// This block was already covered by the q_ref check above if we assume the original TB logic is sound.
				end
			end
			
			if (errors == 1 && errors_q == 1) begin // Trigger queue display only on first observed error
				display_mismatch_queue;
			end
			
		end
	end

	// Timeout
	initial begin
		h#1000000
		$display("TIMEOUT");
		$finish();
	end

	// Final Reporting (Replaces original 'final' block)
	initial begin
		// Wait for simulation to finish or timeout
		@(negedge clk);
		#1;
		
		// Check if any errors were found
		if (errors > 0) begin
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", errors, errortime);
			$finish();
			
		// Display the specific error queue information if it was triggered
			if (errors_q > 0) begin
				display_mismatch_queue;
			end
			
			$display("Total mismatched samples based on queue logic: %0d", errors_q);
			$finish();
			
		end else begin
			$display("SIMULATION PASSED");
			$finish();
		end
	end

endmodule
