		load <= 1;
		ena <= 0;
		data <= 64'h0000000000000000;
		amount <= 2'b00;
		@(posedge clk) data <= 64'h000100;
		wavedrom_start("Shifting");
			@(posedge clk) load <= 0; ena <= 1;
			amount <= 2'b10; // Original code used 2, which is 2'b10
			@(posedge clk) amount <= 2'b10;
			@(posedge clk) amount <= 2'b10;
