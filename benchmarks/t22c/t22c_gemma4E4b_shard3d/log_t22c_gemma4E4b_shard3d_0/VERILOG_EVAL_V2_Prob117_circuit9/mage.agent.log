// --- Testbench Module (Improved) ---
module tb();

	typedef struct packed {
		int errors;
		int errortime;
		int errors_q;
		int errortime_q;
		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		h#5 clk = ~clk;

	logic a;
	logic [2:0] q_ref; // Reference output
	logic [2:0] q_dut; // DUT output

	// --- Queue Management Declarations ---
	// q is 3 bits. MAX_QUEUE_SIZE >= 2^3 = 8. Set to 8.
	localparam MAX_QUEUE_SIZE = 8;
	
	// Signals to store in queues
	reg [2:0] input_a_q [$];
	reg [2:0] output_q_dut_q [$];
	reg [2:0] golden_q_ref_q [$];
	reg reset_q [$]; // Tracking reset/strobe proxy if needed, using 1-bit

	// Mismatch tracking for queue display
	reg mismatch_detected_q = 0;
	
	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stimulus_gen::stim1.clk, tb_mismatch, clk, a, q_ref, q_dut);
	end

	// Verification Signals
	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	// Instantiate DUT and stimulus
	stimulus_gen stim1 (
		.clk,
		.a,
		.wavedrom_title,
		.wavedrom_enable 
	);
	RefModule good1 (
		.clk,
		.a,
		.q(q_ref) );
	TopModule top_module1 (
		.clk,
		.a,
		.q(q_dut) );

	// Task to wait for time step end (Kept as is)
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end	task

	// Verification assignment (Kept as is)
	assign tb_match = ( { q_ref } === ( { q_ref } ^ { q_dut } ^ { q_ref } ) );

	// Clocked Process for Stats, Queueing, and Mismatch Reporting
	always @(posedge clk, negedge clk) begin
		// --- 1. Statistics Update (Original Logic) ---
		stats1.clocks++;
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
			end
		// Original q_ref vs q_dut check (kept for compatibility)
		if (q_ref !== ( q_ref ^ q_dut ^ q_ref ))
		begin 
			if (stats1.errors_q == 0) stats1.errortime_q = $time;
			sstats1.errors_q = stats1.errors_q+1'b1; 
		end
		
		// --- 2. Queue Management (New Requirement) ---
		
		// Dequeue if full
		if (input_a_q.size() >= MAX_QUEUE_SIZE - 1) begin
			input_a_q.delete(0);
			output_q_dut_q.delete(0);
			golden_q_ref_q.delete(0);
			reset_q.delete(0);
		end

		// Enqueue current data
		input_a_q.push_back(a);
		output_q_dut_q.push_back(q_dut);
		golden_q_ref_q.push_back(q_ref);
		reset_q.push_back(1'b0); // Assuming no explicit reset signal present

		// Check for first mismatch ONLY if not already detected
		if (!mismatch_detected_q && (q_dut !== q_ref)) begin
			mismatch_detected_q = 1;
			$display("================================================================================================");
			$display("!!! FIRST MISMATCH DETECTED AT TIME %0t !!!", $time);
			$display("Displaying Last %0d Cycles of Simulation (Queue Size: %0d):
", MAX_QUEUE_SIZE, input_a_q.size());

			for (int i = 0; i < input_a_q.size(); i++) begin
				// Check for mismatch in the historical window
				if (output_q_dut_q[i] !== golden_q_ref_q[i]) begin
					s$display("-> Mismatch occurred at Cycle %0d", i);
				end
				$display("Cycle %0d | Input a: %b | Ref q: %h (%b) | Got q: %h (%b)",
				i,
				input_a_q[i],
				golden_q_ref_q[i],
				golden_q_ref_q[i], 
				output_q_dut_q[i],
				output_q_dut_q[i]);
			end
			$display("================================================================================================");
		end
	end

	// Timeout logic (Kept as is)
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

	// Final reporting logic (Updated) 
	final begin
		if (stats1.errors == 0) 
			$display("SIMULATION PASSED");
		else 
			$display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0d", stats1.errors, stats1.errortime);
	end

endmodule
