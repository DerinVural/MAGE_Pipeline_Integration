                 (x[1]==0 && x[0]==0) ? 1'b1 : 
                 (x[1]==0 && x[0]==1) ? 1'b1 : 
                 (x[1]==0 && x[0]==3) ? 1'b0 : 
                 (x[1]==1 && x[0]==0) ? 1'b1 : 1'b0 ) 
             );

endmodule

