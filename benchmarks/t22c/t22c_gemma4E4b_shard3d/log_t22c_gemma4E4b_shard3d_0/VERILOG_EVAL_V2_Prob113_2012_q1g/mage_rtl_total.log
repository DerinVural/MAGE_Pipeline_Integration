	assign tb_match = ( { f_ref } === ( { f_ref } ^ { f_dut } ^ { f_ref } ) );

	// Sensitivity list must be broad to capture changes during clock edges
always @(posedge clk, negedge clk) begin
		
		stats1.clocks++;
		
