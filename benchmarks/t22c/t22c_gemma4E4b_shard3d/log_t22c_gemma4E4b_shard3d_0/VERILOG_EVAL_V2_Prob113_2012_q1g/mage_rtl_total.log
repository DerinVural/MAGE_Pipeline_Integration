[2026-05-15 10:56:36,070 - mage.agent - INFO] 
`timescale 1 ps/1 ps
`define OK 12
`define INCORRECT 13


module stimulus_gen (
	input clk,
	output logic [3:0] x
);
	initial begin
		repeat(100) @(posedge clk, negedge clk) begin
		x <= $random;
		end
		#1 $finish;
	end
	endmodule

module tb();
	typedef struct packed {
		int errors;
		int errortime;
		int errors_f;
		int errortime_f;
		int clocks;
	} stats;
	
	stats stats1;
	
	// Variables to store first mismatch details
	logic [3:0] x_first_mismatch;
	logic f_ref_first_mismatch;
	logic f_dut_first_mismatch;
	int time_first_mismatch = -1;
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic [3:0] x;
	logic f_ref;
	logic f_dut;

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,x,f_ref,f_dut );
	end

	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk, 
		.* , 
		.x );
	RefModule good1 (
		.x, 
		.f(f_ref) );
	
	TopModule top_module1 (
		.x, 
		.f(f_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
		strobe <= !strobe;  // Try to delay until the very end of the time step.
		@(strobe);
		end
task
		endtask

	
	// --- Improved Final Check Logic ---
	initial begin
		#1000000 // Wait for stimulus_gen timeout if it runs longer
		
		if (stats1.errors > 0 || stats1.errors_f > 0) begin
			$display("============================================================");
			$display("SIMULATION FAILED - x MISMATCHES DETECTED, FIRST AT TIME %0d", time_first_mismatch);
			$display("--- First Mismatch Details (tb_mismatch) ---");
			$display("Time: %0d ps", time_first_mismatch);
			$display("Input x: HEX=%h, BIN=%b", x_first_mismatch, x_first_mismatch);
			$display("Expected f_ref: HEX=%b", f_ref_first_mismatch);
			$display("Actual f_dut: HEX=%b", f_dut_first_mismatch);
			$display("------------------------------------------------------------");
			
			if (stats1.errors_f > 0) begin
				$display("--- First Mismatch Details (f_ref comparison) ---");
				$display("Time: %0d ps", stats1.errortime_f);
				$display("Input x: HEX=%h, BIN=%b", x_first_mismatch, x_first_mismatch); // Reusing x from first error time for simplicity, though technically we should store it
				$display("Expected f_ref: HEX=%b", f_ref_first_mismatch);
				$display("Actual f_dut: HEX=%b", f_dut_first_mismatch);
				$display("------------------------------------------------------------");
			end
			$display("============================================================");
		end else begin
			$display("============================================================");
			$display("SIMULATION PASSED");
			$display("============================================================");
		end
		$finish;
	end

	// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.
	assign tb_match = ( { f_ref } === ( { f_ref } ^ { f_dut } ^ { f_ref } ) );

	// Sensitivity list must be broad to capture changes during clock edges
always @(posedge clk, negedge clk) begin
		
		stats1.clocks++;
		
		// --- Overall Mismatch Tracking ---
		if (!tb_match) begin
			if (stats1.errors == 0) begin
			stats1.errortime = $time;
			time_first_mismatch = $time;
			x_first_mismatch = x;
			f_ref_first_mismatch = f_ref;
			f_dut_first_mismatch = f_dut;
			end
			sstats1.errors++;
		end

		// --- f_ref comparison Mismatch Tracking ---
		if (f_ref !== ( f_ref ^ f_dut ^ f_ref ))
		begin 
			if (stats1.errors_f == 0) stats1.errortime_f = $time;
			sstats1.errors_f = stats1.errors_f+1'b1;
		end
	end

   // Original timeout added for safety
   initial begin
     #1000000
     $display("TIMEOUT REACHED");
     $finish();
   end
	endmodule

