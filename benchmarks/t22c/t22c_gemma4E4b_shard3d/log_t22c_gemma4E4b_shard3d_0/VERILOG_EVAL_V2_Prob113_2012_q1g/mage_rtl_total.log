// f = 1 | 0 | 0 | 1
// f = 0 | 0 | 0 | 0
// f = 1 | 1 | 1 | 0
// f = 1 | 1 | 0 | 1
module TopModule (
    input  logic [3:0] x,
    output logic f
);
    // x[3]x[2] is the row, x[1]x[0] is the column
    // Map rows (x[3]x[2]) to 00, 01, 11, 10
    // Map columns (x[1]x[0]) to 00, 01, 11, 10
    
    // The K-map seems to be indexed as: Row=x[2]x[3], Col=x[0]x[1]
    // Row 00 (x[3]x[2]=00): 1, 0, 0, 1 (for col 00, 01, 11, 10)
    // Row 01 (x[3]x[2]=01): 0, 0, 0, 0
    // Row 11 (x[3]x[2]=11): 1, 1, 1, 0
    // Row 10 (x[3]x[2]=10): 1, 1, 0, 1

    assign f = ( (x[3]==0 && x[2]==0) ? 
                 (x[1]==0 && x[0]==0) ? 1'b1 : 
                 (x[1]==0 && x[0]==1) ? 1'b0 : 
                 (x[1]==0 && x[0]==3) ? 1'b0 : 
