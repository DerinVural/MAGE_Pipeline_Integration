endmodule

module tb();
	
	typedef struct packed {
		int errors;
		int errortime;
		int errors_f;
		int errortime_f;

		int clocks;
	} stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic [3:0] x;
	logic f_ref;
	logic f_dut;

	// Variables to track first mismatch time for final display
	integer first_mismatch_time = -1;
	
	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stimulus_gen::clk, tb_mismatch, x, f_ref, f_dut );
	end

	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk, 
		.* , 
		.x );
		
		// RefModule must be defined or assumed available, using the structure from golden TB
		RefModule good1 (
			.x, 
			.f(f_ref) );
		
		TopModule top_module1 (
			.x,
			.f(f_dut) );

		
		bit strobe = 0;
		task wait_for_end_of_timestep;
			repeat(5) begin
			strobe <= !strobe;  // Try to delay until the very end of the time step.
			@(strobe);
			end
		endtask
	
		// Initialize stats
		stats1 = '{errors: 0, errortime: 0, errors_f: 0, errortime_f: 0, clocks: 0};
	end

	// Verification check
	// Note: The original check was: assign tb_match = ( { f_ref } === ( { f_ref } ^ { f_dut } ^ { f_ref } ) );
	// Since f_ref is 1-bit, this simplifies to: f_ref == (f_ref ^ f_dut ^ f_ref) => f_ref == f_dut.
	// We maintain the original assignment structure for strict adherence, though it resolves to f_ref == f_dut.
	assign tb_match = ( { f_ref } === ( { f_ref } ^ { f_dut } ^ { f_ref } ) );

	// Verification logic (Modified for Combinational Mismatch Display)
	always @(posedge clk, negedge clk) begin
		
		stats1.clocks++;

		// Check for overall mismatch (maintaining original error counting)
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			sstats1.errors++;
			if (first_mismatch_time == -1) first_mismatch_time = $time;
			end
		
		// Check for specific output mismatch (maintaining original error counting)
		if (f_ref !== ( f_ref ^ f_dut ^ f_ref ))
		begin 
			if (stats1.errors_f == 0) stats1.errortime_f = $time;
			sstats1.errors_f = stats1.errors_f + 1'b1;
		end
	end

	// Combinational Mismatch Display Check (Triggered when inputs change, or we check it every cycle for simplicity based on TB structure)
	// Since the DUT is combinational, we check the mismatch condition directly here, tied to the clock for timing consistency.
	always @(*) begin
		if (f_dut !== f_ref) begin
			// We must check if this is the FIRST mismatch, to capture the time correctly.
			if (first_mismatch_time == -1) begin
				first_mismatch_time = $time; // Capture time based on simulation clock progression
			end
		end
	end

	// Simulation End Block (Replaces the original final block)
	initial begin
		// Wait until the stimulus generation finishes (100 cycles + a little buffer)
		@(posedge clk) wait (stim1.x != $random);
		#5;
		
		// Final Mismatch Check for the specific requirement:
		if (stats1.errors > 0) begin
			$display("SIMULATION FAILED - x MISMATCHES DETECTED, FIRST AT TIME %0t", first_mismatch_time);
			// Display the state at the first mismatch time (Combinational logic requirement)
			$display("\n--- FIRST MISMATCH DETECTED ---");
			$display("Time: %0t ps", first_mismatch_time);
			$display("Input x: %h (Binary: %b)", x, x);
			$display("Expected f_ref: %b (Hex: %h)", f_ref, f_ref);
			$display("Got f_dut: %b (Hex: %h)", f_dut, f_dut);
			end
		else begin
			$display("SIMULATION PASSED");
			end
		
		// Maintain original statistical output for debugging/completeness if needed
		$display("Hint: Output 'f' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_f, stats1.errortime_f);
		$display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
		$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
		
		$finish;
	end

	// add timeout after 100K cycles (Maintained from golden TB)
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

endmodule

