			$display("Queue-based simulation mismatch display (Last %0d cycles):", j_queue.size());
			
			for (int i = 0; i < j_queue.size(); i++) begin
				if (out_dut_queue[i] === out_ref_queue[i]) begin
				$display("Cycle %d: Got Match.", i);
				// Displaying inputs/outputs in HEX/BIN format
				$display("         Time: %0d ps | Reset: %b | J: %b | K: %b | Got Out: %h (%b) | Exp Out: %h (%b)",
