				// Capture state at first output mismatch
				captured_inputs_fail_out = {clk, reset, j, k};
				captured_outputs_fail_out = out_ref;
				fail_time_out = $time;
			stats1.errors_out = stats1.errors_out+1'b1;
			end
		end
	end

   // add timeout after 100K cycles
   initial begin
     #1000000
     $display("\nTIMEOUT REACHED");
     $finish();
   end

   // Custom reporting task to handle display format requirements
task report_failure(int time_val, logic [511:0] inputs_val, logic expected_out, logic actual_out, string type);
	begin
		s$display("\n=======================================================================");
		s$display("SIMULATION FAILED - 1 MISMATCHES DETECTED, FIRST AT TIME %0d", time_val);
		s$display("Type: %s", type);
		$display("-----------------------------------------------------------------------");
		$display("Input Signals:");
		$display("  clk: %b", inputs_val[0]);
		$display("  reset: %b", inputs_val[1]);
		$display("  j: %b", inputs_val[2]);
		$display("  k: %b", inputs_val[3]);
		$display("Output Signals:");
		$display("  Expected (out_ref): %h (%b)", expected_out, expected_out);
		$display("  Actual (out_dut):   %h (%b)", actual_out, actual_out);
		$display("=======================================================================\n");
	endtask

	initial begin
		if (stats1.errors_out > 0) begin
			// Report specific output mismatch
			report_failure(fail_time_out, captured_inputs_fail_out, captured_outputs_fail_out, out_dut, "OUTPUT MISMATCH");
			$finish();
		end
		if (stats1.errors > 0) begin
			// Report general mismatch (if output mismatch wasn't the very first error, or if errors are different)
			report_failure(fail_time_gen, captured_inputs_fail_gen, captured_outputs_fail_gen, out_dut, "GENERAL MISMATCH");
			$finish();
		end
	end

