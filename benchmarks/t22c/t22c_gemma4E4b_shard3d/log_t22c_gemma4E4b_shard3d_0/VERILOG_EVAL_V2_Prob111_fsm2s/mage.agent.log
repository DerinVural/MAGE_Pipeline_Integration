		if (j_queue.size() >= MAX_QUEUE_SIZE - 1) begin
			j_queue.delete(0);
			k_queue.delete(0);
			reset_queue.delete(0);
			out_dut_queue.delete(0);
			out_ref_queue.delete(0);
			clk_queue.delete(0);
		end

		// 2. Push Current State/Inputs/Outputs to Queue
		clk_queue.push_back(clk);
		j_queue.push_back(j);
		k_queue.push_back(k);
		reset_queue.push_back(reset);
		out_dut_queue.push_back(out_dut);
		out_ref_queue.push_back(out_ref);

