	// Helper task to display state information
task display_mismatch_state(int time_val, logic [511:0] inputs_val, logic outputs_val, string failure_type);
	begin
		s$display("\n=======================================================================");
		s$display("FAILURE DETECTED (Type: %s) at TIME: %0d ps", failure_type, time_val);
		$display("-----------------------------------------------------------------------");
		$display("Input Signals:");
		$display("  clk: %b", inputs_val[0]);
		$display("  reset: %b", inputs_val[1]);
		$display("  j: %b", inputs_val[2]);
		$display("  k: %b", inputs_val[3]);
