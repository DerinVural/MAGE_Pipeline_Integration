			 (x[3]==1'b0 && x[0]==1'b1 && x[1]==1'b0 && x[2]==1'b0) ? 1'b0 : // R=01, C=00 (0)
			 (x[3]==1'b0 && x[0]==1'b1 && x[1]==1'b0 && x[2]==1'b1) ? 1'b0 : // R=01, C=01 (d->0)
			 (x[3]==1'b0 && x[0]==1'b1 && x[1]==1'b1 && x[2]==1'b1) ? 1'b1 : // R=01, C=11 (1)
