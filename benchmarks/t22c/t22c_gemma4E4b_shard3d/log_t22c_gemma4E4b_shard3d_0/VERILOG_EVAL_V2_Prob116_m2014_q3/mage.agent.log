			 (x[3]==1'b1 && x[0]==1'b1 && x[1]==1'b1 && x[2]==1'b1) ? 1'b0 : // R=11, C=11 (d->0)
			 (x[3]==1'b1 && x[0]==1'b1 && x[1]==1'b1 && x[2]==1'b0) ? 1'b0 : // R=11, C=10 (d->0)
			 
