// --- DUT Implementation (Based on K-map interpretation) ---
module TopModule (
    input logic [3:0] x,
    output logic f
);
		// Interpreting K-map: R = x[3]x[0], C = x[1]x[2]. Choosing 0 for 'd'.
		// (R=00, C=00)->0, (R=00, C=01)->0, (R=00, C=11)->0, (R=00, C=10)->0
