module stimulus_gen (
	input clk,
	output logic [3:0] x
);
	
	initial begin
		repeat(100) @(posedge clk, negedge clk) begin
			x <= $random;
		end
		
		#1 $finish;
	end
	
endmodule

module tb();
	
	typedef struct packed {
		int errors;
		int errortime;
		int errors_f;
		int errortime_f;

		int clocks;
	}
	stats;
	
	stats stats1;
	
	
	wire[511:0] wavedrom_title;
	wire wavedrom_enable;
	int wavedrom_hide_after_time;
	
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic [3:0] x;
	logic f_ref;
	logic f_dut;

	// Variables to capture first mismatch details for combinational display requirement
	logic first_mismatch_detected = 0;
	logic [3:0] x_at_first_mismatch;
	logic f_dut_at_first_mismatch;
	logic f_ref_at_first_mismatch;
	integer first_mismatch_time = 0;

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,x,f_ref,f_dut );
	end


	wire tb_match;
	wire tb_mismatch = ~tb_match;
	
	stimulus_gen stim1 (
		.clk,
		.* ,
		.x );
	RefModule good1 (
		.x,
		.f(f_ref) );
	
	TopModule top_module1 (
		.x,
		.f(f_dut) );

	
	bit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
			strobe <= !strobe;  // Try to delay until the very end of the time step.
			@(strobe);
		end
	endtask

	
	// Original Error Counting Logic
	always @(posedge clk, negedge clk) begin
		stats1.clocks++;
		
		// Error counting (Original functionality maintained)
		if (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			sstats1.errors++;
		end
		
		if (f_ref !== ( f_ref ^ f_dut ^ f_ref ))
		begin 
			if (stats1.errors_f == 0) stats1.errortime_f = $time;
			sstats1.errors_f = stats1.errors_f+1'b1; 
		end
	end

		// Logic to capture first mismatch for detailed combinational display
		if (!tb_match && !first_mismatch_detected) begin
			first_mismatch_detected = 1;
			x_at_first_mismatch = x;
			f_dut_at_first_mismatch = f_dut;
			f_ref_at_first_mismatch = f_ref;
			first_mismatch_time = $time;
		end
		end

	// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.
	assign tb_match = ( { f_ref } === ( { f_ref } ^ { f_dut } ^ { f_ref } ) );

	
	final begin
		// --- Detailed Mismatch Display (Combinational Requirement) ---
		if (first_mismatch_detected)
		begin
			$display("SIMULATION FAILED - x MISMATCHES DETECTED, FIRST AT TIME %0d", first_mismatch_time);
			$display("--- First Mismatch Details ---");
			$display("Time: %0d ps", first_mismatch_time);
			$display("Input x (Binary): %b, Hex: %h", x_at_first_mismatch, x_at_first_mismatch);
			$display("Output f (DUT): Binary=%b, Hex=%h", f_dut_at_first_mismatch, f_dut_at_first_mismatch);
			$display("Expected f (Ref): Binary=%b, Hex=%h", f_ref_at_first_mismatch, f_ref_at_first_mismatch);
		end
		else
		begin
			$display("SIMULATION PASSED");
		end
		
		// Maintain original summary logic for backward compatibility, though the new final block supersedes the required output format
		if (stats1.errors_f) $display("Hint: Output '%s' has %0d mismatches. First mismatch occurred at time %0d.", "f", stats1.errors_f, stats1.errortime_f);
		else $display("Hint: Output '%s' has no mismatches.", "f");
		
		$display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
		$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
		end

	// add timeout after 100K cycles
	initial begin
		#1000000
		$display("TIMEOUT");
		$finish();
	end

endmodule
