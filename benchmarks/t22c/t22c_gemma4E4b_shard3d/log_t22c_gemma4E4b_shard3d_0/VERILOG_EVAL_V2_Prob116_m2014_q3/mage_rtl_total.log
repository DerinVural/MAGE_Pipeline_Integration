		logic f_internal;
		
		// Logic derived from the table, assuming R=x[3]x[0] and C=x[1]x[2]
		assign f_internal = 
			 (x[3]==1'b0 && x[0]==1'b0 && x[1]==1'b0 && x[2]==1'b0) ? 1'b0 : // R=00, C=00 (d->0)
			 (x[3]==1'b0 && x[0]==1'b0 && x[1]==1'b0 && x[2]==1'b1) ? 1'b0 : // R=00, C=01 (0)
