always @(posedge clk, negedge clk) begin
	stats1.clocks++;	if (!tb_match) begin		if (stats1.errors == 0) stats1.errortime = $time;		stats1.errors++;	end	if (Q_ref !== ( Q_ref ^ Q_dut ^ Q_ref ))
	begin		if (stats1.errors_Q == 0) stats1.errortime_Q = $time;		stats1.errors_Q = stats1.errors_Q+1'b1; 	end	
end

   // add timeout after 100K cycles
   initial begin	 #1000000	 $display("TIMEOUT");	 $finish();	end

endmodule
