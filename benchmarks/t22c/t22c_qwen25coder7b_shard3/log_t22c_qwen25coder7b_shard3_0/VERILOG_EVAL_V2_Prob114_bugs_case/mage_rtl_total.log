    "testbench": "`timescale 1 ps/1 ps\n\nmodule tb();\n\ntypedef struct packed {\n\tint errors;\n\tint errortime;\n\tint errors_out;\n\tint errortime_out;\n\tint errors_valid;\n\tint errortime_valid;\n\tint clocks;\n} stats;\n\nstats stats1;\n\nwire [511:0] wavedrom_title;\nwire wavedrom_enable;\n\nreg clk = 0;\ninitial forever #5 clk = ~clk;\n\nlogic [7:0] code;\nlogic [3:0] out_ref;\nlogic [3:0] out_dut;\nlogic valid_ref;\nlogic valid_dut;\n\ninitial begin \n\t$dumpfile(\"wave.vcd\");\n\t$dumpvars(1, stim1.clk, tb_mismatch ,code,out_ref,out_dut,valid_ref,valid_dut );\nend\n\nwire tb_match; // Verification\nwire tb_mismatch = ~tb_match;\n\nstimulus_gen stim1 (\n\t.clk(clk),\n\t.* ,\n\t.code(code)\n);\n\nRefModule good1 (\n\t.code(code),\n\t.out(out_ref),\n\t.valid(valid_ref)\n);\n\nTopModule_top_module top_module1 (\n\t.code(code),\n\t.out(out_dut),\n\t.valid(valid_dut)\n);\n\nbit strobe = 0;\ntask wait_for_end_of_timestep;\n\trepeat(5) begin\n\t\tstrobe <= !strobe;  // Try to delay until the very end of the time step.\n\t\t@(strobe);\n\tend\nendtask\t\n\nfinal begin\n\tif (stats1.errors_out) begin\n\t\t$display(\"Hint: Output '\"out\"' has \"%0d\" mismatches. First mismatch occurred at time \"%0d\".", 
