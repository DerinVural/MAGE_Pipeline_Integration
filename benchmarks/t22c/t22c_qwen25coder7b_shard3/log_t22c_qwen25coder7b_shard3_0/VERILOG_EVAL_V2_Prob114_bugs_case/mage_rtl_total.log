wire[511:0] wavedrom_title;
wire wavedrom_enable;
int wavedrom_hide_after_time;

reg clk=0;
initial forever
	#5 clk = ~clk;

logic [7:0] code;
logic [3:0] out_ref;
logic [3:0] out_dut;
logic valid_ref;
logic valid_dut;

