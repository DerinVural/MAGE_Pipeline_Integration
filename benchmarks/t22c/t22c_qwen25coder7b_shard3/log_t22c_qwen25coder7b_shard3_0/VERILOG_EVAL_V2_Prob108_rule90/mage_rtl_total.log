    input logic clk,
    input logic load,
    input logic [511:0] data,
    output logic [511:0] q
);

    // Initialize q_reg to zero on the rising edge of the clock
    always_ff @(posedge clk) begin
        if (load)
            q_reg <= data;
        else
            q_reg <= q_reg;
    end

    // Combinational logic to calculate the next state based on Rule 90
    logic [511:0] q_next;
    always_comb begin
        for (int i = 0; i < 512; i++) begin
            // Calculate the left neighbor with boundary conditions
            logic left = (i == 0) ? 0 : q_reg[i-1];
            // Calculate the right neighbor with boundary conditions
            logic right = (i == 511) ? 0 : q_reg[i+1];
            // Apply Rule 90
            q_next[i] = (left ^ right) ^ q_reg[i];
        end
    end

    // Assign the calculated next state to the output
    assign q = q_next;

