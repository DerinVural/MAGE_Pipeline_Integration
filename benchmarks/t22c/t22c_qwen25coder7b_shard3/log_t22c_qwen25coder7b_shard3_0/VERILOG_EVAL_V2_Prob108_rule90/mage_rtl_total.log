    end
    repeat(20) @(posedge clk) data <= data + 1;
    repeat(500) @(posedge clk) begin
    end

    #(1) $finish;
  end

endmodule


module tb ();

  typedef struct packed {
    int errors;
    int errortime;
    int errors_q;
    int errortime_q;

    int clocks;
  } stats;

  stats stats1;


