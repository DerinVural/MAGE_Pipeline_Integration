  input logic clk,
  input logic load,
  input logic [511:0] data,
  output logic [511:0] q
);

  // Define the 512-cell array with padding
  logic [511:0] cells;

  initial begin
    cells = 0;
  end

  always @(posedge clk) begin
    if (load)
      cells = {data, 0};
  end

  // Calculate the new state of the cells
  logic [511:0] new_cells;
  always @(*) begin
