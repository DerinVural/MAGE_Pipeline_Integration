[2026-05-14 12:27:57,015 - mage.rtl_editor - INFO] module TopModule (
    input logic clk,
    input logic load,
    input logic [511:0] data,
    output logic [511:0] q
);

    // Initialize the 512-cell system with zeros
    logic [511:0] q_reg;
    initial begin
        q_reg = 0;
    end

    // Sequential logic to update the state of each cell
    always_ff @(posedge clk) begin
        if (load)
            q_reg = data;
        else begin
            logic [511:0] new_state;
            new_state[0] = (q_reg[1] != q_reg[511]);
            new_state[511] = (q_reg[510] != q_reg[0]);
            for (int i = 1; i < 511; i++)
                new_state[i] = (q_reg[i-1] != q_reg[i+1]);
            q_reg = new_state;
        end
    end

    // Assign the output to the register
    assign q = q_reg;

endmodule
