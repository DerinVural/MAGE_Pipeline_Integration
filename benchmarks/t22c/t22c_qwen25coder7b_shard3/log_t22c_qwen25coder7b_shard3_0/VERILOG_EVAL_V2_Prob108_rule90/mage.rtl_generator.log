    input logic load,
    input logic [511:0] data,
    output logic [511:0] q
);

    // Initialize q to zero
    logic [511:0] q_reg;

    // Initial block to set the initial value of q_reg
    initial begin
        q_reg = 512'b0;
    end

    // Always block to update q_reg on the positive edge of the clock
    always @(posedge clk) begin
        if (load)
            q_reg <= data;
    end

    // Combinational logic to calculate the next state based on Rule 90
    logic [511:0] q_next;
    always @(*) begin
        for (int i = 0; i < 512; i++) begin
            // Calculate the left neighbor with boundary conditions
