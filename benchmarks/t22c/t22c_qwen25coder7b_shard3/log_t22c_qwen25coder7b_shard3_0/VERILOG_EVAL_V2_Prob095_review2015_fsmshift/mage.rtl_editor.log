[2026-05-14 11:55:19,537 - mage.rtl_editor - INFO] module TopModule(
    input  logic clk,
    input  logic reset,
    output logic shift_ena
);

    logic [1:0] counter;
    logic shift_ena_reg;

    // Initializations
    initial begin
        shift_ena_reg = 1'b0;
        counter = 2'b00;
    end

    // Sequential logic
    always_ff @(posedge clk or posedge reset) begin
        if (reset) begin
            shift_ena_reg <= 1'b1;
            counter <= 2'b00;
        end else begin
            if (shift_ena_reg && counter < 2'b10) begin
                counter <= counter + 1;
            end else if (counter >= 2'b10) begin
                shift_ena_reg <= 1'b0;
                counter <= 2'b00;
            end
        end
    end

    // Combinational logic
    always @(*) begin
        shift_ena = shift_ena_reg;
    end

endmodule;
