// Define FSM states
localparam IDLE = 2'b00;
localparam COUNT_1 = 2'b01;
localparam COUNT_2 = 2'b10;
localparam ASSERT_ENA = 2'b11;

// State register
logic [1:0] state;

// Internal counters
logic [1:0] count;

// Initial values
initial begin
    state = IDLE;
    count = 2'b00;
end

// Clock edge triggered sequential logic
always @(posedge clk) begin
    if (reset) begin
        state <= IDLE;
        count <= 2'b00;
    end else begin
        case (state)
            IDLE: begin
                if (count == 2'b00) begin
                    count <= count + 1;
                end else begin
                    state <= COUNT_1;
                    count <= 2'b00;
                end
            end
            COUNT_1: begin
                state <= COUNT_2;
            end
            COUNT_2: begin
                state <= ASSERT_ENA;
            end
            ASSERT_ENA: begin
                state <= IDLE;
            end
        endcase
    end
end

// Combinational logic to drive shift_ena
assign shift_ena = (state == ASSERT_ENA);

endmodule
