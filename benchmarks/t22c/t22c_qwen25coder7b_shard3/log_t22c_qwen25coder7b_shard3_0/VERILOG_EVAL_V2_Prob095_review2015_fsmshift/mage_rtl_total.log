    state_next = state;
    count_next = count;
    case(state)
        IDLE:
            begin
                if (/* condition to detect the bit pattern */) // Example condition: 2 consecutive ones
                    state_next = ENABLED;
            end
        ENABLED:
            begin
                state_next = COUNTING;
                count_next = 1;
            end
        COUNTING:
            begin
                if (count < 3)
                    count_next = count + 1;
                else
                    state_next = IDLE;
            end
        default:
            begin
                state_next = IDLE;
                count_next = 0;
            end
    endcase
end

// Output assignment
assign shift_ena = (state == COUNTING);

endmodule
