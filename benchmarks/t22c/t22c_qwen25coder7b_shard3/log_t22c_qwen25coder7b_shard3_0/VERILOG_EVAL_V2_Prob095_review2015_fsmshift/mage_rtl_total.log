[2026-05-14 11:55:21,355 - mage.rtl_editor - INFO] module TopModule(
    input  logic clk,
    input  logic reset,
    output logic shift_ena
);

    logic [1:0] counter;
    logic shift_ena_reg;

    // Initializations
    initial begin
        shift_ena_reg = 1'b0;
        counter = 2'b00;
    end

    // Sequential logic
    always_ff @(posedge clk or posedge reset) begin
