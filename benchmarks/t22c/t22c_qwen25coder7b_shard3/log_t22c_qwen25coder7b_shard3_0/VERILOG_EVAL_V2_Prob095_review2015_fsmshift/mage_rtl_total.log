            ASSERT_ENA: begin
                if (reset || current_count >= 4) begin
                    next_state = IDLE;
                end else begin
                    next_state = ASSERT_ENA;
                end
            end
        endcase
    end

    // Shift counter logic
    logic [1:0] current_count;
    always @(posedge clk or posedge reset) begin
        if (reset) begin
            current_count <= 2'b00;
