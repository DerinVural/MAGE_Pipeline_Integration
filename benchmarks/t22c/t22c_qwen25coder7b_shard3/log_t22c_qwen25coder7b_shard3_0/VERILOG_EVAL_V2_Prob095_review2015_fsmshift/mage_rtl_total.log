localparam IDLE = 2'b00;
localparam ONE_DETECTED = 2'b01;
localparam TWO_DETECTED = 2'b10;
localparam THREE_DETECTED = 2'b11;

// Register to store current state
data_t state;

// Register to count consecutive ones
data_t count;

// Always block for updating the state and count on the rising edge of the clock
always @(posedge clk) begin
