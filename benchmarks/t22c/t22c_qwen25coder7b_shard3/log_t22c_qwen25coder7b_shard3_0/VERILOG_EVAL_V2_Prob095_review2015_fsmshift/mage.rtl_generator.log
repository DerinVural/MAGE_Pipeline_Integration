COUNTING: begin
cycle_count_next = cycle_count + 1;
if (cycle_count >= 3) begin
state_next = DONE;
ena_reg_next = 0;
end
end
DONE: begin
end
endcase
end

// Output logic
assign shift_ena = ena_reg;

endmodule
