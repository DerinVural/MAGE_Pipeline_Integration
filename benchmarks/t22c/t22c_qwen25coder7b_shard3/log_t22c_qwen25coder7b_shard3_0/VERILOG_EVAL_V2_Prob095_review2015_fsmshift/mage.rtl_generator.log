if (cycle_count >= 3) begin
state_next = COUNTING;
ena_reg_next = 1;
end
end
COUNTING: begin
cycle_count_next = cycle_count + 1;
if (cycle_count >= 3) begin
state_next = DONE;
ena_reg_next = 0;
end
end
DONE: begin
ena_reg_next = 0;
end
default: begin
state_next = IDLE;
cycle_count_next = 0;
ena_reg_next = 0;
end
