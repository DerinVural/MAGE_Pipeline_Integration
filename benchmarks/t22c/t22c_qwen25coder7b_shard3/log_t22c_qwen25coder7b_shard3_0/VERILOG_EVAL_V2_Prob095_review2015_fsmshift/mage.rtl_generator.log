// Reset handling
initial begin
cycle_count = 0;
ena_reg = 0;
end

// State transition logic
always @(posedge clk or posedge reset) begin
if (reset) begin
state <= IDLE;
end else begin
state <= state_next;
end
end

// Cycle count transition logic
always @(posedge clk or posedge reset) begin
if (reset) begin
cycle_count <= 0;
end else begin
cycle_count <= cycle_count_next;
end
end

// Ena_reg transition logic
always @(posedge clk or posedge reset) begin
if (reset) begin
ena_reg <= 0;
end else begin
ena_reg <= ena_reg_next;
end
end

// Next state logic
always @(*) begin
state_next = state;
cycle_count_next = cycle_count;
ena_reg_next = ena_reg;

switch (state) begin
IDLE: begin
if (/* specific bit pattern detected */) begin
