typedef enum logic [2:0] {
	IDLE,
	ONE_DETECTED,
	TWO_ONES_DETECTED,
	FOUR_ONES_DETECTED
} state_t;

localparam IDLE_VAL = 3'b000,
	ONE_DETECTED_VAL = 3'b001,
	TWO_ONES_DETECTED_VAL = 3'b010,
	FOUR_ONES_DETECTED_VAL = 3'b011;

// State Register
logic [2:0] state = IDLE_VAL;

// Counter to keep track of consecutive ones
logic [1:0] ones_count = 2'd0;

// Internal signal to handle the final assertion of shift_ena
logic shift_ena_internal = 0;

always_ff @(posedge clk or posedge reset) begin
	if (reset)
	begin
		state <= IDLE_VAL;
		ones_count <= 2'd0;
		shift_ena_internal <= 0;
	end
	else
	begin
		case (state)
		IDLE: if (ones_count == 2'd2)
			state <= ONE_DETECTED_VAL;
		ONE_DETECTED: if (ones_count == 2'd3)
			state <= TWO_ONES_DETECTED_VAL;
		TWO_ONES_DETECTED: if (ones_count == 2'd4)
			state <= FOUR_ONES_DETECTED_VAL;
		FOUR_ONES_DETECTED: state <= IDLE_VAL;
		default: state <= IDLE_VAL;
		endcase
		if (state == FOUR_ONES_DETECTED_VAL)
			shift_ena_internal <= 1;
	end
end

assign shift_ena = shift_ena_internal;

endmodule
