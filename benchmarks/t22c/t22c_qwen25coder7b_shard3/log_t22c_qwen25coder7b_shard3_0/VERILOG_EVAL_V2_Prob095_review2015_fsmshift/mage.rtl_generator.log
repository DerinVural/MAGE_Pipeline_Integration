localparam IDLE = 2'b00;
localparam COUNTING = 2'b01;
localparam DONE = 2'b10;

logic [1:0] state;
always_ff @(posedge clk or posedge reset) begin
    if (reset)
        state <= IDLE;
    else begin
        case(state)
            IDLE: state <= (reset) ? IDLE : COUNTING;
            COUNTING: state <= (count == 4'd4) ? DONE : COUNTING;
            DONE: state <= IDLE;
        endcase
    end
end

logic [1:0] count;
always_ff @(posedge clk or posedge reset) begin
    if (reset)
        count <= 4'd0;
    else begin
        if (state == COUNTING)
            count <= count + 4'd1;
    end
end

assign shift_ena = (state == COUNTING);

endmodule;
