// Define states using localparams
localparam IDLE = 2'b00;
localparam ENABLED = 2'b01;
localparam COUNTING = 2'b10;

// Signals
logic [1:0] state;
logic [1:0] state_next;
logic [1:1] count;
logic [1:1] count_next;

// Initialize signals
initial begin
    state = IDLE;
    count = 0;
end

// Sequential logic
always @(posedge clk) begin
    if (reset)
        begin
            state <= IDLE;
            count <= 0;
        end
    else
        begin
            state <= state_next;
            count <= count_next;
        end
end

// Next state and count logic
always @(*) begin
    state_next = state;
    count_next = count;
    case(state)
        IDLE:
            begin
                if (/* condition to detect the bit pattern */) // Example condition: 2 consecutive ones
                    state_next = ENABLED;
            end
        ENABLED:
            begin
                state_next = COUNTING;
                count_next = 1;
            end
        COUNTING:
            begin
                if (count < 3)
                    count_next = count + 1;
                else
                    state_next = IDLE;
            end
        default:
            begin
                state_next = IDLE;
                count_next = 0;
            end
    endcase
end

// Output assignment
assign shift_ena = (state == COUNTING);

endmodule
