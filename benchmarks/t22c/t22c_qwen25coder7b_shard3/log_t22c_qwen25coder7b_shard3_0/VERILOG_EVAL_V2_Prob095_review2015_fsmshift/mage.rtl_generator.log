			ENABLED_1: enable_count_next = 2'b01;
			ENABLED_2: enable_count_next = 2'b10;
			default: state_next = IDLE;
		endcase
	end
	
	// Clock divider for enabling logic
	reg clk_div;
	initial clk_div = 1'b0;
	always @(posedge clk) begin
		clk_div = ~clk_div;
	end
	
	// Enable count logic
	assign enable_count_next = (enable_count == 2'b11) ? 2'b00 : enable_count + 1;
