	logic clk;
	logic reset;
	logic shift_ena;
	
	// State enum
	localparam IDLE = 2'b00;
	localparam DETECTED = 2'b01;
	localparam ENABLED_1 = 2'b10;
	localparam ENABLED_2 = 2'b11;
	
	// State register
	logic [1:0] state;
	logic [1:0] state_next;
	
	// Counter to keep track of enabled cycles
	logic [1:0] enable_count;
	logic [1:0] enable_count_next;
	
	// Initialize state and counter
	initial begin
		state = IDLE;
		enable_count = 2'b00;
	end
	
	// Shift enable logic
	always @(posedge clk or posedge reset) begin
		if (reset) begin
			shift_ena = 1'b0;
			enable_count = 2'b00;
		end else begin
			shift_ena = (state == ENABLED_1 || state == ENABLED_2);
			enable_count = (shift_ena) ? enable_count_next : 2'b00;
		end
	end
	
	// Next state logic
	always @(*) begin
		state_next = state;
		enable_count_next = enable_count;
		case(state)
			IDLE: if (reset) state_next = IDLE; else if (/* detect pattern */) state_next = DETECTED;
