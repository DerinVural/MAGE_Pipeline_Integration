// Define states
localparam IDLE = 2'b00;
localparam ONE_DETECTED = 2'b01;
localparam TWO_DETECTED = 2'b10;
localparam THREE_DETECTED = 2'b11;

// Registers to store current state and count consecutive ones
logic [1:0] state;
logic [1:0] count;

// Initial block for unknown values initialization
initial begin
    state = IDLE;
    count = 0;
    shift_ena = 0;
end

// Always block for updating the state and count on the rising edge of the clock
always @(posedge clk) begin
    if (reset) begin
        state <= IDLE;
        count <= 0;
        shift_ena <= 0;
    end else begin
        // State transition logic
        case (state)
            IDLE: begin
                if (in_) begin
                    state <= ONE_DETECTED;
                    count <= 1;
                end else begin
                    state <= IDLE;
                    count <= 0;
                end
            end
            ONE_DETECTED: begin
                if (in_) begin
                    state <= TWO_DETECTED;
                    count <= 2;
                end else begin
                    state <= IDLE;
                    count <= 0;
                end
            end
            TWO_DETECTED: begin
                if (in_) begin
                    state <= THREE_DETECTED;
                    count <= 3;
                end else begin
                    state <= IDLE;
                    count <= 0;
                end
            end
            THREE_DETECTED: begin
                if (in_) begin
                    state <= THREE_DETECTED;
                    count <= 3;
                end else begin
                    state <= IDLE;
                    count <= 0;
                end
            end
            default: begin
                state <= IDLE;
                count <= 0;
            end
        endcase

        // Assert shift_ena for 4 cycles after detecting three consecutive ones
        if (count == 3) begin
            shift_ena <= 1;
        end else begin
            shift_ena <= 0;
        end
    end
end

endmodule
