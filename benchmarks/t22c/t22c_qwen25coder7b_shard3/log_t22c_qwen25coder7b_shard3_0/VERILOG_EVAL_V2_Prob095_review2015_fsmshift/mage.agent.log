[2026-05-14 11:51:16,796 - mage.agent - INFO] Initial rtl:
[2026-05-14 11:51:16,796 - mage.agent - INFO] module TopModule (
    input  logic clk,
    input  logic reset,
    output logic shift_ena
);

    localparam IDLE = 2'b00;
    localparam COUNTING = 2'b01;
    localparam DONE = 2'b10;

    logic [1:0] count;
    logic [2:0] state, state_next;

    initial begin
        count = 2'b00;
        state = IDLE;
    end

    always @(posedge clk or posedge reset) begin
        if (reset)
            state <= IDLE;
        else
            state <= state_next;
    end

    always @(*) begin
        state_next = state;
        shift_ena = 1'b0;
        count = count;

        case (state)
            IDLE: begin
                if (count == 2'b00)
                    state_next = COUNTING;
                else if (count == 2'b11)
                    state_next = DONE;
            end
            COUNTING: begin
                shift_ena = 1'b1;
                if (count == 2'b11)
                    state_next = DONE;
                else
                    count = count + 1'b1;
            end
            DONE: ;
        endcase
    end

endmodule;
