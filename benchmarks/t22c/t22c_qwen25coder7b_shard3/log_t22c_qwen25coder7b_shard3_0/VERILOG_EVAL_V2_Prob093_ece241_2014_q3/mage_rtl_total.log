	$display("Mismatches: "%1d in "%1d samples", stats1.errors, stats1.clocks);
end

assign tb_match = ( { mux_in_ref } === ( { mux_in_ref } ^ { mux_in_dut } ^ { mux_in_ref } ) );	// Use explicit sensitivity list here. @(*) causes NetProc::nex_input() to be called when trying to compute
