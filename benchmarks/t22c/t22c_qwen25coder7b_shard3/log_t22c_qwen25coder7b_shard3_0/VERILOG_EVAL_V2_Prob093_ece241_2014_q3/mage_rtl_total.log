        if (stats1.errors || stats1.errors_mux_in) $display("SIMULATION FAILED - %0d MISMATCHES DETECTED, FIRST AT TIME %0t", stats1.errors + stats1.errors_mux_in, stats1.errortime < stats1.errortime_mux_in ? stats1.errortime : stats1.errortime_mux_in);
