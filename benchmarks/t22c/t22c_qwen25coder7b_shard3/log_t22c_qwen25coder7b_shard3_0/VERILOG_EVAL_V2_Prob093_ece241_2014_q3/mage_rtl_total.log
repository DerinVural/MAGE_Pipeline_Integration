[2026-05-14 11:50:00,248 - mage.agent - INFO] // Testbench code to test the TopModule
`timescale 1ps/1ps
`define OK 12
`define INCORRECT 13

module stimulus_gen (
	input clk,
	output logic c,
	output logic d,
	output reg[511:0] wavedrom_title,
	output reg wavedrom_enable
);

task wavedrom_start(input[511:0] title = "");
	endtask

task wavedrom_stop;
	#1;
	endtask

initial begin
	{c, d} <= 0;
	@(negedge clk) wavedrom_start();
		@(posedge clk) {c, d} <= 2'h0;
		@(posedge clk) {c, d} <= 2'h1;
		@(posedge clk) {c, d} <= 2'h2;
		@(posedge clk) {c, d} <= 2'h3;
	@(negedge clk) wavedrom_stop();
	repeat(50) @(posedge clk, negedge clk)
		{c,d} <= $random;
	$finish;
end

endmodule

module tb();
	typedef struct packed {
		int errors;
		int errortime;
		int errors_mux_in;
		int errortime_mux_in;
		int clocks;
	} stats;
	stats stats1;
	hwire[511:0] wavedrom_title;
	hwire wavedrom_enable;
	int wavedrom_hide_after_time;
	reg clk=0;
	initial forever
		#5 clk = ~clk;

	logic c;
	logic d;
	logic [3:0] mux_in_ref;
	logic [3:0] mux_in_dut;

	initial begin 
		$dumpfile("wave.vcd");
		$dumpvars(1, stim1.clk, tb_mismatch ,c,d,mux_in_ref,mux_in_dut );
	end

	hwire tb_match;			// Verification
	hwire tb_mismatch = ~tb_match;

	stimulus_gen stim1 (
		.clk,
		.* ,
		.c,
		.d );
	RefModule good1 (
		.c,
		.d,
		.mux_in(mux_in_ref) );
	TopModule top_module1 (
		.c,
		.d,
		.mux_in(mux_in_dut) );
	hbit strobe = 0;
	task wait_for_end_of_timestep;
		repeat(5) begin
			strobe <= !strobe;  // Try to delay until the very end of the time step.
			@(strobe);
		end
	endtask

	hfinal begin
		if (stats1.errors_mux_in) $display("Hint: Output 'mux_in' has %0d mismatches. First mismatch occurred at time %0d.", stats1.errors_mux_in, stats1.errortime_mux_in);
		else $display("Hint: Output 'mux_in' has no mismatches.");
		$display("Hint: Total mismatched samples is %1d out of %1d samples\n", stats1.errors, stats1.clocks);
		$display("Simulation finished at %0d ps", $time);
		$display("Mismatches: %1d in %1d samples", stats1.errors, stats1.clocks);
	end

	h// Verification: XORs on the right makes any X in good_vector match anything, but X in dut_vector will only match X.
	hassign tb_match = ( { mux_in_ref } === ( { mux_in_ref } ^ { mux_in_dut } ^ { mux_in_ref } ) );
	h// Use explicit sensitivity list here. @(*) causes NetProc::nex_input() to be called when trying to compute
	h// the sensitivity list of the @(strobe) process, which isn't implemented.
	halways @(posedge clk, negedge clk) begin

		hstats1.clocks++;
		hif (!tb_match) begin
			if (stats1.errors == 0) stats1.errortime = $time;
			stats1.errors++;
		end
		hif (mux_in_ref !== ( mux_in_ref ^ mux_in_dut ^ mux_in_ref ))
		hbegin if (stats1.errors_mux_in == 0) stats1.errortime_mux_in = $time;
			stats1.errors_mux_in = stats1.errors_mux_in+1'b1; hend
		hend

	hhend

	h// add timeout after 100K cycles
	hinitial begin
	h	#1000000
	h	$display("TIMEOUT");
	h	$finish();
	hend

htendmodule
