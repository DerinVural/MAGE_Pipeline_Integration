module stimulus_gen (
    input logic clk,
    output logic reset
);
    logic [31:0] clk_gen [1:0];
    logic reset_gen;
    logic clk_delayed;

    delayed_rand #(1,1,"clk") clk_gen_inst (
        .seed($random),
        .width(1),
        .out(clk_gen[0]),
        .done(),
        .valid()
    );

    delayed_rand #(1,1,"reset") reset_gen_inst (
        .seed($random),
        .width(1),
        .out(reset_gen),
        .done(),
        .valid()
    );

    always @(posedge clk or posedge reset) begin
        if (reset)
            reset_gen <= 1'b0;
        else
            reset_gen <= 1'b1;
    end

    always @(posedge clk or posedge reset) begin
        if (reset)
            clk_delayed <= 1'b0;
        else
            clk_delayed <= clk_gen[0];
    end

    assign clk = clk_delayed;
endmodule

