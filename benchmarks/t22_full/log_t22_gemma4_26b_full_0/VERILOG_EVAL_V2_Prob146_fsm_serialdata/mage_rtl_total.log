                        end else begin
                            bit_cnt <= bit_cnt + 1'b1;
                        end
                    end

                STATE_STOP_CHECK:
                    begin
                        if (in == 1'b1) begin
                            // Correct stop bit detected
                            state <= STATE_IDLE;
                        end else begin
                            // Incorrect stop bit, must wait for a stop bit
                            state <= STATE_WAIT_STOP;
                        end
                    end

                STATE_WAIT_STOP:
                    begin
                        if (in == 1'b1) begin
                            state <= STATE_IDLE;
                        end else begin
                            state <= STATE_WAIT_STOP;
                        end
                    end

                default:
                    state <= STATE_IDLE;
            endcase
        end
    end

    // Combinational logic for outputs
    // done is asserted when we transition from STOP_CHECK to IDLE (meaning in was 1)
    // However, the spec says "assert done each time it finds a stop bit".
    // To make it a pulse, we can check the state transition or just check if we are in a valid completion cycle.
    
    // Let's refine: done should be 1 during the cycle the stop bit is verified.
    // The FSM moves to IDLE on the next clock after seeing in=1 in STOP_CHECK.
    // To output done accurately, we can use a small piece of logic.

    logic done_next;
    always @(*) begin
        done_next = 1'b0;
        if (state == STATE_STOP_CHECK && in == 1'b1) begin
            done_next = 1'b1;
        end
    end

    // To ensure done is a single cycle pulse aligned with the verification:
    // We can use a register to capture the 'done' signal if needed, 
    // but based on the spec, a combinational 'done' driven by the current state/input is fine.
    
    assign done = done_next;
    
    // out_byte is valid when done is 1.
    // We need to provide the data collected during the DATA state.
    // Since 'data_reg' is updated cycle by cycle, when we are in STOP_CHECK,
    // 'data_reg' contains the 8 bits.
    
    // Because 'data_reg' is updated on the posedge, when state is STOP_CHECK,
    // data_reg already holds the full byte.
    
    always @(*) begin
        if (done) begin
            out_byte = data_reg;
        end else begin
            out_byte = 8'b0; // Don't care otherwise
        end
    end

endmodule
