                default:
                    state <= STATE_IDLE;
            endcase
        end
    end

    // Combinational output logic
    always @(*) begin
        if (state == STATE_COUNT) begin
            shift_ena = 1'b1;
        end else begin
            shift_ena = 1'b0;
        end
    end

endmodule
