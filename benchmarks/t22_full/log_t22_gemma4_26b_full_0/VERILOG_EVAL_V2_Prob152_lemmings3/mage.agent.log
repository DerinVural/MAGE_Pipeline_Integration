    // State definitions
    localparam WALK_L      = 4'd0;
    localparam WALK_R      = 4'd1;
    localparam DIG_L       = 4'd2;
    localparam DIG_R       = 4'd3;
    localparam FALL_L      = 4'd4;
    localparam FALL_R      = 4'd5;
    localparam DIG_FALL_L  = 4'd6;
    localparam DIG_FALL_R  = 4'd7;

    logic [3:0] state;

    // Asynchronous reset to WALK_L
    always @(posedge clk or posedge areset) begin
        if (areset) begin
            state <= WALK_L;
        end else begin
            state <= state_next;
        end
    end

    logic [3:0] state_next;

    // Determine next state based on precedence: ground=0 > dig=1 > bump
    always @(*) begin
        state_next = state;

        case (state)
            WALK_L:
                if (!ground)      state_next = FALL_L;
                else if (dig)     state_next = DIG_L;
                else if (bump_left)  state_next = WALK_R;
                else if (bump_right) state_next = WALK_L; // No change
                // Note: if bump_left and bump_right both 1, spec says 'still switch directions'. 
                // We interpret this as: if bump_left is 1, go Right. If bump_right is 1, go Left. 
                // If both, let's prioritize one or handle logic. 
