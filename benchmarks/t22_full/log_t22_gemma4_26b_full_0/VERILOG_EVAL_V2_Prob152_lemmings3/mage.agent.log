                else if (bump_right) state_next = WALK_L;
                else if (bump_left && bump_right) state_next = WALK_L;

            DIG_L:
                if (!ground)      state_next = DIG_FALL_L;
                else if (!dig)    state_next = WALK_L;
                // Bumps ignored while digging

            DIG_R:
                if (!ground)      state_next = DIG_FALL_R;
                else if (!dig)    state_next = WALK_R;
