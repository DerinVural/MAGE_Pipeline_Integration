                    else state <= W_L;

                W_R:
                    if (!ground)        state <= F_R;
                    else if (dig)       state <= D_R;
                    else if (bump_right || (bump_left && bump_right)) state <= W_L;
                    else if (bump_left)  state <= W_R;
                    else if (bump_right) state <= W_L;
                    else state <= W_R;

                D_L:
                    if (!ground)        state <= F_D_L;
                    else                state <= D_L;

                D_R:
                    if (!ground)        state <= F_D_R;
                    else                state <= D_R;

                F_L:
                    if (ground)         state <= W_L;
                    else                state <= F_L;

                F_R:
                    if (ground)         state <= W_R;
                    else                state <= F_R;

                F_D_L:
                    if (ground)         state <= W_L;
                    else                state <= F_D_L;

                F_D_R:
                    if (ground)         state <= W_R;
                    else                state <= F_D_R;

