    localparam STATE_DIG_R       = 3'd5;
    localparam STATE_FALL_DIG_L  = 3'd6;
    localparam STATE_FALL_DIG_R  = 3'd7;

    logic [2:0] state;

    // Sequential logic for state transitions
    always @(posedge clk or posedge areset) begin
        if (areset) begin
            state <= STATE_WALK_L;
        end else begin
            case (state)
                STATE_WALK_L: begin
                    if (!ground) 
                        state <= STATE_FALL_L;
                    else if (dig) 
                        state <= STATE_DIG_L;
                    else if (bump_left) 
                        state <= STATE_WALK_R;
                    else if (bump_right) 
                        state <= STATE_WALK_L;
                    // else stay
                end

                STATE_WALK_R: begin
                    if (!ground) 
                        state <= STATE_FALL_R;
                    else if (dig) 
                        state <= STATE_DIG_R;
                    else if (bump_left) 
                        state <= STATE_WALK_R;
                    else if (bump_right) 
                        state <= STATE_WALK_L;
                    // else stay
                end

                STATE_FALL_L: begin
                    if (ground) 
                        state <= STATE_WALK_L;
                    // else stay
                end

                STATE_FALL_R: begin
                    if (ground) 
                        state <= STATE_WALK_R;
                    // else stay
                end

                STATE_DIG_L: begin
                    if (!ground) 
                        state <= STATE_FALL_DIG_L;
                    // else stay
                end

                STATE_DIG_R: begin
                    if (!ground) 
                        state <= STATE_FALL_DIG_R;
                    // else stay
                end

                STATE_FALL_DIG_L: begin
                    if (ground) 
                        state <= STATE_WALK_L;
                    // else stay
                end

                STATE_FALL_DIG_R: begin
                    if (ground) 
                        state <= STATE_WALK_R;
                    // else stay
                end

                default: state <= STATE_WALK_L;
            endcase
        end
    end

    // Combinational logic for outputs (Moore machine)
    always @(*) begin
        walk_left = 1'b0;
        walk_right = 1'b0;
        aaah = 1'b0;
        digging = 1'b0;

        case (state) 
            STATE_WALK_L:     walk_left = 1'b1;
            STATE_WALK_R:     walk_right = 1'b1;
            STATE_FALL_L:     aaah = 1'b1;
            STATE_FALL_R:     aaah = 1'b1;
            STATE_DIG_L:      digging = 1'b1;
            STATE_DIG_R:      digging = 1'b1;
            STATE_FALL_DIG_L: aaah = 1'b1;
            STATE_FALL_DIG_R: aaah = 1'b1;
            default:          begin walk_left = 1'b0; walk_right = 1'b0; aaah = 1'b0; digging = 1'b0; end
        endcase
    end

endmodule
