                    next_state = S_FOUND;
                else 
                    next_state = S_IDLE;
            
            S_FOUND:
                next_state = S_FOUND;
            
            default:
                next_state = S_IDLE;
        endcase
    end

    // Output logic
    always @(*) begin
        if (current_state == S_FOUND) begin
            start_shifting = 1'b1;
        end else begin
            start_shifting = 1'b0;
        end
    end

endmodule
