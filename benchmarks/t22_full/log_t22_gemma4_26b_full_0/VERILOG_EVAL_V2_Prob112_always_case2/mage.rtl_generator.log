[2026-05-12 20:13:23,011 - mage.rtl_generator - INFO] RTL code: module TopModule(
    input  logic [3:0] in,
    output logic [1:0] pos
);

    // Combinational logic for priority encoder
    // Priority is given to the lowest index bit (LSB)
    // If in[0] is 1, pos = 0
    // If in[1] is 1 and in[0] is 0, pos = 1
    // If in[2] is 1 and in[0:1] are 0, pos = 2
    // If in[3] is 1 and in[0:2] are 0, pos = 3
    // If all are 0, pos = 0

    always @(*) begin
        if (in[0]) begin
            pos = 2'd0;
        end else if (in[1]) begin
            pos = 2'd1;
        end else if (in[2]) begin
            pos = 2'd2;
        end else if (in[3]) begin
            pos = 2'd3;
        end else begin
            pos = 2'd0;
        end
    end

endmodule
