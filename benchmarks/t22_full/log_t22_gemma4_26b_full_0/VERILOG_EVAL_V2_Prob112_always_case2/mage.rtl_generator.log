[2026-05-12 20:13:23,048 - mage.rtl_generator - INFO] RTL code: module TopModule(
    input  logic [3:0] in,
    output logic [1:0] pos
);

    // Combinational logic for priority encoder
    // Priority is given to the highest index bit
    always @(*) begin
        if (in[3]) begin
            pos = 2'b11;
        end else if (in[2]) begin
            pos = 2'b10;
        end else if (in[1]) begin
            pos = 2'b01;
        end else begin
            // This covers both in[0] == 1 and in == 4'b0000
            pos = 2'b00;
        end
    end

