[2026-05-12 23:31:43,881 - mage.rtl_generator - INFO] RTL code: module TopModule(
    input  logic       clk,
    input  logic       reset,
    input  logic       data,
    output logic [3:0] count,
    output logic       counting,
    output logic       done,
    input  logic       ack
);

    // State definitions
    localparam STATE_SEARCH     = 3'd0;
    localparam STATE_LOAD_DELAY = 3'd1;
    localparam STATE_COUNTING   = 3'd2;
    localparam STATE_DONE       = 3'd3;
    localparam STATE_WAIT_ACK   = 3'd4;

    logic [2:0] state;
    logic [3:0] pattern_reg;
    logic [3:0] delay_val;
    logic [15:0] timer_cnt;
    logic [3:0] bit_idx;

    // Sequential logic
    always @(posedge clk) begin
        if (reset) begin
            state <= STATE_SEARCH;
            pattern_reg <= 4'b0;
            delay_val <= 4'b0;
            timer_cnt <= 16'd0;
            bit_idx <= 4'd0;
        end else begin
            case (state)
                STATE_SEARCH:
                begin
                    pattern_reg <= {pattern_reg[2:0], data};
                    if ({pattern_reg[2:0], data} == 4'b1101) begin
                        state <= STATE_LOAD_DELAY;
                        bit_idx <= 4'd0;
                    end else begin
                        state <= STATE_SEARCH;
                    end
                end

                STATE_LOAD_DELAY:
                begin
                    // Shift in 4 bits, MSB first
                    // bit_idx 0 is the first bit (MSB)
                    if (bit_idx == 0) delay_val[3] <= data;
                    else if (bit_idx == 1) delay_val[2] <= data;
                    else if (bit_idx == 2) delay_val[1] <= data;
                    else if (bit_idx == 3) delay_val[0] <= data;

                    if (bit_idx == 3) begin
                        state <= STATE_COUNTING;
                        timer_cnt <= (delay_val + 1'b1) * 1000;
                        bit_idx <= 4'd0;
                    end else begin
                        bit_idx <= bit_idx + 1'b1;
                    end
                end

                STATE_COUNTING:
                begin
                    if (timer_cnt == 16'd1) begin
                        state <= STATE_DONE;
                        timer_cnt <= 16'd0;
                    end else begin
                        timer_cnt <= timer_cnt - 1'b1;
                    end
                end

                STATE_DONE:
                begin
                    state <= STATE_WAIT_ACK;
                end

                STATE_WAIT_ACK:
                begin
                    if (ack) begin
                        state <= STATE_SEARCH;
                    end else begin
                        state <= STATE_WAIT_ACK;
                    end
                end

                default:
                begin
                    state <= STATE_SEARCH;
                end
            endcase
        end
    end

    // Combinational logic for outputs
    always @(*);
    begin
        counting = 1'b0;
        done = 1'b0;
        count = 4'b0;

        case (state)
            STATE_SEARCH:
            begin
                counting = 1'b0;
                done = 1'b0;
                count = 4'b0;
            end
            STATE_LOAD_DELAY:
            begin
                counting = 1'b0;
                done = 1'b0;
                count = 4'b0;
            end
            STATE_COUNTING:
            begin
                counting = 1'b1;
                done = 1'b0;
                // The requirement: count for (delay+1)*1000 cycles.
                // Output 'delay' for 1000 cycles, then 'delay-1' for 1000, etc.
                // timer_cnt starts at (delay+1)*1000 and goes down to 1.
                // Total cycles = (delay+1)*1000. 
                // When timer_cnt is between (delay*1000 + 1) and (delay+1)*1000, count = delay.
                // When timer_cnt is between (delay-1)*1000 + 1 and delay*1000, count = delay-1.
                // General formula: count = (timer_cnt - 1) / 1000.
                // But timer_cnt is decreasing. Let's use a progress counter or math.
                // Let's define progress = (Total_Cycles - timer_cnt). 
                // progress = 0 to (delay+1)*1000 - 1.
                // block_index = progress / 1000. (0 to delay).
                // count = delay - block_index.
                // Wait, the spec says: "count for exactly (delay+1)*1000 cycles. delay=0 means 1000 cycles".
                // If delay=0, count should be 0 for 1000 cycles.
                // If delay=5, count is 5 for 1000, 4 for 1000... 0 for 1000. Total 6000 cycles.
                // Correct logic: count = (timer_cnt - 1) / 1000;
                count = 4'( (timer_cnt - 1'b1) / 1000 );
            end
            STATE_DONE:
            begin
                counting = 1'b0;
                done = 1'b1;
                count = 4'b0;
            end
            STATE_WAIT_ACK:
            begin
                counting = 1'b0;
                done = 1'b1;
                count = 4'b0;
            end
        endcase
    end

endmodule
