    input  logic       data,
    output logic [3:0] count,
    output logic       counting,
    output logic       done,
    input  logic       ack
);

    // State Definitions
    localparam STATE_SEARCH     = 3'd0;
    localparam STATE_GET_DELAY  = 3'd1;
    localparam STATE_COUNTING   = 3'd2;
    localparam STATE_DONE_WAIT  = 3'd3;

    logic [2:0] state;
    logic [3:0] shift_reg; // For pattern detection and delay loading
    logic [1:0] delay_bit_cnt;
    logic [3:0] delay_val;
    logic [13:0] cycle_cnt; // Max cycles: (15+1)*1000 = 16000
    logic [13:0] sub_cycle_cnt; // 0 to 999
    logic [3:0] current_delay_display;

    // Sequential Logic
    always @(posedge clk) begin
        if (reset) begin
            state <= STATE_SEARCH;
            shift_reg <= 4'b0;
            delay_bit_cnt <= 2'b0;
            delay_val <= 4'b0;
            cycle_cnt <= 14'd0;
            sub_cycle_cnt <= 14'd0;
            current_delay_display <= 4'b0;
        end else begin
            case (state)
                STATE_SEARCH:
                begin
                    // Shift in data to detect 1101
                    shift_reg <= {shift_reg[2:0], data};
                    if ({shift_reg[2:0], data} == 4'b1101) begin
                        state <= STATE_GET_DELAY;
                        delay_bit_cnt <= 2'd0;
                        shift_reg <= 4'b0; // reset shift reg for delay
                    end else begin
                        state <= STATE_SEARCH;
                    end
                end

                STATE_GET_DELAY:
                begin
                    // Shift in 4 bits, MSB first
                    // The first bit received is delay[3], then [2], [1], [0]
                    shift_reg <= {shift_reg[2:0], data};
                    if (delay_bit_cnt == 2'd3) begin
                        delay_val <= {shift_reg[2:0], data};
                        state <= STATE_COUNTING;
                        cycle_cnt <= 14'd0;
                        sub_cycle_cnt <= 14'd0;
                        current_delay_display <= {shift_reg[2:0], data};
                    end else begin
                        delay_bit_cnt <= delay_bit_cnt + 1'b1;
                    end
                end

                STATE_COUNTING:
                begin
                    // Count for (delay + 1) * 1000 cycles
                    // We use sub_cycle_cnt to count 1000 steps
                    if (sub_cycle_cnt == 14'd999) begin
                        sub_cycle_cnt <= 14'd0;
                        if (cycle_cnt == (delay_val * 14'd1000) + 14'd999) begin
                            state <= STATE_DONE_WAIT;
                        end else begin
                            cycle_cnt <= cycle_cnt + 1'b1;
                            // Update the display value every 1000 cycles
                            // Logic: the count output should be delay for 1000 cycles, 
                            // then delay-1 for 1000 cycles...
                            // This happens when sub_cycle_cnt rolls over.
                            if (cycle_cnt % 14'd1000 == 14'd0) begin
                                // This check is a bit tricky in discrete time.
                                // Let's use a different way to calculate current_delay_display.
                            end
                        end
                    end else begin
                        sub_cycle_cnt <= sub_cycle_cnt + 1'b1;
                    end
                    
                    // Update the 'current_delay_display' based on cycle_cnt
                    // delay=5 means: 
                    // cycles 0-999: count=5
                    // cycles 1000-1999: count=4 ...
                    // We can calculate this: 
                    // current_delay = delay_val - (cycle_cnt / 1000)
                    // But we must be careful with integer division in RTL.
                end

                STATE_DONE_WAIT:
                begin
                    if (ack) begin
                        state <= STATE_SEARCH;
                    end else begin
                        state <= STATE_DONE_WAIT;
                    end
                end

                default:
                    state <= STATE_SEARCH;
            endcase
        end
    end

    // Re-implementing the counter logic more cleanly to avoid complex math
    // We will use a separate state machine logic for the timer to ensure accuracy.
    
    logic [13:0] timer_cycles;
    logic [3:0] timer_delay_level;
    logic [13:0] timer_sub_cnt;

    always @(posedge clk) begin
        if (reset) begin
            timer_cycles <= 14'd0;
            timer_delay_level <= 4'b0;
            timer_sub_cnt <= 14'd0;
        end else if (state == STATE_COUNTING) begin
            if (timer_sub_cnt == 14'd999) begin
                timer_sub_cnt <= 14'd0;
                if (timer_delay_level == 4'b0) begin
                    // If we are at level 0 and finished 1000 cycles, we are done
                    // But the requirement is (delay+1)*1000. 
                    // If delay=0, count 1000 cycles. That's exactly 1 level.
                    // If delay=5, count 6000 cycles. That's 6 levels (5,4,3,2,1,0).
                    // So we stop after timer_delay_level rolls from 0 to -1? No.
                    // Let's track the total levels remaining.
                end else begin
                    timer_delay_level <= timer_delay_level - 1'b1;
                end
                // To handle the total cycle count: 
                // We stop when we have completed (delay_val + 1) segments of 1000
            end else begin
                timer_sub_cnt <= timer_sub_cnt + 1'b1;
            end
        end else begin
            timer_sub_cnt <= 14'd0;
            timer_delay_level <= 4'b0;
        end
    end

    // Refined sequential logic for the timer to meet requirements exactly
    logic [13:0] total_cycles_to_run;
    logic [13:0] current_cycle_idx;
    logic [3:0]  display_count;

    always @(posedge clk) begin
        if (reset) begin
            current_cycle_idx <= 14'd0;
            display_count <= 4'b0;
        end else if (state == STATE_COUNTING) begin
            if (current_cycle_idx == total_cycles_to_run - 1) begin
                current_cycle_idx <= 14'd0;
                display_count <= 4'b0;
            end else begin
                current_cycle_idx <= current_cycle_idx + 1'b1;
                // Display logic: 
                // cycle 0 to 999: delay_val
                // cycle 1000 to 1999: delay_val - 1
                // This can be computed as: delay_val - (current_cycle_idx / 1000)
                // Since we update every cycle, we check the transition.
                if (current_cycle_idx % 14'd1000 == 14'd999) begin
                    if (display_count > 0) 
                        display_count <= display_count - 1'b1;
                end else begin
                    // On the very first cycle of counting, set display_count
                    if (current_cycle_idx == 14'd0) 
                        display_count <= delay_val;
                end
            end
        end else begin
            current_cycle_idx <= 14'd0;
            display_count <= 4'b0;
        end
    end

    // Corrected logic for total_cycles_to_run
    // Since total_cycles_to_run depends on delay_val, we update it when state changes
    always @(posedge clk) begin
        if (reset) begin
            total_cycles_to_run <= 14'd0;
        end else if (state == STATE_GET_DELAY && delay_bit_cnt == 2'd3) begin
             // This bit is tricky because delay_val is updated in the same cycle.
             // In SystemVerilog, we'll use a combination of non-blocking and combinational logic.
