    input  logic       ack
);

    // State definitions
    localparam STATE_SEARCH     = 3'd0;
    localparam STATE_GET_DELAY  = 3'd1;
    localparam STATE_COUNTING   = 3'd2;
    localparam STATE_DONE_WAIT  = 3'd3;

    logic [2:0] state;
    logic [3:0] pattern_reg; // To detect 1101
    logic [3:0] delay;
    logic [3:0] delay_bits_reg; // To collect 4 bits for delay
    logic [15:0] timer_cnt; // Max cycles is (15+1)*1000 = 16000, so 16-bit is enough

    // State transitions and sequential logic
    always @(posedge clk) begin
        if (reset) begin
            state <= STATE_SEARCH;
            pattern_reg <= 4'b0000;
            delay <= 4'b0000;
            delay_bits_reg <= 4'b0000;
            timer_cnt <= 16'd0;
        end else begin
            case (state)n
                STATE_SEARCH:
                    begin
                        // Shift in data to find 1101
                        pattern_reg <= {pattern_reg[2:0], data};
                        if ({pattern_reg[2:0], data} == 4'b1101) begin
                            state <= STATE_GET_DELAY;
                            delay_bits_reg <= 4'b0000;
                        end else begin
                            state <= STATE_SEARCH;
                        end
                    end

                STATE_GET_DELAY:
                    begin
                        // Shift in 4 bits (MSB first)
                        delay_bits_reg <= {delay_bits_reg[2:0], data};
                        if (delay_bits_reg[0] == data || delay_bits_reg == 4'b1111) begin
                            // This logic is slightly tricky due to the way we shift.
                            // Let's use a sub-counter or just check bits.
                            // Actually, let's track how many bits we've received.
                        end
                        // Simpler: use a bit counter for the delay part
                    end

                // Re-structuring state machine to be cleaner
            endcase
        end
    end

    // Refined State Machine implementation
    logic [2:0] state_v2;
    logic [1:0] bit_idx;
    logic [3:0] shift_reg;
    logic [15:0] counter;

    always @(posedge clk) begin
        if (reset) begin
            state_v2 <= STATE_SEARCH;
            pattern_reg <= 4'b0000;
            delay <= 4'b0000;
            bit_idx <= 2'd0;
            shift_reg <= 4'b0000;
            counter <= 16'd0;
        end else begin
            case (state_v2) 
                STATE_SEARCH:
                    begin
                        pattern_reg <= {pattern_reg[2:0], data};
                        if ({pattern_reg[2:0], data} == 4'b1101) begin
                            state_v2 <= STATE_GET_DELAY;
                            bit_idx <= 2'd0;
                            shift_reg <= 4'b0000;
                        end else begin
                            state_v2 <= STATE_SEARCH;
                        end
                    end

                STATE_GET_DELAY:
                    begin
                        shift_reg <= {shift_reg[2:0], data};
                        if (bit_idx == 2'd3) begin
                            delay <= {shift_reg[2:0], data};
                            state_v2 <= STATE_COUNTING;
                            counter <= (({shift_reg[2:0], data} + 4'd1) * 1000);
                        end else begin
                            bit_idx <= bit_idx + 1'b1;
                        end
                    end

                STATE_COUNTING:
                    begin
                        if (counter <= 16'd1) begin
                            state_v2 <= STATE_DONE_WAIT;
                            counter <= 16'd0;
                        end else begin
                            counter <= counter - 1'b1;
                        end
                    end

                STATE_DONE_WAIT:
                    begin
                        if (ack) begin
                            state_v2 <= STATE_SEARCH;
                        end else begin
                            state_v2 <= STATE_DONE_WAIT;
                        end
                    end
                
                default: state_v2 <= STATE_SEARCH;
            endcase
        end
    end

    // Combinational outputs
    always @(*) begin
        counting = (state_v2 == STATE_COUNTING);
        done     = (state_v2 == STATE_DONE_WAIT);
        
        if (state_v2 == STATE_COUNTING) begin
            // counter goes from (delay+1)*1000 down to 1.
            // We want count to be 'delay' for 1000 cycles, 
            // 'delay-1' for 1000, ..., 0 for 1000.
            // Example: delay=1. Count = 2000. 
            // cycles 2000-1001: count=1
            // cycles 1000-1: count=0
            // count = (counter - 1) / 1000
            count = (counter > 16'd0) ? (4'd0 + (counter - 1'b1) / 1000) : 4'd0;
        end else begin
            count = 4'd0; // Don't care
        end
    end

endmodule
