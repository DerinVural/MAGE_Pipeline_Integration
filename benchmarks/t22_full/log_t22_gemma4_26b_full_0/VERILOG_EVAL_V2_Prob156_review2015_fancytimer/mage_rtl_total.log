eat(100000) @(posedge clk) begin\n88: \t\t\treset <= !($random & 8191);\n89: \t\t\tdata <= $random;\n90: \t\t\tack <= !($random & 31);\n91: \t\tend\n92: \n93: \t\t#1 $finish;\n94: \tend\n95: \t\n96: endmodule\n97: module tb();\n98: \n99: \ttypedef struct packed {\n100: \t\tint errors;\n101: \t\tint errortime;\n102: \t\tint errors_count;\n103: \t\tint errortime_count;\n104: \t\tint errors_counting;\n105: \t\tint errortime_counting;\n106: \t\tint errors_done;\n107: \t\tint errortime_done;\n108: \n109: \t\tint clocks;\n110: \t} stats;\n111: \t\n112: \tstats stats1;\n113: \t\n114: \t\n115: \twire[511:0] wavedrom_title;\n116: \twire wavedrom_enable;\n117: \tint wavedrom_hide_after_time;\n118: \t\n119: \treg clk=0;\n120: \tinitial forever\n121: \t\t#5 clk = ~clk;\n122: \n123: \tlogic reset;\n124: \tlogic data;\n125: \tlogic ack;\n126: \tlogic [3:0] count_ref;\n127: \tlogic [3:0] count_dut;\n128: \tlogic counting_ref;\n129: \tlogic counting_dut;\n130: \tlogic done_ref;\n131: \tlogic done_dut;\n132: \n133: \tinitial begin \n134: \t\t$dumpfile("wave.vcd");\n135: \t\t$dumpvars(1, stim1.clk, tb_mismatch ,clk,reset,data,ack,count_ref,count_dut,counting_ref,counting_dut,done_ref,done_dut );\n136: \tend\n137: \n138: \n139: \twire tb_match;\t\t// Verification\n140: \twire tb_mismatch = ~tb_match;\n141: \t\n142: \tstimulus_gen stim1 (\n143: \t\t.clk,\n144: \t\t.* ,\n145: \t\t.reset,\n146: \t\t.data,\n147: \t\t.ack );\n148: \tRefModule good1 (\n149: \t\t.clk,\n150: \t\t.reset,\n151: \t\t.data,\n152: \t\t.ack,\n153: \t\t.count(count_ref),\n154: \t\t.counting(counting_ref),\n155: \t\t.done(done_ref) );\n156: \t\t\n157: \tTopModule top_module1 (\n158: \t\t.clk,\n159: \t\t.reset,\n160: \t\t.data,\n161: \t\t.ack,\n162: \t\t.count(count_dut),\n163: \t\t.counting(counting_dut),\n164: \t\t.done(done_dut) );\n165: \n166: \t\n167: \tbit strobe = 0;\n168: \ttask wait_for_end_of_timestep;\n169: \t\trepeat(5) begin\n170: \t\t\tstrobe <= !strobe;  // Try to delay until the very end of the time st