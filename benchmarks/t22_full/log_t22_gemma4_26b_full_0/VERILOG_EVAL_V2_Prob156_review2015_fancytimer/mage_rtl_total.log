delay_shift_reg; // For collecting 4 bits\\n    logic [13:0] cycle_counter; // Max cycles = (15+1)*1000 = 16000\\n    logic [3:0] current_count_out;\\n\\n    // Sequential Logic\\n    always @(posedge clk) begin\\n        if (reset) begin\\n            state <= STATE_SEARCH;\\n            shift_reg <= 4\'b0000;\\n            delay_val <= 4\'b0000;\\n            delay_shift_reg <= 4\'b0000;\\n            cycle_counter <= 14\'d0;\\n            current_count_out <= 4\'b0000;\\n        end else begin\\n            case (state)n\\n                STATE_SEARCH:\\n                begin\\n                    // Shift in data to find 1101\\n                    shift_reg <= {shift_reg[2:0], data};\\n                    if ({shift_reg[2:0], data} == 4\'b1101) begin\\n                        state <= STATE_GET_DELAY;\\n                        delay_shift_reg <= 4\'b0000;\\n                    end else begin\\n                        state <= STATE_SEARCH;\\n                    end\\n                end\\n\\n                STATE_GET_DELAY:\\n                begin\\n                    // Shift in 4 bits, MSB first\\n                    delay_shift_reg <= {delay_shift_reg[2:0], data};\\n                    // We need to know when 4 bits are received. \\n                    // Since we transition on the 4th bit detection:\\n                    // However, the spec says \'after 1101 is detected, shift in 4 more bits\'.\\n                    // To track 4 bits, we can use a small sub-counter or just check the register.\\n                    // Let\'s use a helper to count bits or use the shift_reg\'s state.\\n                    // Since we are in this state, we know we are receiving bits.\\n                    // A more robust way is to add a bit counter.\\n                    // But we can simply check if we\'ve shifted 4 times.\\n                    // Let\'s assume a local counter for bits.\\n                    // For simplicity in this block, I will use the value of delay_shi