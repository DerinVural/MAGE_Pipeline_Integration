    input  logic       clk,
    input  logic       reset,
    input  logic       data,
    output logic [3:0] count,
    output logic       counting,
    output logic       done,
    input  logic       ack
);

    // State encoding
    localparam S_SEARCH   = 3'd0;
    localparam S_LOAD     = 3'd1;
    localparam S_INIT     = 3'd2;
    localparam S_COUNTING = 3'd3;
    localparam S_DONE     = 3'd4;

    logic [2:0] st;
    logic [3:0] sr;   // Pattern shift register
    logic [3:0] dr;   // Delay register
    logic [2:0] dc;   // Delay bit counter
    logic [13:0] tv;  // Total timer
    logic [3:0] dcnt_out; // Current delay value to display
    logic [9:0] scnt; // Sub-counter for 1000 cycles

    always @(posedge clk) begin
        if (reset) begin
            st <= S_SEARCH;
            sr <= 4'b0;
            dr <= 4'b0;
            dc <= 3'd0;
            tv <= 14'd0;
            dcnt_out <= 4'd0;
            scnt <= 10'd0;
        end else begin
            case (st)
                S_SEARCH:
                begin
                    sr <= {sr[2:0], data};
                    if ({sr[2:0], data} == 4'b1101) begin
                        st <= S_LOAD;
                        dc <= 3'd0;
                        dr <= 4'b0;
                    end else begin
                        st <= S_SEARCH;
                    end
                end

                S_LOAD:
                begin
                    dr <= {dr[2:0], data};
                    if (dc == 3'd3) begin
                        st <= S_INIT;
                    end else begin
                        dc <= dc + 3'd1;
                    end
                end

                S_INIT:
                begin
                    // Initialize timer: (delay + 1) * 1000
                    tv <= (dr + 4'd1) * 14'd1000;
                    dcnt_out <= dr;
                    scnt <= 10'd0;
                    st <= S_COUNTING;
                end

                S_COUNTING:
                begin
                    if (tv == 14'd1) begin
                        st <= S_DONE;
                        tv <= 14'd0;
                    end else begin
                        tv <= tv - 14'd1;
                        if (scnt == 10'd999) begin
                            scnt <= 10'd0;
                            if (dcnt_out > 4'd0) begin
                                dcnt_out <= dcnt_out - 4'd1;
                            end
                        end else begin
                            scnt <= scnt + 10'd1;
                        end
                    end
                end

                S_DONE:
                begin
                    if (ack) begin
                        st <= S_SEARCH;
                    end else begin
                        st <= S_DONE;
                    end
                end

                default:
                begin
                    st <= S_SEARCH;
                end
            endcase
        end
    end

    assign counting = (st == S_COUNTING);
    assign done     = (st == S_DONE);
    assign count    = (st == S_COUNTING) ? dcnt_out : 4'b0;

endmodule
