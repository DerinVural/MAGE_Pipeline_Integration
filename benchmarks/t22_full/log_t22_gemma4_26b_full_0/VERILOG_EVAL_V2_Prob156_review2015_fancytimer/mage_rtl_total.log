m S_SEARCH   = 3\'d0;\n13:     localparam S_LOAD     = 3\'d1;\n14:     localparam S_INIT     = 3\'d2;\n15:     localparam S_COUNTING = 3\'d3;\n16:     localparam S_DONE     = 3\'d4;\n17: \n18:     logic [2:0] st;\n19:     logic [3:0] sr;   // Pattern shift register\n20:     logic [3:0] dr;   // Delay register\n21:     logic [2:0] dc;   // Delay bit counter\n22:     logic [13:0] tv;  // Total timer\n23:     logic [3:0] dcnt_out; // Current delay value to display\n24:     logic [9:0] scnt; // Sub-counter for 1000 cycles\n25: \n26:     always @(posedge clk) begin\n27:         if (reset) begin\n28:             st <= S_SEARCH;\n29:             sr <= 4\'b0;\n30:             dr <= 4\'b0;\n31:             dc <= 3\'d0;\n32:             tv <= 14\'d0;\n33:             dcnt_out <= 4\'d0;\n34:             scnt <= 10\'d0;\n35:         end else begin\n36:             case (st)\n37:                 S_SEARCH:\n38:                 begin\n39:                     sr <= {sr[2:0], data};\n40:                     if ({sr[2:0], data} == 4\'b1101) begin\n41:                         st <= S_LOAD;\n42:                         dc <= 3\'d0;\n43:                         dr <= 4\'b0;\n44:                     end else begin\n45:                         st <= S_SEARCH;\n46:                     end\n47:                 end\n48: \n49:                 S_LOAD:\n50:                 begin\n51:                     dr <= {dr[2:0], data};\n52:                     if (dc == 3\'d3) begin\n53:                         st <= S_INIT;\n54:                     end else begin\n55:                         dc <= dc + 3\'d1;\n56:                     end\n57:                 end\n58: \n59:                 S_INIT:\n60:                 begin\n61:                     // Initialize timer: (delay + 1) * 1000\n62:                     tv <= (dr + 4\'d1) * 14\'d1000;\n63:                     dcnt_out <= dr;\n64:                     scnt <= 10\'d0;\n65:                     st <= S_COUNTING;\n66:                 end\n67: \n68:                 S_COUNTING:\n69:                 begin\n70:                     if (tv == 14\'d1) begin\n71:                         st <= S_DONE;\n72:                         tv <= 14\'d0;\n73:                     end else begin\n74:                         tv <= tv - 14\'d1;\n75:                         if (scnt == 10\'d999) begin\n76:                             scnt <= 10\'d0;\n77:                             if (dcnt_out > 4\'d0) begin\n78:                                 dcnt_out <= dcnt_out - 4\'d1;\n79:                             end\n80:                         end else begin\n81:                             scnt <= scnt + 10\'d1;\n82:                         end\n83:                     end\n84:                 end\n85: \n86:                 S_DONE:\n87:                 begin\n88:                     if (ack) begin\n89:                         st <= S_SEARCH;\n90:                     end else begin\n91:                         st <= S_DONE;\n92:                     end\n93:                 end\n94: \n95:                 default:\n96:                 begin\n97:                     st <= S_SEARCH;\n98:                 end\n99:             endcase\n100:         end\n101:     end\n102: \n103:     assign counting = (st == S_COUNTING);\n104:     assign done     = (st == S_DONE);\n105:     assign count    = (st == S_COUNTING) ? dcnt_out : 4\'b0;\n106: \n107: endmodule\n\n</failed_rtl>\n<failed_testbench>\n1: `timescale 1 ps/1 ps\n2: `define OK 12\n3: `define INCORRECT 13\n4: `default_nettype none\n5: \n6: \n7: module stimulus_gen (\n8: \tinput wire clk,\n9: \toutput reg reset,\n10: \toutput reg data, \n11: \toutput reg ack,\n12: \tinput wire tb_match,\n13: \tinput wire counting_dut\n14: );\n15: \tbit failed = 0;\n16: \tint counting_cycles = 0;\n17: \t\n18: \talways @(posedge clk, negedge clk)\n19: \t\tif (!tb_match) \n20: \t\t\tfailed <= 1;\n21: \t\t\t\n22: \talways @(posedge clk)\n23: \t\tif (counting_dut)\n24: \t\t\tcounting_cycles++;\n25: \t\n26: \tinitial begi