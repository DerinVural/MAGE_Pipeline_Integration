            S_5:
                if (in) state_next = S_6;
                else    state_next = S_DISC;
            S_6:
                if (in) state_next = S_ERR;
                else    state_next = S_FLAG;
            S_DISC:
                state_next = S_0;
            S_FLAG:
                state_next = S_0;
            S_ERR:
                if (in) state_next = S_ERR;
                else    state_next = S_0;
            default:
                state_next = S_0;
        endcase
    end

    // Output combinational logic (Moore Machine)
    always @(*) begin
        disc = 1'b0;
        flag = 1'b0;
        err  = 1'b0;
        case (state)
            S_DISC:
                disc = 1'b1;
            S_FLAG:
                flag = 1'b1;
            S_ERR:
                err  = 1'b1;
            default:
                begin
                    disc = 1'b0;
                    flag = 1'b0;
                    err  = 1'b0;
                end
        endcase
    end

endmodule
