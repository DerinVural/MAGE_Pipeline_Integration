    "module": "module TopModule(\n    input  logic clk,\n    input  logic reset,\n    input  logic in,\n    output logic disc,\n    output logic flag,\n    output logic err\n);\n\n    // State encoding\n    localparam S_0    = 4'd0;\n    localparam S_1    = 4'd1;\n    localparam S_2    = 4'd2;\n    localparam S_3    = 4'd3;\n    localparam S_4    = 4'd4;\n    localparam S_5    = 4'd5;\n    localparam S_6    = 4'd6;\n    localparam S_DISC = 4'd7;\n    localparam S_FLAG = 4'd8;\n    localparam S_ERR  = 4'd9;\n\n    logic [3:0] state;\n    logic [3:0] state_next;\n\n    // Sequential logic\n    always @(posedge clk) begin\n        if (reset) begin\n            state <= S_0;\n        end else begin\n            state <= state_next;\n        end\n    end\n\n    // Next state combinational logic\n    always @(*) begin\n        state_next = S_0;\n        case (state)\n            S_0:\n                if (in) state_next = S_1;\n                else    state_next = S_0;\n            S_1:\n                if (in) state_next = S_2;\n                else    state_next = S_0;\n            S_2:\n                if (in) state_next = S_3;\n                else    state_next = S_0;\n            S_3:\n                if (in) state_next = S_4;\n                else    state_next = S_0;\n            S_4:\n                if (in) state_next = S_5;\n                else    state_next = S_0;\n            S_5:\n                if (in) state_next = S_6;\n                else    state_next = S_DISC;\n            S_6:\n                if (in) state_next = S_ERR;\n                else    state_next = S_FLAG;\n            S_DISC:\n                state_next = S_0;\n            S_FLAG:\n                state_next = S_0;\n            S_ERR:\n                if (in) state_next = S_ERR;\n                else    state_next = S_0;\n            default:\n                state_next = S_0;\n        endcase\n    end\n\n    // Output combinational logic (Moore Machine)\n    always @(*) begin\n        dis