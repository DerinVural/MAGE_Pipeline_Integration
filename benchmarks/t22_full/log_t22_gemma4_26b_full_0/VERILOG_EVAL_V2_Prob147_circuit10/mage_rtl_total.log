[2026-05-12 22:32:45,292 - mage.rtl_generator - INFO] RTL code: module TopModule(
    input  logic clk,
    input  logic a,
    input  logic b,
    output logic q,
    output logic state
);

    logic state_ff;

    // Initialize state to 0 to avoid X
    initial begin
        state_ff = 1'b0;
    end

    // Sequential logic: One bit of memory
    always @(posedge clk) begin
        state_ff <= next_state;
    end

    // Combinational logic for next state
    logic next_state;
    always @(*) begin
        case ({state_ff, a, b})
            3'b000: next_state = 1'b0;
            3'b001: next_state = 1'b1;
            3'b010: next_state = 1'b1;
            3'b011: next_state = 1'b1;
            3'b100: next_state = 1'b0;
            3'b101: next_state = 1'b0;
            3'b110: next_state = 1'b0;
            3'b111: next_state = 1'b1;
            default: next_state = 1'b0;
        endcase
    end

    // Combinational logic for output q
    always @(*) begin
        case ({state_ff, a, b})
            3'b000: q = 1'b0;
            3'b001: q = 1'b1;
            3'b010: q = 1'b0;
            3'b011: q = 1'b0;
            3'b100: q = 1'b1;
            3'b101: q = 1'b0;
            3'b110: q = 1'b0;
            3'b111: q = 1'b1;
            default: q = 1'b0;
        endcase
    end

    // Assign output state to the flip-flop value
    assign state = state_ff;

endmodule
