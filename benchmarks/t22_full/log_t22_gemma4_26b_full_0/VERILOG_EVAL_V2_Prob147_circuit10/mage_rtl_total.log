                state_next = 1'b0;
            end
        end
    end

    // Output combinational logic
    always @(*) begin
        q = 1'b0;
        if (state == 1'b0) begin
            if (a == 1'b0 && b == 1'b1) begin
                q = 1'b1;
            end else if (a == 1'b1 && b == 1'b1) begin
