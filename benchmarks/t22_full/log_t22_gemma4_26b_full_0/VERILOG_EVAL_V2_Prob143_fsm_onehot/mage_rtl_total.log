            if (in) ns_comb[4] = 1'b1;
            else     ns_comb[0] = 1'b1;
        end
        // S4
        if (state[4]) begin
            if (in) ns_comb[5] = 1'b1;
            else     ns_comb[0] = 1'b1;
        end
        // S5
        if (state[5]) begin
            if (in) ns_comb[6] = 1'b1;
            else     ns_comb[8] = 1'b1;
        end
        // S6
        if (state[6]) begin
            if (in) ns_comb[7] = 1'b1;
            else     ns_comb[9] = 1'b1;
        end
        // S7
        if (state[7]) begin
            if (in) ns_comb[7] = 1'b1;
            else     ns_comb[0] = 1'b1;
            o2_comb = 1'b1; // S7: (0, 1)
        end
        // S8
        if (state[8]) begin
            if (in) ns_comb[1] = 1'b1;
            else     ns_comb[0] = 1'b1;
            o1_comb = 1'b1; // S8: (1, 0)
        end
        // S9
        if (state[9]) begin
            if (in) ns_comb[1] = 1'b1;
            else     ns_comb[0] = 1'b1;
            o1_comb = 1'b1; // S9: (1, 1)
            o2_comb = 1'b1;
        end

        // Because we used if statements with assignments like ns_comb[x] = 1'b1, 
        // we must be careful with the logic. To properly OR them, let's use a cleaner way.
        // Re-calculating ns_comb to ensure it acts as an OR of all possible next states.
