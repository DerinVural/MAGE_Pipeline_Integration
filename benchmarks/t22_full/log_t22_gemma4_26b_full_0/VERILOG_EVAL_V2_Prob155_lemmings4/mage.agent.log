[2026-05-12 22:59:49,619 - mage.agent - INFO] module TopModule(
    input  logic clk,
    input  logic areset,
    input  logic bump_left,
    input  logic bump_right,
    input  logic ground,
    input  logic dig,
    output logic walk_left,
    output logic walk_right,
    output logic aaah,
    output logic digging
);

    // State definitions
    localparam STATE_WALK_L   = 3'd0;
    localparam STATE_WALK_R   = 3'd1;
    localparam STATE_FALL_L   = 3'd2;
    localparam STATE_FALL_R   = 3'd3;
    localparam STATE_DIG_L    = 3'd4;
    localparam STATE_DIG_R    = 3'd5;
    localparam STATE_SPLAT    = 3'd6;

    logic [2:0] state;
    logic [7:0] fall_cnt;

    // Sequential logic for state and fall counter
    always @(posedge clk or posedge areset) begin
        if (areset) begin
            state <= STATE_WALK_L;
            fall_cnt <= 8'd0;
        end else begin
            case (state)
                STATE_WALK_L: begin
                    if (!ground) begin
                        state <= STATE_FALL_L;
                        fall_cnt <= 8'd0;
                    end else if (dig) begin
                        state <= STATE_DIG_L;
                    end else if (bump_left || bump_right) begin
                        // If bumped both sides, it still switches. 
                        // Specification: bump_left -> walk right, bump_right -> walk left.
                        // If both, it's ambiguous, but usually implies a direction switch. 
                        // Let's check bump_left first for right, then bump_right for left.
                        // The prompt says: "If it's bumped on both sides at the same time, it will still switch directions."
                        // We'll prioritize bump_left (to right) or bump_right (to left). 
                        // A simple way is to treat bump_left as a command to go right.
                        if (bump_left) state <= STATE_WALK_R;
                        else state <= STATE_WALK_L; // stay left if only bump_right?
                        // Actually, let's look at the logic: if bump_left -> walk right. if bump_right -> walk left.
                        // If both are 1, let's pick one or flip.
                        // Let's refine: if bump_left, go right. else if bump_right, go left.
                        if (bump_left) state <= STATE_WALK_R;
                        else if (bump_right) state <= STATE_WALK_L;
                    end
                end
                STATE_WALK_R: begin
                    if (!ground) begin
                        state <= STATE_FALL_R;
                        fall_cnt <= 8'd0;
                    end else if (dig) begin
                        state <= STATE_DIG_R;
                    end else if (bump_left || bump_right) begin
                        if (bump_right) state <= STATE_WALK_L;
                        else if (bump_left) state <= STATE_WALK_R;
                    end
                end

                STATE_FALL_L: begin
                    if (!ground) begin
                        fall_cnt <= fall_cnt + 8'd1;
                    end else begin
                        if (fall_cnt > 8'd20) state <= STATE_SPLAT;
                        else state <= STATE_WALK_L;
                    end
                end

                STATE_FALL_R: begin
                    if (!ground) begin
                        fall_cnt <= fall_cnt + 8'd1;
                    end else begin
                        if (fall_cnt > 8'd20) state <= STATE_SPLAT;
                        else state <= STATE_WALK_R;
                    end
                end

                STATE_DIG_L: begin
                    if (!ground) begin
                        state <= STATE_FALL_L;
                        fall_cnt <= 8'd0;
                    end
                end

                STATE_DIG_R: begin
                    if (!ground) begin
                        state <= STATE_FALL_R;
                        fall_cnt <= 8'd0;
                    end
                end

                STATE_SPLAT: begin
                    // Stay here forever
                end

                default: state <= STATE_WALK_L;
            endcase
        end
    end

    // Correcting the bumping logic for WALK states to match 'switch direction'
    // Redefining the logic inside the case for clarity and correctness
    // Let's rewrite the state transitions for WALK_L and WALK_R carefully.
    // Prompt: bump_left -> walk_right. bump_right -> walk_left.
    // If both: "it will still switch directions". This is slightly ambiguous.
    // Let's use: if (bump_left) state <= WALK_R; else if (bump_right) state <= WALK_L;

    // Re-implementing the sequential logic properly
    always @(posedge clk or posedge areset) begin
        if (areset) begin
            state <= STATE_WALK_L;
            fall_cnt <= 8'd0;
        end else begin
            case (state)
                STATE_WALK_L: begin
                    if (!ground) begin
                        state <= STATE_FALL_L;
                        fall_cnt <= 8'd0;
                    end else if (dig) begin
                        state <= STATE_DIG_L;
                    end else if (bump_left) begin
                        state <= STATE_WALK_R;
                    end else if (bump_right) begin
                        state <= STATE_WALK_L;
                    end
                end
                STATE_WALK_R: begin
                    if (!ground) begin
                        state <= STATE_FALL_R;
                        fall_cnt <= 8'd0;
                    end else if (dig) begin
                        state <= STATE_DIG_R;
                    end else if (bump_right) begin
                        state <= STATE_WALK_L;
                    end else if (bump_left) begin
                        state <= STATE_WALK_R;
                    end
                end
                STATE_FALL_L: begin
                    if (!ground) fall_cnt <= fall_cnt + 8'd1;
                    else if (fall_cnt > 8'd20) state <= STATE_SPLAT;
                    else state <= STATE_WALK_L;
                end
                STATE_FALL_R: begin
                    if (!ground) fall_cnt <= fall_cnt + 8'd1;
                    else if (fall_cnt > 8'd20) state <= STATE_SPLAT;
                    else state <= STATE_WALK_R;
                end
                STATE_DIG_L: begin
                    if (!ground) begin
                        state <= STATE_FALL_L;
                        fall_cnt <= 8'd0;
                    end
                end
                STATE_DIG_R: begin
                    if (!ground) begin
                        state <= STATE_FALL_R;
                        fall_cnt <= 8'd0;
                    end
                end
                STATE_SPLAT: ; // Do nothing
                default: state <= STATE_WALK_L;
            endcase
        end
    end

    // Combinational logic for outputs (Moore Machine)
    always @(*) begin
        walk_left  = 1'b0;
        walk_right = 1'b0;
        aaah       = 1'b0;
        digging    = 1'b0;

        case (state) 
