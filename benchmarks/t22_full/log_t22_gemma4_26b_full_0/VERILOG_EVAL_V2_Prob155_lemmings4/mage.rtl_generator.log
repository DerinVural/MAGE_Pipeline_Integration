    // Sequential logic
    always @(posedge clk or posedge areset) begin
        if (areset) begin
            state <= STATE_WALK_LEFT;
            fall_timer <= 8'd0;
            dir_is_left <= 1'b1;
        end else begin
            case (state)
                STATE_WALK_LEFT:
                    if (!ground) begin
                        state <= STATE_FALLING;
                        fall_timer <= 8'd0;
                    end else if (dig) begin
                        state <= STATE_DIGGING;
                    end else begin
                        if (bump_right) dir_is_left <= 1'b0;
                        if (bump_left)  dir_is_left <= 1'b1;
                    end

                STATE_WALK_RIGHT:
                    if (!ground) begin
                        state <= STATE_FALLING;
                        fall_timer <= 8'd0;
                    end else if (dig) begin
                        state <= STATE_DIGGING;
                    end else begin
                        if (bump_left)  dir_is_left <= 1'b1;
                        if (bump_right) dir_is_left <= 1'b0;
                    end

                STATE_FALLING:
                    if (!ground) begin
                        fall_timer <= fall_timer + 8'd1;
                    end else begin
                        if (fall_timer > 8'd20) begin
                            state <= STATE_SPLATTERED;
                        end else begin
                            state <= (dir_is_left) ? STATE_WALK_LEFT : STATE_WALK_RIGHT;
                        end
                    end

                STATE_DIGGING:
                    if (!ground) begin
                        state <= STATE_FALLING;
                        fall_timer <= 8'd0;
                    end else begin
                        // Stay in digging
                    end

                STATE_SPLATTERED:
                    state <= STATE_SPLATTERED;

                default:
                    state <= STATE_WALK_LEFT;
            endcase
        end
    end

    // Output logic (Moore Machine)
    always @(*) begin
        walk_left  = 1'b0;
        walk_right = 1'b0;
        aaah       = 1'b0;
        digging    = 1'b0;

        case (state) 
            STATE_WALK_LEFT:  walk_left  = 1'b1;
            STATE_WALK_RIGHT: walk_right = 1'b1;
            STATE_FALLING:    aaah       = 1'b1;
            STATE_DIGGING:    digging    = 1'b1;
            STATE_SPLATTERED: begin
                walk_left  = 1'b0;
                walk_right = 1'b0;
                aaah       = 1'b0;
                digging    = 1'b0;
            end
