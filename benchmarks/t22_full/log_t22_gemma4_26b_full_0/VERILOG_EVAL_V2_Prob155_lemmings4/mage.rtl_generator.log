                if (!ground) begin
                    next_state = ST_FALL_R;
                    next_fall_cnt = 6'd1;
                end else if (dig) begin
                    next_state = ST_DIG_R;
                end else if (bump_left) begin
                    next_state = ST_WALK_L;
                end else if (bump_right) begin
                    next_state = ST_WALK_R;
                end else begin
                    next_state = ST_WALK_R;
                end
            end

            ST_DIG_L: begin
                if (!ground) begin
                    next_state = ST_FALL_L;
                    next_fall_cnt = 6'd1;
                end else begin
                    next_state = ST_DIG_L;
                end
            end

            ST_DIG_R: begin
                if (!ground) begin
                    next_state = ST_FALL_R;
                    next_fall_cnt = 6'd1;
                end else begin
                    next_state = ST_DIG_R;
                end
            end

            ST_FALL_L: begin
                if (ground) begin
                    if (fall_cnt > 6'd20) begin
                        next_state = ST_SPLAT;
                        next_fall_cnt = 6'd0;
                    end else begin
                        next_state = ST_WALK_L;
                        next_fall_cnt = 6'd0;
                    end
                end else begin
                    next_fall_cnt = fall_cnt + 6'd1;
                end
            end

            ST_FALL_R: begin
                if (ground) begin
                    if (fall_cnt > 6'd20) begin
                        next_state = ST_SPLAT;
                        next_fall_cnt = 6'd0;
                    end else begin
                        next_state = ST_WALK_R;
                        next_fall_cnt = 6'd0;
                    end
                end else begin
                    next_fall_cnt = fall_cnt + 6'd1;
                end
            end

            ST_SPLAT: begin
                next_state = ST_SPLAT;
                next_fall_cnt = 6'd0;
            end

            default: begin
                next_state = ST_WALK_L;
                next_fall_cnt = 6'd0;
            end
        endcase
    end

    // Output logic (Moore)
    always @(*) begin
        walk_left  = 1'b0;
        walk_right = 1'b0;
        aaah      = 1'b0;
        digging    = 1'b0;

        case (state)
            ST_WALK_L: walk_left  = 1'b1;
            ST_WALK_R: walk_right = 1'b1;
            ST_FALL_L: aaah      = 1'b1;
            ST_FALL_R: aaah      = 1'b1;
            ST_DIG_L:  digging    = 1'b1;
            ST_DIG_R:  digging    = 1'b1;
            ST_SPLAT:  begin walk_left=1'b0; walk_right=1'b0; aaah=1'b0; digging=1'b0; end
            default:   begin walk_left=1'b0; walk_right=1'b0; aaah=1'b0; digging=1'b0; end
        endcase
