                if (!ground) begin
                    next_state = ST_FALL_L;
                    next_fall_cnt = 6'd1;
                end else if (dig) begin
                    next_state = ST_DIG_L;
                end else if (bump_right) begin
                    next_state = ST_WALK_R;
                end else if (bump_left) begin
                    next_state = ST_WALK_L;
                end else begin
                    next_state = ST_WALK_L;
                end
            end

