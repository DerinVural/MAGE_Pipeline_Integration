    // State encoding
    localparam ST_WALK_L   = 3'd0;
    localparam ST_WALK_R   = 3'd1;
    localparam ST_FALL_L   = 3'd2;
    localparam ST_FALL_R   = 3'd3;
    localparam ST_DIG_L    = 3'd4;
    localparam ST_DIG_R    = 3'd5;
    localparam ST_SPLAT    = 3'd6;

    logic [2:0] state;
    logic [5:0] fall_cnt;
    logic [2:0] next_state;
    logic [5:0] next_fall_cnt;

    // Sequential logic
    always @(posedge clk or posedge areset) begin
        if (areset) begin
            state <= ST_WALK_L;
            fall_cnt <= 6'd0;
        end else begin
            state <= next_state;
            fall_cnt <= next_fall_cnt;
        end
    end

    // Combinational logic for next state and counter
    always @(*) begin
        next_state = state;
        next_fall_cnt = fall_cnt;

        case (state)
