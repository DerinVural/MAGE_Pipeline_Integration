[2026-05-12 23:04:42,657 - mage.rtl_generator - INFO] RTL code: module TopModule(
    input  logic clk,
    input  logic areset,
    input  logic bump_left,
    input  logic bump_right,
    input  logic ground,
    input  logic dig,
    output logic walk_left,
    output logic walk_right,
    output logic aaah,
    output logic digging
);

    // State definitions
    localparam STATE_WALK_LEFT      = 3'd0;
    localparam STATE_WALK_RIGHT     = 3'd1;
    localparam STATE_FALLING_LEFT   = 3'd2;
    localparam STATE_FALLING_RIGHT  = 3'd3;
    localparam STATE_DIGGING        = 3'd4;
    localparam STATE_FALLING_DIG_L  = 3'd5;
    localparam STATE_FALLING_DIG_R  = 3'd6;
    localparam STATE_SPLAT          = 3'd7;

    logic [2:0] state;
    logic [7:0] fall_counter;

    // State register
    always @(posedge clk or posedge areset) begin
        if (areset) begin
            state <= STATE_WALK_LEFT;
            fall_counter <= 8'd0;
        end else begin
            case (state)n
                STATE_WALK_LEFT:
                    if (!ground) state <= STATE_FALLING_LEFT;
                    else if (dig) state <= STATE_DIGGING;
                    else if (bump_left || bump_right) begin
                        if (bump_left && bump_right) state <= STATE_WALK_RIGHT;
                        else if (bump_left) state <= STATE_WALK_RIGHT;
                        else state <= STATE_WALK_LEFT;
                    end else state <= STATE_WALK_LEFT;

                STATE_WALK_RIGHT:
                    if (!ground) state <= STATE_FALLING_RIGHT;
                    else if (dig) state <= STATE_DIGGING;
                    else if (bump_left || bump_right) begin
                        if (bump_left && bump_right) state <= STATE_WALK_LEFT;
                        else if (bump_right) state <= STATE_WALK_LEFT;
                        else state <= STATE_WALK_RIGHT;
                    end else state <= STATE_WALK_RIGHT;

                STATE_FALLING_LEFT:
                    if (ground) begin
                        // Check splatter condition: fall > 20 cycles
                        if (fall_counter > 20) state <= STATE_SPLAT;
                        else state <= STATE_WALK_LEFT;
                    end else state <= STATE_FALLING_LEFT;

                STATE_FALLING_RIGHT:
                    if (ground) begin
                        if (fall_counter > 20) state <= STATE_SPLAT;
                        else state <= STATE_WALK_RIGHT;
                    end else state <= STATE_FALLING_RIGHT;

                STATE_DIGGING:
                    if (!ground) state <= STATE_FALLING_DIG_L; // Direction doesn't matter much here but we need to track it
                    else state <= STATE_DIGGING;

                STATE_FALLING_DIG_L:
                    if (ground) begin
                        if (fall_counter > 20) state <= STATE_SPLAT;
                        else state <= STATE_WALK_LEFT;
                    end else state <= STATE_FALLING_DIG_L;

                STATE_FALLING_DIG_R:
                    if (ground) begin
                        if (fall_counter > 20) state <= STATE_SPLAT;
                        else state <= STATE_WALK_RIGHT;
                    end else state <= STATE_FALLING_DIG_R;

                STATE_SPLAT:
                    state <= STATE_SPLAT;

                default:
                    state <= STATE_WALK_LEFT;
            endcase

            // Counter logic
            if (state == STATE_FALLING_LEFT || state == STATE_FALLING_RIGHT || 
                state == STATE_FALLING_DIG_L || state == STATE_FALLING_DIG_R) begin
                fall_counter <= fall_counter + 1'b1;
