                else           state_next = STATE_D;
            end
            STATE_D: begin
                if (in == 1'b0) state_next = STATE_C;
                else           state_next = STATE_B;
            end
            default: state_next = STATE_A;
        endcase
    end

    // Combinational logic for output (Moore machine)
    always @(*) begin
        case (state) 
            STATE_D: out = 1'b1;
            default: out = 1'b0;
        endcase
    end

endmodule
