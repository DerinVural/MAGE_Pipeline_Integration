n                        state <= STATE_Y_WAIT_2;\n\n                STATE_Y_WAIT_2:\n                    if (y == 1'b1) \n                        state <= STATE_G_PERM_1;\n                    else \n                        state <= STATE_G_PERM_0;\n\n                STATE_G_PERM_1:\n                    state <= STATE_G_PERM_1;\n\n                STATE_G_PERM_0:\n                    state <= STATE_G_PERM_0;\n\n                default:\n                    state <= STATE_IDLE;\n            endcase\n        end\n    end\n\n    // Corrected state machine logic using a shift register for x to ensure \"successive\" logic is perfect\n    logic [2:0] x_shift;\n    always @(posedge clk) begin\n        if (!resetn) begin\n            x_shift <= 3'b000;\n        end else begin\n            x_shift <= {x_shift[1:0], x};\n        end\n    end\n\n    // Re-implementing the FSM logic using the x_shift for the sequence detection\n    // State machine for the main logic\n    localparam S_IDLE      = 4'd0;\n    localparam S_F_PULSE  = 4'd1;\n    localparam S_MONITOR  = 4'd2;\n    localparam S_G_ACTIVE = 4'd3;\n    localparam S_Y_WAIT_1 = 4'd4;\n    localparam S_Y_WAIT_2 = 4'd5;\n    localparam S_G_PERM_1 = 4'd6;\n    localparam S_G_PERM_0 = 4'd7;\n\n    logic [3:0] main_state;\n\n    always @(posedge clk) begin\n        if (!resetn) begin\n            main_state <= S_IDLE;\n        end else begin\n            case (main_state)\n                S_IDLE:\n                    main_state <= S_F_PULSE;\n\n                S_F_PULSE:\n                    main_state <= S_MONITOR;\n\n                S_MONITOR:\n                    if (x_shift == 3'b101) \n                        main_state <= S_G_ACTIVE;\n                    else\n                        main_state <= S_MONITOR;\n\n                S_G_ACTIVE:\n                    if (y == 1'b1) \n                        main_state <= S_G_PERM_1;\n                    else\n                        main_state <= S_Y_WAIT_1;\n\n                S_Y_WAIT_1:\n                    if (y == 1'b1) \n                        main_state <= S_G_PERM_1;\n                    else\n                        main_state <= S_Y_WAIT_2;\n\n                S_Y_WAIT_2:\n                    if (y == 1'b1) \n                        main_state <= S_G_PERM_1;\n                    else\n                        main_state <= S_G_PERM_0;\n\n                S_G_PERM_1:\n                    main_state <= S_G_PERM_1;\n\n                S_G_PERM_0:\n                    main_state <= S_G_PERM_0;\n\n                default:\n                    main_state <= S_IDLE;\n            endcase\n        end\n    end\n\n    // Output logic\n    always @(*) begin\n        f = 1'b0;\n        g = 1'b0;\n        case (main_state)\n            S_F_PULSE: f = 1'b1;\n            S_G_ACTIVE, S_Y_WAIT_1, S_Y_WAIT_2, S_G_PERM_1: g = 1'b1;\n            S_G_PERM_0: g = 1'b0;\n            default: begin\n                f = 1'b0;\n                g = 1'b0;\n            end\n        endcase\n    end\n\nendmodule"
}
