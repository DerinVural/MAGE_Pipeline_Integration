                    begin
                        if (y) begin
                            state <= STATE_E;
                        end else if (y_timer == 2'd2) begin
                            state <= STATE_F;
                        end else begin
                            y_timer <= y_timer + 1'b1;
                            state <= STATE_D;
                        end
                    end

                STATE_E:
                    state <= STATE_E;

                STATE_F:
                    state <= STATE_F;

                default:
                    state <= STATE_A;
            endcase
        end
    end

    // Output Logic
    always @(*) begin
        f = 1'b0;
        g = 1'b0;
        case (state) 
            STATE_B: f = 1'b1;
            STATE_D: g = 1'b1;
            STATE_E: g = 1'b1;
            STATE_F: g = 1'b0;
            default: begin
                f = 1'b0;
                g = 1'b0;
            end
        endcase
    end

endmodule
