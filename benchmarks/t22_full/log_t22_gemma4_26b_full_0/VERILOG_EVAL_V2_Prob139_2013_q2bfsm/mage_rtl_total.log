    // State definitions
    localparam STATE_A = 3'd0; // Initial State
    localparam STATE_B = 3'd1; // f=1 pulse
    localparam STATE_C = 3'd2; // Monitor X pattern
    localparam STATE_D = 3'd3; // Monitor Y (g=1, counting)
    localparam STATE_E = 3'd4; // g=1 permanent
    localparam STATE_F = 3'd5; // g=0 permanent

    logic [2:0] state;
    logic [2:0] x_hist;
    logic [1:0] y_timer;

    // Initialize signals to avoid X in simulation
    initial begin
        state = STATE_A;
        x_hist = 3'b000;
        y_timer = 2'b00;
    end

    // State Transition and Sequential Logic
    always @(posedge clk) begin
        if (!resetn) begin
            state <= STATE_A;
            x_hist <= 3'b000;
            y_timer <= 2'b00;
        end else begin
            case (state)
                STATE_A:
                    state <= STATE_B;

                STATE_B:
                    state <= STATE_C;

                STATE_C:
                    begin
                        x_hist <= {x_hist[1:0], x};
                        if ({x_hist[1:0], x} == 3'b101) begin
                            state <= STATE_D;
                            y_timer <= 2'b00;
                        end else begin
                            state <= STATE_C;
                        end
