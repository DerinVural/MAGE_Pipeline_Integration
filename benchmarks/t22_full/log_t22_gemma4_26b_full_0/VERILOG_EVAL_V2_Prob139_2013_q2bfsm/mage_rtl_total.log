[2026-05-12 20:59:02,672 - mage.rtl_generator - INFO] RTL code: module TopModule(
    input  logic clk,
    input  logic resetn,
    input  logic x,
    input  logic y,
    output logic f,
    output logic g
);

    // State definitions
    localparam STATE_A        = 3'd0;
    localparam STATE_F_DONE   = 3'd1;
    localparam STATE_X_WATCH  = 3'd2;
    localparam STATE_G_CHECK  = 3'd3;
    localparam STATE_G_PERM   = 3'd4;
    localparam STATE_G_OFF    = 3'd5;

    logic [2:0] state;
    logic [2:0] x_shift;
    logic [1:0] y_timer;
    logic       g_permanent;

    // Initialize signals to avoid X
    initial begin
        state = STATE_A;
        x_shift = 3'b000;
        y_timer = 2'b00;
        g_permanent = 1'b0;
    end

    // Sequential Logic
    always @(posedge clk) begin
        if (!resetn) begin
            state <= STATE_A;
            x_shift <= 3'b000;
            y_timer <= 2'b00;
            g_permanent <= 1'b0;
        end else begin
            case (state)
                STATE_A:
                    state <= STATE_F_DONE;

                STATE_F_DONE:
                    state <= STATE_X_WATCH;

                STATE_X_WATCH:
                    begin
                        x_shift <= {x_shift[1:0], x};
                        if ({x_shift[1:0], x} == 3'b101) begin
                            state <= STATE_G_CHECK;
                            y_timer <= 2'b00;
                        end
                    end

                STATE_G_CHECK:
                    begin
                        if (y) begin
                            g_permanent <= 1'b1;
                            state <= STATE_G_PERM;
                        end else if (y_timer == 2'b11) begin
                            g_permanent <= 1'b0;
                            state <= STATE_G_OFF;
                        end else begin
                            y_timer <= y_timer + 1'b1;
                        end
                    end

                STATE_G_PERM:
                    begin
                        // Stay here
                        state <= STATE_G_PERM;
                    end

                STATE_G_OFF:
                    begin
                        // Stay here
                        state <= STATE_G_OFF;
                    end

                default:
                    state <= STATE_A;
            endcase
        end
    end

    // Combinational Output Logic
    always @(*) begin
        f = 1'b0;
        g = 1'b0;

        // f is 1 for one cycle after reset is de-asserted
        if (state == STATE_F_DONE) begin
            f = 1'b1;
        end

        // g logic
        if (state == STATE_G_PERM) begin
            g = 1'b1;
        end else if (state == STATE_G_CHECK) begin
            // During the checking period, g is 1
            g = 1'b1;
        end else if (g_permanent) begin
            g = 1'b1;
        end else if (state == STATE_G_OFF) begin
            g = 1'b0;
        end else begin
            g = 1'b0;
        end
    end

endmodule
