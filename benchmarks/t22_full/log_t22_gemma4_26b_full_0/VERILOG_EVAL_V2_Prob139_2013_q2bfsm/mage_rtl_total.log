[2026-05-12 20:59:02,710 - mage.rtl_generator - INFO] RTL code: module TopModule(
    input  logic clk,
    input  logic resetn,
    input  logic x,
    input  logic y,
    output logic f,
    output logic g
);

    // State Definitions
    localparam STATE_A       = 4'd0;
    localparam STATE_F       = 4'd1;
    localparam STATE_X1      = 4'd2;
    localparam STATE_X10     = 4'd3;
    localparam STATE_G_START = 4'd4;
    localparam STATE_G_Y1    = 4'd5;
    localparam STATE_G_Y2    = 4'd6;
    localparam STATE_G_PERM  = 4'd7;
    localparam STATE_G_FAIL  = 4'd8;

    logic [3:0] state;

    // State Transitions
    always @(posedge clk) begin
        if (!resetn) begin
            state <= STATE_A;
        end else begin
            case (state)
                STATE_A: begin
                    // After resetn is de-asserted, the next cycle sets f=1.
                    // This implies we move from A to F.
                    state <= STATE_F;
                end

                STATE_F: begin
                    if (x) state <= STATE_X1;
                    else   state <= STATE_F;
                end

                STATE_X1: begin
                    if (x)      state <= STATE_X1;
                    else if (!x) state <= STATE_X10;
                    else        state <= STATE_F;
                end

                STATE_X10: begin
                    if (x)      state <= STATE_G_START;
                    else        state <= STATE_F;
                end

                STATE_G_START: begin
                    // g=1 is set. Monitor y.
                    // "If y has the value 1 within at most two clock cycles..."
                    // The current cycle is the 0-th cycle of monitoring y.
                    if (y)      state <= STATE_G_PERM;
                    else        state <= STATE_G_Y1;
                end

                STATE_G_Y1: begin
                    // This is the 1st clock cycle of y being 0.
                    if (y)      state <= STATE_G_PERM;
                    else        state <= STATE_G_Y2;
                end

                STATE_G_Y2: begin
                    // This is the 2nd clock cycle of y being 0.
                    if (y)      state <= STATE_G_PERM;
                    else        state <= STATE_G_FAIL;
                end

                STATE_G_PERM: begin
                    state <= STATE_G_PERM;
                end

                STATE_G_FAIL: begin
                    state <= STATE_G_FAIL;
                end

                default: state <= STATE_A;
            endcase
        end
    end

    // Output Logic
    always @(*) begin
        f = 1'b0;
        g = 1'b0;
        case (state)
            STATE_F:       f = 1'b1;
            STATE_G_START: g = 1'b1;
            STATE_G_Y1:    g = 1'b1;
            STATE_G_Y2:    g = 1'b1;
            STATE_G_PERM:  g = 1'b1;
            // STATE_A, STATE_X1, STATE_X10, STATE_G_FAIL have f=0, g=0
            default:       begin f = 1'b0; g = 1'b0; end
        endcase
    end

endmodule
