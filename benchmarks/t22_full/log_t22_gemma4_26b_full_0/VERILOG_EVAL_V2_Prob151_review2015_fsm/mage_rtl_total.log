    end

    // Combinational logic for outputs
    always @(*) begin
        shift_ena = 1'b0;
        counting  = 1'b0;
        done      = 1'b0;

        case (state) 
            STATE_SHIFT:         shift_ena = 1'b1;
            STATE_WAIT_COUNTING: counting  = 1'b1;
            STATE_DONE_NOTIFY:   done     = 1'b1;
            default:             begin
                                    shift_ena = 1'b0;
                                    counting  = 1'b0;
                                    done      = 1'b0;
                                 end
        endcase
    end

