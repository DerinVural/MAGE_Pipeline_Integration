[2026-05-12 22:41:46,305 - mage.agent - INFO] module TopModule(
    input  logic clk,
    input  logic reset,
    input  logic data,
    input  logic done_counting,
    input  logic ack,
    output logic shift_ena,
    output logic counting,
    output logic done
);

    // State definitions
    localparam STATE_IDLE          = 3'd0;
    localparam STATE_SHIFT        = 3'd1;
    localparam STATE_WAIT_COUNTING = 3'd2;
    localparam STATE_WAIT_ACK      = 3'd3;

    logic [2:0] state;
    logic [2:0] next_state;

    // Pattern detection register (tracks last 4 bits)
    logic [3:0] pattern_reg;
    // Counter for shift_ena duration
    logic [2:0] shift_cnt;

    // Initialize non-reset signals to avoid X
    initial begin
        pattern_reg = 4'b0000;
        shift_cnt = 3'b000;
    end

    // Sequential logic for state and pattern register
    always @(posedge clk) begin
        if (reset) begin
            state <= STATE_IDLE;
            pattern_reg <= 4'b0000;
            shift_cnt <= 3'b000;
        end else begin
            state <= next_state;
            
            // Update pattern register every cycle
            pattern_reg <= {pattern_reg[2:0], data};

            // Counter for the 4-cycle shift_ena duration
            if (state == STATE_SHIFT) begin
                if (shift_cnt == 3'd3) 
                    shift_cnt <= 3'd0;
                else
                    shift_cnt <= shift_cnt + 1'b1;
            end else begin
                shift_cnt <= 3'd0;
            end
        end
    end

    // Next state logic
    always @(*) begin
        next_state = state;
        case (state) 
            STATE_IDLE: begin
                // Pattern 1101 detected
                if (pattern_reg == 4'b1101) 
                    next_state = STATE_SHIFT;
                else
                    next_state = STATE_IDLE;
            end
            STATE_SHIFT: begin
                // Assert for exactly 4 cycles
                if (shift_cnt == 3'd3) 
                    next_state = STATE_WAIT_COUNTING;
                else
                    next_state = STATE_SHIFT;
            end
            STATE_WAIT_COUNTING: begin
                if (done_counting) 
                    next_state = STATE_WAIT_ACK;
                else
                    next_state = STATE_WAIT_COUNTING;
            end
            STATE_WAIT_ACK: begin
                if (ack) 
                    next_state = STATE_IDLE;
                else
                    next_state = STATE_WAIT_ACK;
            end
            default: next_state = STATE_IDLE;
        endcase
    end

    // Output logic
    always @(*) begin
        shift_ena = 1'b0;
        counting  = 1'b0;
        done      = 1'b0;

        case (state) 
            STATE_SHIFT: begin
                shift_ena = 1'b1;
            end
            STATE_WAIT_COUNTING: begin
                counting = 1'b1;
            end
            STATE_WAIT_ACK: begin
                done = 1'b1;
            end
            default: ;
        endcase
    end

endmodule
