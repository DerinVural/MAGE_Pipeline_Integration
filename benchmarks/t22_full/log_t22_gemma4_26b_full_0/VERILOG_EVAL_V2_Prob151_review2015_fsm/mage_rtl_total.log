[2026-05-12 22:45:25,733 - mage.rtl_generator - INFO] RTL code: module TopModule(
    input  logic clk,
    input  logic reset,
    input  logic data,
    input  logic done_counting,
    input  logic ack,
    output logic shift_ena,
    output logic counting,
    output logic done
);

    // State definitions
    localparam STATE_IDLE          = 3'd0;
    localparam STATE_SHIFT         = 3'd1;
    localparam STATE_WAIT_COUNTING = 3'd2;
    localparam STATE_WAIT_ACK      = 3'd3;

    logic [2:0] state;
    logic [2:0] next_state;

    // Pattern detection logic
    logic [3:0] pattern_reg;
    logic [3:0] next_pattern_reg;

    // Shift duration counter
    logic [1:0] shift_cnt;
    logic [1:0] next_shift_cnt;

    // Sequential logic
    always @(posedge clk) begin
        if (reset) begin
            state <= STATE_IDLE;
            pattern_reg <= 4'b0000;
            shift_cnt <= 2'b00;
        end else begin
            state <= next_state;
            pattern_reg <= next_pattern_reg;
            shift_cnt <= next_shift_cnt;
        end
    end

    // Next state and pattern logic
    always @(*) begin
        next_state = state;
        next_pattern_reg = {pattern_reg[2:0], data};
        next_shift_cnt = shift_cnt;

        case (state) 
            STATE_IDLE: begin
                // Check for pattern 1101. 
                // Note: pattern_reg holds previous bits. 
                // The pattern is detected when the shift register reaches 1101.
                // We check if the current incoming data completes the 1101 pattern.
                if ({pattern_reg[2:0], data} == 4'b1101) begin
                    next_state = STATE_SHIFT;
                    next_shift_cnt = 2'd0;
                end else begin
                    next_state = STATE_IDLE;
                end
            end

            STATE_SHIFT: begin
                if (shift_cnt == 2'd3) begin
                    next_state = STATE_WAIT_COUNTING;
                end else begin
                    next_shift_cnt = shift_cnt + 2'd1;
                    next_state = STATE_SHIFT;
                end
            end

            STATE_WAIT_COUNTING: begin
                if (done_counting) begin
                    next_state = STATE_WAIT_ACK;
                end else begin
                    next_state = STATE_WAIT_COUNTING;
                end
            end

            STATE_WAIT_ACK: begin
                if (ack) begin
                    next_state = STATE_IDLE;
                end else begin
                    next_state = STATE_WAIT_ACK;
                end
            end

            default: begin
                next_state = STATE_IDLE;
            end
        endcase
    end

    // Output logic
    always @(*) begin
        shift_ena = 1'b0;
        counting  = 1'b0;
        done      = 1'b0;

        case (state) 
            STATE_SHIFT: begin
                shift_ena = 1'b1;
            end
            STATE_WAIT_COUNTING: begin
                counting = 1'b1;
            end
            STATE_WAIT_ACK: begin
                done = 1'b1;
            end
            default: begin
                shift_ena = 1'b0;
                counting  = 1'b0;
                done      = 1'b0;
            end
        endcase
    end

endmodule
