    // Output logic
    always @(*) begin
        shift_ena = 1'b0;
        counting  = 1'b0;
        done      = 1'b0;

        if (state == STATE_SHIFT_EN) begin
            shift_ena = 1'b1;
        end else if (state == STATE_WAIT_COUNT) begin
            counting = 1'b1;
        end else if (state == STATE_WAIT_ACK) begin
            done = 1'b1;
        end
    end

endmodule
