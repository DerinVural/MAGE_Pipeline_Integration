            // Above s[2]: s[0], s[1], s[2] are 1 -> s == 3'b111
            if (s == 3'b111) begin
                fr2 = 1'b0;
                fr1 = 1'b0;
                fr0 = 1'b0;
                dfr = 1'b0;
            end 
            // Between s[2] and s[1]: s[0], s[1] are 1 -> s == 3'b011
