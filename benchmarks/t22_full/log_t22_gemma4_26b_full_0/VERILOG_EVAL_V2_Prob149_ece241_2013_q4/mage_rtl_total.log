                fr0 = 1'b1;
                // dfr logic will be applied below
            end
            // Between s[1] and s[0]: s[0] is 1 -> s == 3'b001
            else if (s == 3'b001) begin
                fr2 = 1'b0;
                fr1 = 1'b1;
                fr0 = 1'b1;
                // dfr logic will be applied below
            end
            // Below s[0]: None -> s == 3'b000
            else if (s == 3'b000) begin
                fr2 = 1'b1;
                fr1 = 1'b1;
                fr0 = 1'b1;
                // dfr logic will be applied below
            end
            else begin
