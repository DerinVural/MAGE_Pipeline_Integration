        next_state = current_state;
        case (current_state) 
            STATE_RESET: begin
                if (x == 1'b1) 
                    next_state = STATE_1;
                else 
                    next_state = STATE_RESET;
            end
            STATE_1: begin
                if (x == 1'b1) 
                    next_state = STATE_1;
                else if (x == 1'b0) 
                    next_state = STATE_10;
                else
                    next_state = STATE_1;
            end
            STATE_10: begin
                if (x == 1'b1) 
                    next_state = STATE_1; // Overlap: '101' -> last '1' is start of new sequence
                else if (x == 1'b0) 
                    next_state = STATE_RESET;
                else
                    next_state = STATE_10;
            end
            default: begin
                next_state = STATE_RESET;
            end
        endcase
    end

    // Combinational logic: Mealy Output
    // Output z is 1 when in STATE_10 and input x is 1
    always @(*) begin
        if (current_state == STATE_10 && x == 1'b1) begin
            z = 1'b1;
        end else begin
            z = 1'b0;
        end
    end

endmodule
