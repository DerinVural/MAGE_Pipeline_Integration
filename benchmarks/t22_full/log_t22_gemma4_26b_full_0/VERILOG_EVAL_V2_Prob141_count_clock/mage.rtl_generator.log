    logic       p_reg;

    // Sequential logic for time keeping
    always @(posedge clk) begin
        if (reset) begin
            s_reg <= 6'd0;
            m_reg <= 6'd0;
            h_reg <= 4'd12;
            p_reg <= 1'b0;
        end else if (ena) begin
            if (s_reg == 6'd59) begin
                s_reg <= 6'd0;
                if (m_reg == 6'd59) begin
                    m_reg <= 6'd0;
                    if (h_reg == 4'd12) begin
                        h_reg <= 4'd1;
                        // 12:59:59 -> 01:00:00. No PM toggle.
                    end else if (h_reg == 4'd11) begin
                        h_reg <= 4'd12;
                        p_reg <= ~p_reg; // 11:59:59 -> 12:00:00 triggers PM toggle
                    end else begin
                        h_reg <= h_reg + 4'd1;
                    end
                end else begin
                    m_reg <= m_reg + 6'd1;
                end
            end else begin
                s_reg <= s_reg + 6'd1;
            end
        end
    end

    // BCD conversion logic
    always @(*) begin
        // Seconds
        ss[7:4] = 4'd(s_reg / 10);
        ss[3:0] = 4'd(s_reg % 10);

        // Minutes
        mm[7:4] = 4'd(m_reg / 10);
        mm[3:0] = 4'd(m_reg % 10);

        // Hours
        hh[7:4] = 4'd(h_reg / 10);
        hh[3:0] = 4'd(h_reg % 10);

        // PM indicator
        pm = p_reg;
    end

endmodule
